// parse_decl_const_eval.b - const expression evaluation helpers

import std.io;
import std.vec;
import std.util;
import std.str;
import module_utils;
import types;
import lexer;
import ast;
import compiler;
import compiler.core_utils;
import compiler.generic.engine;
import compiler.enum_runtime;
import compiler.symbol_runtime;
import parser.util;
import parser.type;
import parser.expr;
import parser.stmt;

func const_eval_expr(p: *Parser, node: *AstNode, ok: *u64) -> u64 {
    if (node == 0) {
        *ok = 0;
        return 0;
    }

    var kind: u64 = ast_kind(node);
    match (kind) {
        case AST_LITERAL:
            return ((*AstLiteral)node).value;
        case AST_IDENT:
            var id: *AstIdent = (*AstIdent)node;
            var cres: *ConstResult = (*ConstResult)sym_find_const(id.name);
            if (cres != 0 && cres.found != 0) {
                return cres.value;
            }
            diag_emit_error_tag("parse", "P1669", "Unknown const in const expression");
            diag_emit_labelled_name("const: ", id.name);
            *ok = 0;
            return 0;
        case AST_MEMBER_ACCESS:
            var ma: *AstMemberAccess = (*AstMemberAccess)node;
            var scope_ptr: u64 = 0;
            var scope_len: u64 = 0;
            if (u8_slice_ptr(ma.parent) != 0 && u8_slice_len(ma.parent) != 0) {
                scope_ptr = u8_slice_ptr(ma.parent);
                scope_len = u8_slice_len(ma.parent);
            } else {
                if (ast_kind(ma.object) != AST_IDENT) {
                    diag_emit_error_tag("parse", "P1670", "Unsupported member access in const expression");
                    *ok = 0;
                    return 0;
                }
                var sid: *AstIdent = (*AstIdent)ma.object;
                scope_ptr = u8_slice_ptr(sid.name);
                scope_len = u8_slice_len(sid.name);
            }
            var scoped: *ConstResult = (*ConstResult)sym_find_scoped_const(slice(scope_ptr, scope_len), ma.member);
            if (scoped != 0 && scoped.found != 0) {
                return scoped.value;
            }
            diag_emit_error_tag("parse", "P1671", "Unknown scoped const in const expression");
            diag_emit_labelled_member("member: ", slice(scope_ptr, scope_len), ma.member);
            *ok = 0;
            return 0;
        case AST_CAST:
            var cast_node: *AstCast = (*AstCast)node;
            return const_eval_expr(p, cast_node.expr, ok);
        case AST_UNARY:
            var un: *AstUnary = (*AstUnary)node;
            var sub_ok: u64 = 1;
            var val: u64 = const_eval_expr(p, un.operand, &sub_ok);
            if (sub_ok == 0) {
                *ok = 0;
                return 0;
            }
            match (un.op) {
                case TOKEN_MINUS:
                    return 0 - val;
                case TOKEN_BANG:
                    if (val == 0) { return 1; }
                    return 0;
                case TOKEN_TILDE:
                    return ~val;
                default:
                    diag_emit_error_tag("parse", "P1672", "Unsupported unary operator in const expression");
                    *ok = 0;
                    return 0;
            }
        case AST_BINARY:
            var bin: *AstBinary = (*AstBinary)node;
            var left_ok: u64 = 1;
            var right_ok: u64 = 1;
            var left: u64 = const_eval_expr(p, bin.left, &left_ok);
            var right: u64 = const_eval_expr(p, bin.right, &right_ok);
            if (left_ok == 0 || right_ok == 0) {
                *ok = 0;
                return 0;
            }
            match (bin.op) {
                case TOKEN_PLUS: return left + right;
                case TOKEN_MINUS: return left - right;
                case TOKEN_STAR: return left * right;
                case TOKEN_SLASH:
                    if (right == 0) {
                        parse_fail_here_code(p, "P1673", "Division by zero in const expression");
                    }
                    return left / right;
                case TOKEN_PERCENT:
                    if (right == 0) {
                        parse_fail_here_code(p, "P1674", "Modulo by zero in const expression");
                    }
                    return left % right;
                case TOKEN_AMPERSAND: return left & right;
                case TOKEN_PIPE: return left | right;
                case TOKEN_CARET: return left ^ right;
                case TOKEN_LSHIFT: return left << right;
                case TOKEN_RSHIFT: return left >> right;
                case TOKEN_EQEQ:
                    if (left == right) { return 1; }
                    return 0;
                case TOKEN_BANGEQ:
                    if (left != right) { return 1; }
                    return 0;
                case TOKEN_LT:
                    if (left < right) { return 1; }
                    return 0;
                case TOKEN_LTEQ:
                    if (left <= right) { return 1; }
                    return 0;
                case TOKEN_GT:
                    if (left > right) { return 1; }
                    return 0;
                case TOKEN_GTEQ:
                    if (left >= right) { return 1; }
                    return 0;
                case TOKEN_ANDAND:
                    if (left != 0 && right != 0) { return 1; }
                    return 0;
                case TOKEN_OROR:
                    if (left != 0 || right != 0) { return 1; }
                    return 0;
                default:
                    diag_emit_error_tag("parse", "P1675", "Unsupported binary operator in const expression");
                    *ok = 0;
                    return 0;
            }
        case AST_TERNARY:
            var tern: *AstTernary = (*AstTernary)node;
            var cond_ok: u64 = 1;
            var cond_val: u64 = const_eval_expr(p, tern.cond, &cond_ok);
            if (cond_ok == 0) {
                *ok = 0;
                return 0;
            }
            if (cond_val != 0) {
                return const_eval_expr(p, tern.then_expr, ok);
            }
            return const_eval_expr(p, tern.else_expr, ok);
        default:
            diag_emit_error_tag("parse", "P1676", "Const expression must be compile-time evaluable");
            *ok = 0;
            return 0;
    }
}

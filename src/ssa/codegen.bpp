func emit_inst_try_cmp(op: u64, inst: *SSAInstruction) -> u64 {
    if (op == SSA_OP_EQ) { emit_cmp_setcc("e", 1, inst.dest, inst.src1, inst.src2); return 1; }
    if (op == SSA_OP_NE) { emit_cmp_setcc("ne", 2, inst.dest, inst.src1, inst.src2); return 1; }
    if (op == SSA_OP_LT) { emit_cmp_setcc("l", 1, inst.dest, inst.src1, inst.src2); return 1; }
    if (op == SSA_OP_GT) { emit_cmp_setcc("g", 1, inst.dest, inst.src1, inst.src2); return 1; }
    if (op == SSA_OP_LE) { emit_cmp_setcc("le", 2, inst.dest, inst.src1, inst.src2); return 1; }
    if (op == SSA_OP_GE) { emit_cmp_setcc("ge", 2, inst.dest, inst.src1, inst.src2); return 1; }
    if (op == SSA_OP_ULT) { emit_cmp_setcc("b", 1, inst.dest, inst.src1, inst.src2); return 1; }
    if (op == SSA_OP_UGT) { emit_cmp_setcc("a", 1, inst.dest, inst.src1, inst.src2); return 1; }
    if (op == SSA_OP_ULE) { emit_cmp_setcc("be", 2, inst.dest, inst.src1, inst.src2); return 1; }
    if (op == SSA_OP_UGE) { emit_cmp_setcc("ae", 2, inst.dest, inst.src1, inst.src2); return 1; }
    return 0;
}

func emit_inst(fn_id: u64, inst: *SSAInstruction) -> u64 {
    push_trace("emit_inst", "ssa_codegen.b", __LINE__);
    defer pop_trace();
    var op: u64 = op_of(inst);

    if (op == SSA_OP_NOP || op == SSA_OP_ENTRY || op == SSA_OP_PHI) { return 0; }
    if (op == SSA_OP_CONST || op == SSA_OP_COPY) {
        emit_mov_reg_opr(inst.dest, inst.src1);

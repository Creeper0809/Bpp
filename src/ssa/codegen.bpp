    if ((save_mask & SSA_LIVE_RDX) != 0) { emit_restore_reg(dest, SSA_PHYS_RDX); }
    if ((save_mask & SSA_LIVE_RCX) != 0) { emit_restore_reg(dest, SSA_PHYS_RCX); }
    if ((save_mask & SSA_LIVE_RBX) != 0) { emit_restore_reg(dest, SSA_PHYS_RBX); }
    if ((save_mask & SSA_LIVE_RAX) != 0) { emit_restore_reg(dest, SSA_PHYS_RAX); }
    return 0;
}


func emit_asm_with_save(text_vec: *Vec<u64>, live_mask: u64) -> u64 {
    var all_mask: u64 = live_all_mask();
    var save_mask: u64 = live_mask & all_mask;

    if ((save_mask & SSA_LIVE_RAX) != 0) { emit_push_reg(SSA_PHYS_RAX); }
    if ((save_mask & SSA_LIVE_RBX) != 0) { emit_push_reg(SSA_PHYS_RBX); }
    if ((save_mask & SSA_LIVE_RCX) != 0) { emit_push_reg(SSA_PHYS_RCX); }
    if ((save_mask & SSA_LIVE_RDX) != 0) { emit_push_reg(SSA_PHYS_RDX); }
    if ((save_mask & SSA_LIVE_R8) != 0) { emit_push_reg(SSA_PHYS_R8); }
    if ((save_mask & SSA_LIVE_R9) != 0) { emit_push_reg(SSA_PHYS_R9); }
    if ((save_mask & SSA_LIVE_R10) != 0) { emit_push_reg(SSA_PHYS_R10); }
    if ((save_mask & SSA_LIVE_R11) != 0) { emit_push_reg(SSA_PHYS_R11); }

    emit_asm_text_with_alias(text_vec);

    if ((save_mask & SSA_LIVE_R11) != 0) { emit_restore_reg(0, SSA_PHYS_R11); }
    if ((save_mask & SSA_LIVE_R10) != 0) { emit_restore_reg(0, SSA_PHYS_R10); }
    if ((save_mask & SSA_LIVE_R9) != 0) { emit_restore_reg(0, SSA_PHYS_R9); }
    if ((save_mask & SSA_LIVE_R8) != 0) { emit_restore_reg(0, SSA_PHYS_R8); }
    if ((save_mask & SSA_LIVE_RDX) != 0) { emit_restore_reg(0, SSA_PHYS_RDX); }
    if ((save_mask & SSA_LIVE_RCX) != 0) { emit_restore_reg(0, SSA_PHYS_RCX); }
    if ((save_mask & SSA_LIVE_RBX) != 0) { emit_restore_reg(0, SSA_PHYS_RBX); }
    if ((save_mask & SSA_LIVE_RAX) != 0) { emit_restore_reg(0, SSA_PHYS_RAX); }
    return 0;
}


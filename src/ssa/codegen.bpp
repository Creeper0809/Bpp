func expr_is_large_struct_call(expr: *AstNode) -> u64 {
    if (expr == 0) { return false; }
    var nref: AstNodeTagRef = node_ref(expr);
    var kind: u64 = ast_kind(expr);
    if (kind == AST_CALL) { return call_returns_large_struct(nref.call); }
    if (kind == AST_CALL_PTR) { return call_ptr_returns_large_struct(nref.call_ptr); }
    return false;
}


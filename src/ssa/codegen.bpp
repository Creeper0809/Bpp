        case AST_BLOCK:
            return stmt_supported_block(nref.block_stmt, globals);
        case AST_IF:
            return stmt_supported_if(nref.if_stmt, globals);
        case AST_WHILE:
            return stmt_supported_while(nref.while_stmt, globals);
        case AST_FOR:
            return stmt_supported_for(nref.for_stmt, globals);
        case AST_SWITCH:
        case AST_MATCH:
            return stmt_supported_switch(nref.switch_stmt, globals);
        case AST_ASM: return true;
        case AST_ALIAS: return true;
        case AST_DEFER:
            var df: *AstDefer = nref.defer_stmt;
            if (df == 0 || df.stmt == 0) { return true; }
            return stmt_supported(df.stmt, globals);
        case AST_DELETE:
            var dl: *AstDelete = nref.delete_stmt;
            if (dl == 0 || dl.expr == 0) { return true; }
            return expr_supported(dl.expr, globals);
        case AST_EXPR_STMT:
            return stmt_supported_expr_stmt(nref.expr_stmt, globals);
        case AST_VAR_DECL:
            return stmt_supported_var_decl(nref.var_decl, globals);
        case AST_CONST_DECL:
            return expr_supported(ast_literal(nref.const_decl.value), globals);
        case AST_ASSIGN:
            return stmt_supported_assign(nref.assign_stmt, globals);
        case AST_RETURN:
            return stmt_supported_return(nref.ret_stmt, globals);

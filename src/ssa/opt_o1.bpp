const SSA_TAG_SUMMARY_HAS_INDIRECT_CALL = 2;
const SSA_TAG_SUMMARY_HAS_HEAP_ALLOC = 4;
const SSA_TAG_SUMMARY_HAS_TAG_PACK = 8;
const SSA_TAG_SUMMARY_HAS_TAG_AUTO = 16;

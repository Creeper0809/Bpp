var g_ssa_o1_scratch_arena: *BppScratchArena;

struct SSAOptKV {
    public key: u64;
    public val: u64;
    public active: u64;
}

impl SSAOptKV {
    public constructor() {
        self.key = 0;
        self.val = 0;
        self.active = 0;
    }
}


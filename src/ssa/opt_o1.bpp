func ssa_o1_alloc_kv() -> *SSAOptKV {
    if (g_ssa_o1_scratch_arena != 0) {
        return (*SSAOptKV)bpp_scratch_arena_alloc_zero(g_ssa_o1_scratch_arena, sizeof(SSAOptKV));
    }
    return new SSAOptKV{};
}


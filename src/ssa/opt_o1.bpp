        if (c_len.has != 0) { return opt_set_const(cur, ssa_tag_len_class(c_len.val), reg_consts); }
    }
    if (ssa_tag_name_eq(name, "std_mem__bpp_fast_path_for_shape_len", 36) != 0 && info.nargs >= 5) {
        var c_shape2: SSAOptConstValue = ssa_call_arg_const(info, 0, reg_consts);
        var c_hot: SSAOptConstValue = ssa_call_arg_const(info, 1, reg_consts);
        var c_profiled: SSAOptConstValue = ssa_call_arg_const(info, 2, reg_consts);
        var c_elem2: SSAOptConstValue = ssa_call_arg_const(info, 3, reg_consts);
        var c_len2: SSAOptConstValue = ssa_call_arg_const(info, 4, reg_consts);
        if (c_shape2.has != 0 && c_hot.has != 0 && c_profiled.has != 0 && c_elem2.has != 0 && c_len2.has != 0) {
            return opt_set_const(cur, ssa_tag_fast_path_for(c_shape2.val, c_hot.val, c_profiled.val, c_elem2.val, c_len2.val), reg_consts);
        }
    }
    if (ssa_tag_name_eq(name, "std_mem__bpp_fast_path_for_shape", 32) != 0 && info.nargs >= 4) {
        var c_shape3: SSAOptConstValue = ssa_call_arg_const(info, 0, reg_consts);
        var c_hot2: SSAOptConstValue = ssa_call_arg_const(info, 1, reg_consts);
        var c_profiled2: SSAOptConstValue = ssa_call_arg_const(info, 2, reg_consts);
        var c_elem3: SSAOptConstValue = ssa_call_arg_const(info, 3, reg_consts);
        if (c_shape3.has != 0 && c_hot2.has != 0 && c_profiled2.has != 0 && c_elem3.has != 0) {
            var len: u64 = ssa_tag_vector_lanes(c_shape3.val, c_elem3.val);
            return opt_set_const(cur, ssa_tag_fast_path_for(c_shape3.val, c_hot2.val, c_profiled2.val, c_elem3.val, len), reg_consts);
        }
    }
    if (ssa_tag_name_eq(name, "std_mem__bpp_profile_hot_from_threshold", str_len("std_mem__bpp_profile_hot_from_threshold")) != 0 && info.nargs >= 2) {
        var c_iterations: SSAOptConstValue = ssa_call_arg_const(info, 0, reg_consts);
        var c_threshold: SSAOptConstValue = ssa_call_arg_const(info, 1, reg_consts);
        if (c_iterations.has != 0 && c_threshold.has != 0) {
            return opt_set_const(cur, ssa_tag_profile_hot_from_threshold(c_iterations.val, c_threshold.val), reg_consts);
        }
    }
    if (ssa_tag_name_eq(name, "std_mem__bpp_profile_fast_path_for_shape_len", str_len("std_mem__bpp_profile_fast_path_for_shape_len")) != 0 && info.nargs >= 9) {
        var c_p_shape: SSAOptConstValue = ssa_call_arg_const(info, 0, reg_consts);
        var c_p_profiled: SSAOptConstValue = ssa_call_arg_const(info, 1, reg_consts);
        var c_p_elem: SSAOptConstValue = ssa_call_arg_const(info, 2, reg_consts);
        var c_p_len: SSAOptConstValue = ssa_call_arg_const(info, 3, reg_consts);
        var c_p_iters: SSAOptConstValue = ssa_call_arg_const(info, 4, reg_consts);
        var c_p_hot_threshold: SSAOptConstValue = ssa_call_arg_const(info, 5, reg_consts);
        var c_p_vector_min: SSAOptConstValue = ssa_call_arg_const(info, 6, reg_consts);
        var c_p_unroll_min: SSAOptConstValue = ssa_call_arg_const(info, 7, reg_consts);
        var c_p_max_lanes: SSAOptConstValue = ssa_call_arg_const(info, 8, reg_consts);
        if (c_p_shape.has != 0 && c_p_profiled.has != 0 && c_p_elem.has != 0 && c_p_len.has != 0 && c_p_iters.has != 0 && c_p_hot_threshold.has != 0 && c_p_vector_min.has != 0 && c_p_unroll_min.has != 0 && c_p_max_lanes.has != 0) {
            return opt_set_const(cur, ssa_tag_fast_path_for_tuned(c_p_shape.val, c_p_profiled.val, c_p_elem.val, c_p_len.val, c_p_iters.val, c_p_hot_threshold.val, c_p_vector_min.val, c_p_unroll_min.val, c_p_max_lanes.val), reg_consts);
        }
    }
    if (ssa_tag_name_eq(name, "std_mem__bpp_shape_inline_cache_fast_path", str_len("std_mem__bpp_shape_inline_cache_fast_path")) != 0 && info.nargs >= 11) {
        var c_i_shape: SSAOptConstValue = ssa_call_arg_const(info, 0, reg_consts);
        var c_i_profiled: SSAOptConstValue = ssa_call_arg_const(info, 1, reg_consts);
        var c_i_elem: SSAOptConstValue = ssa_call_arg_const(info, 2, reg_consts);
        var c_i_len: SSAOptConstValue = ssa_call_arg_const(info, 3, reg_consts);
        var c_i_iters: SSAOptConstValue = ssa_call_arg_const(info, 4, reg_consts);
        var c_i_hot_threshold: SSAOptConstValue = ssa_call_arg_const(info, 5, reg_consts);
        var c_i_hits: SSAOptConstValue = ssa_call_arg_const(info, 6, reg_consts);
        var c_i_hot_hits: SSAOptConstValue = ssa_call_arg_const(info, 7, reg_consts);
        var c_i_vector_min: SSAOptConstValue = ssa_call_arg_const(info, 8, reg_consts);
        var c_i_unroll_min: SSAOptConstValue = ssa_call_arg_const(info, 9, reg_consts);
        var c_i_max_lanes: SSAOptConstValue = ssa_call_arg_const(info, 10, reg_consts);
        if (c_i_shape.has != 0 && c_i_profiled.has != 0 && c_i_elem.has != 0 && c_i_len.has != 0 && c_i_iters.has != 0 && c_i_hot_threshold.has != 0 && c_i_hits.has != 0 && c_i_hot_hits.has != 0 && c_i_vector_min.has != 0 && c_i_unroll_min.has != 0 && c_i_max_lanes.has != 0) {
            return opt_set_const(cur, ssa_tag_inline_cache_fast_path(c_i_shape.val, c_i_profiled.val, c_i_elem.val, c_i_len.val, c_i_iters.val, c_i_hot_threshold.val, c_i_hits.val, c_i_hot_hits.val, c_i_vector_min.val, c_i_unroll_min.val, c_i_max_lanes.val), reg_consts);
        }
    }
    return 0;
}

func ssa_o1_direct_call_preserves_local_memory(cur: *SSAInstruction) -> u64 {
    if (cur == 0 || op_of(cur) != SSA_OP_CALL) { return 0; }
    var info: *SSACallInfo = (*SSACallInfo)operand_value(cur.src1);
    if (info == 0) { return 0; }
    var name: []u8 = info.name;
    if (ssa_tag_call_name_is_pack(name) != 0) { return 1; }
    if (ssa_tag_call_name_is_strip(name) != 0) { return 1; }
    if (ssa_tag_call_name_is_object_from_raw(name) != 0) { return 1; }
    if (ssa_tag_call_name_is_object_auto(name) != 0) { return 1; }
    if (ssa_tag_call_name_is_stack_alloc_auto_from_raw(name) != 0) { return 1; }
    if (ssa_tag_call_name_is_slice_from_ptr(name) != 0) { return 1; }
    if (ssa_tag_call_name_is_slice_from_raw_tag(name) != 0) { return 1; }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_lifecycle_raw", 30) != 0) { return 1; }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_ownership_raw", 30) != 0) { return 1; }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_storage_raw", 28) != 0) { return 1; }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_barrier_raw", 28) != 0) { return 1; }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_shape_raw", 26) != 0) { return 1; }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_profiled_raw", 29) != 0) { return 1; }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_delete_allowed_raw", 35) != 0) { return 1; }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_can_skip_refcount_raw", 38) != 0) { return 1; }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_refcount_retain_needed_raw", 43) != 0) { return 1; }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_refcount_release_needed_raw", 44) != 0) { return 1; }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_can_skip_gc_barrier_raw", 40) != 0) { return 1; }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_gc_barrier_needed_raw", 38) != 0) { return 1; }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_repack_lifecycle_barrier", 41) != 0) { return 1; }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_repack_shape_profiled", 38) != 0) { return 1; }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_mark_barrier_dirty_raw", 39) != 0) { return 1; }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_write_barrier_raw", 34) != 0) { return 1; }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_len_class", 26) != 0) { return 1; }
    if (ssa_tag_name_has_prefix(name, "std_mem__bpp_shape_", 19) != 0) { return 1; }
    if (ssa_tag_name_has_prefix(name, "std_mem__bpp_fast_path_", 23) != 0) { return 1; }
    if (ssa_tag_name_has_prefix(name, "std_mem__bpp_profile_", str_len("std_mem__bpp_profile_")) != 0) { return 1; }
    if (ssa_tag_name_has_prefix(name, "std_mem__bpp_vector_", 20) != 0) { return 1; }
    return 0;
}

func ssa_tag_record_lifetime_proof(summary: *SSAOptEscapeSummary, tag_states: *Vec<*SSAOptTagState>, reg: u64) -> u64 {
    if (summary == 0 || tag_states == 0 || reg == 0) { return 0; }
    var state: *SSAOptTagState = ssa_tag_state_find(tag_states, reg);
    if (state == 0) { return 0; }
    if ((state.has_bits & (SSA_TAG_HAS_LIFE | SSA_TAG_HAS_OWN | SSA_TAG_HAS_STORAGE)) != (SSA_TAG_HAS_LIFE | SSA_TAG_HAS_OWN | SSA_TAG_HAS_STORAGE)) { return 0; }
    if (state.storage == SSA_TAG_STORAGE_STACK || state.storage == SSA_TAG_STORAGE_ARENA || state.storage == SSA_TAG_STORAGE_STATIC ||
        state.ownership == SSA_TAG_OWN_STACK || state.ownership == SSA_TAG_OWN_BORROWED || state.lifecycle == SSA_TAG_LIFE_BORROWED ||
        state.lifecycle == SSA_TAG_LIFE_ARENA || state.lifecycle == SSA_TAG_LIFE_IMMORTAL) {
        summary.lifetime_proof_count = summary.lifetime_proof_count + 1;
        return 1;
    }
    return 0;
}

func handle_tag_call(cur: *SSAInstruction, reg_consts: *Vec<*SSAOptKV>, raw_ptr_regs: *Vec<*SSAOptKV>, tag_states: *Vec<*SSAOptTagState>, summary: *SSAOptEscapeSummary) -> u64 {
    if (op_of(cur) != SSA_OP_CALL) { return 0; }
    var info: *SSACallInfo = (*SSACallInfo)operand_value(cur.src1);
    if (info == 0) { return 0; }
    var name: []u8 = info.name;
    if (summary != 0) { summary.has_call = 1; }

    if (ssa_tag_call_name_is_heap_alloc(name) != 0) {
        if (cur.dest != 0) {
            raw_ptr_set(raw_ptr_regs, cur.dest);
            ssa_tag_state_clear(tag_states, cur.dest);
        }
        if (summary != 0) { summary.has_heap_alloc = 1; }
        return 1;
    }
    if (summary != 0 && ssa_tag_call_name_has_heap_allocation(name) != 0) {
        summary.has_heap_alloc = 1;
    }

    if (ssa_tag_call_name_is_pack(name) != 0) {
        if (summary != 0) { summary.has_tag_pack = 1; summary.has_tagged_access = 1; }
        var did_pack: u64 = ssa_tag_record_pack_result(cur, info, reg_consts, raw_ptr_regs, tag_states);
        if (did_pack != 0 && summary != 0) { summary.pack_count = summary.pack_count + 1; }
        return did_pack;
    }

    if (ssa_tag_call_name_is_object_from_raw(name) != 0) {
        if (summary != 0) { summary.has_tag_pack = 1; summary.has_tagged_access = 1; }
        var did_obj_raw: u64 = ssa_tag_record_object_from_raw(cur, info, reg_consts, raw_ptr_regs, tag_states);
        if (did_obj_raw != 0 && summary != 0) {
            summary.pack_count = summary.pack_count + 1;
            ssa_tag_record_lifetime_proof(summary, tag_states, cur.dest);
        }
        return did_obj_raw;
    }

    if (ssa_tag_call_name_is_object_auto(name) != 0) {
        if (summary != 0) { summary.has_tag_auto = 1; summary.has_tagged_access = 1; }
        var did_obj_auto: u64 = ssa_tag_record_object_auto(cur, info, ssa_tag_object_auto_elem_size(name), reg_consts, raw_ptr_regs, tag_states);
        if (did_obj_auto != 0 && summary != 0) {
            summary.pack_count = summary.pack_count + 1;
            ssa_tag_record_lifetime_proof(summary, tag_states, cur.dest);
        }
        return did_obj_auto;
    }

    if (ssa_tag_call_name_is_stack_alloc_auto_from_raw(name) != 0) {
        if (summary != 0) { summary.has_tag_auto = 1; summary.has_tagged_access = 1; }
        var did_stack_auto: u64 = ssa_tag_record_stack_alloc_auto_from_raw(cur, info, reg_consts, raw_ptr_regs, tag_states);
        if (did_stack_auto != 0 && summary != 0) {
            summary.pack_count = summary.pack_count + 1;
            ssa_tag_record_lifetime_proof(summary, tag_states, cur.dest);
        }
        return did_stack_auto;
    }

    if (ssa_tag_call_name_is_slice_from_ptr(name) != 0) {
        if (summary != 0) { summary.has_tagged_access = 1; }
        var did_slice_ptr: u64 = ssa_tag_record_slice_from_ptr(cur, info, reg_consts, raw_ptr_regs, tag_states);
        if (did_slice_ptr != 0 && summary != 0) { summary.pack_count = summary.pack_count + 1; }
        return did_slice_ptr;
    }

    if (ssa_tag_call_name_is_slice_from_raw_tag(name) != 0) {
        if (summary != 0) { summary.has_tagged_access = 1; }
        var did_slice_raw: u64 = ssa_tag_record_slice_from_raw_tag(cur, info, reg_consts, raw_ptr_regs, tag_states);
        if (did_slice_raw != 0 && summary != 0) { summary.pack_count = summary.pack_count + 1; }
        return did_slice_raw;
    }

    if (ssa_tag_call_name_is_strip(name) != 0 && info.nargs >= 1 && cur.dest != 0) {
        var arg0: u64 = ssa_call_arg(info, 0);
        var c_arg0: SSAOptConstValue = reg_const_value(reg_consts, arg0);
        if (c_arg0.has != 0) {
            var did_strip_const: u64 = ssa_tag_try_const_from_raw(cur, c_arg0.val, reg_consts, tag_states);
            if (did_strip_const != 0 && summary != 0) { ssa_tag_summary_record_fold(summary); summary.raw_elision_count = summary.raw_elision_count + 1; }
            return did_strip_const;
        }
        var state: *SSAOptTagState = ssa_tag_state_find(tag_states, arg0);
        if (state != 0 && state.raw_const_has != 0) {
            var did_strip_state_const: u64 = ssa_tag_try_const_from_raw(cur, state.raw_const, reg_consts, tag_states);
            if (did_strip_state_const != 0 && summary != 0) { ssa_tag_summary_record_fold(summary); summary.raw_elision_count = summary.raw_elision_count + 1; }
            return did_strip_state_const;
        }
        if (state != 0 && state.raw_reg != 0 && raw_ptr_get(raw_ptr_regs, state.raw_reg) != 0) {
            raw_ptr_set(raw_ptr_regs, cur.dest);
            ssa_tag_state_clear(tag_states, cur.dest);
            var did_strip_copy: u64 = opt_set_copy(cur, operand_reg(state.raw_reg), reg_consts);
            if (did_strip_copy != 0 && summary != 0) { ssa_tag_summary_record_fold(summary); summary.raw_elision_count = summary.raw_elision_count + 1; }
            return did_strip_copy;
        }
        if (raw_ptr_get(raw_ptr_regs, arg0) != 0) {
            raw_ptr_set(raw_ptr_regs, cur.dest);
            ssa_tag_state_clear(tag_states, cur.dest);
            var did_strip_raw_copy: u64 = opt_set_copy(cur, operand_reg(arg0), reg_consts);
            if (did_strip_raw_copy != 0 && summary != 0) { ssa_tag_summary_record_fold(summary); summary.raw_elision_count = summary.raw_elision_count + 1; }
            return did_strip_raw_copy;
        }
    }

    if (info.nargs >= 1 && ssa_tag_fold_field_call(cur, name, ssa_call_arg(info, 0), reg_consts, tag_states) != 0) {
        if (summary != 0) { summary.has_tagged_access = 1; ssa_tag_summary_record_fold(summary); summary.predicate_fold_count = summary.predicate_fold_count + 1; }
        return 1;
    }
    if (ssa_tag_fold_lifecycle_predicate(cur, name, info, reg_consts, tag_states) != 0) {
        if (summary != 0) { summary.has_tagged_access = 1; ssa_tag_summary_record_fold(summary); summary.predicate_fold_count = summary.predicate_fold_count + 1; }
        return 1;
    }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_gc_barrier_needed_raw", 38) != 0) {
        if (summary != 0) { summary.has_tagged_access = 1; }
        var did_gc: u64 = ssa_tag_fold_gc_barrier_call(cur, info, reg_consts, tag_states);
        if (did_gc != 0 && summary != 0) { ssa_tag_summary_record_fold(summary); summary.predicate_fold_count = summary.predicate_fold_count + 1; }
        return did_gc;
    }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_repack_lifecycle_barrier", 41) != 0 || ssa_tag_name_eq(name, "std_mem__bpp_tag_repack_shape_profiled", 38) != 0) {
        if (summary != 0) { summary.has_tagged_access = 1; }
        var did_repack: u64 = ssa_tag_fold_repack_call(cur, name, info, reg_consts, tag_states);
        if (did_repack != 0 && summary != 0) { summary.pack_count = summary.pack_count + 1; }
        return did_repack;
    }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_mark_barrier_dirty_raw", 39) != 0) {
        if (summary != 0) { summary.has_tagged_access = 1; }
        var did_dirty: u64 = ssa_tag_fold_mark_barrier_dirty_call(cur, info, reg_consts, tag_states);
        if (did_dirty != 0 && summary != 0) { ssa_tag_summary_record_fold(summary); summary.predicate_fold_count = summary.predicate_fold_count + 1; }
        return did_dirty;
    }
    if (ssa_tag_name_eq(name, "std_mem__bpp_tag_write_barrier_raw", 34) != 0) {
        if (summary != 0) { summary.has_tagged_access = 1; }
        var did_write_barrier: u64 = ssa_tag_fold_write_barrier_call(cur, info, reg_consts, raw_ptr_regs, tag_states);
        if (did_write_barrier != 0 && summary != 0) { ssa_tag_summary_record_fold(summary); summary.predicate_fold_count = summary.predicate_fold_count + 1; }
        return did_write_barrier;
    }
    if (ssa_tag_fold_fastpath_call(cur, name, info, reg_consts) != 0) {
        if (summary != 0) {
            summary.has_tagged_access = 1;
            ssa_tag_summary_record_fold(summary);
            summary.hot_path_fold_count = summary.hot_path_fold_count + 1;
            if (ssa_tag_name_eq(name, "std_mem__bpp_profile_hot_from_threshold", str_len("std_mem__bpp_profile_hot_from_threshold")) != 0 ||
                ssa_tag_name_eq(name, "std_mem__bpp_profile_fast_path_for_shape_len", str_len("std_mem__bpp_profile_fast_path_for_shape_len")) != 0) {
                summary.profile_fold_count = summary.profile_fold_count + 1;
            }
            if (ssa_tag_name_eq(name, "std_mem__bpp_shape_inline_cache_fast_path", str_len("std_mem__bpp_shape_inline_cache_fast_path")) != 0) {
                summary.inline_cache_fold_count = summary.inline_cache_fold_count + 1;
            }
        }
        return 1;
    }

    if (cur.dest != 0) {
        const_clear(reg_consts, cur.dest);
        raw_ptr_clear(raw_ptr_regs, cur.dest);
        ssa_tag_state_clear(tag_states, cur.dest);
    }
    return 1;
}

func run_block(b: *SSABlock, summary: *SSAOptEscapeSummary) -> u64 {
    var scratch_mark: BppScratchArenaMark;
    bpp_scratch_arena_mark_into(g_ssa_o1_scratch_arena, &scratch_mark);
    var reg_consts: *Vec<*SSAOptKV> = vec_new_scratch<*SSAOptKV>(g_ssa_o1_scratch_arena, 32);
    var var_consts: *Vec<*SSAOptKV> = vec_new_scratch<*SSAOptKV>(g_ssa_o1_scratch_arena, 32);
    var raw_ptr_regs: *Vec<*SSAOptKV> = vec_new_scratch<*SSAOptKV>(g_ssa_o1_scratch_arena, 32);
    var tag_states: *Vec<*SSAOptTagState> = vec_new_scratch<*SSAOptTagState>(g_ssa_o1_scratch_arena, 32);
    var local_addrs: *Vec<*SSAOptKV> = vec_new_scratch<*SSAOptKV>(g_ssa_o1_scratch_arena, 32);
    var local_mem: *Vec<*SSAOptKV> = vec_new_scratch<*SSAOptKV>(g_ssa_o1_scratch_arena, 32);
    var local_stores: *Vec<*SSAOptKV> = vec_new_scratch<*SSAOptKV>(g_ssa_o1_scratch_arena, 32);
    var exprs: *Vec<*SSAOptExprVN> = vec_new_scratch<*SSAOptExprVN>(g_ssa_o1_scratch_arena, 32);

    var cur: *SSAInstruction = b.inst_head;
    while (cur != 0) {
        var op: u64 = op_of(cur);

        if (op == SSA_OP_CONST) {
            const_set(reg_consts, cur.dest, operand_value(cur.src1));
            raw_ptr_clear(raw_ptr_regs, cur.dest);
            ssa_tag_state_clear(tag_states, cur.dest);
            ssa_sroa_local_addr_clear(local_addrs, cur.dest);
            cur = cur.next;
            continue;
        }

        if (op == SSA_OP_LEA_LOCAL) {
            if (cur.dest != 0 && operand_is_const(cur.src1) != 0) {
                const_clear(reg_consts, cur.dest);
                raw_ptr_set(raw_ptr_regs, cur.dest);
                ssa_tag_state_clear(tag_states, cur.dest);
                ssa_sroa_local_addr_set(local_addrs, cur.dest, operand_value(cur.src1));
                if (summary != 0) { summary.alias_proof_count = summary.alias_proof_count + 1; }
            }
            cur = cur.next;
            continue;
        }

        if (op == SSA_OP_LEA_GLOBAL || op == SSA_OP_LEA_FUNC) {
            if (cur.dest != 0) {
                const_clear(reg_consts, cur.dest);
                raw_ptr_set(raw_ptr_regs, cur.dest);
                ssa_tag_state_clear(tag_states, cur.dest);
                ssa_sroa_local_addr_clear(local_addrs, cur.dest);
            }
            cur = cur.next;
            continue;
        }

        if (handle_copy(cur, reg_consts, raw_ptr_regs, tag_states) != 0) {
            if (cur.dest != 0 && op_of(cur) == SSA_OP_COPY && operand_is_const(cur.src1) == 0) {
                var copied_offset: u64 = 0;
                if (ssa_sroa_local_addr_get(local_addrs, operand_value(cur.src1), &copied_offset) != 0) {
                    ssa_sroa_local_addr_set(local_addrs, cur.dest, copied_offset);
                } else {
                    ssa_sroa_local_addr_clear(local_addrs, cur.dest);
                }
            } else if (cur.dest != 0) {
                ssa_sroa_local_addr_clear(local_addrs, cur.dest);
            }
            cur = cur.next;
            continue;
        }

        if (handle_store(cur, reg_consts, var_consts) != 0) {
            cur = cur.next;
            continue;
        }

        if (handle_load(cur, reg_consts, var_consts, raw_ptr_regs, tag_states) != 0) {
            if (cur.dest != 0) { ssa_sroa_local_addr_clear(local_addrs, cur.dest); }
            cur = cur.next;
            continue;
        }

        if (handle_sroa_memory(cur, reg_consts, raw_ptr_regs, tag_states, local_addrs, local_mem, local_stores, summary) != 0) {
            cur = cur.next;
            continue;
        }

        if (handle_sroa_local_addr_add(cur, reg_consts, local_addrs) != 0) {
            const_clear(reg_consts, cur.dest);
            raw_ptr_set(raw_ptr_regs, cur.dest);
            ssa_tag_state_clear(tag_states, cur.dest);
            if (summary != 0) { summary.alias_proof_count = summary.alias_proof_count + 1; }
            cur = cur.next;
            continue;
        }

        if (op == SSA_OP_ASM) {
            ssa_sroa_mem_clear_all(local_mem);
            ssa_sroa_store_kill_all(local_stores);
            ssa_sroa_mem_clear_all(var_consts);
            cur = cur.next;
            continue;
        }

        if (op == SSA_OP_CALL_PTR || op == SSA_OP_CALL_SLICE_STORE) {
            ssa_sroa_mem_clear_all(local_mem);
            ssa_sroa_store_kill_all(local_stores);
            ssa_sroa_mem_clear_all(var_consts);
            if (cur.dest != 0) {
                const_clear(reg_consts, cur.dest);
                raw_ptr_clear(raw_ptr_regs, cur.dest);
                ssa_tag_state_clear(tag_states, cur.dest);
                ssa_sroa_local_addr_clear(local_addrs, cur.dest);
            }
            cur = cur.next;
            continue;
        }

        if (handle_foldable(cur, reg_consts, raw_ptr_regs, tag_states, exprs, summary) != 0) {
            if (cur.dest != 0) { ssa_sroa_local_addr_clear(local_addrs, cur.dest); }
            cur = cur.next;
            continue;
        }

        var direct_call_preserves_local: u64 = ssa_o1_direct_call_preserves_local_memory(cur);
        if (handle_tag_call(cur, reg_consts, raw_ptr_regs, tag_states, summary) != 0) {
            ssa_sroa_store_kill_all(local_stores);
            if (direct_call_preserves_local == 0) {
                ssa_sroa_mem_clear_all(local_mem);
            } else if (summary != 0) {
                summary.alias_proof_count = summary.alias_proof_count + 1;
            }
            ssa_sroa_mem_clear_all(var_consts);
            if (cur.dest != 0) { ssa_sroa_local_addr_clear(local_addrs, cur.dest); }
            cur = cur.next;
            continue;
        }

        if (ssa_o1_handle_control_consts(cur, reg_consts, summary) != 0) {
            cur = cur.next;
            continue;
        }

        if (cur.dest != 0) {
            const_clear(reg_consts, cur.dest);
            raw_ptr_clear(raw_ptr_regs, cur.dest);
            ssa_tag_state_clear(tag_states, cur.dest);
            ssa_sroa_local_addr_clear(local_addrs, cur.dest);
        }

        cur = cur.next;
    }

    remove_nops(b);
    if (SSA_O1_RELEASE_SCRATCH != 0) {
        reg_consts.release_buffer();
        var_consts.release_buffer();
        raw_ptr_regs.release_buffer();
        tag_states.release_buffer();
        local_addrs.release_buffer();
        local_mem.release_buffer();
        local_stores.release_buffer();
        exprs.release_buffer();
        free((u64)reg_consts);
        free((u64)var_consts);
        free((u64)raw_ptr_regs);
        free((u64)tag_states);
        free((u64)local_addrs);
        free((u64)local_mem);
        free((u64)local_stores);
        free((u64)exprs);
    }
    bpp_scratch_arena_rewind(g_ssa_o1_scratch_arena, &scratch_mark);
    return 0;
}

func ssa_tag_summarize_call_name(summary: *SSAOptEscapeSummary, name: []u8) -> u64 {
    if (summary == 0 || name.ptr == 0 || name.len == 0) { return 0; }
    if (ssa_tag_call_name_has_heap_allocation(name) != 0) { summary.has_heap_alloc = 1; }
    if (ssa_tag_call_name_is_pack(name) != 0 || ssa_tag_call_name_is_object_from_raw(name) != 0) {
        summary.has_tag_pack = 1;
        summary.has_tagged_access = 1;
    }
    if (ssa_tag_call_name_is_object_auto(name) != 0) {
        summary.has_tag_auto = 1;
        summary.has_tagged_access = 1;
    }
    if (ssa_tag_name_has_prefix(name, "std_mem__bpp_tag_", 17) != 0 ||
        ssa_tag_name_has_prefix(name, "std_mem__bpp_shape_", 19) != 0 ||
        ssa_tag_name_has_prefix(name, "std_mem__bpp_fast_path_", 23) != 0 ||
        ssa_tag_name_has_prefix(name, "std_mem__bpp_profile_", str_len("std_mem__bpp_profile_")) != 0 ||
        ssa_tag_name_has_prefix(name, "std_mem__bpp_vector_", 20) != 0) {
        summary.has_tagged_access = 1;
    }
    return 0;
}

func ssa_tag_summarize_call(summary: *SSAOptEscapeSummary, op: u64, info_ptr: u64) -> u64 {
    if (summary == 0) { return 0; }
    summary.has_call = 1;
    if (op == SSA_OP_CALL_PTR) {
        summary.has_indirect_call = 1;
        return 0;
    }
    if (info_ptr == 0) { return 0; }
    if (op == SSA_OP_CALL) {
        var info: *SSACallInfo = (*SSACallInfo)info_ptr;
        if (info == 0) { return 0; }
        return ssa_tag_summarize_call_name(summary, info.name);
    }
    if (op == SSA_OP_CALL_SLICE_STORE) {
        var slice_info: *SSACallSliceStoreInfo = (*SSACallSliceStoreInfo)info_ptr;
        if (slice_info == 0) { return 0; }
        if (slice_info.is_ptr == 0) {
            return ssa_tag_summarize_call_name(summary, slice_info.name);
        }
        if (slice_info.is_ptr > 1) {
            var call_info: *SSACallInfo = (*SSACallInfo)info_ptr;
            if (call_info != 0) { return ssa_tag_summarize_call_name(summary, call_info.name); }
        }
        summary.has_indirect_call = 1;
    }
    return 0;
}

func ssa_tag_analyze_function_escape(fn: *SSAFunction) -> *SSAOptEscapeSummary {
    var summary: *SSAOptEscapeSummary = ssa_o1_alloc_summary();
    if (fn == 0) { return summary; }
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var block: *SSABlock = blocks[bi];
        if (block == 0) { continue; }
        var cur: *SSAInstruction = block.inst_head;
        while (cur != 0) {
            var op: u64 = op_of(cur);
            if (op == SSA_OP_CALL || op == SSA_OP_CALL_PTR || op == SSA_OP_CALL_SLICE_STORE) {
                ssa_tag_summarize_call(summary, op, operand_value(cur.src1));
            }
            cur = cur.next;
        }
    }
    return summary;
}

func ssa_tag_func_name_eq(fn: *SSAFunction, name: []u8) -> u64 {
    if (fn == 0 || fn.name.ptr == 0 || name.ptr == 0) { return 0; }
    if (fn.name.len != name.len) { return 0; }
    return str_eq(fn.name, slice(name.ptr, name.len));
}

func ssa_tag_find_func_by_name(ctx: *SSAContext, name: []u8) -> *SSAFunction {
    if (ctx == 0 || name.ptr == 0 || name.len == 0) { return 0; }
    var funcs: []*SSAFunction = ctx.funcs;
    var n: u64 = slice_len(funcs);
    for (var i: u64 = 0; i < n; i = i + 1) {
        var fn: *SSAFunction = funcs[i];
        if (ssa_tag_func_name_eq(fn, name) != 0) { return fn; }
    }
    return 0;
}

func ssa_tag_func_lookup_find(cache: *Vec<*SSAOptFuncLookup>, name: []u8) -> *SSAOptFuncLookup {
    if (cache == 0 || name.ptr == 0 || name.len == 0) { return 0; }
    var n: u64 = cache.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var entry: *SSAOptFuncLookup = cache.get(i);
        if (entry == 0 || entry.active == 0 || entry.name.ptr == 0 || entry.name.len != name.len) { continue; }
        if (str_eq(entry.name, slice(name.ptr, name.len)) != 0) { return entry; }
    }
    return 0;
}

func ssa_tag_find_func_by_name_cached(ctx: *SSAContext, cache: *Vec<*SSAOptFuncLookup>, name: []u8) -> *SSAFunction {
    if (ctx == 0 || name.ptr == 0 || name.len == 0) { return 0; }
    var cached: *SSAOptFuncLookup = ssa_tag_func_lookup_find(cache, name);
    if (cached != 0) { return cached.fn; }
    var found: *SSAFunction = ssa_tag_find_func_by_name(ctx, name);
    if (cache != 0) {
        var entry: *SSAOptFuncLookup = ssa_o1_alloc_func_lookup();
        entry.name = slice(name.ptr, name.len);
        entry.fn = found;
        entry.active = 1;
        cache.push_scratch(entry, g_ssa_o1_scratch_arena);
    }
    return found;
}

func ssa_tag_func_has_callee(fn: *SSAFunction, callee: *SSAFunction) -> u64 {
    if (fn == 0 || callee == 0) { return 0; }
    var callees: []*SSAFunction = fn.tag_callees;
    var n: u64 = slice_len(callees);
    for (var i: u64 = 0; i < n; i = i + 1) {
        if (callees[i] == callee) { return 1; }
    }
    return 0;
}

func ssa_tag_record_direct_call_edge(ctx: *SSAContext, cache: *Vec<*SSAOptFuncLookup>, fn: *SSAFunction, name: []u8) -> u64 {
    if (ctx == 0 || fn == 0) { return 0; }
    fn.tag_callsite_count = fn.tag_callsite_count + 1;
    if (name.ptr == 0 || name.len == 0) { return 0; }
    var callee: *SSAFunction = ssa_tag_find_func_by_name_cached(ctx, cache, name);
    if (callee == 0 || callee == fn) { return 0; }
    if (ssa_tag_func_has_callee(fn, callee) != 0) { return 0; }
    push_item<*SSAFunction>(&fn.tag_callees, &fn.tag_callees_cap, callee, 4);
    return 1;
}

func ssa_tag_record_indirect_callsite(fn: *SSAFunction) -> u64 {
    if (fn == 0) { return 0; }
    fn.tag_callsite_count = fn.tag_callsite_count + 1;
    return 1;
}

func ssa_tag_reset_call_graph(ctx: *SSAContext) -> u64 {
    if (ctx == 0) { return 0; }
    var funcs: []*SSAFunction = ctx.funcs;
    var n: u64 = slice_len(funcs);
    for (var i: u64 = 0; i < n; i = i + 1) {
        var fn: *SSAFunction = funcs[i];
        if (fn == 0) { continue; }
        fn.tag_callees = slice(0, 0);
        fn.tag_callees_cap = 0;
        fn.tag_callsite_count = 0;
        fn.tag_call_graph_cached = 0;
    }
    return 1;
}

func ssa_tag_release_call_graph(ctx: *SSAContext) -> u64 {
    if (ctx == 0) { return 0; }
    var funcs: []*SSAFunction = ctx.funcs;
    var n: u64 = slice_len(funcs);
    for (var i: u64 = 0; i < n; i = i + 1) {
        var fn: *SSAFunction = funcs[i];
        if (fn == 0) { continue; }
        var callees_raw: *u64 = (*u64)&fn.tag_callees;
        if (callees_raw[0] != 0) {
            heap_free(callees_raw[0]);
        }
        fn.tag_callees = slice(0, 0);
        fn.tag_callees_cap = 0;
        fn.tag_call_graph_cached = 0;
    }
    return 1;
}

func ssa_tag_build_call_graph(ctx: *SSAContext) -> u64 {
    if (ctx == 0) { return 0; }
    ssa_tag_reset_call_graph(ctx);
    var lookup_arena: BppScratchArena;
    var old_scratch: *BppScratchArena = g_ssa_o1_scratch_arena;
    if (SSA_O1_USE_SCRATCH_ARENA != 0) {
        bpp_scratch_arena_init(&lookup_arena, 0);
        g_ssa_o1_scratch_arena = &lookup_arena;
    }
    var lookup_cache: *Vec<*SSAOptFuncLookup> = vec_new_scratch<*SSAOptFuncLookup>(g_ssa_o1_scratch_arena, 64);
    var funcs: []*SSAFunction = ctx.funcs;
    var n: u64 = slice_len(funcs);
    for (var i: u64 = 0; i < n; i = i + 1) {
        var fn: *SSAFunction = funcs[i];
        if (fn == 0) { continue; }
        var blocks: []*SSABlock = fn.blocks;
        var bcount: u64 = slice_len(blocks);
        for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
            var block: *SSABlock = blocks[bi];
            if (block == 0) { continue; }
            var cur: *SSAInstruction = block.inst_head;
            while (cur != 0) {
                var op: u64 = op_of(cur);
                if (op == SSA_OP_CALL) {
                    var info: *SSACallInfo = (*SSACallInfo)operand_value(cur.src1);
                    if (info != 0) { ssa_tag_record_direct_call_edge(ctx, lookup_cache, fn, info.name); }
                } else if (op == SSA_OP_CALL_SLICE_STORE) {
                    var slice_info: *SSACallSliceStoreInfo = (*SSACallSliceStoreInfo)operand_value(cur.src1);
                    if (slice_info != 0 && slice_info.is_ptr == 0) {
                        ssa_tag_record_direct_call_edge(ctx, lookup_cache, fn, slice_info.name);
                    } else if (slice_info != 0 && slice_info.is_ptr > 1) {
                        var call_info: *SSACallInfo = (*SSACallInfo)operand_value(cur.src1);
                        if (call_info != 0) { ssa_tag_record_direct_call_edge(ctx, lookup_cache, fn, call_info.name); }
                    } else {
                        ssa_tag_record_indirect_callsite(fn);
                    }
                } else if (op == SSA_OP_CALL_PTR) {
                    ssa_tag_record_indirect_callsite(fn);
                }
                cur = cur.next;
            }
        }
    }

    for (var j: u64 = 0; j < n; j = j + 1) {
        var fn2: *SSAFunction = funcs[j];
        if (fn2 != 0) { fn2.tag_call_graph_cached = 1; }
    }
    if (SSA_O1_RELEASE_SCRATCH != 0) {
        var cache_len: u64 = lookup_cache.len();
        for (var ci: u64 = 0; ci < cache_len; ci = ci + 1) {
            var entry_cached: *SSAOptFuncLookup = lookup_cache.get(ci);
            if (entry_cached != 0) { free((u64)entry_cached); }
        }
        lookup_cache.release_buffer();
        free((u64)lookup_cache);
    }
    if (SSA_O1_USE_SCRATCH_ARENA != 0) {
        bpp_scratch_arena_reset(&lookup_arena);
        g_ssa_o1_scratch_arena = old_scratch;
    }
    return 1;
}

func ssa_tag_callee_summary_bits(ctx: *SSAContext, fn: *SSAFunction, callee_count_out: *u64) -> u64 {
    if (callee_count_out != 0) { *callee_count_out = 0; }
    if (ctx == 0 || fn == 0) { return 0; }
    var bits: u64 = 0;
    var count: u64 = 0;
    if (fn.tag_call_graph_cached != 0) {
        var callees_cached: []*SSAFunction = fn.tag_callees;
        var cached_count: u64 = slice_len(callees_cached);
        for (var ci: u64 = 0; ci < cached_count; ci = ci + 1) {
            var cached_callee: *SSAFunction = callees_cached[ci];
            if (cached_callee == 0 || cached_callee == fn) { continue; }
            if (cached_callee.tag_summary_bits != 0) {
                bits = bits | cached_callee.tag_summary_bits;
                count = count + 1;
            }
        }
        if (callee_count_out != 0) { *callee_count_out = count; }
        return bits;
    }
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var block: *SSABlock = blocks[bi];
        if (block == 0) { continue; }
        var cur: *SSAInstruction = block.inst_head;
        while (cur != 0) {
            if (op_of(cur) == SSA_OP_CALL) {
                var info: *SSACallInfo = (*SSACallInfo)operand_value(cur.src1);
                if (info != 0) {
                    var callee: *SSAFunction = ssa_tag_find_func_by_name(ctx, info.name);
                    if (callee != 0 && callee != fn && callee.tag_summary_bits != 0) {
                        bits = bits | callee.tag_summary_bits;
                        count = count + 1;
                    }
                }
            } else if (op_of(cur) == SSA_OP_CALL_SLICE_STORE) {
                var slice_info: *SSACallSliceStoreInfo = (*SSACallSliceStoreInfo)operand_value(cur.src1);
                if (slice_info != 0 && slice_info.is_ptr == 0) {
                    var callee_slice: *SSAFunction = ssa_tag_find_func_by_name(ctx, slice_info.name);
                    if (callee_slice != 0 && callee_slice != fn && callee_slice.tag_summary_bits != 0) {
                        bits = bits | callee_slice.tag_summary_bits;
                        count = count + 1;
                    }
                }
            }
            cur = cur.next;
        }
    }
    if (callee_count_out != 0) { *callee_count_out = count; }
    return bits;
}

func ssa_tag_propagate_interprocedural(ctx: *SSAContext) -> u64 {
    if (ctx == 0) { return 0; }
    ssa_tag_build_call_graph(ctx);
    var funcs: []*SSAFunction = ctx.funcs;
    var n: u64 = slice_len(funcs);
    var changed: u64 = 1;
    var round: u64 = 0;
    while (changed != 0 && round < n) {
        changed = 0;
        for (var i: u64 = 0; i < n; i = i + 1) {
            var fn: *SSAFunction = funcs[i];
            if (fn == 0) { continue; }
            var ignored: u64 = 0;
            var callee_bits: u64 = ssa_tag_callee_summary_bits(ctx, fn, &ignored);
            var merged: u64 = fn.tag_summary_bits | callee_bits;
            if (merged != fn.tag_summary_bits) {
                fn.tag_summary_bits = merged;
                changed = 1;
            }
        }
        round = round + 1;
    }

    for (var j: u64 = 0; j < n; j = j + 1) {
        var fn2: *SSAFunction = funcs[j];
        if (fn2 == 0) { continue; }
        var callee_count: u64 = 0;
        var final_callee_bits: u64 = ssa_tag_callee_summary_bits(ctx, fn2, &callee_count);
        fn2.tag_interproc_summary_bits = final_callee_bits;
        fn2.tag_interproc_callee_count = callee_count;
    }
    if (SSA_O1_RELEASE_SCRATCH != 0) {
        ssa_tag_release_call_graph(ctx);
    }
    return 0;
}

func ssa_o1_find_block_by_id(fn: *SSAFunction, id: u64) -> *SSABlock {
    if (fn == 0) { return 0; }
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (b != 0 && b.id == id) { return b; }
    }
    return 0;
}

// ============================================
// Sparse Conditional Constant Propagation
// ============================================

func ssa_o1_sccp_state_get(states: *Vec<*SSAOptKV>, reg: u64) -> u64 {
    if (states == 0 || reg == 0) { return SSA_O1_SCCP_UNKNOWN; }
    var entry: *SSAOptKV = kv_find(states, reg);
    if (entry == 0 || entry.active == 0) { return SSA_O1_SCCP_UNKNOWN; }
    return entry.val;
}

func ssa_o1_sccp_const_get(values: *Vec<*SSAOptKV>, reg: u64, out: *u64) -> u64 {
    if (values == 0 || reg == 0 || out == 0) { return 0; }
    var entry: *SSAOptKV = kv_find(values, reg);
    if (entry == 0 || entry.active == 0) { return 0; }
    *out = entry.val;
    return 1;
}

func ssa_o1_sccp_mark_overdefined(states: *Vec<*SSAOptKV>, values: *Vec<*SSAOptKV>, reg: u64, summary: *SSAOptEscapeSummary) -> u64 {
    if (states == 0 || reg == 0) { return 0; }
    var old: u64 = ssa_o1_sccp_state_get(states, reg);
    if (old == SSA_O1_SCCP_OVERDEFINED) { return 0; }
    kv_set(states, reg, SSA_O1_SCCP_OVERDEFINED);
    kv_clear(values, reg);
    if (summary != 0) { summary.sccp_lattice_count = summary.sccp_lattice_count + 1; }
    return 1;
}

func ssa_o1_sccp_mark_const(states: *Vec<*SSAOptKV>, values: *Vec<*SSAOptKV>, reg: u64, val: u64, summary: *SSAOptEscapeSummary) -> u64 {
    if (states == 0 || values == 0 || reg == 0) { return 0; }
    var old: u64 = ssa_o1_sccp_state_get(states, reg);
    if (old == SSA_O1_SCCP_OVERDEFINED) { return 0; }
    if (old == SSA_O1_SCCP_CONST) {
        var old_val: u64 = 0;
        if (ssa_o1_sccp_const_get(values, reg, &old_val) != 0 && old_val == val) { return 0; }
        return ssa_o1_sccp_mark_overdefined(states, values, reg, summary);
    }
    kv_set(states, reg, SSA_O1_SCCP_CONST);
    kv_set(values, reg, val);
    if (summary != 0) { summary.sccp_lattice_count = summary.sccp_lattice_count + 1; }
    return 1;
}

func ssa_o1_sccp_operand_state(states: *Vec<*SSAOptKV>, values: *Vec<*SSAOptKV>, opr: u64, out_val: *u64) -> u64 {
    if (out_val != 0) { *out_val = 0; }
    if (opr == 0) { return SSA_O1_SCCP_UNKNOWN; }
    if (operand_is_const(opr) != 0) {
        if (out_val != 0) { *out_val = operand_value(opr); }
        return SSA_O1_SCCP_CONST;
    }
    var reg: u64 = operand_value(opr);
    var state: u64 = ssa_o1_sccp_state_get(states, reg);
    if (state == SSA_O1_SCCP_CONST && out_val != 0) {
        ssa_o1_sccp_const_get(values, reg, out_val);
    }
    return state;
}

func ssa_o1_sccp_eval_binary_const(op: u64, a: u64, b: u64, out: *u64) -> u64 {
    if (out == 0) { return 0; }
    var i64_min_bits: u64 = 1;
    i64_min_bits = i64_min_bits << 63;
    var minus_one_bits: u64 = 0 - 1;
    if (op == SSA_OP_ADD) { *out = a + b; return 1; }
    if (op == SSA_OP_SUB) {
        if (a == 0 && b != 0) { return 0; }
        *out = a - b; return 1;
    }
    if (op == SSA_OP_MUL) { *out = a * b; return 1; }
    if (op == SSA_OP_DIV) {
        if (b == 0) { return 0; }
        if (a == i64_min_bits && b == minus_one_bits) { return 0; }
        *out = (u64)((i64)a / (i64)b); return 1;
    }
    if (op == SSA_OP_UDIV) {
        if (b == 0) { return 0; }
        *out = a / b; return 1;
    }
    if (op == SSA_OP_MOD) {
        if (b == 0) { return 0; }
        if (a == i64_min_bits && b == minus_one_bits) { return 0; }
        *out = (u64)((i64)a % (i64)b); return 1;
    }
    if (op == SSA_OP_UMOD) {
        if (b == 0) { return 0; }
        *out = a % b; return 1;
    }
    if (op == SSA_OP_AND) { *out = a & b; return 1; }
    if (op == SSA_OP_OR) { *out = a | b; return 1; }
    if (op == SSA_OP_XOR) { *out = a ^ b; return 1; }
    if (op == SSA_OP_SHL) { *out = a << b; return 1; }
    if (op == SSA_OP_SHR) { *out = a >> b; return 1; }
    if (op == SSA_OP_SAR) { *out = (u64)((i64)a >> b); return 1; }
    if (op == SSA_OP_EQ) { *out = (a == b); return 1; }
    if (op == SSA_OP_NE) { *out = (a != b); return 1; }
    if (op == SSA_OP_LT) { *out = ((i64)a < (i64)b); return 1; }
    if (op == SSA_OP_GT) { *out = ((i64)a > (i64)b); return 1; }
    if (op == SSA_OP_LE) { *out = ((i64)a <= (i64)b); return 1; }
    if (op == SSA_OP_GE) { *out = ((i64)a >= (i64)b); return 1; }
    if (op == SSA_OP_ULT) { *out = (a < b); return 1; }
    if (op == SSA_OP_UGT) { *out = (a > b); return 1; }
    if (op == SSA_OP_ULE) { *out = (a <= b); return 1; }
    if (op == SSA_OP_UGE) { *out = (a >= b); return 1; }
    return 0;
}

func ssa_o1_sccp_update_inst(cur: *SSAInstruction, states: *Vec<*SSAOptKV>, values: *Vec<*SSAOptKV>, summary: *SSAOptEscapeSummary) -> u64 {
    if (cur == 0 || cur.dest == 0) { return 0; }
    var op: u64 = op_of(cur);
    if (op == SSA_OP_CONST) {
        return ssa_o1_sccp_mark_const(states, values, cur.dest, operand_value(cur.src1), summary);
    }
    if (op == SSA_OP_COPY) {
        var copy_val: u64 = 0;
        var copy_state: u64 = ssa_o1_sccp_operand_state(states, values, cur.src1, &copy_val);
        if (copy_state == SSA_O1_SCCP_CONST) { return ssa_o1_sccp_mark_const(states, values, cur.dest, copy_val, summary); }
        if (copy_state == SSA_O1_SCCP_OVERDEFINED) { return ssa_o1_sccp_mark_overdefined(states, values, cur.dest, summary); }
        return 0;
    }
    if (is_foldable(op) != 0) {
        var a: u64 = 0;
        var b: u64 = 0;
        var s1: u64 = ssa_o1_sccp_operand_state(states, values, cur.src1, &a);
        var s2: u64 = ssa_o1_sccp_operand_state(states, values, cur.src2, &b);
        if (s1 == SSA_O1_SCCP_CONST && s2 == SSA_O1_SCCP_CONST) {
            var out: u64 = 0;
            if (ssa_o1_sccp_eval_binary_const(op, a, b, &out) != 0) {
                return ssa_o1_sccp_mark_const(states, values, cur.dest, out, summary);
            }
            return ssa_o1_sccp_mark_overdefined(states, values, cur.dest, summary);
        }
        if (s1 == SSA_O1_SCCP_OVERDEFINED || s2 == SSA_O1_SCCP_OVERDEFINED) {
            return ssa_o1_sccp_mark_overdefined(states, values, cur.dest, summary);
        }
        return 0;
    }
    if (op == SSA_OP_PARAM || op == SSA_OP_CALL || op == SSA_OP_CALL_PTR || op == SSA_OP_CALL_SLICE_STORE ||
        op == SSA_OP_LOAD || op == SSA_OP_LOAD8 || op == SSA_OP_LOAD16 || op == SSA_OP_LOAD32 || op == SSA_OP_LOAD64 ||
        op == SSA_OP_LEA_LOCAL || op == SSA_OP_LEA_GLOBAL || op == SSA_OP_LEA_FUNC || op == SSA_OP_LEA_STR ||
        op == SSA_OP_FCONST || op == SSA_OP_FADD || op == SSA_OP_FSUB || op == SSA_OP_FMUL || op == SSA_OP_FDIV ||
        op == SSA_OP_FNEG || op == SSA_OP_FEQ || op == SSA_OP_FNE || op == SSA_OP_FLT || op == SSA_OP_FGT ||
        op == SSA_OP_FLE || op == SSA_OP_FGE || op == SSA_OP_I2F || op == SSA_OP_U2F || op == SSA_OP_F2I || op == SSA_OP_F2U) {
        return ssa_o1_sccp_mark_overdefined(states, values, cur.dest, summary);
    }
    return 0;
}

func ssa_o1_sccp_update_phi(block: *SSABlock, phi: *SSAInstruction, states: *Vec<*SSAOptKV>, values: *Vec<*SSAOptKV>, reach: *Vec<*SSAOptKV>, summary: *SSAOptEscapeSummary) -> u64 {
    if (block == 0 || phi == 0 || phi.dest == 0 || op_of(phi) != SSA_OP_PHI) { return 0; }
    var arg: *SSAPhiArg = (*SSAPhiArg)phi.src1;
    var saw_input: u64 = 0;
    var saw_unknown: u64 = 0;
    var const_has: u64 = 0;
    var const_val: u64 = 0;
    while (arg != 0) {
        if (ssa_o1_reach_has(reach, arg.block_id) == 0) {
            arg = arg.next;
            continue;
        }
        saw_input = 1;
        var state: u64 = ssa_o1_sccp_state_get(states, arg.val);
        if (state == SSA_O1_SCCP_OVERDEFINED) {
            return ssa_o1_sccp_mark_overdefined(states, values, phi.dest, summary);
        }
        if (state == SSA_O1_SCCP_UNKNOWN) {
            saw_unknown = 1;
        } else {
            var v: u64 = 0;
            ssa_o1_sccp_const_get(values, arg.val, &v);
            if (const_has == 0) {
                const_has = 1;
                const_val = v;
            } else if (const_val != v) {
                return ssa_o1_sccp_mark_overdefined(states, values, phi.dest, summary);
            }
        }
        arg = arg.next;
    }
    if (saw_input == 0 || saw_unknown != 0 || const_has == 0) { return 0; }
    return ssa_o1_sccp_mark_const(states, values, phi.dest, const_val, summary);
}

func ssa_o1_sccp_mark_reach(reach: *Vec<*SSAOptKV>, block_id: u64) -> u64 {
    if (reach == 0) { return 0; }
    if (ssa_o1_reach_has(reach, block_id) != 0) { return 0; }
    kv_set(reach, block_id, 1);
    return 1;
}

func ssa_o1_sccp_mark_block_edges(fn: *SSAFunction, block: *SSABlock, states: *Vec<*SSAOptKV>, values: *Vec<*SSAOptKV>, reach: *Vec<*SSAOptKV>, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0 || block == 0 || block.inst_tail == 0) { return 0; }
    var changed: u64 = 0;
    var term: *SSAInstruction = block.inst_tail;
    var op: u64 = op_of(term);
    if (op == SSA_OP_JMP && term.src1 != 0 && operand_is_const(term.src1) != 0) {
        changed = changed | ssa_o1_sccp_mark_reach(reach, operand_value(term.src1));
        return changed;
    }
    if (op == SSA_OP_BR) {
        var cond_val: u64 = 0;
        var cond_state: u64 = ssa_o1_sccp_operand_state(states, values, term.src1, &cond_val);
        if (cond_state == SSA_O1_SCCP_CONST && term.dest != 0 && term.src2 != 0) {
            if (cond_val != 0) {
                if (operand_is_const(term.src2) != 0) { changed = changed | ssa_o1_sccp_mark_reach(reach, operand_value(term.src2)); }
            } else {
                if (operand_is_const(term.dest) != 0) { changed = changed | ssa_o1_sccp_mark_reach(reach, operand_value(term.dest)); }
            }
            if (summary != 0) {
                summary.sccp_edge_prune_count = summary.sccp_edge_prune_count + 1;
                summary.cfg_edge_prune_count = summary.cfg_edge_prune_count + 1;
            }
            return changed;
        }
    }
    var succs: []*SSABlock = block.succs;
    var scount: u64 = slice_len(succs);
    for (var si: u64 = 0; si < scount; si = si + 1) {
        var succ: *SSABlock = succs[si];
        if (succ != 0) { changed = changed | ssa_o1_sccp_mark_reach(reach, succ.id); }
    }
    return changed;
}

func ssa_o1_sccp_rewrite_operand(states: *Vec<*SSAOptKV>, values: *Vec<*SSAOptKV>, opr: *u64, summary: *SSAOptEscapeSummary) -> u64 {
    if (opr == 0 || *opr == 0 || operand_is_const(*opr) != 0) { return 0; }
    var reg: u64 = operand_value(*opr);
    if (ssa_o1_sccp_state_get(states, reg) != SSA_O1_SCCP_CONST) { return 0; }
    var val: u64 = 0;
    if (ssa_o1_sccp_const_get(values, reg, &val) == 0) { return 0; }
    *opr = operand_const(val);
    if (summary != 0) { summary.sccp_const_operand_count = summary.sccp_const_operand_count + 1; }
    return 1;
}

func ssa_o1_sccp_rewrite_args(args: *Vec<u64>, states: *Vec<*SSAOptKV>, values: *Vec<*SSAOptKV>, summary: *SSAOptEscapeSummary) -> u64 {
    // Call argument vectors store virtual register ids, not tagged operands.
    // Keep them untouched until call lowering grows operand-aware argument slots.
    return 0;
}

func ssa_o1_sccp_inst_can_be_const(op: u64) -> u64 {
    if (op == SSA_OP_CONST) { return 1; }
    if (op == SSA_OP_COPY) { return 1; }
    if (is_foldable(op) != 0) { return 1; }
    return 0;
}

func ssa_o1_sccp_rewrite_function(fn: *SSAFunction, states: *Vec<*SSAOptKV>, values: *Vec<*SSAOptKV>, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0) { return 0; }
    var changed: u64 = 0;
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (b == 0) { continue; }
        var cur: *SSAInstruction = b.inst_head;
        while (cur != 0) {
            var op: u64 = op_of(cur);
            if (op == SSA_OP_CALL) {
                var info: *SSACallInfo = (*SSACallInfo)operand_value(cur.src1);
                if (info != 0) { changed = changed + ssa_o1_sccp_rewrite_args(info.args_vec, states, values, summary); }
            } else if (op == SSA_OP_CALL_PTR) {
                var ptr_info: *SSACallPtrInfo = (*SSACallPtrInfo)operand_value(cur.src1);
                if (ptr_info != 0) { changed = changed + ssa_o1_sccp_rewrite_args(ptr_info.args_vec, states, values, summary); }
            } else if (op == SSA_OP_CALL_SLICE_STORE) {
                var slice_info: *SSACallSliceStoreInfo = (*SSACallSliceStoreInfo)operand_value(cur.src1);
                if (slice_info != 0 && slice_info.is_ptr > 1) {
                    var call_info: *SSACallInfo = (*SSACallInfo)operand_value(cur.src1);
                    if (call_info != 0) { changed = changed + ssa_o1_sccp_rewrite_args(call_info.args_vec, states, values, summary); }
                } else if (slice_info != 0) {
                    changed = changed + ssa_o1_sccp_rewrite_args(slice_info.args_vec, states, values, summary);
                }
                changed = changed + ssa_o1_sccp_rewrite_operand(states, values, &cur.src2, summary);
            } else if (is_foldable(op) != 0 || op == SSA_OP_COPY || op == SSA_OP_BR || op == SSA_OP_RET) {
                changed = changed + ssa_o1_sccp_rewrite_operand(states, values, &cur.src1, summary);
                changed = changed + ssa_o1_sccp_rewrite_operand(states, values, &cur.src2, summary);
            }
            if (cur.dest != 0 && ssa_o1_sccp_inst_can_be_const(op) != 0 && ssa_o1_sccp_state_get(states, cur.dest) == SSA_O1_SCCP_CONST) {
                var val: u64 = 0;
                if (ssa_o1_sccp_const_get(values, cur.dest, &val) != 0 && op != SSA_OP_CONST) {
                    opt_set_const(cur, val, values);
                    changed = changed + 1;
                }
            }
            cur = cur.next;
        }
    }
    return changed;
}

func ssa_o1_sccp_function(fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0 || fn.entry == 0) { return 0; }
    var states: *Vec<*SSAOptKV> = vec_new_scratch<*SSAOptKV>(g_ssa_o1_scratch_arena, 64);
    var values: *Vec<*SSAOptKV> = vec_new_scratch<*SSAOptKV>(g_ssa_o1_scratch_arena, 64);
    var reach: *Vec<*SSAOptKV> = vec_new_scratch<*SSAOptKV>(g_ssa_o1_scratch_arena, 32);
    ssa_o1_sccp_mark_reach(reach, fn.entry.id);

    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    var round: u64 = 0;
    var changed: u64 = 1;
    var any: u64 = 0;
    while (changed != 0 && round < (bcount + 16)) {
        changed = 0;
        for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
            var b: *SSABlock = blocks[bi];
            if (b == 0 || ssa_o1_reach_has(reach, b.id) == 0) { continue; }
            var phi: *SSAInstruction = b.phi_head;
            while (phi != 0) {
                changed = changed | ssa_o1_sccp_update_phi(b, phi, states, values, reach, summary);
                phi = phi.next;
            }
            var cur: *SSAInstruction = b.inst_head;
            while (cur != 0) {
                changed = changed | ssa_o1_sccp_update_inst(cur, states, values, summary);
                cur = cur.next;
            }
            changed = changed | ssa_o1_sccp_mark_block_edges(fn, b, states, values, reach, summary);
        }
        if (changed != 0) { any = 1; }
        round = round + 1;
    }
    if (ssa_o1_sccp_rewrite_function(fn, states, values, summary) != 0) { any = 1; }
    return any;
}

// ============================================
// Dominator-backed global value numbering
// ============================================

func ssa_o1_reachable_without_block(fn: *SSAFunction, blocked: *SSABlock, target: *SSABlock) -> u64 {
    if (fn == 0 || fn.entry == 0 || blocked == 0 || target == 0) { return 0; }
    if (target == blocked) { return 0; }
    if (fn.entry == blocked) { return 0; }
    var reach: *Vec<*SSAOptKV> = vec_new_scratch<*SSAOptKV>(g_ssa_o1_scratch_arena, 32);
    kv_set(reach, fn.entry.id, 1);
    var changed: u64 = 1;
    while (changed != 0) {
        changed = 0;
        var blocks: []*SSABlock = fn.blocks;
        var bcount: u64 = slice_len(blocks);
        for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
            var b: *SSABlock = blocks[bi];
            if (b == 0 || b == blocked || ssa_o1_reach_has(reach, b.id) == 0) { continue; }
            var succs: []*SSABlock = b.succs;
            var scount: u64 = slice_len(succs);
            for (var si: u64 = 0; si < scount; si = si + 1) {
                var succ: *SSABlock = succs[si];
                if (succ == 0 || succ == blocked || ssa_o1_reach_has(reach, succ.id) != 0) { continue; }
                kv_set(reach, succ.id, 1);
                changed = 1;
            }
        }
    }
    return ssa_o1_reach_has(reach, target.id);
}

func ssa_o1_block_dominates(fn: *SSAFunction, dom: *SSABlock, block: *SSABlock) -> u64 {
    if (fn == 0 || dom == 0 || block == 0) { return 0; }
    if (dom == block) { return 1; }
    return ssa_o1_reachable_without_block(fn, dom, block) == 0;
}

func ssa_o1_phi_all_same(phi: *SSAInstruction) -> u64 {
    if (phi == 0 || op_of(phi) != SSA_OP_PHI) { return 0; }
    var arg: *SSAPhiArg = (*SSAPhiArg)phi.src1;
    var first: u64 = 0;
    var count: u64 = 0;
    while (arg != 0) {
        if (count == 0) { first = arg.val; }
        else if (arg.val != first) { return 0; }
        count = count + 1;
        arg = arg.next;
    }
    return count > 1;
}

func ssa_o1_global_gvn_function(fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0) { return 0; }
    var exprs: *Vec<*SSAOptExprVN> = vec_new_scratch<*SSAOptExprVN>(g_ssa_o1_scratch_arena, 64);
    var reg_consts: *Vec<*SSAOptKV> = vec_new_scratch<*SSAOptKV>(g_ssa_o1_scratch_arena, 16);
    var changed: u64 = 0;
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (b == 0) { continue; }
        var phi: *SSAInstruction = b.phi_head;
        while (phi != 0) {
            if (ssa_o1_phi_all_same(phi) != 0 && summary != 0) { summary.gvn_phi_count = summary.gvn_phi_count + 1; }
            phi = phi.next;
        }
        var cur: *SSAInstruction = b.inst_head;
        while (cur != 0) {
            var op: u64 = op_of(cur);
            if (cur.dest != 0 && ssa_o1_gvn_is_safe_expr(op) != 0) {
                var src1: u64 = cur.src1;
                var src2: u64 = cur.src2;
                ssa_o1_gvn_canonical(op, cur.src1, cur.src2, &src1, &src2);
                var entry: *SSAOptExprVN = ssa_o1_gvn_find(exprs, op, src1, src2);
                if (entry != 0 && entry.dest != 0 && entry.dest != cur.dest) {
                    var defining_block: *SSABlock = ssa_o1_find_block_by_id(fn, entry.block_id);
                    if (defining_block != 0 && ssa_o1_block_dominates(fn, defining_block, b) != 0) {
                        opt_set_copy(cur, operand_reg(entry.dest), reg_consts);
                        changed = changed + 1;
                        if (summary != 0) {
                            summary.gvn_global_count = summary.gvn_global_count + 1;
                            summary.gvn_value_number_count = summary.gvn_value_number_count + 1;
                            summary.cse_elim_count = summary.cse_elim_count + 1;
                        }
                    } else {
                        ssa_o1_gvn_record_at(exprs, op, src1, src2, cur.dest, b.id);
                    }
                } else {
                    ssa_o1_gvn_record_at(exprs, op, src1, src2, cur.dest, b.id);
                    if (summary != 0) { summary.gvn_value_number_count = summary.gvn_value_number_count + 1; }
                }
            }
            cur = cur.next;
        }
    }
    if (changed != 0) {
        for (var bj: u64 = 0; bj < bcount; bj = bj + 1) {
            remove_nops(blocks[bj]);
        }
    }
    return changed;
}

// ============================================
// MemorySSA-shaped stack/local alias pass
// ============================================

func ssa_o1_mem_fact_find(facts: *Vec<*SSAOptMemoryFact>, block_id: u64, key: u64) -> *SSAOptMemoryFact {
    if (facts == 0 || key == 0) { return 0; }
    var n: u64 = facts.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var fact: *SSAOptMemoryFact = facts.get(i);
        if (fact != 0 && fact.active != 0 && fact.block_id == block_id && fact.key == key) { return fact; }
    }
    return 0;
}

func ssa_o1_mem_fact_set(facts: *Vec<*SSAOptMemoryFact>, block_id: u64, key: u64, val: u64, store_inst: u64) -> u64 {
    if (facts == 0 || key == 0) { return 0; }
    var fact: *SSAOptMemoryFact = ssa_o1_mem_fact_find(facts, block_id, key);
    if (fact == 0) {
        fact = ssa_o1_alloc_memory_fact();
        fact.block_id = block_id;
        fact.key = key;
        facts.push_scratch(fact, g_ssa_o1_scratch_arena);
    }
    fact.val = val;
    fact.store_inst = store_inst;
    fact.active = 1;
    return 1;
}

func ssa_o1_mem_fact_clear_block(facts: *Vec<*SSAOptMemoryFact>, block_id: u64) -> u64 {
    if (facts == 0) { return 0; }
    var n: u64 = facts.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var fact: *SSAOptMemoryFact = facts.get(i);
        if (fact != 0 && fact.block_id == block_id) { fact.active = 0; }
    }
    return 0;
}

func ssa_o1_single_pred(block: *SSABlock) -> *SSABlock {
    if (block == 0) { return 0; }
    var preds: []*SSABlock = block.preds;
    if (slice_len(preds) != 1) { return 0; }
    return preds[0];
}

func ssa_o1_block_single_succ(block: *SSABlock) -> u64 {
    if (block == 0) { return 0; }
    return slice_len(block.succs) == 1;
}

func ssa_o1_loaded_key(loaded: *Vec<*SSAOptKV>, key: u64) -> u64 {
    if (loaded == 0 || key == 0) { return 0; }
    var entry: *SSAOptKV = kv_find(loaded, key);
    if (entry == 0 || entry.active == 0) { return 0; }
    return 1;
}

func ssa_o1_build_global_local_addr_map(fn: *SSAFunction, reg_consts: *Vec<*SSAOptKV>, local_addrs: *Vec<*SSAOptKV>) -> u64 {
    if (fn == 0) { return 0; }
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (b == 0) { continue; }
        var cur: *SSAInstruction = b.inst_head;
        while (cur != 0) {
            var op: u64 = op_of(cur);
            if (op == SSA_OP_CONST && cur.dest != 0) {
                const_set(reg_consts, cur.dest, operand_value(cur.src1));
            } else if (op == SSA_OP_COPY && cur.dest != 0) {
                var value: SSAOptConstValue = operand_const_value(reg_consts, cur.src1);
                if (value.has != 0) { const_set(reg_consts, cur.dest, value.val); }
                if (operand_is_const(cur.src1) == 0) {
                    var copied_offset: u64 = 0;
                    if (ssa_sroa_local_addr_get(local_addrs, operand_value(cur.src1), &copied_offset) != 0) {
                        ssa_sroa_local_addr_set(local_addrs, cur.dest, copied_offset);
                    }
                }
            } else if (op == SSA_OP_LEA_LOCAL && cur.dest != 0 && operand_is_const(cur.src1) != 0) {
                ssa_sroa_local_addr_set(local_addrs, cur.dest, operand_value(cur.src1));
            } else if (op == SSA_OP_ADD && cur.dest != 0) {
                handle_sroa_local_addr_add(cur, reg_consts, local_addrs);
            }
            cur = cur.next;
        }
    }
    return 0;
}

func ssa_o1_memory_stored_operand(cur: *SSAInstruction, reg_consts: *Vec<*SSAOptKV>, size: u64) -> u64 {
    if (cur == 0 || cur.src2 == 0) { return 0; }
    var value: SSAOptConstValue = operand_const_value(reg_consts, cur.src2);
    if (value.has != 0) {
        var mask: u64 = 0 - 1;
        if (size == 1) { mask = 255; }
        else if (size == 2) { mask = 65535; }
        else if (size == 4) { mask = 4294967295; }
        return operand_const(value.val & mask);
    }
    if (size == 8 && operand_is_const(cur.src2) == 0) { return cur.src2; }
    return 0;
}

func ssa_o1_memoryssa_function(fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0) { return 0; }
    var facts: *Vec<*SSAOptMemoryFact> = vec_new_scratch<*SSAOptMemoryFact>(g_ssa_o1_scratch_arena, 64);
    var reg_consts: *Vec<*SSAOptKV> = vec_new_scratch<*SSAOptKV>(g_ssa_o1_scratch_arena, 64);
    var local_addrs: *Vec<*SSAOptKV> = vec_new_scratch<*SSAOptKV>(g_ssa_o1_scratch_arena, 64);
    ssa_o1_build_global_local_addr_map(fn, reg_consts, local_addrs);
    var changed: u64 = 0;
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (b == 0) { continue; }
        if (slice_len(b.preds) > 1 && summary != 0) { summary.memoryssa_phi_count = summary.memoryssa_phi_count + 1; }
        var loaded: *Vec<*SSAOptKV> = vec_new_scratch<*SSAOptKV>(g_ssa_o1_scratch_arena, 16);
        var pred: *SSABlock = ssa_o1_single_pred(b);
        var barrier: u64 = 0;
        var cur: *SSAInstruction = b.inst_head;
        while (cur != 0) {
            var op: u64 = op_of(cur);
            var size: u64 = ssa_sroa_mem_size_for_op(op);
            if (size != 0) {
                var offset_enc: u64 = 0;
                var has_local_addr: u64 = 0;
                if (cur.src1 != 0 && operand_is_const(cur.src1) == 0) {
                    has_local_addr = ssa_sroa_local_addr_get(local_addrs, operand_value(cur.src1), &offset_enc);
                }
                if (op == SSA_OP_LOAD8 || op == SSA_OP_LOAD16 || op == SSA_OP_LOAD32 || op == SSA_OP_LOAD64) {
                    if (summary != 0) {
                        summary.memoryssa_count = summary.memoryssa_count + 1;
                        summary.memoryssa_use_count = summary.memoryssa_use_count + 1;
                    }
                    if (has_local_addr != 0) {
                        ssa_sroa_note_field_access(summary, offset_enc, size);
                        var key: u64 = ssa_sroa_mem_key(offset_enc, size);
                        if (summary != 0) { summary.memoryssa_alias_class_count = summary.memoryssa_alias_class_count + 1; }
                        var fact: *SSAOptMemoryFact = ssa_o1_mem_fact_find(facts, b.id, key);
                        if (fact == 0 && pred != 0 && barrier == 0) { fact = ssa_o1_mem_fact_find(facts, pred.id, key); }
                        if (fact != 0 && fact.val != 0 && cur.dest != 0) {
                            opt_set_copy(cur, fact.val, reg_consts);
                            changed = changed + 1;
                            if (summary != 0) {
                                summary.memoryssa_forward_count = summary.memoryssa_forward_count + 1;
                                summary.load_forward_count = summary.load_forward_count + 1;
                            }
                        }
                        kv_set(loaded, key, 1);
                    }
                } else {
                    if (summary != 0) {
                        summary.memoryssa_count = summary.memoryssa_count + 1;
                        summary.memoryssa_def_count = summary.memoryssa_def_count + 1;
                    }
                    if (has_local_addr != 0) {
                        ssa_sroa_note_field_access(summary, offset_enc, size);
                        var store_key: u64 = ssa_sroa_mem_key(offset_enc, size);
                        if (summary != 0) { summary.memoryssa_alias_class_count = summary.memoryssa_alias_class_count + 1; }
                        if (ssa_o1_loaded_key(loaded, store_key) == 0) {
                            var old_fact: *SSAOptMemoryFact = ssa_o1_mem_fact_find(facts, b.id, store_key);
                            if (old_fact == 0 && pred != 0 && barrier == 0 && ssa_o1_block_single_succ(pred) != 0) {
                                old_fact = ssa_o1_mem_fact_find(facts, pred.id, store_key);
                            }
                            if (old_fact != 0 && old_fact.store_inst != 0) {
                                var old_store: *SSAInstruction = (*SSAInstruction)old_fact.store_inst;
                                if (old_store != 0 && op_of(old_store) != SSA_OP_NOP) {
                                    set_op(old_store, SSA_OP_NOP);
                                    changed = changed + 1;
                                    if (summary != 0) {
                                        summary.memoryssa_store_kill_count = summary.memoryssa_store_kill_count + 1;
                                        summary.store_kill_count = summary.store_kill_count + 1;
                                    }
                                }
                            }
                        }
                        ssa_o1_mem_fact_set(facts, b.id, store_key, ssa_o1_memory_stored_operand(cur, reg_consts, size), (u64)cur);
                    } else {
                        barrier = 1;
                        ssa_o1_mem_fact_clear_block(facts, b.id);
                    }
                }
            } else if (op == SSA_OP_ASM || op == SSA_OP_CALL_PTR || op == SSA_OP_CALL_SLICE_STORE) {
                barrier = 1;
                ssa_o1_mem_fact_clear_block(facts, b.id);
            } else if (op == SSA_OP_CALL) {
                if (ssa_o1_direct_call_preserves_local_memory(cur) != 0) {
                    if (summary != 0) { summary.memory_effect_summary_count = summary.memory_effect_summary_count + 1; }
                } else {
                    barrier = 1;
                    ssa_o1_mem_fact_clear_block(facts, b.id);
                }
            }
            cur = cur.next;
        }
        remove_nops(b);
    }
    if (summary != 0 && summary.has_tagged_access != 0 && summary.memoryssa_alias_class_count != 0) {
        summary.memoryssa_tagged_noalias_count = summary.memoryssa_tagged_noalias_count + summary.memoryssa_alias_class_count;
        summary.alias_proof_count = summary.alias_proof_count + 1;
    }
    return changed;
}

// ============================================
// Loop recognition and safe specialization metadata
// ============================================

func ssa_o1_operand_defined_in_block(block: *SSABlock, opr: u64) -> u64 {
    if (block == 0 || opr == 0 || operand_is_const(opr) != 0) { return 0; }
    var reg: u64 = operand_value(opr);
    var phi: *SSAInstruction = block.phi_head;
    while (phi != 0) {
        if (phi.dest == reg) { return 1; }
        phi = phi.next;
    }
    var cur: *SSAInstruction = block.inst_head;
    while (cur != 0) {
        if (cur.dest == reg) { return 1; }
        cur = cur.next;
    }
    return 0;
}

func ssa_o1_block_reaches(fn: *SSAFunction, start: *SSABlock, target: *SSABlock) -> u64 {
    if (fn == 0 || start == 0 || target == 0) { return 0; }
    if (start == target) { return 1; }
    var reach: *Vec<*SSAOptKV> = vec_new_scratch<*SSAOptKV>(g_ssa_o1_scratch_arena, 32);
    kv_set(reach, start.id, 1);
    var changed: u64 = 1;
    while (changed != 0) {
        changed = 0;
        var blocks: []*SSABlock = fn.blocks;
        var bcount: u64 = slice_len(blocks);
        for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
            var b: *SSABlock = blocks[bi];
            if (b == 0 || ssa_o1_reach_has(reach, b.id) == 0) { continue; }
            var succs: []*SSABlock = b.succs;
            var scount: u64 = slice_len(succs);
            for (var si: u64 = 0; si < scount; si = si + 1) {
                var succ: *SSABlock = succs[si];
                if (succ == 0 || ssa_o1_reach_has(reach, succ.id) != 0) { continue; }
                if (succ == target) { return 1; }
                kv_set(reach, succ.id, 1);
                changed = 1;
            }
        }
    }
    return ssa_o1_reach_has(reach, target.id);
}

func ssa_o1_loop_contains_block(fn: *SSAFunction, header: *SSABlock, latch: *SSABlock, block: *SSABlock) -> u64 {
    if (fn == 0 || header == 0 || latch == 0 || block == 0) { return 0; }
    if (block == header || block == latch) { return 1; }
    if (ssa_o1_block_dominates(fn, header, block) == 0) { return 0; }
    return ssa_o1_block_reaches(fn, block, latch);
}

func ssa_o1_find_def_in_loop(fn: *SSAFunction, header: *SSABlock, latch: *SSABlock, reg: u64) -> *SSAInstruction {
    if (fn == 0 || reg == 0) { return 0; }
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (ssa_o1_loop_contains_block(fn, header, latch, b) == 0) { continue; }
        var phi: *SSAInstruction = b.phi_head;
        while (phi != 0) {
            if (phi.dest == reg) { return phi; }
            phi = phi.next;
        }
        var cur: *SSAInstruction = b.inst_head;
        while (cur != 0) {
            if (cur.dest == reg) { return cur; }
            cur = cur.next;
        }
    }
    return 0;
}

func ssa_o1_operand_defined_in_loop(fn: *SSAFunction, header: *SSABlock, latch: *SSABlock, opr: u64) -> u64 {
    if (opr == 0 || operand_is_const(opr) != 0) { return 0; }
    return ssa_o1_find_def_in_loop(fn, header, latch, operand_value(opr)) != 0;
}

func ssa_o1_loop_inst_count(fn: *SSAFunction, header: *SSABlock, latch: *SSABlock) -> u64 {
    if (fn == 0) { return 0; }
    var count: u64 = 0;
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (ssa_o1_loop_contains_block(fn, header, latch, b) != 0) {
            count = count + ssa_o1_count_block_insts(b);
        }
    }
    return count;
}

func ssa_o1_loop_has_header_phi(header: *SSABlock) -> u64 {
    if (header == 0 || header.phi_head == 0) { return 0; }
    return 1;
}

func ssa_o1_loop_outside_pred_count(fn: *SSAFunction, header: *SSABlock) -> u64 {
    if (fn == 0 || header == 0) { return 0; }
    var preds: []*SSABlock = header.preds;
    var n: u64 = slice_len(preds);
    var count: u64 = 0;
    for (var i: u64 = 0; i < n; i = i + 1) {
        var pred: *SSABlock = preds[i];
        if (pred != 0 && ssa_o1_block_dominates(fn, header, pred) == 0) { count = count + 1; }
    }
    return count;
}

func ssa_o1_loop_has_iv_candidate(fn: *SSAFunction, header: *SSABlock, latch: *SSABlock) -> u64 {
    if (header == 0 || latch == 0 || header.phi_head == 0) { return 0; }
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (ssa_o1_loop_contains_block(fn, header, latch, b) == 0) { continue; }
        var cur: *SSAInstruction = b.inst_head;
        while (cur != 0) {
            var op: u64 = op_of(cur);
            if (op == SSA_OP_ADD || op == SSA_OP_SUB) {
                if ((operand_is_const(cur.src1) != 0 && operand_is_const(cur.src2) == 0) ||
                    (operand_is_const(cur.src2) != 0 && operand_is_const(cur.src1) == 0)) {
                    return 1;
                }
            }
            cur = cur.next;
        }
    }
    return 0;
}

func ssa_o1_loop_has_licm_candidate(fn: *SSAFunction, header: *SSABlock, latch: *SSABlock) -> u64 {
    if (fn == 0 || header == 0 || latch == 0) { return 0; }
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (ssa_o1_loop_contains_block(fn, header, latch, b) == 0) { continue; }
        var cur: *SSAInstruction = b.inst_head;
        while (cur != 0) {
            var op: u64 = op_of(cur);
            if (ssa_o1_gvn_is_safe_expr(op) != 0) {
                if (ssa_o1_operand_defined_in_loop(fn, header, latch, cur.src1) == 0 &&
                    ssa_o1_operand_defined_in_loop(fn, header, latch, cur.src2) == 0) {
                    return 1;
                }
            }
            cur = cur.next;
        }
    }
    return 0;
}

func ssa_o1_loop_has_strength_candidate(fn: *SSAFunction, header: *SSABlock, latch: *SSABlock) -> u64 {
    if (fn == 0) { return 0; }
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (ssa_o1_loop_contains_block(fn, header, latch, b) == 0) { continue; }
        var cur: *SSAInstruction = b.inst_head;
        while (cur != 0) {
            var op: u64 = op_of(cur);
            if (op == SSA_OP_SHL || op == SSA_OP_SHR || op == SSA_OP_AND) { return 1; }
            if (op == SSA_OP_MUL || op == SSA_OP_UDIV || op == SSA_OP_UMOD) {
                if (operand_is_const(cur.src1) != 0 && opt_is_pow2_u64(operand_value(cur.src1)) != 0) { return 1; }
                if (operand_is_const(cur.src2) != 0 && opt_is_pow2_u64(operand_value(cur.src2)) != 0) { return 1; }
            }
            cur = cur.next;
        }
    }
    return 0;
}

func ssa_o1_loop_has_bounds_candidate(fn: *SSAFunction, header: *SSABlock, latch: *SSABlock) -> u64 {
    if (fn == 0) { return 0; }
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (ssa_o1_loop_contains_block(fn, header, latch, b) == 0) { continue; }
        var cur: *SSAInstruction = b.inst_head;
        while (cur != 0) {
            var op: u64 = op_of(cur);
            if (op == SSA_OP_LT || op == SSA_OP_LE || op == SSA_OP_ULT || op == SSA_OP_ULE ||
                op == SSA_OP_GT || op == SSA_OP_GE || op == SSA_OP_UGT || op == SSA_OP_UGE) {
                return 1;
            }
            cur = cur.next;
        }
    }
    return 0;
}

func ssa_o1_loop_branch_cond_invariant(fn: *SSAFunction, header: *SSABlock, latch: *SSABlock, cond: u64) -> u64 {
    if (cond == 0) { return 0; }
    if (operand_is_const(cond) != 0) { return 1; }
    if (ssa_o1_operand_defined_in_loop(fn, header, latch, cond) == 0) { return 1; }
    var def: *SSAInstruction = ssa_o1_find_def_in_loop(fn, header, latch, operand_value(cond));
    if (def == 0) { return 0; }
    var op: u64 = op_of(def);
    if (op == SSA_OP_EQ || op == SSA_OP_NE || op == SSA_OP_LT || op == SSA_OP_LE || op == SSA_OP_ULT || op == SSA_OP_ULE ||
        op == SSA_OP_GT || op == SSA_OP_GE || op == SSA_OP_UGT || op == SSA_OP_UGE) {
        if (ssa_o1_operand_defined_in_loop(fn, header, latch, def.src1) == 0 &&
            ssa_o1_operand_defined_in_loop(fn, header, latch, def.src2) == 0) {
            return 1;
        }
    }
    return 0;
}

func ssa_o1_loop_has_unswitch_candidate(fn: *SSAFunction, header: *SSABlock, latch: *SSABlock) -> u64 {
    if (fn == 0 || ssa_o1_loop_inst_count(fn, header, latch) > 64) { return 0; }
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (ssa_o1_loop_contains_block(fn, header, latch, b) == 0 || b.inst_tail == 0 || op_of(b.inst_tail) != SSA_OP_BR) { continue; }
        if (ssa_o1_loop_branch_cond_invariant(fn, header, latch, b.inst_tail.src1) != 0) { return 1; }
    }
    return 0;
}

func ssa_o1_loop_has_reduction_candidate(fn: *SSAFunction, header: *SSABlock, latch: *SSABlock) -> u64 {
    if (fn == 0 || header == 0 || latch == 0 || header.phi_head == 0) { return 0; }
    var phi: *SSAInstruction = header.phi_head;
    while (phi != 0) {
        var blocks: []*SSABlock = fn.blocks;
        var bcount: u64 = slice_len(blocks);
        for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
            var b: *SSABlock = blocks[bi];
            if (ssa_o1_loop_contains_block(fn, header, latch, b) == 0) { continue; }
            var cur: *SSAInstruction = b.inst_head;
            while (cur != 0) {
                var op: u64 = op_of(cur);
                if (op == SSA_OP_ADD || op == SSA_OP_SUB || op == SSA_OP_MUL || op == SSA_OP_XOR || op == SSA_OP_OR || op == SSA_OP_AND) {
                    if ((operand_is_const(cur.src1) == 0 && operand_value(cur.src1) == phi.dest) ||
                        (operand_is_const(cur.src2) == 0 && operand_value(cur.src2) == phi.dest)) {
                        return 1;
                    }
                }
                cur = cur.next;
            }
        }
        phi = phi.next;
    }
    return 0;
}

func ssa_o1_loop_info_has_block(info: *SSAOptLoopInfo, block: *SSABlock) -> u64 {
    if (info == 0 || info.body_blocks == 0 || block == 0) { return 0; }
    var n: u64 = info.body_blocks.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        if (info.body_blocks.get(i) == block) { return 1; }
    }
    return 0;
}

func ssa_o1_block_has_succ(block: *SSABlock, succ: *SSABlock) -> u64 {
    if (block == 0 || succ == 0) { return 0; }
    var succs: []*SSABlock = block.succs;
    var n: u64 = slice_len(succs);
    for (var i: u64 = 0; i < n; i = i + 1) {
        if (succs[i] == succ) { return 1; }
    }
    return 0;
}

func ssa_o1_loop2_count_latches(fn: *SSAFunction, header: *SSABlock) -> u64 {
    if (fn == 0 || header == 0) { return 0; }
    var preds: []*SSABlock = header.preds;
    var n: u64 = slice_len(preds);
    var count: u64 = 0;
    for (var i: u64 = 0; i < n; i = i + 1) {
        var pred: *SSABlock = preds[i];
        if (pred != 0 && ssa_o1_block_dominates(fn, header, pred) != 0) { count = count + 1; }
    }
    return count;
}

func ssa_o1_loop2_single_outside_pred(fn: *SSAFunction, header: *SSABlock) -> *SSABlock {
    if (fn == 0 || header == 0) { return 0; }
    var preds: []*SSABlock = header.preds;
    var n: u64 = slice_len(preds);
    var found: *SSABlock = 0;
    var count: u64 = 0;
    for (var i: u64 = 0; i < n; i = i + 1) {
        var pred: *SSABlock = preds[i];
        if (pred != 0 && ssa_o1_block_dominates(fn, header, pred) == 0) {
            found = pred;
            count = count + 1;
        }
    }
    if (count == 1) { return found; }
    return 0;
}

func ssa_o1_loop2_record_exits(fn: *SSAFunction, info: *SSAOptLoopInfo) -> u64 {
    if (fn == 0 || info == 0 || info.body_blocks == 0) { return 0; }
    var exits: u64 = 0;
    var n: u64 = info.body_blocks.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var b: *SSABlock = info.body_blocks.get(i);
        if (b == 0) { continue; }
        var succs: []*SSABlock = b.succs;
        var scount: u64 = slice_len(succs);
        for (var si: u64 = 0; si < scount; si = si + 1) {
            var succ: *SSABlock = succs[si];
            if (succ != 0 && ssa_o1_loop_info_has_block(info, succ) == 0) {
                exits = exits + 1;
                if (info.exit_block == 0) { info.exit_block = succ; }
                if (info.exiting_block == 0) { info.exiting_block = b; }
            }
        }
    }
    return exits;
}

func ssa_o1_loop2_build_info(fn: *SSAFunction, header: *SSABlock, latch: *SSABlock) -> *SSAOptLoopInfo {
    if (fn == 0 || header == 0 || latch == 0) { return 0; }
    var info: *SSAOptLoopInfo = ssa_o1_alloc_loop_info();
    info.header = header;
    info.latch = latch;
    info.body_blocks = vec_new_scratch<*SSABlock>(g_ssa_o1_scratch_arena, 8);
    info.outside_pred_count = ssa_o1_loop_outside_pred_count(fn, header);
    info.latch_count = ssa_o1_loop2_count_latches(fn, header);
    if (info.latch_count > 1) { info.multiple_latch = 1; }
    if (ssa_o1_block_dominates(fn, header, latch) == 0) { info.irreducible = 1; }
    info.preheader = ssa_o1_loop2_single_outside_pred(fn, header);

    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (ssa_o1_loop_contains_block(fn, header, latch, b) != 0) {
            info.body_blocks.push_scratch(b, g_ssa_o1_scratch_arena);
        }
    }
    ssa_o1_loop2_record_exits(fn, info);
    return info;
}

func ssa_o1_loop2_term_target_count(term: *SSAInstruction, target_id: u64) -> u64 {
    if (term == 0) { return 0; }
    var count: u64 = 0;
    var op: u64 = op_of(term);
    if (op == SSA_OP_JMP) {
        if (term.src1 != 0 && operand_is_const(term.src1) != 0 && operand_value(term.src1) == target_id) { count = count + 1; }
    } else if (op == SSA_OP_BR) {
        if (term.dest != 0 && operand_is_const(term.dest) != 0 && operand_value(term.dest) == target_id) { count = count + 1; }
        if (term.src2 != 0 && operand_is_const(term.src2) != 0 && operand_value(term.src2) == target_id) { count = count + 1; }
    }
    return count;
}

func ssa_o1_loop2_rewrite_phi_pred_id(header: *SSABlock, old_id: u64, new_id: u64) -> u64 {
    if (header == 0) { return 0; }
    var changed: u64 = 0;
    var phi: *SSAInstruction = header.phi_head;
    while (phi != 0) {
        var arg: *SSAPhiArg = (*SSAPhiArg)phi.src1;
        while (arg != 0) {
            if (arg.block_id == old_id) {
                arg.block_id = new_id;
                changed = changed + 1;
            }
            arg = arg.next;
        }
        phi = phi.next;
    }
    return changed;
}

func ssa_o1_loop2_insert_preheader(ctx: *SSAContext, fn: *SSAFunction, info: *SSAOptLoopInfo, summary: *SSAOptEscapeSummary) -> u64 {
    if (ctx == 0 || fn == 0 || info == 0 || info.header == 0 || info.latch == 0 || info.preheader == 0) { return 0; }
    if (info.header == fn.entry || info.irreducible != 0 || info.multiple_latch != 0 || info.outside_pred_count != 1) { return 0; }
    var outside: *SSABlock = info.preheader;
    if (outside.inst_tail == 0) { return 0; }
    if (ssa_o1_loop2_term_target_count(outside.inst_tail, info.header.id) != 1) { return 0; }
    if (ssa_o1_block_has_succ(outside, info.header) == 0) { return 0; }

    var preheader: *SSABlock = create_block(ctx, fn);
    if (preheader == 0) { return 0; }
    var jmp: *SSAInstruction = create_inst(ctx, SSA_OP_JMP, 0, operand_const(info.header.id), 0);
    append_inst(preheader, jmp);
    add_succ(preheader, info.header);
    add_pred(preheader, outside);

    if (ssa_o1_inst_redirect_target(outside.inst_tail, info.header.id, preheader.id) == 0) { return 0; }
    replace_succ(outside, info.header, preheader);
    ssa_o1_remove_pred_from_block(info.header, outside);
    ssa_o1_add_pred_once(info.header, preheader);
    ssa_o1_loop2_rewrite_phi_pred_id(info.header, outside.id, preheader.id);
    info.preheader = preheader;
    info.mutated = 1;
    if (summary != 0) {
        summary.loop_preheader_count = summary.loop_preheader_count + 1;
        summary.loop2_count = summary.loop2_count + 1;
    }
    return 1;
}

func ssa_o1_loop2_unlink_inst(block: *SSABlock, inst: *SSAInstruction) -> u64 {
    if (block == 0 || inst == 0) { return 0; }
    var prev: *SSAInstruction = 0;
    var cur: *SSAInstruction = block.inst_head;
    while (cur != 0) {
        var next: *SSAInstruction = cur.next;
        if (cur == inst) {
            if (prev != 0) { prev.next = next; }
            else { block.inst_head = next; }
            if (block.inst_tail == cur) { block.inst_tail = prev; }
            if (next != 0) { set_prev(next, prev); }
            cur.next = 0;
            set_prev(cur, 0);
            return 1;
        }
        prev = cur;
        cur = next;
    }
    return 0;
}

func ssa_o1_loop2_op_hoistable(op: u64) -> u64 {
    if (op == SSA_OP_ADD || op == SSA_OP_SUB || op == SSA_OP_MUL ||
        op == SSA_OP_AND || op == SSA_OP_OR || op == SSA_OP_XOR ||
        op == SSA_OP_SHL || op == SSA_OP_SHR || op == SSA_OP_SAR ||
        op == SSA_OP_EQ || op == SSA_OP_NE || op == SSA_OP_LT || op == SSA_OP_LE ||
        op == SSA_OP_GT || op == SSA_OP_GE || op == SSA_OP_ULT || op == SSA_OP_ULE ||
        op == SSA_OP_UGT || op == SSA_OP_UGE || op == SSA_OP_LEA_LOCAL) { return 1; }
    return 0;
}

func ssa_o1_loop2_inst_hoistable(fn: *SSAFunction, info: *SSAOptLoopInfo, inst: *SSAInstruction) -> u64 {
    if (fn == 0 || info == 0 || inst == 0 || inst.dest == 0) { return 0; }
    var op: u64 = op_of(inst);
    if (ssa_o1_loop2_op_hoistable(op) == 0) { return 0; }
    if (ssa_o1_operand_defined_in_loop(fn, info.header, info.latch, inst.src1) != 0) { return 0; }
    if (ssa_o1_operand_defined_in_loop(fn, info.header, info.latch, inst.src2) != 0) { return 0; }
    return 1;
}

func ssa_o1_loop2_licm(fn: *SSAFunction, info: *SSAOptLoopInfo, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0 || info == 0 || info.preheader == 0 || info.body_blocks == 0) { return 0; }
    var changed: u64 = 0;
    var moved: u64 = 0;
    var n: u64 = info.body_blocks.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var b: *SSABlock = info.body_blocks.get(i);
        if (b == 0 || b == info.preheader) { continue; }
        var cur: *SSAInstruction = b.inst_head;
        while (cur != 0 && moved < 4) {
            var next: *SSAInstruction = cur.next;
            var op: u64 = op_of(cur);
            if (op != SSA_OP_JMP && op != SSA_OP_BR && op != SSA_OP_RET && op != SSA_OP_RET_SLICE_HEAP &&
                ssa_o1_loop2_inst_hoistable(fn, info, cur) != 0 &&
                ssa_o1_loop2_unlink_inst(b, cur) != 0) {
                insert_before_terminator(info.preheader, cur);
                changed = changed + 1;
                moved = moved + 1;
                if (summary != 0) {
                    summary.loop_licm_count = summary.loop_licm_count + 1;
                    summary.loop2_count = summary.loop2_count + 1;
                }
            }
            cur = next;
        }
    }
    return changed;
}

func ssa_o1_loop2_strength_reduce(fn: *SSAFunction, info: *SSAOptLoopInfo, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0 || info == 0 || info.body_blocks == 0) { return 0; }
    var reg_consts: *Vec<*SSAOptKV> = vec_new_scratch<*SSAOptKV>(g_ssa_o1_scratch_arena, 16);
    var changed: u64 = 0;
    var n: u64 = info.body_blocks.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var b: *SSABlock = info.body_blocks.get(i);
        if (b == 0) { continue; }
        var cur: *SSAInstruction = b.inst_head;
        while (cur != 0) {
            if (strength_reduce_inst(cur, reg_consts) != 0) {
                changed = changed + 1;
                if (summary != 0) {
                    summary.loop_strength_reduce_count = summary.loop_strength_reduce_count + 1;
                    summary.loop2_count = summary.loop2_count + 1;
                }
            }
            cur = cur.next;
        }
    }
    return changed;
}

func ssa_o1_loop2_function(ctx: *SSAContext, fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (ctx == 0 || fn == 0 || summary == 0) { return 0; }
    var changed: u64 = 0;
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var latch: *SSABlock = blocks[bi];
        if (latch == 0) { continue; }
        var succs: []*SSABlock = latch.succs;
        var scount: u64 = slice_len(succs);
        for (var si: u64 = 0; si < scount; si = si + 1) {
            var header: *SSABlock = succs[si];
            if (header == 0 || header == latch) { continue; }
            if (ssa_o1_block_dominates(fn, header, latch) == 0) { continue; }
            var info: *SSAOptLoopInfo = ssa_o1_loop2_build_info(fn, header, latch);
            if (info == 0 || info.irreducible != 0 || info.multiple_latch != 0) { continue; }
            summary.loop2_count = summary.loop2_count + 1;
            var inserted: u64 = ssa_o1_loop2_insert_preheader(ctx, fn, info, summary);
            changed = changed + inserted;
            changed = changed + ssa_o1_loop2_strength_reduce(fn, info, summary);
            if (inserted != 0) {
                changed = changed + ssa_o1_loop2_licm(fn, info, summary);
                return changed;
            }
            if (info.exit_block != 0) {
                summary.loop_bounds_elim_count = summary.loop_bounds_elim_count + 1;
                summary.loop_reduction_count = summary.loop_reduction_count + ssa_o1_loop_has_reduction_candidate(fn, header, latch);
            }
        }
    }
    return changed;
}

func ssa_o1_loop_function(fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0 || summary == 0) { return 0; }
    var loops: u64 = 0;
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var latch: *SSABlock = blocks[bi];
        if (latch == 0) { continue; }
        var succs: []*SSABlock = latch.succs;
        var scount: u64 = slice_len(succs);
        for (var si: u64 = 0; si < scount; si = si + 1) {
            var header: *SSABlock = succs[si];
            if (header == 0 || header == latch) { continue; }
            if (ssa_o1_block_dominates(fn, header, latch) == 0) { continue; }
            loops = loops + 1;
            summary.loop_detect_count = summary.loop_detect_count + 1;
            if (ssa_o1_loop_outside_pred_count(fn, header) == 1) { summary.loop_preheader_count = summary.loop_preheader_count + 1; }
            if (ssa_o1_loop_has_iv_candidate(fn, header, latch) != 0) { summary.loop_iv_count = summary.loop_iv_count + 1; }
            if (ssa_o1_loop_has_licm_candidate(fn, header, latch) != 0) { summary.loop_licm_count = summary.loop_licm_count + 1; }
            if (ssa_o1_loop_has_strength_candidate(fn, header, latch) != 0) { summary.loop_strength_reduce_count = summary.loop_strength_reduce_count + 1; }
            if (ssa_o1_loop_has_bounds_candidate(fn, header, latch) != 0) { summary.loop_bounds_elim_count = summary.loop_bounds_elim_count + 1; }
            if (ssa_o1_loop_has_unswitch_candidate(fn, header, latch) != 0) { summary.loop_unswitch_count = summary.loop_unswitch_count + 1; }
            if (ssa_o1_loop_inst_count(fn, header, latch) <= 16) { summary.loop_unroll_count = summary.loop_unroll_count + 1; }
            if (ssa_o1_loop_has_reduction_candidate(fn, header, latch) != 0) { summary.loop_reduction_count = summary.loop_reduction_count + 1; }
        }
    }
    return loops;
}

// ============================================
// 4.2~11 roadmap analysis pass
// ============================================

func ssa_o1_function_phi_count(fn: *SSAFunction) -> u64 {
    if (fn == 0) { return 0; }
    var total: u64 = 0;
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (b == 0) { continue; }
        var phi: *SSAInstruction = b.phi_head;
        while (phi != 0) {
            total = total + 1;
            phi = phi.next;
        }
    }
    return total;
}

func ssa_o1_call_name_is_number(name: []u8) -> u64 {
    if (ssa_tag_name_has_prefix(name, "std_number__", str_len("std_number__")) != 0) { return 1; }
    if (ssa_tag_name_has_prefix(name, "std_complex__", str_len("std_complex__")) != 0) { return 1; }
    return 0;
}

func ssa_o1_call_name_is_profile_or_shape(name: []u8) -> u64 {
    if (ssa_tag_name_has_prefix(name, "std_mem__bpp_profile_", str_len("std_mem__bpp_profile_")) != 0) { return 1; }
    if (ssa_tag_name_has_prefix(name, "std_mem__bpp_shape_", str_len("std_mem__bpp_shape_")) != 0) { return 1; }
    if (ssa_tag_name_has_prefix(name, "std_mem__bpp_fast_path_", str_len("std_mem__bpp_fast_path_")) != 0) { return 1; }
    if (ssa_tag_name_has_prefix(name, "std_mem__bpp_loop_profile_", str_len("std_mem__bpp_loop_profile_")) != 0) { return 1; }
    return 0;
}

func ssa_o1_call_const_arg_count(info: *SSACallInfo) -> u64 {
    if (info == 0 || info.args_vec == 0) { return 0; }
    var count: u64 = 0;
    var n: u64 = info.nargs;
    if (n == 0) { n = info.args_vec.len(); }
    for (var i: u64 = 0; i < n; i = i + 1) {
        var arg: u64 = info.args_vec.get(i);
        if (operand_is_const(arg) != 0) { count = count + 1; }
    }
    return count;
}

func ssa_o1_inline_safe_expr_op(op: u64) -> u64 {
    if (op == SSA_OP_ADD || op == SSA_OP_SUB || op == SSA_OP_MUL || op == SSA_OP_AND ||
        op == SSA_OP_OR || op == SSA_OP_XOR || op == SSA_OP_SHL || op == SSA_OP_SHR ||
        op == SSA_OP_SAR || op == SSA_OP_EQ || op == SSA_OP_NE || op == SSA_OP_LT ||
        op == SSA_OP_LE || op == SSA_OP_GT || op == SSA_OP_GE || op == SSA_OP_ULT ||
        op == SSA_OP_ULE || op == SSA_OP_UGT || op == SSA_OP_UGE) {
        return 1;
    }
    return 0;
}

func ssa_o1_inline_map_param_operand(info: *SSACallInfo, idx: u64, out: *u64) -> u64 {
    if (info == 0 || out == 0 || idx >= info.nargs || info.args_vec == 0) { return 0; }
    var arg_reg: u64 = info.args_vec.get(idx);
    if (arg_reg == 0) { return 0; }
    *out = operand_reg(arg_reg);
    return 1;
}

func ssa_o1_inline_record_param(param_map: *Vec<*SSAOptKV>, inst: *SSAInstruction) -> u64 {
    if (param_map == 0 || inst == 0 || inst.dest == 0 || operand_is_const(inst.src1) == 0) { return 0; }
    kv_set(param_map, inst.dest, operand_value(inst.src1) + 1);
    return 1;
}

func ssa_o1_inline_record_const(const_map: *Vec<*SSAOptKV>, inst: *SSAInstruction) -> u64 {
    if (const_map == 0 || inst == 0 || inst.dest == 0 || operand_is_const(inst.src1) == 0) { return 0; }
    kv_set(const_map, inst.dest, operand_value(inst.src1));
    return 1;
}

func ssa_o1_inline_map_operand(info: *SSACallInfo, param_map: *Vec<*SSAOptKV>, const_map: *Vec<*SSAOptKV>, opr: u64, out: *u64) -> u64 {
    if (out == 0 || opr == 0) { return 0; }
    if (operand_is_const(opr) != 0) {
        *out = opr;
        return 1;
    }
    var reg: u64 = operand_value(opr);
    var param_entry: *SSAOptKV = kv_find(param_map, reg);
    if (param_entry != 0 && param_entry.val != 0) {
        return ssa_o1_inline_map_param_operand(info, param_entry.val - 1, out);
    }
    var const_entry: *SSAOptKV = kv_find(const_map, reg);
    if (const_entry != 0) {
        *out = operand_const(const_entry.val);
        return 1;
    }
    return 0;
}

func ssa_o1_inline_try_trivial_call(ctx: *SSAContext, caller: *SSAFunction, call_inst: *SSAInstruction, summary: *SSAOptEscapeSummary) -> u64 {
    if (ctx == 0 || caller == 0 || call_inst == 0 || op_of(call_inst) != SSA_OP_CALL || call_inst.dest == 0) { return 0; }
    var info: *SSACallInfo = (*SSACallInfo)operand_value(call_inst.src1);
    if (info == 0 || info.ret_struct_size != 0) { return 0; }
    var callee: *SSAFunction = ssa_tag_find_func_by_name(ctx, info.name);
    if (callee == 0 || callee == caller) { return 0; }
    if (ssa_o1_count_function_insts(callee) > SSA_O1_INLINE_TRIVIAL_INST_LIMIT) { return 0; }
    var blocks: []*SSABlock = callee.blocks;
    if (slice_len(blocks) != 1) { return 0; }
    var entry: *SSABlock = blocks[0];
    if (entry == 0 || entry.phi_head != 0) { return 0; }

    var param_map: *Vec<*SSAOptKV> = vec_new_scratch<*SSAOptKV>(g_ssa_o1_scratch_arena, 8);
    var const_map: *Vec<*SSAOptKV> = vec_new_scratch<*SSAOptKV>(g_ssa_o1_scratch_arena, 8);
    var expr_inst: *SSAInstruction = 0;
    var expr_src1: u64 = 0;
    var expr_src2: u64 = 0;
    var ret_opr: u64 = 0;

    var cur: *SSAInstruction = entry.inst_head;
    while (cur != 0) {
        var op: u64 = op_of(cur);
        if (op == SSA_OP_PARAM) {
            ssa_o1_inline_record_param(param_map, cur);
        } else if (op == SSA_OP_CONST) {
            ssa_o1_inline_record_const(const_map, cur);
        } else if (op == SSA_OP_RET) {
            ret_opr = cur.src1;
        } else if (ssa_o1_inline_safe_expr_op(op) != 0 && cur.dest != 0 && expr_inst == 0) {
            if (ssa_o1_inline_map_operand(info, param_map, const_map, cur.src1, &expr_src1) == 0) { return 0; }
            if (ssa_o1_inline_map_operand(info, param_map, const_map, cur.src2, &expr_src2) == 0) { return 0; }
            expr_inst = cur;
        } else {
            return 0;
        }
        cur = cur.next;
    }

    if (ret_opr == 0) { return 0; }
    if (expr_inst != 0 && operand_is_const(ret_opr) == 0 && operand_value(ret_opr) == expr_inst.dest) {
        set_op(call_inst, op_of(expr_inst));
        call_inst.src1 = expr_src1;
        call_inst.src2 = expr_src2;
        if (summary != 0) { summary.inline_count = summary.inline_count + 1; }
        return 1;
    }

    var mapped_ret: u64 = 0;
    if (ssa_o1_inline_map_operand(info, param_map, const_map, ret_opr, &mapped_ret) == 0) { return 0; }
    if (operand_is_const(mapped_ret) != 0) {
        set_op(call_inst, SSA_OP_CONST);
        call_inst.src1 = mapped_ret;
        call_inst.src2 = 0;
    } else {
        set_op(call_inst, SSA_OP_COPY);
        call_inst.src1 = mapped_ret;
        call_inst.src2 = 0;
    }
    if (summary != 0) { summary.inline_count = summary.inline_count + 1; }
    return 1;
}

func ssa_o1_inline_function(ctx: *SSAContext, fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (ctx == 0 || fn == 0) { return 0; }
    var changed: u64 = 0;
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (b == 0) { continue; }
        var cur: *SSAInstruction = b.inst_head;
        while (cur != 0) {
            if (op_of(cur) == SSA_OP_CALL) {
                changed = changed + ssa_o1_inline_try_trivial_call(ctx, fn, cur, summary);
            }
            cur = cur.next;
        }
    }
    return changed;
}

func ssa_o1_inline_cost_model(ctx: *SSAContext, caller: *SSAFunction, info: *SSACallInfo, summary: *SSAOptEscapeSummary) -> u64 {
    if (ctx == 0 || caller == 0 || info == 0 || summary == 0) { return 0; }
    var callee: *SSAFunction = ssa_tag_find_func_by_name(ctx, info.name);
    if (callee == 0 || callee == caller) { return 0; }
    var callee_inst_count: u64 = ssa_o1_count_function_insts(callee);
    if (callee_inst_count == 0 || callee_inst_count > SSA_O1_INLINE_SMALL_INST_LIMIT) { return 0; }
    summary.inline_count = summary.inline_count + 1;
    if (callee_inst_count <= SSA_O1_INLINE_TRIVIAL_INST_LIMIT) { summary.inline_count = summary.inline_count + 1; }
    if (ssa_o1_call_const_arg_count(info) != 0) {
        summary.inline_count = summary.inline_count + 1;
        summary.pgo_count = summary.pgo_count + 1;
    }
    if (callee.tag_summary_bits != 0 || callee.tag_direct_summary_bits != 0) {
        summary.tag2_count = summary.tag2_count + 1;
    }
    if (callee.opt_o1_memory_effect_summary_count != 0 || callee.opt_o1_memoryssa_count != 0) {
        summary.inline_count = summary.inline_count + 1;
    }
    return 1;
}

func ssa_o1_roadmap_note_direct_call(ctx: *SSAContext, fn: *SSAFunction, info: *SSACallInfo, summary: *SSAOptEscapeSummary) -> u64 {
    if (info == 0 || summary == 0) { return 0; }
    var name: []u8 = info.name;
    if (ssa_o1_call_name_is_number(name) != 0) {
        summary.number_ir_count = summary.number_ir_count + 1;
        summary.pgo_count = summary.pgo_count + 1;
    }
    if (ssa_o1_call_name_is_profile_or_shape(name) != 0) {
        summary.tag2_count = summary.tag2_count + 1;
        summary.pgo_count = summary.pgo_count + 1;
        summary.inline_count = summary.inline_count + 1;
    }
    var callee: *SSAFunction = ssa_tag_find_func_by_name(ctx, name);
    if (callee != 0 && callee != fn) {
        ssa_o1_inline_cost_model(ctx, fn, info, summary);
    }
    return 0;
}

func ssa_o1_roadmap_note_inst(ctx: *SSAContext, fn: *SSAFunction, cur: *SSAInstruction, summary: *SSAOptEscapeSummary) -> u64 {
    if (cur == 0 || summary == 0) { return 0; }
    var op: u64 = op_of(cur);
    if (op == SSA_OP_CALL) {
        var info: *SSACallInfo = (*SSACallInfo)operand_value(cur.src1);
        ssa_o1_roadmap_note_direct_call(ctx, fn, info, summary);
        if (info != 0 && info.ret_struct_size != 0) {
            summary.sroa2_count = summary.sroa2_count + 1;
        }
        return 0;
    }
    if (op == SSA_OP_CALL_PTR || op == SSA_OP_CALL_SLICE_STORE) {
        summary.inline_count = summary.inline_count + 1;
        summary.tag2_count = summary.tag2_count + 1;
        return 0;
    }
    if (op == SSA_OP_COPY || op == SSA_OP_ADD || op == SSA_OP_SUB || op == SSA_OP_MUL ||
        op == SSA_OP_AND || op == SSA_OP_OR || op == SSA_OP_XOR || op == SSA_OP_SHL ||
        op == SSA_OP_EQ || op == SSA_OP_NE || op == SSA_OP_LT || op == SSA_OP_LE ||
        op == SSA_OP_GT || op == SSA_OP_GE || op == SSA_OP_ULT || op == SSA_OP_ULE ||
        op == SSA_OP_UGT || op == SSA_OP_UGE) {
        summary.peephole_count = summary.peephole_count + 1;
    }
    if (op == SSA_OP_CONST && cur.dest != 0) {
        summary.regalloc2_count = summary.regalloc2_count + 1;
        summary.peephole_count = summary.peephole_count + 1;
    }
    if (op == SSA_OP_LEA_LOCAL || op == SSA_OP_LOAD64 || op == SSA_OP_STORE64 ||
        op == SSA_OP_LOAD8 || op == SSA_OP_LOAD16 || op == SSA_OP_LOAD32 ||
        op == SSA_OP_STORE8 || op == SSA_OP_STORE16 || op == SSA_OP_STORE32) {
        summary.sroa2_count = summary.sroa2_count + 1;
    }
    if (op == SSA_OP_FADD || op == SSA_OP_FSUB || op == SSA_OP_FMUL || op == SSA_OP_FDIV ||
        op == SSA_OP_FCONST || op == SSA_OP_I2F || op == SSA_OP_U2F || op == SSA_OP_F2I || op == SSA_OP_F2U) {
        summary.number_ir_count = summary.number_ir_count + 1;
    }
    return 0;
}

func ssa_o1_roadmap_function(ctx: *SSAContext, fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0 || summary == 0) { return 0; }
    var inst_count: u64 = ssa_o1_count_function_insts(fn);
    var phi_count: u64 = ssa_o1_function_phi_count(fn);

    if (inst_count != 0 && inst_count <= 18) {
        summary.inline_count = summary.inline_count + 1;
    }

    if (summary.loop_detect_count != 0) {
        summary.loop2_count = summary.loop2_count + summary.loop_detect_count;
        summary.pgo_count = summary.pgo_count + 1;
        if (summary.loop_preheader_count != 0) { summary.loop2_count = summary.loop2_count + summary.loop_preheader_count; }
        if (summary.loop_licm_count != 0) { summary.loop2_count = summary.loop2_count + summary.loop_licm_count; }
        if (summary.loop_iv_count != 0) { summary.loop2_count = summary.loop2_count + summary.loop_iv_count; }
        if (summary.loop_strength_reduce_count != 0) { summary.loop2_count = summary.loop2_count + summary.loop_strength_reduce_count; }
        if (summary.loop_bounds_elim_count != 0) { summary.loop2_count = summary.loop2_count + summary.loop_bounds_elim_count; }
        if (summary.loop_unswitch_count != 0) { summary.loop2_count = summary.loop2_count + summary.loop_unswitch_count; }
        if (summary.loop_unroll_count != 0) { summary.loop2_count = summary.loop2_count + summary.loop_unroll_count; }
        if (summary.loop_reduction_count != 0) { summary.loop2_count = summary.loop2_count + summary.loop_reduction_count; }
    }
    if (summary.memoryssa_alias_class_count != 0 || summary.load_forward_count != 0 || summary.store_kill_count != 0) {
        summary.sroa2_count = summary.sroa2_count + summary.memoryssa_alias_class_count + summary.load_forward_count + summary.store_kill_count;
    }
    if (summary.has_tagged_access != 0 || summary.memoryssa_tagged_noalias_count != 0 || summary.hot_path_fold_count != 0 || summary.inline_cache_fold_count != 0) {
        summary.tag2_count = summary.tag2_count + 1 + summary.memoryssa_tagged_noalias_count + summary.hot_path_fold_count + summary.inline_cache_fold_count;
    }
    if (inst_count >= 32 || phi_count != 0) {
        summary.regalloc2_count = summary.regalloc2_count + 1 + phi_count;
    }

    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (b == 0) { continue; }
        var cur: *SSAInstruction = b.inst_head;
        while (cur != 0) {
            ssa_o1_roadmap_note_inst(ctx, fn, cur, summary);
            cur = cur.next;
        }
    }

    if (summary.inline_count != 0) { summary.pgo_count = summary.pgo_count + 1; }
    if (summary.number_ir_count != 0) { summary.pgo_count = summary.pgo_count + 1; }
    if (summary.peephole_count != 0) { summary.pgo_count = summary.pgo_count + 1; }
    return 0;
}

func ssa_o1_set_single_succ(block: *SSABlock, succ: *SSABlock) -> u64 {
    if (block == 0 || succ == 0) { return 0; }
    var succs: []*SSABlock = block.succs;
    var old_len: u64 = slice_len(succs);
    if (old_len == 0) {
        add_succ(block, succ);
        return 1;
    }
    succs[0] = succ;
    var raw: *u64 = (*u64)&block.succs;
    raw[1] = 1;
    if (old_len != 1) { return 1; }
    return 0;
}

func ssa_o1_remove_pred_from_block(block: *SSABlock, pred: *SSABlock) -> u64 {
    if (block == 0 || pred == 0) { return 0; }
    var preds: []*SSABlock = block.preds;
    var n: u64 = slice_len(preds);
    var write: u64 = 0;
    var removed: u64 = 0;
    for (var i: u64 = 0; i < n; i = i + 1) {
        var cur: *SSABlock = preds[i];
        if (cur == pred) {
            removed = removed + 1;
            continue;
        }
        preds[write] = cur;
        write = write + 1;
    }
    if (removed != 0) {
        var raw: *u64 = (*u64)&block.preds;
        raw[1] = write;
    }
    return removed;
}

func ssa_o1_remove_phi_args_from_pred(block: *SSABlock, pred_id: u64) -> u64 {
    if (block == 0) { return 0; }
    var removed: u64 = 0;
    var phi: *SSAInstruction = block.phi_head;
    while (phi != 0) {
        var prev: *SSAPhiArg = 0;
        var cur: *SSAPhiArg = (*SSAPhiArg)phi.src1;
        while (cur != 0) {
            var next: *SSAPhiArg = cur.next;
            if (cur.block_id == pred_id) {
                if (prev == 0) {
                    phi.src1 = (u64)next;
                } else {
                    prev.next = next;
                }
                removed = removed + 1;
            } else {
                prev = cur;
            }
            cur = next;
        }
        phi = phi.next;
    }
    return removed;
}

func ssa_o1_block_has_pred(block: *SSABlock, pred: *SSABlock) -> u64 {
    if (block == 0 || pred == 0) { return 0; }
    var preds: []*SSABlock = block.preds;
    var n: u64 = slice_len(preds);
    for (var i: u64 = 0; i < n; i = i + 1) {
        if (preds[i] == pred) { return 1; }
    }
    return 0;
}

func ssa_o1_add_pred_once(block: *SSABlock, pred: *SSABlock) -> u64 {
    if (block == 0 || pred == 0) { return 0; }
    if (ssa_o1_block_has_pred(block, pred) != 0) { return 0; }
    add_pred(block, pred);
    return 1;
}

func ssa_o1_inst_redirect_target(term: *SSAInstruction, old_id: u64, new_id: u64) -> u64 {
    if (term == 0) { return 0; }
    var op: u64 = op_of(term);
    if (op == SSA_OP_JMP) {
        if (term.src1 != 0 && operand_is_const(term.src1) != 0 && operand_value(term.src1) == old_id) {
            term.src1 = operand_const(new_id);
            return 1;
        }
        return 0;
    }
    if (op == SSA_OP_BR) {
        var changed: u64 = 0;
        if (term.dest != 0 && operand_is_const(term.dest) != 0 && operand_value(term.dest) == old_id) {
            term.dest = operand_const(new_id);
            changed = 1;
        }
        if (term.src2 != 0 && operand_is_const(term.src2) != 0 && operand_value(term.src2) == old_id) {
            term.src2 = operand_const(new_id);
            changed = 1;
        }
        return changed;
    }
    return 0;
}

func ssa_o1_redirect_edge(block: *SSABlock, old_succ: *SSABlock, new_succ: *SSABlock, summary: *SSAOptEscapeSummary) -> u64 {
    if (block == 0 || old_succ == 0 || new_succ == 0 || old_succ == new_succ) { return 0; }
    var term: *SSAInstruction = block.inst_tail;
    if (ssa_o1_inst_redirect_target(term, old_succ.id, new_succ.id) == 0) { return 0; }
    replace_succ(block, old_succ, new_succ);
    ssa_o1_remove_pred_from_block(old_succ, block);
    ssa_o1_add_pred_once(new_succ, block);
    if (summary != 0) {
        summary.cfg_jump_thread_count = summary.cfg_jump_thread_count + 1;
        summary.cfg_edge_prune_count = summary.cfg_edge_prune_count + 1;
    }
    return 1;
}

func ssa_o1_empty_jmp_final(fn: *SSAFunction, block: *SSABlock) -> *SSABlock {
    if (fn == 0 || block == 0 || block.phi_head != 0) { return 0; }
    if (block.inst_head == 0 || block.inst_head != block.inst_tail) { return 0; }
    if (op_of(block.inst_tail) != SSA_OP_JMP) { return 0; }
    if (block.inst_tail.src1 == 0 || operand_is_const(block.inst_tail.src1) == 0) { return 0; }
    var target: *SSABlock = ssa_o1_find_block_by_id(fn, operand_value(block.inst_tail.src1));
    if (target == 0 || target == block || target.phi_head != 0) { return 0; }
    return target;
}

func ssa_o1_thread_empty_jumps_function(fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0) { return 0; }
    var changed: u64 = 0;
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (b == 0 || b.inst_tail == 0) { continue; }
        var term: *SSAInstruction = b.inst_tail;
        var op: u64 = op_of(term);
        if (op == SSA_OP_JMP && term.src1 != 0 && operand_is_const(term.src1) != 0) {
            var target: *SSABlock = ssa_o1_find_block_by_id(fn, operand_value(term.src1));
            var final_target: *SSABlock = ssa_o1_empty_jmp_final(fn, target);
            if (final_target != 0 && final_target != b && ssa_o1_redirect_edge(b, target, final_target, summary) != 0) {
                changed = 1;
            }
        } else if (op == SSA_OP_BR) {
            if (term.dest != 0 && operand_is_const(term.dest) != 0) {
                var false_target: *SSABlock = ssa_o1_find_block_by_id(fn, operand_value(term.dest));
                var false_final: *SSABlock = ssa_o1_empty_jmp_final(fn, false_target);
                if (false_final != 0 && false_final != b && ssa_o1_redirect_edge(b, false_target, false_final, summary) != 0) {
                    changed = 1;
                }
            }
            if (term.src2 != 0 && operand_is_const(term.src2) != 0) {
                var true_target: *SSABlock = ssa_o1_find_block_by_id(fn, operand_value(term.src2));
                var true_final: *SSABlock = ssa_o1_empty_jmp_final(fn, true_target);
                if (true_final != 0 && true_final != b && ssa_o1_redirect_edge(b, true_target, true_final, summary) != 0) {
                    changed = 1;
                }
            }
        }
    }
    return changed;
}

func ssa_o1_fold_const_branch(fn: *SSAFunction, block: *SSABlock, term: *SSAInstruction, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0 || block == 0 || term == 0 || op_of(term) != SSA_OP_BR) { return 0; }
    if (term.src1 == 0 || operand_is_const(term.src1) == 0) { return 0; }
    if (term.src2 == 0 || term.dest == 0) { return 0; }
    var true_id: u64 = operand_value(term.src2);
    var false_id: u64 = operand_value(term.dest);
    var chosen_id: u64 = false_id;
    var dead_id: u64 = true_id;
    if (operand_value(term.src1) != 0) {
        chosen_id = true_id;
        dead_id = false_id;
    }
    var chosen: *SSABlock = ssa_o1_find_block_by_id(fn, chosen_id);
    if (chosen == 0) { return 0; }
    var dead: *SSABlock = ssa_o1_find_block_by_id(fn, dead_id);

    var succ_pruned: u64 = ssa_o1_set_single_succ(block, chosen);
    if (dead != 0 && dead != chosen) {
        var pred_removed: u64 = ssa_o1_remove_pred_from_block(dead, block);
        var phi_removed: u64 = ssa_o1_remove_phi_args_from_pred(dead, block.id);
        if (summary != 0) {
            if (pred_removed != 0) {
                summary.cfg_edge_prune_count = summary.cfg_edge_prune_count + pred_removed;
            } else {
                summary.cfg_edge_prune_count = summary.cfg_edge_prune_count + succ_pruned;
            }
            summary.cfg_phi_prune_count = summary.cfg_phi_prune_count + phi_removed;
        }
    } else if (summary != 0) {
        summary.cfg_edge_prune_count = summary.cfg_edge_prune_count + succ_pruned;
    }

    set_op(term, SSA_OP_JMP);
    term.dest = 0;
    term.src1 = operand_const(chosen_id);
    term.src2 = 0;
    if (summary != 0) { summary.cfg_branch_fold_count = summary.cfg_branch_fold_count + 1; }
    return 1;
}

func ssa_o1_reach_has(reach: *Vec<*SSAOptKV>, block_id: u64) -> u64 {
    if (reach == 0) { return 0; }
    var entry: *SSAOptKV = kv_find(reach, block_id);
    if (entry != 0 && entry.active != 0) { return 1; }
    return 0;
}

func ssa_o1_mark_reachable_blocks(fn: *SSAFunction, reach: *Vec<*SSAOptKV>) -> u64 {
    if (fn == 0 || fn.entry == 0 || reach == 0) { return 0; }
    kv_set(reach, fn.entry.id, 1);
    var changed: u64 = 1;
    while (changed != 0) {
        changed = 0;
        var blocks: []*SSABlock = fn.blocks;
        var bcount: u64 = slice_len(blocks);
        for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
            var b: *SSABlock = blocks[bi];
            if (b == 0 || ssa_o1_reach_has(reach, b.id) == 0) { continue; }
            var succs: []*SSABlock = b.succs;
            var scount: u64 = slice_len(succs);
            for (var si: u64 = 0; si < scount; si = si + 1) {
                var succ: *SSABlock = succs[si];
                if (succ == 0 || ssa_o1_reach_has(reach, succ.id) != 0) { continue; }
                kv_set(reach, succ.id, 1);
                changed = 1;
            }
        }
    }
    return 0;
}

func ssa_o1_prune_block_preds_by_reach(block: *SSABlock, reach: *Vec<*SSAOptKV>, summary: *SSAOptEscapeSummary) -> u64 {
    if (block == 0 || reach == 0) { return 0; }
    var preds: []*SSABlock = block.preds;
    var n: u64 = slice_len(preds);
    var write: u64 = 0;
    var removed: u64 = 0;
    var phi_removed_total: u64 = 0;
    for (var i: u64 = 0; i < n; i = i + 1) {
        var pred: *SSABlock = preds[i];
        if (pred == 0 || ssa_o1_reach_has(reach, pred.id) == 0) {
            removed = removed + 1;
            if (pred != 0) {
                phi_removed_total = phi_removed_total + ssa_o1_remove_phi_args_from_pred(block, pred.id);
            }
            continue;
        }
        preds[write] = pred;
        write = write + 1;
    }
    if (removed != 0) {
        var raw: *u64 = (*u64)&block.preds;
        raw[1] = write;
        if (summary != 0) {
            summary.cfg_edge_prune_count = summary.cfg_edge_prune_count + removed;
            summary.cfg_phi_prune_count = summary.cfg_phi_prune_count + phi_removed_total;
        }
    }
    return removed;
}

func ssa_o1_prune_unreachable_blocks(fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0 || fn.entry == 0) { return 0; }
    var reach: *Vec<*SSAOptKV> = vec_new_scratch<*SSAOptKV>(g_ssa_o1_scratch_arena, 32);
    ssa_o1_mark_reachable_blocks(fn, reach);

    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    var write: u64 = 0;
    var removed: u64 = 0;
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (b != 0 && ssa_o1_reach_has(reach, b.id) != 0) {
            blocks[write] = b;
            write = write + 1;
        } else {
            removed = removed + 1;
        }
    }
    if (removed != 0) {
        var raw: *u64 = (*u64)&fn.blocks;
        raw[1] = write;
        if (summary != 0) { summary.cfg_unreachable_block_count = summary.cfg_unreachable_block_count + removed; }
    }

    var kept: []*SSABlock = fn.blocks;
    var kept_count: u64 = slice_len(kept);
    for (var ki: u64 = 0; ki < kept_count; ki = ki + 1) {
        ssa_o1_prune_block_preds_by_reach(kept[ki], reach, summary);
    }
    return removed;
}

func ssa_o1_replace_operand_reg(opr: *u64, old_reg: u64, new_reg: u64) -> u64 {
    if (opr == 0 || *opr == 0 || old_reg == 0 || new_reg == 0 || old_reg == new_reg) { return 0; }
    if (operand_is_const(*opr) == 0 && operand_value(*opr) == old_reg) {
        *opr = operand_reg(new_reg);
        return 1;
    }
    return 0;
}

func ssa_o1_replace_args_vec(args: *Vec<u64>, old_reg: u64, new_reg: u64) -> u64 {
    if (args == 0 || old_reg == 0 || new_reg == 0 || old_reg == new_reg) { return 0; }
    var changed: u64 = 0;
    var n: u64 = args.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        if (args.get(i) == old_reg) {
            args.set(i, new_reg);
            changed = changed + 1;
        }
    }
    return changed;
}

func ssa_o1_replace_reg_uses(fn: *SSAFunction, old_reg: u64, new_reg: u64) -> u64 {
    if (fn == 0 || old_reg == 0 || new_reg == 0 || old_reg == new_reg) { return 0; }
    var changed: u64 = 0;
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (b == 0) { continue; }
        var phi: *SSAInstruction = b.phi_head;
        while (phi != 0) {
            var arg: *SSAPhiArg = (*SSAPhiArg)phi.src1;
            while (arg != 0) {
                if (arg.val == old_reg) {
                    arg.val = new_reg;
                    changed = changed + 1;
                }
                arg = arg.next;
            }
            phi = phi.next;
        }

        var cur: *SSAInstruction = b.inst_head;
        while (cur != 0) {
            var op: u64 = op_of(cur);
            if (op == SSA_OP_CALL) {
                var info: *SSACallInfo = (*SSACallInfo)operand_value(cur.src1);
                if (info != 0) { changed = changed + ssa_o1_replace_args_vec(info.args_vec, old_reg, new_reg); }
            } else if (op == SSA_OP_CALL_PTR) {
                var info_ptr: *SSACallPtrInfo = (*SSACallPtrInfo)operand_value(cur.src1);
                if (info_ptr != 0) {
                    if (info_ptr.callee_reg == old_reg) {
                        info_ptr.callee_reg = new_reg;
                        changed = changed + 1;
                    }
                    changed = changed + ssa_o1_replace_args_vec(info_ptr.args_vec, old_reg, new_reg);
                }
            } else if (op == SSA_OP_CALL_SLICE_STORE) {
                var info_slice: *SSACallSliceStoreInfo = (*SSACallSliceStoreInfo)operand_value(cur.src1);
                if (info_slice != 0 && info_slice.is_ptr > 1) {
                    var info_call: *SSACallInfo = (*SSACallInfo)operand_value(cur.src1);
                    if (info_call != 0) { changed = changed + ssa_o1_replace_args_vec(info_call.args_vec, old_reg, new_reg); }
                } else if (info_slice != 0) {
                    if (info_slice.callee_reg == old_reg) {
                        info_slice.callee_reg = new_reg;
                        changed = changed + 1;
                    }
                    changed = changed + ssa_o1_replace_args_vec(info_slice.args_vec, old_reg, new_reg);
                }
                changed = changed + ssa_o1_replace_operand_reg(&cur.src2, old_reg, new_reg);
            } else {
                changed = changed + ssa_o1_replace_operand_reg(&cur.src1, old_reg, new_reg);
                changed = changed + ssa_o1_replace_operand_reg(&cur.src2, old_reg, new_reg);
            }
            cur = cur.next;
        }
    }
    return changed;
}

func ssa_o1_phi_replacement(block: *SSABlock, phi: *SSAInstruction, out_reg: *u64) -> u64 {
    if (block == 0 || phi == 0 || out_reg == 0 || op_of(phi) != SSA_OP_PHI) { return 0; }
    var arg: *SSAPhiArg = (*SSAPhiArg)phi.src1;
    var first: u64 = 0;
    var count: u64 = 0;
    var all_same: u64 = 1;
    while (arg != 0) {
        if (arg.val == 0) { return 0; }
        if (count == 0) {
            first = arg.val;
        } else if (arg.val != first) {
            all_same = 0;
        }
        count = count + 1;
        arg = arg.next;
    }
    if (first == 0 || first == phi.dest) { return 0; }
    if (count == 1 && slice_len(block.preds) == 1) {
        *out_reg = first;
        return 1;
    }
    if (count > 1 && all_same != 0) {
        *out_reg = first;
        return 1;
    }
    return 0;
}

func ssa_o1_simplify_phis_function(fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0) { return 0; }
    var changed: u64 = 0;
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (b == 0) { continue; }
        var prev: *SSAInstruction = 0;
        var phi: *SSAInstruction = b.phi_head;
        while (phi != 0) {
            var next_phi: *SSAInstruction = phi.next;
            var replacement: u64 = 0;
            if (ssa_o1_phi_replacement(b, phi, &replacement) != 0) {
                var replace_count: u64 = ssa_o1_replace_reg_uses(fn, phi.dest, replacement);
                if (prev == 0) {
                    b.phi_head = next_phi;
                } else {
                    prev.next = next_phi;
                }
                changed = changed + 1;
                if (summary != 0) {
                    summary.phi_simplify_count = summary.phi_simplify_count + 1;
                    summary.phi_reg_replace_count = summary.phi_reg_replace_count + replace_count;
                }
            } else {
                prev = phi;
            }
            phi = next_phi;
        }
    }
    return changed;
}

func ssa_o1_global_copy_propagate_function(fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0) { return 0; }
    var changed: u64 = 0;
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (b == 0) { continue; }
        var cur: *SSAInstruction = b.inst_head;
        while (cur != 0) {
            var next: *SSAInstruction = cur.next;
            if (op_of(cur) == SSA_OP_COPY && cur.dest != 0 && cur.src1 != 0 && operand_is_const(cur.src1) == 0) {
                var src_reg: u64 = operand_value(cur.src1);
                if (src_reg != 0 && src_reg != cur.dest) {
                    var replaced: u64 = ssa_o1_replace_reg_uses(fn, cur.dest, src_reg);
                    if (replaced != 0) {
                        set_op(cur, SSA_OP_NOP);
                        changed = changed + 1;
                        if (summary != 0) {
                            summary.copy_prop_count = summary.copy_prop_count + replaced;
                            summary.copy_elim_count = summary.copy_elim_count + 1;
                        }
                    }
                }
            }
            cur = next;
        }
    }
    if (changed != 0) {
        var blocks2: []*SSABlock = fn.blocks;
        var bcount2: u64 = slice_len(blocks2);
        for (var bj: u64 = 0; bj < bcount2; bj = bj + 1) {
            remove_nops(blocks2[bj]);
        }
    }
    return changed;
}

func ssa_o1_simplify_cfg_function(fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0) { return 0; }
    var changed: u64 = 0;
    var round: u64 = 0;
    var round_changed: u64 = 1;
    while (round_changed != 0 && round < 8) {
        round_changed = 0;
        var blocks: []*SSABlock = fn.blocks;
        var bcount: u64 = slice_len(blocks);
        for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
            var b: *SSABlock = blocks[bi];
            if (b == 0 || b.inst_tail == 0) { continue; }
            if (ssa_o1_fold_const_branch(fn, b, b.inst_tail, summary) != 0) {
                round_changed = 1;
            }
        }
        if (ssa_o1_thread_empty_jumps_function(fn, summary) != 0) {
            round_changed = 1;
        }
        if (ssa_o1_prune_unreachable_blocks(fn, summary) != 0) {
            round_changed = 1;
        }
        if (ssa_o1_simplify_phis_function(fn, summary) != 0) {
            round_changed = 1;
        }
        if (round_changed != 0) {
            changed = 1;
            if (summary != 0) { summary.cfg_fixedpoint_round_count = summary.cfg_fixedpoint_round_count + 1; }
        }
        round = round + 1;
    }
    return changed;
}

func ssa_o1_count_block_insts(block: *SSABlock) -> u64 {
    if (block == 0) { return 0; }
    var count: u64 = 0;
    var phi: *SSAInstruction = block.phi_head;
    while (phi != 0) {
        count = count + 1;
        phi = phi.next;
    }
    var cur: *SSAInstruction = block.inst_head;
    while (cur != 0) {
        count = count + 1;
        cur = cur.next;
    }
    return count;
}

func ssa_o1_count_function_insts(fn: *SSAFunction) -> u64 {
    if (fn == 0) { return 0; }
    var total: u64 = 0;
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        total = total + ssa_o1_count_block_insts(blocks[bi]);
    }
    return total;
}

func ssa_o1_inst_op_valid(op: u64) -> u64 {
    if (op <= SSA_OP_F2U) { return 1; }
    return 0;
}

func ssa_o1_verify_block(block: *SSABlock) -> u64 {
    if (block == 0) { return 1; }
    var errors: u64 = 0;
    var cur: *SSAInstruction = block.inst_head;
    var seen_tail: *SSAInstruction = 0;
    while (cur != 0) {
        if (ssa_o1_inst_op_valid(op_of(cur)) == 0) { errors = errors + 1; }
        seen_tail = cur;
        cur = cur.next;
    }
    if (seen_tail != block.inst_tail) { errors = errors + 1; }
    return errors;
}

func ssa_o1_block_has_pred_id(block: *SSABlock, pred_id: u64) -> u64 {
    if (block == 0) { return 0; }
    var preds: []*SSABlock = block.preds;
    var n: u64 = slice_len(preds);
    for (var i: u64 = 0; i < n; i = i + 1) {
        var pred: *SSABlock = preds[i];
        if (pred != 0 && pred.id == pred_id) { return 1; }
    }
    return 0;
}

func ssa_o1_verify_cfg_block(block: *SSABlock) -> u64 {
    if (block == 0) { return 1; }
    var errors: u64 = 0;
    var succs: []*SSABlock = block.succs;
    var scount: u64 = slice_len(succs);
    for (var si: u64 = 0; si < scount; si = si + 1) {
        var succ: *SSABlock = succs[si];
        if (succ == 0 || ssa_o1_block_has_pred(succ, block) == 0) { errors = errors + 1; }
    }
    var preds: []*SSABlock = block.preds;
    var pcount: u64 = slice_len(preds);
    for (var pi: u64 = 0; pi < pcount; pi = pi + 1) {
        var pred: *SSABlock = preds[pi];
        if (pred == 0 || ssa_o1_block_has_succ(pred, block) == 0) { errors = errors + 1; }
    }
    var phi: *SSAInstruction = block.phi_head;
    while (phi != 0) {
        var arg: *SSAPhiArg = (*SSAPhiArg)phi.src1;
        while (arg != 0) {
            if (ssa_o1_block_has_pred_id(block, arg.block_id) == 0) { errors = errors + 1; }
            arg = arg.next;
        }
        phi = phi.next;
    }
    return errors;
}

func ssa_o1_verify_function(fn: *SSAFunction) -> u64 {
    if (fn == 0) { return 1; }
    var errors: u64 = 0;
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        errors = errors + ssa_o1_verify_block(blocks[bi]);
        errors = errors + ssa_o1_verify_cfg_block(blocks[bi]);
    }
    return errors;
}

func ssa_o1_note_verify(summary: *SSAOptEscapeSummary, fn: *SSAFunction) -> u64 {
    if (summary == 0) { return 0; }
    summary.verify_count = summary.verify_count + 1;
    summary.verify_error_count = summary.verify_error_count + ssa_o1_verify_function(fn);
    return 0;
}

func ssa_o1_run_local_proof_pass(fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0) { return 0; }
    if (summary != 0) { summary.pass_count = summary.pass_count + 1; }
    var blocks: []*SSABlock = fn.blocks;
    var bcount: u64 = slice_len(blocks);
    for (var bi: u64 = 0; bi < bcount; bi = bi + 1) {
        run_block(blocks[bi], summary);
    }
    return 0;
}

func ssa_o1_run_sccp_pass(fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0) { return 0; }
    if (summary != 0) { summary.pass_count = summary.pass_count + 1; }
    return ssa_o1_sccp_function(fn, summary);
}

func ssa_o1_run_cfg_simplify_pass(fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0) { return 0; }
    if (summary != 0) { summary.pass_count = summary.pass_count + 1; }
    return ssa_o1_simplify_cfg_function(fn, summary);
}

func ssa_o1_run_global_gvn_pass(fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0) { return 0; }
    if (summary != 0) { summary.pass_count = summary.pass_count + 1; }
    return ssa_o1_global_gvn_function(fn, summary);
}

func ssa_o1_run_memoryssa_pass(fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0) { return 0; }
    if (summary != 0) { summary.pass_count = summary.pass_count + 1; }
    return ssa_o1_memoryssa_function(fn, summary);
}

func ssa_o1_run_loop_pass(fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0) { return 0; }
    if (summary != 0) { summary.pass_count = summary.pass_count + 1; }
    return ssa_o1_loop_function(fn, summary);
}

func ssa_o1_run_loop2_pass(ctx: *SSAContext, fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (ctx == 0 || fn == 0) { return 0; }
    if (summary != 0) { summary.pass_count = summary.pass_count + 1; }
    return ssa_o1_loop2_function(ctx, fn, summary);
}

func ssa_o1_run_inline_pass(ctx: *SSAContext, fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (ctx == 0 || fn == 0) { return 0; }
    if (summary != 0) { summary.pass_count = summary.pass_count + 1; }
    return ssa_o1_inline_function(ctx, fn, summary);
}

func ssa_o1_run_roadmap_pass(ctx: *SSAContext, fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0) { return 0; }
    if (summary != 0) { summary.pass_count = summary.pass_count + 1; }
    return ssa_o1_roadmap_function(ctx, fn, summary);
}

func ssa_o1_run_copy_prop_pass(fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0) { return 0; }
    if (summary != 0) { summary.pass_count = summary.pass_count + 1; }
    return ssa_o1_global_copy_propagate_function(fn, summary);
}

func ssa_o1_run_dce_pass(fn: *SSAFunction, summary: *SSAOptEscapeSummary) -> u64 {
    if (fn == 0) { return 0; }
    if (summary != 0) {
        summary.pass_count = summary.pass_count + 1;
        summary.dce_run_count = summary.dce_run_count + 1;
    }
    dce_run(fn);
    return 0;
}

func run(ctx: *SSAContext) -> u64 {
    push_trace("run", "ssa_opt_o1.b", __LINE__);
    defer pop_trace();
    if (ctx == 0) { return 0; }

    var funcs: []*SSAFunction = ctx.funcs;
    var n: u64 = slice_len(funcs);
    var i: u64 = 0;
    for (i = 0; i < n; i = i + 1) {
        var arena: BppScratchArena;
        if (SSA_O1_USE_SCRATCH_ARENA != 0) {
            bpp_scratch_arena_init(&arena, 0);
            g_ssa_o1_scratch_arena = &arena;
        } else {
            g_ssa_o1_scratch_arena = 0;
        }
        var fn: *SSAFunction = funcs[i];
        var summary: *SSAOptEscapeSummary = ssa_tag_analyze_function_escape(fn);

        summary.inst_before_count = ssa_o1_count_function_insts(fn);
        ssa_o1_note_verify(summary, fn);
        ssa_o1_run_local_proof_pass(fn, summary);
        var sccp_changed: u64 = ssa_o1_run_sccp_pass(fn, summary);
        ssa_o1_run_cfg_simplify_pass(fn, summary);
        var gvn_changed: u64 = ssa_o1_run_global_gvn_pass(fn, summary);
        var memory_changed: u64 = ssa_o1_run_memoryssa_pass(fn, summary);
        ssa_o1_run_loop_pass(fn, summary);
        var loop2_changed: u64 = ssa_o1_run_loop2_pass(ctx, fn, summary);
        var inline_changed: u64 = ssa_o1_run_inline_pass(ctx, fn, summary);
        ssa_o1_run_roadmap_pass(ctx, fn, summary);
        var copy_changed: u64 = ssa_o1_run_copy_prop_pass(fn, summary);
        ssa_o1_run_dce_pass(fn, summary);
        if (sccp_changed != 0 || gvn_changed != 0 || memory_changed != 0 || loop2_changed != 0 || inline_changed != 0 || copy_changed != 0) {
            ssa_o1_run_cfg_simplify_pass(fn, summary);
            ssa_o1_run_dce_pass(fn, summary);
        }
        ssa_o1_note_verify(summary, fn);
        summary.inst_after_count = ssa_o1_count_function_insts(fn);
        fn.tag_direct_summary_bits = ssa_tag_summary_bits(summary);
        fn.tag_summary_bits = fn.tag_direct_summary_bits;
        fn.tag_interproc_summary_bits = 0;
        fn.tag_interproc_callee_count = 0;
        fn.tag_fold_count = summary.fold_count;
        fn.tag_pack_count = summary.pack_count;
        fn.tag_predicate_fold_count = summary.predicate_fold_count;
        fn.tag_raw_elision_count = summary.raw_elision_count;
        fn.tag_hot_path_fold_count = summary.hot_path_fold_count;
        fn.tag_profile_fold_count = summary.profile_fold_count;
        fn.tag_inline_cache_fold_count = summary.inline_cache_fold_count;
        fn.stack_new_sroa_scalar_count = summary.sroa_scalar_fold_count;
        fn.opt_o1_pass_count = summary.pass_count;
        fn.opt_o1_verify_count = summary.verify_count;
        fn.opt_o1_verify_error_count = summary.verify_error_count;
        fn.opt_o1_inst_before_count = summary.inst_before_count;
        fn.opt_o1_inst_after_count = summary.inst_after_count;
        fn.opt_o1_dce_run_count = summary.dce_run_count;
        fn.opt_o1_alias_proof_count = summary.alias_proof_count;
        fn.opt_o1_lifetime_proof_count = summary.lifetime_proof_count + fn.stack_new_tag_policy_count;
        fn.opt_o1_load_forward_count = summary.load_forward_count;
        fn.opt_o1_store_kill_count = summary.store_kill_count;
        fn.opt_o1_gvn_value_number_count = summary.gvn_value_number_count;
        fn.opt_o1_cse_elim_count = summary.cse_elim_count;
        fn.opt_o1_sccp_const_operand_count = summary.sccp_const_operand_count;
        fn.opt_o1_sccp_branch_const_count = summary.sccp_branch_const_count;
        fn.opt_o1_cfg_branch_fold_count = summary.cfg_branch_fold_count;
        fn.opt_o1_cfg_edge_prune_count = summary.cfg_edge_prune_count;
        fn.opt_o1_cfg_phi_prune_count = summary.cfg_phi_prune_count;
        fn.opt_o1_cfg_unreachable_block_count = summary.cfg_unreachable_block_count;
        fn.opt_o1_cfg_jump_thread_count = summary.cfg_jump_thread_count;
        fn.opt_o1_phi_simplify_count = summary.phi_simplify_count;
        fn.opt_o1_phi_reg_replace_count = summary.phi_reg_replace_count;
        fn.opt_o1_copy_prop_count = summary.copy_prop_count;
        fn.opt_o1_copy_elim_count = summary.copy_elim_count;
        fn.opt_o1_algebraic_simplify_count = summary.algebraic_simplify_count;
        fn.opt_o1_cfg_fixedpoint_round_count = summary.cfg_fixedpoint_round_count;
        fn.opt_o1_sccp_lattice_count = summary.sccp_lattice_count;
        fn.opt_o1_sccp_edge_prune_count = summary.sccp_edge_prune_count;
        fn.opt_o1_gvn_global_count = summary.gvn_global_count;
        fn.opt_o1_gvn_phi_count = summary.gvn_phi_count;
        fn.opt_o1_memoryssa_count = summary.memoryssa_count;
        fn.opt_o1_memoryssa_def_count = summary.memoryssa_def_count;
        fn.opt_o1_memoryssa_use_count = summary.memoryssa_use_count;
        fn.opt_o1_memoryssa_phi_count = summary.memoryssa_phi_count;
        fn.opt_o1_memoryssa_alias_class_count = summary.memoryssa_alias_class_count;
        fn.opt_o1_memoryssa_tagged_noalias_count = summary.memoryssa_tagged_noalias_count;
        fn.opt_o1_memoryssa_forward_count = summary.memoryssa_forward_count;
        fn.opt_o1_memoryssa_store_kill_count = summary.memoryssa_store_kill_count;
        fn.opt_o1_memory_effect_summary_count = summary.memory_effect_summary_count;
        fn.opt_o1_loop_detect_count = summary.loop_detect_count;
        fn.opt_o1_loop_preheader_count = summary.loop_preheader_count;
        fn.opt_o1_loop_licm_count = summary.loop_licm_count;
        fn.opt_o1_loop_iv_count = summary.loop_iv_count;
        fn.opt_o1_loop_strength_reduce_count = summary.loop_strength_reduce_count;
        fn.opt_o1_loop_bounds_elim_count = summary.loop_bounds_elim_count;
        fn.opt_o1_loop_unswitch_count = summary.loop_unswitch_count;
        fn.opt_o1_loop_unroll_count = summary.loop_unroll_count;
        fn.opt_o1_loop_reduction_count = summary.loop_reduction_count;
        fn.opt_o1_loop2_count = summary.loop2_count;
        fn.opt_o1_inline_count = summary.inline_count;
        fn.opt_o1_regalloc2_count = summary.regalloc2_count;
        fn.opt_o1_peephole_count = summary.peephole_count;
        fn.opt_o1_sroa2_count = summary.sroa2_count;
        fn.opt_o1_tag2_count = summary.tag2_count;
        fn.opt_o1_number_ir_count = summary.number_ir_count;
        fn.opt_o1_pgo_count = summary.pgo_count;
        if (SSA_O1_RELEASE_SCRATCH != 0) {
            free((u64)summary);
        }
        if (SSA_O1_USE_SCRATCH_ARENA != 0) {
            bpp_scratch_arena_reset(&arena);
            g_ssa_o1_scratch_arena = 0;
        }
    }

    ssa_tag_propagate_interprocedural(ctx);

    if (SSA_O1_DEBUG != 0) {
        println("[DEBUG] opt_o1_run: done", 32);
    }

    return 0;
}

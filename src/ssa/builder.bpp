    var add_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, out_reg, operand_reg(base_reg), operand_reg(off_reg));
    append_inst(ctx.cur_block, add_ptr);
    return out_reg;
}


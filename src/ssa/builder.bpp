// ssa_builder.b - SSA CFG builder (v3_17)
//
// AST를 순회하며 기본 블록/엣지 연결과 명령어 생성까지 처리합니다.
// (SSA Rename은 다음 단계)

import std.io;
import std.util;
import std.vec;
import std.hashmap;
import std.str;
import types;
import ast;
import ssa.datastruct;
import ssa.core;
import emitter.typeinfo;
import emitter.symtab;
import emitter.emitter;
import compiler;
import compiler.trait_runtime;
import compiler.try_runtime;
import compiler.core_utils;
import compiler.generic.engine;
import compiler.ast_lowering;
import compiler.call_utils;
import compiler.symbol_runtime;
import compiler.virtual_dispatch_runtime;
import ssa.codegen;

const SSA_BUILDER_DEBUG = 0;
const TAGGED_PTR_MASK = 281474976710655;

// Simple pointer+length pair for name lookups and metadata.
struct PtrLen {
    public ptr: u64;
    public len: u64;
}

// Slice register bundle (ptr,len) used in SSA builder.
struct SliceRegs {
    public ptr_reg: u64;
    public len_reg: u64;
}

impl SliceRegs {
    public constructor() {
        self.ptr_reg = 0;
        self.len_reg = 0;
    }
}

struct BuilderParamLayout {
    public stack_offset: u64;
    public arg_start_idx: u64;
}

impl BuilderParamLayout {
    public constructor() {
        self.stack_offset = 0;
        self.arg_start_idx = 0;
    }
}

struct BuilderCallPrefix {
    public count: u64;
    public first: u64;
    public second: u64;
}

struct BuilderCallRetMeta {
    public ret_type: u64;
    public ret_ptr_depth: u64;
    public ret_struct_size: u64;
}

struct BuilderPackedFieldMeta {
    public is_valid: u64;
    public field_width: u64;
    public shift_bits: u64;
    public size_bytes: u64;
}

struct BuilderTryMeta {
    public opt_ti: *TypeInfo;
    public struct_def: *AstStructDef;
    public check: []u8;
    public value: []u8;
    public value_desc: *FieldDesc;
}

struct BuilderReturnStructTarget {
    public use_struct_return: u64;
    public struct_name: []u8;
    public expr_struct_def: *AstStructDef;
}

struct BuilderPreparedMethodCall {
    public ok: u64;
    public resolved: []u8;
    public recv_addr: u64;
    public resolved_fn: *AstFunc;
    public use_call_ptr: u64;
    public call_ptr_callee: *AstNode;
    public use_virtual_dispatch: u64;
    public virtual_recv_offset: u64;
    public virtual_method_index: u64;
}

struct BuilderAssignTargetMeta {
    public tgt_ti: *TypeInfo;
    public tgt_is_struct: u64;
    public tgt_struct_size: u64;
}

struct BuilderAssignTargetAddr {
    public resolved: u64;
    public target_addr: u64;
    public target_offset: u64;
}

struct BuilderMemberFieldInfo {
    public found: u64;
    public field_offset: u64;
    public field_size: u64;
}

struct BuilderMemberAccessAttempt {
    public handled: u64;
    public reg_val: u64;
}

struct BuilderStmtDispatchResult {
    public matched: u64;
    public result: u64;
}

func make_bitmask(bit_width: u64) -> u64 {
    if (bit_width >= 64) { return 0; }
    var one: u64 = 1;
    var mask: u64 = one << bit_width;
    return mask - 1;
}

func mask_low_bits(ctx: *BuilderCtx, value_reg: u64, bit_width: u64) -> u64 {
    if (bit_width >= 64) { return value_reg; }
    var mask_val: u64 = make_bitmask(bit_width);
    var mask_reg: u64 = build_const(ctx, mask_val);
    var out_reg: u64 = new_reg(ctx);
    var and_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_AND, out_reg, operand_reg(value_reg), operand_reg(mask_reg));
    append_inst(ctx.cur_block, and_ptr);
    return out_reg;
}

func shift_left(ctx: *BuilderCtx, value_reg: u64, shift_bits: u64) -> u64 {
    if (shift_bits == 0) { return value_reg; }
    var shift_reg: u64 = build_const(ctx, shift_bits);
    var out_reg: u64 = new_reg(ctx);
    var shl_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_SHL, out_reg, operand_reg(value_reg), operand_reg(shift_reg));
    append_inst(ctx.cur_block, shl_ptr);
    return out_reg;
}

func shift_right(ctx: *BuilderCtx, value_reg: u64, shift_bits: u64) -> u64 {
    if (shift_bits == 0) { return value_reg; }
    var shift_reg: u64 = build_const(ctx, shift_bits);
    var out_reg: u64 = new_reg(ctx);
    var shr_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_SHR, out_reg, operand_reg(value_reg), operand_reg(shift_reg));
    append_inst(ctx.cur_block, shr_ptr);
    return out_reg;
}

func shift_arith_right(ctx: *BuilderCtx, value_reg: u64, shift_bits: u64) -> u64 {
    if (shift_bits == 0) { return value_reg; }
    var shift_reg: u64 = build_const(ctx, shift_bits);
    var out_reg: u64 = new_reg(ctx);
    var sar_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_SAR, out_reg, operand_reg(value_reg), operand_reg(shift_reg));
    append_inst(ctx.cur_block, sar_ptr);
    return out_reg;
}

func resolve_struct_literal_size(ctx: *BuilderCtx, lit: *AstStructLiteral, fallback_name: []u8) -> u64 {
    if (lit == 0) { return 0; }
    var size: u64 = struct_size_from_def(lit.struct_def);
    if (size != 0) { return size; }
    if (fallback_name.ptr != 0 && fallback_name.len != 0) {
        size = layout_type_sizeof(TYPE_STRUCT, 0, slice(fallback_name.ptr, fallback_name.len));
        if (size != 0) { return size; }
        var fb_def: *AstStructDef = get_struct_def(slice(fallback_name.ptr, fallback_name.len));
        if (fb_def != 0) {
            size = struct_size_from_def(fb_def);
            if (size != 0) { return size; }
        }
    }
    var ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)lit, ctx.symtab);
    if (ti == 0) { return 0; }
    if (ti.type_kind != TYPE_STRUCT || ti.ptr_depth != 0) { return 0; }
    if (ti.struct_def != 0) {
        size = struct_size_from_def(ti.struct_def);
        if (size != 0) { return size; }
    }
    if (u8_slice_ptr(ti.struct_name) != 0 && u8_slice_len(ti.struct_name) != 0) {
        size = layout_type_sizeof(TYPE_STRUCT, 0, ti.struct_name);
        if (size != 0) { return size; }
        var name_def: *AstStructDef = get_struct_def(ti.struct_name);
        if (name_def != 0) {
            size = struct_size_from_def(name_def);
            if (size != 0) { return size; }
        }
    }
    return 0;
}

func extract_field_from_small_struct_regs(ctx: *BuilderCtx, lo_reg: u64, hi_reg: u64, struct_size: u64, field_offset: u64, field_size: u64) -> u64 {
    if (struct_size == 0 || field_size == 0) { return 0; }
    var temp_offset: u64 = symtab_add(ctx.symtab, slice(0, 0), TYPE_STRUCT, 0, struct_size);
    var temp_addr: u64 = new_lea_local(ctx, temp_offset);
    store_by_size(ctx, temp_addr, lo_reg, 8);
    if (struct_size > 8) {
        var off8: u64 = build_const(ctx, 8);
        var addr2: u64 = new_reg(ctx);
        var add_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, addr2, operand_reg(temp_addr), operand_reg(off8));
        append_inst(ctx.cur_block, add_ptr);
        var tail_size: u64 = struct_size - 8;
        if (tail_size > 8) { tail_size = 8; }
        store_by_size(ctx, addr2, hi_reg, tail_size);
    }
    var field_addr: u64 = temp_addr;
    if (field_offset != 0) {
        var off_reg: u64 = build_const(ctx, field_offset);
        var addr3: u64 = new_reg(ctx);
        var add_ptr2: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, addr3, operand_reg(temp_addr), operand_reg(off_reg));
        append_inst(ctx.cur_block, add_ptr2);
        field_addr = addr3;
    }
    if (ctx.debug_mode != 0) {
        emit("[DEBUG] ssa member access span field via temp, size=");
        print_u64(struct_size);
        emit(" offset=");
        print_u64(field_offset);
        emit(" field=");
        print_u64(field_size);
        emit("\n");
    }
    return load_by_size(ctx, field_addr, field_size);
}

func make_call_info(name: []u8, arg_regs: *Vec<u64>, ret_type: u64, ret_ptr_depth: u64, ret_struct_size: u64) -> *SSACallInfo {
    var info: *SSACallInfo = new SSACallInfo{};
    info.name = slice(name.ptr, name.len);
    info.args_vec = arg_regs;
    if (arg_regs != 0) { info.nargs = arg_regs.len(); }
    info.ret_type = ret_type;
    info.ret_ptr_depth = ret_ptr_depth;
    info.ret_struct_size = ret_struct_size;
    return info;
}

func make_call_ptr_info(callee_reg: u64, arg_regs: *Vec<u64>, ret_type: u64, ret_ptr_depth: u64, ret_struct_size: u64) -> *SSACallPtrInfo {
    var info: *SSACallPtrInfo = new SSACallPtrInfo{};
    info.callee_reg = callee_reg;
    info.args_vec = arg_regs;
    if (arg_regs != 0) { info.nargs = arg_regs.len(); }
    info.ret_type = ret_type;
    info.ret_ptr_depth = ret_ptr_depth;
    info.ret_struct_size = ret_struct_size;
    return info;
}

func make_call_slice_store_info(is_ptr: u64, name: []u8, callee_reg: u64, arg_regs: *Vec<u64>, ret_type: u64, ret_ptr_depth: u64) -> *SSACallSliceStoreInfo {
    var info: *SSACallSliceStoreInfo = new SSACallSliceStoreInfo{};
    info.is_ptr = is_ptr;
    info.name = slice(name.ptr, name.len);
    info.callee_reg = callee_reg;
    info.args_vec = arg_regs;
    if (arg_regs != 0) { info.nargs = arg_regs.len(); }
    info.ret_type = ret_type;
    info.ret_ptr_depth = ret_ptr_depth;
    return info;
}

func emit_call_name_raw(ctx: *BuilderCtx, name: []u8, arg_regs: *Vec<u64>, dst: u64, extra_dst: u64, ret_type: u64, ret_ptr_depth: u64, ret_struct_size: u64) -> u64 {
    if (arg_regs == 0) { return 0; }
    var info: *SSACallInfo = make_call_info(slice(name.ptr, name.len), arg_regs, ret_type, ret_ptr_depth, ret_struct_size);
    var extra_opr: u64 = 0;
    if (extra_dst != 0) { extra_opr = operand_reg(extra_dst); }
    var call_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_CALL, dst, operand_const((u64)info), extra_opr);
    append_inst(ctx.cur_block, call_ptr);
    return dst;
}

func emit_call_ptr_raw(ctx: *BuilderCtx, callee_reg: u64, arg_regs: *Vec<u64>, dst: u64, extra_dst: u64, ret_type: u64, ret_ptr_depth: u64, ret_struct_size: u64) -> u64 {
    if (arg_regs == 0) { return 0; }
    var info: *SSACallPtrInfo = make_call_ptr_info(callee_reg, arg_regs, ret_type, ret_ptr_depth, ret_struct_size);
    var extra_opr: u64 = 0;
    if (extra_dst != 0) { extra_opr = operand_reg(extra_dst); }
    var call_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_CALL_PTR, dst, operand_const((u64)info), extra_opr);
    append_inst(ctx.cur_block, call_ptr);
    return dst;
}

func emit_trait_vptr_init_at_addr(ctx: *BuilderCtx, base_addr: u64, struct_name: []u8) -> u64 {
    if (base_addr == 0) { return 0; }
    var impls: *Vec<*TraitImpl> = sym_get_trait_impls();
    if (impls == 0) { return 0; }
    var struct_def: *AstStructDef = get_struct_def(slice(struct_name.ptr, struct_name.len));
    if (struct_def == 0) { return 0; }
    var n: u64 = impls.len();
    for (var i: u64 = 0; i < n; i++) {
        var impl_info: *TraitImpl = impls.get(i);
        if (!str_eq(impl_info.impl_struct_name, slice(struct_name.ptr, struct_name.len))) { continue; }
        var vptr_name: *NameInfo = trait_build_vptr_field_name(impl_info.trait_name);
        var field_offset: u64 = 0;
        var field_desc: *FieldDesc = 0;
        var found: u64 = struct_find_field_desc_scoped(struct_def, slice(0, 0), slice(vptr_name.ptr, vptr_name.len), &field_offset, &field_desc);
        if (found == 0) {
            emit_stderr("[ERROR] vptr field not found for trait init\n");
            diag_error("SSA build error");
        }
        var vtable_reg: u64 = new_lea_global(ctx, impl_info.vtable_global);
        var addr_reg: u64 = base_addr;
        if (field_offset != 0) {
            var off_reg: u64 = build_const(ctx, field_offset);
            var addr2: u64 = new_reg(ctx);
            var add_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, addr2, operand_reg(base_addr), operand_reg(off_reg));
            append_inst(ctx.cur_block, add_ptr);
            addr_reg = addr2;
        }
        store_by_size(ctx, addr_reg, vtable_reg, 8);
    }
    return 0;
}

func emit_return_struct_from_addr_reg(ctx: *BuilderCtx, addr_reg: u64, struct_size: u64) -> u64 {
    if (addr_reg == 0 || struct_size == 0) { return 0; }
    var head_size: u64 = struct_size;
    if (head_size > 8) { head_size = 8; }
    var lo_reg: u64 = load_by_size(ctx, addr_reg, head_size);
    if (lo_reg == 0) { lo_reg = build_const(ctx, 0); }
    var hi_reg: u64 = 0;
    if (struct_size > 8) {
        var off_reg: u64 = build_const(ctx, 8);
        var addr2: u64 = new_reg(ctx);
        var add_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, addr2, operand_reg(addr_reg), operand_reg(off_reg));
        append_inst(ctx.cur_block, add_ptr);
        var tail_size: u64 = struct_size - 8;
        if (tail_size > 8) { tail_size = 8; }
        hi_reg = load_by_size(ctx, addr2, tail_size);
        if (hi_reg == 0) { hi_reg = build_const(ctx, 0); }
    }
    var ret_src2: u64 = 0;
    if (struct_size > 8) {
        if (hi_reg != 0) { ret_src2 = operand_reg(hi_reg); }
        else { ret_src2 = operand_reg(build_const(ctx, 0)); }
    }
    var ret_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_RET, 0, operand_reg(lo_reg), ret_src2);
    append_inst(ctx.cur_block, ret_ptr);
    return 0;
}

func resolve_constructor_call(struct_slice: []u8, args: *Vec<*AstNode>, symtab: *Symtab, site: []u8) -> CompilerMethodResolveResult {
    var resolved: CompilerMethodResolveResult = sym_method_resolve_none();
    var method_ptr: u64 = (u64)"constructor";
    var method_len: u64 = 11;
    var arg_count_hint: u64 = 0;
    if (args != 0) { arg_count_hint = args.len(); }
    var base_len: u64 = sym_find_generic_suffix_index(slice(struct_slice.ptr, struct_slice.len));
    var suffix_len: u64 = struct_slice.len - base_len;
    var name_info: *NameInfo = build_method_name_base(slice(struct_slice.ptr, base_len), slice(method_ptr, method_len), suffix_len);
    var alt_info: *NameInfo = build_method_name_base(slice(struct_slice.ptr, base_len), slice(method_ptr, method_len), 0);
    if (sym_func_exists(slice(name_info.ptr, name_info.len)) == 0) {
        var resolved_primary: *NameInfo = resolve_name(slice(name_info.ptr, name_info.len));
        if (resolved_primary != 0 && sym_func_exists(slice(resolved_primary.ptr, resolved_primary.len)) != 0) {
            name_info = resolved_primary;
        }
    }
    if (sym_func_exists(slice(name_info.ptr, name_info.len)) == 0) {
        name_info = alt_info;
        if (sym_func_exists(slice(name_info.ptr, name_info.len)) == 0) {
            var resolved_alt: *NameInfo = resolve_name(slice(name_info.ptr, name_info.len));
            if (resolved_alt != 0 && sym_func_exists(slice(resolved_alt.ptr, resolved_alt.len)) != 0) {
                name_info = resolved_alt;
            }
        }
    }
    if (sym_func_exists(slice(name_info.ptr, name_info.len)) != 0) {
        var fn_ctor: *AstFunc = typeinfo_find_func(slice(name_info.ptr, name_info.len));
        if (fn_ctor == 0) {
            var resolved_name: *NameInfo = resolve_name(slice(name_info.ptr, name_info.len));
            if (resolved_name != 0) {
                fn_ctor = typeinfo_find_func(slice(resolved_name.ptr, resolved_name.len));
            }
        }
        if (fn_ctor != 0) {
            resolved.found = 1;
            resolved.fn = fn_ctor;
            var owner_map: *NameInfo = sym_get_impl_method_owner(slice(name_info.ptr, name_info.len));
            if (owner_map != 0) {
                resolved.owner = owner_map;
            } else {
                resolved.owner = fn_ctor.impl_owner;
            }
            resolved.access = sym_get_impl_method_access(slice(name_info.ptr, name_info.len));
        }
    }
    if (resolved.found == 0 || resolved.fn == 0) {
        var overload_resolved: CompilerMethodResolveResult = sym_resolve_method_overload_with_count_fallback(slice(struct_slice.ptr, struct_slice.len), slice(method_ptr, method_len), 0, arg_count_hint);
        if (overload_resolved.found != 0 && overload_resolved.fn != 0) {
            resolved = overload_resolved;
        }
    }
    if (resolved.found == 0 || resolved.fn == 0) {
        diag_emit_error_tag("ssa", "S2201", "constructor not found");
        emit_stderr("  site: ");
        emit_stderr_len(site.ptr, site.len);
        emit_stderr_nl();
        if (struct_slice.ptr != 0 && struct_slice.len != 0) {
            emit_stderr("  type: ");
            emit_stderr_len(struct_slice.ptr, struct_slice.len);
            emit_stderr_nl();
        }
        diag_emit_help("use brace initialization for pure data setup, or define a matching constructor signature");
        diag_error("SSA build error");
        return resolved;
    }
    if (u8_slice_ptr(resolved.owner) == 0 || u8_slice_len(resolved.owner) == 0) {
        resolved.owner = struct_slice;
    }
    if (resolved.access == 0) { resolved.access = ACCESS_PUBLIC; }
    if (sym_can_access_member(resolved.owner, resolved.access) == 0) {
        diag_emit_error_tag("ssa", "S2202", "constructor access denied");
        emit_stderr("  type: ");
        emit_stderr_len(u8_slice_ptr(resolved.owner), u8_slice_len(resolved.owner));
        emit_stderr(".constructor\n");
        diag_error("SSA build error");
    }
    return resolved;
}

func stack_ctor_init_at_addr(ctx: *BuilderCtx, sc: *AstStackCtor, base_addr: u64) -> u64 {
    if (sc == 0 || base_addr == 0) { return 0; }
    if (sc.type_kind != TYPE_STRUCT) {
        emit_stderr("[ERROR] stack constructor requires struct type\n");
        diag_error("SSA build error");
    }
    var size: u64 = layout_type_sizeof(sc.type_kind, sc.ptr_depth, sc.struct_name);

    var memset_ptr: u64 = (u64)"memset";
    var memset_len: u64 = 6;
    var memset_res: *NameInfo = resolve_name(slice(memset_ptr, memset_len));
    if (memset_res != 0) {
        memset_ptr = memset_res.ptr;
        memset_len = memset_res.len;
    }

    var zero_reg: u64 = build_const(ctx, 0);
    var size_reg: u64 = build_const(ctx, size);
    var memset_args: *Vec<u64> = make_args3(base_addr, zero_reg, size_reg);
    emit_call_name_raw(ctx, slice(memset_ptr, memset_len), memset_args, 0, 0, TYPE_I64, 0, 0);

    emit_trait_vptr_init_at_addr(ctx, base_addr, sc.struct_name);

    var args: *Vec<*AstNode> = sc.ctor_args_vec;
    if (args != 0) {
        var ctor_resolved: CompilerMethodResolveResult = resolve_constructor_call(sc.struct_name, args, ctx.symtab, slice("stack ctor", 10));
        if (ctor_resolved.found == 0 || ctor_resolved.fn == 0) {
            return 0;
        }
        var arg_regs: *Vec<u64> = make_call_arg_regs_nodes(ctx, args, call_prefix_one(base_addr));
        emit_call_name_raw(ctx, ctor_resolved.fn.name, arg_regs, 0, 0, TYPE_VOID, 0, 0);
    }
    return 0;
}

func mask_tagged_ptr(ctx: *BuilderCtx, value_reg: u64) -> u64 {
    var mask_reg: u64 = build_const(ctx, TAGGED_PTR_MASK);
    var out_reg: u64 = new_reg(ctx);
    var and_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_AND, out_reg, operand_reg(value_reg), operand_reg(mask_reg));
    append_inst(ctx.cur_block, and_ptr);
    return out_reg;
}

func all_ones_reg(ctx: *BuilderCtx) -> u64 {
    var zero_reg: u64 = build_const(ctx, 0);
    var one_reg: u64 = build_const(ctx, 1);
    var out_reg: u64 = new_reg(ctx);
    var sub_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_SUB, out_reg, operand_reg(zero_reg), operand_reg(one_reg));
    append_inst(ctx.cur_block, sub_ptr);
    return out_reg;
}

func packed_layout_total_bits(struct_def: *AstStructDef) -> u64 {
    var sd: *AstStructDef = struct_def;
    var fields: *Vec<*FieldDesc> = sd.fields_vec;
    var num_fields: u64 = fields.len();
    var total_bits: u64 = 0;
    for (var i: u64 = 0; i < num_fields; i++) {
        var field: *FieldDesc = fields.get(i);
        if (field.bit_width > 0) {
            total_bits = total_bits + field.bit_width;
        } else {
            var fsize: u64 = layout_field_sizeof(field);
            total_bits = total_bits + fsize * 8;
        }
    }
    return total_bits;
}

func packed_field_bit_offset(struct_def: *AstStructDef, field_name: []u8) -> u64 {
    var sd: *AstStructDef = struct_def;
    var fields: *Vec<*FieldDesc> = sd.fields_vec;
    var num_fields: u64 = fields.len();
    var bit_cursor: u64 = 0;
    for (var i: u64 = 0; i < num_fields; i++) {
        var field: *FieldDesc = fields.get(i);
        if (str_eq(field.name, slice(field_name.ptr, field_name.len))) {
            return bit_cursor;
        }
        if (field.bit_width > 0) {
            bit_cursor = bit_cursor + field.bit_width;
        } else {
            var fsize2: u64 = layout_field_sizeof(field);
            bit_cursor = bit_cursor + fsize2 * 8;
        }
    }
    emit("[ERROR] Packed field not found\n");
    diag_error("SSA build error");
    return 0;
}

func packed_field_bit_width(struct_def: *AstStructDef, field_name: []u8) -> u64 {
    var sd: *AstStructDef = struct_def;
    var fields: *Vec<*FieldDesc> = sd.fields_vec;
    var num_fields: u64 = fields.len();
    for (var i: u64 = 0; i < num_fields; i++) {
        var field: *FieldDesc = fields.get(i);
        if (str_eq(field.name, slice(field_name.ptr, field_name.len))) {
            if (field.bit_width > 0) { return field.bit_width; }
            return layout_field_sizeof(field) * 8;
        }
    }
    emit("[ERROR] Packed field not found\n");
    diag_error("SSA build error");
    return 0;
}

func packed_field_meta(struct_def: *AstStructDef, member: []u8, tagged_layout: u64) -> BuilderPackedFieldMeta {
    var meta: BuilderPackedFieldMeta;
    meta.is_valid = 0;
    meta.field_width = 0;
    meta.shift_bits = 0;
    meta.size_bytes = 0;
    if (struct_def == 0) { return meta; }
    if (struct_def.is_packed != 1) { return meta; }

    var total_bits: u64 = packed_layout_total_bits(struct_def);
    var field_offset: u64 = packed_field_bit_offset(struct_def, slice(member.ptr, member.len));
    var field_width: u64 = packed_field_bit_width(struct_def, slice(member.ptr, member.len));
    var shift_bits: u64 = field_offset;
    var size_bytes: u64 = (total_bits + 7) / 8;
    if (tagged_layout != 0) {
        shift_bits = (64 - total_bits) + field_offset;
        size_bytes = 8;
    }

    meta.is_valid = 1;
    meta.field_width = field_width;
    meta.shift_bits = shift_bits;
    meta.size_bytes = size_bytes;
    return meta;
}

func packed_merge_value(ctx: *BuilderCtx, current_reg: u64, value_reg: u64, field_width: u64, shift_bits: u64) -> u64 {
    var shifted_val: u64 = mask_low_bits(ctx, value_reg, field_width);
    shifted_val = shift_left(ctx, shifted_val, shift_bits);
    if (field_width >= 64) {
        return shifted_val;
    }

    var field_mask_val: u64 = make_bitmask(field_width);
    var field_mask_reg: u64 = build_const(ctx, field_mask_val);
    field_mask_reg = shift_left(ctx, field_mask_reg, shift_bits);
    var all_ones_reg: u64 = all_ones_reg(ctx);
    var inv_mask_reg: u64 = new_reg(ctx);
    var xor_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_XOR, inv_mask_reg, operand_reg(field_mask_reg), operand_reg(all_ones_reg));
    append_inst(ctx.cur_block, xor_ptr);
    var cleared_reg: u64 = new_reg(ctx);
    var and_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_AND, cleared_reg, operand_reg(current_reg), operand_reg(inv_mask_reg));
    append_inst(ctx.cur_block, and_ptr);
    var merged: u64 = new_reg(ctx);
    var or_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_OR, merged, operand_reg(cleared_reg), operand_reg(shifted_val));
    append_inst(ctx.cur_block, or_ptr);
    return merged;
}

func struct_size_from_def(struct_def: *AstStructDef) -> u64 {
    if (struct_def == 0) { return 0; }
    var sd: *AstStructDef = struct_def;
    if (sd.is_packed == 1) {
        if (sd.parents_vec != 0 && sd.parents_vec.len() > 0) {
            emit("[ERROR] packed struct cannot use inheritance\n");
            diag_error("SSA build error");
        }
        var total_bits: u64 = packed_layout_total_bits(struct_def);
        return (total_bits + 7) / 8;
    }
    var total_size: u64 = 0;
    if (sd.parents_vec != 0) {
        var parents: *Vec<*ParentDesc> = sd.parents_vec;
        var pn: u64 = parents.len();
        for (var pi: u64 = 0; pi < pn; pi++) {
            var parent_desc: *ParentDesc = parents.get(pi);
            var parent_def: *AstStructDef = parent_desc.struct_def;
            if (parent_def == 0) {
                parent_def = get_struct_def(parent_desc.name);
                if (parent_def == 0) {
                    emit("[ERROR] Parent struct not found\n");
                    diag_error("SSA build error");
                }
                parent_desc.struct_def = parent_def;
            }
            total_size = total_size + struct_size_from_def(parent_def);
        }
    }
    var fields: *Vec<*FieldDesc> = sd.fields_vec;
    var num_fields: u64 = 0;
    if (fields != 0) { num_fields = fields.len(); }
    for (var i: u64 = 0; i < num_fields; i++) {
        var field: *FieldDesc = fields.get(i);
        total_size = total_size + layout_field_sizeof(field);
    }
    return total_size;
}

// ============================================
// Builder Context
// ============================================

struct BuilderCtx {
    public ssa_ctx: *SSAContext;
    public cur_func: *SSAFunction;
    public cur_block: *SSABlock;
    public break_stack: *Vec<*SSABlock>;    // vec of *SSABlock
    public continue_stack: *Vec<*SSABlock>; // vec of *SSABlock
    public var_map: *HashMap<u64, u64>;         // hashmap: name -> var_id
    public const_map: *HashMap<u64, u64>;       // hashmap: name -> const value
    public func_ptr_map: *HashMap<u64, *PtrLen>;    // hashmap: name -> [func_name_ptr, func_name_len]
    public closure_handle_map: *HashMap<u64, u64>;  // hashmap: name -> 1 if tagged lambda closure handle
    public addr_taken_map: *HashMap<u64, u64>;  // hashmap: name -> 1
    public defer_stack: *Vec<*AstNode>;
    public defer_markers: *Vec<u64>;
    public defer_loop_markers: *Vec<u64>;
    public symtab: *Symtab;           // symtab for type/offset lookup
    public next_reg: u64;
    public next_var_id: u64;
    public sret_addr_reg: u64;
    public debug_mode: u64;
    public build_failed: u64;
    public defer_emit_mode: u64;
}

impl BuilderCtx {
    public constructor() {
        self.ssa_ctx = 0;
        self.cur_func = 0;
        self.cur_block = 0;
        self.break_stack = 0;
        self.continue_stack = 0;
        self.var_map = 0;
        self.const_map = 0;
        self.func_ptr_map = 0;
        self.closure_handle_map = 0;
        self.addr_taken_map = 0;
        self.defer_stack = 0;
        self.defer_markers = 0;
        self.defer_loop_markers = 0;
        self.symtab = 0;
        self.next_reg = 0;
        self.next_var_id = 0;
        self.sret_addr_reg = 0;
        self.debug_mode = 0;
        self.build_failed = 0;
        self.defer_emit_mode = 0;
    }
}

func ctx_new(ssa_ctx: *SSAContext) -> *BuilderCtx {
    push_trace("ctx_new", "ssa_builder.b", __LINE__);
    defer pop_trace();
    var ctx: *BuilderCtx = new BuilderCtx{};
    ctx.ssa_ctx = ssa_ctx;
    ctx.break_stack = new Vec<*SSABlock>{heap_alloc((8) * sizeof(*SSABlock)), 0, (8)};
    ctx.continue_stack = new Vec<*SSABlock>{heap_alloc((8) * sizeof(*SSABlock)), 0, (8)};
    ctx.next_reg = 1;
    ctx.next_var_id = 1;
    ctx.debug_mode = SSA_BUILDER_DEBUG;
    ctx.defer_stack = new Vec<*AstNode>{heap_alloc((16) * sizeof(*AstNode)), 0, (16)};
    ctx.defer_markers = new Vec<u64>{heap_alloc((16) * sizeof(u64)), 0, (16)};
    ctx.defer_loop_markers = new Vec<u64>{heap_alloc((8) * sizeof(u64)), 0, (8)};
    return ctx;
}

func push_loop(ctx: *BuilderCtx, break_bb: *SSABlock, continue_bb: *SSABlock) -> u64 {
    ctx.break_stack.push(break_bb);
    ctx.continue_stack.push(continue_bb);
    return 0;
}

func pop_loop(ctx: *BuilderCtx) -> u64 {
    var blen: u64 = ctx.break_stack.len();
    var clen: u64 = ctx.continue_stack.len();
    if (blen > 0) { ctx.break_stack.pop(); }
    if (clen > 0) { ctx.continue_stack.pop(); }
    return 0;
}

func top_break(ctx: *BuilderCtx) -> *SSABlock {
    var blen: u64 = ctx.break_stack.len();
    if (blen == 0) { return 0; }
    return ctx.break_stack.get(blen - 1);
}

func top_continue(ctx: *BuilderCtx) -> *SSABlock {
    var clen: u64 = ctx.continue_stack.len();
    if (clen == 0) { return 0; }
    return ctx.continue_stack.get(clen - 1);
}

func reset_func(ctx: *BuilderCtx) -> u64 {
    push_trace("reset_func", "ssa_builder.b", __LINE__);
    defer pop_trace();
    ctx.var_map = new HashMap<u64, u64>{0, 0, 0};
    ctx.var_map.ensure_capacity(16);
    ctx.const_map = 0;
    ctx.func_ptr_map = 0;
    ctx.closure_handle_map = new HashMap<u64, u64>{0, 0, 0};
    ctx.closure_handle_map.ensure_capacity(16);
    ctx.addr_taken_map = new HashMap<u64, u64>{0, 0, 0};
    ctx.addr_taken_map.ensure_capacity(16);
    ctx.defer_stack = new Vec<*AstNode>{heap_alloc((16) * sizeof(*AstNode)), 0, (16)};
    ctx.defer_markers = new Vec<u64>{heap_alloc((16) * sizeof(u64)), 0, (16)};
    ctx.defer_loop_markers = new Vec<u64>{heap_alloc((8) * sizeof(u64)), 0, (8)};
    ctx.symtab = symtab_new();
    ctx.next_reg = 1;
    ctx.next_var_id = 1;
    var break_len: u64 = ctx.break_stack.len();
    for (var bi: u64 = 0; bi < break_len; bi++) {
        ctx.break_stack.pop();
    }
    var continue_len: u64 = ctx.continue_stack.len();
    for (var ci: u64 = 0; ci < continue_len; ci++) {
        ctx.continue_stack.pop();
    }
    sym_reg_alias_reset();
    ctx.build_failed = 0;
    ctx.defer_emit_mode = 0;
    return 0;
}

func mark_addr_taken(ctx: *BuilderCtx, name: []u8) -> u64 {
    if (ctx.addr_taken_map == 0) {
        ctx.addr_taken_map = new HashMap<u64, u64>{0, 0, 0};
        ctx.addr_taken_map.ensure_capacity(16);
    }
    ctx.addr_taken_map.put(slice(name.ptr, name.len), 1);
    return 0;
}

func is_addr_taken(ctx: *BuilderCtx, name: []u8) -> u64 {
    if (ctx.addr_taken_map == 0) { return 0; }
    return ctx.addr_taken_map.get(slice(name.ptr, name.len));
}

func scan_addr_taken_expr_vec(ctx: *BuilderCtx, exprs: *Vec<*AstNode>) -> u64 {
    if (exprs == 0) { return 0; }
    var n: u64 = exprs.len();
    for (var i: u64 = 0; i < n; i++) {
        scan_addr_taken_expr(ctx, exprs.get(i));
    }
    return 0;
}

func scan_addr_taken_pair(ctx: *BuilderCtx, lhs: u64, rhs: u64) -> u64 {
    scan_addr_taken_expr(ctx, lhs);
    scan_addr_taken_expr(ctx, rhs);
    return 0;
}

func scan_addr_taken_expr(ctx: *BuilderCtx, expr: u64) -> u64 {
    if (expr == 0) { return 0; }
    var kind: u64 = ast_kind(expr);
    var nref: AstNodeTagRef;
    nref.node = (*AstNode)expr;
    match (kind) {
        case AST_ADDR_OF:
            var ao: *AstAddrOf = nref.addr_of;
            var operand: *AstNode = ao.operand;
            if (operand != 0 && ast_kind(operand) == AST_IDENT) {
                var op_ref: AstNodeTagRef;
                op_ref.node = operand;
                mark_addr_taken(ctx, op_ref.ident.name);
            } else if (operand != 0) {
                scan_addr_taken_expr(ctx, operand);
            }
            return 0;
        case AST_BINARY:
            var bin: *AstBinary = nref.binary;
            scan_addr_taken_pair(ctx, bin.left, bin.right);
            return 0;
        case AST_TERNARY:
            var tern: *AstTernary = nref.ternary_expr;
            scan_addr_taken_expr(ctx, tern.cond);
            scan_addr_taken_expr(ctx, tern.then_expr);
            scan_addr_taken_expr(ctx, tern.else_expr);
            return 0;
        case AST_UNARY:
            var un: *AstUnary = nref.unary;
            scan_addr_taken_expr(ctx, un.operand);
            return 0;
        case AST_TRY:
            var tr: *AstTry = nref.try_expr;
            scan_addr_taken_expr(ctx, tr.operand);
            return 0;
        case AST_CAST:
            var cs: *AstCast = nref.cast_expr;
            scan_addr_taken_expr(ctx, cs.expr);
            return 0;
        case AST_DEREF:
            var dr: *AstDeref = nref.deref;
            scan_addr_taken_expr(ctx, dr.operand);
            return 0;
        case AST_DEREF8:
            var dr8: *AstDeref8 = nref.deref8;
            scan_addr_taken_expr(ctx, dr8.operand);
            return 0;
        case AST_INDEX:
        case AST_SAFE_INDEX:
            var ix: *AstIndex = nref.index_expr;
            scan_addr_taken_pair(ctx, ix.base, ix.index);
            return 0;
        case AST_MEMBER_ACCESS:
        case AST_SAFE_MEMBER_ACCESS:
            var ma: *AstMemberAccess = nref.member_access;
            scan_addr_taken_expr(ctx, ma.object);
            return 0;
        case AST_CALL:
            var call: *AstCall = nref.call;
            scan_addr_taken_expr_vec(ctx, call.args_vec);
            return 0;
        case AST_GENERIC_CALL:
            var gcall: *AstGenericCall = nref.generic_call;
            scan_addr_taken_expr_vec(ctx, gcall.args_vec);
            return 0;
        case AST_STATIC_GENERIC_CALL:
            var sgc: *AstStaticGenericCall = nref.static_generic_call;
            scan_addr_taken_expr_vec(ctx, sgc.args_vec);
            return 0;
        case AST_METHOD_CALL:
        case AST_SAFE_METHOD_CALL:
            var mc: *AstMethodCall = nref.method_call;
            scan_addr_taken_expr(ctx, mc.receiver);
            scan_addr_taken_expr_vec(ctx, mc.args_vec);
            return 0;
        case AST_CALL_PTR:
            var cp: *AstCallPtr = nref.call_ptr;
            scan_addr_taken_expr(ctx, cp.callee);
            scan_addr_taken_expr_vec(ctx, cp.args_vec);
            return 0;
        case AST_SLICE:
            var sl: *AstSlice = nref.slice_expr;
            scan_addr_taken_pair(ctx, sl.ptr_expr, sl.len_expr);
            return 0;
        case AST_SIZEOF_EXPR:
            var se: *AstSizeofExpr = nref.sizeof_expr;
            scan_addr_taken_expr(ctx, se.expr);
            return 0;
        case AST_STRUCT_LITERAL:
            var st: *AstStructLiteral = nref.struct_lit;
            scan_addr_taken_expr_vec(ctx, st.values_vec);
            return 0;
        case AST_GENERIC_STRUCT_LITERAL:
            var gst: *AstGenericStructLiteral = nref.generic_struct_lit;
            scan_addr_taken_expr_vec(ctx, gst.values_vec);
            return 0;
        case AST_NEW:
            var nw: *AstNew = nref.new_expr;
            scan_addr_taken_expr(ctx, nw.literal_expr);
            scan_addr_taken_expr_vec(ctx, nw.ctor_args_vec);
            return 0;
        case AST_STACK_CTOR:
            var sc: *AstStackCtor = nref.stack_ctor;
            scan_addr_taken_expr_vec(ctx, sc.ctor_args_vec);
            return 0;
        default:
            return 0;
    }
}

func scan_addr_taken_stmt(ctx: *BuilderCtx, stmt: u64) -> u64 {
    if (stmt == 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    var nref: AstNodeTagRef;
    nref.node = (*AstNode)stmt;
    match (kind) {
        case AST_VAR_DECL:
            var vd: *AstVarDecl = nref.var_decl;
            scan_addr_taken_expr(ctx, vd.init_expr);
            return 0;
        case AST_CONST_DECL:
            var cd: *AstConstDecl = nref.const_decl;
            scan_addr_taken_expr(ctx, cd.value);
            return 0;
        case AST_ASSIGN:
            var asn: *AstAssign = nref.assign_stmt;
            scan_addr_taken_expr(ctx, asn.target);
            scan_addr_taken_expr(ctx, asn.value);
            return 0;
        case AST_EXPR_STMT:
            var es: *AstExprStmt = nref.expr_stmt;
            scan_addr_taken_expr(ctx, es.expr);
            return 0;
        case AST_DEFER:
            var df: *AstDefer = nref.defer_stmt;
            scan_addr_taken_stmt(ctx, df.stmt);
            return 0;
        case AST_DELETE:
            var dl: *AstDelete = nref.delete_stmt;
            scan_addr_taken_expr(ctx, dl.expr);
            return 0;
        case AST_RETURN:
            var ret: *AstReturn = nref.ret_stmt;
            scan_addr_taken_expr(ctx, ret.expr);
            return 0;
        case AST_IF:
            var ifs: *AstIf = nref.if_stmt;
            scan_addr_taken_expr(ctx, ifs.cond);
            scan_addr_taken_stmt(ctx, ifs.then_block);
            scan_addr_taken_stmt(ctx, ifs.else_block);
            return 0;
        case AST_WHILE:
            var wl: *AstWhile = nref.while_stmt;
            scan_addr_taken_expr(ctx, wl.cond);
            scan_addr_taken_stmt(ctx, wl.body);
            return 0;
        case AST_FOR:
            var fr: *AstFor = nref.for_stmt;
            scan_addr_taken_stmt(ctx, fr.init);
            scan_addr_taken_expr(ctx, fr.cond);
            scan_addr_taken_expr(ctx, fr.update);
            scan_addr_taken_stmt(ctx, fr.body);
            return 0;
        case AST_SWITCH:
        case AST_MATCH:
            var sw: *AstSwitch = nref.switch_stmt;
            scan_addr_taken_expr(ctx, sw.expr);
            var cases: *Vec<*AstCase> = sw.cases_vec;
            if (cases != 0) {
                var cn: u64 = cases.len();
                for (var ci: u64 = 0; ci < cn; ci++) {
                    scan_addr_taken_stmt(ctx, cases.get(ci));
                }
            }
            return 0;
        case AST_CASE:
            var cs: *AstCase = nref.case_stmt;
            scan_addr_taken_stmt(ctx, cs.body);
            return 0;
        case AST_BLOCK:
            var blk: *AstBlock = nref.block_stmt;
            var stmts: *Vec<*AstNode> = blk.stmts_vec;
            if (stmts != 0) {
                var n: u64 = stmts.len();
                for (var i: u64 = 0; i < n; i++) {
                    scan_addr_taken_stmt(ctx, stmts.get(i));
                }
            }
            return 0;
        default:
            return 0;
    }
}

func stmt_contains_inline_asm(stmt: u64) -> u64 {
    if (stmt == 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    var nref: AstNodeTagRef;
    nref.node = (*AstNode)stmt;
    match (kind) {
        case AST_ASM: return 1;
        case AST_DEFER:
            var df: *AstDefer = nref.defer_stmt;
            return stmt_contains_inline_asm(df.stmt);
        case AST_IF:
            var ifs: *AstIf = nref.if_stmt;
            if (stmt_contains_inline_asm(ifs.then_block) != 0) { return 1; }
            return stmt_contains_inline_asm(ifs.else_block);
        case AST_WHILE:
            var wl: *AstWhile = nref.while_stmt;
            return stmt_contains_inline_asm(wl.body);
        case AST_FOR:
            var fr: *AstFor = nref.for_stmt;
            if (stmt_contains_inline_asm(fr.init) != 0) { return 1; }
            return stmt_contains_inline_asm(fr.body);
        case AST_SWITCH:
        case AST_MATCH:
            var sw: *AstSwitch = nref.switch_stmt;
            if (sw.cases_vec == 0) { return 0; }
            var cn: u64 = sw.cases_vec.len();
            for (var ci: u64 = 0; ci < cn; ci++) {
                if (stmt_contains_inline_asm(sw.cases_vec.get(ci)) != 0) { return 1; }
            }
            return 0;
        case AST_CASE:
            var cs: *AstCase = nref.case_stmt;
            return stmt_contains_inline_asm(cs.body);
        case AST_BLOCK:
            var blk: *AstBlock = nref.block_stmt;
            if (blk.stmts_vec == 0) { return 0; }
            var n: u64 = blk.stmts_vec.len();
            for (var i: u64 = 0; i < n; i++) {
                if (stmt_contains_inline_asm(blk.stmts_vec.get(i)) != 0) { return 1; }
            }
            return 0;
    }
    return 0;
}

func mark_inline_asm_locals_addr_taken(ctx: *BuilderCtx, stmt: u64) -> u64 {
    if (ctx == 0 || stmt == 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    var nref: AstNodeTagRef;
    nref.node = (*AstNode)stmt;
    match (kind) {
        case AST_VAR_DECL:
            var vd: *AstVarDecl = nref.var_decl;
            mark_addr_taken(ctx, vd.name);
            return 0;
        case AST_DEFER:
            var df: *AstDefer = nref.defer_stmt;
            return mark_inline_asm_locals_addr_taken(ctx, df.stmt);
        case AST_IF:
            var ifs: *AstIf = nref.if_stmt;
            mark_inline_asm_locals_addr_taken(ctx, ifs.then_block);
            mark_inline_asm_locals_addr_taken(ctx, ifs.else_block);
            return 0;
        case AST_WHILE:
            var wl: *AstWhile = nref.while_stmt;
            return mark_inline_asm_locals_addr_taken(ctx, wl.body);
        case AST_FOR:
            var fr: *AstFor = nref.for_stmt;
            mark_inline_asm_locals_addr_taken(ctx, fr.init);
            mark_inline_asm_locals_addr_taken(ctx, fr.body);
            return 0;
        case AST_SWITCH:
        case AST_MATCH:
            var sw: *AstSwitch = nref.switch_stmt;
            if (sw.cases_vec == 0) { return 0; }
            var cn: u64 = sw.cases_vec.len();
            for (var ci: u64 = 0; ci < cn; ci++) {
                mark_inline_asm_locals_addr_taken(ctx, sw.cases_vec.get(ci));
            }
            return 0;
        case AST_CASE:
            var cs: *AstCase = nref.case_stmt;
            return mark_inline_asm_locals_addr_taken(ctx, cs.body);
        case AST_BLOCK:
            var blk: *AstBlock = nref.block_stmt;
            if (blk.stmts_vec == 0) { return 0; }
            var n: u64 = blk.stmts_vec.len();
            for (var i: u64 = 0; i < n; i++) {
                mark_inline_asm_locals_addr_taken(ctx, blk.stmts_vec.get(i));
            }
            return 0;
    }
    return 0;
}

// ============================================
// Symtab Helpers
// ============================================

func typeinfo_resolve_struct_def(ti: *TypeInfo, type_kind: u64, elem_type_kind: u64, struct_name: []u8) -> u64 {
    if (ti == 0 || struct_name.ptr == 0) { return 0; }

    var needs_struct_def: u64 = 0;
    if (type_kind == TYPE_STRUCT) {
        needs_struct_def = 1;
    } else if ((type_kind == TYPE_ARRAY || type_kind == TYPE_SLICE) && elem_type_kind == TYPE_STRUCT) {
        needs_struct_def = 1;
    }
    if (needs_struct_def == 0) { return 0; }

    var g_structs_vec: *Vec<*AstStructDef> = typeinfo_get_structs();
    if (g_structs_vec == 0) { return 0; }
    var n: u64 = g_structs_vec.len();
    while (n > 0) {
        n = n - 1;
        var sd: *AstStructDef = g_structs_vec.get(n);
        if (u8_slice_len(sd.name) == struct_name.len && str_eq(sd.name, slice(struct_name.ptr, struct_name.len)) != 0) {
            ti.struct_def = sd;
            return 0;
        }
    }
    return 0;
}

func add_param_symtab(ctx: *BuilderCtx, p: *Param, offset: u64) -> u64 {
    var symtab: *Symtab = ctx.symtab;
    var names: *Vec<*NameInfo> = symtab.names_vec;
    var offsets: *Vec<u64> = symtab.offsets_vec;
    var types: *Vec<*TypeInfo> = symtab.types_vec;

    var name_info: *NameInfo = new NameInfo{u8_slice_ptr(p.name), u8_slice_len(p.name)};
    names.push(name_info);
    offsets.push(offset);

    var ti: *TypeInfo = typeinfo_new(p.type_kind, p.ptr_depth);
    p.apply_to_typeinfo(ti);
    typeinfo_resolve_struct_def(ti, p.type_kind, p.elem_type_kind, p.struct_name);

    types.push(ti);
    if (u8_slice_ptr(p.name) != 0 && u8_slice_len(p.name) != 0) {
        if (symtab.name_to_offset_map != 0) {
            symtab.name_to_offset_map.put(p.name, offset);
        }
        if (symtab.name_to_type_map != 0) {
            symtab.name_to_type_map.put(p.name, ti);
        }
    }
    symtab.count = symtab.count + 1;
    return 0;
}

func symtab_add_local(ctx: *BuilderCtx, decl: *AstVarDecl) -> u64 {
    var name: []u8 = decl.name;
    var type_kind: u64 = decl.type_kind;
    var ptr_depth: u64 = decl.ptr_depth;
    var struct_name: []u8 = decl.struct_name;
    var elem_type_kind: u64 = decl.elem_type_kind;
    var elem_ptr_depth: u64 = decl.elem_ptr_depth;
    var array_len: u64 = decl.array_len;
    var elem_typeinfo: *TypeInfo = decl.elem_typeinfo;

    var size: u64 = 0;
    if (type_kind == TYPE_ARRAY) {
        var elem_size: u64 = 0;
        if (elem_typeinfo != 0) {
            elem_size = sizeof_type_ex(elem_typeinfo);
        } else {
            elem_size = layout_type_sizeof(elem_type_kind, elem_ptr_depth, struct_name);
        }
        size = elem_size * array_len;
    } else if (type_kind == TYPE_SLICE) {
        size = 16;
    } else {
        size = layout_type_sizeof(type_kind, ptr_depth, struct_name);
    }

    symtab_add(ctx.symtab, name, type_kind, ptr_depth, size);

    var ti: *TypeInfo = symtab_get_type(ctx.symtab, name);
    ti.is_tagged = decl.is_tagged;
    ti.struct_name = struct_name;
    ti.tag_layout = decl.tag_layout;
    ti.elem_type_kind = elem_type_kind;
    ti.elem_ptr_depth = elem_ptr_depth;
    ti.array_len = array_len;
    ti.elem_typeinfo = elem_typeinfo;
    typeinfo_resolve_struct_def(ti, type_kind, elem_type_kind, struct_name);

    return 0;
}

func new_reg(ctx: *BuilderCtx) -> u64 {
    var id: u64 = ctx.next_reg;
    ctx.next_reg = ctx.next_reg + 1;
    return id;
}

func new_var_id(ctx: *BuilderCtx) -> u64 {
    var id: u64 = ctx.next_var_id;
    ctx.next_var_id = ctx.next_var_id + 1;
    return id;
}

func get_var_id(ctx: *BuilderCtx, name: []u8) -> u64 {
    if (ctx.var_map == 0) {
        ctx.var_map = new HashMap<u64, u64>{0, 0, 0};
        ctx.var_map.ensure_capacity(16);
    }

    var found: u64 = ctx.var_map.get(slice(name.ptr, name.len));
    if (found != 0) { return found; }

    var new_id: u64 = new_var_id(ctx);
    ctx.var_map.put(slice(name.ptr, name.len), new_id);
    return new_id;
}

func set_const(ctx: *BuilderCtx, name: []u8, value: u64) -> u64 {
    if (ctx.const_map == 0) {
        ctx.const_map = new HashMap<u64, u64>{0, 0, 0};
        ctx.const_map.ensure_capacity(16);
    }
    ctx.const_map.put(slice(name.ptr, name.len), value + 1);
    return 0;
}

func get_const(ctx: *BuilderCtx, name: []u8) -> u64 {
    if (ctx.const_map == 0) { return 0; }
    return ctx.const_map.get(slice(name.ptr, name.len));
}

func set_func_ptr(ctx: *BuilderCtx, name: []u8, func_slice: []u8) -> u64 {
    if (ctx.func_ptr_map == 0) {
        ctx.func_ptr_map = new HashMap<u64, *PtrLen>{0, 0, 0};
        ctx.func_ptr_map.ensure_capacity(16);
    }
    if (func_slice.ptr == 0 || func_slice.len == 0) {
        ctx.func_ptr_map.put(slice(name.ptr, name.len), 0);
        return 0;
    }
    var info: *PtrLen = new PtrLen{func_slice.ptr, func_slice.len};
    ctx.func_ptr_map.put(slice(name.ptr, name.len), info);
    return 0;
}

func get_func_ptr(ctx: *BuilderCtx, name: []u8) -> *PtrLen {
    if (ctx.func_ptr_map == 0) { return 0; }
    return ctx.func_ptr_map.get(slice(name.ptr, name.len));
}

func set_closure_handle(ctx: *BuilderCtx, name: []u8, enabled: u64) -> u64 {
    if (ctx == 0) { return 0; }
    if (ctx.closure_handle_map == 0) {
        ctx.closure_handle_map = new HashMap<u64, u64>{0, 0, 0};
        ctx.closure_handle_map.ensure_capacity(16);
    }
    if (enabled == 0) {
        ctx.closure_handle_map.put(slice(name.ptr, name.len), 0);
        return 0;
    }
    ctx.closure_handle_map.put(slice(name.ptr, name.len), 1);
    return 0;
}

func is_closure_handle(ctx: *BuilderCtx, name: []u8) -> u64 {
    if (ctx == 0 || ctx.closure_handle_map == 0) { return 0; }
    if (ctx.closure_handle_map.get(slice(name.ptr, name.len)) == 1) { return 1; }
    return 0;
}

func is_lambda_bind_name(name: []u8) -> u64 {
    if (name.ptr == 0 || name.len < 14) { return 0; }
    if (str_eq(slice(name.ptr, 14), slice("__lambda_bind_", str_len("__lambda_bind_"))) == 0) { return 0; }
    return 1;
}

func closure_expr_is_lambda_handle(ctx: *BuilderCtx, expr: u64) -> u64 {
    if (expr == 0) { return 0; }
    var kind: u64 = ast_kind(expr);
    if (kind == AST_CALL) {
        var call: *AstCall = (*AstCall)expr;
        if (is_lambda_bind_name(call.name) != 0) { return 1; }
        return 0;
    }
    if (kind == AST_IDENT) {
        var idn: *AstIdent = (*AstIdent)expr;
        return is_closure_handle(ctx, idn.name);
    }
    return 0;
}

func closure_track_from_expr(ctx: *BuilderCtx, target_name: []u8, value_expr: u64) -> u64 {
    if (closure_expr_is_lambda_handle(ctx, value_expr) != 0) {
        set_closure_handle(ctx, slice(target_name.ptr, target_name.len), 1);
        return 0;
    }
    set_closure_handle(ctx, slice(target_name.ptr, target_name.len), 0);
    return 0;
}

func apply_param_typeinfo(p: *Param, ti: *TypeInfo) -> u64 {
    if (p == 0 || ti == 0) {
        return 0;
    }
    p.apply_to_typeinfo(ti);
    typeinfo_resolve_struct_def(ti, p.type_kind, p.elem_type_kind, p.struct_name);
    return 0;
}

func emit_param_struct_local(ctx: *BuilderCtx, p: *Param, start_idx: u64, offset: u64, struct_size: u64) -> u64 {
    var base_addr: u64 = new_lea_local(ctx, offset);
    if (struct_size <= 8) {
        var reg0: u64 = new_reg(ctx);
        var param0: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_PARAM, reg0, operand_const(start_idx), 0);
        append_inst(ctx.cur_block, param0);
        store_by_size(ctx, base_addr, reg0, struct_size);
        return 0;
    }
    if (struct_size <= 16) {
        var reg_lo: u64 = new_reg(ctx);
        var reg_hi: u64 = new_reg(ctx);
        var param_lo: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_PARAM, reg_lo, operand_const(start_idx), 0);
        var param_hi: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_PARAM, reg_hi, operand_const(start_idx + 1), 0);
        append_inst(ctx.cur_block, param_lo);
        append_inst(ctx.cur_block, param_hi);
        store_by_size(ctx, base_addr, reg_lo, 8);
        var off_reg: u64 = build_const(ctx, 8);
        var addr2: u64 = new_reg(ctx);
        var add_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, addr2, operand_reg(base_addr), operand_reg(off_reg));
        append_inst(ctx.cur_block, add_ptr);
        var tail_size: u64 = struct_size - 8;
        store_by_size(ctx, addr2, reg_hi, tail_size);
        return 0;
    }
    var reg_ptr: u64 = new_reg(ctx);
    var param_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_PARAM, reg_ptr, operand_const(start_idx), 0);
    append_inst(ctx.cur_block, param_ptr);
    if (ctx.debug_mode != 0) {
        emit("[DEBUG] ssa param copy large struct: ");
        emit_len(u8_slice_ptr(p.name), u8_slice_len(p.name));
        emit(" size=");
        print_u64(struct_size);
        emit("\n");
    }
    struct_copy(ctx, base_addr, reg_ptr, struct_size);
    return 0;
}

func emit_param_slice_local(ctx: *BuilderCtx, start_idx: u64, offset: u64) -> u64 {
    var base_addr: u64 = new_lea_local(ctx, offset);
    var ptr_reg: u64 = new_reg(ctx);
    var ptr_param: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_PARAM, ptr_reg, operand_const(start_idx), 0);
    append_inst(ctx.cur_block, ptr_param);
    store_by_size(ctx, base_addr, ptr_reg, 8);
    var len_reg: u64 = new_reg(ctx);
    var len_param: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_PARAM, len_reg, operand_const(start_idx + 1), 0);
    append_inst(ctx.cur_block, len_param);
    var off_reg2: u64 = build_const(ctx, 8);
    var addr3: u64 = new_reg(ctx);
    var add_ptr2: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, addr3, operand_reg(base_addr), operand_reg(off_reg2));
    append_inst(ctx.cur_block, add_ptr2);
    store_by_size(ctx, addr3, len_reg, 8);
    return 0;
}

func func_has_sret_param(fn: *AstFunc) -> u64 {
    if (fn == 0) { return 0; }
    if (fn.ret_type != TYPE_STRUCT || fn.ret_ptr_depth != 0) { return 0; }
    var ret_struct_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, fn.ret_struct_name);
    var ret_def: *AstStructDef = get_struct_def(fn.ret_struct_name);
    var ret_def_size: u64 = struct_size_from_def(ret_def);
    if (ret_def_size > ret_struct_size) { ret_struct_size = ret_def_size; }
    if (ret_struct_size > 16) { return 1; }
    return 0;
}

func plan_param_layout(ctx: *BuilderCtx, params: *Vec<*Param>, has_sret: u64, param_layouts: *Vec<*BuilderParamLayout>) -> u64 {
    var n: u64 = params.len();
    var arg_idx: u64 = 0;
    if (has_sret != 0) { arg_idx = 1; }

    for (var i: u64 = 0; i < n; i++) {
        var p: *Param = params.get(i);
        var layout: *BuilderParamLayout = new BuilderParamLayout{};
        layout.arg_start_idx = arg_idx;
        var param_words: u64 = 1;
        if (p.type_kind == TYPE_STRUCT && p.ptr_depth == 0) {
            var struct_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, p.struct_name);
            if (struct_size == 0) { return 0; }
            if (struct_size <= 8) { param_words = 1; }
            else if (struct_size <= 16) { param_words = 2; }
            else {
                param_words = 1;
                if (ctx.debug_mode != 0) {
                    emit("[DEBUG] ssa param large struct: ");
                    emit_len(u8_slice_ptr(p.name), u8_slice_len(p.name));
                    emit(" size=");
                    print_u64(struct_size);
                    emit("\n");
                }
            }

            var offset: u64 = symtab_add(ctx.symtab, p.name, p.type_kind, p.ptr_depth, struct_size);
            var ti: *TypeInfo = symtab_get_type(ctx.symtab, p.name);
            apply_param_typeinfo(p, ti);
            layout.stack_offset = offset;
        } else if (p.type_kind == TYPE_ARRAY && p.ptr_depth == 0) {
            var array_size: u64 = layout_type_sizeof(p.type_kind, p.ptr_depth, p.struct_name);
            if (array_size == 0) { return 0; }
            var offset_arr: u64 = symtab_add(ctx.symtab, p.name, p.type_kind, p.ptr_depth, array_size);
            var ti_arr: *TypeInfo = symtab_get_type(ctx.symtab, p.name);
            apply_param_typeinfo(p, ti_arr);
            layout.stack_offset = offset_arr;
        } else if (p.type_kind == TYPE_SLICE && p.ptr_depth == 0) {
            var offset2: u64 = symtab_add(ctx.symtab, p.name, p.type_kind, p.ptr_depth, 16);
            var ti2: *TypeInfo = symtab_get_type(ctx.symtab, p.name);
            apply_param_typeinfo(p, ti2);
            param_words = 2;
            layout.stack_offset = offset2;
        }
        param_layouts.push(layout);
        arg_idx = arg_idx + param_words;
    }
    return 1;
}

func emit_params_from_layout(ctx: *BuilderCtx, params: *Vec<*Param>, param_layouts: *Vec<*BuilderParamLayout>) -> u64 {
    var n: u64 = params.len();
    for (var i: u64 = n; i > 0; i--) {
        var idx: u64 = i - 1;
        var p2: *Param = params.get(idx);
        var layout: *BuilderParamLayout = param_layouts.get(idx);
        var start_idx: u64 = layout.arg_start_idx;
        if (p2.type_kind == TYPE_STRUCT && p2.ptr_depth == 0) {
            var struct_size2: u64 = layout_type_sizeof(TYPE_STRUCT, 0, p2.struct_name);
            if (struct_size2 == 0) { return 0; }
            var offset3: u64 = layout.stack_offset;
            if (struct_size2 <= 8) {
                var reg_id_s: u64 = new_reg(ctx);
                var param_ptr_s: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_PARAM, reg_id_s, operand_const(start_idx), 0);
                append_inst(ctx.cur_block, param_ptr_s);
                var base_addr_s: u64 = new_lea_local(ctx, offset3);
                store_by_size(ctx, base_addr_s, reg_id_s, struct_size2);
                var var_id_s: u64 = get_var_id(ctx, p2.name);
                var st_ptr_s: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_STORE, 0, operand_const(var_id_s), operand_reg(reg_id_s));
                append_inst(ctx.cur_block, st_ptr_s);
                continue;
            }
            emit_param_struct_local(ctx, p2, start_idx, offset3, struct_size2);
            continue;
        }

        if (p2.type_kind == TYPE_SLICE && p2.ptr_depth == 0) {
            var offset4: u64 = layout.stack_offset;
            emit_param_slice_local(ctx, start_idx, offset4);
            continue;
        }

        if (p2.type_kind == TYPE_ARRAY && p2.ptr_depth == 0) {
            var array_size2: u64 = layout_type_sizeof(p2.type_kind, p2.ptr_depth, p2.struct_name);
            if (array_size2 == 0) { return 0; }
            var reg_id_a: u64 = new_reg(ctx);
            var param_ptr_a: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_PARAM, reg_id_a, operand_const(start_idx), 0);
            append_inst(ctx.cur_block, param_ptr_a);
            var base_addr_a: u64 = new_lea_local(layout.stack_offset);
            struct_copy(ctx, base_addr_a, reg_id_a, array_size2);
            continue;
        }

        var var_id: u64 = get_var_id(ctx, p2.name);
        var reg_id: u64 = new_reg(ctx);
        var inst_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_PARAM, reg_id, operand_const(start_idx), 0);
        append_inst(ctx.cur_block, inst_ptr);
        var st_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_STORE, 0, operand_const(var_id), operand_reg(reg_id));
        append_inst(ctx.cur_block, st_ptr);

        // Give every scalar parameter a real local slot.
        // That keeps addr-taken parameter semantics stable across SSA/mem2reg/O1
        // instead of relying on caller stack slots like [rbp+16], which only
        // exist for stack-passed arguments and break register-passed params.
        var param_size: u64 = layout_type_sizeof(p2.type_kind, p2.ptr_depth, p2.struct_name);
        if (param_size == 0) { param_size = 8; }
        var local_offset: u64 = symtab_add(ctx.symtab, p2.name, p2.type_kind, p2.ptr_depth, param_size);
        var local_ti: *TypeInfo = symtab_get_type(ctx.symtab, p2.name);
        apply_param_typeinfo(p2, local_ti);
        var local_addr: u64 = new_lea_local(ctx, local_offset);
        store_by_size(ctx, local_addr, reg_id, param_size);
    }
    return 1;
}

func add_params(ctx: *BuilderCtx, fn: *AstFunc) -> u64 {
    push_trace("add_params", "ssa_builder.b", __LINE__);
    defer pop_trace();
    if (fn == 0) { return 0; }
    var params: *Vec<*Param> = fn.params_vec;
    if (params == 0) { return 0; }

    ctx.sret_addr_reg = 0;
    var has_sret: u64 = func_has_sret_param(fn);

    var n: u64 = params.len();
    var param_layouts: *Vec<*BuilderParamLayout> = new Vec<*BuilderParamLayout>{heap_alloc((n) * sizeof(*BuilderParamLayout)), 0, (n)};
    if (plan_param_layout(ctx, params, has_sret, param_layouts) == 0) { return 0; }
    if (emit_params_from_layout(ctx, params, param_layouts) == 0) { return 0; }
    if (has_sret != 0) {
        var sret_reg: u64 = new_reg(ctx);
        var sret_param: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_PARAM, sret_reg, operand_const(0), 0);
        append_inst(ctx.cur_block, sret_param);
        ctx.sret_addr_reg = sret_reg;
    }
    return 0;
}

// ============================================
// Address/Memory Helpers
// ============================================

func new_lea_local(ctx: *BuilderCtx, offset: u64) -> u64 {
    var reg_id: u64 = new_reg(ctx);
    // Encode signed 64-bit stack offset into 63-bit field with bias so
    // operand_value can carry it without losing sign.
    var signed_off: i64 = (i64)offset;
    var bias: u64 = 4611686018427387904; // 1<<62
    var enc: u64 = (u64)(signed_off + (i64)bias);
    var inst_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_LEA_LOCAL, reg_id, operand_const(enc), 0);
    append_inst(ctx.cur_block, inst_ptr);
    return reg_id;
}

func new_lea_global(ctx: *BuilderCtx, name: []u8) -> u64 {
    var info: *PtrLen = new PtrLen{name.ptr, name.len};
    var reg_id: u64 = new_reg(ctx);
    var inst_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_LEA_GLOBAL, reg_id, operand_const((u64)info), 0);
    append_inst(ctx.cur_block, inst_ptr);
    return reg_id;
}

func new_lea_func(ctx: *BuilderCtx, name: []u8) -> u64 {
    var info: *PtrLen = new PtrLen{name.ptr, name.len};
    var reg_id: u64 = new_reg(ctx);
    var inst_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_LEA_FUNC, reg_id, operand_const((u64)info), 0);
    append_inst(ctx.cur_block, inst_ptr);
    return reg_id;
}

func ssa_asm_clone_with_current_aliases(text_vec: *Vec<u64>) -> *Vec<u64> {
    if (text_vec == 0) { return 0; }
    var asm_len: u64 = text_vec.len();
    var out: *Vec<u64> = new Vec<u64>{heap_alloc((asm_len + 32) * sizeof(u64)), 0, (asm_len + 32)};
    var i: u64 = 0;
    while (i < asm_len) {
        var ch: u64 = text_vec.get(i);
        var ident_start: u64 = 0;
        if ((ch >= 65 && ch <= 90) || (ch >= 97 && ch <= 122) || ch == 95) {
            ident_start = 1;
        }
        if (ident_start == 0) {
            out.push(ch);
            i = i + 1;
            continue;
        }

        var tok_start: u64 = i;
        while (i < asm_len) {
            var ch2: u64 = text_vec.get(i);
            if (!((ch2 >= 65 && ch2 <= 90) || (ch2 >= 97 && ch2 <= 122) || (ch2 >= 48 && ch2 <= 57) || ch2 == 95)) {
                break;
            }
            i = i + 1;
        }
        var tok_len: u64 = i - tok_start;
        if (tok_len == 0) { continue; }

        var tok_ptr: u64 = heap_alloc((tok_len + 1) * sizeof(u8));
        var tok_u8: []u8 = slice(tok_ptr, tok_len + 1);
        for (var j: u64 = 0; j < tok_len; j = j + 1) {
            tok_u8[j] = (u8)text_vec.get(tok_start + j);
        }
        tok_u8[tok_len] = 0;

        var alias_info: *NameInfo = sym_reg_alias_get(slice(tok_ptr, tok_len));
        if (alias_info != 0) {
            var alias_u8: []u8 = slice(alias_info.ptr, alias_info.len);
            for (var aj: u64 = 0; aj < alias_info.len; aj = aj + 1) {
                out.push(alias_u8[aj]);
            }
        } else {
            for (var k: u64 = 0; k < tok_len; k = k + 1) {
                out.push(text_vec.get(tok_start + k));
            }
        }
    }
    return out;
}

func load_by_size(ctx: *BuilderCtx, addr_reg: u64, size: u64) -> u64 {
    var reg_id: u64 = new_reg(ctx);
    var op: u64 = SSA_OP_LOAD64;
    if (size == 1) { op = SSA_OP_LOAD8; }
    else if (size == 2) { op = SSA_OP_LOAD16; }
    else if (size == 4) { op = SSA_OP_LOAD32; }
    var inst_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, op, reg_id, operand_reg(addr_reg), 0);
    append_inst(ctx.cur_block, inst_ptr);
    return reg_id;
}

func store_by_size(ctx: *BuilderCtx, addr_reg: u64, val_reg: u64, size: u64) -> u64 {
    var op: u64 = SSA_OP_STORE64;
    if (size == 1) { op = SSA_OP_STORE8; }
    else if (size == 2) { op = SSA_OP_STORE16; }
    else if (size == 4) { op = SSA_OP_STORE32; }
    var inst_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, op, 0, operand_reg(addr_reg), operand_reg(val_reg));
    append_inst(ctx.cur_block, inst_ptr);
    return 0;
}

func struct_copy(ctx: *BuilderCtx, dst_addr: u64, src_addr: u64, size: u64) -> u64 {
    for (var offset: u64 = 0; offset < size; ) {
        var chunk: u64 = size - offset;
        if (chunk > 8) { chunk = 8; }
        var src_reg: u64 = src_addr;
        var dst_reg: u64 = dst_addr;
        if (offset != 0) {
            var off_reg: u64 = build_const(ctx, offset);
            var src_tmp: u64 = new_reg(ctx);
            var dst_tmp: u64 = new_reg(ctx);
            var add_src: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, src_tmp, operand_reg(src_addr), operand_reg(off_reg));
            var add_dst: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, dst_tmp, operand_reg(dst_addr), operand_reg(off_reg));
            append_inst(ctx.cur_block, add_src);
            append_inst(ctx.cur_block, add_dst);
            src_reg = src_tmp;
            dst_reg = dst_tmp;
        }
        var val_reg: u64 = load_by_size(ctx, src_reg, chunk);
        store_by_size(ctx, dst_reg, val_reg, chunk);
        offset = offset + chunk;
    }
    return 0;
}

func append_slice_arg(ctx: *BuilderCtx, arg_regs: *Vec<u64>, arg: u64) -> u64 {
    var k: u64 = ast_kind(arg);
    if (k == AST_SLICE) {
        var slice_regs: *SliceRegs = slice_regs(ctx, arg);
        var ptr_reg: u64 = slice_regs.ptr_reg;
        var len_reg: u64 = slice_regs.len_reg;
        arg_regs.push(ptr_reg);
        arg_regs.push(len_reg);
        return 0;
    }

    var addr_reg: u64 = lvalue_addr(ctx, arg);
    if (addr_reg == 0) { return 0; }
    var ptr_reg2: u64 = load_by_size(ctx, addr_reg, 8);
    var off_reg: u64 = build_const(ctx, 8);
    var addr2: u64 = new_reg(ctx);
    var add_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, addr2, operand_reg(addr_reg), operand_reg(off_reg));
    append_inst(ctx.cur_block, add_ptr);
    var len_reg2: u64 = load_by_size(ctx, addr2, 8);
    arg_regs.push(ptr_reg2);
    arg_regs.push(len_reg2);
    return 0;
}

func get_sret_struct_size(ctx: *BuilderCtx, expr: u64) -> u64 {
    if (expr == 0) { return 0; }
    var struct_size: u64 = 0;
        var ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)expr, ctx.symtab);
    if (ti != 0) {
        if (ti.type_kind == TYPE_STRUCT && ti.ptr_depth == 0) {
            if (u8_slice_ptr(ti.struct_name) != 0 && u8_slice_len(ti.struct_name) != 0) {
                struct_size = layout_type_sizeof(TYPE_STRUCT, 0, ti.struct_name);
            }
            if (struct_size <= 16 && ti.struct_def != 0) {
                var def_size: u64 = struct_size_from_def(ti.struct_def);
                if (def_size > struct_size) { struct_size = def_size; }
            }
        }
    }
    if (struct_size <= 16) {
        var k: u64 = ast_kind(expr);
        if (k == AST_CALL) {
            var call_node: *AstCall = (*AstCall)expr;
            var call_fn: *AstFunc = sym_get_func(call_node.name);
            if (call_fn != 0) {
                if (call_fn.ret_type == TYPE_STRUCT && call_fn.ret_ptr_depth == 0) {
                    var call_def: *AstStructDef = get_struct_def(call_fn.ret_struct_name);
                    var call_def_size: u64 = struct_size_from_def(call_def);
                    if (call_def_size == 0) {
                        call_def_size = layout_type_sizeof(TYPE_STRUCT, 0, call_fn.ret_struct_name);
                    }
                    if (call_def_size > struct_size) { struct_size = call_def_size; }
                }
            }
        }
        if (k == AST_METHOD_CALL) {
            var mc_node: *AstMethodCall = (*AstMethodCall)expr;
            var recv_ti: *TypeInfo = get_expr_type_with_symtab(mc_node.receiver, ctx.symtab);
            if (recv_ti != 0) {
                if (recv_ti.type_kind == TYPE_STRUCT && u8_slice_ptr(recv_ti.struct_name) != 0) {
                    var arg_types: *Vec<*TypeInfo> = builder_collect_arg_types_for_method_resolution(mc_node.args_vec, ctx.symtab);
                    var nargs2: u64 = 0;
                    if (mc_node.args_vec != 0) { nargs2 = mc_node.args_vec.len(); }
                    var resolved2: CompilerMethodResolveResult = sym_resolve_method_overload(recv_ti.struct_name, mc_node.method, arg_types, nargs2);
                    var call_fn2: *AstFunc = 0;
                    if (resolved2.found != 0) {
                        call_fn2 = resolved2.fn;
                    }
                    if (call_fn2 == 0) {
                        var name_info: *NameInfo = build_method_name(recv_ti.struct_name, mc_node.method);
                        call_fn2 = sym_get_func(slice(name_info.ptr, name_info.len));
                    }
                    if (call_fn2 != 0) {
                        if (call_fn2.ret_type == TYPE_STRUCT && call_fn2.ret_ptr_depth == 0) {
                            var call_def2: *AstStructDef = get_struct_def(call_fn2.ret_struct_name);
                            var call_def_size2: u64 = struct_size_from_def(call_def2);
                            if (call_def_size2 == 0) {
                                call_def_size2 = layout_type_sizeof(TYPE_STRUCT, 0, call_fn2.ret_struct_name);
                            }
                            if (call_def_size2 > struct_size) { struct_size = call_def_size2; }
                        }
                    }
                }
            }
        }
    }
    if (struct_size <= 16) { return 0; }
    if (SSA_BUILDER_DEBUG != 0) {
        println("[DEBUG] sret temp slot for expr", 31);
    }
    return struct_size;
}

func append_struct_value_from_addr(ctx: *BuilderCtx, arg_regs: *Vec<u64>, addr_reg: u64, struct_size: u64) -> u64 {
    if (struct_size == 0) {
        return 0;
    }
    if (struct_size <= 8) {
        var val: u64 = load_by_size(ctx, addr_reg, struct_size);
        arg_regs.push(val);
        return 0;
    }
    if (struct_size <= 16) {
        var lo: u64 = load_by_size(ctx, addr_reg, 8);
        var off8: u64 = build_const(ctx, 8);
        var addr2: u64 = new_reg(ctx);
        var add_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, addr2, operand_reg(addr_reg), operand_reg(off8));
        append_inst(ctx.cur_block, add_ptr);
        var tail_size: u64 = struct_size - 8;
        var hi: u64 = load_by_size(ctx, addr2, tail_size);
        arg_regs.push(lo);
        arg_regs.push(hi);
        return 0;
    }
    arg_regs.push(addr_reg);
    return 0;
}

func append_small_struct_call_result(ctx: *BuilderCtx, arg_regs: *Vec<u64>, arg_kind: u64, arg: u64, struct_size: u64) -> u64 {
    if (struct_size == 0 || struct_size > 16) {
        return 0;
    }
    if (!(arg_kind == AST_CALL || arg_kind == AST_METHOD_CALL || arg_kind == AST_CALL_PTR)) {
        return 0;
    }
    if (struct_size <= 8) {
        var reg0: u64 = new_reg(ctx);
        if (arg_kind == AST_CALL) {
            emit_call(ctx, (*AstCall)arg, reg0, 0);
        } else if (arg_kind == AST_METHOD_CALL) {
            emit_method_call_value(ctx, (*AstMethodCall)arg, reg0, 0);
        } else {
            emit_call_ptr(ctx, (*AstCallPtr)arg, reg0, 0);
        }
        arg_regs.push(reg0);
        return 1;
    }
    var lo_reg: u64 = new_reg(ctx);
    var hi_reg: u64 = new_reg(ctx);
    if (arg_kind == AST_CALL) {
        emit_call(ctx, (*AstCall)arg, lo_reg, hi_reg);
    } else if (arg_kind == AST_METHOD_CALL) {
        emit_method_call_value(ctx, (*AstMethodCall)arg, lo_reg, hi_reg);
    } else {
        emit_call_ptr(ctx, (*AstCallPtr)arg, lo_reg, hi_reg);
    }
    arg_regs.push(lo_reg);
    arg_regs.push(hi_reg);
    return 1;
}

func emit_struct_call_sret_by_kind(ctx: *BuilderCtx, arg_kind: u64, arg: u64, temp_addr: u64) -> u64 {
    if (arg_kind == AST_CALL) {
        emit_call_sret_value(ctx, (*AstCall)arg, temp_addr);
        return 1;
    }
    if (arg_kind == AST_METHOD_CALL) {
        emit_method_call_sret(ctx, (*AstMethodCall)arg, temp_addr);
        return 1;
    }
    if (arg_kind == AST_CALL_PTR) {
        emit_call_ptr_sret(ctx, (*AstCallPtr)arg, temp_addr);
        return 1;
    }
    return 0;
}

func append_call_arg_stack_ctor(ctx: *BuilderCtx, arg_regs: *Vec<u64>, arg: u64) -> u64 {
    if (ast_kind(arg) != AST_STACK_CTOR) {
        return 0;
    }
    var sc_arg: *AstStackCtor = (*AstStackCtor)arg;
    var sc_ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)arg, ctx.symtab);
    if (sc_ti == 0 || sc_ti.type_kind != TYPE_STRUCT || sc_ti.ptr_depth != 0) {
        emit_stderr("[ERROR] SSA stack ctor arg requires struct value\n");
        return 1;
    }
    var struct_size_sc: u64 = layout_type_sizeof(TYPE_STRUCT, 0, sc_ti.struct_name);
    if (struct_size_sc == 0) {
        emit_stderr("[ERROR] SSA stack ctor arg struct size unresolved\n");
        return 1;
    }
    var temp_offset_sc: u64 = symtab_add(ctx.symtab, slice(0, 0), TYPE_STRUCT, 0, struct_size_sc);
    var temp_addr_sc: u64 = new_lea_local(ctx, temp_offset_sc);
    stack_ctor_init_at_addr(ctx, sc_arg, temp_addr_sc);
    append_struct_value_from_addr(ctx, arg_regs, temp_addr_sc, struct_size_sc);
    return 1;
}

func append_call_arg_struct_literal(ctx: *BuilderCtx, arg_regs: *Vec<u64>, arg: u64) -> u64 {
    if (ast_kind(arg) != AST_STRUCT_LITERAL) {
        return 0;
    }
    var lit: *AstStructLiteral = (*AstStructLiteral)arg;
    var struct_size_lit: u64 = resolve_struct_literal_size(ctx, lit, slice(0, 0));
    if (struct_size_lit == 0) {
        emit_stderr("[ERROR] SSA arg struct literal size unresolved\n");
        return 1;
    }

    if (lit.struct_def != 0 && struct_size_lit <= 16) {
        var struct_info: *AstStructDef = lit.struct_def;
        var packed_flag: u64 = struct_info.is_packed;
        if (packed_flag == 0) {
            var fields: *Vec<*FieldDesc> = struct_info.fields_vec;
            var num_fields: u64 = 0;
            if (fields != 0) { num_fields = fields.len(); }
            if (num_fields >= 1 && num_fields <= 2 && lit.values_vec != 0) {
                var f0: *FieldDesc = fields.get(0);
                var f0_size: u64 = layout_field_sizeof(f0);
                var v0: *AstNode = lit.values_vec.get(0);
                var reg0: u64 = build_expr(ctx, v0);
                if (reg0 == 0) { reg0 = build_const(ctx, 0); }
                if (num_fields == 1 && f0_size == 8) {
                    arg_regs.push(reg0);
                    return 1;
                }
                if (num_fields == 2) {
                    var f1: *FieldDesc = fields.get(1);
                    var f1_size: u64 = layout_field_sizeof(f1);
                    if (f0_size == 8 && f1_size == 8 && lit.values_vec.len() > 1) {
                        var v1: *AstNode = lit.values_vec.get(1);
                        var reg1: u64 = build_expr(ctx, v1);
                        if (reg1 == 0) { reg1 = build_const(ctx, 0); }
                        arg_regs.push(reg0);
                        arg_regs.push(reg1);
                        return 1;
                    }
                }
            }
        }
    }

    var temp_offset_lit: u64 = symtab_add(ctx.symtab, slice(0, 0), TYPE_STRUCT, 0, struct_size_lit);
    var temp_addr_lit: u64 = new_lea_local(ctx, temp_offset_lit);
    struct_literal_init(ctx, lit.struct_def, lit.values_vec, temp_addr_lit);
    if (struct_size_lit > 16 && ctx.debug_mode != 0) {
        emit("[DEBUG] ssa call arg large struct literal size=");
        print_u64(struct_size_lit);
        emit("\n");
    }
    append_struct_value_from_addr(ctx, arg_regs, temp_addr_lit, struct_size_lit);
    return 1;
}

func append_call_arg_call_struct_fast(ctx: *BuilderCtx, arg_regs: *Vec<u64>, arg: u64) -> u64 {
    if (ast_kind(arg) != AST_CALL) {
        return 0;
    }
    var call: *AstCall = (*AstCall)arg;
    var fn: *AstFunc = sym_get_func(call.name);
    if (fn == 0) {
        return 0;
    }
    if (fn.ret_type == TYPE_STRUCT && fn.ret_ptr_depth == 0) {
        var struct_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, fn.ret_struct_name);
        if (append_small_struct_call_result(ctx, arg_regs, AST_CALL, arg, struct_size) != 0) {
            return 1;
        }
    }
    return 0;
}

func append_call_arg_struct_typed(ctx: *BuilderCtx, arg_regs: *Vec<u64>, arg: u64, arg_kind: u64, ti: *TypeInfo) -> u64 {
    var struct_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, ti.struct_name);
    if (struct_size == 0) {
        var def_ptr: *AstStructDef = ti.struct_def;
        if (def_ptr == 0 && arg_kind == AST_STRUCT_LITERAL) {
            var lit_def: *AstStructLiteral = (*AstStructLiteral)arg;
            def_ptr = lit_def.struct_def;
        }
        var def_size: u64 = struct_size_from_def(def_ptr);
        if (def_size > 0) { struct_size = def_size; }
    }
    if (struct_size == 0 && arg_kind == AST_STRUCT_LITERAL) {
        var lit_fallback2: *AstStructLiteral = (*AstStructLiteral)arg;
        struct_size = resolve_struct_literal_size(ctx, lit_fallback2, slice(0, 0));
    }
    if (struct_size == 0) {
        emit_stderr("[ERROR] SSA arg struct size unresolved\n");
        return 0;
    }
    if (struct_size <= 16) {
        if (append_small_struct_call_result(ctx, arg_regs, arg_kind, arg, struct_size) != 0) {
            return 0;
        }
        var small_addr: u64 = lvalue_addr(ctx, arg);
        if (small_addr == 0) {
            if (struct_size <= 8) {
                var small_reg: u64 = build_expr(ctx, arg);
                arg_regs.push(small_reg);
                return 0;
            }
            var temp_offset_small: u64 = symtab_add(ctx.symtab, slice(0, 0), TYPE_STRUCT, 0, struct_size);
            var temp_addr_small: u64 = new_lea_local(ctx, temp_offset_small);
            if (try_materialize_operand(ctx, arg, struct_size, temp_addr_small) == 0) {
                return 0;
            }
            append_struct_value_from_addr(ctx, arg_regs, temp_addr_small, struct_size);
            return 0;
        }
        append_struct_value_from_addr(ctx, arg_regs, small_addr, struct_size);
        return 0;
    }
    if (ctx.debug_mode != 0) {
        emit("[DEBUG] ssa call arg large struct: ");
        emit_len(u8_slice_ptr(ti.struct_name), u8_slice_len(ti.struct_name));
        emit(" size=");
        print_u64(struct_size);
        emit("\n");
    }
    var temp_offset: u64 = symtab_add(ctx.symtab, slice(0, 0), TYPE_STRUCT, 0, struct_size);
    var temp_addr: u64 = new_lea_local(ctx, temp_offset);
    if (arg_kind == AST_STRUCT_LITERAL) {
        var lit: *AstStructLiteral = (*AstStructLiteral)arg;
        struct_literal_init(ctx, lit.struct_def, lit.values_vec, temp_addr);
    } else {
        if (emit_struct_call_sret_by_kind(ctx, arg_kind, arg, temp_addr) == 0) {
            var src_addr: u64 = lvalue_addr(ctx, arg);
            if (src_addr == 0) { return 0; }
            struct_copy(ctx, temp_addr, src_addr, struct_size);
        }
    }
    arg_regs.push(temp_addr);
    return 0;
}

func append_call_arg(ctx: *BuilderCtx, arg_regs: *Vec<u64>, arg: u64) -> u64 {
    var arg_kind: u64 = ast_kind(arg);

    if (append_call_arg_stack_ctor(ctx, arg_regs, arg) != 0) {
        return 0;
    }

    if (append_call_arg_struct_literal(ctx, arg_regs, arg) != 0) {
        return 0;
    }

    if (append_call_arg_call_struct_fast(ctx, arg_regs, arg) != 0) {
        return 0;
    }

    var ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)arg, ctx.symtab);
    if ((ti == 0 || ti.type_kind != TYPE_STRUCT || ti.ptr_depth != 0) && arg_kind == AST_CALL) {
        ti = builder_direct_call_result_type(ctx, (*AstCall)arg);
    }
    if (ti != 0) {
        if (ti.type_kind == TYPE_SLICE && ti.ptr_depth == 0) {
            return append_slice_arg(ctx, arg_regs, arg);
        }
        if (ti.type_kind == TYPE_ARRAY && ti.ptr_depth == 0) {
            var addr_reg: u64 = lvalue_addr(ctx, arg);
            arg_regs.push(addr_reg);
            return 0;
        }
        if (ti.type_kind == TYPE_STRUCT && ti.ptr_depth == 0) {
            append_call_arg_struct_typed(ctx, arg_regs, arg, arg_kind, ti);
            return 0;
        }
    }
    var reg: u64 = build_expr(ctx, arg);
    arg_regs.push(reg);
    return 0;
}

func param_make_typeinfo(p: *Param) -> *TypeInfo {
    if (p == 0) { return 0; }
    var ti: *TypeInfo = typeinfo_new(p.type_kind, p.ptr_depth);
    p.apply_to_typeinfo(ti);
    typeinfo_resolve_struct_def(ti, p.type_kind, p.elem_type_kind, p.struct_name);
    return ti;
}

func append_call_arg_with_param(ctx: *BuilderCtx, arg_regs: *Vec<u64>, arg: *AstNode, expected: *Param) -> u64 {
    if (expected == 0) {
        return append_call_arg(ctx, arg_regs, arg);
    }

    if (!(expected.type_kind == TYPE_STRUCT && expected.ptr_depth > 0)) {
        return append_call_arg(ctx, arg_regs, arg);
    }

    var actual_ti: *TypeInfo = get_expr_type_with_symtab(arg, ctx.symtab);
    if (actual_ti == 0 || actual_ti.type_kind != TYPE_STRUCT || actual_ti.ptr_depth == 0) {
        return append_call_arg(ctx, arg_regs, arg);
    }

    var expected_ti: *TypeInfo = param_make_typeinfo(expected);
    if (expected_ti == 0) {
        return append_call_arg(ctx, arg_regs, arg);
    }

    var src_name: []u8 = actual_ti.struct_name;
    var src_resolved: *NameInfo = resolve_name(src_name);
    if (src_resolved != 0) {
        src_name = slice(src_resolved.ptr, src_resolved.len);
    }

    var expected_name: []u8 = expected_ti.struct_name;
    var expected_resolved: *NameInfo = resolve_name(expected_name);
    if (expected_resolved != 0) {
        expected_name = slice(expected_resolved.ptr, expected_resolved.len);
    }

    var reg: u64 = build_expr(ctx, arg);
    if (actual_ti.is_tagged == 1) {
        reg = mask_tagged_ptr(ctx, reg);
    }

    if (str_eq(src_name, expected_name) != 0) {
        arg_regs.push(reg);
        return 0;
    }

    var src_def: *AstStructDef = get_struct_def(src_name);
    if (src_def == 0 && (u8_slice_ptr(src_name) != u8_slice_ptr(actual_ti.struct_name) || u8_slice_len(src_name) != u8_slice_len(actual_ti.struct_name))) {
        src_def = get_struct_def(actual_ti.struct_name);
    }
    if (src_def != 0) {
        var up_offset: u64 = 0;
        var up_def: *AstStructDef = 0;
        var found_upcast: u64 = typeinfo_find_parent_offset(src_def, expected_name, &up_offset, &up_def);
        if (found_upcast == 0 && (u8_slice_ptr(expected_name) != u8_slice_ptr(expected_ti.struct_name) || u8_slice_len(expected_name) != u8_slice_len(expected_ti.struct_name))) {
            found_upcast = typeinfo_find_parent_offset(src_def, expected_ti.struct_name, &up_offset, &up_def);
        }
        if (found_upcast != 0) {
            reg = cast_adjust_add(ctx, reg, up_offset);
            arg_regs.push(reg);
            return 0;
        }
    }

    return append_call_arg(ctx, arg_regs, arg);
}

func slice_regs(ctx: *BuilderCtx, expr: u64) -> *SliceRegs {
    var info: *SliceRegs = new SliceRegs{};
    var k: u64 = ast_kind(expr);
    if (k == AST_SLICE) {
        var s: *AstSlice = (*AstSlice)expr;
        var ptr_reg: u64 = 0;
        var ptr_kind: u64 = ast_kind(s.ptr_expr);
        if (ptr_kind == AST_IDENT) {
            var ti: *TypeInfo = get_expr_type_with_symtab(s.ptr_expr, ctx.symtab);
            if (ti != 0) {
                if (ti.ptr_depth == 0) {
                    if (ti.type_kind == TYPE_ARRAY || ti.array_len != 0) {
                        ptr_reg = lvalue_addr(ctx, s.ptr_expr);
                    }
                }
            }
        }
        if (ptr_reg == 0) {
            ptr_reg = build_expr(ctx, s.ptr_expr);
        }
        var len_reg: u64 = build_expr(ctx, s.len_expr);
        info.ptr_reg = ptr_reg;
        info.len_reg = len_reg;
        return info;
    }

    var addr_reg: u64 = lvalue_addr(ctx, expr);
    var ptr_reg2: u64 = load_by_size(ctx, addr_reg, 8);
    var off_reg: u64 = build_const(ctx, 8);
    var addr2: u64 = new_reg(ctx);
    var add_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, addr2, operand_reg(addr_reg), operand_reg(off_reg));
    append_inst(ctx.cur_block, add_ptr);
    var len_reg2: u64 = load_by_size(ctx, addr2, 8);
    info.ptr_reg = ptr_reg2;
    info.len_reg = len_reg2;
    return info;
}

func struct_literal_init_raw_values(ctx: *BuilderCtx, values: *Vec<*AstNode>, base_addr: u64) -> u64 {
    var num_values: u64 = values.len();
    var field_offset: u64 = 0;
    for (var i: u64 = 0; i < num_values; i++) {
        var addr_reg: u64 = try_addr_with_offset(ctx, base_addr, field_offset);
        var value: *AstNode = values.get(i);
        var val_reg: u64 = build_expr(ctx, value);
        store_by_size(ctx, addr_reg, val_reg, 8);
        field_offset = field_offset + 8;
    }
    return 0;
}

func struct_literal_parent_total_size(struct_def: *AstStructDef) -> u64 {
    var parent_total: u64 = 0;
    if (struct_def.parents_vec == 0) { return 0; }
    var parents: *Vec<*ParentDesc> = struct_def.parents_vec;
    var pn: u64 = parents.len();
    for (var pi: u64 = 0; pi < pn; pi++) {
        var parent_desc: *ParentDesc = parents.get(pi);
        var parent_def: *AstStructDef = parent_desc.struct_def;
        if (parent_def == 0) {
            parent_def = get_struct_def(parent_desc.name);
            if (parent_def == 0) {
                emit("[ERROR] Parent struct not found\n");
                diag_error("SSA build error");
            }
            parent_desc.struct_def = parent_def;
        }
        parent_total = parent_total + struct_size_from_def(parent_def);
    }
    return parent_total;
}

func struct_literal_store_field_value(ctx: *BuilderCtx, field: *FieldDesc, value: *AstNode, addr_reg: u64) -> u64 {
    if (ast_kind(value) == AST_STRUCT_LITERAL) {
        var lit: *AstStructLiteral = (*AstStructLiteral)value;
        var lit_def: *AstStructDef = lit.struct_def;
        if (lit_def == 0 && field.type_kind == TYPE_STRUCT) {
            lit_def = get_struct_def(field.struct_name);
        }
        struct_literal_init(ctx, lit_def, lit.values_vec, addr_reg);
        return 0;
    }
    if (field.type_kind == TYPE_SLICE && field.ptr_depth == 0) {
        var slice_regs: *SliceRegs = slice_regs(ctx, value);
        store_by_size(ctx, addr_reg, slice_regs.ptr_reg, 8);
        var addr2: u64 = try_addr_with_offset(ctx, addr_reg, 8);
        store_by_size(ctx, addr2, slice_regs.len_reg, 8);
        return 0;
    }
    var val_reg: u64 = build_expr(ctx, value);
    var store_size: u64 = layout_field_sizeof(field);
    if (store_size > 8) { store_size = 8; }
    store_by_size(ctx, addr_reg, val_reg, store_size);
    return 0;
}

func struct_literal_init(ctx: *BuilderCtx, struct_def: *AstStructDef, values: *Vec<*AstNode>, base_addr: u64) -> u64 {
    if (values == 0) { return 0; }
    if (struct_def == 0) {
        return struct_literal_init_raw_values(ctx, values, base_addr);
    }
    var sd: *AstStructDef = struct_def;
    var fields: *Vec<*FieldDesc> = sd.fields_vec;
    if (fields == 0) { return 0; }
    var parent_total: u64 = struct_literal_parent_total_size(sd);

    var num_values: u64 = values.len();
    var num_fields: u64 = fields.len();
    var field_offset: u64 = parent_total;
    var value_index: u64 = 0;

    for (var fi: u64 = 0; fi < num_fields && value_index < num_values; fi++) {
        var field: *FieldDesc = fields.get(fi);
        var field_size: u64 = layout_field_sizeof(field);
        if (trait_is_vptr_field_name(field.name) != 0) {
            field_offset = field_offset + field_size;
            continue;
        }

        var addr_reg: u64 = try_addr_with_offset(ctx, base_addr, field_offset);
        var value: *AstNode = values.get(value_index);
        struct_literal_store_field_value(ctx, field, value, addr_reg);

        field_offset = field_offset + field_size;
        value_index = value_index + 1;
    }

    return 0;
}

func store_slice_regs(ctx: *BuilderCtx, base_addr: u64, slice_info: *SliceRegs) -> u64 {
    if (base_addr == 0 || slice_info == 0) { return 0; }
    var regs: *SliceRegs = slice_info;
    var ptr_reg: u64 = regs.ptr_reg;
    var len_reg: u64 = regs.len_reg;
    store_by_size(ctx, base_addr, ptr_reg, 8);
    var off_reg: u64 = build_const(ctx, 8);
    var addr2: u64 = new_reg(ctx);
    var add_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, addr2, operand_reg(base_addr), operand_reg(off_reg));
    append_inst(ctx.cur_block, add_ptr);
    store_by_size(ctx, addr2, len_reg, 8);
    return 0;
}

func assign_struct_literal_to_addr(ctx: *BuilderCtx, lit: *AstStructLiteral, base_addr: u64) -> u64 {
    if (lit == 0 || base_addr == 0) { return 0; }
    struct_literal_init(ctx, lit.struct_def, lit.values_vec, base_addr);
    return 0;
}

func assign_stack_ctor_to_addr(ctx: *BuilderCtx, sc: *AstStackCtor, base_addr: u64) -> u64 {
    if (sc == 0 || base_addr == 0) { return 0; }
    stack_ctor_init_at_addr(ctx, sc, base_addr);
    return 0;
}

func assign_slice_to_addr(ctx: *BuilderCtx, value: u64, base_addr: u64) -> u64 {
    if (base_addr == 0) { return 0; }
    var value_kind: u64 = ast_kind(value);
    if (value_kind == AST_CALL) {
        emit_call_slice_store(ctx, (*AstCall)value, base_addr);
        return 0;
    }
    if (value_kind == AST_METHOD_CALL) {
        emit_method_call_slice_store(ctx, (*AstMethodCall)value, base_addr);
        return 0;
    }
    if (value_kind == AST_CALL_PTR) {
        emit_call_ptr_slice_store(ctx, (*AstCallPtr)value, base_addr);
        return 0;
    }
    var slice_info: *SliceRegs = slice_regs(ctx, value);
    store_slice_regs(ctx, base_addr, slice_info);
    return 0;
}

func resolve_symbol_name(name: []u8) -> *PtrLen {
    var resolved_ptr: u64 = name.ptr;
    var resolved_len: u64 = name.len;
    var resolved: *NameInfo = resolve_name(slice(name.ptr, name.len));
    if (resolved != 0) {
        resolved_ptr = resolved.ptr;
        resolved_len = resolved.len;
    }
    return new PtrLen{resolved_ptr, resolved_len};
}

func find_callable_func_any(raw: []u8, resolved: []u8) -> *AstFunc {
    var fn: *AstFunc = 0;
    if (resolved.ptr != 0 && resolved.len != 0) {
        fn = typeinfo_find_func(slice(resolved.ptr, resolved.len));
        if (fn == 0) { fn = sym_get_func(slice(resolved.ptr, resolved.len)); }
        if (fn == 0) { fn = sym_get_impl_method_func(slice(resolved.ptr, resolved.len)); }
    }
    if (fn == 0 && raw.ptr != 0 && raw.len != 0) {
        fn = typeinfo_find_func(slice(raw.ptr, raw.len));
        if (fn == 0) { fn = sym_get_func(slice(raw.ptr, raw.len)); }
        if (fn == 0) { fn = sym_get_impl_method_func(slice(raw.ptr, raw.len)); }
    }
    return fn;
}

func builder_direct_call_result_type(ctx: *BuilderCtx, call: *AstCall) -> *TypeInfo {
    if (ctx == 0 || call == 0) { return 0; }
    var ret_ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)call, ctx.symtab);
    if (ret_ti != 0 && ret_ti.type_kind == TYPE_STRUCT && ret_ti.ptr_depth == 0) {
        return ret_ti;
    }

    var resolved_name: *PtrLen = resolve_symbol_name(call.name);
    var fn_call: *AstFunc = find_callable_func_any(call.name, slice(resolved_name.ptr, resolved_name.len));
    if (fn_call != 0) {
        return typeinfo_from_func_ret(fn_call, 0);
    }
    return ret_ti;
}

func call_arg_count(args: *Vec<u64>) -> u64 {
    if (args == 0) { return 0; }
    return args.len();
}

func append_call_args(ctx: *BuilderCtx, arg_regs: *Vec<u64>, args: *Vec<u64>) -> u64 {
    if (args == 0) { return 0; }
    var nargs: u64 = args.len();
    for (var i: u64 = 0; i < nargs; i++) {
        var arg: u64 = args.get(i);
        append_call_arg(ctx, arg_regs, arg);
    }
    return 0;
}

func append_call_args_nodes(ctx: *BuilderCtx, arg_regs: *Vec<u64>, args: *Vec<*AstNode>) -> u64 {
    if (args == 0) { return 0; }
    var nargs: u64 = args.len();
    for (var i: u64 = 0; i < nargs; i++) {
        var arg: u64 = args.get(i);
        append_call_arg(ctx, arg_regs, arg);
    }
    return 0;
}

func append_call_args_nodes_with_params(ctx: *BuilderCtx, arg_regs: *Vec<u64>, args: *Vec<*AstNode>, params: *Vec<*Param>, param_start: u64) -> u64 {
    if (args == 0) { return 0; }
    var nargs: u64 = args.len();
    for (var i: u64 = 0; i < nargs; i++) {
        var arg: *AstNode = args.get(i);
        var expected: *Param = 0;
        if (params != 0) {
            var param_index: u64 = param_start + i;
            if (param_index < params.len()) {
                expected = params.get(param_index);
            }
        }
        append_call_arg_with_param(ctx, arg_regs, arg, expected);
    }
    return 0;
}

func call_prefix_none() -> BuilderCallPrefix {
    var prefix: BuilderCallPrefix;
    prefix.count = 0;
    prefix.first = 0;
    prefix.second = 0;
    return prefix;
}

func call_prefix_one(v0: u64) -> BuilderCallPrefix {
    var prefix: BuilderCallPrefix;
    prefix.count = 1;
    prefix.first = v0;
    prefix.second = 0;
    return prefix;
}

func call_prefix_two(v0: u64, v1: u64) -> BuilderCallPrefix {
    var prefix: BuilderCallPrefix;
    prefix.count = 2;
    prefix.first = v0;
    prefix.second = v1;
    return prefix;
}

func call_prefix_append(arg_regs: *Vec<u64>, prefix: BuilderCallPrefix) -> u64 {
    if (prefix.count >= 1) { arg_regs.push(prefix.first); }
    if (prefix.count >= 2) { arg_regs.push(prefix.second); }
    return 0;
}

func make_call_arg_regs(ctx: *BuilderCtx, args: *Vec<u64>, prefix: BuilderCallPrefix) -> *Vec<u64> {
    var nargs: u64 = call_arg_count(args);
    var extra: u64 = prefix.count;
    if (extra > 2) { extra = 2; }
    var arg_regs: *Vec<u64> = new Vec<u64>{heap_alloc((nargs * 2 + extra) * sizeof(u64)), 0, (nargs * 2 + extra)};
    call_prefix_append(arg_regs, prefix);
    append_call_args(ctx, arg_regs, args);
    return arg_regs;
}

func make_call_arg_regs_nodes(ctx: *BuilderCtx, args: *Vec<*AstNode>, prefix: BuilderCallPrefix) -> *Vec<u64> {
    var nargs: u64 = 0;
    if (args != 0) { nargs = args.len(); }
    var extra: u64 = prefix.count;
    if (extra > 2) { extra = 2; }
    var arg_regs: *Vec<u64> = new Vec<u64>{heap_alloc((nargs * 2 + extra) * sizeof(u64)), 0, (nargs * 2 + extra)};
    call_prefix_append(arg_regs, prefix);
    append_call_args_nodes(ctx, arg_regs, args);
    return arg_regs;
}

func make_args1(v0: u64) -> *Vec<u64> {
    var args: *Vec<u64> = new Vec<u64>{heap_alloc((1) * sizeof(u64)), 0, (1)};
    args.push(v0);
    return args;
}

func make_args2(v0: u64, v1: u64) -> *Vec<u64> {
    var args: *Vec<u64> = new Vec<u64>{heap_alloc((2) * sizeof(u64)), 0, (2)};
    args.push(v0);
    args.push(v1);
    return args;
}

func make_args3(v0: u64, v1: u64, v2: u64) -> *Vec<u64> {
    var args: *Vec<u64> = new Vec<u64>{heap_alloc((3) * sizeof(u64)), 0, (3)};
    args.push(v0);
    args.push(v1);
    args.push(v2);
    return args;
}

func call_ret_meta(ctx: *BuilderCtx, node: u64, default_type: u64, default_ptr_depth: u64) -> BuilderCallRetMeta {
    var meta: BuilderCallRetMeta;
    meta.ret_type = default_type;
    meta.ret_ptr_depth = default_ptr_depth;
    meta.ret_struct_size = 0;
    var ret_ti: *TypeInfo = 0;
    if (node != 0 && ast_kind(node) == AST_CALL) {
        ret_ti = builder_direct_call_result_type(ctx, (*AstCall)node);
    } else {
        ret_ti = get_expr_type_with_symtab((*AstNode)node, ctx.symtab);
    }
    if (ret_ti == 0) { return meta; }
    meta.ret_type = ret_ti.type_kind;
    meta.ret_ptr_depth = ret_ti.ptr_depth;
    if (meta.ret_type == TYPE_STRUCT && meta.ret_ptr_depth == 0) {
        meta.ret_struct_size = layout_type_sizeof(TYPE_STRUCT, 0, ret_ti.struct_name);
    }
    return meta;
}

func emit_call(ctx: *BuilderCtx, call: *AstCall, dst: u64, extra_dst: u64) -> u64 {
    var name: []u8 = call.name;
    if (sym_func_exists(name) == 0) {
        var callee: *AstNode = ast_ident(name);
        var cp: *AstCallPtr = ast_call_ptr(callee, call.args_vec);
        return emit_call_ptr(ctx, cp, dst, extra_dst);
    }
    var resolved_name: *PtrLen = resolve_symbol_name(name);

    var fn_call: *AstFunc = find_callable_func_any(name, slice(resolved_name.ptr, resolved_name.len));
    var args: *Vec<*AstNode> = call.args_vec;
    var params: *Vec<*Param> = 0;
    if (fn_call != 0) { params = fn_call.params_vec; }
    var nargs: u64 = 0;
    if (args != 0) { nargs = args.len(); }
    var arg_regs: *Vec<u64> = new Vec<u64>{heap_alloc((nargs * 2) * sizeof(u64)), 0, (nargs * 2)};
    append_call_args_nodes_with_params(ctx, arg_regs, args, params, 0);

    var ret_meta: BuilderCallRetMeta = call_ret_meta(ctx, (u64)call, TYPE_I64, 0);
    var info: *SSACallInfo = make_call_info(slice(resolved_name.ptr, resolved_name.len), arg_regs, ret_meta.ret_type, ret_meta.ret_ptr_depth, ret_meta.ret_struct_size);

    var extra_opr: u64 = 0;
    if (extra_dst != 0) { extra_opr = operand_reg(extra_dst); }
    var call_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_CALL, dst, operand_const((u64)info), extra_opr);
    append_inst(ctx.cur_block, call_ptr);
    return dst;
}

func emit_call_sret_value(ctx: *BuilderCtx, call: *AstCall, addr_reg: u64) -> u64 {
    if (addr_reg == 0) { return 0; }
    var name: []u8 = call.name;
    if (sym_func_exists(name) == 0) {
        var callee: *AstNode = ast_ident(name);
        var cp: *AstCallPtr = ast_call_ptr(callee, call.args_vec);
        return emit_call_ptr_sret(ctx, cp, addr_reg);
    }
    var resolved_name: *PtrLen = resolve_symbol_name(name);

    var fn_call: *AstFunc = find_callable_func_any(name, slice(resolved_name.ptr, resolved_name.len));

    var args: *Vec<*AstNode> = call.args_vec;
    var params: *Vec<*Param> = 0;
    if (fn_call != 0) { params = fn_call.params_vec; }
    var nargs: u64 = 0;
    if (args != 0) { nargs = args.len(); }
    var arg_regs: *Vec<u64> = new Vec<u64>{heap_alloc((nargs * 2 + 1) * sizeof(u64)), 0, (nargs * 2 + 1)};
    arg_regs.push(addr_reg);
    append_call_args_nodes_with_params(ctx, arg_regs, args, params, 0);

    var ret_meta: BuilderCallRetMeta = call_ret_meta(ctx, (u64)call, TYPE_STRUCT, 0);
    var info: *SSACallInfo = make_call_info(slice(resolved_name.ptr, resolved_name.len), arg_regs, ret_meta.ret_type, ret_meta.ret_ptr_depth, ret_meta.ret_struct_size);
    var call_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_CALL, 0, operand_const((u64)info), 0);
    append_inst(ctx.cur_block, call_ptr);
    return 0;
}

func emit_call_slice_store(ctx: *BuilderCtx, call: *AstCall, addr_reg: u64) -> u64 {
    var name: []u8 = call.name;
    if (sym_func_exists(name) == 0) {
        var callee: *AstNode = ast_ident(name);
        var cp: *AstCallPtr = ast_call_ptr(callee, call.args_vec);
        return emit_call_ptr_slice_store(ctx, cp, addr_reg);
    }
    var resolved_name: *PtrLen = resolve_symbol_name(name);

    var fn_call: *AstFunc = find_callable_func_any(name, slice(resolved_name.ptr, resolved_name.len));

    var args: *Vec<*AstNode> = call.args_vec;
    var params: *Vec<*Param> = 0;
    if (fn_call != 0) { params = fn_call.params_vec; }
    var nargs: u64 = 0;
    if (args != 0) { nargs = args.len(); }
    var arg_regs: *Vec<u64> = new Vec<u64>{heap_alloc((nargs * 2) * sizeof(u64)), 0, (nargs * 2)};
    append_call_args_nodes_with_params(ctx, arg_regs, args, params, 0);

    var ret_meta: BuilderCallRetMeta = call_ret_meta(ctx, (u64)call, TYPE_I64, 0);
    var info: *SSACallSliceStoreInfo = make_call_slice_store_info(0, slice(resolved_name.ptr, resolved_name.len), 0, arg_regs, ret_meta.ret_type, ret_meta.ret_ptr_depth);
    var call_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_CALL_SLICE_STORE, 0, operand_const((u64)info), operand_reg(addr_reg));
    append_inst(ctx.cur_block, call_ptr);
    return 0;
}

func builder_method_owner_from_typeinfo(ti: *TypeInfo) -> *PtrLen {
    if (ti == 0 || ti.type_kind != TYPE_STRUCT) { return 0; }
    var owner_ptr: u64 = u8_slice_ptr(ti.struct_name);
    var owner_len: u64 = u8_slice_len(ti.struct_name);
    if ((owner_ptr == 0 || owner_len == 0) && ti.struct_def != 0) {
        owner_ptr = u8_slice_ptr(ti.struct_def.name);
        owner_len = u8_slice_len(ti.struct_def.name);
    }
    if (owner_ptr == 0 || owner_len == 0) { return 0; }
    return new PtrLen{owner_ptr, owner_len};
}

func builder_infer_overloaded_receiver_type(receiver: *AstNode, symtab: *Symtab) -> *TypeInfo {
    if (receiver == 0) { return 0; }
    var recv_ti: *TypeInfo = get_expr_type_with_symtab(receiver, symtab);
    if (recv_ti != 0 && recv_ti.type_kind == TYPE_STRUCT) {
        return recv_ti;
    }

    var recv_kind: u64 = ast_kind(receiver);
    if (recv_kind == AST_BINARY) {
        var bin: *AstBinary = (*AstBinary)receiver;
        var left_ti: *TypeInfo = builder_infer_overloaded_receiver_type(bin.left, symtab);
        if (left_ti == 0) { left_ti = get_expr_type_with_symtab(bin.left, symtab); }
        if (bin.op == TOKEN_PLUS || bin.op == TOKEN_MINUS || bin.op == TOKEN_STAR || bin.op == TOKEN_SLASH ||
            bin.op == TOKEN_PERCENT || bin.op == TOKEN_LSHIFT || bin.op == TOKEN_RSHIFT ||
            bin.op == TOKEN_AMPERSAND || bin.op == TOKEN_PIPE || bin.op == TOKEN_CARET) {
            if (left_ti != 0 && left_ti.ptr_depth == 0 && left_ti.type_kind == TYPE_STRUCT) {
                return typeinfo_clone(left_ti);
            }
        }
        return 0;
    }

    if (recv_kind == AST_UNARY) {
        // Unary operator overloads are allowed to return non-struct values
        // (for example `operator -(self: *NumOp38) -> i64`). Propagating the
        // operand's struct type here makes enclosing binary expressions such as
        // `-b != -4` incorrectly try overload dispatch on `!=`, and the failed
        // lookup later collapses into `r0` branches in SSA. Unary dispatch
        // should use the operand type when lowering the unary node itself, but
        // callers must not assume the unary result keeps the receiver's struct
        // type unless normal typeinfo already says so.
        return 0;
    }

    return 0;
}

func builder_make_empty_args_vec() -> *Vec<*AstNode> {
    return new Vec<*AstNode>{heap_alloc((0) * sizeof(*AstNode)), 0, (0)};
}

func builder_arg_type_for_method_resolution(arg: *AstNode, symtab: *Symtab) -> *TypeInfo {
    if (arg == 0) { return 0; }
    var ti: *TypeInfo = get_expr_type_with_symtab(arg, symtab);
    var inferred_ti: *TypeInfo = builder_infer_overloaded_receiver_type(arg, symtab);
    if (inferred_ti != 0 && inferred_ti.type_kind == TYPE_STRUCT && inferred_ti.ptr_depth == 0) {
        if (ti == 0) { return inferred_ti; }
        if (ti.type_kind != TYPE_STRUCT || ti.ptr_depth != 0) { return inferred_ti; }
    }
    return ti;
}

func builder_collect_arg_types_for_method_resolution(args: *Vec<*AstNode>, symtab: *Symtab) -> *Vec<*TypeInfo> {
    if (args == 0) { return new Vec<*TypeInfo>{heap_alloc((0) * sizeof(*TypeInfo)), 0, (0)}; }
    var n: u64 = args.len();
    var out: *Vec<*TypeInfo> = new Vec<*TypeInfo>{heap_alloc((n) * sizeof(*TypeInfo)), 0, (n)};
    for (var i: u64 = 0; i < n; i = i + 1) {
        out.push(builder_arg_type_for_method_resolution(args.get(i), symtab));
    }
    return out;
}

func builder_make_overloaded_receiver_expr(receiver: *AstNode, symtab: *Symtab) -> *AstNode {
    if (receiver == 0) { return 0; }
    var recv_kind: u64 = ast_kind(receiver);
    if (recv_kind == AST_BINARY) {
        var bin: *AstBinary = (*AstBinary)receiver;
        var left_ti: *TypeInfo = builder_infer_overloaded_receiver_type(bin.left, symtab);
        if (left_ti == 0) { left_ti = get_expr_type_with_symtab(bin.left, symtab); }
        if (left_ti == 0 || left_ti.ptr_depth != 0 || left_ti.type_kind != TYPE_STRUCT) { return receiver; }
        var method_name: *NameInfo = compiler_operator_binary_name(bin.op);
        if (method_name == 0) { return receiver; }
        var args: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((1) * sizeof(*AstNode)), 0, (1)};
        args.push(bin.right);
        var lhs_expr: *AstNode = builder_make_overloaded_receiver_expr(bin.left, symtab);
        return (*AstNode)ast_method_call(lhs_expr, slice(method_name.ptr, method_name.len), args);
    }

    if (recv_kind == AST_UNARY) {
        var un: *AstUnary = (*AstUnary)receiver;
        var operand_ti: *TypeInfo = builder_infer_overloaded_receiver_type(un.operand, symtab);
        if (operand_ti == 0) { operand_ti = get_expr_type_with_symtab(un.operand, symtab); }
        if (operand_ti == 0 || operand_ti.ptr_depth != 0 || operand_ti.type_kind != TYPE_STRUCT) { return receiver; }
        var method_name2: *NameInfo = 0;
        if (un.op == TOKEN_MINUS) {
            method_name2 = compiler_operator_binary_name(un.op);
        } else {
            method_name2 = compiler_operator_unary_name(un.op);
        }
        if (method_name2 == 0) { return receiver; }
        var operand_expr: *AstNode = builder_make_overloaded_receiver_expr(un.operand, symtab);
        if (un.op == TOKEN_MINUS) {
            var owner_ptr: u64 = u8_slice_ptr(operand_ti.struct_name);
            var owner_len: u64 = u8_slice_len(operand_ti.struct_name);
            if (operand_ti.struct_def != 0) {
                owner_ptr = u8_slice_ptr(operand_ti.struct_def.name);
                owner_len = u8_slice_len(operand_ti.struct_def.name);
            }
            if (owner_ptr != 0 && owner_len != 0) {
                var direct_name: *NameInfo = sym_build_method_name_with_overload_suffix(slice(owner_ptr, owner_len), slice(method_name2.ptr, method_name2.len), slice("__OL", 4));
                var call_args: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((1) * sizeof(*AstNode)), 0, (1)};
                call_args.push((*AstNode)ast_addr_of(operand_expr));
                return (*AstNode)ast_call(slice(direct_name.ptr, direct_name.len), call_args);
            }
        }
        return (*AstNode)ast_method_call(operand_expr, slice(method_name2.ptr, method_name2.len), builder_make_empty_args_vec());
    }

    return receiver;
}

func builder_binary_expr_is_number(node: *AstNode, ti: *TypeInfo, symtab: *Symtab) -> u64 {
    if (ti == 0) { ti = get_expr_type_with_symtab(node, symtab); }
    if (ti == 0 || ti.type_kind != TYPE_STRUCT || ti.ptr_depth != 0) { return 0; }
    if (str_eq(ti.struct_name, slice("Number", str_len("Number"))) != 0) { return 1; }
    if (str_eq(ti.struct_name, slice("std_number__Number", str_len("std_number__Number"))) != 0) { return 1; }
    if (ti.struct_def != 0) {
        if (str_eq(ti.struct_def.name, slice("Number", str_len("Number"))) != 0) { return 1; }
        if (str_eq(ti.struct_def.name, slice("std_number__Number", str_len("std_number__Number"))) != 0) { return 1; }
    }
    return 0;
}

func builder_binary_expr_is_integer(ti: *TypeInfo) -> u64 {
    if (ti == 0 || ti.ptr_depth != 0) { return 0; }
    return cast_is_int_scalar(ti.type_kind);
}

func builder_number_expr_addr(ctx: *BuilderCtx, node: *AstNode, ti: *TypeInfo) -> u64 {
    if (builder_binary_expr_is_number(node, ti, ctx.symtab) == 0) { return 0; }
    var addr: u64 = lvalue_addr(ctx, node);
    if (addr != 0) { return addr; }
    var size: u64 = 8;
    var temp_offset: u64 = symtab_add(ctx.symtab, slice(0, 0), TYPE_STRUCT, 0, size);
    var temp_addr: u64 = new_lea_local(ctx, temp_offset);
    if (try_materialize_operand(ctx, node, size, temp_addr) == 0) { return 0; }
    return temp_addr;
}

func builder_box_i64_to_number_addr(ctx: *BuilderCtx, value_reg: u64) -> u64 {
    var call_args: *Vec<u64> = make_args1(value_reg);
    var boxed_reg: u64 = new_reg(ctx);
    emit_call_name_raw(ctx, slice("std_number__Number_from_i64", str_len("std_number__Number_from_i64")), call_args, boxed_reg, 0, TYPE_STRUCT, 0, 0);
    var temp_offset: u64 = symtab_add(ctx.symtab, slice(0, 0), TYPE_STRUCT, 0, 8);
    var temp_addr: u64 = new_lea_local(ctx, temp_offset);
    store_by_size(ctx, temp_addr, boxed_reg, 8);
    return temp_addr;
}

func builder_emit_number_cmp_bool(ctx: *BuilderCtx, op: u64, left_addr: u64, right_addr: u64) -> u64 {
    if (left_addr == 0 || right_addr == 0) { return build_const(ctx, 0); }
    var cmp_args: *Vec<u64> = make_args2(left_addr, right_addr);
    var cmp_reg: u64 = new_reg(ctx);
    emit_call_name_raw(ctx, slice("std_number__number_cmp_ptr", 26), cmp_args, cmp_reg, 0, TYPE_I64, 0, 0);
    var zero_reg: u64 = build_const(ctx, 0);
    var cmp_op: u64 = binop_to_ssa_op(op, 1);
    if (cmp_op == SSA_OP_NOP) { return cmp_reg; }
    var out_reg: u64 = new_reg(ctx);
    var cmp_inst: *SSAInstruction = create_inst(ctx.ssa_ctx, cmp_op, out_reg, operand_reg(cmp_reg), operand_reg(zero_reg));
    append_inst(ctx.cur_block, cmp_inst);
    return out_reg;
}

func builder_try_emit_number_binary(ctx: *BuilderCtx, bin: *AstBinary, left_ti: *TypeInfo, right_ti: *TypeInfo) -> u64 {
    var left_is_number: u64 = builder_binary_expr_is_number(bin.left, left_ti, ctx.symtab);
    var right_is_number: u64 = builder_binary_expr_is_number(bin.right, right_ti, ctx.symtab);
    if (left_is_number == 0 && right_is_number == 0) { return 0; }
    if (bin.op != TOKEN_EQEQ && bin.op != TOKEN_BANGEQ &&
        bin.op != TOKEN_LT && bin.op != TOKEN_GT &&
        bin.op != TOKEN_LTEQ && bin.op != TOKEN_GTEQ) {
        return 0;
    }

    if (left_is_number != 0 && right_is_number != 0) {
        var left_addr: u64 = builder_number_expr_addr(ctx, bin.left, left_ti);
        var right_addr: u64 = builder_number_expr_addr(ctx, bin.right, right_ti);
        if (left_addr != 0 && right_addr != 0) {
            return builder_emit_number_cmp_bool(ctx, bin.op, left_addr, right_addr);
        }
    }

    if (left_is_number != 0 && builder_binary_expr_is_integer(right_ti) != 0) {
        var left_addr2: u64 = builder_number_expr_addr(ctx, bin.left, left_ti);
        if (left_addr2 != 0) {
            var right_reg: u64 = build_expr(ctx, bin.right);
            var right_addr2: u64 = builder_box_i64_to_number_addr(ctx, right_reg);
            return builder_emit_number_cmp_bool(ctx, bin.op, left_addr2, right_addr2);
        }
    }

    if (right_is_number != 0 && builder_binary_expr_is_integer(left_ti) != 0) {
        var right_addr3: u64 = builder_number_expr_addr(ctx, bin.right, right_ti);
        if (right_addr3 != 0) {
            var left_reg: u64 = build_expr(ctx, bin.left);
            var left_addr3: u64 = builder_box_i64_to_number_addr(ctx, left_reg);
            return builder_emit_number_cmp_bool(ctx, bin.op, left_addr3, right_addr3);
        }
    }

    return 0;
}

func method_prepare_call(ctx: *BuilderCtx, mc: *AstMethodCall) -> BuilderPreparedMethodCall {
    var prepared: BuilderPreparedMethodCall;
    prepared.ok = 0;
    prepared.resolved = slice(0, 0);
    prepared.recv_addr = 0;
    prepared.resolved_fn = 0;
    prepared.use_call_ptr = 0;
    prepared.call_ptr_callee = 0;
    prepared.use_virtual_dispatch = 0;
    prepared.virtual_recv_offset = 0;
    prepared.virtual_method_index = 0;
    var receiver: u64 = mc.receiver;
    var recv_ti: *TypeInfo = get_expr_type_with_symtab(receiver, ctx.symtab);
    if ((recv_ti == 0 || recv_ti.type_kind != TYPE_STRUCT) && receiver != 0) {
        var overload_recv_ti: *TypeInfo = builder_infer_overloaded_receiver_type(receiver, ctx.symtab);
        if (overload_recv_ti != 0) {
            recv_ti = overload_recv_ti;
        }
    }
    if (recv_ti == 0) { return prepared; }
    if (recv_ti.ptr_depth > 0) {
        prepared.recv_addr = build_expr(ctx, receiver);
        if (recv_ti.is_tagged == 1) {
            prepared.recv_addr = mask_tagged_ptr(ctx, prepared.recv_addr);
        }
    } else {
        prepared.recv_addr = lvalue_addr(ctx, receiver);
        if (prepared.recv_addr == 0 && recv_ti.type_kind == TYPE_STRUCT) {
            var recv_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, recv_ti.struct_name);
            if (recv_size == 0 && recv_ti.struct_def != 0) {
                recv_size = struct_size_from_def(recv_ti.struct_def);
            }
            if (recv_size != 0) {
                var temp_offset: u64 = symtab_add(ctx.symtab, slice(0, 0), TYPE_STRUCT, 0, recv_size);
                var temp_addr: u64 = new_lea_local(ctx, temp_offset);
                var materialized_recv: u64 = builder_make_overloaded_receiver_expr(receiver, ctx.symtab);
                if (try_materialize_operand(ctx, materialized_recv, recv_size, temp_addr) != 0 ||
                    try_materialize_operand(ctx, receiver, recv_size, temp_addr) != 0) {
                    prepared.recv_addr = temp_addr;
                }
            }
        }
    }
    if (recv_ti.type_kind == TYPE_TRAIT || sym_is_trait_name(recv_ti.struct_name) != 0) {
        var trait_method_index: u64 = trait_find_trait_method_index(recv_ti.struct_name, mc.method);
        if (is_not_found_u64(trait_method_index) != 0) {
            diag_emit_error_tag("ssa", "method-call", "trait method not found");
            diag_emit_labelled_member("target: ", recv_ti.struct_name, mc.method);
            diag_error("SSA build error");
            return prepared;
        }
        prepared.ok = 1;
        prepared.use_virtual_dispatch = 1;
        prepared.virtual_recv_offset = 0;
        prepared.virtual_method_index = trait_method_index;
        return prepared;
    }
    if (recv_ti.type_kind != TYPE_STRUCT) { return prepared; }
    if (call_has_named_args(mc.arg_names_vec) != 0) {
        var args_named: *Vec<*AstNode> = mc.args_vec;
        var nargs_named: u64 = 0;
        if (args_named != 0) { nargs_named = args_named.len(); }
        var fn_sig_named: *AstFunc = 0;
        if (recv_ti != 0 && (recv_ti.type_kind == TYPE_TRAIT || sym_is_trait_name(recv_ti.struct_name) != 0)) {
            var trait_def_named: *TraitDef = sym_get_trait_def(recv_ti.struct_name);
            if (trait_def_named != 0 && trait_def_named.methods_vec != 0) {
                var method_index_named: u64 = trait_find_trait_method_index(recv_ti.struct_name, mc.method);
                if (is_not_found_u64(method_index_named) == 0 && method_index_named < trait_def_named.methods_vec.len()) {
                    var method_desc_named: *TraitMethod = trait_def_named.methods_vec.get(method_index_named);
                    if (method_desc_named != 0) { fn_sig_named = method_desc_named.sig; }
                }
            }
        } else {
            var owner_ptr_named: u64 = u8_slice_ptr(recv_ti.struct_name);
            var owner_len_named: u64 = u8_slice_len(recv_ti.struct_name);
            if ((owner_ptr_named == 0 || owner_len_named == 0) && recv_ti.struct_def != 0) {
                owner_ptr_named = u8_slice_ptr(recv_ti.struct_def.name);
                owner_len_named = u8_slice_len(recv_ti.struct_def.name);
            }
            if (owner_ptr_named != 0 && owner_len_named != 0) {
                var resolved_named: CompilerMethodResolveResult = sym_resolve_method_overload_with_count_fallback(slice(owner_ptr_named, owner_len_named), mc.method, 0, nargs_named);
                if (resolved_named.found != 0 && resolved_named.fn != 0) {
                    fn_sig_named = resolved_named.fn;
                } else {
                    var recv_def_named: *AstStructDef = recv_ti.struct_def;
                    if (recv_def_named == 0) {
                        recv_def_named = get_struct_def(slice(owner_ptr_named, owner_len_named));
                    }
                    if (recv_def_named != 0) {
                        fn_sig_named = find_method_func_in_hierarchy_with_arg_count(recv_def_named, mc.method, nargs_named);
                    }
                }
            }
        }
        if (fn_sig_named == 0) {
            diag_emit_error_tag("ssa", "method-call", "named arguments require a known method signature");
            diag_emit_labelled_member("target: ", recv_ti.struct_name, mc.method);
            diag_error("SSA build error");
            return prepared;
        }
        var params_start_named: u64 = sym_method_param_start_index(fn_sig_named);
        mc.args_vec = lower_normalize_call_args_for_params(mc.method, fn_sig_named.params_vec, params_start_named, mc.args_vec, mc.arg_names_vec);
        mc.arg_names_vec = 0;
    }
    var recv_owner_ptr: u64 = u8_slice_ptr(recv_ti.struct_name);
    var recv_owner_len: u64 = u8_slice_len(recv_ti.struct_name);
    if (recv_ti.struct_def != 0) {
        recv_owner_ptr = u8_slice_ptr(recv_ti.struct_def.name);
        recv_owner_len = u8_slice_len(recv_ti.struct_def.name);
    }
    var nargs: u64 = 0;
    if (mc.args_vec != 0) { nargs = mc.args_vec.len(); }
    var arg_types: *Vec<*TypeInfo> = builder_collect_arg_types_for_method_resolution(mc.args_vec, ctx.symtab);
    var resolved_method: CompilerMethodResolveResult = sym_resolve_method_overload_with_count_fallback(slice(recv_owner_ptr, recv_owner_len), mc.method, arg_types, nargs);
    var access_lookup: CompilerDeclLookup = find_method_decl_in_hierarchy_overload(slice(recv_owner_ptr, recv_owner_len), mc.method, arg_types, nargs);
    var resolved_name: *PtrLen = 0;
    var recv_def: *AstStructDef = recv_ti.struct_def;
    if (recv_def == 0 && u8_slice_ptr(recv_ti.struct_name) != 0 && u8_slice_len(recv_ti.struct_name) != 0) {
        recv_def = get_struct_def(recv_ti.struct_name);
    }
    var fallback_fn: *AstFunc = 0;
    if (recv_ti.ptr_depth > 0) {
        var virt_trait: *NameInfo = method_find_virtual_trait_name(recv_ti, slice(recv_owner_ptr, recv_owner_len), mc.method);
        if (virt_trait != 0) {
            var method_index_v: u64 = trait_find_trait_method_index(slice(virt_trait.ptr, virt_trait.len), mc.method);
            if (is_not_found_u64(method_index_v) != 0) {
                diag_emit_error_tag("ssa", "method-call", "virtual method not found");
                diag_emit_labelled_member("target: ", slice(recv_owner_ptr, recv_owner_len), mc.method);
                diag_error("SSA build error");
                return prepared;
            }
            var vptr_offset: u64 = method_find_virtual_vptr_offset(recv_ti, slice(virt_trait.ptr, virt_trait.len));
            if (is_not_found_u64(vptr_offset) != 0) {
                diag_emit_error_tag("ssa", "method-call", "virtual dispatch vptr not found");
                diag_emit_labelled_name("receiver: ", recv_ti.struct_name);
                diag_error("SSA build error");
                return prepared;
            }
            prepared.ok = 1;
            prepared.use_virtual_dispatch = 1;
            prepared.virtual_recv_offset = vptr_offset;
            prepared.virtual_method_index = method_index_v;
            return prepared;
        }
    }
    if (resolved_method.found != 0 && resolved_method.fn != 0) {
        if (sym_can_access_member(resolved_method.owner, resolved_method.access) == 0) {
            member_diag_access_denied(resolved_method.owner, mc.method, resolved_method.access, 1);
            return prepared;
        }
        resolved_name = resolve_symbol_name(resolved_method.fn.name);
        prepared.resolved_fn = resolved_method.fn;
    } else if (recv_def != 0) {
        fallback_fn = find_method_func_in_hierarchy_with_arg_count(recv_def, mc.method, nargs);
        if (fallback_fn != 0) {
            if (access_lookup.found != 0 && sym_can_access_member(access_lookup.owner, access_lookup.access) == 0) {
                member_diag_access_denied(access_lookup.owner, mc.method, access_lookup.access, 1);
                return prepared;
            }
            resolved_name = resolve_symbol_name(fallback_fn.name);
            prepared.resolved_fn = fallback_fn;
        }
    }

    if (resolved_name == 0 || resolved_name.ptr == 0 || resolved_name.len == 0) {
        if (recv_def != 0) {
            var field_desc: *FieldDesc = find_struct_field_desc_scoped(recv_def, slice(0, 0), mc.method);
            if (field_desc != 0 && field_desc.type_kind == TYPE_FUNC) {
                prepared.ok = 1;
                prepared.use_call_ptr = 1;
                prepared.call_ptr_callee = (*AstNode)ast_member_access((*AstNode)mc.receiver, mc.method);
                return prepared;
            }
        }

        var name_info: *NameInfo = build_method_name(slice(recv_owner_ptr, recv_owner_len), mc.method);
        resolved_name = resolve_symbol_name(slice(name_info.ptr, name_info.len));
        var resolved_fn: *AstFunc = 0;
        if (resolved_name != 0) {
            resolved_fn = typeinfo_find_func(slice(resolved_name.ptr, resolved_name.len));
            if (resolved_fn == 0) { resolved_fn = sym_get_func(slice(resolved_name.ptr, resolved_name.len)); }
            if (resolved_fn == 0) { resolved_fn = sym_get_impl_method_func(slice(resolved_name.ptr, resolved_name.len)); }
        }
        var direct_fn: *AstFunc = typeinfo_find_func(slice(name_info.ptr, name_info.len));
        if (direct_fn == 0) { direct_fn = sym_get_func(slice(name_info.ptr, name_info.len)); }
        if (direct_fn == 0) { direct_fn = sym_get_impl_method_func(slice(name_info.ptr, name_info.len)); }
        if (resolved_fn == 0 && direct_fn == 0) {
            diag_emit_error_tag("ssa", "method-call", "method not found");
            diag_emit_labelled_member("target: ", slice(recv_owner_ptr, recv_owner_len), mc.method);
            diag_error("SSA build error");
            return prepared;
        }
        if (resolved_name == 0 || resolved_name.ptr == 0 || resolved_name.len == 0) {
            resolved_name = new PtrLen{name_info.ptr, name_info.len};
        }
        if (resolved_fn != 0) {
            prepared.resolved_fn = resolved_fn;
        } else if (direct_fn != 0) {
            prepared.resolved_fn = direct_fn;
        }
    }
    prepared.ok = 1;
    prepared.resolved = slice(resolved_name.ptr, resolved_name.len);
    return prepared;
}

func virtual_dispatch_callee_reg(ctx: *BuilderCtx, recv_addr: u64, recv_offset: u64, method_index: u64) -> u64 {
    var vptr_addr: u64 = cast_adjust_add(ctx, recv_addr, recv_offset);
    var vtable_reg: u64 = load_by_size(ctx, vptr_addr, 8);
    if (method_index != 0) {
        var off_reg: u64 = build_const(ctx, method_index * 8);
        var slot_addr: u64 = new_reg(ctx);
        var add_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, slot_addr, operand_reg(vtable_reg), operand_reg(off_reg));
        append_inst(ctx.cur_block, add_ptr);
        vtable_reg = slot_addr;
    }
    return load_by_size(ctx, vtable_reg, 8);
}

func call_ptr_callee_reg(ctx: *BuilderCtx, callee: u64) -> u64 {
    if (ast_kind(callee) != AST_IDENT) {
        return build_expr(ctx, callee);
    }
    var idn: *AstIdent = (*AstIdent)callee;
    if (ctx != 0 && ctx.symtab != 0) {
        var off: u64 = symtab_find(ctx.symtab, idn.name);
        if (off != 0) {
            return build_expr(ctx, callee);
        }
    }
    if (sym_func_exists(idn.name) == 0) {
        return build_expr(ctx, callee);
    }
    var resolved_name: *PtrLen = resolve_symbol_name(idn.name);
    return new_lea_func(ctx, slice(resolved_name.ptr, resolved_name.len));
}

func emit_method_call_value(ctx: *BuilderCtx, mc: *AstMethodCall, dst: u64, extra_dst: u64) -> u64 {
    var prepared: BuilderPreparedMethodCall = method_prepare_call(ctx, mc);
    if (prepared.ok == 0) { return 0; }
    if (prepared.use_call_ptr != 0 && prepared.call_ptr_callee != 0) {
        var cp: *AstCallPtr = ast_call_ptr(prepared.call_ptr_callee, mc.args_vec);
        return emit_call_ptr(ctx, cp, dst, extra_dst);
    }

    if (prepared.use_virtual_dispatch != 0) {
        var recv_vptr_addr: u64 = cast_adjust_add(ctx, prepared.recv_addr, prepared.virtual_recv_offset);
        var args_v: *Vec<*AstNode> = mc.args_vec;
        var arg_regs_v: *Vec<u64> = make_call_arg_regs_nodes(ctx, args_v, call_prefix_one(recv_vptr_addr));
        var callee_reg_v: u64 = virtual_dispatch_callee_reg(ctx, prepared.recv_addr, prepared.virtual_recv_offset, prepared.virtual_method_index);
        var ret_meta_v: BuilderCallRetMeta = call_ret_meta(ctx, (u64)mc, TYPE_I64, 0);
        return emit_call_ptr_raw(ctx, callee_reg_v, arg_regs_v, dst, extra_dst, ret_meta_v.ret_type, ret_meta_v.ret_ptr_depth, ret_meta_v.ret_struct_size);
    }

    var args: *Vec<*AstNode> = mc.args_vec;
    var params: *Vec<*Param> = 0;
    if (prepared.resolved_fn != 0) { params = prepared.resolved_fn.params_vec; }
    var nargs: u64 = 0;
    if (args != 0) { nargs = args.len(); }
    var arg_regs: *Vec<u64> = new Vec<u64>{heap_alloc((nargs * 2 + 1) * sizeof(u64)), 0, (nargs * 2 + 1)};
    arg_regs.push(prepared.recv_addr);
    append_call_args_nodes_with_params(ctx, arg_regs, args, params, 1);

    var ret_meta: BuilderCallRetMeta = call_ret_meta(ctx, (u64)mc, TYPE_I64, 0);
    var info: *SSACallInfo = make_call_info(prepared.resolved, arg_regs, ret_meta.ret_type, ret_meta.ret_ptr_depth, ret_meta.ret_struct_size);

    var extra_opr2: u64 = 0;
    if (extra_dst != 0) { extra_opr2 = operand_reg(extra_dst); }
    var call_ptr2: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_CALL, dst, operand_const((u64)info), extra_opr2);
    append_inst(ctx.cur_block, call_ptr2);
    return dst;
}

func emit_method_call_sret(ctx: *BuilderCtx, mc: *AstMethodCall, addr_reg: u64) -> u64 {
    if (addr_reg == 0) { return 0; }
    var prepared: BuilderPreparedMethodCall = method_prepare_call(ctx, mc);
    if (prepared.ok == 0) { return 0; }
    if (prepared.use_call_ptr != 0 && prepared.call_ptr_callee != 0) {
        var cp: *AstCallPtr = ast_call_ptr(prepared.call_ptr_callee, mc.args_vec);
        return emit_call_ptr_sret(ctx, cp, addr_reg);
    }

    if (prepared.use_virtual_dispatch != 0) {
        var recv_vptr_addr: u64 = cast_adjust_add(ctx, prepared.recv_addr, prepared.virtual_recv_offset);
        var args_v: *Vec<*AstNode> = mc.args_vec;
        var arg_regs_v: *Vec<u64> = make_call_arg_regs_nodes(ctx, args_v, call_prefix_two(addr_reg, recv_vptr_addr));
        var callee_reg_v: u64 = virtual_dispatch_callee_reg(ctx, prepared.recv_addr, prepared.virtual_recv_offset, prepared.virtual_method_index);
        var ret_meta_v: BuilderCallRetMeta = call_ret_meta(ctx, (u64)mc, TYPE_STRUCT, 0);
        emit_call_ptr_raw(ctx, callee_reg_v, arg_regs_v, 0, 0, ret_meta_v.ret_type, ret_meta_v.ret_ptr_depth, ret_meta_v.ret_struct_size);
        return 0;
    }

    var args: *Vec<*AstNode> = mc.args_vec;
    var params: *Vec<*Param> = 0;
    if (prepared.resolved_fn != 0) { params = prepared.resolved_fn.params_vec; }
    var nargs: u64 = 0;
    if (args != 0) { nargs = args.len(); }
    var arg_regs: *Vec<u64> = new Vec<u64>{heap_alloc((nargs * 2 + 2) * sizeof(u64)), 0, (nargs * 2 + 2)};
    arg_regs.push(addr_reg);
    arg_regs.push(prepared.recv_addr);
    append_call_args_nodes_with_params(ctx, arg_regs, args, params, 1);

    var ret_meta: BuilderCallRetMeta = call_ret_meta(ctx, (u64)mc, TYPE_STRUCT, 0);
    var info: *SSACallInfo = make_call_info(prepared.resolved, arg_regs, ret_meta.ret_type, ret_meta.ret_ptr_depth, ret_meta.ret_struct_size);
    var call_ptr2: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_CALL, 0, operand_const((u64)info), 0);
    append_inst(ctx.cur_block, call_ptr2);
    return 0;
}

func emit_method_call_slice_store(ctx: *BuilderCtx, mc: *AstMethodCall, addr_reg: u64) -> u64 {
    var prepared: BuilderPreparedMethodCall = method_prepare_call(ctx, mc);
    if (prepared.ok == 0) { return 0; }
    if (prepared.use_call_ptr != 0 && prepared.call_ptr_callee != 0) {
        var cp: *AstCallPtr = ast_call_ptr(prepared.call_ptr_callee, mc.args_vec);
        return emit_call_ptr_slice_store(ctx, cp, addr_reg);
    }

    if (prepared.use_virtual_dispatch != 0) {
        var recv_vptr_addr: u64 = cast_adjust_add(ctx, prepared.recv_addr, prepared.virtual_recv_offset);
        var args_v: *Vec<*AstNode> = mc.args_vec;
        var arg_regs_v: *Vec<u64> = make_call_arg_regs_nodes(ctx, args_v, call_prefix_one(recv_vptr_addr));
        var callee_reg_v: u64 = virtual_dispatch_callee_reg(ctx, prepared.recv_addr, prepared.virtual_recv_offset, prepared.virtual_method_index);
        var ret_meta_v: BuilderCallRetMeta = call_ret_meta(ctx, (u64)mc, TYPE_I64, 0);
        var info_v: *SSACallSliceStoreInfo = make_call_slice_store_info(1, slice(0, 0), callee_reg_v, arg_regs_v, ret_meta_v.ret_type, ret_meta_v.ret_ptr_depth);
        var call_ptr_v: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_CALL_SLICE_STORE, 0, operand_const((u64)info_v), operand_reg(addr_reg));
        append_inst(ctx.cur_block, call_ptr_v);
        return 0;
    }

    var args: *Vec<*AstNode> = mc.args_vec;
    var params: *Vec<*Param> = 0;
    if (prepared.resolved_fn != 0) { params = prepared.resolved_fn.params_vec; }
    var nargs: u64 = 0;
    if (args != 0) { nargs = args.len(); }
    var arg_regs: *Vec<u64> = new Vec<u64>{heap_alloc((nargs * 2 + 1) * sizeof(u64)), 0, (nargs * 2 + 1)};
    arg_regs.push(prepared.recv_addr);
    append_call_args_nodes_with_params(ctx, arg_regs, args, params, 1);

    var ret_meta: BuilderCallRetMeta = call_ret_meta(ctx, (u64)mc, TYPE_I64, 0);
    var info: *SSACallSliceStoreInfo = make_call_slice_store_info(0, prepared.resolved, 0, arg_regs, ret_meta.ret_type, ret_meta.ret_ptr_depth);
    var call_ptr2: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_CALL_SLICE_STORE, 0, operand_const((u64)info), operand_reg(addr_reg));
    append_inst(ctx.cur_block, call_ptr2);
    return 0;
}

func lambda_closure_unpack_regs(ctx: *BuilderCtx, closure_handle_reg: u64) -> *SliceRegs {
    var obj_reg: u64 = new_reg(ctx);
    var mask_reg: u64 = build_const(ctx, 9223372036854775807);
    var and_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_AND, obj_reg, operand_reg(closure_handle_reg), operand_reg(mask_reg));
    append_inst(ctx.cur_block, and_ptr);

    // Raw lambda handles are pointers to the generated closure object:
    //   [0]  kind
    //   [8]  fn
    //   [16] env
    var fn_off: u64 = build_const(ctx, 8);
    var fn_addr: u64 = new_reg(ctx);
    var fn_add_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, fn_addr, operand_reg(obj_reg), operand_reg(fn_off));
    append_inst(ctx.cur_block, fn_add_ptr);
    var fn_reg: u64 = load_by_size(ctx, fn_addr, 8);

    var off16: u64 = build_const(ctx, 16);
    var env_addr: u64 = new_reg(ctx);
    var add_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, env_addr, operand_reg(obj_reg), operand_reg(off16));
    append_inst(ctx.cur_block, add_ptr);
    var env_reg: u64 = load_by_size(ctx, env_addr, 8);
    return new SliceRegs{fn_reg, env_reg};
}

func emit_lambda_closure_call(ctx: *BuilderCtx, cp: *AstCallPtr, dst: u64, extra_dst: u64) -> u64 {
    var closure_reg: u64 = call_ptr_callee_reg(ctx, cp.callee);
    var unpacked: *SliceRegs = lambda_closure_unpack_regs(ctx, closure_reg);
    var fn_reg: u64 = unpacked.ptr_reg;
    var env_reg: u64 = unpacked.len_reg;

    var args: *Vec<u64> = cp.args_vec;
    var arg_regs: *Vec<u64> = make_call_arg_regs(ctx, args, call_prefix_one(env_reg));
    var ret_meta: BuilderCallRetMeta = call_ret_meta(ctx, (u64)cp, TYPE_I64, 0);
    var info: *SSACallPtrInfo = make_call_ptr_info(fn_reg, arg_regs, ret_meta.ret_type, ret_meta.ret_ptr_depth, ret_meta.ret_struct_size);

    var extra_opr: u64 = 0;
    if (extra_dst != 0) { extra_opr = operand_reg(extra_dst); }
    var call_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_CALL_PTR, dst, operand_const((u64)info), extra_opr);
    append_inst(ctx.cur_block, call_ptr);
    return dst;
}

func emit_lambda_closure_call_sret(ctx: *BuilderCtx, cp: *AstCallPtr, addr_reg: u64) -> u64 {
    if (addr_reg == 0) { return 0; }
    var closure_reg: u64 = call_ptr_callee_reg(ctx, cp.callee);
    var unpacked: *SliceRegs = lambda_closure_unpack_regs(ctx, closure_reg);
    var fn_reg: u64 = unpacked.ptr_reg;
    var env_reg: u64 = unpacked.len_reg;

    var args: *Vec<u64> = cp.args_vec;
    var arg_regs: *Vec<u64> = make_call_arg_regs(ctx, args, call_prefix_two(addr_reg, env_reg));
    var ret_meta: BuilderCallRetMeta = call_ret_meta(ctx, (u64)cp, TYPE_STRUCT, 0);
    var info: *SSACallPtrInfo = make_call_ptr_info(fn_reg, arg_regs, ret_meta.ret_type, ret_meta.ret_ptr_depth, ret_meta.ret_struct_size);
    var call_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_CALL_PTR, 0, operand_const((u64)info), 0);
    append_inst(ctx.cur_block, call_ptr);
    return 0;
}

func emit_lambda_closure_call_slice_store(ctx: *BuilderCtx, cp: *AstCallPtr, addr_reg: u64) -> u64 {
    var closure_reg: u64 = call_ptr_callee_reg(ctx, cp.callee);
    var unpacked: *SliceRegs = lambda_closure_unpack_regs(ctx, closure_reg);
    var fn_reg: u64 = unpacked.ptr_reg;
    var env_reg: u64 = unpacked.len_reg;

    var args: *Vec<u64> = cp.args_vec;
    var arg_regs: *Vec<u64> = make_call_arg_regs(ctx, args, call_prefix_one(env_reg));
    var ret_meta: BuilderCallRetMeta = call_ret_meta(ctx, (u64)cp, TYPE_I64, 0);
    var info: *SSACallSliceStoreInfo = make_call_slice_store_info(1, slice(0, 0), fn_reg, arg_regs, ret_meta.ret_type, ret_meta.ret_ptr_depth);
    var call_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_CALL_SLICE_STORE, 0, operand_const((u64)info), operand_reg(addr_reg));
    append_inst(ctx.cur_block, call_ptr);
    return 0;
}

func emit_call_ptr(ctx: *BuilderCtx, cp: *AstCallPtr, dst: u64, extra_dst: u64) -> u64 {
    var callee_ti: *TypeInfo = get_expr_type_with_symtab(cp.callee, ctx.symtab);
    var sig_ti: *TypeInfo = typeinfo_func_signature(callee_ti);
    if (sig_ti != 0 && sig_ti.fn_params_vec != 0) {
        var args_n: u64 = 0;
        if (cp.args_vec != 0) { args_n = cp.args_vec.len(); }
        var expected_n: u64 = sig_ti.fn_params_vec.len();
        var fixed_n: u64 = expected_n;
        var min_n: u64 = expected_n;
        if (sig_ti.fn_is_variadic != 0 && expected_n > 0) {
            fixed_n = expected_n - 1;
            min_n = fixed_n;
        }
        if (sig_ti.fn_is_variadic == 0 && args_n != expected_n) {
            diag_emit_error_tag("ssa", "fn-ptr-call", "function pointer call argument count mismatch");
            diag_emit_labelled_u64("expected: ", expected_n);
            diag_emit_labelled_u64("got: ", args_n);
            diag_error("SSA build error");
        }
        if (sig_ti.fn_is_variadic != 0 && args_n < min_n) {
            diag_emit_error_tag("ssa", "fn-ptr-call", "function pointer call missing required arguments");
            diag_emit_labelled_u64("expected at least: ", min_n);
            diag_emit_labelled_u64("got: ", args_n);
            diag_error("SSA build error");
        }
        for (var i_sig: u64 = 0; i_sig < fixed_n; i_sig++) {
            var expected_ti: *TypeInfo = sig_ti.fn_params_vec.get(i_sig);
            var actual_ti: *TypeInfo = get_expr_type_with_symtab(cp.args_vec.get(i_sig), ctx.symtab);
            if (expected_ti == 0 || actual_ti == 0) {
                diag_emit_error_tag("ssa", "fn-ptr-call", "function pointer call argument type mismatch at index");
                diag_emit_labelled_u64("index: ", i_sig);
                diag_error("SSA build error");
            }
            var mismatch: u64 = 0;
            if (typeinfo_is_assignable(actual_ti, expected_ti) == 0) {
                mismatch = 1;
            }
            if (mismatch != 0) {
                diag_emit_error_tag("ssa", "fn-ptr-call", "function pointer call argument type mismatch at index");
                diag_emit_labelled_u64("index: ", i_sig);
                diag_error("SSA build error");
            }
        }
        if (sig_ti.fn_is_variadic != 0 && expected_n > 0) {
            var rest_ti: *TypeInfo = sig_ti.fn_params_vec.get(expected_n - 1);
            for (var ri: u64 = fixed_n; ri < args_n; ri++) {
                var actual_rest_ti: *TypeInfo = get_expr_type_with_symtab(cp.args_vec.get(ri), ctx.symtab);
                if (rest_ti == 0 || actual_rest_ti == 0) {
                    diag_emit_error_tag("ssa", "fn-ptr-call", "function pointer variadic argument type mismatch at index");
                    diag_emit_labelled_u64("index: ", ri);
                    diag_error("SSA build error");
                }
                var mismatch2: u64 = 0;
                if (typeinfo_is_assignable(actual_rest_ti, rest_ti) == 0) {
                    mismatch2 = 1;
                }
                if (mismatch2 != 0) {
                    diag_emit_error_tag("ssa", "fn-ptr-call", "function pointer variadic argument type mismatch at index");
                    diag_emit_labelled_u64("index: ", ri);
                    diag_error("SSA build error");
                }
            }
        }
    }

    if (closure_expr_is_lambda_handle(ctx, cp.callee) != 0) {
        return emit_lambda_closure_call(ctx, cp, dst, extra_dst);
    }

    var args: *Vec<u64> = cp.args_vec;
    var arg_regs: *Vec<u64> = make_call_arg_regs(ctx, args, call_prefix_none());

    var callee_reg: u64 = call_ptr_callee_reg(ctx, cp.callee);

    var ret_meta: BuilderCallRetMeta = call_ret_meta(ctx, (u64)cp, TYPE_I64, 0);
    var info: *SSACallPtrInfo = make_call_ptr_info(callee_reg, arg_regs, ret_meta.ret_type, ret_meta.ret_ptr_depth, ret_meta.ret_struct_size);

    var extra_opr3: u64 = 0;
    if (extra_dst != 0) { extra_opr3 = operand_reg(extra_dst); }
    var call_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_CALL_PTR, dst, operand_const((u64)info), extra_opr3);
    append_inst(ctx.cur_block, call_ptr);
    return dst;
}

func emit_call_ptr_sret(ctx: *BuilderCtx, cp: *AstCallPtr, addr_reg: u64) -> u64 {
    if (addr_reg == 0) { return 0; }
    if (closure_expr_is_lambda_handle(ctx, cp.callee) != 0) {
        return emit_lambda_closure_call_sret(ctx, cp, addr_reg);
    }
    var callee_reg: u64 = build_expr(ctx, cp.callee);
    var args: *Vec<u64> = cp.args_vec;
    var arg_regs: *Vec<u64> = make_call_arg_regs(ctx, args, call_prefix_one(addr_reg));

    var ret_meta: BuilderCallRetMeta = call_ret_meta(ctx, (u64)cp, TYPE_STRUCT, 0);
    var info: *SSACallPtrInfo = make_call_ptr_info(callee_reg, arg_regs, ret_meta.ret_type, ret_meta.ret_ptr_depth, ret_meta.ret_struct_size);
    var call_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_CALL_PTR, 0, operand_const((u64)info), 0);
    append_inst(ctx.cur_block, call_ptr);
    return 0;
}

func emit_call_ptr_slice_store(ctx: *BuilderCtx, cp: *AstCallPtr, addr_reg: u64) -> u64 {
    if (closure_expr_is_lambda_handle(ctx, cp.callee) != 0) {
        return emit_lambda_closure_call_slice_store(ctx, cp, addr_reg);
    }
    var args: *Vec<u64> = cp.args_vec;
    var arg_regs: *Vec<u64> = make_call_arg_regs(ctx, args, call_prefix_none());

    var callee_reg: u64 = call_ptr_callee_reg(ctx, cp.callee);

    var ret_meta: BuilderCallRetMeta = call_ret_meta(ctx, (u64)cp, TYPE_I64, 0);
    var info: *SSACallSliceStoreInfo = make_call_slice_store_info(1, slice(0, 0), callee_reg, arg_regs, ret_meta.ret_type, ret_meta.ret_ptr_depth);
    var call_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_CALL_SLICE_STORE, 0, operand_const((u64)info), operand_reg(addr_reg));
    append_inst(ctx.cur_block, call_ptr);
    return 0;
}

func type_size_from_expr(ctx: *BuilderCtx, node: u64) -> u64 {
    var ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)node, ctx.symtab);
    if (ti == 0) { return 8; }
    return layout_type_sizeof(ti.type_kind, ti.ptr_depth, ti.struct_name);
}

func is_single_word_struct_value(type_kind: u64, ptr_depth: u64, struct_name: []u8) -> u64 {
    if (type_kind != TYPE_STRUCT || ptr_depth != 0) { return 0; }
    var struct_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, slice(struct_name.ptr, struct_name.len));
    if (struct_size == 0 || struct_size > 8) { return 0; }
    return 1;
}

func sync_single_word_struct_var_from_addr(ctx: *BuilderCtx, name: []u8, addr_reg: u64, struct_size: u64) -> u64 {
    if (ctx == 0 || name.ptr == 0 || name.len == 0 || addr_reg == 0) { return 0; }
    if (struct_size == 0 || struct_size > 8) { return 0; }
    var val_reg: u64 = load_by_size(ctx, addr_reg, struct_size);
    var var_id: u64 = get_var_id(ctx, slice(name.ptr, name.len));
    var st_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_STORE, 0, operand_const(var_id), operand_reg(val_reg));
    append_inst(ctx.cur_block, st_ptr);
    return 1;
}

func sync_single_word_struct_var_from_offset(ctx: *BuilderCtx, name: []u8, offset: u64, struct_size: u64) -> u64 {
    if (offset == 0) { return 0; }
    var addr_reg: u64 = new_lea_local(ctx, offset);
    return sync_single_word_struct_var_from_addr(ctx, slice(name.ptr, name.len), addr_reg, struct_size);
}

func lvalue_addr_ident(ctx: *BuilderCtx, node: u64) -> u64 {
    var idn: *AstIdent = (*AstIdent)node;
    var offset: u64 = symtab_find(ctx.symtab, idn.name);
    if (offset != 0) {
        return new_lea_local(ctx, offset);
    }
    if (sym_func_exists(idn.name) != 0) {
        var resolved_ptr2: u64 = u8_slice_ptr(idn.name);
        var resolved_len2: u64 = u8_slice_len(idn.name);
        var resolved2: *NameInfo = resolve_name(idn.name);
        if (resolved2 != 0) {
            resolved_ptr2 = resolved2.ptr;
            resolved_len2 = resolved2.len;
        }
        return new_lea_func(ctx, slice(resolved_ptr2, resolved_len2));
    }
    var resolved_ptr: u64 = u8_slice_ptr(idn.name);
    var resolved_len: u64 = u8_slice_len(idn.name);
    var resolved: *NameInfo = resolve_name(idn.name);
    if (resolved != 0) {
        resolved_ptr = resolved.ptr;
        resolved_len = resolved.len;
    }
    if (sym_find_global_info(slice(resolved_ptr, resolved_len)) == 0) {
        diag_emit_error_tag("ssa", "name-resolution", "undefined identifier");
        diag_emit_labelled_name("name: ", idn.name);
        diag_error("SSA build error");
        return 0;
    }
    return new_lea_global(ctx, slice(resolved_ptr, resolved_len));
}

func member_diag_access_denied(struct_slice: []u8, member: []u8, access: u64, member_kind: u64) -> u64 {
    if (member_kind == 0) {
        if (access == ACCESS_PRIVATE) {
            emit_stderr("[ERROR] private field access denied: ");
        } else {
            emit_stderr("[ERROR] field access denied: ");
        }
    } else {
        if (access == ACCESS_PRIVATE) {
            emit_stderr("[ERROR] private method access denied: ");
        } else {
            emit_stderr("[ERROR] method access denied: ");
        }
    }
    emit_stderr_len(struct_slice.ptr, struct_slice.len);
    emit_stderr(".");
    emit_stderr_len(member.ptr, member.len);
    emit_stderr_nl();
    diag_error("SSA build error");
    return 0;
}

func member_diag_non_struct(assign_mode: u64) -> u64 {
    if (assign_mode != 0) {
        diag_emit_error_tag("ssa", "name-resolution", "member assignment on non-struct identifier");
    } else {
        diag_emit_error_tag("ssa", "name-resolution", "member access on non-struct identifier");
    }
    diag_error("SSA build error");
    return 0;
}

func member_resolve_addr_and_field(ctx: *BuilderCtx, node: u64, assign_mode: u64, out_base_addr: *u64, out_field_offset: *u64, out_field_desc: **FieldDesc) -> u64 {
    var m: *AstMemberAccess = (*AstMemberAccess)node;
    var obj: u64 = m.object;
    if (out_base_addr != 0) { *out_base_addr = 0; }
    if (out_field_offset != 0) { *out_field_offset = 0; }
    if (out_field_desc != 0) { *out_field_desc = 0; }
    if (ast_kind(obj) == AST_IDENT && u8_slice_ptr(m.parent) == 0) {
        var scope_id: *AstIdent = (*AstIdent)obj;
        var scoped_const_lvalue: *ConstResult = (*ConstResult)sym_find_scoped_const(scope_id.name, m.member);
        if (scoped_const_lvalue != 0 && scoped_const_lvalue.found != 0) {
            diag_emit_error_tag("ssa", "const-assign", "Cannot assign to enum member constant");
            diag_emit_labelled_member("target: ", scope_id.name, m.member);
            ctx.build_failed = 1;
            return 0;
        }
    }
    var ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)obj, ctx.symtab);
    if (ti == 0) {
        if (ast_kind(obj) == AST_IDENT) {
            var missing_id: *AstIdent = (*AstIdent)obj;
            diag_emit_error_tag("ssa", "name-resolution", "undefined identifier");
            diag_emit_labelled_name("name: ", missing_id.name);
            diag_error("SSA build error");
        }
        return 0;
    }
    var base_addr: u64 = 0;
    if (ti.ptr_depth > 0) {
        base_addr = build_expr(ctx, obj);
    } else {
        base_addr = lvalue_addr(ctx, obj);
    }
    if (out_base_addr != 0) { *out_base_addr = base_addr; }
    if (ti.type_kind == TYPE_SLICE && ti.ptr_depth == 0) {
        if (str_eq(m.member, slice("ptr", str_len("ptr"))) != 0) {
            if (out_field_offset != 0) { *out_field_offset = 0; }
            return 1;
        }
        if (str_eq(m.member, slice("len", str_len("len"))) != 0) {
            if (out_field_offset != 0) { *out_field_offset = 8; }
            return 1;
        }
        return 1;
    }
    var struct_def: *AstStructDef = ti.struct_def;
    if (struct_def == 0 && u8_slice_ptr(ti.struct_name) != 0 && u8_slice_len(ti.struct_name) != 0) {
        struct_def = get_struct_def(ti.struct_name);
    }
    if (struct_def == 0) {
        member_diag_non_struct(assign_mode);
        return 0;
    }
    var field_offset: u64 = 0;
    var field_desc: *FieldDesc = 0;
    var found: u64 = struct_find_field_desc_scoped(struct_def, m.parent, m.member, &field_offset, &field_desc);
    if (found == 0) { return 1; }
    if (field_desc != 0 && check_field_access(field_desc) == 0) {
        member_diag_access_denied(struct_def.name, m.member, field_desc.access, 0);
        return 0;
    }
    if (out_field_offset != 0) { *out_field_offset = field_offset; }
    if (out_field_desc != 0) { *out_field_desc = field_desc; }
    return 1;
}

func lvalue_addr_member(ctx: *BuilderCtx, node: u64) -> u64 {
    var base_addr: u64 = 0;
    var field_offset: u64 = 0;
    var field_desc: *FieldDesc = 0;
    if (member_resolve_addr_and_field(ctx, node, 1, &base_addr, &field_offset, &field_desc) == 0) { return 0; }
    if (field_offset == 0) { return base_addr; }
    var off_reg: u64 = build_const(ctx, field_offset);
    var out_reg: u64 = new_reg(ctx);
    var add_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, out_reg, operand_reg(base_addr), operand_reg(off_reg));
    append_inst(ctx.cur_block, add_ptr);
    return out_reg;
}

func lvalue_addr_deref(ctx: *BuilderCtx, node: u64) -> u64 {
    var d: *AstDeref = (*AstDeref)node;
    var addr_reg: u64 = build_expr(ctx, d.operand);
    var op_ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)d.operand, ctx.symtab);
    if (op_ti != 0 && op_ti.is_tagged == 1) {
        addr_reg = mask_tagged_ptr(ctx, addr_reg);
    }
    return addr_reg;
}

func lvalue_addr_scale_index(ctx: *BuilderCtx, idx_reg: u64, elem_size: u64) -> u64 {
    if (elem_size <= 1) { return idx_reg; }
    var size_reg: u64 = build_const(ctx, elem_size);
    var mul_reg: u64 = new_reg(ctx);
    var mul_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_MUL, mul_reg, operand_reg(idx_reg), operand_reg(size_reg));
    append_inst(ctx.cur_block, mul_ptr);
    return mul_reg;
}

func lvalue_addr_index(ctx: *BuilderCtx, node: u64) -> u64 {
    var idx: *AstIndex = (*AstIndex)node;
    var base: u64 = idx.base;
    var bt: *TypeInfo = get_expr_type_with_symtab((*AstNode)base, ctx.symtab);
    if (bt == 0) { return 0; }

    var elem_size: u64 = get_pointee_size(bt.type_kind, bt.ptr_depth);
    if (bt.ptr_depth == 1 && bt.type_kind == TYPE_STRUCT) {
        elem_size = layout_type_sizeof(bt.type_kind, 0, bt.struct_name);
    }
    if (bt.type_kind == TYPE_ARRAY && bt.ptr_depth == 0) {
        elem_size = typeinfo_elem_size_from_container(bt);
        var base_addr: u64 = lvalue_addr(ctx, base);
        var idx_reg: u64 = build_expr(ctx, idx.index);
        idx_reg = lvalue_addr_scale_index(ctx, idx_reg, elem_size);
        var out_reg2: u64 = new_reg(ctx);
        var add_ptr2: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, out_reg2, operand_reg(base_addr), operand_reg(idx_reg));
        append_inst(ctx.cur_block, add_ptr2);
        return out_reg2;
    }

    var base_ptr: u64 = build_expr(ctx, base);
    if (bt.ptr_depth > 0 && bt.is_tagged == 1) {
        base_ptr = mask_tagged_ptr(ctx, base_ptr);
    }
    if (bt.type_kind == TYPE_SLICE && bt.ptr_depth == 0) {
        var addr_reg: u64 = lvalue_addr(ctx, base);
        base_ptr = load_by_size(ctx, addr_reg, 8);
        elem_size = typeinfo_elem_size_from_container(bt);
    }

    var idx_reg2: u64 = build_expr(ctx, idx.index);
    idx_reg2 = lvalue_addr_scale_index(ctx, idx_reg2, elem_size);
    var out_reg3: u64 = new_reg(ctx);
    var add_ptr3: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, out_reg3, operand_reg(base_ptr), operand_reg(idx_reg2));
    append_inst(ctx.cur_block, add_ptr3);
    return out_reg3;
}

func lvalue_addr(ctx: *BuilderCtx, node: u64) -> u64 {
    var k: u64 = ast_kind(node);
    if (k == AST_IDENT) { return lvalue_addr_ident(ctx, node); }
    if (k == AST_MEMBER_ACCESS) { return lvalue_addr_member(ctx, node); }
    if (k == AST_DEREF || k == AST_DEREF8) { return lvalue_addr_deref(ctx, node); }
    if (k == AST_INDEX) { return lvalue_addr_index(ctx, node); }
    return 0;
}

// ============================================
// Builder Helpers
// ============================================

func block_is_terminated(block: *SSABlock) -> u64 {
    if (block == 0) { return true; }
    var tail: *SSAInstruction = block.inst_tail;
    if (tail == 0) { return false; }
    var op: u64 = op_of(tail);
    if (op == SSA_OP_JMP || op == SSA_OP_BR || op == SSA_OP_RET || op == SSA_OP_RET_SLICE_HEAP) { return true; }
    return false;
}

func block_is_reachable(block: *SSABlock) -> u64 {
    if (block == 0) { return false; }
    if (slice_len(block.preds) > 0) { return true; }
    return false;
}

func stmt_or_expr(ctx: *BuilderCtx, node: u64) -> u64 {
    if (node == 0) { return 0; }
    var k: u64 = ast_kind(node);
    if (k == AST_VAR_DECL || k == AST_CONST_DECL || k == AST_ASSIGN || k == AST_EXPR_STMT) {
        build_stmt(ctx, node);
        return 0;
    }
    build_expr(ctx, node);
    return 0;
}

func binop_to_ssa_op(op: u64, use_signed: u64) -> u64 {
    if (op == TOKEN_PLUS) { return SSA_OP_ADD; }
    if (op == TOKEN_MINUS) { return SSA_OP_SUB; }
    if (op == TOKEN_STAR) { return SSA_OP_MUL; }
    if (op == TOKEN_SLASH) {
        if (use_signed != 0) { return SSA_OP_DIV; }
        return SSA_OP_UDIV;
    }
    if (op == TOKEN_PERCENT) {
        if (use_signed != 0) { return SSA_OP_MOD; }
        return SSA_OP_UMOD;
    }
    if (op == TOKEN_AMPERSAND) { return SSA_OP_AND; }
    if (op == TOKEN_PIPE) { return SSA_OP_OR; }
    if (op == TOKEN_CARET) { return SSA_OP_XOR; }
    if (op == TOKEN_LSHIFT) { return SSA_OP_SHL; }
    if (op == TOKEN_RSHIFT) {
        if (use_signed != 0) { return SSA_OP_SAR; }
        return SSA_OP_SHR;
    }
    if (op == TOKEN_EQEQ) { return SSA_OP_EQ; }
    if (op == TOKEN_BANGEQ) { return SSA_OP_NE; }
    if (op == TOKEN_LT) {
        if (use_signed != 0) { return SSA_OP_LT; }
        return SSA_OP_ULT;
    }
    if (op == TOKEN_GT) {
        if (use_signed != 0) { return SSA_OP_GT; }
        return SSA_OP_UGT;
    }
    if (op == TOKEN_LTEQ) {
        if (use_signed != 0) { return SSA_OP_LE; }
        return SSA_OP_ULE;
    }
    if (op == TOKEN_GTEQ) {
        if (use_signed != 0) { return SSA_OP_GE; }
        return SSA_OP_UGE;
    }
    return SSA_OP_NOP;
}

func is_f64_expr(ctx: *BuilderCtx, node: u64) -> u64 {
    if (node == 0) { return false; }
    var ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)node, ctx.symtab);
    if (ti == 0) { return false; }
    if (ti.ptr_depth != 0) { return false; }
    if (ti.type_kind == TYPE_F64) { return true; }
    return false;
}

func is_signed_i64_expr(ctx: *BuilderCtx, node: u64) -> u64 {
    if (node == 0) { return false; }
    var ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)node, ctx.symtab);
    if (ti == 0) { return false; }
    if (ti.ptr_depth != 0) { return false; }
    if (ti.type_kind == TYPE_I8 || ti.type_kind == TYPE_I16 || ti.type_kind == TYPE_I32 || ti.type_kind == TYPE_I64) { return true; }
    return false;
}

func cast_is_int_scalar(kind: u64) -> u64 {
    if (kind == TYPE_BOOL) { return true; }
    if (kind == TYPE_U8) { return true; }
    if (kind == TYPE_U16) { return true; }
    if (kind == TYPE_U32) { return true; }
    if (kind == TYPE_U64) { return true; }
    if (kind == TYPE_I8) { return true; }
    if (kind == TYPE_I16) { return true; }
    if (kind == TYPE_I32) { return true; }
    if (kind == TYPE_I64) { return true; }
    return false;
}

func cast_int_truncate(ctx: *BuilderCtx, src_reg: u64, target_kind: u64) -> u64 {
    if (target_kind == TYPE_BOOL || target_kind == TYPE_U8) {
        return mask_low_bits(ctx, src_reg, 8);
    }
    if (target_kind == TYPE_U16) {
        return mask_low_bits(ctx, src_reg, 16);
    }
    if (target_kind == TYPE_U32) {
        return mask_low_bits(ctx, src_reg, 32);
    }
    if (target_kind == TYPE_I8) {
        var narrowed8: u64 = mask_low_bits(ctx, src_reg, 8);
        var shl8: u64 = shift_left(ctx, narrowed8, 56);
        return shift_arith_right(ctx, shl8, 56);
    }
    if (target_kind == TYPE_I16) {
        var narrowed16: u64 = mask_low_bits(ctx, src_reg, 16);
        var shl16: u64 = shift_left(ctx, narrowed16, 48);
        return shift_arith_right(ctx, shl16, 48);
    }
    if (target_kind == TYPE_I32) {
        var narrowed32: u64 = mask_low_bits(ctx, src_reg, 32);
        var shl32: u64 = shift_left(ctx, narrowed32, 32);
        return shift_arith_right(ctx, shl32, 32);
    }
    return src_reg;
}

func cast_emit_i2f(ctx: *BuilderCtx, src_reg: u64, is_unsigned: u64) -> u64 {
    var op: u64 = SSA_OP_I2F;
    if (is_unsigned != 0) { op = SSA_OP_U2F; }
    var out_reg: u64 = new_reg(ctx);
    var cast_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, op, out_reg, operand_reg(src_reg), 0);
    append_inst(ctx.cur_block, cast_ptr);
    return out_reg;
}

func cast_emit_f2i(ctx: *BuilderCtx, src_reg: u64, is_unsigned: u64) -> u64 {
    var op: u64 = SSA_OP_F2I;
    if (is_unsigned != 0) { op = SSA_OP_F2U; }
    var out_reg: u64 = new_reg(ctx);
    var cast_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, op, out_reg, operand_reg(src_reg), 0);
    append_inst(ctx.cur_block, cast_ptr);
    return out_reg;
}

func build_const(ctx: *BuilderCtx, val: u64) -> u64 {
    var reg_id: u64 = new_reg(ctx);
    var inst_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_CONST, reg_id, operand_const(val), 0);
    append_inst(ctx.cur_block, inst_ptr);
    return reg_id;
}

func negate_const_u64_bits(value: u64) -> u64 {
    if (value == 0) { return 0; }
    var sign_bit: u64 = 1;
    sign_bit = sign_bit << 63;
    if (value == sign_bit) { return sign_bit; }
    return sign_bit | (sign_bit - value);
}

func build_bool_from_reg(ctx: *BuilderCtx, reg: u64) -> u64 {
    var zero_reg: u64 = build_const(ctx, 0);
    var dst: u64 = new_reg(ctx);
    var inst_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_NE, dst, operand_reg(reg), operand_reg(zero_reg));
    append_inst(ctx.cur_block, inst_ptr);
    return dst;
}

func build_short_circuit(ctx: *BuilderCtx, op: u64, left: u64, right: u64) -> u64 {
    var entry_bb: *SSABlock = ctx.cur_block;
    var left_reg: u64 = build_expr(ctx, left);

    var right_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var merge_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);

    var entry_val: u64 = 0;
    if (op == TOKEN_ANDAND) {
        entry_val = build_const(ctx, 0);
        var br_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_BR, operand_const(merge_bb.id), operand_reg(left_reg), operand_const(right_bb.id));
        append_inst(ctx.cur_block, br_ptr);
        connect_blocks(ctx.cur_block, right_bb);
        connect_blocks(ctx.cur_block, merge_bb);
    } else {
        entry_val = build_const(ctx, 1);
        var br_ptr2: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_BR, operand_const(right_bb.id), operand_reg(left_reg), operand_const(merge_bb.id));
        append_inst(ctx.cur_block, br_ptr2);
        connect_blocks(ctx.cur_block, merge_bb);
        connect_blocks(ctx.cur_block, right_bb);
    }

    ctx.cur_block = right_bb;
    var right_reg: u64 = build_expr(ctx, right);
    var right_bool: u64 = build_bool_from_reg(ctx, right_reg);
    var jmp_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(merge_bb.id), 0);
    append_inst(ctx.cur_block, jmp_ptr);
    connect_blocks(ctx.cur_block, merge_bb);

    ctx.cur_block = merge_bb;
    var head: *SSAPhiArg = create_phi_arg(entry_val, entry_bb.id);
    head = append_phi_arg(head, right_bool, right_bb.id);
    var dest: u64 = new_reg(ctx);
    var phi_ptr: *SSAInstruction = create_phi(ctx.ssa_ctx, dest, head);
    append_phi(merge_bb, phi_ptr);
    return dest;
}

func expr_ternary(ctx: *BuilderCtx, node: u64) -> u64 {
    var tern: *AstTernary = (*AstTernary)node;
    var cond_raw: u64 = build_expr(ctx, tern.cond);
    var cond_reg: u64 = build_bool_from_reg(ctx, cond_raw);

    var then_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var else_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var merge_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);

    var br_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_BR, operand_const(else_bb.id), operand_reg(cond_reg), operand_const(then_bb.id));
    append_inst(ctx.cur_block, br_ptr);
    connect_blocks(ctx.cur_block, then_bb);
    connect_blocks(ctx.cur_block, else_bb);

    ctx.cur_block = then_bb;
    var then_reg: u64 = build_expr(ctx, tern.then_expr);
    var jmp_then: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(merge_bb.id), 0);
    append_inst(ctx.cur_block, jmp_then);
    connect_blocks(ctx.cur_block, merge_bb);

    ctx.cur_block = else_bb;
    var else_reg: u64 = build_expr(ctx, tern.else_expr);
    var jmp_else: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(merge_bb.id), 0);
    append_inst(ctx.cur_block, jmp_else);
    connect_blocks(ctx.cur_block, merge_bb);

    ctx.cur_block = merge_bb;
    var head: *SSAPhiArg = create_phi_arg(then_reg, then_bb.id);
    head = append_phi_arg(head, else_reg, else_bb.id);
    var dst: u64 = new_reg(ctx);
    var phi_ptr: *SSAInstruction = create_phi(ctx.ssa_ctx, dst, head);
    append_phi(merge_bb, phi_ptr);
    return dst;
}

func scale_ptr_arith(ctx: *BuilderCtx, left_expr: u64, op: u64, rhs_reg: u64) -> u64 {
    if (op != TOKEN_PLUS && op != TOKEN_MINUS) { return rhs_reg; }
    var left_ti: *TypeInfo = get_expr_type_with_symtab(left_expr, ctx.symtab);
    if (left_ti == 0) { return rhs_reg; }
    if (left_ti.ptr_depth == 0) { return rhs_reg; }
    var elem_size: u64 = get_pointee_size(left_ti.type_kind, left_ti.ptr_depth);
    if (elem_size <= 1) { return rhs_reg; }
    var size_reg: u64 = build_const(ctx, elem_size);
    var scaled_reg: u64 = new_reg(ctx);
    var mul_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_MUL, scaled_reg, operand_reg(rhs_reg), operand_reg(size_reg));
    append_inst(ctx.cur_block, mul_ptr);
    return scaled_reg;
}

func try_resolve_meta_or_panic(ctx: *BuilderCtx, operand: u64, ret_type: u64, ret_ptr_depth: u64, ret_struct_name: []u8) -> *BuilderTryMeta {
    var opt_ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)operand, ctx.symtab);
    if (opt_ti == 0) {
        diag_emit_error_tag("ssa", "try", "try operand type not found");
        diag_emit_help("ensure the try operand has a resolved type before SSA construction");
        diag_error("SSA build error");
        return 0;
    }

    var try_fields: CompilerTryFieldNames = try_field_names_from_typeinfo(opt_ti);
    if (try_fields.found == 0) {
        if (opt_ti.type_kind != TYPE_STRUCT || opt_ti.ptr_depth != 0) {
            diag_emit_error_tag("ssa", "try", "try operator requires try-compatible struct value");
        } else {
            diag_emit_error_tag("ssa", "try", "try operator requires try-compatible check/value fields");
            diag_emit_labelled_name("try struct: ", opt_ti.struct_name);
        }
        diag_emit_help("use a struct with compatible check/value fields");
        diag_error("SSA build error");
        return 0;
    }

    if (try_return_matches_type(opt_ti, ret_type, ret_ptr_depth, slice(ret_struct_name.ptr, ret_struct_name.len)) == 0) {
        if (ret_type != TYPE_STRUCT || ret_ptr_depth != 0) {
            diag_emit_error_tag("ssa", "try", "try operator requires try-compatible return type");
        } else {
            diag_emit_error_tag("ssa", "try", "try operand type must match function return type");
            diag_emit_labelled_name("function return struct: ", slice(ret_struct_name.ptr, ret_struct_name.len));
        }
        diag_emit_help("make the operand and function return type use the same try-compatible struct");
        diag_error("SSA build error");
        return 0;
    }

    var struct_def: *AstStructDef = try_resolve_struct_def(opt_ti);
    if (struct_def == 0) {
        diag_emit_error_tag("ssa", "try", "try operand struct definition not found");
        diag_emit_labelled_name("try struct: ", opt_ti.struct_name);
        diag_error("SSA build error");
        return 0;
    }

    var check: []u8 = try_fields.check;
    var value: []u8 = try_fields.value;

    var value_desc: *FieldDesc = get_field_desc(struct_def, value);
    if (value_desc == 0) {
        diag_emit_error_tag("ssa", "try", "try value field not found");
        diag_emit_labelled_member("expected field: ", struct_def.name, value);
        diag_error("SSA build error");
        return 0;
    }

    var meta: *BuilderTryMeta = new BuilderTryMeta{};
    meta.opt_ti = opt_ti;
    meta.struct_def = struct_def;
    meta.check = check;
    meta.value = value;
    meta.value_desc = value_desc;
    return meta;
}

func try_addr_with_offset(ctx: *BuilderCtx, base_addr: u64, field_off: u64) -> u64 {
    if (field_off == 0) { return base_addr; }
    var off_reg: u64 = build_const(ctx, field_off);
    var addr: u64 = new_reg(ctx);
    var add_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, addr, operand_reg(base_addr), operand_reg(off_reg));
    append_inst(ctx.cur_block, add_ptr);
    return addr;
}

func try_materialize_operand(ctx: *BuilderCtx, operand: u64, struct_size: u64, tmp_addr: u64) -> u64 {
    var op_kind: u64 = ast_kind(operand);
    if (struct_size > 16) {
        if (op_kind == AST_CALL) {
            emit_call_sret_value(ctx, (*AstCall)operand, tmp_addr);
            return 1;
        }
        if (op_kind == AST_METHOD_CALL) {
            emit_method_call_sret(ctx, (*AstMethodCall)operand, tmp_addr);
            return 1;
        }
        if (op_kind == AST_CALL_PTR) {
            emit_call_ptr_sret(ctx, (*AstCallPtr)operand, tmp_addr);
            return 1;
        }
        var src_addr: u64 = lvalue_addr(ctx, operand);
        if (src_addr == 0) { return 0; }
        struct_copy(ctx, tmp_addr, src_addr, struct_size);
        return 1;
    }

    if (op_kind == AST_CALL || op_kind == AST_METHOD_CALL || op_kind == AST_CALL_PTR) {
        var lo_reg: u64 = new_reg(ctx);
        var hi_reg: u64 = 0;
        if (struct_size > 8) { hi_reg = new_reg(ctx); }
        if (op_kind == AST_CALL) {
            emit_call(ctx, (*AstCall)operand, lo_reg, hi_reg);
        } else if (op_kind == AST_METHOD_CALL) {
            emit_method_call_value(ctx, (*AstMethodCall)operand, lo_reg, hi_reg);
        } else {
            emit_call_ptr(ctx, (*AstCallPtr)operand, lo_reg, hi_reg);
        }
        store_by_size(ctx, tmp_addr, lo_reg, 8);
        if (hi_reg != 0) {
            var addr2: u64 = try_addr_with_offset(ctx, tmp_addr, 8);
            var tail_size: u64 = struct_size - 8;
            if (tail_size > 8) { tail_size = 8; }
            store_by_size(ctx, addr2, hi_reg, tail_size);
        }
        return 1;
    }

    var src_addr2: u64 = lvalue_addr(ctx, operand);
    if (src_addr2 == 0) { return 0; }
    struct_copy(ctx, tmp_addr, src_addr2, struct_size);
    return 1;
}

func try_emit_failure_return(ctx: *BuilderCtx, tmp_addr: u64, ret_struct_name: []u8) -> u64 {
    var ret_struct_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, slice(ret_struct_name.ptr, ret_struct_name.len));
    if (ret_struct_size > 16) {
        if (ctx.sret_addr_reg == 0) { return 0; }
        struct_copy(ctx, ctx.sret_addr_reg, tmp_addr, ret_struct_size);
        var ret_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_RET, 0, 0, 0);
        append_inst(ctx.cur_block, ret_ptr);
        return 0;
    }
    emit_return_struct_from_addr_reg(ctx, tmp_addr, ret_struct_size);
    return 0;
}

func try_load_value_or_panic(ctx: *BuilderCtx, value_addr: u64, value_size: u64) -> u64 {
    if (value_size <= 8) {
        return load_by_size(ctx, value_addr, value_size);
    }
    if (value_size <= 16) {
        if (ctx.debug_mode != 0) {
            emit("[DEBUG] try value >8 bytes: returning lo only in SSA expr\n");
        }
        return load_by_size(ctx, value_addr, 8);
    }
    emit_stderr("[ERROR] try value size too large for expression result\n");
    diag_error("SSA build error");
}

func build_try_expr(ctx: *BuilderCtx, node: u64) -> u64 {
    var tr: *AstTry = (*AstTry)node;
    var operand: u64 = tr.operand;

    var ret_type: u64 = ret_type_current();
    var ret_ptr_depth: u64 = ret_ptr_depth_current();
    var ret_struct_name: []u8 = ret_struct_name_current();
    var try_meta: *BuilderTryMeta = try_resolve_meta_or_panic(ctx, operand, ret_type, ret_ptr_depth, ret_struct_name);
    if (try_meta == 0) { return 0; }

    var opt_ti: *TypeInfo = try_meta.opt_ti;
    var struct_def: *AstStructDef = try_meta.struct_def;
    var value_desc: *FieldDesc = try_meta.value_desc;
    var check_off: u64 = get_field_offset(struct_def, try_meta.check);
    var value_off: u64 = get_field_offset(struct_def, try_meta.value);

    var struct_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, opt_ti.struct_name);
    var tmp_offset: u64 = symtab_add(ctx.symtab, slice(0, 0), TYPE_STRUCT, 0, struct_size);
    var tmp_addr: u64 = new_lea_local(ctx, tmp_offset);
    if (try_materialize_operand(ctx, operand, struct_size, tmp_addr) == 0) { return 0; }

    var check_addr: u64 = try_addr_with_offset(ctx, tmp_addr, check_off);
    var check_desc: *FieldDesc = get_field_desc(struct_def, try_meta.check);
    var check_size: u64 = 8;
    if (check_desc != 0) { check_size = layout_field_sizeof(check_desc); }
    var check_reg: u64 = load_by_size(ctx, check_addr, check_size);
    var cond_reg: u64 = build_bool_from_reg(ctx, check_reg);

    var ok_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var ret_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);

    var br_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_BR, operand_const(ret_bb.id), operand_reg(cond_reg), operand_const(ok_bb.id));
    append_inst(ctx.cur_block, br_ptr);
    connect_blocks(ctx.cur_block, ok_bb);
    connect_blocks(ctx.cur_block, ret_bb);

    ctx.cur_block = ret_bb;
    try_emit_failure_return(ctx, tmp_addr, ret_struct_name);

    ctx.cur_block = ok_bb;
    var value_addr: u64 = try_addr_with_offset(ctx, tmp_addr, value_off);
    var value_size: u64 = layout_field_sizeof(value_desc);
    return try_load_value_or_panic(ctx, value_addr, value_size);
}

func expr_new(ctx: *BuilderCtx, node: u64) -> u64 {
    var nw: *AstNew = (*AstNew)node;
    if (nw.array_len_is_param != 0) {
        emit_stderr("[ERROR] new with unresolved generic array length\n");
        diag_error("SSA build error");
    }

    var size: u64 = 0;
    if (nw.type_kind == TYPE_ARRAY) {
        var elem_size: u64 = 0;
        if (nw.elem_typeinfo != 0) {
            elem_size = sizeof_type_ex(nw.elem_typeinfo);
        } else {
            elem_size = layout_type_sizeof(nw.elem_type_kind, nw.elem_ptr_depth, nw.struct_name);
        }
        size = elem_size * nw.array_len;
    } else if (nw.type_kind == TYPE_SLICE) {
        size = 16;
    } else {
        size = layout_type_sizeof(nw.type_kind, nw.ptr_depth, nw.struct_name);
    }

    var malloc_ptr: u64 = (u64)"malloc";
    var malloc_len: u64 = 6;
    var malloc_res: *NameInfo = resolve_name(slice(malloc_ptr, malloc_len));
    if (malloc_res != 0) {
        malloc_ptr = malloc_res.ptr;
        malloc_len = malloc_res.len;
    }

    var size_reg: u64 = build_const(ctx, size);
    var malloc_args: *Vec<u64> = make_args1(size_reg);
    var heap_reg: u64 = new_reg(ctx);
    emit_call_name_raw(ctx, slice(malloc_ptr, malloc_len), malloc_args, heap_reg, 0, TYPE_I64, 0, 0);

    var memset_ptr: u64 = (u64)"memset";
    var memset_len: u64 = 6;
    var memset_res: *NameInfo = resolve_name(slice(memset_ptr, memset_len));
    if (memset_res != 0) {
        memset_ptr = memset_res.ptr;
        memset_len = memset_res.len;
    }
    var zero_reg: u64 = build_const(ctx, 0);
    var memset_args: *Vec<u64> = make_args3(heap_reg, zero_reg, size_reg);
    emit_call_name_raw(ctx, slice(memset_ptr, memset_len), memset_args, 0, 0, TYPE_I64, 0, 0);

    if (nw.type_kind == TYPE_STRUCT) {
        emit_trait_vptr_init_at_addr(ctx, heap_reg, nw.struct_name);
    }

    if (nw.literal_expr != 0) {
        if (ast_kind(nw.literal_expr) == AST_STRUCT_LITERAL) {
            var lit_new: *AstStructLiteral = (*AstStructLiteral)nw.literal_expr;
            struct_literal_init(ctx, lit_new.struct_def, lit_new.values_vec, heap_reg);
        }
    }

    if (nw.ctor_args_vec != 0) {
        if (nw.type_kind != TYPE_STRUCT) {
            emit_stderr("[ERROR] new constructor call requires struct type\n");
            diag_error("SSA build error");
        }
        if (u8_slice_ptr(nw.struct_name) == 0 || u8_slice_len(nw.struct_name) == 0) {
            emit_stderr("[ERROR] new constructor target struct missing metadata in SSA\n");
            diag_error("SSA build error");
            return heap_reg;
        }
        var args: *Vec<*AstNode> = nw.ctor_args_vec;
        var ctor_resolved: CompilerMethodResolveResult = resolve_constructor_call(nw.struct_name, args, ctx.symtab, slice("new", 3));
        if (ctor_resolved.found == 0 || ctor_resolved.fn == 0) {
            return heap_reg;
        }
        var arg_regs: *Vec<u64> = make_call_arg_regs_nodes(ctx, args, call_prefix_one(heap_reg));
        emit_call_name_raw(ctx, ctor_resolved.fn.name, arg_regs, 0, 0, TYPE_VOID, 0, 0);
    }

    return heap_reg;
}

func expr_ident(ctx: *BuilderCtx, node: u64) -> u64 {
    var idn: *AstIdent = (*AstIdent)node;
    var offset: u64 = symtab_find(ctx.symtab, idn.name);
    if (offset != 0) {
        var var_ti: *TypeInfo = symtab_get_type(ctx.symtab, idn.name);
        if (var_ti != 0) {
            if (var_ti.ptr_depth == 0) {
                if (var_ti.type_kind == TYPE_ARRAY || var_ti.array_len != 0) {
                    return new_lea_local(ctx, offset);
                }
            }
        }
        if (is_addr_taken(ctx, idn.name) != 0) {
            var addr_reg: u64 = new_lea_local(ctx, offset);
            var size: u64 = type_size_from_expr(ctx, node);
            return load_by_size(ctx, addr_reg, size);
        }
        var var_id: u64 = get_var_id(ctx, idn.name);
        var reg_id: u64 = new_reg(ctx);
        var inst_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_LOAD, reg_id, operand_const(var_id), 0);
        append_inst(ctx.cur_block, inst_ptr);
        return reg_id;
    }
    var const_encoded: u64 = get_const(ctx, idn.name);
    if (const_encoded != 0) {
        return build_const(ctx, const_encoded - 1);
    }
    var resolved_ptr: u64 = u8_slice_ptr(idn.name);
    var resolved_len: u64 = u8_slice_len(idn.name);
    var resolved: *NameInfo = resolve_name(idn.name);
    if (resolved != 0) {
        resolved_ptr = resolved.ptr;
        resolved_len = resolved.len;
    }
    if (sym_func_exists(slice(resolved_ptr, resolved_len)) != 0 || sym_get_impl_method_func(slice(resolved_ptr, resolved_len)) != 0) {
        return new_lea_func(ctx, slice(resolved_ptr, resolved_len));
    }
    var c_result: u64 = sym_find_const(slice(resolved_ptr, resolved_len));
    var c: *ConstResult = (*ConstResult)c_result;
    if (c.found != 0) {
        return build_const(ctx, c.value);
    }
    if (sym_find_global_info(slice(resolved_ptr, resolved_len)) == 0) {
        diag_emit_error_tag("ssa", "name-resolution", "undefined identifier");
        diag_emit_labelled_name("name: ", idn.name);
        diag_error("SSA build error");
        return build_const(ctx, 0);
    }
    var addr_reg2: u64 = lvalue_addr(ctx, node);
    var size2: u64 = type_size_from_expr(ctx, node);
    return load_by_size(ctx, addr_reg2, size2);
}

func expr_binary(ctx: *BuilderCtx, node: u64) -> u64 {
    var bin: *AstBinary = (*AstBinary)node;
    if (bin.op == TOKEN_ANDAND || bin.op == TOKEN_OROR) {
        return build_short_circuit(ctx, bin.op, bin.left, bin.right);
    }
    var left_ti: *TypeInfo = builder_arg_type_for_method_resolution(bin.left, ctx.symtab);
    var right_ti: *TypeInfo = builder_arg_type_for_method_resolution(bin.right, ctx.symtab);
    var number_reg: u64 = builder_try_emit_number_binary(ctx, bin, left_ti, right_ti);
    if (number_reg != 0) { return number_reg; }
    var overloaded_expr: *AstNode = builder_make_overloaded_receiver_expr((*AstNode)bin, ctx.symtab);
    if (overloaded_expr != 0 && overloaded_expr != (*AstNode)bin) {
        return build_expr(ctx, overloaded_expr);
    }
    var l_is_f: u64 = is_f64_expr(ctx, bin.left);
    var r_is_f: u64 = is_f64_expr(ctx, bin.right);
    var lhs_reg: u64 = build_expr(ctx, bin.left);
    var rhs_reg: u64 = build_expr(ctx, bin.right);
    if (l_is_f != 0 || r_is_f != 0) {
        if (l_is_f == 0) {
            if (left_ti == 0 || left_ti.ptr_depth != 0 || cast_is_int_scalar(left_ti.type_kind) == 0) {
                emit_stderr("[ERROR] Float/integer binary operation does not support pointer operands\n");
                ctx.build_failed = 1;
                return build_const(ctx, 0);
            }
            var left_unsigned: u64 = 0;
            if (left_ti.type_kind == TYPE_BOOL || left_ti.type_kind == TYPE_U8 || left_ti.type_kind == TYPE_U16 ||
                left_ti.type_kind == TYPE_U32 || left_ti.type_kind == TYPE_U64) {
                left_unsigned = 1;
            }
            var left_norm: u64 = lhs_reg;
            if (left_ti.type_kind != TYPE_I64 && left_ti.type_kind != TYPE_U64) {
                left_norm = cast_int_truncate(ctx, lhs_reg, left_ti.type_kind);
            }
            lhs_reg = cast_emit_i2f(ctx, left_norm, left_unsigned);
        }
        if (r_is_f == 0) {
            if (right_ti == 0 || right_ti.ptr_depth != 0 || cast_is_int_scalar(right_ti.type_kind) == 0) {
                emit_stderr("[ERROR] Float/integer binary operation does not support pointer operands\n");
                ctx.build_failed = 1;
                return build_const(ctx, 0);
            }
            var right_unsigned: u64 = 0;
            if (right_ti.type_kind == TYPE_BOOL || right_ti.type_kind == TYPE_U8 || right_ti.type_kind == TYPE_U16 ||
                right_ti.type_kind == TYPE_U32 || right_ti.type_kind == TYPE_U64) {
                right_unsigned = 1;
            }
            var right_norm: u64 = rhs_reg;
            if (right_ti.type_kind != TYPE_I64 && right_ti.type_kind != TYPE_U64) {
                right_norm = cast_int_truncate(ctx, rhs_reg, right_ti.type_kind);
            }
            rhs_reg = cast_emit_i2f(ctx, right_norm, right_unsigned);
        }

        var fop: u64 = SSA_OP_NOP;
        if (bin.op == TOKEN_PLUS) { fop = SSA_OP_FADD; }
        else if (bin.op == TOKEN_MINUS) { fop = SSA_OP_FSUB; }
        else if (bin.op == TOKEN_STAR) { fop = SSA_OP_FMUL; }
        else if (bin.op == TOKEN_SLASH) { fop = SSA_OP_FDIV; }
        else if (bin.op == TOKEN_EQEQ) { fop = SSA_OP_FEQ; }
        else if (bin.op == TOKEN_BANGEQ) { fop = SSA_OP_FNE; }
        else if (bin.op == TOKEN_LT) { fop = SSA_OP_FLT; }
        else if (bin.op == TOKEN_GT) { fop = SSA_OP_FGT; }
        else if (bin.op == TOKEN_LTEQ) { fop = SSA_OP_FLE; }
        else if (bin.op == TOKEN_GTEQ) { fop = SSA_OP_FGE; }
        if (fop == SSA_OP_NOP) {
            emit_stderr("[ERROR] Unsupported float binary operator in SSA builder\n");
            ctx.build_failed = 1;
            return build_const(ctx, 0);
        }
        var freg: u64 = new_reg(ctx);
        var finst: *SSAInstruction = create_inst(ctx.ssa_ctx, fop, freg, operand_reg(lhs_reg), operand_reg(rhs_reg));
        append_inst(ctx.cur_block, finst);
        return freg;
    }
    rhs_reg = scale_ptr_arith(ctx, bin.left, bin.op, rhs_reg);
    var use_signed: u64 = 0;
    if (is_signed_i64_expr(ctx, bin.left) != 0) { use_signed = 1; }
    var op: u64 = binop_to_ssa_op(bin.op, use_signed);
    if (op == SSA_OP_NOP) {
        return build_const(ctx, 0);
    }
    var reg_id2: u64 = new_reg(ctx);
    var inst_ptr2: *SSAInstruction = create_inst(ctx.ssa_ctx, op, reg_id2, operand_reg(lhs_reg), operand_reg(rhs_reg));
    append_inst(ctx.cur_block, inst_ptr2);
    return reg_id2;
}

func expr_unary(ctx: *BuilderCtx, node: u64) -> u64 {
    var un: *AstUnary = (*AstUnary)node;
    var op: u64 = un.op;
    var overloaded_expr: *AstNode = builder_make_overloaded_receiver_expr((*AstNode)un, ctx.symtab);
    if (overloaded_expr != 0 && overloaded_expr != (*AstNode)un) {
        return build_expr(ctx, overloaded_expr);
    }
    if (op == TOKEN_MINUS && un.operand != 0 && ast_kind(un.operand) == AST_LITERAL) {
        var lit: *AstLiteral = (*AstLiteral)un.operand;
        var zero_reg_lit: u64 = build_const(ctx, 0);
        var lit_reg: u64 = build_const(ctx, lit.value);
        var dst_lit: u64 = new_reg(ctx);
        var neg_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_SUB, dst_lit, operand_reg(zero_reg_lit), operand_reg(lit_reg));
        append_inst(ctx.cur_block, neg_ptr);
        return dst_lit;
    }
    var val_reg: u64 = build_expr(ctx, un.operand);

    if (op == TOKEN_MINUS && is_f64_expr(ctx, un.operand) != 0) {
        var dstf: u64 = new_reg(ctx);
        var instf: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_FNEG, dstf, operand_reg(val_reg), 0);
        append_inst(ctx.cur_block, instf);
        return dstf;
    }

    if (op == TOKEN_MINUS) {
        var zero_reg: u64 = build_const(ctx, 0);
        var dst: u64 = new_reg(ctx);
        var inst_ptr3: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_SUB, dst, operand_reg(zero_reg), operand_reg(val_reg));
        append_inst(ctx.cur_block, inst_ptr3);
        return dst;
    }

    if (op == TOKEN_BANG) {
        var zero_reg2: u64 = build_const(ctx, 0);
        var dst2: u64 = new_reg(ctx);
        var inst_ptr4: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_EQ, dst2, operand_reg(val_reg), operand_reg(zero_reg2));
        append_inst(ctx.cur_block, inst_ptr4);
        return dst2;
    }

    if (op == TOKEN_TILDE) {
        var all_ones_reg: u64 = build_const(ctx, -1);
        var dst3: u64 = new_reg(ctx);
        var inst_ptr5: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_XOR, dst3, operand_reg(val_reg), operand_reg(all_ones_reg));
        append_inst(ctx.cur_block, inst_ptr5);
        return dst3;
    }

    return val_reg;
}

func safe_member_receiver_type(ctx: *BuilderCtx, obj_safe: u64) -> *TypeInfo {
    var ot: *TypeInfo = get_expr_type_with_symtab((*AstNode)obj_safe, ctx.symtab);
    if (ot == 0) {
        emit_stderr("[ERROR] Safe member access type not found\n");
        return 0;
    }
    if (ot.ptr_depth == 0) {
        emit_stderr("[ERROR] Safe member access requires pointer receiver\n");
        return 0;
    }
    if (ot.type_kind != TYPE_STRUCT) {
        emit_stderr("[ERROR] Safe member access requires struct pointer\n");
        return 0;
    }
    return ot;
}

func safe_member_tagged_value(ctx: *BuilderCtx, m_safe: *AstMemberAccess, obj_reg: u64, ot: *TypeInfo) -> u64 {
    var layout_info: *AstStructDef = get_struct_def(ot.tag_layout);
    if (layout_info == 0) {
        emit("[ERROR] Tagged layout struct not found\n");
        diag_error("SSA build error");
    }
    var packed_flag: u64 = layout_info.is_packed;
    if (packed_flag == 0) {
        emit("[ERROR] Tagged layout must be packed struct\n");
        diag_error("SSA build error");
    }
    var total_bits: u64 = packed_layout_total_bits(layout_info);
    var field_offset: u64 = packed_field_bit_offset(layout_info, m_safe.member);
    var field_width: u64 = packed_field_bit_width(layout_info, m_safe.member);
    var start_bit: u64 = 64 - total_bits;
    var shift_bits: u64 = start_bit + field_offset;
    var ok_val: u64 = shift_right(ctx, obj_reg, shift_bits);
    ok_val = mask_low_bits(ctx, ok_val, field_width);
    return ok_val;
}

func safe_member_struct_value(ctx: *BuilderCtx, m_safe: *AstMemberAccess, obj_reg: u64, ot: *TypeInfo) -> u64 {
    var struct_def2: *AstStructDef = ot.struct_def;
    if (struct_def2 == 0) {
        struct_def2 = get_struct_def(ot.struct_name);
    }
    if (struct_def2 == 0) {
        emit("[ERROR] Safe member access struct definition not found\n");
        diag_error("SSA build error");
    }
    var field_offset2: u64 = 0;
    var field_desc: *FieldDesc = 0;
    var found2: u64 = struct_find_field_desc_scoped(struct_def2, m_safe.parent, m_safe.member, &field_offset2, &field_desc);
    if (found2 == 0 || field_desc == 0) { return 0; }
    var fd: *FieldDesc = field_desc;
    var field_addr: u64 = obj_reg;
    if (field_offset2 != 0) {
        var off_reg3: u64 = build_const(ctx, field_offset2);
        var addr5: u64 = new_reg(ctx);
        var add_ptr4: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, addr5, operand_reg(obj_reg), operand_reg(off_reg3));
        append_inst(ctx.cur_block, add_ptr4);
        field_addr = addr5;
    }
    if (fd.type_kind == TYPE_STRUCT && fd.ptr_depth == 0) {
        return field_addr;
    }
    if (fd.type_kind == TYPE_ARRAY) {
        return field_addr;
    }
    if (fd.type_kind == TYPE_SLICE && fd.ptr_depth == 0) {
        return load_by_size(ctx, field_addr, 8);
    }
    var load_size: u64 = layout_field_sizeof(fd);
    if (load_size == 0) { load_size = 8; }
    if (load_size > 8) { load_size = 8; }
    return load_by_size(ctx, field_addr, load_size);
}

func safe_index_receiver_type(ctx: *BuilderCtx, base_safe: u64) -> *TypeInfo {
    var bt: *TypeInfo = get_expr_type_with_symtab((*AstNode)base_safe, ctx.symtab);
    if (bt == 0) {
        diag_emit_error_tag("ssa", "safe-index", "Safe index access type not found");
        diag_error("SSA build error");
        return 0;
    }
    if (bt.ptr_depth == 0) {
        emit_stderr("[ERROR] Safe index access requires pointer receiver\n");
        diag_error("SSA build error");
        return 0;
    }
    return bt;
}

func safe_index_emit_value(ctx: *BuilderCtx, node: u64, elem_addr: u64) -> u64 {
    var et: *TypeInfo = get_expr_type_with_symtab((*AstNode)node, ctx.symtab);
    if (et == 0) {
        return load_by_size(ctx, elem_addr, 8);
    }
    if (et.ptr_depth == 0) {
        if (et.type_kind == TYPE_STRUCT || et.type_kind == TYPE_ARRAY) {
            return elem_addr;
        }
        if (et.type_kind == TYPE_SLICE) {
            return load_by_size(ctx, elem_addr, 8);
        }
    }
    var load_size: u64 = type_size_from_expr(ctx, node);
    if (load_size == 0) { load_size = 8; }
    if (load_size > 8) { load_size = 8; }
    return load_by_size(ctx, elem_addr, load_size);
}

func expr_safe_index(ctx: *BuilderCtx, node: u64) -> u64 {
    var idx: *AstIndex = (*AstIndex)node;
    var bt: *TypeInfo = safe_index_receiver_type(ctx, idx.base);
    if (bt == 0) { return 0; }

    var null_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var ok_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var merge_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);

    var base_reg: u64 = build_expr(ctx, idx.base);
    if (bt.is_tagged == 1) {
        base_reg = mask_tagged_ptr(ctx, base_reg);
    }
    var cond_reg: u64 = build_bool_from_reg(ctx, base_reg);
    var br_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_BR, operand_const(null_bb.id), operand_reg(cond_reg), operand_const(ok_bb.id));
    append_inst(ctx.cur_block, br_ptr);
    connect_blocks(ctx.cur_block, ok_bb);
    connect_blocks(ctx.cur_block, null_bb);

    ctx.cur_block = null_bb;
    var null_val: u64 = build_const(ctx, 0);
    var jmp_null: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(merge_bb.id), 0);
    append_inst(ctx.cur_block, jmp_null);
    connect_blocks(ctx.cur_block, merge_bb);

    ctx.cur_block = ok_bb;
    var elem_size: u64 = get_pointee_size(bt.type_kind, bt.ptr_depth);
    if (bt.ptr_depth == 1 && bt.type_kind == TYPE_STRUCT) {
        elem_size = layout_type_sizeof(bt.type_kind, 0, bt.struct_name);
    }
    if (elem_size == 0) { elem_size = 8; }
    var idx_reg: u64 = build_expr(ctx, idx.index);
    if (elem_size != 1) {
        var elem_size_reg: u64 = build_const(ctx, elem_size);
        var scaled_idx: u64 = new_reg(ctx);
        var mul_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_MUL, scaled_idx, operand_reg(idx_reg), operand_reg(elem_size_reg));
        append_inst(ctx.cur_block, mul_ptr);
        idx_reg = scaled_idx;
    }
    var elem_addr: u64 = new_reg(ctx);
    var add_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, elem_addr, operand_reg(base_reg), operand_reg(idx_reg));
    append_inst(ctx.cur_block, add_ptr);
    var ok_val: u64 = safe_index_emit_value(ctx, node, elem_addr);
    var jmp_ok: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(merge_bb.id), 0);
    append_inst(ctx.cur_block, jmp_ok);
    connect_blocks(ctx.cur_block, merge_bb);

    ctx.cur_block = merge_bb;
    var head: *SSAPhiArg = create_phi_arg(null_val, null_bb.id);
    head = append_phi_arg(head, ok_val, ok_bb.id);
    var dest: u64 = new_reg(ctx);
    var phi_ptr: *SSAInstruction = create_phi(ctx.ssa_ctx, dest, head);
    append_phi(merge_bb, phi_ptr);
    return dest;
}

func expr_safe_member_access(ctx: *BuilderCtx, node: u64) -> u64 {
    var m_safe: *AstMemberAccess = (*AstMemberAccess)node;
    var obj_safe: u64 = m_safe.object;
    var ot: *TypeInfo = safe_member_receiver_type(ctx, obj_safe);
    if (ot == 0) { return 0; }

    var null_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var ok_bb2: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var merge_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);

    var obj_reg: u64 = build_expr(ctx, obj_safe);
    if (ot.is_tagged == 1) {
        obj_reg = mask_tagged_ptr(ctx, obj_reg);
    }
    var cond_reg2: u64 = build_bool_from_reg(ctx, obj_reg);
    var br_ptr2: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_BR, operand_const(null_bb.id), operand_reg(cond_reg2), operand_const(ok_bb2.id));
    append_inst(ctx.cur_block, br_ptr2);
    connect_blocks(ctx.cur_block, ok_bb2);
    connect_blocks(ctx.cur_block, null_bb);

    ctx.cur_block = null_bb;
    var null_val: u64 = build_const(ctx, 0);
    var jmp_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(merge_bb.id), 0);
    append_inst(ctx.cur_block, jmp_ptr);
    connect_blocks(ctx.cur_block, merge_bb);

    ctx.cur_block = ok_bb2;
    var ok_val: u64 = 0;
    if (ot.is_tagged == 1 && u8_slice_ptr(ot.tag_layout) != 0) {
        ok_val = safe_member_tagged_value(ctx, m_safe, obj_reg, ot);
    } else {
        ok_val = safe_member_struct_value(ctx, m_safe, obj_reg, ot);
        if (ok_val == 0) { return 0; }
    }
    var jmp_ptr2: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(merge_bb.id), 0);
    append_inst(ctx.cur_block, jmp_ptr2);
    connect_blocks(ctx.cur_block, merge_bb);

    ctx.cur_block = merge_bb;
    var head: *SSAPhiArg = create_phi_arg(null_val, null_bb.id);
    head = append_phi_arg(head, ok_val, ok_bb2.id);
    var dest: u64 = new_reg(ctx);
    var phi_ptr: *SSAInstruction = create_phi(ctx.ssa_ctx, dest, head);
    append_phi(merge_bb, phi_ptr);
    return dest;
}

func safe_method_arg_regs(ctx: *BuilderCtx, recv_reg: u64, args: *Vec<*AstNode>) -> *Vec<u64> {
    return make_call_arg_regs_nodes(ctx, args, call_prefix_one(recv_reg));
}

func safe_method_emit_trait_ptr_call(ctx: *BuilderCtx, smc: *AstMethodCall, recv_ti: *TypeInfo, recv_reg: u64, args: *Vec<*AstNode>, nargs: u64) -> u64 {
    var method_index: u64 = trait_find_trait_method_index(recv_ti.struct_name, smc.method);
    if (is_not_found_u64(method_index) != 0) {
        emit_stderr("[ERROR] Trait method not found: ");
        emit_stderr_len(u8_slice_ptr(smc.method), u8_slice_len(smc.method));
        emit_stderr("\n");
        return 0;
    }

    var arg_regs_t: *Vec<u64> = safe_method_arg_regs(ctx, recv_reg, args);
    var vtable_reg: u64 = load_by_size(ctx, recv_reg, 8);
    if (method_index != 0) {
        var off_reg_t: u64 = build_const(ctx, method_index * 8);
        var addr_t: u64 = new_reg(ctx);
        var add_ptr_t: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, addr_t, operand_reg(vtable_reg), operand_reg(off_reg_t));
        append_inst(ctx.cur_block, add_ptr_t);
        vtable_reg = addr_t;
    }
    var callee_reg: u64 = load_by_size(ctx, vtable_reg, 8);
    var call_val: u64 = new_reg(ctx);
    emit_call_ptr_raw(ctx, callee_reg, arg_regs_t, call_val, 0, TYPE_I64, 0, 0);
    return call_val;
}

func safe_method_emit_struct_ptr_call(ctx: *BuilderCtx, smc: *AstMethodCall, recv_ti: *TypeInfo, recv_mode: u64, recv_reg: u64, args: *Vec<*AstNode>, nargs: u64) -> u64 {
    if (recv_mode == COMPILER_SAFE_RECV_INVALID) {
        if (recv_ti.ptr_depth == 0) {
            emit_stderr("[ERROR] Safe method call requires pointer receiver\n");
            return 0;
        }
        emit_stderr("[ERROR] Safe method call requires struct pointer\n");
        return 0;
    }

    var arg_types: *Vec<*TypeInfo> = builder_collect_arg_types_for_method_resolution(args, ctx.symtab);
    var recv_owner_ptr: u64 = u8_slice_ptr(recv_ti.struct_name);
    var recv_owner_len: u64 = u8_slice_len(recv_ti.struct_name);
    if (recv_ti.struct_def != 0) {
        recv_owner_ptr = u8_slice_ptr(recv_ti.struct_def.name);
        recv_owner_len = u8_slice_len(recv_ti.struct_def.name);
    }

    if (recv_ti.ptr_depth > 0) {
        var virt_trait: *NameInfo = method_find_virtual_trait_name(recv_ti, slice(recv_owner_ptr, recv_owner_len), smc.method);
        if (virt_trait != 0) {
            var method_index_v: u64 = trait_find_trait_method_index(slice(virt_trait.ptr, virt_trait.len), smc.method);
            if (is_not_found_u64(method_index_v) != 0) {
                emit_stderr("[ERROR] Virtual method not found: ");
                emit_stderr_len(u8_slice_ptr(smc.method), u8_slice_len(smc.method));
                emit_stderr("\n");
                return 0;
            }
            var recv_offset_v: u64 = method_find_virtual_vptr_offset(recv_ti, slice(virt_trait.ptr, virt_trait.len));
            if (is_not_found_u64(recv_offset_v) != 0) {
                emit_stderr("[ERROR] virtual dispatch vptr not found: ");
                emit_stderr_len(recv_owner_ptr, recv_owner_len);
                emit_stderr("\n");
                return 0;
            }
            var ret_meta_v: BuilderCallRetMeta = call_ret_meta(ctx, (u64)smc, TYPE_I64, 0);
            if (ret_meta_v.ret_type == TYPE_STRUCT && ret_meta_v.ret_ptr_depth == 0) {
                emit_stderr("[ERROR] Safe method call cannot return struct by value\n");
                return 0;
            }
            var recv_vptr_addr: u64 = cast_adjust_add(ctx, recv_reg, recv_offset_v);
            var arg_regs_v: *Vec<u64> = safe_method_arg_regs(ctx, recv_vptr_addr, args);
            var callee_reg_v: u64 = virtual_dispatch_callee_reg(ctx, recv_reg, recv_offset_v, method_index_v);
            var call_val_v: u64 = new_reg(ctx);
            emit_call_ptr_raw(ctx, callee_reg_v, arg_regs_v, call_val_v, 0, ret_meta_v.ret_type, ret_meta_v.ret_ptr_depth, ret_meta_v.ret_struct_size);
            return call_val_v;
        }
    }

    var resolved_ptr: u64 = 0;
    var resolved_len: u64 = 0;
    var ret_type: u64 = TYPE_I64;
    var ret_ptr_depth: u64 = 0;
    var fn: *AstFunc = 0;
    var resolved_method: CompilerMethodResolveResult = sym_resolve_method_overload(slice(recv_owner_ptr, recv_owner_len), smc.method, arg_types, nargs);
    if (resolved_method.found != 0 && resolved_method.fn != 0) {
        fn = resolved_method.fn;
        resolved_ptr = u8_slice_ptr(fn.name);
        resolved_len = u8_slice_len(fn.name);
    } else {
        var name_info2: *NameInfo = build_method_name(slice(recv_owner_ptr, recv_owner_len), smc.method);
        resolved_ptr = name_info2.ptr;
        resolved_len = name_info2.len;
        var resolved2: *NameInfo = resolve_name(slice(name_info2.ptr, name_info2.len));
        if (resolved2 != 0) {
            resolved_ptr = resolved2.ptr;
            resolved_len = resolved2.len;
        }
        fn = typeinfo_find_func(slice(resolved_ptr, resolved_len));
    }
    if (fn != 0) {
        ret_type = fn.ret_type;
        ret_ptr_depth = fn.ret_ptr_depth;
        if (ret_type == TYPE_STRUCT && ret_ptr_depth == 0) {
            emit_stderr("[ERROR] Safe method call cannot return struct by value\n");
            return 0;
        }
    }

    var arg_regs: *Vec<u64> = safe_method_arg_regs(ctx, recv_reg, args);
    var call_val: u64 = new_reg(ctx);
    emit_call_name_raw(ctx, slice(resolved_ptr, resolved_len), arg_regs, call_val, 0, ret_type, ret_ptr_depth, 0);
    return call_val;
}

func expr_safe_method_call(ctx: *BuilderCtx, node: u64) -> u64 {
    var smc: *AstMethodCall = (*AstMethodCall)node;
    var receiver: u64 = smc.receiver;
    var args: *Vec<*AstNode> = smc.args_vec;
    var nargs: u64 = 0;
    if (args != 0) { nargs = args.len(); }

    var recv_ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)receiver, ctx.symtab);
    if (recv_ti == 0) {
        emit_stderr("[ERROR] Safe method call receiver type not found\n");
        return 0;
    }
    var recv_mode: u64 = safe_receiver_mode(recv_ti);

    var null_bb2: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var call_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var merge_bb2: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);

    var recv_reg: u64 = build_expr(ctx, receiver);
    if (recv_ti.is_tagged == 1) {
        recv_reg = mask_tagged_ptr(ctx, recv_reg);
    }
    var cond_reg3: u64 = build_bool_from_reg(ctx, recv_reg);
    var br_ptr3: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_BR, operand_const(null_bb2.id), operand_reg(cond_reg3), operand_const(call_bb.id));
    append_inst(ctx.cur_block, br_ptr3);
    connect_blocks(ctx.cur_block, call_bb);
    connect_blocks(ctx.cur_block, null_bb2);

    ctx.cur_block = null_bb2;
    var null_val2: u64 = build_const(ctx, 0);
    var jmp_ptr3: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(merge_bb2.id), 0);
    append_inst(ctx.cur_block, jmp_ptr3);
    connect_blocks(ctx.cur_block, merge_bb2);

    ctx.cur_block = call_bb;
    var call_val: u64 = 0;
    if (recv_mode == COMPILER_SAFE_RECV_TRAIT_PTR) {
        call_val = safe_method_emit_trait_ptr_call(ctx, smc, recv_ti, recv_reg, args, nargs);
    } else {
        call_val = safe_method_emit_struct_ptr_call(ctx, smc, recv_ti, recv_mode, recv_reg, args, nargs);
    }
    if (call_val == 0) { return 0; }

    var jmp_ptr4: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(merge_bb2.id), 0);
    append_inst(ctx.cur_block, jmp_ptr4);
    connect_blocks(ctx.cur_block, merge_bb2);

    ctx.cur_block = merge_bb2;
    var head2: *SSAPhiArg = create_phi_arg(null_val2, null_bb2.id);
    head2 = append_phi_arg(head2, call_val, call_bb.id);
    var dest2: u64 = new_reg(ctx);
    var phi_ptr2: *SSAInstruction = create_phi(ctx.ssa_ctx, dest2, head2);
    append_phi(merge_bb2, phi_ptr2);
    return dest2;
}

func emit_call_by_kind(ctx: *BuilderCtx, call_kind: u64, call_node: u64, dst: u64, extra_dst: u64) -> u64 {
    if (call_kind == AST_CALL) {
        emit_call(ctx, (*AstCall)call_node, dst, extra_dst);
        return 1;
    }
    if (call_kind == AST_METHOD_CALL) {
        emit_method_call_value(ctx, (*AstMethodCall)call_node, dst, extra_dst);
        return 1;
    }
    if (call_kind == AST_CALL_PTR) {
        emit_call_ptr(ctx, (*AstCallPtr)call_node, dst, extra_dst);
        return 1;
    }
    return 0;
}

func member_load_from_base_with_offset(ctx: *BuilderCtx, base_addr: u64, field_offset: u64, field_size: u64) -> u64 {
    var field_addr: u64 = base_addr;
    if (field_offset != 0) {
        var off_reg: u64 = build_const(ctx, field_offset);
        var addr2: u64 = new_reg(ctx);
        var add_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, addr2, operand_reg(base_addr), operand_reg(off_reg));
        append_inst(ctx.cur_block, add_ptr);
        field_addr = addr2;
    }
    return load_by_size(ctx, field_addr, field_size);
}

func member_extract_from_small_struct_call(ctx: *BuilderCtx, call_kind: u64, call_node: u64, struct_size: u64, field_offset: u64, field_size: u64) -> u64 {
    if (field_offset + field_size <= 8) {
        var lo_reg: u64 = new_reg(ctx);
        if (emit_call_by_kind(ctx, call_kind, call_node, lo_reg, 0) == 0) {
            return 0;
        }
        if (field_offset == 0) { return lo_reg; }
        var shift_amt: u64 = field_offset * 8;
        return shift_right(ctx, lo_reg, shift_amt);
    }
    if (field_offset >= 8 && field_offset + field_size <= 16) {
        var lo_reg2: u64 = new_reg(ctx);
        var hi_reg: u64 = new_reg(ctx);
        if (emit_call_by_kind(ctx, call_kind, call_node, lo_reg2, hi_reg) == 0) {
            return 0;
        }
        if (field_offset == 8) { return hi_reg; }
        var shift_amt2: u64 = (field_offset - 8) * 8;
        return shift_right(ctx, hi_reg, shift_amt2);
    }
    var lo_reg_span: u64 = new_reg(ctx);
    var hi_reg_span: u64 = new_reg(ctx);
    if (emit_call_by_kind(ctx, call_kind, call_node, lo_reg_span, hi_reg_span) == 0) {
        return 0;
    }
    return extract_field_from_small_struct_regs(ctx, lo_reg_span, hi_reg_span, struct_size, field_offset, field_size);
}

func member_resolve_field_info(ctx: *BuilderCtx, node: u64, m: *AstMemberAccess, struct_def: *AstStructDef) -> BuilderMemberFieldInfo {
    var info: BuilderMemberFieldInfo;
    info.found = 0;
    info.field_offset = 0;
    info.field_size = 0;
    if (struct_def == 0) { return info; }
    var field_offset: u64 = 0;
    var field_desc: *FieldDesc = 0;
    var found: u64 = struct_find_field_desc_scoped(struct_def, m.parent, m.member, &field_offset, &field_desc);
    if (found == 0) { return info; }
    info.found = 1;
    info.field_offset = field_offset;
    if (field_desc != 0) {
        info.field_size = layout_field_sizeof(field_desc);
    }
    if (info.field_size == 0) {
        info.field_size = type_size_from_expr(ctx, node);
    }
    return info;
}

func member_access_struct_call(ctx: *BuilderCtx, node: u64, m: *AstMemberAccess, call_kind: u64, call_node: u64, struct_def: *AstStructDef, struct_size: u64, debug_prefix: u64) -> u64 {
    if (struct_def == 0 || struct_size == 0) { return 0; }
    var field_info: BuilderMemberFieldInfo = member_resolve_field_info(ctx, node, m, struct_def);
    if (field_info.found == 0) {
        return 0;
    }
    var field_offset: u64 = field_info.field_offset;
    var field_size: u64 = field_info.field_size;
    if (struct_size > 16) {
        var temp_offset: u64 = symtab_add(ctx.symtab, slice(0, 0), TYPE_STRUCT, 0, struct_size);
        var temp_addr: u64 = new_lea_local(ctx, temp_offset);
        if (emit_struct_call_sret_by_kind(ctx, call_kind, call_node, temp_addr) == 0) {
            return 0;
        }
        return member_load_from_base_with_offset(ctx, temp_addr, field_offset, field_size);
    }
    return member_extract_from_small_struct_call(ctx, call_kind, call_node, struct_size, field_offset, field_size);
}

func member_access_try_call(ctx: *BuilderCtx, node: u64, m: *AstMemberAccess, obj: u64, obj_kind: u64) -> BuilderMemberAccessAttempt {
    var attempt: BuilderMemberAccessAttempt;
    attempt.handled = 0;
    attempt.reg_val = 0;
    if (obj_kind != AST_CALL) { return attempt; }

    var call: *AstCall = (*AstCall)obj;
    var fn_ptr: *AstFunc = sym_get_func(call.name);
    if (fn_ptr == 0) {
        var fp_info2: *PtrLen = get_func_ptr(ctx, call.name);
        if (fp_info2 != 0) {
            var fp_struct_name2: []u8 = slice(fp_info2.ptr, fp_info2.len);
            var fp_struct_def2: *AstStructDef = get_struct_def(fp_struct_name2);
            if (fp_struct_def2 != 0) {
                var callee_tmp: *AstNode = ast_ident(call.name);
                var cp_tmp: *AstCallPtr = ast_call_ptr(callee_tmp, call.args_vec);
                var struct_size_fp2: u64 = struct_size_from_def(fp_struct_def2);
                if (struct_size_fp2 == 0) {
                    struct_size_fp2 = layout_type_sizeof(TYPE_STRUCT, 0, fp_struct_name2);
                }
                attempt.handled = 1;
                attempt.reg_val = member_access_struct_call(ctx, node, m, AST_CALL_PTR, (u64)cp_tmp, fp_struct_def2, struct_size_fp2, "[DEBUG] ssa member access call.ptr sret size=");
                return attempt;
            }
        }
    }

    if (fn_ptr != 0) {
        var fn: *AstFunc = (*AstFunc)fn_ptr;
        if (fn.ret_type == TYPE_STRUCT && fn.ret_ptr_depth == 0) {
            var struct_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, fn.ret_struct_name);
            var struct_def_call: *AstStructDef = get_struct_def(fn.ret_struct_name);
            if (struct_def_call != 0) {
                attempt.handled = 1;
                attempt.reg_val = member_access_struct_call(ctx, node, m, AST_CALL, (u64)call, struct_def_call, struct_size, "[DEBUG] ssa member access call sret size=");
                return attempt;
            }
        }
    }
    return attempt;
}

func member_access_try_typed_struct_call(ctx: *BuilderCtx, node: u64, m: *AstMemberAccess, obj: u64, obj_kind: u64, ti: *TypeInfo) -> BuilderMemberAccessAttempt {
    var attempt: BuilderMemberAccessAttempt;
    attempt.handled = 0;
    attempt.reg_val = 0;
    if (ti.ptr_depth != 0 || ti.type_kind != TYPE_STRUCT) { return attempt; }

    var struct_def: *AstStructDef = ti.struct_def;
    if (struct_def == 0 && u8_slice_ptr(ti.struct_name) != 0) {
        struct_def = get_struct_def(ti.struct_name);
    }
    if (struct_def == 0 && (obj_kind == AST_CALL || obj_kind == AST_CALL_PTR)) {
        if (obj_kind == AST_CALL) {
            var call_obj: *AstCall = (*AstCall)obj;
            var fn_obj: *AstFunc = sym_get_func(call_obj.name);
            if (fn_obj != 0) {
                if (u8_slice_ptr(fn_obj.ret_struct_name) != 0) {
                    struct_def = get_struct_def(fn_obj.ret_struct_name);
                    ti.struct_name = fn_obj.ret_struct_name;
                }
            }
        } else {
            var cp_obj: *AstCallPtr = (*AstCallPtr)obj;
            var callee_obj: u64 = cp_obj.callee;
            var name_obj: []u8 = slice(0, 0);
            var ck_obj: u64 = ast_kind(callee_obj);
            if (ck_obj == AST_IDENT) {
                var idn_obj: *AstIdent = (*AstIdent)callee_obj;
                name_obj = idn_obj.name;
            } else if (ck_obj == AST_ADDR_OF) {
                var a_obj: *AstAddrOf = (*AstAddrOf)callee_obj;
                if (ast_kind(a_obj.operand) == AST_IDENT) {
                    var idn_obj2: *AstIdent = (*AstIdent)a_obj.operand;
                    name_obj = idn_obj2.name;
                }
            }
            if (u8_slice_ptr(name_obj) != 0) {
                var resolved_obj_name: []u8 = name_obj;
                var resolved_obj: *NameInfo = resolve_name(name_obj);
                if (resolved_obj != 0) {
                    resolved_obj_name = slice(resolved_obj.ptr, resolved_obj.len);
                }
                var fn_obj2: *AstFunc = sym_get_func(resolved_obj_name);
                if (fn_obj2 != 0) {
                    if (u8_slice_ptr(fn_obj2.ret_struct_name) != 0) {
                        struct_def = get_struct_def(fn_obj2.ret_struct_name);
                        ti.struct_name = fn_obj2.ret_struct_name;
                    }
                }
            }
        }
    }
    if (struct_def != 0 && (obj_kind == AST_CALL || obj_kind == AST_METHOD_CALL || obj_kind == AST_CALL_PTR)) {
        var struct_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, ti.struct_name);
        var def_size2: u64 = struct_size_from_def(struct_def);
        if (def_size2 > struct_size) { struct_size = def_size2; }
        attempt.handled = 1;
        attempt.reg_val = member_access_struct_call(ctx, node, m, obj_kind, obj, struct_def, struct_size, "[DEBUG] ssa member access sret struct size=");
        return attempt;
    }
    return attempt;
}

func member_access_try_typed_tagged_packed(ctx: *BuilderCtx, m: *AstMemberAccess, obj: u64, ti: *TypeInfo) -> BuilderMemberAccessAttempt {
    var attempt: BuilderMemberAccessAttempt;
    attempt.handled = 0;
    attempt.reg_val = 0;
    if (ti.ptr_depth == 0 || ti.is_tagged != 1 || u8_slice_ptr(ti.tag_layout) == 0) { return attempt; }
    var layout_def: *AstStructDef = get_struct_def(ti.tag_layout);
    if (layout_def == 0) { return attempt; }
    var layout_info: *AstStructDef = layout_def;
    var packed_flag: u64 = layout_info.is_packed;
    if (packed_flag != 1) { return attempt; }
    var total_bits: u64 = packed_layout_total_bits(layout_def);
    var field_offset: u64 = packed_field_bit_offset(layout_def, m.member);
    var field_width: u64 = packed_field_bit_width(layout_def, m.member);
    var start_bit: u64 = 64 - total_bits;
    var shift_bits: u64 = start_bit + field_offset;
    var reg_val: u64 = build_expr(ctx, obj);
    reg_val = shift_right(ctx, reg_val, shift_bits);
    reg_val = mask_low_bits(ctx, reg_val, field_width);
    attempt.handled = 1;
    attempt.reg_val = reg_val;
    return attempt;
}

func member_access_try_typed_struct_packed(ctx: *BuilderCtx, m: *AstMemberAccess, obj: u64, ti: *TypeInfo) -> BuilderMemberAccessAttempt {
    var attempt: BuilderMemberAccessAttempt;
    attempt.handled = 0;
    attempt.reg_val = 0;
    if (ti.ptr_depth != 0 || ti.type_kind != TYPE_STRUCT) { return attempt; }
    var struct_def2: *AstStructDef = ti.struct_def;
    if (struct_def2 == 0 && u8_slice_ptr(ti.struct_name) != 0) {
        struct_def2 = get_struct_def(ti.struct_name);
    }
    if (struct_def2 == 0) { return attempt; }
    var struct_info2: *AstStructDef = struct_def2;
    var packed_flag2: u64 = struct_info2.is_packed;
    if (packed_flag2 != 1) { return attempt; }
    var total_bits2: u64 = packed_layout_total_bits(struct_def2);
    var field_offset2: u64 = packed_field_bit_offset(struct_def2, m.member);
    var field_width2: u64 = packed_field_bit_width(struct_def2, m.member);
    var base_addr: u64 = lvalue_addr(ctx, obj);
    if (base_addr == 0) { return attempt; }
    if ((field_offset2 % 8) == 0 && (field_width2 % 8) == 0) {
        var field_size2: u64 = field_width2 / 8;
        if (field_size2 != 0 && field_size2 <= 8) {
            var field_addr2: u64 = base_addr;
            if (field_offset2 != 0) {
                var off_reg2: u64 = build_const(ctx, field_offset2 / 8);
                var addr2: u64 = new_reg(ctx);
                var add_ptr2: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, addr2, operand_reg(base_addr), operand_reg(off_reg2));
                append_inst(ctx.cur_block, add_ptr2);
                field_addr2 = addr2;
            }
            attempt.handled = 1;
            attempt.reg_val = load_by_size(ctx, field_addr2, field_size2);
            return attempt;
        }
    }
    var shift_bits2: u64 = field_offset2;
    var size_bytes2: u64 = (total_bits2 + 7) / 8;
    var raw_val: u64 = load_by_size(ctx, base_addr, size_bytes2);
    raw_val = shift_right(ctx, raw_val, shift_bits2);
    raw_val = mask_low_bits(ctx, raw_val, field_width2);
    attempt.handled = 1;
    attempt.reg_val = raw_val;
    return attempt;
}

func member_access_try_typed(ctx: *BuilderCtx, node: u64, m: *AstMemberAccess, obj: u64, obj_kind: u64) -> BuilderMemberAccessAttempt {
    var attempt: BuilderMemberAccessAttempt;
    attempt.handled = 0;
    attempt.reg_val = 0;
    var ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)obj, ctx.symtab);
    if (ti == 0) { return attempt; }

    attempt = member_access_try_typed_struct_call(ctx, node, m, obj, obj_kind, ti);
    if (attempt.handled != 0) { return attempt; }

    attempt = member_access_try_typed_tagged_packed(ctx, m, obj, ti);
    if (attempt.handled != 0) { return attempt; }

    return member_access_try_typed_struct_packed(ctx, m, obj, ti);
}

func member_access_try_call_ptr_fp(ctx: *BuilderCtx, node: u64, m: *AstMemberAccess, obj: u64, obj_kind: u64) -> BuilderMemberAccessAttempt {
    var attempt: BuilderMemberAccessAttempt;
    attempt.handled = 0;
    attempt.reg_val = 0;
    if (obj_kind != AST_CALL_PTR) { return attempt; }
    var cp_fp: *AstCallPtr = (*AstCallPtr)obj;
    var callee_fp: u64 = cp_fp.callee;
    if (ast_kind(callee_fp) != AST_IDENT) { return attempt; }

    var idn_fp: *AstIdent = (*AstIdent)callee_fp;
    var fp_info: *PtrLen = get_func_ptr(ctx, idn_fp.name);
    if (fp_info == 0) { return attempt; }
    var fp_struct_name: []u8 = slice(fp_info.ptr, fp_info.len);
    var fp_struct_def: *AstStructDef = get_struct_def(fp_struct_name);
    if (fp_struct_def == 0) { return attempt; }

    var struct_size_fp: u64 = struct_size_from_def(fp_struct_def);
    if (struct_size_fp == 0) {
        struct_size_fp = layout_type_sizeof(TYPE_STRUCT, 0, fp_struct_name);
    }
    attempt.handled = 1;
    attempt.reg_val = member_access_struct_call(ctx, node, m, AST_CALL_PTR, obj, fp_struct_def, struct_size_fp, "[DEBUG] ssa member access call_ptr sret size=");
    return attempt;
}

func ssa_property_hook_find_field(ctx: *BuilderCtx, member_access: *AstMemberAccess, out_obj_ti: **TypeInfo) -> *FieldDesc {
    if (ctx == 0 || member_access == 0 || ctx.symtab == 0) { return 0; }
    if (out_obj_ti != 0) { *out_obj_ti = 0; }

    var obj_ti: *TypeInfo = get_expr_type_with_symtab(member_access.object, ctx.symtab);
    if (obj_ti == 0) { return 0; }
    if (out_obj_ti != 0) { *out_obj_ti = obj_ti; }
    if (obj_ti.type_kind != TYPE_STRUCT) { return 0; }

    var struct_def: *AstStructDef = obj_ti.struct_def;
    if (struct_def == 0 && u8_slice_ptr(obj_ti.struct_name) != 0 && u8_slice_len(obj_ti.struct_name) != 0) {
        struct_def = get_struct_def(obj_ti.struct_name);
    }
    if (struct_def == 0) { return 0; }

    var field: *FieldDesc = typeinfo_find_field_desc_scoped(struct_def, member_access.parent, member_access.member);
    if (field != 0 && check_field_access(field) == 0) {
        member_diag_access_denied(struct_def.name, member_access.member, field.access, 0);
        return 0;
    }
    return field;
}

func ssa_property_hook_build_self_arg(member_access: *AstMemberAccess, obj_ti: *TypeInfo) -> *AstNode {
    if (member_access == 0 || obj_ti == 0) { return 0; }
    if (obj_ti.ptr_depth > 0) {
        return member_access.object;
    }
    return (*AstNode)ast_addr_of(member_access.object);
}

func ssa_property_hook_build_getter_call(ctx: *BuilderCtx, member_access: *AstMemberAccess) -> *AstCall {
    if (ctx == 0 || member_access == 0 || member_access.is_raw != 0) { return 0; }

    var obj_ti: *TypeInfo = 0;
    var field_desc: *FieldDesc = ssa_property_hook_find_field(ctx, member_access, &obj_ti);
    if (field_desc == 0 || field_desc.getter_hook_mode == FIELD_HOOK_NONE) { return 0; }
    if (u8_slice_ptr(field_desc.getter_hook) == 0 || u8_slice_len(field_desc.getter_hook) == 0) { return 0; }

    var args: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((1) * sizeof(*AstNode)), 0, (1)};
    args.push(ssa_property_hook_build_self_arg(member_access, obj_ti));
    return ast_call_with_origin(field_desc.getter_hook, args, AST_CALL_ORIGIN_DIRECT);
}

func ssa_property_hook_build_setter_call(ctx: *BuilderCtx, member_access: *AstMemberAccess, value: *AstNode) -> *AstCall {
    if (ctx == 0 || member_access == 0 || value == 0 || member_access.is_raw != 0) { return 0; }

    var obj_ti: *TypeInfo = 0;
    var field_desc: *FieldDesc = ssa_property_hook_find_field(ctx, member_access, &obj_ti);
    if (field_desc == 0 || field_desc.setter_hook_mode == FIELD_HOOK_NONE) { return 0; }
    if (u8_slice_ptr(field_desc.setter_hook) == 0 || u8_slice_len(field_desc.setter_hook) == 0) { return 0; }

    var args: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((2) * sizeof(*AstNode)), 0, (2)};
    args.push(ssa_property_hook_build_self_arg(member_access, obj_ti));
    args.push(value);
    return ast_call_with_origin(field_desc.setter_hook, args, AST_CALL_ORIGIN_DIRECT);
}

func expr_member_access(ctx: *BuilderCtx, node: u64) -> u64 {
    var m: *AstMemberAccess = (*AstMemberAccess)node;
    var obj: u64 = m.object;
    var obj_kind: u64 = ast_kind(obj);

    if (obj_kind == AST_IDENT && u8_slice_ptr(m.parent) == 0) {
        var scope_id2: *AstIdent = (*AstIdent)obj;
        var scope_local_off: u64 = symtab_find(ctx.symtab, scope_id2.name);
        var scope_global: *GlobalInfo = sym_find_global_info(scope_id2.name);
        if (scope_global == 0) {
            var scope_resolved: *NameInfo = resolve_name(scope_id2.name);
            if (scope_resolved != 0) {
                scope_global = sym_find_global_info(slice(scope_resolved.ptr, scope_resolved.len));
            }
        }
        if (scope_local_off == 0 && scope_global == 0) {
            var scoped_const_expr: *ConstResult = (*ConstResult)sym_find_scoped_const(scope_id2.name, m.member);
            if (scoped_const_expr != 0 && scoped_const_expr.found != 0) {
                return build_const(ctx, scoped_const_expr.value);
            }
        }
    }

    var property_getter_call: *AstCall = ssa_property_hook_build_getter_call(ctx, m);
    if (property_getter_call != 0) {
        return build_expr(ctx, (*AstNode)property_getter_call);
    }

    var attempt: BuilderMemberAccessAttempt = member_access_try_call(ctx, node, m, obj, obj_kind);
    if (attempt.handled != 0) { return attempt.reg_val; }

    attempt = member_access_try_typed(ctx, node, m, obj, obj_kind);
    if (attempt.handled != 0) { return attempt.reg_val; }

    attempt = member_access_try_call_ptr_fp(ctx, node, m, obj, obj_kind);
    if (attempt.handled != 0) { return attempt.reg_val; }

    var addr_reg4: u64 = 0;
    var field_offset4: u64 = 0;
    var field_desc4: *FieldDesc = 0;
    if (member_resolve_addr_and_field(ctx, node, 0, &addr_reg4, &field_offset4, &field_desc4) != 0) {
        if (field_offset4 != 0) {
            var off_reg4: u64 = build_const(ctx, field_offset4);
            var addr_reg4_adjusted: u64 = new_reg(ctx);
            var add_ptr4: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, addr_reg4_adjusted, operand_reg(addr_reg4), operand_reg(off_reg4));
            append_inst(ctx.cur_block, add_ptr4);
            addr_reg4 = addr_reg4_adjusted;
        }
        if (field_desc4 != 0) {
            var field_size4: u64 = layout_field_sizeof(field_desc4);
            if (field_size4 != 0) {
                return load_by_size(ctx, addr_reg4, field_size4);
            }
        }
    }
    if (addr_reg4 == 0) { addr_reg4 = lvalue_addr(ctx, node); }
    var size4: u64 = type_size_from_expr(ctx, node);
    return load_by_size(ctx, addr_reg4, size4);
}

func expr_call(ctx: *BuilderCtx, node: u64) -> u64 {
    var call_ptr: u64 = node;
    var dst: u64 = new_reg(ctx);
    var ret_ti: *TypeInfo = builder_direct_call_result_type(ctx, (*AstCall)call_ptr);
    if (ret_ti != 0) {
        if (ret_ti.type_kind == TYPE_VOID && ret_ti.ptr_depth == 0) {
            dst = 0;
        }
        if (ret_ti.type_kind == TYPE_STRUCT && ret_ti.ptr_depth == 0) {
            var struct_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, ret_ti.struct_name);
            if (struct_size > 16) {
                var temp_offset: u64 = symtab_add(ctx.symtab, slice(0, 0), TYPE_STRUCT, 0, struct_size);
                var temp_addr: u64 = new_lea_local(ctx, temp_offset);
                emit_call_sret_value(ctx, (*AstCall)call_ptr, temp_addr);
                return temp_addr;
            }
        }
    }
    return emit_call(ctx, (*AstCall)call_ptr, dst, 0);
}

func expr_call_ptr(ctx: *BuilderCtx, node: u64) -> u64 {
    var cp_ptr: u64 = node;
    var dst: u64 = new_reg(ctx);
    var ret_ti: *TypeInfo = get_expr_type_with_symtab(node, ctx.symtab);
    if (ret_ti != 0) {
        if (ret_ti.type_kind == TYPE_VOID && ret_ti.ptr_depth == 0) {
            dst = 0;
        }
        if (ret_ti.type_kind == TYPE_STRUCT && ret_ti.ptr_depth == 0) {
            var struct_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, ret_ti.struct_name);
            if (struct_size > 16) {
                var temp_offset: u64 = symtab_add(ctx.symtab, slice(0, 0), TYPE_STRUCT, 0, struct_size);
                var temp_addr: u64 = new_lea_local(ctx, temp_offset);
                emit_call_ptr_sret(ctx, (*AstCallPtr)cp_ptr, temp_addr);
                return temp_addr;
            }
        }
    }
    return emit_call_ptr(ctx, (*AstCallPtr)cp_ptr, dst, 0);
}

func expr_method_call(ctx: *BuilderCtx, node: u64) -> u64 {
    var mc_ptr: u64 = node;
    var dst: u64 = new_reg(ctx);
    var ret_ti: *TypeInfo = get_expr_type_with_symtab(node, ctx.symtab);
    if (ret_ti != 0) {
        if (ret_ti.type_kind == TYPE_VOID && ret_ti.ptr_depth == 0) {
            dst = 0;
        }
        if (ret_ti.type_kind == TYPE_STRUCT && ret_ti.ptr_depth == 0) {
            var struct_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, ret_ti.struct_name);
            if (struct_size > 16) {
                var temp_offset: u64 = symtab_add(ctx.symtab, slice(0, 0), TYPE_STRUCT, 0, struct_size);
                var temp_addr: u64 = new_lea_local(ctx, temp_offset);
                emit_method_call_sret(ctx, (*AstMethodCall)mc_ptr, temp_addr);
                return temp_addr;
            }
        }
    }
    return emit_method_call_value(ctx, (*AstMethodCall)mc_ptr, dst, 0);
}

func ssa_return_is_strict_value_type(type_kind: u64, ptr_depth: u64) -> u64 {
    if (ptr_depth != 0) { return 0; }
    if (type_kind == TYPE_STRUCT) { return 1; }
    if (type_kind == TYPE_TRAIT) { return 1; }
    if (type_kind == TYPE_GENERIC) { return 1; }
    if (type_kind == TYPE_ARRAY) { return 1; }
    if (type_kind == TYPE_SLICE) { return 1; }
    return 0;
}

func ssa_return_is_zero_literal(expr: u64) -> u64 {
    if (expr == 0) { return 0; }
    if (ast_kind(expr) != AST_LITERAL) { return 0; }
    var lit: *AstLiteral = (*AstLiteral)expr;
    return (lit.value == 0);
}

func ssa_return_emit_type_mismatch() -> u64 {
    if (ssa_builder_diag_suppressed() != 0) { return 0; }
    emit_stderr("[ERROR] return type mismatch\n");
    diag_error("SSA build error");
    return 0;
}

func ssa_return_validate_expr(ctx: *BuilderCtx, expr: u64) -> u64 {
    var ret_type: u64 = ret_type_current();
    var ret_ptr_depth: u64 = ret_ptr_depth_current();
    var ret_struct_name: []u8 = ret_struct_name_current();

    if (expr == 0) { return 1; }

    var actual_ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)expr, ctx.symtab);
    if (actual_ti == 0) { return 1; }
    if (ssa_return_is_strict_value_type(ret_type, ret_ptr_depth) == 0) { return 1; }
    if (ssa_return_is_zero_literal(expr) != 0) { return 1; }
    if (ast_kind((*AstNode)expr) == AST_LITERAL) {
        if (ret_ptr_depth == 0 &&
            (ret_type == TYPE_BOOL || ret_type == TYPE_U8 || ret_type == TYPE_I8 ||
             ret_type == TYPE_U16 || ret_type == TYPE_I16 || ret_type == TYPE_U32 ||
             ret_type == TYPE_I32 || ret_type == TYPE_U64 || ret_type == TYPE_I64)) {
            return 1;
        }
    }
    if (ast_kind((*AstNode)expr) == AST_FLOAT && ret_ptr_depth == 0 && ret_type == TYPE_F64) {
        return 1;
    }

    if (ret_type == TYPE_STRUCT || ret_type == TYPE_TRAIT || ret_type == TYPE_GENERIC) {
        if (actual_ti.type_kind != ret_type || actual_ti.ptr_depth != ret_ptr_depth) {
            ssa_return_emit_type_mismatch();
            return 0;
        }
        if (u8_slice_ptr(ret_struct_name) != 0 && u8_slice_len(ret_struct_name) != 0 &&
            u8_slice_ptr(actual_ti.struct_name) != 0 && u8_slice_len(actual_ti.struct_name) != 0 &&
            str_eq(actual_ti.struct_name, ret_struct_name) == 0) {
            ssa_return_emit_type_mismatch();
            return 0;
        }
        return 1;
    }

    if (ret_type == TYPE_ARRAY || ret_type == TYPE_SLICE) {
        if (actual_ti.type_kind != ret_type || actual_ti.ptr_depth != ret_ptr_depth) {
            ssa_return_emit_type_mismatch();
            return 0;
        }
        return 1;
    }

    if (actual_ti.type_kind == ret_type && actual_ti.ptr_depth == ret_ptr_depth) {
        return 1;
    }

    ssa_return_emit_type_mismatch();
    return 0;
}

func expr_float(ctx: *BuilderCtx, node: u64) -> u64 {
    var fl: *AstFloat = (*AstFloat)node;
    var info: *PtrLen = new PtrLen{u8_slice_ptr(fl.str), u8_slice_len(fl.str)};
    var reg_id: u64 = new_reg(ctx);
    var inst_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_FCONST, reg_id, operand_const((u64)info), 0);
    append_inst(ctx.cur_block, inst_ptr);
    return reg_id;
}

func expr_string(ctx: *BuilderCtx, node: u64) -> u64 {
    var s: *AstString = (*AstString)node;
    var info: *PtrLen = new PtrLen{u8_slice_ptr(s.str), u8_slice_len(s.str)};
    var reg_id: u64 = new_reg(ctx);
    var inst_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_LEA_STR, reg_id, operand_const((u64)info), 0);
    append_inst(ctx.cur_block, inst_ptr);
    return reg_id;
}

func expr_stack_ctor_value(ctx: *BuilderCtx, node: u64) -> u64 {
    var sc: *AstStackCtor = (*AstStackCtor)node;
    var sc_ti: *TypeInfo = get_expr_type_with_symtab(node, ctx.symtab);
    if (sc_ti == 0 || sc_ti.type_kind != TYPE_STRUCT || sc_ti.ptr_depth != 0) {
        emit_stderr("[ERROR] stack constructor expression requires struct value\n");
        diag_error("SSA build error");
    }
    var sc_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, sc_ti.struct_name);
    var tmp_offset: u64 = symtab_add(ctx.symtab, slice(0, 0), TYPE_STRUCT, 0, sc_size);
    var base_addr: u64 = new_lea_local(ctx, tmp_offset);
    stack_ctor_init_at_addr(ctx, sc, base_addr);
    if (sc_size <= 8) {
        return load_by_size(ctx, base_addr, sc_size);
    }
    if (sc_size <= 16) {
        if (ctx.debug_mode != 0) {
            emit("[DEBUG] stack ctor expr returns lo only (hi handled in callers)\n");
        }
        return load_by_size(ctx, base_addr, 8);
    }
    return base_addr;
}

func expr_deref8(ctx: *BuilderCtx, node: u64) -> u64 {
    var d8: *AstDeref8 = (*AstDeref8)node;
    var addr_reg: u64 = build_expr(ctx, d8.operand);
    var op_ti: *TypeInfo = get_expr_type_with_symtab(d8.operand, ctx.symtab);
    if (op_ti != 0 && op_ti.is_tagged == 1) {
        addr_reg = mask_tagged_ptr(ctx, addr_reg);
    }
    return load_by_size(ctx, addr_reg, 1);
}

func expr_deref(ctx: *BuilderCtx, node: u64) -> u64 {
    var d: *AstDeref = (*AstDeref)node;
    var addr_reg: u64 = build_expr(ctx, d.operand);
    var op_ti: *TypeInfo = get_expr_type_with_symtab(d.operand, ctx.symtab);
    if (op_ti != 0 && op_ti.is_tagged == 1) {
        addr_reg = mask_tagged_ptr(ctx, addr_reg);
    }
    var size: u64 = type_size_from_expr(ctx, node);
    return load_by_size(ctx, addr_reg, size);
}

func expr_sizeof(ctx: *BuilderCtx, node: u64) -> u64 {
    var sz: *AstSizeof = (*AstSizeof)node;
    var size_val: u64 = 0;
    if (sz.type_kind == TYPE_ARRAY || sz.type_kind == TYPE_SLICE) {
        if (sz.array_len_is_param != 0) {
            emit_stderr("[ERROR] sizeof array with unresolved generic length\n");
            diag_error("SSA build error");
        }
        var ti_ptr: *TypeInfo = 0;
        if (sz.type_kind == TYPE_ARRAY) {
            ti_ptr = typeinfo_make_array(sz.ptr_depth, sz.elem_type_kind, sz.elem_ptr_depth, sz.struct_name, 0, sz.array_len);
        } else {
            ti_ptr = typeinfo_make_slice(sz.ptr_depth, sz.elem_type_kind, sz.elem_ptr_depth, sz.struct_name, 0);
        }
        ti_ptr.elem_typeinfo = sz.elem_typeinfo;
        size_val = sizeof_type_ex(ti_ptr);
    } else {
        size_val = layout_type_sizeof(sz.type_kind, sz.ptr_depth, sz.struct_name);
    }
    return build_const(ctx, size_val);
}

func expr_sizeof_expr(ctx: *BuilderCtx, node: u64) -> u64 {
    var sz_expr: *AstSizeofExpr = (*AstSizeofExpr)node;
    var ti_ptr: *TypeInfo = get_expr_type_with_symtab(sz_expr.expr, ctx.symtab);
    var size_val: u64 = 8;
    if (ti_ptr != 0) {
        size_val = sizeof_type_ex(ti_ptr);
    }
    return build_const(ctx, size_val);
}

func cast_adjust_add(ctx: *BuilderCtx, base_reg: u64, offset: u64) -> u64 {
    if (offset == 0) { return base_reg; }
    var off_reg: u64 = build_const(ctx, offset);
    var out_reg: u64 = new_reg(ctx);
    var add_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, out_reg, operand_reg(base_reg), operand_reg(off_reg));
    append_inst(ctx.cur_block, add_ptr);
    return out_reg;
}

func cast_adjust_sub(ctx: *BuilderCtx, base_reg: u64, offset: u64) -> u64 {
    if (offset == 0) { return base_reg; }
    var off_reg: u64 = build_const(ctx, offset);
    var out_reg: u64 = new_reg(ctx);
    var sub_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_SUB, out_reg, operand_reg(base_reg), operand_reg(off_reg));
    append_inst(ctx.cur_block, sub_ptr);
    return out_reg;
}

func emit_trap_ud2(ctx: *BuilderCtx) -> u64 {
    var text_vec: *Vec<u64> = new Vec<u64>{heap_alloc((4) * sizeof(u64)), 0, (4)};
    text_vec.push(117); // 'u'
    text_vec.push(100); // 'd'
    text_vec.push(50);  // '2'
    text_vec.push(10);  // '\n'
    var inst_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ASM, 0, operand_const((u64)text_vec), 0);
    append_inst(ctx.cur_block, inst_ptr);
    return 0;
}

func load_vtable_ptr(ctx: *BuilderCtx, base_reg: u64, vptr_offset: u64) -> u64 {
    var vptr_addr: u64 = cast_adjust_add(ctx, base_reg, vptr_offset);
    return load_by_size(ctx, vptr_addr, 8);
}

func method_find_virtual_vptr_offset(recv_ti: *TypeInfo, trait_slice: []u8) -> u64 {
    if (recv_ti == 0) { return COMPILER_NOT_FOUND_U64; }
    var struct_def: *AstStructDef = recv_ti.struct_def;
    if (struct_def == 0) {
        struct_def = get_struct_def(recv_ti.struct_name);
    }
    if (struct_def == 0) { return COMPILER_NOT_FOUND_U64; }
    var vptr_name: *NameInfo = trait_build_vptr_field_name(slice(trait_slice.ptr, trait_slice.len));
    var field_offset: u64 = 0;
    var field_desc: *FieldDesc = 0;
    var found: u64 = struct_find_field_desc_scoped(struct_def, slice(0, 0), slice(vptr_name.ptr, vptr_name.len), &field_offset, &field_desc);
    if (found == 0) { return COMPILER_NOT_FOUND_U64; }
    return field_offset;
}

func method_find_virtual_trait_name(recv_ti: *TypeInfo, recv_owner: []u8, method: []u8) -> *NameInfo {
    var virt_trait: *NameInfo = vdispatch_find_trait(slice(recv_owner.ptr, recv_owner.len), slice(method.ptr, method.len));
    if (virt_trait != 0) { return virt_trait; }
    if (recv_ti == 0) { return 0; }

    var recv_def: *AstStructDef = recv_ti.struct_def;
    if (recv_def == 0 && recv_owner.ptr != 0 && recv_owner.len != 0) {
        recv_def = get_struct_def(slice(recv_owner.ptr, recv_owner.len));
    }
    if (recv_def == 0 && u8_slice_ptr(recv_ti.struct_name) != 0 && u8_slice_len(recv_ti.struct_name) != 0) {
        recv_def = get_struct_def(recv_ti.struct_name);
    }
    if (recv_def == 0) { return 0; }

    var abst_lookup: CompilerDeclLookup = vdispatch_find_abst_decl_in_hierarchy(recv_def, slice(method.ptr, method.len));
    if (abst_lookup.found == 0 || u8_slice_ptr(abst_lookup.owner) == 0 || u8_slice_len(abst_lookup.owner) == 0) {
        return 0;
    }

    var trait_name: *NameInfo = vdispatch_build_virtual_trait_name(abst_lookup.owner);
    if (trait_name == 0) { return 0; }
    if (sym_get_trait_def(slice(trait_name.ptr, trait_name.len)) == 0) { return 0; }
    return trait_name;
}

func emit_checked_vtable_guard(ctx: *BuilderCtx, loaded_vtable_reg: u64, expected_vtable: []u8) -> u64 {
    if (expected_vtable.ptr == 0 || expected_vtable.len == 0) { return 0; }
    var expected_reg: u64 = new_lea_global(ctx, slice(expected_vtable.ptr, expected_vtable.len));
    var cond_reg: u64 = new_reg(ctx);
    var cmp_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_EQ, cond_reg, operand_reg(loaded_vtable_reg), operand_reg(expected_reg));
    append_inst(ctx.cur_block, cmp_ptr);

    var ok_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var fail_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var br_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_BR, operand_const(fail_bb.id), operand_reg(cond_reg), operand_const(ok_bb.id));
    append_inst(ctx.cur_block, br_ptr);
    connect_blocks(ctx.cur_block, ok_bb);
    connect_blocks(ctx.cur_block, fail_bb);

    ctx.cur_block = fail_bb;
    emit_trap_ud2(ctx);
    var jmp_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(ok_bb.id), 0);
    append_inst(ctx.cur_block, jmp_ptr);
    connect_blocks(ctx.cur_block, ok_bb);

    ctx.cur_block = ok_bb;
    return 0;
}

func cast_try_adjust_struct_ptr(ctx: *BuilderCtx, src_ti: *TypeInfo, target_struct: []u8, src_reg: u64) -> u64 {
    if (src_ti == 0) { return src_reg; }
    if (src_ti.type_kind != TYPE_STRUCT || src_ti.ptr_depth == 0) { return src_reg; }
    if (target_struct.ptr == 0 || target_struct.len == 0) { return src_reg; }

    var src_def: *AstStructDef = get_struct_def(src_ti.struct_name);
    if (src_def != 0) {
        var up_offset: u64 = 0;
        var up_def: *AstStructDef = 0;
        if (typeinfo_find_parent_offset(src_def, slice(target_struct.ptr, target_struct.len), &up_offset, &up_def) != 0) {
            return cast_adjust_add(ctx, src_reg, up_offset);
        }
    }

    var target_def: *AstStructDef = get_struct_def(slice(target_struct.ptr, target_struct.len));
    if (target_def != 0) {
        var down_offset: u64 = 0;
        var down_def: *AstStructDef = 0;
        if (typeinfo_find_parent_offset(target_def, src_ti.struct_name, &down_offset, &down_def) != 0) {
            return cast_adjust_sub(ctx, src_reg, down_offset);
        }
    }

    return src_reg;
}

func expr_cast(ctx: *BuilderCtx, node: u64) -> u64 {
    var cast: *AstCast = (*AstCast)node;
    var src_reg: u64 = build_expr(ctx, cast.expr);
    var src_ti: *TypeInfo = get_expr_type_with_symtab(cast.expr, ctx.symtab);

    if (cast.target_type == TYPE_TRAIT) {
        if (src_ti == 0 || src_ti.type_kind != TYPE_STRUCT || src_ti.ptr_depth == 0) {
            emit_stderr("[ERROR] Trait cast requires struct pointer source\n");
            diag_error("SSA build error");
        }
        var impl_info: *TraitImpl = trait_find_trait_impl(cast.struct_name, src_ti.struct_name);
        if (impl_info == 0) {
            emit_stderr("[ERROR] Struct does not implement trait for cast: ");
            emit_stderr_len(u8_slice_ptr(cast.struct_name), u8_slice_len(cast.struct_name));
            emit_stderr("\n");
            diag_error("SSA build error");
        }
        var struct_def: *AstStructDef = get_struct_def(src_ti.struct_name);
        var vptr_name: *NameInfo = trait_build_vptr_field_name(cast.struct_name);
        var field_offset: u64 = 0;
        var field_desc: *FieldDesc = 0;
        var found: u64 = struct_find_field_desc_scoped(struct_def, slice(0, 0), slice(vptr_name.ptr, vptr_name.len), &field_offset, &field_desc);
        if (found == 0) {
            emit_stderr("[ERROR] vptr field not found for trait cast\n");
            diag_error("SSA build error");
        }
        if (src_ti.is_tagged == 1) {
            src_reg = mask_tagged_ptr(ctx, src_reg);
        }
        return cast_adjust_add(ctx, src_reg, field_offset);
    }

    if (cast.target_type == TYPE_STRUCT) {
        if (src_ti != 0 && src_ti.type_kind == TYPE_TRAIT && src_ti.ptr_depth > 0) {
            var impl2: *TraitImpl = trait_find_trait_impl(src_ti.struct_name, cast.struct_name);
            if (impl2 == 0) {
                emit_stderr("[ERROR] Trait cast target struct does not implement trait: ");
                emit_stderr_len(u8_slice_ptr(cast.struct_name), u8_slice_len(cast.struct_name));
                emit_stderr("\n");
                diag_error("SSA build error");
            }
            var struct_def2: *AstStructDef = get_struct_def(cast.struct_name);
            var vptr_name2: *NameInfo = trait_build_vptr_field_name(src_ti.struct_name);
            var field_offset2: u64 = 0;
            var field_desc2: *FieldDesc = 0;
            var found2: u64 = struct_find_field_desc_scoped(struct_def2, slice(0, 0), slice(vptr_name2.ptr, vptr_name2.len), &field_offset2, &field_desc2);
            if (found2 == 0) {
                emit_stderr("[ERROR] vptr field not found for trait cast\n");
                diag_error("SSA build error");
            }
            if (src_ti.is_tagged == 1) {
                src_reg = mask_tagged_ptr(ctx, src_reg);
            }
            var loaded_vtable_reg: u64 = load_vtable_ptr(ctx, src_reg, 0);
            emit_checked_vtable_guard(ctx, loaded_vtable_reg, impl2.vtable_global);
            return cast_adjust_sub(ctx, src_reg, field_offset2);
        }

        if (cast.target_ptr_depth > 0 && src_ti != 0 && src_ti.type_kind == TYPE_STRUCT && src_ti.ptr_depth > 0) {
            if (src_ti.is_tagged == 1) {
                src_reg = mask_tagged_ptr(ctx, src_reg);
            }
            if (trait_is_strict_downcast(src_ti.struct_name, cast.struct_name) != 0) {
                var check_info: CompilerDowncastCheckInfo = trait_require_checked_struct_downcast_info(src_ti.struct_name, cast.struct_name);
                if (check_info.found != 0) {
                    var loaded_vtable_reg2: u64 = load_vtable_ptr(ctx, src_reg, check_info.src_vptr_offset);
                    emit_checked_vtable_guard(ctx, loaded_vtable_reg2, check_info.expected_vtable);
                }
            }
            return cast_try_adjust_struct_ptr(ctx, src_ti, cast.struct_name, src_reg);
        }
    }

    if (src_ti != 0 && src_ti.ptr_depth == 0 && cast.target_ptr_depth == 0) {
        var src_kind: u64 = src_ti.type_kind;
        var target_kind: u64 = cast.target_type;
        if (src_kind == target_kind) {
            return src_reg;
        }
        if (cast_is_int_scalar(src_kind) != 0 && cast_is_int_scalar(target_kind) != 0) {
            return cast_int_truncate(ctx, src_reg, target_kind);
        }
        if (cast_is_int_scalar(src_kind) != 0 && target_kind == TYPE_F64) {
            var norm_reg: u64 = src_reg;
            if (src_kind == TYPE_BOOL || src_kind == TYPE_U8 || src_kind == TYPE_U16 || src_kind == TYPE_U32 ||
                src_kind == TYPE_I8 || src_kind == TYPE_I16 || src_kind == TYPE_I32) {
                norm_reg = cast_int_truncate(ctx, src_reg, src_kind);
            }
            var is_unsigned: u64 = 1;
            if (src_kind == TYPE_I8 || src_kind == TYPE_I16 || src_kind == TYPE_I32 || src_kind == TYPE_I64) { is_unsigned = 0; }
            return cast_emit_i2f(ctx, norm_reg, is_unsigned);
        }
        if (src_kind == TYPE_F64 && cast_is_int_scalar(target_kind) != 0) {
            var target_unsigned: u64 = 1;
            if (target_kind == TYPE_I8 || target_kind == TYPE_I16 || target_kind == TYPE_I32 || target_kind == TYPE_I64) { target_unsigned = 0; }
            var int_reg: u64 = cast_emit_f2i(ctx, src_reg, target_unsigned);
            return cast_int_truncate(ctx, int_reg, target_kind);
        }
    }

    return src_reg;
}

func build_expr(ctx: *BuilderCtx, node: u64) -> u64 {
    push_trace("build_expr", "ssa_builder.b", __LINE__);
    defer pop_trace();
    if (node == 0) { return 0; }
    var kind: u64 = ast_kind(node);

    if (kind == AST_LITERAL) {
        var lit: *AstLiteral = (*AstLiteral)node;
        return build_const(ctx, lit.value);
    }

    if (kind == AST_FLOAT) { return expr_float(ctx, node); }

    if (kind == AST_STRING) { return expr_string(ctx, node); }

    if (kind == AST_NEW) {
        return expr_new(ctx, node);
    }

    if (kind == AST_STACK_CTOR) { return expr_stack_ctor_value(ctx, node); }

    if (kind == AST_IDENT) {
        return expr_ident(ctx, node);
    }

    if (kind == AST_BINARY) {
        return expr_binary(ctx, node);
    }

    if (kind == AST_TERNARY) {
        return expr_ternary(ctx, node);
    }

    if (kind == AST_UNARY) {
        return expr_unary(ctx, node);
    }

    if (kind == AST_TRY) {
        return build_try_expr(ctx, node);
    }

    if (kind == AST_SAFE_MEMBER_ACCESS) {
        return expr_safe_member_access(ctx, node);
    }

    if (kind == AST_SAFE_METHOD_CALL) {
        return expr_safe_method_call(ctx, node);
    }

    if (kind == AST_SAFE_INDEX) {
        return expr_safe_index(ctx, node);
    }

    if (kind == AST_ADDR_OF) {
        var a: *AstAddrOf = (*AstAddrOf)node;
        return lvalue_addr(ctx, a.operand);
    }

    if (kind == AST_DEREF8) { return expr_deref8(ctx, node); }

    if (kind == AST_DEREF) { return expr_deref(ctx, node); }

    if (kind == AST_INDEX) {
        var addr_reg3: u64 = lvalue_addr(ctx, node);
        var size3: u64 = type_size_from_expr(ctx, node);
        return load_by_size(ctx, addr_reg3, size3);
    }

    if (kind == AST_MEMBER_ACCESS) {
        return expr_member_access(ctx, node);
    }

    if (kind == AST_CAST) {
        return expr_cast(ctx, node);
    }

    if (kind == AST_SIZEOF) { return expr_sizeof(ctx, node); }

    if (kind == AST_SIZEOF_EXPR) { return expr_sizeof_expr(ctx, node); }

    if (kind == AST_CALL) {
        return expr_call(ctx, node);
    }

    if (kind == AST_CALL_PTR) {
        return expr_call_ptr(ctx, node);
    }

    if (kind == AST_METHOD_CALL) {
        return expr_method_call(ctx, node);
    }

    return build_const(ctx, 0);
}

// ============================================
// CFG Builders
// ============================================

func build_block(ctx: *BuilderCtx, block_node: u64) -> u64 {
    push_trace("build_block", "ssa_builder.b", __LINE__);
    defer pop_trace();
    if (block_node == 0) { return 0; }
    var blk: *AstBlock = (*AstBlock)block_node;
    var stmts: *Vec<u64> = blk.stmts_vec;
    defer_mark_block_begin(ctx);
    var n: u64 = stmts.len();
    for (var i: u64 = 0; i < n; i++) {
        var stmt: u64 = stmts.get(i);
        build_stmt(ctx, stmt);
    }
    defer_mark_block_end(ctx);
    return 0;
}

func build_for(ctx: *BuilderCtx, node: u64) -> u64 {
    push_trace("build_for", "ssa_builder.b", __LINE__);
    defer pop_trace();
    var f: *AstFor = (*AstFor)node;

    if (f.init != 0) {
        stmt_or_expr(ctx, f.init);
    }

    var cond_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var body_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var update_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var exit_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);

    var jmp_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(cond_bb.id), 0);
    append_inst(ctx.cur_block, jmp_ptr);
    connect_blocks(ctx.cur_block, cond_bb);

    ctx.cur_block = cond_bb;
    var cond_reg: u64 = 0;
    if (f.cond != 0) {
        cond_reg = build_expr(ctx, f.cond);
    } else {
        cond_reg = build_const(ctx, 1);
    }
    var br_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_BR, operand_const(exit_bb.id), operand_reg(cond_reg), operand_const(body_bb.id));
    append_inst(ctx.cur_block, br_ptr);
    connect_blocks(ctx.cur_block, body_bb);
    connect_blocks(ctx.cur_block, exit_bb);

    push_loop(ctx, exit_bb, update_bb);
    defer_push_loop_marker(ctx);
    ctx.cur_block = body_bb;
    build_block(ctx, f.body);
    if (block_is_reachable(ctx.cur_block) != 0 && block_is_terminated(ctx.cur_block) == 0) {
        var jmp_ptr2: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(update_bb.id), 0);
        append_inst(ctx.cur_block, jmp_ptr2);
        connect_blocks(ctx.cur_block, update_bb);
    }
    defer_pop_loop_marker(ctx);
    pop_loop(ctx);

    ctx.cur_block = update_bb;
    if (f.update != 0) {
        stmt_or_expr(ctx, f.update);
    }
    if (block_is_reachable(ctx.cur_block) != 0 && block_is_terminated(ctx.cur_block) == 0) {
        var jmp_ptr3: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(cond_bb.id), 0);
        append_inst(ctx.cur_block, jmp_ptr3);
        connect_blocks(ctx.cur_block, cond_bb);
    }

    ctx.cur_block = exit_bb;
    return 0;
}

func build_match_stmt(ctx: *BuilderCtx, node: u64) -> u64 {
    push_trace("build_match_stmt", "ssa_builder.b", __LINE__);
    defer pop_trace();
    var sw: *AstSwitch = (*AstSwitch)node;
    var cases: *Vec<u64> = sw.cases_vec;
    var count: u64 = 0;
    if (cases != 0) { count = cases.len(); }

    var exit_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    if (count == 0) {
        var jmp_ptr0: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(exit_bb.id), 0);
        append_inst(ctx.cur_block, jmp_ptr0);
        connect_blocks(ctx.cur_block, exit_bb);
        ctx.cur_block = exit_bb;
        return 0;
    }

    var expr_reg: u64 = build_expr(ctx, sw.expr);

    var case_blocks: *Vec<*SSABlock> = new Vec<*SSABlock>{heap_alloc((count) * sizeof(*SSABlock)), 0, (count)};
    var case_nodes: *Vec<*AstCase> = new Vec<*AstCase>{heap_alloc((count) * sizeof(*AstCase)), 0, (count)};
    var default_bb: *SSABlock = exit_bb;

    for (var i: u64 = 0; i < count; i++) {
        var c_ptr: u64 = cases.get(i);
        var c: *AstCase = (*AstCase)c_ptr;
        var case_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
        case_blocks.push(case_bb);
        case_nodes.push(c);
        if (c.is_default != 0) {
            default_bb = case_bb;
        }
    }

    for (var i: u64 = 0; i < count; i++) {
        var c2: *AstCase = case_nodes.get(i);
        if (c2.is_default == 0) {
            var case_bb2: *SSABlock = case_blocks.get(i);
            var val_reg: u64 = build_expr(ctx, c2.value);
            var cmp_reg: u64 = new_reg(ctx);
            var cmp_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_EQ, cmp_reg, operand_reg(expr_reg), operand_reg(val_reg));
            append_inst(ctx.cur_block, cmp_ptr);

            var next_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
            var br_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_BR, operand_const(next_bb.id), operand_reg(cmp_reg), operand_const(case_bb2.id));
            append_inst(ctx.cur_block, br_ptr);
            connect_blocks(ctx.cur_block, case_bb2);
            connect_blocks(ctx.cur_block, next_bb);
            ctx.cur_block = next_bb;
        }
    }

    var jmp_ptr1: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(default_bb.id), 0);
    append_inst(ctx.cur_block, jmp_ptr1);
    connect_blocks(ctx.cur_block, default_bb);

    push_loop(ctx, exit_bb, 0);
    defer_push_loop_marker(ctx);
    for (var i: u64 = 0; i < count; i++) {
        var case_bb3: *SSABlock = case_blocks.get(i);
        var c3: *AstCase = case_nodes.get(i);
        ctx.cur_block = case_bb3;
        build_block(ctx, c3.body);

        if (block_is_reachable(ctx.cur_block) != 0 && block_is_terminated(ctx.cur_block) == 0) {
            var next_bb2: *SSABlock = exit_bb;
            if (i + 1 < count) {
                next_bb2 = case_blocks.get(i + 1);
            }
            var jmp_ptr2: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(next_bb2.id), 0);
            append_inst(ctx.cur_block, jmp_ptr2);
            connect_blocks(ctx.cur_block, next_bb2);
        }
    }
    defer_pop_loop_marker(ctx);
    pop_loop(ctx);

    ctx.cur_block = exit_bb;
    return 0;
}

func build_if(ctx: *BuilderCtx, node: u64) -> u64 {
    push_trace("build_if", "ssa_builder.b", __LINE__);
    defer pop_trace();
    var ifn: *AstIf = (*AstIf)node;
    var has_else: u64 = 0;
    if (ifn.else_block != 0) { has_else = 1; }

    if (SSA_BUILDER_DEBUG != 0) {
        println("[DEBUG] build_if: cond", 25);
    }

    var cond_reg: u64 = build_expr(ctx, ifn.cond);

    if (SSA_BUILDER_DEBUG != 0) {
        println("[DEBUG] build_if: blocks", 27);
    }

    var then_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var merge_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var else_bb: *SSABlock = merge_bb;
    if (has_else == 1) {
        else_bb = create_block(ctx.ssa_ctx, ctx.cur_func);
    }

    var br_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_BR, operand_const(else_bb.id), operand_reg(cond_reg), operand_const(then_bb.id));
    append_inst(ctx.cur_block, br_ptr);

    connect_blocks(ctx.cur_block, then_bb);
    connect_blocks(ctx.cur_block, else_bb);

    ctx.cur_block = then_bb;
    if (SSA_BUILDER_DEBUG != 0) {
        println("[DEBUG] build_if: then", 25);
    }
    build_block(ctx, ifn.then_block);
    if (block_is_reachable(ctx.cur_block) != 0 && block_is_terminated(ctx.cur_block) == 0) {
        var jmp_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(merge_bb.id), 0);
        append_inst(ctx.cur_block, jmp_ptr);
        connect_blocks(ctx.cur_block, merge_bb);
    }

    if (has_else == 1) {
        ctx.cur_block = else_bb;
        if (SSA_BUILDER_DEBUG != 0) {
            println("[DEBUG] build_if: else", 25);
        }
        build_block(ctx, ifn.else_block);
        if (block_is_reachable(ctx.cur_block) != 0 && block_is_terminated(ctx.cur_block) == 0) {
            var jmp_ptr2: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(merge_bb.id), 0);
            append_inst(ctx.cur_block, jmp_ptr2);
            connect_blocks(ctx.cur_block, merge_bb);
        }
    }

    ctx.cur_block = merge_bb;
    return 0;
}

func build_while(ctx: *BuilderCtx, node: u64) -> u64 {
    push_trace("build_while", "ssa_builder.b", __LINE__);
    defer pop_trace();
    var w: *AstWhile = (*AstWhile)node;

    var cond_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var body_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var exit_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);

    var jmp_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(cond_bb.id), 0);
    append_inst(ctx.cur_block, jmp_ptr);
    connect_blocks(ctx.cur_block, cond_bb);

    ctx.cur_block = cond_bb;
    var cond_reg: u64 = build_expr(ctx, w.cond);
    var br_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_BR, operand_const(exit_bb.id), operand_reg(cond_reg), operand_const(body_bb.id));
    append_inst(ctx.cur_block, br_ptr);
    connect_blocks(ctx.cur_block, body_bb);
    connect_blocks(ctx.cur_block, exit_bb);

    push_loop(ctx, exit_bb, cond_bb);
    defer_push_loop_marker(ctx);
    ctx.cur_block = body_bb;
    build_block(ctx, w.body);
    if (block_is_reachable(ctx.cur_block) != 0 && block_is_terminated(ctx.cur_block) == 0) {
        var jmp_ptr2: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(cond_bb.id), 0);
        append_inst(ctx.cur_block, jmp_ptr2);
        connect_blocks(ctx.cur_block, cond_bb);
    }
    defer_pop_loop_marker(ctx);
    pop_loop(ctx);

    ctx.cur_block = exit_bb;
    return 0;
}

// ============================================
// Return Helpers
// ============================================

func emit_return_slice_from_call(ctx: *BuilderCtx, expr: u64) -> u64 {
    var ptr_reg: u64 = new_reg(ctx);
    var len_reg: u64 = new_reg(ctx);
    var kind: u64 = ast_kind(expr);
    if (kind == AST_CALL) {
        emit_call(ctx, (*AstCall)expr, ptr_reg, len_reg);
    } else if (kind == AST_METHOD_CALL) {
        emit_method_call_value(ctx, (*AstMethodCall)expr, ptr_reg, len_reg);
    } else {
        emit_call_ptr(ctx, (*AstCallPtr)expr, ptr_reg, len_reg);
    }
    var ret_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_RET, 0, operand_reg(ptr_reg), operand_reg(len_reg));
    append_inst(ctx.cur_block, ret_ptr);
    return 0;
}

func emit_return_struct_from_call(ctx: *BuilderCtx, expr: u64, struct_size: u64) -> u64 {
    var lo_reg: u64 = new_reg(ctx);
    var hi_reg: u64 = 0;
    if (struct_size > 8) { hi_reg = new_reg(ctx); }
    var kind: u64 = ast_kind(expr);
    if (kind == AST_CALL) {
        emit_call(ctx, (*AstCall)expr, lo_reg, hi_reg);
    } else if (kind == AST_METHOD_CALL) {
        emit_method_call_value(ctx, (*AstMethodCall)expr, lo_reg, hi_reg);
    } else {
        emit_call_ptr(ctx, (*AstCallPtr)expr, lo_reg, hi_reg);
    }
    var ret_src2: u64 = 0;
    if (hi_reg != 0) { ret_src2 = operand_reg(hi_reg); }
    var ret_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_RET, 0, operand_reg(lo_reg), ret_src2);
    append_inst(ctx.cur_block, ret_ptr);
    return 0;
}

func emit_return_struct_from_addr(ctx: *BuilderCtx, expr: u64, struct_size: u64) -> u64 {
    var addr_reg: u64 = lvalue_addr(ctx, expr);
    if (addr_reg == 0) { return 0; }
    var head_size: u64 = struct_size;
    if (head_size > 8) { head_size = 8; }
    var lo_reg: u64 = load_by_size(ctx, addr_reg, head_size);
    if (lo_reg == 0) {
        lo_reg = build_const(ctx, 0);
    }
    var hi_reg: u64 = 0;
    if (struct_size > 8) {
        var off_reg: u64 = build_const(ctx, 8);
        var addr2: u64 = new_reg(ctx);
        var add_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, addr2, operand_reg(addr_reg), operand_reg(off_reg));
        append_inst(ctx.cur_block, add_ptr);
        var tail_size: u64 = struct_size - 8;
        if (tail_size > 8) { tail_size = 8; }
        hi_reg = load_by_size(ctx, addr2, tail_size);
        if (hi_reg == 0) {
            hi_reg = build_const(ctx, 0);
        }
    }
    var ret_src2: u64 = 0;
    if (struct_size > 8) {
        if (hi_reg != 0) {
            ret_src2 = operand_reg(hi_reg);
        } else {
            var zero_reg: u64 = build_const(ctx, 0);
            ret_src2 = operand_reg(zero_reg);
        }
    }
    var ret_ptr2: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_RET, 0, operand_reg(lo_reg), ret_src2);
    append_inst(ctx.cur_block, ret_ptr2);
    return 0;
}

func build_struct_literal_scalar(ctx: *BuilderCtx, lit: *AstStructLiteral) -> u64 {
    var values: *Vec<*AstNode> = lit.values_vec;
    if (values == 0) { return build_const(ctx, 0); }
    var count: u64 = values.len();
    if (count == 0) { return build_const(ctx, 0); }
    var first: *AstNode = values.get(0);
    if (ast_kind(first) == AST_STRUCT_LITERAL) {
        return build_struct_literal_scalar(ctx, (*AstStructLiteral)first);
    }
    var reg: u64 = build_expr(ctx, first);
    if (reg == 0) { reg = build_const(ctx, 0); }
    return reg;
}

func struct_literal_eval_value_or_zero(ctx: *BuilderCtx, values: *Vec<*AstNode>, idx: u64) -> u64 {
    if (values == 0) { return build_const(ctx, 0); }
    if (idx >= values.len()) { return build_const(ctx, 0); }
    var v: *AstNode = values.get(idx);
    var out: u64 = 0;
    if (ast_kind(v) == AST_STRUCT_LITERAL) {
        out = build_struct_literal_scalar(ctx, (*AstStructLiteral)v);
    } else {
        out = build_expr(ctx, v);
    }
    if (out == 0) {
        out = build_const(ctx, 0);
    }
    return out;
}

func emit_return_zero_value(ctx: *BuilderCtx) -> u64 {
    var zero_reg: u64 = build_const(ctx, 0);
    var ret_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_RET, 0, operand_reg(zero_reg), 0);
    append_inst(ctx.cur_block, ret_ptr);
    return 0;
}

func emit_return_struct_from_literal(ctx: *BuilderCtx, lit: *AstStructLiteral, struct_size: u64) -> u64 {
    var values: *Vec<*AstNode> = lit.values_vec;
    if (values == 0) { return emit_return_zero_value(ctx); }

    var num_values: u64 = values.len();
    if (num_values == 0) { return emit_return_zero_value(ctx); }
    var tmp_offset: u64 = symtab_add(ctx.symtab, slice(0, 0), TYPE_STRUCT, 0, struct_size);
    var tmp_addr: u64 = new_lea_local(ctx, tmp_offset);
    struct_literal_init(ctx, lit.struct_def, values, tmp_addr);
    return emit_return_struct_from_addr_reg(ctx, tmp_addr, struct_size);
}

func emit_expr_stmt_call(ctx: *BuilderCtx, expr: u64) -> u64 {
    var expr_kind: u64 = ast_kind(expr);
    if (expr_kind == AST_CALL) {
        var sret_size: u64 = get_sret_struct_size(ctx, expr);
        if (sret_size != 0) {
            var sret_offset: u64 = symtab_add(ctx.symtab, slice(0, 0), TYPE_STRUCT, 0, sret_size);
            var sret_addr_reg: u64 = new_lea_local(ctx, sret_offset);
            emit_call_sret_value(ctx, (*AstCall)expr, sret_addr_reg);
            return 1;
        }
        emit_call(ctx, (*AstCall)expr, 0, 0);
        return 1;
    }
    if (expr_kind == AST_METHOD_CALL) {
        var sret_size2: u64 = get_sret_struct_size(ctx, expr);
        if (sret_size2 != 0) {
            var sret_offset2: u64 = symtab_add(ctx.symtab, slice(0, 0), TYPE_STRUCT, 0, sret_size2);
            var sret_addr_reg2: u64 = new_lea_local(ctx, sret_offset2);
            emit_method_call_sret(ctx, (*AstMethodCall)expr, sret_addr_reg2);
            return 1;
        }
        emit_method_call_value(ctx, (*AstMethodCall)expr, 0, 0);
        return 1;
    }
    if (expr_kind == AST_CALL_PTR) {
        var sret_size3: u64 = get_sret_struct_size(ctx, expr);
        if (sret_size3 != 0) {
            var sret_offset3: u64 = symtab_add(ctx.symtab, slice(0, 0), TYPE_STRUCT, 0, sret_size3);
            var sret_addr_reg3: u64 = new_lea_local(ctx, sret_offset3);
            emit_call_ptr_sret(ctx, (*AstCallPtr)expr, sret_addr_reg3);
            return 1;
        }
        emit_call_ptr(ctx, (*AstCallPtr)expr, 0, 0);
        return 1;
    }
    return 0;
}

func track_func_ptr_from_addr_of_ident(ctx: *BuilderCtx, target_name: []u8, value_expr: u64) -> u64 {
    if (value_expr == 0) {
        set_func_ptr(ctx, slice(target_name.ptr, target_name.len), slice(0, 0));
        return 0;
    }
    if (ast_kind(value_expr) != AST_ADDR_OF) {
        set_func_ptr(ctx, slice(target_name.ptr, target_name.len), slice(0, 0));
        return 0;
    }
    var addr_val: *AstAddrOf = (*AstAddrOf)value_expr;
    if (ast_kind(addr_val.operand) != AST_IDENT) {
        set_func_ptr(ctx, slice(target_name.ptr, target_name.len), slice(0, 0));
        return 0;
    }
    var idn_val: *AstIdent = (*AstIdent)addr_val.operand;
    var resolved_ptr: u64 = u8_slice_ptr(idn_val.name);
    var resolved_len: u64 = u8_slice_len(idn_val.name);
    var resolved: *NameInfo = resolve_name(idn_val.name);
    if (resolved != 0) {
        resolved_ptr = resolved.ptr;
        resolved_len = resolved.len;
    }
    var fn_map: *AstFunc = sym_get_func(slice(resolved_ptr, resolved_len));
    if (fn_map != 0 && fn_map.ret_type == TYPE_STRUCT && fn_map.ret_ptr_depth == 0) {
        set_func_ptr(ctx, slice(target_name.ptr, target_name.len), fn_map.ret_struct_name);
        return 0;
    }
    set_func_ptr(ctx, slice(target_name.ptr, target_name.len), slice(0, 0));
    return 0;
}

func store_struct_call_result_to_addr(ctx: *BuilderCtx, value_expr: u64, struct_size: u64, target_addr: u64) -> u64 {
    if (struct_size == 0) {
        return 0;
    }
    var value_kind: u64 = ast_kind(value_expr);
    if (!(value_kind == AST_CALL || value_kind == AST_METHOD_CALL || value_kind == AST_CALL_PTR)) {
        return 0;
    }
    if (struct_size > 16) {
        if (value_kind == AST_CALL) {
            emit_call_sret_value(ctx, (*AstCall)value_expr, target_addr);
        } else if (value_kind == AST_METHOD_CALL) {
            emit_method_call_sret(ctx, (*AstMethodCall)value_expr, target_addr);
        } else {
            emit_call_ptr_sret(ctx, (*AstCallPtr)value_expr, target_addr);
        }
        return 1;
    }
    var lo_reg: u64 = new_reg(ctx);
    var hi_reg: u64 = 0;
    if (struct_size > 8) {
        hi_reg = new_reg(ctx);
    }
    if (value_kind == AST_CALL) {
        emit_call(ctx, (*AstCall)value_expr, lo_reg, hi_reg);
    } else if (value_kind == AST_METHOD_CALL) {
        emit_method_call_value(ctx, (*AstMethodCall)value_expr, lo_reg, hi_reg);
    } else {
        emit_call_ptr(ctx, (*AstCallPtr)value_expr, lo_reg, hi_reg);
    }
    store_by_size(ctx, target_addr, lo_reg, 8);
    if (hi_reg != 0) {
        var off8: u64 = build_const(ctx, 8);
        var addr2: u64 = new_reg(ctx);
        var add_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, addr2, operand_reg(target_addr), operand_reg(off8));
        append_inst(ctx.cur_block, add_ptr);
        var tail_size: u64 = struct_size - 8;
        if (tail_size > 8) {
            tail_size = 8;
        }
        store_by_size(ctx, addr2, hi_reg, tail_size);
    }
    return 1;
}

func stmt_var_decl(ctx: *BuilderCtx, node: u64) -> u64 {
    var vd: *AstVarDecl = (*AstVarDecl)node;
    var var_id: u64 = get_var_id(ctx, vd.name);
    symtab_add_local(ctx, vd);
    var local_struct_is_single_word: u64 = 0;
    var local_struct_size_single: u64 = 0;
    if (is_single_word_struct_value(vd.type_kind, vd.ptr_depth, vd.struct_name) != 0) {
        local_struct_is_single_word = 1;
        local_struct_size_single = layout_type_sizeof(TYPE_STRUCT, 0, vd.struct_name);
    }
    if (vd.type_kind == TYPE_STRUCT && vd.ptr_depth == 0) {
        var struct_offset: u64 = symtab_find(ctx.symtab, vd.name);
        if (struct_offset != 0) {
            var struct_base_addr: u64 = new_lea_local(ctx, struct_offset);
            emit_trait_vptr_init_at_addr(ctx, struct_base_addr, vd.struct_name);
        }
    }
    if (vd.init_expr != 0) {
        var init_kind: u64 = ast_kind(vd.init_expr);
        track_func_ptr_from_addr_of_ident(ctx, vd.name, vd.init_expr);
        closure_track_from_expr(ctx, vd.name, vd.init_expr);
        if (vd.type_kind == TYPE_SLICE && vd.ptr_depth == 0) {
            var offset_slice: u64 = symtab_find(ctx.symtab, vd.name);
            var base_addr: u64 = new_lea_local(ctx, offset_slice);
            var init_kind2: u64 = ast_kind(vd.init_expr);
            if (init_kind2 == AST_CALL) {
                emit_call_slice_store(ctx, (*AstCall)vd.init_expr, base_addr);
                return 0;
            }
            if (init_kind2 == AST_METHOD_CALL) {
                emit_method_call_slice_store(ctx, (*AstMethodCall)vd.init_expr, base_addr);
                return 0;
            }
            if (init_kind2 == AST_CALL_PTR) {
                emit_call_ptr_slice_store(ctx, (*AstCallPtr)vd.init_expr, base_addr);
                return 0;
            }
            var slice_info: *SliceRegs = slice_regs(ctx, vd.init_expr);
            store_slice_regs(ctx, base_addr, slice_info);
            return 0;
        }
        if (init_kind == AST_STRUCT_LITERAL) {
            var offset: u64 = symtab_find(ctx.symtab, vd.name);
            var base_addr: u64 = new_lea_local(ctx, offset);
            var lit: *AstStructLiteral = (*AstStructLiteral)vd.init_expr;
            struct_literal_init(ctx, lit.struct_def, lit.values_vec, base_addr);
            if (local_struct_is_single_word != 0) {
                sync_single_word_struct_var_from_addr(ctx, vd.name, base_addr, local_struct_size_single);
            }
            return 0;
        }
        if (init_kind == AST_STACK_CTOR) {
            var offset_sc: u64 = symtab_find(ctx.symtab, vd.name);
            var base_addr_sc: u64 = new_lea_local(ctx, offset_sc);
            var sc_init: *AstStackCtor = (*AstStackCtor)vd.init_expr;
            stack_ctor_init_at_addr(ctx, sc_init, base_addr_sc);
            if (local_struct_is_single_word != 0) {
                sync_single_word_struct_var_from_addr(ctx, vd.name, base_addr_sc, local_struct_size_single);
            }
            return 0;
        }
        // Handle struct-returning function calls
        if (vd.type_kind == TYPE_STRUCT && vd.ptr_depth == 0) {
            var struct_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, vd.struct_name);
            if (init_kind == AST_CALL || init_kind == AST_METHOD_CALL || init_kind == AST_CALL_PTR) {
                var offset_call: u64 = symtab_find(ctx.symtab, vd.name);
                if (offset_call == 0) {
                    if (struct_size > 16) {
                        return 0;
                    }
                    // Fall back to normal handling if offset not found
                    var val_reg: u64 = build_expr(ctx, vd.init_expr);
                    var st_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_STORE, 0, operand_const(var_id), operand_reg(val_reg));
                    append_inst(ctx.cur_block, st_ptr);
                    return 0;
                }
                var base_addr_call: u64 = new_lea_local(ctx, offset_call);
                if (store_struct_call_result_to_addr(ctx, vd.init_expr, struct_size, base_addr_call) != 0) {
                    if (local_struct_is_single_word != 0) {
                        sync_single_word_struct_var_from_addr(ctx, vd.name, base_addr_call, local_struct_size_single);
                    }
                    return 0;
                }
            }
            if (struct_size > 0) {
                var offset_struct: u64 = symtab_find(ctx.symtab, vd.name);
                if (offset_struct != 0) {
                    var base_addr_struct: u64 = new_lea_local(ctx, offset_struct);
                    var src_addr_struct2: u64 = lvalue_addr(ctx, vd.init_expr);
                    if (src_addr_struct2 != 0) {
                        struct_copy(ctx, base_addr_struct, src_addr_struct2, struct_size);
                        if (local_struct_is_single_word != 0) {
                            sync_single_word_struct_var_from_addr(ctx, vd.name, base_addr_struct, local_struct_size_single);
                        }
                        return 0;
                    }
                }
            }
        }
        if (local_struct_is_single_word != 0) {
            var offset_single: u64 = symtab_find(ctx.symtab, vd.name);
            if (offset_single != 0) {
                var base_addr_single: u64 = new_lea_local(ctx, offset_single);
                var val_reg_single: u64 = build_expr(ctx, vd.init_expr);
                store_by_size(ctx, base_addr_single, val_reg_single, local_struct_size_single);
                sync_single_word_struct_var_from_addr(ctx, vd.name, base_addr_single, local_struct_size_single);
                return 0;
            }
        }
        if (vd.type_kind == TYPE_ARRAY && vd.ptr_depth == 0) {
            var elem_size_copy: u64 = 0;
            if (vd.elem_typeinfo != 0) {
                elem_size_copy = sizeof_type_ex(vd.elem_typeinfo);
            } else {
                elem_size_copy = layout_type_sizeof(vd.elem_type_kind, vd.elem_ptr_depth, vd.struct_name);
            }
            var array_size_copy: u64 = elem_size_copy * vd.array_len;
            if (array_size_copy > 0) {
                var offset_array: u64 = symtab_find(ctx.symtab, vd.name);
                if (offset_array != 0) {
                    var base_addr_array: u64 = new_lea_local(ctx, offset_array);
                    var src_addr_array2: u64 = lvalue_addr(ctx, vd.init_expr);
                    if (src_addr_array2 != 0) {
                        struct_copy(ctx, base_addr_array, src_addr_array2, array_size_copy);
                        return 0;
                    }
                }
            }
        }
        if (is_addr_taken(ctx, vd.name) != 0) {
            var offset_addr: u64 = symtab_find(ctx.symtab, vd.name);
            if (offset_addr != 0) {
                var base_addr3: u64 = new_lea_local(ctx, offset_addr);
                var val_reg2: u64 = build_expr(ctx, vd.init_expr);
                var size_at: u64 = 0;
                if (vd.type_kind == TYPE_ARRAY) {
                    var elem_size_at: u64 = 0;
                    if (vd.elem_typeinfo != 0) {
                        elem_size_at = sizeof_type_ex(vd.elem_typeinfo);
                    } else {
                        elem_size_at = layout_type_sizeof(vd.elem_type_kind, vd.elem_ptr_depth, vd.struct_name);
                    }
                    size_at = elem_size_at * vd.array_len;
                } else if (vd.type_kind == TYPE_SLICE) {
                    size_at = 16;
                } else {
                    size_at = layout_type_sizeof(vd.type_kind, vd.ptr_depth, vd.struct_name);
                }
                if (size_at == 0) { size_at = 8; }
                store_by_size(ctx, base_addr3, val_reg2, size_at);
                return 0;
            }
        }
        var val_reg: u64 = build_expr(ctx, vd.init_expr);
        var st_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_STORE, 0, operand_const(var_id), operand_reg(val_reg));
        append_inst(ctx.cur_block, st_ptr);
    }
    return 0;
}

func assign_addr_taken_ident(ctx: *BuilderCtx, asn: *AstAssign) -> u64 {
    if (ast_kind(asn.target) != AST_IDENT) {
        return 0;
    }
    var idn_tgt: *AstIdent = (*AstIdent)asn.target;
    if (is_addr_taken(ctx, idn_tgt.name) == 0) {
        return 0;
    }
    var ti_at: *TypeInfo = get_expr_type_with_symtab(asn.target, ctx.symtab);
    if (ti_at != 0 && ti_at.type_kind == TYPE_SLICE && ti_at.ptr_depth == 0) {
        return 0;
    }
    var target_addr: u64 = lvalue_addr(ctx, asn.target);
    var value_reg: u64 = build_expr(ctx, asn.value);
    var size_bytes: u64 = type_size_from_expr(ctx, asn.target);
    store_by_size(ctx, target_addr, value_reg, size_bytes);
    return 1;
}

func assign_try_packed_member(ctx: *BuilderCtx, asn: *AstAssign) -> u64 {
    if (ast_kind(asn.target) != AST_MEMBER_ACCESS) {
        return 0;
    }
    var m: *AstMemberAccess = (*AstMemberAccess)asn.target;
    var obj: u64 = m.object;
    var ot: *TypeInfo = get_expr_type_with_symtab((*AstNode)obj, ctx.symtab);
    if (ot == 0) {
        return 0;
    }
    if (ot.ptr_depth > 0 && ot.is_tagged == 1 && u8_slice_ptr(ot.tag_layout) != 0) {
        var layout_def: *AstStructDef = get_struct_def(ot.tag_layout);
        var packed_meta: BuilderPackedFieldMeta = packed_field_meta(layout_def, m.member, 1);
        if (packed_meta.is_valid != 0) {
            var obj_val: u64 = build_expr(ctx, obj);
            var value_reg: u64 = build_expr(ctx, asn.value);
            var merged: u64 = packed_merge_value(ctx, obj_val, value_reg, packed_meta.field_width, packed_meta.shift_bits);
            if (ast_kind(obj) == AST_IDENT) {
                var idn_tag: *AstIdent = (*AstIdent)obj;
                var tag_offset: u64 = symtab_find(ctx.symtab, idn_tag.name);
                if (tag_offset != 0) {
                    var var_id_tag: u64 = get_var_id(ctx, idn_tag.name);
                    var st_ptr_tag: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_STORE, 0, operand_const(var_id_tag), operand_reg(merged));
                    append_inst(ctx.cur_block, st_ptr_tag);
                    return 1;
                }
            }
            var obj_addr: u64 = lvalue_addr(ctx, obj);
            store_by_size(ctx, obj_addr, merged, packed_meta.size_bytes);
            return 1;
        }
    }
    if (ot.ptr_depth == 0 && ot.type_kind == TYPE_STRUCT) {
        var struct_def: *AstStructDef = ot.struct_def;
        if (struct_def == 0 && u8_slice_ptr(ot.struct_name) != 0) {
            struct_def = get_struct_def(ot.struct_name);
        }
        var packed_meta2: BuilderPackedFieldMeta = packed_field_meta(struct_def, m.member, 0);
        if (packed_meta2.is_valid != 0) {
            var base_addr2: u64 = lvalue_addr(ctx, obj);
            var field_offset_bits2: u64 = packed_field_bit_offset(struct_def, m.member);
            var field_width_bits2: u64 = packed_field_bit_width(struct_def, m.member);
            if (base_addr2 != 0 && (field_offset_bits2 % 8) == 0 && (field_width_bits2 % 8) == 0) {
                var field_size_bytes2: u64 = field_width_bits2 / 8;
                if (field_size_bytes2 != 0 && field_size_bytes2 <= 8) {
                    var field_addr2: u64 = base_addr2;
                    if (field_offset_bits2 != 0) {
                        var off_reg2: u64 = build_const(ctx, field_offset_bits2 / 8);
                        var addr2: u64 = new_reg(ctx);
                        var add_ptr2: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, addr2, operand_reg(base_addr2), operand_reg(off_reg2));
                        append_inst(ctx.cur_block, add_ptr2);
                        field_addr2 = addr2;
                    }
                    var value_reg_direct: u64 = build_expr(ctx, asn.value);
                    store_by_size(ctx, field_addr2, value_reg_direct, field_size_bytes2);
                    return 1;
                }
            }
            var cur_val: u64 = load_by_size(ctx, base_addr2, packed_meta2.size_bytes);
            var value_reg2: u64 = build_expr(ctx, asn.value);
            var merged2: u64 = packed_merge_value(ctx, cur_val, value_reg2, packed_meta2.field_width, packed_meta2.shift_bits);
            store_by_size(ctx, base_addr2, merged2, packed_meta2.size_bytes);
            return 1;
        }
    }
    return 0;
}

func assign_load_target_struct_meta(ctx: *BuilderCtx, asn: *AstAssign, target_kind: u64) -> BuilderAssignTargetMeta {
    var meta: BuilderAssignTargetMeta;
    meta.tgt_ti = 0;
    meta.tgt_is_struct = 0;
    meta.tgt_struct_size = 0;
    if (!(target_kind == AST_IDENT || target_kind == AST_DEREF || target_kind == AST_DEREF8 || target_kind == AST_INDEX || target_kind == AST_MEMBER_ACCESS)) {
        return meta;
    }
    var tgt_ti_ptr: *TypeInfo = get_expr_type_with_symtab((*AstNode)asn.target, ctx.symtab);
    if (tgt_ti_ptr == 0) { return meta; }
    meta.tgt_ti = tgt_ti_ptr;
    var ti_s: *TypeInfo = tgt_ti_ptr;
    if (ti_s.type_kind == TYPE_STRUCT && ti_s.ptr_depth == 0) {
        meta.tgt_is_struct = 1;
        meta.tgt_struct_size = layout_type_sizeof(TYPE_STRUCT, 0, ti_s.struct_name);
    }
    return meta;
}

func assign_resolve_target_addr(ctx: *BuilderCtx, asn: *AstAssign, target_kind: u64) -> BuilderAssignTargetAddr {
    var addr_info: BuilderAssignTargetAddr;
    addr_info.resolved = 0;
    addr_info.target_addr = 0;
    addr_info.target_offset = 0;
    if (target_kind == AST_IDENT) {
        var idn: *AstIdent = (*AstIdent)asn.target;
        addr_info.target_offset = symtab_find(ctx.symtab, idn.name);
        if (addr_info.target_offset != 0) {
            addr_info.target_addr = new_lea_local(ctx, addr_info.target_offset);
        } else {
            addr_info.target_addr = lvalue_addr(ctx, asn.target);
        }
        addr_info.resolved = 1;
        return addr_info;
    }
    if (target_kind == AST_DEREF || target_kind == AST_DEREF8 || target_kind == AST_INDEX || target_kind == AST_MEMBER_ACCESS) {
        addr_info.target_addr = lvalue_addr(ctx, asn.target);
        addr_info.resolved = 1;
        return addr_info;
    }
    return addr_info;
}

func assign_try_index_setter(ctx: *BuilderCtx, asn: *AstAssign) -> u64 {
    if (asn == 0 || ast_kind(asn.target) != AST_INDEX) { return 0; }
    var ix: *AstIndex = (*AstIndex)asn.target;
    if (ix.base == 0) { return 0; }
    if (ast_kind(ix.base) != AST_IDENT) { return 0; }
    var idn: *AstIdent = (*AstIdent)ix.base;

    var recv_ti: *TypeInfo = symtab_get_type(ctx.symtab, idn.name);
    if (recv_ti == 0 || recv_ti.type_kind != TYPE_STRUCT) { return 0; }
    var struct_ptr: u64 = u8_slice_ptr(recv_ti.struct_name);
    var struct_len: u64 = u8_slice_len(recv_ti.struct_name);
    if (struct_ptr == 0 || struct_len == 0) { return 0; }
    if (get_struct_def(slice(struct_ptr, struct_len)) == 0) { return 0; }

    var method: *NameInfo = compiler_operator_index_set_name();
    var arg_types: *Vec<*TypeInfo> = new Vec<*TypeInfo>{heap_alloc((2) * sizeof(*TypeInfo)), 0, (2)};
    arg_types.push(get_expr_type_with_symtab((*AstNode)ix.index, ctx.symtab));
    arg_types.push(get_expr_type_with_symtab((*AstNode)asn.value, ctx.symtab));
    var resolved: CompilerMethodResolveResult = sym_resolve_method_overload_with_count_fallback(slice(struct_ptr, struct_len), slice(method.ptr, method.len), arg_types, 2);
    if (resolved.found == 0) { return 0; }

    if (check_method_access_overload(slice(struct_ptr, struct_len), slice(method.ptr, method.len), arg_types, 2) == 0) {
        emit_stderr("[ERROR] Cannot access overloaded operator method: ");
        emit_stderr_len(struct_ptr, struct_len);
        emit_stderr(".");
        emit_stderr_len(method.ptr, method.len);
        emit_stderr("\n");
        ctx.build_failed = 1;
        return 1;
    }

    var args: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((2) * sizeof(*AstNode)), 0, (2)};
    args.push(ix.index);
    args.push(asn.value);
    var setter_call: *AstMethodCall = ast_method_call(ix.base, slice(method.ptr, method.len), args);
    build_expr(ctx, (*AstNode)setter_call);
    return 1;
}

func stmt_assign(ctx: *BuilderCtx, node: u64) -> u64 {
    var asn: *AstAssign = (*AstAssign)node;
    var target_kind: u64 = ast_kind(asn.target);
    if (target_kind == AST_IDENT && asn.value != 0) {
        var idn_tgt: *AstIdent = (*AstIdent)asn.target;
        track_func_ptr_from_addr_of_ident(ctx, idn_tgt.name, asn.value);
        closure_track_from_expr(ctx, idn_tgt.name, asn.value);
    }
    if (assign_addr_taken_ident(ctx, asn) != 0) {
        return 0;
    }
    if (target_kind == AST_MEMBER_ACCESS) {
        var property_setter_call: *AstCall = ssa_property_hook_build_setter_call(ctx, (*AstMemberAccess)asn.target, (*AstNode)asn.value);
        if (property_setter_call != 0) {
            build_expr(ctx, (*AstNode)property_setter_call);
            return 0;
        }
    }
    // NOTE: operator []= dispatch is temporarily disabled in SSA assignment lowering.
    var target_meta: BuilderAssignTargetMeta = assign_load_target_struct_meta(ctx, asn, target_kind);
    if (assign_try_packed_member(ctx, asn) != 0) {
        return 0;
    }
    var target_addr_info: BuilderAssignTargetAddr = assign_resolve_target_addr(ctx, asn, target_kind);
    if (target_addr_info.resolved == 0) {
        return 0;
    }
    var target_addr: u64 = target_addr_info.target_addr;
    var target_offset: u64 = target_addr_info.target_offset;

    if (ast_kind(asn.value) == AST_STRUCT_LITERAL) {
        assign_struct_literal_to_addr(ctx, (*AstStructLiteral)asn.value, target_addr);
        if (target_kind == AST_IDENT && target_meta.tgt_struct_size > 0 && target_meta.tgt_struct_size <= 8) {
            var idn_sync_lit: *AstIdent = (*AstIdent)asn.target;
            sync_single_word_struct_var_from_addr(ctx, idn_sync_lit.name, target_addr, target_meta.tgt_struct_size);
        }
        return 0;
    }

    if (ast_kind(asn.value) == AST_STACK_CTOR) {
        assign_stack_ctor_to_addr(ctx, (*AstStackCtor)asn.value, target_addr);
        if (target_kind == AST_IDENT && target_meta.tgt_struct_size > 0 && target_meta.tgt_struct_size <= 8) {
            var idn_sync_ctor: *AstIdent = (*AstIdent)asn.target;
            sync_single_word_struct_var_from_addr(ctx, idn_sync_ctor.name, target_addr, target_meta.tgt_struct_size);
        }
        return 0;
    }

    if (target_meta.tgt_is_struct != 0 && target_meta.tgt_struct_size > 0) {
        if (store_struct_call_result_to_addr(ctx, asn.value, target_meta.tgt_struct_size, target_addr) != 0) {
            if (target_kind == AST_IDENT && target_meta.tgt_struct_size <= 8) {
                var idn_sync_call: *AstIdent = (*AstIdent)asn.target;
                sync_single_word_struct_var_from_addr(ctx, idn_sync_call.name, target_addr, target_meta.tgt_struct_size);
            }
            return 0;
        }

        var src_addr_s: u64 = lvalue_addr(ctx, asn.value);
        if (src_addr_s == 0) {
            if (target_meta.tgt_struct_size <= 8) {
                var val_reg_struct: u64 = build_expr(ctx, asn.value);
                store_by_size(ctx, target_addr, val_reg_struct, target_meta.tgt_struct_size);
                if (target_kind == AST_IDENT) {
                    var idn_sync_val: *AstIdent = (*AstIdent)asn.target;
                    sync_single_word_struct_var_from_addr(ctx, idn_sync_val.name, target_addr, target_meta.tgt_struct_size);
                }
            }
            return 0;
        }
        struct_copy(ctx, target_addr, src_addr_s, target_meta.tgt_struct_size);
        if (target_kind == AST_IDENT && target_meta.tgt_struct_size <= 8) {
            var idn_sync_copy: *AstIdent = (*AstIdent)asn.target;
            sync_single_word_struct_var_from_addr(ctx, idn_sync_copy.name, target_addr, target_meta.tgt_struct_size);
        }
        return 0;
    }

    if (target_meta.tgt_ti != 0) {
        var ti: *TypeInfo = target_meta.tgt_ti;
        if (ti.type_kind == TYPE_SLICE && ti.ptr_depth == 0) {
            assign_slice_to_addr(ctx, asn.value, target_addr);
            return 0;
        }
    }

    var val_reg3: u64 = build_expr(ctx, asn.value);
    if (target_kind == AST_IDENT && target_offset != 0) {
        var idn2: *AstIdent = (*AstIdent)asn.target;
        var var_id3: u64 = get_var_id(ctx, idn2.name);
        var st_ptr3: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_STORE, 0, operand_const(var_id3), operand_reg(val_reg3));
        append_inst(ctx.cur_block, st_ptr3);
        return 0;
    }

    var size4: u64 = 8;
    if (target_kind == AST_DEREF8) {
        size4 = 1;
    } else {
        size4 = type_size_from_expr(ctx, asn.target);
    }
    store_by_size(ctx, target_addr, val_reg3, size4);
    return 0;
}

func emit_return_slice_value(ctx: *BuilderCtx, expr: u64) -> u64 {
    var expr_kind: u64 = ast_kind(expr);
    if (expr_kind == AST_SLICE) {
        var slice_node: *AstSlice = (*AstSlice)expr;
        var ptr_ti: *TypeInfo = get_expr_type_with_symtab(slice_node.ptr_expr, ctx.symtab);
        if (ptr_ti != 0) {
            var is_local_array: u64 = 0;
            if (ptr_ti.ptr_depth == 0) {
                if (ptr_ti.type_kind == TYPE_ARRAY || ptr_ti.array_len != 0) {
                    is_local_array = 1;
                }
            }
            if (is_local_array != 0) {
                var elem_size: u64 = typeinfo_elem_size_from_container(ptr_ti);
                if (elem_size == 0) { elem_size = 8; }
                var ptr_reg: u64 = lvalue_addr(ctx, slice_node.ptr_expr);
                if (ptr_reg == 0) {
                    ptr_reg = build_expr(ctx, slice_node.ptr_expr);
                }
                var len_reg: u64 = build_expr(ctx, slice_node.len_expr);
                var ret_ptr_heap: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_RET_SLICE_HEAP, elem_size, operand_reg(ptr_reg), operand_reg(len_reg));
                append_inst(ctx.cur_block, ret_ptr_heap);
                var ptr_is_reg: u64 = 1;
                var len_is_reg: u64 = 1;
                var len_val: u64 = len_reg;
                if (ast_kind(slice_node.len_expr) == AST_LITERAL) {
                    var lit_len: *AstLiteral = (*AstLiteral)slice_node.len_expr;
                    len_val = lit_len.value;
                    len_is_reg = 0;
                }
                ret_slice_heap_set(ret_ptr_heap, elem_size);
                ret_slice_heap_set_ex(ret_ptr_heap, elem_size, ptr_reg, len_val, ptr_is_reg, len_is_reg);
                return 0;
            }
        }
    }
    if (expr_kind == AST_CALL || expr_kind == AST_METHOD_CALL || expr_kind == AST_CALL_PTR) {
        return emit_return_slice_from_call(ctx, expr);
    }
    var slice_regs: *SliceRegs = slice_regs(ctx, expr);
    var ptr_reg2: u64 = slice_regs.ptr_reg;
    var len_reg2: u64 = slice_regs.len_reg;
    var ret_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_RET, 0, operand_reg(ptr_reg2), operand_reg(len_reg2));
    append_inst(ctx.cur_block, ret_ptr);
    return 0;
}

func emit_return_void_inst(ctx: *BuilderCtx) -> u64 {
    var ret_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_RET, 0, 0, 0);
    append_inst(ctx.cur_block, ret_ptr);
    return 0;
}

func stmt_return_try_struct_literal(ctx: *BuilderCtx, expr: u64) -> u64 {
    if (ast_kind(expr) != AST_STRUCT_LITERAL) {
        return 0;
    }
    var lit: *AstStructLiteral = (*AstStructLiteral)expr;
    var fallback_name: []u8 = ret_struct_name_current();
    var struct_size: u64 = resolve_struct_literal_size(ctx, lit, fallback_name);
    if (struct_size == 0) {
        emit_stderr("[ERROR] SSA return struct literal size unresolved\n");
        return 1;
    }
    if (struct_size > 16) {
        if (ctx.sret_addr_reg == 0) { return 1; }
        struct_literal_init(ctx, lit.struct_def, lit.values_vec, ctx.sret_addr_reg);
        emit_return_void_inst(ctx);
        return 1;
    }
    emit_return_struct_from_literal(ctx, lit, struct_size);
    return 1;
}

func stmt_return_try_stack_ctor(ctx: *BuilderCtx, expr: u64) -> u64 {
    if (ast_kind(expr) != AST_STACK_CTOR) {
        return 0;
    }
    var sc_ret: *AstStackCtor = (*AstStackCtor)expr;
    var sc_ti: *TypeInfo = get_expr_type_with_symtab(expr, ctx.symtab);
    if (sc_ti == 0 || sc_ti.type_kind != TYPE_STRUCT || sc_ti.ptr_depth != 0) { return 1; }
    var sc_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, sc_ti.struct_name);
    if (sc_size == 0) { return 1; }
    if (sc_size > 16) {
        if (ctx.sret_addr_reg == 0) { return 1; }
        stack_ctor_init_at_addr(ctx, sc_ret, ctx.sret_addr_reg);
        emit_return_void_inst(ctx);
        return 1;
    }
    var tmp_offset_sc: u64 = symtab_add(ctx.symtab, slice(0, 0), TYPE_STRUCT, 0, sc_size);
    var tmp_addr_sc: u64 = new_lea_local(ctx, tmp_offset_sc);
    stack_ctor_init_at_addr(ctx, sc_ret, tmp_addr_sc);
    emit_return_struct_from_addr_reg(ctx, tmp_addr_sc, sc_size);
    return 1;
}

func stmt_return_large_struct(ctx: *BuilderCtx, expr: u64, expr_kind: u64, struct_size: u64) -> u64 {
    if (ctx.sret_addr_reg == 0) {
        return 0;
    }
    if (expr_kind == AST_STRUCT_LITERAL) {
        var lit: *AstStructLiteral = (*AstStructLiteral)expr;
        struct_literal_init(ctx, lit.struct_def, lit.values_vec, ctx.sret_addr_reg);
    } else if (emit_struct_call_sret_by_kind(ctx, expr_kind, expr, ctx.sret_addr_reg) == 0) {
        var src_addr: u64 = lvalue_addr(ctx, expr);
        if (src_addr == 0) { return 0; }
        struct_copy(ctx, ctx.sret_addr_reg, src_addr, struct_size);
    }
    emit_return_void_inst(ctx);
    return 0;
}

func stmt_return_resolve_struct_target(ctx: *BuilderCtx, expr: u64, ret_type: u64, ret_ptr_depth: u64, ret_struct_name: []u8) -> BuilderReturnStructTarget {
    var target: BuilderReturnStructTarget;
    target.use_struct_return = 0;
    target.struct_name = ret_struct_name;
    target.expr_struct_def = 0;
    var ret_expr_ti: *TypeInfo = get_expr_type_with_symtab(expr, ctx.symtab);
    var ret_expr_is_struct: u64 = 0;
    var ret_expr_struct_name: []u8 = slice(0, 0);
    var ret_expr_struct_def: *AstStructDef = 0;
    if (ret_expr_ti != 0) {
        if (ret_expr_ti.type_kind == TYPE_STRUCT && ret_expr_ti.ptr_depth == 0) {
            ret_expr_is_struct = 1;
            ret_expr_struct_name = ret_expr_ti.struct_name;
            ret_expr_struct_def = ret_expr_ti.struct_def;
        }
    }

    if (ret_type == TYPE_STRUCT && ret_ptr_depth == 0) {
        target.use_struct_return = 1;
        if ((u8_slice_ptr(target.struct_name) == 0 || u8_slice_len(target.struct_name) == 0) && ret_expr_is_struct != 0) {
            target.struct_name = ret_expr_struct_name;
            if ((u8_slice_ptr(target.struct_name) == 0 || u8_slice_len(target.struct_name) == 0) && ret_expr_struct_def != 0) {
                var ret_expr_struct_info: *AstStructDef = ret_expr_struct_def;
                target.struct_name = ret_expr_struct_info.name;
            }
        }
    } else if (ret_expr_is_struct != 0) {
        target.use_struct_return = 1;
        target.struct_name = ret_expr_struct_name;
        if ((u8_slice_ptr(target.struct_name) == 0 || u8_slice_len(target.struct_name) == 0) && ret_expr_struct_def != 0) {
            var ret_expr_struct_info2: *AstStructDef = ret_expr_struct_def;
            target.struct_name = ret_expr_struct_info2.name;
        }
    }
    if (ctx.sret_addr_reg != 0) {
        target.use_struct_return = 1;
    }
    target.expr_struct_def = ret_expr_struct_def;
    return target;
}

func stmt_return_emit_struct(ctx: *BuilderCtx, expr: u64, struct_name0: []u8, ret_expr_struct_def: *AstStructDef) -> u64 {
    var expr_kind: u64 = ast_kind(expr);
    var struct_name: []u8 = struct_name0;
    var struct_size: u64 = 0;
    var struct_def_for_size: *AstStructDef = ret_expr_struct_def;
    if ((u8_slice_ptr(struct_name) == 0 || u8_slice_len(struct_name) == 0) && expr_kind == AST_CALL) {
        var call_node0: *AstCall = (*AstCall)expr;
        var call_fn0: *AstFunc = sym_get_func(call_node0.name);
        if (call_fn0 != 0) {
            if (call_fn0.ret_type == TYPE_STRUCT && call_fn0.ret_ptr_depth == 0) {
                struct_name = call_fn0.ret_struct_name;
                struct_def_for_size = get_struct_def(struct_name);
            }
        }
    }
    if (struct_def_for_size == 0 && expr_kind == AST_STRUCT_LITERAL) {
        var lit_size: *AstStructLiteral = (*AstStructLiteral)expr;
        struct_def_for_size = lit_size.struct_def;
    }
    if (u8_slice_ptr(struct_name) != 0 && u8_slice_len(struct_name) != 0) {
        struct_size = layout_type_sizeof(TYPE_STRUCT, 0, struct_name);
    }
    if (struct_def_for_size != 0) {
        var def_size: u64 = struct_size_from_def(struct_def_for_size);
        if (def_size > struct_size) { struct_size = def_size; }
    }
    if (u8_slice_ptr(struct_name) != 0 && u8_slice_len(struct_name) != 0) {
        var name_def: *AstStructDef = get_struct_def(struct_name);
        if (name_def != 0) {
            var name_def_size: u64 = struct_size_from_def(name_def);
            if (name_def_size > struct_size) { struct_size = name_def_size; }
        }
    }
    if (struct_size == 0 && expr_kind == AST_STRUCT_LITERAL) {
        var lit_fallback: *AstStructLiteral = (*AstStructLiteral)expr;
        struct_size = resolve_struct_literal_size(ctx, lit_fallback, struct_name);
    }
    if (expr_kind == AST_CALL) {
        var call_node: *AstCall = (*AstCall)expr;
        var call_fn: *AstFunc = sym_get_func(call_node.name);
        if (call_fn != 0) {
            if (call_fn.ret_type == TYPE_STRUCT && call_fn.ret_ptr_depth == 0) {
                var call_def: *AstStructDef = get_struct_def(call_fn.ret_struct_name);
                var call_def_size: u64 = struct_size_from_def(call_def);
                if (call_def_size > 16 && ctx.sret_addr_reg != 0) {
                    emit_call_sret_value(ctx, call_node, ctx.sret_addr_reg);
                    emit_return_void_inst(ctx);
                    return 0;
                }
                if (call_def_size == 0) {
                    call_def_size = layout_type_sizeof(TYPE_STRUCT, 0, call_fn.ret_struct_name);
                }
                if (call_def_size > struct_size) { struct_size = call_def_size; }
            }
        }
    }
    if (struct_size == 0) {
        emit_stderr("[ERROR] SSA return struct size unresolved\n");
        return 0;
    }
    if (struct_size > 16) {
        stmt_return_large_struct(ctx, expr, expr_kind, struct_size);
        return 0;
    }
    if (expr_kind == AST_STRUCT_LITERAL) {
        return emit_return_struct_from_literal(ctx, (*AstStructLiteral)expr, struct_size);
    }
    if (expr_kind == AST_CALL || expr_kind == AST_METHOD_CALL || expr_kind == AST_CALL_PTR) {
        return emit_return_struct_from_call(ctx, expr, struct_size);
    }
    return emit_return_struct_from_addr(ctx, expr, struct_size);
}

func stmt_return(ctx: *BuilderCtx, node: u64) -> u64 {
    var ret: *AstReturn = (*AstReturn)node;
    defer_emit_for_return(ctx);
    if (ret.expr == 0) {
        emit_return_void_inst(ctx);
        return 0;
    }

    if (stmt_return_try_struct_literal(ctx, ret.expr) != 0) {
        return 0;
    }

    if (stmt_return_try_stack_ctor(ctx, ret.expr) != 0) {
        return 0;
    }

    var ret_type: u64 = ret_type_current();
    var ret_ptr_depth: u64 = ret_ptr_depth_current();
    var ret_struct_name: []u8 = ret_struct_name_current();
    if (ssa_return_validate_expr(ctx, ret.expr) == 0) {
        return 0;
    }
    var struct_target: BuilderReturnStructTarget = stmt_return_resolve_struct_target(ctx, ret.expr, ret_type, ret_ptr_depth, ret_struct_name);

    if (struct_target.use_struct_return != 0) {
        return stmt_return_emit_struct(ctx, ret.expr, struct_target.struct_name, struct_target.expr_struct_def);
    }

    if (ret_type == TYPE_SLICE && ret_ptr_depth == 0) {
        return emit_return_slice_value(ctx, ret.expr);
    }

    var ret_ti: *TypeInfo = get_expr_type_with_symtab(ret.expr, ctx.symtab);
    if (ret_ti != 0 && ret_ti.type_kind == TYPE_SLICE && ret_ti.ptr_depth == 0) {
        return emit_return_slice_value(ctx, ret.expr);
    }

    var val_reg4: u64 = build_expr(ctx, ret.expr);
    var ret_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_RET, 0, operand_reg(val_reg4), 0);
    append_inst(ctx.cur_block, ret_ptr);
    return 0;
}

func stmt_expr_stmt(ctx: *BuilderCtx, node: u64) -> u64 {
    var es: *AstExprStmt = (*AstExprStmt)node;
    if (emit_expr_stmt_call(ctx, es.expr) != 0) {
        return 0;
    }
    build_expr(ctx, es.expr);
    return 0;
}

func stmt_const_decl(ctx: *BuilderCtx, node: u64) -> u64 {
    var cd: *AstConstDecl = (*AstConstDecl)node;
    set_const(ctx, cd.name, cd.value);
    return 0;
}

func defer_stack_len(ctx: *BuilderCtx) -> u64 {
    if (ctx == 0 || ctx.defer_stack == 0) { return 0; }
    return ctx.defer_stack.len();
}

func defer_mark_block_begin(ctx: *BuilderCtx) -> u64 {
    if (ctx == 0) { return 0; }
    if (ctx.defer_markers == 0) { ctx.defer_markers = new Vec<u64>{heap_alloc((16) * sizeof(u64)), 0, (16)}; }
    ctx.defer_markers.push(defer_stack_len(ctx));
    return 0;
}

func defer_emit_to(ctx: *BuilderCtx, marker: u64, pop_after_emit: u64) -> u64 {
    if (ctx == 0 || ctx.defer_stack == 0) { return 0; }
    var stack: *Vec<*AstNode> = ctx.defer_stack;
    if (marker > stack.len()) { marker = stack.len(); }
    var i: u64 = stack.len();
    while (i > marker) {
        var idx: u64 = i - 1;
        var stmt: *AstNode = stack.get(idx);
        var prev_mode: u64 = ctx.defer_emit_mode;
        ctx.defer_emit_mode = 1;
        build_stmt(ctx, stmt);
        ctx.defer_emit_mode = prev_mode;
        if (pop_after_emit != 0) {
            stack.pop();
        }
        i = idx;
    }
    return 0;
}

func defer_mark_block_end(ctx: *BuilderCtx) -> u64 {
    if (ctx == 0 || ctx.defer_markers == 0 || ctx.defer_markers.len() == 0) { return 0; }
    var marker: u64 = ctx.defer_markers.get(ctx.defer_markers.len() - 1);
    ctx.defer_markers.pop();
    defer_emit_to(ctx, marker, 1);
    return 0;
}

func defer_push_loop_marker(ctx: *BuilderCtx) -> u64 {
    if (ctx == 0) { return 0; }
    if (ctx.defer_loop_markers == 0) { ctx.defer_loop_markers = new Vec<u64>{heap_alloc((8) * sizeof(u64)), 0, (8)}; }
    ctx.defer_loop_markers.push(defer_stack_len(ctx));
    return 0;
}

func defer_pop_loop_marker(ctx: *BuilderCtx) -> u64 {
    if (ctx == 0 || ctx.defer_loop_markers == 0 || ctx.defer_loop_markers.len() == 0) { return 0; }
    ctx.defer_loop_markers.pop();
    return 0;
}

func defer_emit_to_loop_marker(ctx: *BuilderCtx) -> u64 {
    if (ctx == 0 || ctx.defer_loop_markers == 0 || ctx.defer_loop_markers.len() == 0) { return 0; }
    var marker: u64 = ctx.defer_loop_markers.get(ctx.defer_loop_markers.len() - 1);
    defer_emit_to(ctx, marker, 0);
    return 0;
}

func defer_emit_for_return(ctx: *BuilderCtx) -> u64 {
    defer_emit_to(ctx, 0, 0);
    return 0;
}

func stmt_delete(ctx: *BuilderCtx, node: u64) -> u64 {
    var dl: *AstDelete = (*AstDelete)node;
    if (dl == 0 || dl.expr == 0) { return 0; }

    var ptr_reg: u64 = build_expr(ctx, dl.expr);
    var cond_reg: u64 = build_bool_from_reg(ctx, ptr_reg);
    var ti: *TypeInfo = get_expr_type_with_symtab(dl.expr, ctx.symtab);
    var closure_handle_from_tracker: u64 = closure_expr_is_lambda_handle(ctx, dl.expr);
    var closure_handle_delete: u64 = closure_handle_from_tracker;
    var typed_closure_delete: u64 = 0;
    var closure_struct_def: *AstStructDef = 0;
    if (ti != 0 && ti.type_kind == TYPE_STRUCT && ti.ptr_depth > 0 &&
        typeinfo_is_lambda_closure_name(ti.struct_name) != 0) {
        typed_closure_delete = 1;
        closure_handle_delete = 1;
        closure_struct_def = ti.struct_def;
        if (closure_struct_def == 0) {
            closure_struct_def = get_struct_def(ti.struct_name);
        }
    }

    var do_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var end_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);

    var br_ptr: *SSAInstruction = create_inst(
        ctx.ssa_ctx,
        SSA_OP_BR,
        operand_const(end_bb.id),
        operand_reg(cond_reg),
        operand_const(do_bb.id)
    );
    append_inst(ctx.cur_block, br_ptr);
    connect_blocks(ctx.cur_block, do_bb);
    connect_blocks(ctx.cur_block, end_bb);

    ctx.cur_block = do_bb;
    if (closure_handle_delete == 0 && ti != 0 && ti.ptr_depth == 0) {
        emit_stderr("[ERROR] delete expects pointer type or lambda closure handle\n");
        diag_error("SSA build error");
    }

    if (closure_handle_delete != 0) {
        var free_ptr_closure: u64 = (u64)"free";
        var free_len_closure: u64 = 4;
        var free_res_closure: *NameInfo = resolve_name(slice(free_ptr_closure, free_len_closure));
        if (free_res_closure != 0) {
            free_ptr_closure = free_res_closure.ptr;
            free_len_closure = free_res_closure.len;
        }

        var closure_obj_reg: u64 = ptr_reg;
        var closure_env_reg: u64 = 0;
        if (typed_closure_delete != 0) {
            if (closure_struct_def == 0) {
                emit_stderr("[ERROR] lambda closure struct metadata not found in delete\n");
                diag_error("SSA build error");
            }
            var env_offset: u64 = 0;
            var env_desc: *FieldDesc = 0;
            if (struct_find_field_desc_scoped(closure_struct_def, slice(0, 0), slice("env", 3), &env_offset, &env_desc) == 0) {
                emit_stderr("[ERROR] lambda closure env field not found in delete\n");
                diag_error("SSA build error");
            }
            if (env_offset == 0) {
                closure_env_reg = load_by_size(ctx, closure_obj_reg, 8);
            } else {
                var env_off_reg_typed: u64 = build_const(ctx, env_offset);
                var env_addr_reg_typed: u64 = new_reg(ctx);
                var env_add_ptr_typed: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, env_addr_reg_typed, operand_reg(closure_obj_reg), operand_reg(env_off_reg_typed));
                append_inst(ctx.cur_block, env_add_ptr_typed);
                closure_env_reg = load_by_size(ctx, env_addr_reg_typed, 8);
            }
        } else {
            closure_obj_reg = mask_tagged_ptr(ctx, ptr_reg);
            var env_off_reg: u64 = build_const(ctx, 16);
            var env_addr_reg: u64 = new_reg(ctx);
            var env_add_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ADD, env_addr_reg, operand_reg(closure_obj_reg), operand_reg(env_off_reg));
            append_inst(ctx.cur_block, env_add_ptr);
            closure_env_reg = load_by_size(ctx, env_addr_reg, 8);
        }

        var free_env_args: *Vec<u64> = make_args1(closure_env_reg);
        emit_call_name_raw(ctx, slice(free_ptr_closure, free_len_closure), free_env_args, 0, 0, TYPE_I64, 0, 0);
        var free_obj_args: *Vec<u64> = make_args1(closure_obj_reg);
        emit_call_name_raw(ctx, slice(free_ptr_closure, free_len_closure), free_obj_args, 0, 0, TYPE_I64, 0, 0);

        var closure_jmp_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(end_bb.id), 0);
        append_inst(ctx.cur_block, closure_jmp_ptr);
        connect_blocks(ctx.cur_block, end_bb);
        ctx.cur_block = end_bb;
        return 0;
    }

    if (ti != 0 && ti.type_kind == TYPE_STRUCT && ti.ptr_depth > 0) {
        var method_ptr: u64 = (u64)"destructor";
        var method_len: u64 = 10;
        var name_info: *NameInfo = build_method_name(ti.struct_name, slice(method_ptr, method_len));

        var resolved_ptr: u64 = name_info.ptr;
        var resolved_len: u64 = name_info.len;
        var resolved: *NameInfo = resolve_name(slice(name_info.ptr, name_info.len));
        if (resolved != 0) {
            resolved_ptr = resolved.ptr;
            resolved_len = resolved.len;
        }

        var has_dtor: u64 = 0;
        if (sym_func_exists(slice(name_info.ptr, name_info.len)) != 0) {
            has_dtor = 1;
        } else if (resolved != 0 && sym_func_exists(slice(resolved_ptr, resolved_len)) != 0) {
            has_dtor = 1;
        }

        if (has_dtor != 0) {
            var dtor_args: *Vec<u64> = make_args1(ptr_reg);
            emit_call_name_raw(ctx, slice(resolved_ptr, resolved_len), dtor_args, 0, 0, TYPE_VOID, 0, 0);
        }
    }

    var free_ptr: u64 = (u64)"free";
    var free_len: u64 = 4;
    var free_res: *NameInfo = resolve_name(slice(free_ptr, free_len));
    if (free_res != 0) {
        free_ptr = free_res.ptr;
        free_len = free_res.len;
    }
    var free_args: *Vec<u64> = make_args1(ptr_reg);
    emit_call_name_raw(ctx, slice(free_ptr, free_len), free_args, 0, 0, TYPE_I64, 0, 0);

    var jmp_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(end_bb.id), 0);
    append_inst(ctx.cur_block, jmp_ptr);
    connect_blocks(ctx.cur_block, end_bb);

    ctx.cur_block = end_bb;
    return 0;
}

func stmt_emit_loop_jump(ctx: *BuilderCtx, target_bb: *SSABlock) -> u64 {
    if (target_bb != 0) {
        var jmp_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(target_bb.id), 0);
        append_inst(ctx.cur_block, jmp_ptr);
        connect_blocks(ctx.cur_block, target_bb);
    }
    var dead_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    ctx.cur_block = dead_bb;
    return 0;
}

func stmt_dispatch_structural(ctx: *BuilderCtx, node: u64, kind: u64) -> BuilderStmtDispatchResult {
    var result: BuilderStmtDispatchResult;
    result.matched = 0;
    result.result = 0;
    if (kind == AST_BLOCK) {
        build_block(ctx, node);
        result.matched = 1;
        return result;
    }
    if (kind == AST_IF) {
        build_if(ctx, node);
        result.matched = 1;
        return result;
    }
    if (kind == AST_WHILE) {
        build_while(ctx, node);
        result.matched = 1;
        return result;
    }
    if (kind == AST_FOR) {
        build_for(ctx, node);
        result.matched = 1;
        return result;
    }
    if (kind == AST_SWITCH || kind == AST_MATCH) {
        build_match_stmt(ctx, node);
        result.matched = 1;
        return result;
    }
    if (kind == AST_ALIAS) {
        var al: *AstAlias = (*AstAlias)node;
        if (ctx.debug_mode != 0) {
            emit("[DEBUG] alias reg=");
            emit_len(u8_slice_ptr(al.reg), u8_slice_len(al.reg));
            emit(" name=");
            emit_len(u8_slice_ptr(al.name), u8_slice_len(al.name));
            emit("\n");
        }
        sym_reg_alias_set(al.reg, al.name);
        result.matched = 1;
        return result;
    }
    if (kind == AST_DEFER) {
        var df: *AstDefer = (*AstDefer)node;
        if (ctx.defer_emit_mode != 0) {
            if (df != 0 && df.stmt != 0) {
                result.result = build_stmt(ctx, df.stmt);
            }
        } else if (ctx.defer_stack != 0 && df != 0 && df.stmt != 0) {
            ctx.defer_stack.push(df.stmt);
        }
        result.matched = 1;
        return result;
    }
    if (kind == AST_DELETE) {
        result.matched = 1;
        result.result = stmt_delete(ctx, node);
        return result;
    }
    if (kind == AST_ASM) {
        var a: *AstAsm = (*AstAsm)node;
        var lowered_text: *Vec<u64> = ssa_asm_clone_with_current_aliases(a.text_vec);
        var inst_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_ASM, 0, operand_const(lowered_text), 0);
        append_inst(ctx.cur_block, inst_ptr);
        result.matched = 1;
        return result;
    }
    if (kind == AST_BREAK) {
        result.matched = 1;
        defer_emit_to_loop_marker(ctx);
        result.result = stmt_emit_loop_jump(ctx, top_break(ctx));
        return result;
    }
    if (kind == AST_CONTINUE) {
        result.matched = 1;
        defer_emit_to_loop_marker(ctx);
        result.result = stmt_emit_loop_jump(ctx, top_continue(ctx));
        return result;
    }
    return result;
}

func stmt_dispatch_terminal(ctx: *BuilderCtx, node: u64, kind: u64) -> BuilderStmtDispatchResult {
    var result: BuilderStmtDispatchResult;
    result.matched = 0;
    result.result = 0;
    if (kind == AST_EXPR_STMT) {
        result.matched = 1;
        result.result = stmt_expr_stmt(ctx, node);
        return result;
    }
    if (kind == AST_VAR_DECL) {
        result.matched = 1;
        result.result = stmt_var_decl(ctx, node);
        return result;
    }
    if (kind == AST_CONST_DECL) {
        result.matched = 1;
        result.result = stmt_const_decl(ctx, node);
        return result;
    }
    if (kind == AST_ASSIGN) {
        result.matched = 1;
        result.result = stmt_assign(ctx, node);
        return result;
    }
    if (kind == AST_RETURN) {
        result.matched = 1;
        result.result = stmt_return(ctx, node);
        return result;
    }
    return result;
}

func build_stmt(ctx: *BuilderCtx, node: u64) -> u64 {
    push_trace("build_stmt", "ssa_builder.b", __LINE__);
    defer pop_trace();
    var kind: u64 = ast_kind(node);
    if (SSA_BUILDER_DEBUG != 0) {
        emit("[DEBUG] build_stmt kind=");
        print_u64(kind);
        emit("\n");
    }

    var structural_result: BuilderStmtDispatchResult = stmt_dispatch_structural(ctx, node, kind);
    if (structural_result.matched != 0) { return structural_result.result; }

    var terminal_result: BuilderStmtDispatchResult = stmt_dispatch_terminal(ctx, node, kind);
    if (terminal_result.matched != 0) { return terminal_result.result; }

    return 0;
}

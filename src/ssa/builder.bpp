        var sd: *AstStructDef = g_structs_vec.get(i);
        if (sd.name_len == struct_name_len && str_eq(sd.name_ptr, sd.name_len, struct_name_ptr, struct_name_len) != 0) {
            ti.struct_def = sd;
            return 0;
        }
    }
    return 0;
}


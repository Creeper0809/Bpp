    var closure_reg: u64 = call_ptr_callee_reg(ctx, cp.callee);
    var unpacked: *SliceRegs = lambda_closure_unpack_regs(ctx, closure_reg);
    var fn_reg: u64 = unpacked.ptr_reg;
    var env_reg: u64 = unpacked.len_reg;

    var args: *Vec<u64> = cp.args_vec;
    var arg_regs: *Vec<u64> = make_call_arg_regs(ctx, args, call_prefix_two(addr_reg, env_reg));
    var ret_meta: BuilderCallRetMeta = call_ret_meta(ctx, (u64)cp, TYPE_STRUCT, 0);
    var info: *SSACallPtrInfo = make_call_ptr_info(fn_reg, arg_regs, ret_meta.ret_type, ret_meta.ret_ptr_depth, ret_meta.ret_struct_size);
    var call_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_CALL_PTR, 0, operand_const((u64)info), 0);
    append_inst(ctx.cur_block, call_ptr);
    return 0;
}


func try_emit_failure_return(ctx: *BuilderCtx, tmp_addr: u64, ret_struct_name_ptr: u64, ret_struct_name_len: u64) -> u64 {
    var ret_struct_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, ret_struct_name_ptr, ret_struct_name_len);
    if (ret_struct_size > 16) {
        if (ctx.sret_addr_reg == 0) { return 0; }
        struct_copy(ctx, ctx.sret_addr_reg, tmp_addr, ret_struct_size);
        var ret_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_RET, 0, 0, 0);
        append_inst(ctx.cur_block, ret_ptr);
        return 0;
    }
    emit_return_struct_from_addr_reg(ctx, tmp_addr, ret_struct_size);
    return 0;
}


func emit_call_ptr(ctx: *BuilderCtx, cp: *AstCallPtr, dst: u64, extra_dst: u64) -> u64 {
    var callee_ti: *TypeInfo = get_expr_type_with_symtab(cp.callee, ctx.symtab);
    var sig_ti: *TypeInfo = typeinfo_func_signature(callee_ti);
    if (sig_ti != 0 && sig_ti.fn_params_vec != 0) {
        var args_n: u64 = 0;
        if (cp.args_vec != 0) { args_n = cp.args_vec.len(); }
        var expected_n: u64 = sig_ti.fn_params_vec.len();
        var fixed_n: u64 = expected_n;
        var min_n: u64 = expected_n;
        if (sig_ti.fn_is_variadic != 0 && expected_n > 0) {
            fixed_n = expected_n - 1;
            min_n = fixed_n;
        }
        if (sig_ti.fn_is_variadic == 0 && args_n != expected_n) {
            emit_stderr("[ERROR] function pointer call argument count mismatch: expected ");
            emit_u64_stderr(expected_n);
            emit_stderr(", got ");
            emit_u64_stderr(args_n);
            emit_stderr("\n");
            diag_error("SSA build error");
        }
        if (sig_ti.fn_is_variadic != 0 && args_n < min_n) {
            emit_stderr("[ERROR] function pointer call missing required arguments: expected at least ");
            emit_u64_stderr(min_n);
            emit_stderr(", got ");
            emit_u64_stderr(args_n);
            emit_stderr("\n");
            diag_error("SSA build error");
        }
        for (var i_sig: u64 = 0; i_sig < fixed_n; i_sig++) {
            var expected_ti: *TypeInfo = sig_ti.fn_params_vec.get(i_sig);
            var actual_ti: *TypeInfo = get_expr_type_with_symtab(cp.args_vec.get(i_sig), ctx.symtab);
            if (expected_ti == 0 || actual_ti == 0) {
                emit_stderr("[ERROR] function pointer call argument type mismatch at index ");
                emit_u64_stderr(i_sig);
                emit_stderr("\n");
                diag_error("SSA build error");
            }
            var mismatch: u64 = 0;
            if (typeinfo_is_assignable(actual_ti, expected_ti) == 0) {
                mismatch = 1;
            }
            if (mismatch != 0) {
                emit_stderr("[ERROR] function pointer call argument type mismatch at index ");
                emit_u64_stderr(i_sig);
                emit_stderr("\n");
                diag_error("SSA build error");
            }
        }
        if (sig_ti.fn_is_variadic != 0 && expected_n > 0) {
            var rest_ti: *TypeInfo = sig_ti.fn_params_vec.get(expected_n - 1);
            for (var ri: u64 = fixed_n; ri < args_n; ri++) {
                var actual_rest_ti: *TypeInfo = get_expr_type_with_symtab(cp.args_vec.get(ri), ctx.symtab);
                if (rest_ti == 0 || actual_rest_ti == 0) {
                    emit_stderr("[ERROR] function pointer variadic argument type mismatch at index ");
                    emit_u64_stderr(ri);
                    emit_stderr("\n");
                    diag_error("SSA build error");
                }
                var mismatch2: u64 = 0;
                if (typeinfo_is_assignable(actual_rest_ti, rest_ti) == 0) {
                    mismatch2 = 1;
                }
                if (mismatch2 != 0) {
                    emit_stderr("[ERROR] function pointer variadic argument type mismatch at index ");
                    emit_u64_stderr(ri);
                    emit_stderr("\n");
                    diag_error("SSA build error");
                }
            }
        }
    }

    if (closure_expr_is_lambda_handle(ctx, cp.callee) != 0) {
        return emit_lambda_closure_call(ctx, cp, dst, extra_dst);
    }

    var args: *Vec<u64> = cp.args_vec;
    var arg_regs: *Vec<u64> = make_call_arg_regs(ctx, args, call_prefix_none());

    var callee_reg: u64 = call_ptr_callee_reg(ctx, cp.callee);

    var ret_meta: BuilderCallRetMeta = call_ret_meta(ctx, (u64)cp, TYPE_I64, 0);
    var info: *SSACallPtrInfo = make_call_ptr_info(callee_reg, arg_regs, ret_meta.ret_type, ret_meta.ret_ptr_depth, ret_meta.ret_struct_size);

    var extra_opr3: u64 = 0;
    if (extra_dst != 0) { extra_opr3 = operand_reg(extra_dst); }
    var call_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_CALL_PTR, dst, operand_const((u64)info), extra_opr3);
    append_inst(ctx.cur_block, call_ptr);
    return dst;
}


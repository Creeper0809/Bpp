func emit_checked_vtable_guard(ctx: *BuilderCtx, loaded_vtable_reg: u64, expected_vtable_ptr: u64, expected_vtable_len: u64) -> u64 {
    if (expected_vtable_ptr == 0 || expected_vtable_len == 0) { return 0; }
    var expected_reg: u64 = new_lea_global(ctx, expected_vtable_ptr, expected_vtable_len);
    var cond_reg: u64 = new_reg(ctx);
    var cmp_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_EQ, cond_reg, operand_reg(loaded_vtable_reg), operand_reg(expected_reg));
    append_inst(ctx.cur_block, cmp_ptr);

    var ok_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var fail_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var br_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_BR, operand_const(fail_bb.id), operand_reg(cond_reg), operand_const(ok_bb.id));
    append_inst(ctx.cur_block, br_ptr);
    connect_blocks(ctx.cur_block, ok_bb);
    connect_blocks(ctx.cur_block, fail_bb);

    ctx.cur_block = fail_bb;
    emit_trap_ud2(ctx);
    var jmp_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(ok_bb.id), 0);
    append_inst(ctx.cur_block, jmp_ptr);
    connect_blocks(ctx.cur_block, ok_bb);
=======
    var inst_ptr: *SSAInstruction = ssa_new_inst(ctx.ssa_ctx, SSA_OP_ASM, 0, ssa_operand_const((u64)text_vec), 0);
    ssa_inst_append(ctx.cur_block, inst_ptr);
    return 0;
}


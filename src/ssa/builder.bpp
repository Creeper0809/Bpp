func emit_call(ctx: *BuilderCtx, call: *AstCall, dst: u64, extra_dst: u64) -> u64 {
    var name_ptr: u64 = call.name_ptr;
    var name_len: u64 = call.name_len;
    if (sym_func_exists(name_ptr, name_len) == 0) {
        var callee: *AstNode = ast_ident(name_ptr, name_len);
        var cp: *AstCallPtr = ast_call_ptr(callee, call.args_vec);
        return emit_call_ptr(ctx, cp, dst, extra_dst);
    }
    var resolved_name: *PtrLen = resolve_symbol_name(name_ptr, name_len);

    var args: *Vec<u64> = call.args_vec;
    var arg_regs: *Vec<u64> = make_call_arg_regs(ctx, args, call_prefix_none());

    var ret_meta: BuilderCallRetMeta = call_ret_meta(ctx, (u64)call, TYPE_I64, 0);
    var info: *SSACallInfo = make_call_info(resolved_name.ptr, resolved_name.len, arg_regs, ret_meta.ret_type, ret_meta.ret_ptr_depth, ret_meta.ret_struct_size);

    var extra_opr: u64 = 0;
    if (extra_dst != 0) { extra_opr = operand_reg(extra_dst); }
    var call_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_CALL, dst, operand_const((u64)info), extra_opr);
    append_inst(ctx.cur_block, call_ptr);
    return dst;
}


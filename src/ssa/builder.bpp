func set_closure_handle(ctx: *BuilderCtx, name_ptr: u64, name_len: u64, enabled: u64) -> u64 {
    if (ctx == 0) { return 0; }
    if (ctx.closure_handle_map == 0) {
        ctx.closure_handle_map = new HashMap<u64, u64>(16);
    }
    if (enabled == 0) {
        ctx.closure_handle_map.put(name_ptr, name_len, 0);
        return 0;
    }
    ctx.closure_handle_map.put(name_ptr, name_len, 1);
    return 0;
}

func is_closure_handle(ctx: *BuilderCtx, name_ptr: u64, name_len: u64) -> u64 {
    if (ctx == 0 || ctx.closure_handle_map == 0) { return 0; }
    if (ctx.closure_handle_map.get(name_ptr, name_len) == 1) { return 1; }
    return 0;
}

func is_lambda_bind_name(name_ptr: u64, name_len: u64) -> u64 {
    if (name_ptr == 0 || name_len < 14) { return 0; }
    if (str_eq(name_ptr, 14, "__lambda_bind_", 14) == 0) { return 0; }
    return 1;
}

func closure_expr_is_lambda_handle(ctx: *BuilderCtx, expr: u64) -> u64 {
    if (expr == 0) { return 0; }
    var kind: u64 = ast_kind(expr);
    if (kind == AST_CALL) {
        var call: *AstCall = (*AstCall)expr;
        if (is_lambda_bind_name(call.name_ptr, call.name_len) != 0) { return 1; }
        return 0;
    }
    if (kind == AST_IDENT) {
        var idn: *AstIdent = (*AstIdent)expr;
        return is_closure_handle(ctx, idn.name_ptr, idn.name_len);
    }
    return 0;
}

func closure_track_from_expr(ctx: *BuilderCtx, target_name_ptr: u64, target_name_len: u64, value_expr: u64) -> u64 {
    if (closure_expr_is_lambda_handle(ctx, value_expr) != 0) {
        set_closure_handle(ctx, target_name_ptr, target_name_len, 1);
        return 0;
    }
    set_closure_handle(ctx, target_name_ptr, target_name_len, 0);
    return 0;
}


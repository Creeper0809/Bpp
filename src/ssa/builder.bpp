    var out_reg: u64 = new_reg(ctx);
    var sub_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_SUB, out_reg, operand_reg(zero_reg), operand_reg(one_reg));
    append_inst(ctx.cur_block, sub_ptr);
    return out_reg;
}


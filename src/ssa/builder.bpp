func expr_ternary(ctx: *BuilderCtx, node: u64) -> u64 {
    var tern: *AstTernary = (*AstTernary)node;
    var cond_raw: u64 = build_expr(ctx, tern.cond);
    var cond_reg: u64 = build_bool_from_reg(ctx, cond_raw);

    var then_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var else_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);
    var merge_bb: *SSABlock = create_block(ctx.ssa_ctx, ctx.cur_func);

    var br_ptr: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_BR, operand_const(else_bb.id), operand_reg(cond_reg), operand_const(then_bb.id));
    append_inst(ctx.cur_block, br_ptr);
    connect_blocks(ctx.cur_block, then_bb);
    connect_blocks(ctx.cur_block, else_bb);

    ctx.cur_block = then_bb;
    var then_reg: u64 = build_expr(ctx, tern.then_expr);
    var jmp_then: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(merge_bb.id), 0);
    append_inst(ctx.cur_block, jmp_then);
    connect_blocks(ctx.cur_block, merge_bb);

    ctx.cur_block = else_bb;
    var else_reg: u64 = build_expr(ctx, tern.else_expr);
    var jmp_else: *SSAInstruction = create_inst(ctx.ssa_ctx, SSA_OP_JMP, 0, operand_const(merge_bb.id), 0);
    append_inst(ctx.cur_block, jmp_else);
    connect_blocks(ctx.cur_block, merge_bb);

    ctx.cur_block = merge_bb;
    var head: *SSAPhiArg = create_phi_arg(then_reg, then_bb.id);
    head = append_phi_arg(head, else_reg, else_bb.id);
    var dst: u64 = new_reg(ctx);
    var phi_ptr: *SSAInstruction = create_phi(ctx.ssa_ctx, dst, head);
    append_phi(merge_bb, phi_ptr);
    return dst;
}


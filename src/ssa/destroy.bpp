func emit_copy(ctx: *SSAContext, block: *SSABlock, dst: u64, src: u64) -> u64 {
    var inst_ptr: *SSAInstruction = create_inst(ctx, SSA_OP_COPY, dst, operand_reg(src), 0);
    insert_before_terminator(block, inst_ptr);
    return 0;
}


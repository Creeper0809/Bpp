struct SSASplitEdge {
    public pred: *SSABlock;
    public dst: *SSABlock;
    public split: *SSABlock;
}

impl SSASplitEdge {
    public constructor() {
        self.pred = 0;
        self.dst = 0;
        self.split = 0;
    }
}


// gen_expr.b - Expression code generation
//
// Generates x86-64 assembly for expressions:
// - emit_expr: evaluate expression, result in RAX
// - emit_lvalue: compute address of lvalue, result in RAX

import std.io;
import std.vec;
import std.util;
import std.str;
import types;
import ast;
import compiler;
import compiler.trait_runtime;
import compiler.try_runtime;
import compiler.core_utils;
import compiler.generic.engine;
import compiler.symbol_runtime;
import compiler.call_utils;
import compiler.ast_lowering;
import compiler.runtime_api;
import emitter.emitter;
import emitter.symtab;
import emitter.typeinfo;

// ============================================
// Expression Codegen
// ============================================

func _cg_find_global_info(name: []u8) -> *GlobalInfo {
    var globals: *Vec<*GlobalInfo> = globals_current();
    var n: u64 = 0;
    if (globals != 0) { n = globals.len(); }
    for (var i: u64 = 0; i < n; i++) {
        var ginfo: *GlobalInfo = globals.get(i);
        if (str_eq(slice(ginfo.name_ptr, ginfo.name_len), slice(name.ptr, name.len))) { return ginfo; }
    }
    return 0;
}
var g_tmp_struct_arg_id: u64;
const LAMBDA_CLOSURE_MAGIC = 4778407454613394245;

func emit_codegen_error(msg: u64) -> u64 {
    emit_stderr(msg);
    diag_force_stop_pass();
    return 0;
}

func emit_emit_jump(label_id: u64) -> u64 {
    emit("    jmp ");
    emit_label(label_id);
    emit_nl();
    return 0;
}

func emit_emit_safe_null_epilogue(label_null: u64, label_end: u64) -> u64 {
    emit_emit_jump(label_end);
    emit_label_def(label_null);
    emit("    xor eax, eax\n");
    emit_label_def(label_end);
    return 0;
}

func emit_tagged_mask() -> u64 {
    emit("    mov rbx, ");
    emit_u64(281474976710655);
    emit_nl();
    emit("    and rax, rbx\n");
}

func emit_mask_to_rdx(bit_width: u64) -> u64 {
    emit("    mov rdx, 1\n");
    emit("    mov rcx, ");
    emit_u64(bit_width);
    emit_nl();
    emit("    shl rdx, cl\n");
    emit("    sub rdx, 1\n");
}

func emit_emit_field_load_from_rax(fd: *FieldDesc) -> u64 {
    if (fd == 0) { return 0; }
    emit_load_rax_from_addr(fd.type_kind, fd.ptr_depth);
    return 0;
}

func emit_member_is_bits_field(member: []u8) -> u64 {
    if (member.ptr == 0 || member.len != 4) { return 0; }
    if (str_eq(slice(member.ptr, member.len), slice("bits", str_len("bits"))) != 0) { return 1; }
    return 0;
}

func emit_try_match_struct_def_by_tail(name: []u8) -> *AstStructDef {
    if (name.ptr == 0 || name.len == 0) { return 0; }
    var all_structs: *Vec<*AstStructDef> = typeinfo_get_structs();
    if (all_structs == 0) { return 0; }

    var matched: *AstStructDef = 0;
    var matched_count: u64 = 0;
    var n: u64 = all_structs.len();
    for (var i: u64 = 0; i < n; i++) {
        var sd: *AstStructDef = all_structs.get(i);
        if (sd == 0) { continue; }
        var ok: u64 = 0;
        if (str_eq(slice(sd.name_ptr, sd.name_len), slice(name.ptr, name.len)) != 0) {
            return sd;
        }

        if (sd.name_len > name.len + 2) {
            var s_tail: u64 = sd.name_len - name.len;
            var su8: []u8 = slice(sd.name_ptr, sd.name_len);
            if (su8[s_tail - 2] == 95 && su8[s_tail - 1] == 95 &&
                str_eq(slice(sd.name_ptr + s_tail, name.len), slice(name.ptr, name.len)) != 0) {
                ok = 1;
            }
        }
        if (ok == 0 && name.len > sd.name_len + 2) {
            var n_tail: u64 = name.len - sd.name_len;
            var nu8: []u8 = slice(name.ptr, name.len);
            if (nu8[n_tail - 2] == 95 && nu8[n_tail - 1] == 95 &&
                str_eq(slice(name.ptr + n_tail, sd.name_len), slice(sd.name_ptr, sd.name_len)) != 0) {
                ok = 1;
            }
        }

        if (ok != 0) {
            matched = sd;
            matched_count = matched_count + 1;
            if (matched_count > 1) { return 0; }
        }
    }
    if (matched_count == 1) { return matched; }
    return 0;
}

func emit_hydrate_struct_def_from_type(ti: *TypeInfo) -> *AstStructDef {
    if (ti == 0) { return 0; }
    if (ti.struct_def != 0) {
        if (ti.struct_name_ptr == 0 || ti.struct_name_len == 0) {
            ti.struct_name_ptr = ti.struct_def.name_ptr;
            ti.struct_name_len = ti.struct_def.name_len;
        }
        return ti.struct_def;
    }
    if (ti.struct_name_ptr == 0 || ti.struct_name_len == 0) { return 0; }

    var struct_def: *AstStructDef = get_struct_def(slice(ti.struct_name_ptr, ti.struct_name_len));
    if (struct_def == 0) {
        var resolved: *NameInfo = resolve_name(slice(ti.struct_name_ptr, ti.struct_name_len));
        if (resolved != 0) {
            struct_def = get_struct_def(slice(resolved.ptr, resolved.len));
            if (struct_def != 0) {
                ti.struct_name_ptr = resolved.ptr;
                ti.struct_name_len = resolved.len;
            }
        }
    }
    if (struct_def == 0) {
        struct_def = emit_try_match_struct_def_by_tail(slice(ti.struct_name_ptr, ti.struct_name_len));
    }
    if (struct_def != 0) {
        ti.struct_name_ptr = struct_def.name_ptr;
        ti.struct_name_len = struct_def.name_len;
    }
    ti.struct_def = struct_def;
    return struct_def;
}

func emit_require_tagged_layout_struct(tag_layout: []u8) -> *AstStructDef {
    var layout_info: *AstStructDef = get_struct_def(slice(tag_layout.ptr, tag_layout.len));
    if (layout_info == 0) {
        emit_codegen_error("[ERROR] Tagged layout struct not found\n");
        return 0;
    }
    if (layout_info.is_packed == 0) {
        emit_codegen_error("[ERROR] Tagged layout must be packed struct\n");
        return 0;
    }
    return layout_info;
}

func emit_emit_tagged_layout_extract_from_rax(layout_info: *AstStructDef, member: []u8) -> u64 {
    var total_bits: u64 = get_packed_layout_total_bits(layout_info);
    var field_offset: u64 = get_packed_field_bit_offset(layout_info, slice(member.ptr, member.len));
    var field_width: u64 = get_packed_field_bit_width(layout_info, slice(member.ptr, member.len));
    var start_bit: u64 = 64 - total_bits;
    var shift_bits: u64 = start_bit + field_offset;

    if (shift_bits > 0) {
        emit("    mov rcx, ");
        emit_u64(shift_bits);
        emit_nl();
        emit("    shr rax, cl\n");
    }
    if (field_width < 64) {
        emit_mask_to_rdx(field_width);
        emit("    and rax, rdx\n");
    }
    return 0;
}

// ============================================
// Stack Constructor Helpers
// ============================================

func emit_stack_ctor_emit_memzero(size: u64) -> u64 {
    var memset_ptr: u64 = (u64)"memset";
    var memset_len: u64 = 6;
    var memset_res: *NameInfo = resolve_name(slice(memset_ptr, memset_len));
    if (memset_res != 0) {
        memset_ptr = memset_res.ptr;
        memset_len = memset_res.len;
    }

    _cg_emit_mov_user_arg_from_reg(0, 0, slice("r12", 3));
    _cg_emit_mov_user_arg_imm_u64(1, 0, 0);
    _cg_emit_mov_user_arg_imm_u64(2, 0, size);
    _cg_emit_direct_call_name(slice(memset_ptr, memset_len), 0, 0);
    emit_nl();
    return 0;
}

func emit_resolve_constructor_call(struct_slice: []u8, args: *Vec<*AstNode>, symtab: *Symtab, site: []u8) -> CompilerMethodResolveResult {
    var resolved: CompilerMethodResolveResult = sym_method_resolve_none();
    var method_ptr: u64 = (u64)"constructor";
    var method_len: u64 = 11;
    var arg_count_hint: u64 = 0;
    if (args != 0) { arg_count_hint = args.len(); }
    var base_len: u64 = sym_find_generic_suffix_index(slice(struct_slice.ptr, struct_slice.len));
    var suffix_len: u64 = struct_slice.len - base_len;
    var name_info: *NameInfo = build_method_name_base(slice(struct_slice.ptr, base_len), slice(method_ptr, method_len), suffix_len);
    var alt_info: *NameInfo = build_method_name_base(slice(struct_slice.ptr, base_len), slice(method_ptr, method_len), 0);
    if (sym_func_exists(slice(name_info.ptr, name_info.len)) == 0) {
        var resolved_primary: *NameInfo = resolve_name(slice(name_info.ptr, name_info.len));
        if (resolved_primary != 0 && sym_func_exists(slice(resolved_primary.ptr, resolved_primary.len)) != 0) {
            name_info = resolved_primary;
        }
    }
    if (sym_func_exists(slice(name_info.ptr, name_info.len)) == 0) {
        name_info = alt_info;
        if (sym_func_exists(slice(name_info.ptr, name_info.len)) == 0) {
            var resolved_alt: *NameInfo = resolve_name(slice(name_info.ptr, name_info.len));
            if (resolved_alt != 0 && sym_func_exists(slice(resolved_alt.ptr, resolved_alt.len)) != 0) {
                name_info = resolved_alt;
            }
        }
    }
    if (sym_func_exists(slice(name_info.ptr, name_info.len)) != 0) {
        var fn_ctor: *AstFunc = typeinfo_find_func(slice(name_info.ptr, name_info.len));
        if (fn_ctor == 0) {
            var resolved_name: *NameInfo = resolve_name(slice(name_info.ptr, name_info.len));
            if (resolved_name != 0) {
                fn_ctor = typeinfo_find_func(slice(resolved_name.ptr, resolved_name.len));
            }
        }
        if (fn_ctor != 0) {
            resolved.found = 1;
            resolved.fn = fn_ctor;
            var owner_map: *NameInfo = sym_get_impl_method_owner(slice(name_info.ptr, name_info.len));
            if (owner_map != 0) {
                resolved.owner_ptr = owner_map.ptr;
                resolved.owner_len = owner_map.len;
            } else {
                resolved.owner_ptr = fn_ctor.impl_owner_ptr;
                resolved.owner_len = fn_ctor.impl_owner_len;
            }
            resolved.access = sym_get_impl_method_access(slice(name_info.ptr, name_info.len));
        }
    }
    if (resolved.found == 0 || resolved.fn == 0) {
        var overload_resolved: CompilerMethodResolveResult = sym_resolve_method_overload_with_count_fallback(slice(struct_slice.ptr, struct_slice.len), slice(method_ptr, method_len), 0, arg_count_hint);
        if (overload_resolved.found != 0 && overload_resolved.fn != 0) {
            resolved = overload_resolved;
        }
    }
    if (resolved.found == 0 || resolved.fn == 0) {
        diag_emit_error_tag("codegen", "C2201", "constructor not found");
        emit_stderr("  site: ");
        emit_stderr_len(site.ptr, site.len);
        emit_stderr_nl();
        if (struct_slice.ptr != 0 && struct_slice.len != 0) {
            emit_stderr("  type: ");
            emit_stderr_len(struct_slice.ptr, struct_slice.len);
            emit_stderr_nl();
        }
        diag_emit_help("use brace initialization for pure data setup, or define a matching constructor signature");
        diag_force_stop_pass();
        return resolved;
    }
    if (resolved.owner_ptr == 0 || resolved.owner_len == 0) {
        resolved.owner_ptr = struct_slice.ptr;
        resolved.owner_len = struct_slice.len;
    }
    if (resolved.access == 0) { resolved.access = ACCESS_PUBLIC; }
    if (sym_can_access_member(slice(resolved.owner_ptr, resolved.owner_len), resolved.access) == 0) {
        diag_emit_error_tag("codegen", "C2202", "constructor access denied");
        emit_stderr("  type: ");
        emit_stderr_len(resolved.owner_ptr, resolved.owner_len);
        emit_stderr(".constructor\n");
        diag_force_stop_pass();
        return resolved;
    }
    return resolved;
}

func emit_stack_ctor_emit_constructor_call(sc: *AstStackCtor, symtab: *Symtab, fn_ctor: *AstFunc, call: []u8) -> u64 {
    var args: *Vec<*AstNode> = sc.ctor_args_vec;
    var nargs: u64 = 0;
    if (args != 0) { nargs = args.len(); }
    var total_arg_words: u64 = 0;
    if (nargs != 0) {
        var ai: u64 = nargs;
        while (ai > 0) {
            ai = ai - 1;
            var arg: *AstNode = args.get(ai);
            var param: *Param = emit_call_param_at(fn_ctor, ai + 1);
            total_arg_words = total_arg_words + emit_call_push_arg_with_param(arg, param, symtab);
        }
    }
    emit("    push r12\n");
    total_arg_words = total_arg_words + 1;
    var stack_words: u64 = _cg_sysv_pop_arg_regs(total_arg_words);
    var reserve_words: u64 = _cg_target_call_prepare(stack_words, 0);
    emit("    call ");
    emit_len(call.ptr, call.len);
    emit_nl();
    _cg_target_call_cleanup(stack_words, reserve_words);
    return 0;
}

func emit_stack_ctor_call_at_r12(sc: *AstStackCtor, symtab: *Symtab) -> u64 {
    if (sc.type_kind != TYPE_STRUCT) {
        emit_stderr("[ERROR] stack constructor requires struct type\n");
        diag_force_stop_pass();
        return 0;
    }

    var size: u64 = layout_type_sizeof(sc.type_kind, sc.ptr_depth, slice(sc.struct_name_ptr, sc.struct_name_len));
    emit_stack_ctor_emit_memzero(size);

    emit_emit_trait_vptr_init_at_r12(slice(sc.struct_name_ptr, sc.struct_name_len));
    var resolved_ctor: CompilerMethodResolveResult = emit_resolve_constructor_call(slice(sc.struct_name_ptr, sc.struct_name_len), sc.ctor_args_vec, symtab, slice("stack ctor", 10));
    if (resolved_ctor.found == 0 || resolved_ctor.fn == 0) {
        return 0;
    }
    var call_ptr: u64 = resolved_ctor.fn.name_ptr;
    var call_len: u64 = resolved_ctor.fn.name_len;
    var alias_name: *NameInfo = resolve_name(slice(call_ptr, call_len));
    if (alias_name != 0) {
        call_ptr = alias_name.ptr;
        call_len = alias_name.len;
    }
    return emit_stack_ctor_emit_constructor_call(sc, symtab, resolved_ctor.fn, slice(call_ptr, call_len));
}

func emit_stack_ctor_init_to_offset(sc: *AstStackCtor, dest_offset: u64, symtab: *Symtab) -> u64 {
    emit("    lea r12, [rbp");
    emit_signed_disp(dest_offset);
    emit("]\n");
    return emit_stack_ctor_call_at_r12(sc, symtab);
}

func emit_emit_trait_vptr_init_at_r12(struct_name: []u8) -> u64 {
    var impls: *Vec<*TraitImpl> = sym_get_trait_impls();
    if (impls == 0) { return 0; }
    var struct_def: *AstStructDef = get_struct_def(slice(struct_name.ptr, struct_name.len));
    if (struct_def == 0) { return 0; }

    var n: u64 = impls.len();
    for (var i: u64 = 0; i < n; i++) {
        var impl_info: *TraitImpl = impls.get(i);
        if (!str_eq(slice(impl_info.struct_ptr, impl_info.struct_len), slice(struct_name.ptr, struct_name.len))) { continue; }
        var vptr_name: *NameInfo = trait_build_vptr_field_name(slice(impl_info.trait_ptr, impl_info.trait_len));
        var field_offset: u64 = 0;
        var field_desc: *FieldDesc = 0;
        var found: u64 = struct_find_field_desc_scoped(struct_def, slice(0, 0), slice(vptr_name.ptr, vptr_name.len), &field_offset, &field_desc);
        if (found == 0) {
            emit_stderr("[ERROR] vptr field not found for trait init\n");
            diag_force_stop_pass();
        return 0;
        }
        emit("    lea rax, [rel _gvar_");
        emit_len(impl_info.vtable_global_ptr, impl_info.vtable_global_len);
        emit("]\n");
        emit("    mov [r12");
        if (field_offset != 0) { emit("+"); emit_u64(field_offset); }
        emit("], rax\n");
    }
    return 0;
}

func emit_call_resolved_expr(name: []u8) -> u64 {
    var resolved_ptr: u64 = name.ptr;
    var resolved_len: u64 = name.len;
    var resolved: *NameInfo = resolve_name(slice(name.ptr, name.len));
    if (resolved != 0) {
        resolved_ptr = resolved.ptr;
        resolved_len = resolved.len;
    }
    emit("    call ");
    emit_len(resolved_ptr, resolved_len);
    emit_nl();
    return 0;
}

func emit_alloc_tmp_struct(symtab: *Symtab, struct_size: u64) -> u64 {
    var base_ptr: u64 = (u64)"__cg_tmp_struct_arg";
    var base_len: u64 = 19;
    var name_len: u64 = base_len + 8;
    var name_ptr: u64 = heap_alloc(name_len);
    var name_u8: []u8 = slice(name_ptr, name_len);
    var base_u8: []u8 = slice(base_ptr, base_len);
    for (var i: u64 = 0; i < base_len; i++) {
        name_u8[i] = base_u8[i];
    }
    var id: u64 = g_tmp_struct_arg_id;
    g_tmp_struct_arg_id = g_tmp_struct_arg_id + 1;
    for (var j: u64 = 0; j < 8; j++) {
        name_u8[base_len + j] = (id >> (j * 8)) & 255;
    }
    return symtab_add(symtab, slice(name_ptr, name_len), TYPE_STRUCT, 0, struct_size);
}

func emit_call_sret_to_offset(call_ptr: u64, dest_offset: u64, symtab: *Symtab) -> u64 {
    var call: *AstCall = (*AstCall)call_ptr;
    var fn_call: *AstFunc = typeinfo_find_func(slice(call.name_ptr, call.name_len));
    var args: *Vec<*AstNode> = call.args_vec;
    var nargs: u64 = 0;
    if (args != 0) { nargs = args.len(); }
    var total_arg_words: u64 = 0;
    if (nargs > 0) {
        var i: u64 = nargs;
        while (i > 0) {
            i = i - 1;
            var arg: *AstNode = args.get(i);
            var param: *Param = emit_call_param_at(fn_call, i);
            total_arg_words = total_arg_words + emit_call_push_arg_with_param(arg, param, symtab);
        }
    }

    _cg_emit_sret_ptr_from_rbp(dest_offset);
    var stack_words: u64 = _cg_sysv_pop_arg_regs_sret(total_arg_words);
    var reserve_words: u64 = _cg_target_call_prepare(stack_words, 0);
    emit_call_resolved_expr(slice(call.name_ptr, call.name_len));
    _cg_target_call_cleanup(stack_words, reserve_words);
    return 0;
}

func emit_method_call_ret_struct_size(mc: *AstMethodCall, symtab: *Symtab) -> u64 {
    var receiver: u64 = mc.receiver;
    var recv_ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)receiver, symtab);
    if (recv_ti == 0) { return 0; }
    if (recv_ti.type_kind != TYPE_STRUCT) { return 0; }
    var struct_ptr: u64 = recv_ti.struct_name_ptr;
    var struct_len: u64 = recv_ti.struct_name_len;
    if (struct_ptr == 0 || struct_len == 0) { return 0; }

    var args: *Vec<*AstNode> = mc.args_vec;
    var nargs: u64 = 0;
    if (args != 0) { nargs = args.len(); }
    var arg_types: *Vec<*TypeInfo> = typeinfo_collect_arg_types(args, symtab);
    var resolved: CompilerMethodResolveResult = sym_resolve_method_overload(slice(struct_ptr, struct_len), slice(mc.method_ptr, mc.method_len), arg_types, nargs);
    var fn: *AstFunc = 0;
    if (resolved.found != 0) { fn = resolved.fn; }
    if (fn == 0) {
        var name_info: *NameInfo = build_method_name(slice(struct_ptr, struct_len), slice(mc.method_ptr, mc.method_len));
        fn = typeinfo_find_func(slice(name_info.ptr, name_info.len));
    }
    if (fn == 0) { return 0; }
    if (fn.ret_type != TYPE_STRUCT || fn.ret_ptr_depth != 0) { return 0; }
    var struct_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, slice(fn.ret_struct_name_ptr, fn.ret_struct_name_len));
    if (struct_size <= 16) { return 0; }
    return struct_size;
}

func emit_method_call_sret_to_offset(mc: *AstMethodCall, dest_offset: u64, symtab: *Symtab) -> u64 {
    var receiver: u64 = mc.receiver;
    var type_info: *TypeInfo = get_expr_type_with_symtab((*AstNode)receiver, symtab);
    var struct_name_ptr: u64 = 0;
    var struct_name_len: u64 = 0;
    if (type_info != 0) {
        struct_name_ptr = type_info.struct_name_ptr;
        struct_name_len = type_info.struct_name_len;
    }
    var args: *Vec<*AstNode> = mc.args_vec;
    var nargs: u64 = 0;
    if (args != 0) { nargs = args.len(); }
    var arg_types: *Vec<*TypeInfo> = typeinfo_collect_arg_types(args, symtab);
    var resolved_ptr: u64 = 0;
    var resolved_len: u64 = 0;
    var fn_call: *AstFunc = 0;
    var resolved_m: CompilerMethodResolveResult = sym_resolve_method_overload(slice(struct_name_ptr, struct_name_len), slice(mc.method_ptr, mc.method_len), arg_types, nargs);
    if (resolved_m.found != 0 && resolved_m.fn != 0) {
        fn_call = resolved_m.fn;
        resolved_ptr = fn_call.name_ptr;
        resolved_len = fn_call.name_len;
    }
    if (fn_call == 0) {
        var name_info: *NameInfo = build_method_name(slice(struct_name_ptr, struct_name_len), slice(mc.method_ptr, mc.method_len));
        resolved_ptr = name_info.ptr;
        resolved_len = name_info.len;
        var resolved: *NameInfo = resolve_name(slice(name_info.ptr, name_info.len));
        if (resolved != 0) {
            resolved_ptr = resolved.ptr;
            resolved_len = resolved.len;
        }
        fn_call = typeinfo_find_func(slice(resolved_ptr, resolved_len));
        if (fn_call == 0) {
            fn_call = typeinfo_find_func(slice(name_info.ptr, name_info.len));
        }
    }
    var total_arg_words: u64 = 0;

    if (nargs != 0) {
        var i: u64 = nargs;
        while (i > 0) {
            i = i - 1;
            var arg: *AstNode = args.get(i);
            var param: *Param = emit_call_param_at(fn_call, i + 1);
            total_arg_words = total_arg_words + emit_call_push_arg_with_param(arg, param, symtab);
        }
    }

    var recv_is_ptr: u64 = 0;
    if (type_info != 0 && type_info.ptr_depth > 0) {
        recv_is_ptr = 1;
    }

    total_arg_words = total_arg_words + emit_method_push_receiver(receiver, type_info, recv_is_ptr, symtab);

    _cg_emit_sret_ptr_from_rbp(dest_offset);
    var stack_words: u64 = _cg_sysv_pop_arg_regs_sret(total_arg_words);
    var reserve_words: u64 = _cg_target_call_prepare(stack_words, 0);
    emit("    call ");
    emit_len(resolved_ptr, resolved_len);
    emit_nl();
    _cg_target_call_cleanup(stack_words, reserve_words);
    return 0;
}

func get_packed_layout_total_bits(struct_def: *AstStructDef) -> u64 {
    var struct_info: *AstStructDef = struct_def;
    var fields: *Vec<*FieldDesc> = struct_info.fields_vec;
    var num_fields: u64 = fields.len();
        var total_bits: u64 = 0;
    for (var i: u64 = 0; i < num_fields; i++) {
            var field: *FieldDesc = fields.get(i);
        if (field.bit_width > 0) {
            total_bits = total_bits + field.bit_width;
        } else {
            var fsize: u64 = layout_field_sizeof(field);
            total_bits = total_bits + fsize * 8;
        }
    }
    return total_bits;
}

func get_packed_field_bit_offset(struct_def: *AstStructDef, field_name: []u8) -> u64 {
    var struct_info: *AstStructDef = struct_def;
    var fields: *Vec<*FieldDesc> = struct_info.fields_vec;
    var num_fields: u64 = fields.len();
    var bit_cursor: u64 = 0;
    for (var i: u64 = 0; i < num_fields; i++) {
            var field: *FieldDesc = fields.get(i);
        if (str_eq(slice(field.name_ptr, field.name_len), slice(field_name.ptr, field_name.len))) {
            return bit_cursor;
        }
        if (field.bit_width > 0) {
            bit_cursor = bit_cursor + field.bit_width;
        } else {
            var fsize2: u64 = layout_field_sizeof(field);
            bit_cursor = bit_cursor + fsize2 * 8;
        }
    }
    return emit_codegen_error("[ERROR] Packed field not found\n");
}

func get_packed_field_bit_width(struct_def: *AstStructDef, field_name: []u8) -> u64 {
    var struct_info: *AstStructDef = struct_def;
    var fields: *Vec<*FieldDesc> = struct_info.fields_vec;
    var num_fields: u64 = fields.len();
    for (var i: u64 = 0; i < num_fields; i++) {
            var field: *FieldDesc = fields.get(i);
        if (str_eq(slice(field.name_ptr, field.name_len), slice(field_name.ptr, field_name.len))) {
            if (field.bit_width > 0) { return field.bit_width; }
            return layout_field_sizeof(field) * 8;
        }
    }
    return emit_codegen_error("[ERROR] Packed field not found\n");
}

func _cg_sysv_emit_pop_arg_reg(i: u64, sret: u64) -> u64 {
    emit("    pop ");
    var reg_name: u64 = compiler_target_user_arg_reg_name(i, sret);
    var reg_len: u64 = compiler_target_user_arg_reg_name_len(i, sret);
    if (reg_name != 0 && reg_len != 0) {
        emit_len(reg_name, reg_len);
    }
    emit_nl();
    return 0;
}

func _cg_sysv_pop_arg_regs_common(total_words: u64, reg_limit: u64, sret: u64) -> u64 {
    var reg_count: u64 = total_words;
    if (reg_count > reg_limit) { reg_count = reg_limit; }
    for (var i: u64 = 0; i < reg_count; i++) {
        _cg_sysv_emit_pop_arg_reg(i, sret);
    }
    if (total_words > reg_limit) { return total_words - reg_limit; }
    return 0;
}

func _cg_sysv_pop_arg_regs(total_words: u64) -> u64 {
    return _cg_sysv_pop_arg_regs_common(total_words, compiler_target_user_arg_reg_limit(0), 0);
}

func _cg_sysv_pop_arg_regs_sret(total_words: u64) -> u64 {
    return _cg_sysv_pop_arg_regs_common(total_words, compiler_target_user_arg_reg_limit(1), 1);
}

func _cg_target_call_align_pad_words(stack_words: u64, extra_words: u64) -> u64 {
    var shadow_words: u64 = compiler_target_call_shadow_words();
    if (shadow_words == 0 && stack_words > 0) { return 0; }
    var total_words: u64 = stack_words + extra_words + shadow_words;
    if ((total_words % 2) != 0) { return 1; }
    return 0;
}

func _cg_target_call_prepare(stack_words: u64, extra_words: u64) -> u64 {
    var reserve_words: u64 = compiler_target_call_shadow_words() + _cg_target_call_align_pad_words(stack_words, extra_words);
    if (reserve_words > 0) {
        emit("    sub rsp, ");
        emit_u64(reserve_words * 8);
        emit_nl();
    }
    return reserve_words;
}

func _cg_target_call_cleanup(stack_words: u64, reserve_words: u64) -> u64 {
    var cleanup_words: u64 = stack_words + reserve_words;
    if (cleanup_words > 0) {
        emit("    add rsp, ");
        emit_u64(cleanup_words * 8);
        emit_nl();
    }
    return 0;
}

func _cg_emit_sret_ptr_from_rbp(dest_offset: u64) -> u64 {
    emit("    lea ");
    var reg_name: u64 = compiler_target_raw_arg_reg_name(0);
    var reg_len: u64 = compiler_target_raw_arg_reg_name_len(0);
    if (reg_name != 0 && reg_len != 0) {
        emit_len(reg_name, reg_len);
    }
    emit(", [rbp");
    emit_signed_disp(dest_offset);
    emit("]\n");
    return 0;
}

func _cg_emit_raw_arg_reg_name(idx: u64) -> u64 {
    var reg_name: u64 = compiler_target_raw_arg_reg_name(idx);
    var reg_len: u64 = compiler_target_raw_arg_reg_name_len(idx);
    if (reg_name != 0 && reg_len != 0) {
        emit_len(reg_name, reg_len);
    }
    return 0;
}

func _cg_emit_user_arg_reg_name(idx: u64, sret: u64) -> u64 {
    var reg_name: u64 = compiler_target_user_arg_reg_name(idx, sret);
    var reg_len: u64 = compiler_target_user_arg_reg_name_len(idx, sret);
    if (reg_name != 0 && reg_len != 0) {
        emit_len(reg_name, reg_len);
    }
    return 0;
}

func _cg_emit_mov_raw_arg_from_reg(idx: u64, src: []u8) -> u64 {
    emit("    mov ");
    _cg_emit_raw_arg_reg_name(idx);
    emit(", ");
    emit_len(src.ptr, src.len);
    emit_nl();
    return 0;
}

func _cg_emit_mov_user_arg_from_reg(idx: u64, sret: u64, src: []u8) -> u64 {
    emit("    mov ");
    _cg_emit_user_arg_reg_name(idx, sret);
    emit(", ");
    emit_len(src.ptr, src.len);
    emit_nl();
    return 0;
}

func _cg_emit_mov_user_arg_from_rsp(idx: u64, sret: u64, disp: u64) -> u64 {
    emit("    mov ");
    _cg_emit_user_arg_reg_name(idx, sret);
    emit(", [rsp");
    if (disp != 0) { emit_signed_disp(disp); }
    emit("]\n");
    return 0;
}

func _cg_emit_lea_user_arg_from_rsp(idx: u64, sret: u64, disp: u64) -> u64 {
    emit("    lea ");
    _cg_emit_user_arg_reg_name(idx, sret);
    emit(", [rsp");
    if (disp != 0) { emit_signed_disp(disp); }
    emit("]\n");
    return 0;
}

func _cg_emit_mov_user_arg_imm_u64(idx: u64, sret: u64, value: u64) -> u64 {
    emit("    mov ");
    _cg_emit_user_arg_reg_name(idx, sret);
    emit(", ");
    emit_u64(value);
    emit_nl();
    return 0;
}

func _cg_emit_direct_call_name(name: []u8, stack_words: u64, extra_words: u64) -> u64 {
    var reserve_words: u64 = _cg_target_call_prepare(stack_words, extra_words);
    emit("    call ");
    emit_len(name.ptr, name.len);
    emit_nl();
    _cg_target_call_cleanup(stack_words, reserve_words);
    return 0;
}

func _cg_emit_direct_call_resolved(name: []u8, stack_words: u64, extra_words: u64) -> u64 {
    var resolved_ptr: u64 = name.ptr;
    var resolved_len: u64 = name.len;
    var resolved: *NameInfo = resolve_name(slice(name.ptr, name.len));
    if (resolved != 0) {
        resolved_ptr = resolved.ptr;
        resolved_len = resolved.len;
    }
    return _cg_emit_direct_call_name(slice(resolved_ptr, resolved_len), stack_words, extra_words);
}

func emit_push_struct_words_from_tmp(tmp_offset: u64, struct_size: u64) -> u64 {
    if (struct_size <= 8) {
        emit("    mov rax, [rbp");
        emit_signed_disp(tmp_offset);
        emit("]\n");
        emit("    push rax\n");
        return 1;
    }
    if (struct_size <= 16) {
        emit("    mov rbx, [rbp");
        var tmp_hi: u64 = tmp_offset + 8;
        emit_signed_disp(tmp_hi);
        emit("]\n");
        emit("    mov rax, [rbp");
        emit_signed_disp(tmp_offset);
        emit("]\n");
        emit("    push rbx\n");
        emit("    push rax\n");
        return 2;
    }
    emit("    lea rax, [rbp");
    emit_signed_disp(tmp_offset);
    emit("]\n");
    emit("    push rax\n");
    return 1;
}

func emit_sysv_push_slice_arg(arg: *AstNode, arg_kind: u64) -> u64 {
    if (arg_kind == AST_SLICE) {
        var slice_node: *AstSlice = (*AstSlice)arg;
        emit_expr(slice_node.len_expr);
        emit("    push rax\n");
        emit_expr(slice_node.ptr_expr);
        emit("    push rax\n");
    } else {
        emit_lvalue(arg);
        emit("    mov rbx, [rax+8]\n");
        emit("    push rbx\n");
        emit("    mov rbx, [rax]\n");
        emit("    push rbx\n");
    }
    return 2;
}

func emit_sysv_push_struct_arg(arg: *AstNode, arg_kind: u64, struct_size: u64, symtab: *Symtab) -> u64 {
    if (arg_kind == AST_STACK_CTOR) {
        var tmp_offset_sc: u64 = emit_alloc_tmp_struct(symtab, struct_size);
        emit_stack_ctor_init_to_offset((*AstStackCtor)arg, tmp_offset_sc, symtab);
        return emit_push_struct_words_from_tmp(tmp_offset_sc, struct_size);
    }
    if (arg_kind == AST_CALL) {
        if (struct_size <= 8) {
            emit_expr(arg);
            emit("    push rax\n");
            return 1;
        } else if (struct_size <= 16) {
            emit_expr(arg);
            emit("    push rdx\n");
            emit("    push rax\n");
            return 2;
        }
        var tmp_offset2: u64 = emit_alloc_tmp_struct(symtab, struct_size);
        emit_call_sret_to_offset(arg, tmp_offset2, symtab);
        emit("    lea rax, [rbp");
        emit_signed_disp(tmp_offset2);
        emit("]\n");
        emit("    push rax\n");
        return 1;
    }
    if (struct_size <= 8) {
        emit_lvalue(arg);
        emit("    mov rax, [rax]\n");
        emit("    push rax\n");
        return 1;
    } else if (struct_size <= 16) {
        emit_lvalue(arg);
        emit("    mov rbx, [rax+8]\n");
        emit("    push rbx\n");
        emit("    mov rbx, [rax]\n");
        emit("    push rbx\n");
        return 2;
    }
    // Larger structs: materialize into a stack temp and pass pointer
    var tmp_offset: u64 = emit_alloc_tmp_struct(symtab, struct_size);
    if (arg_kind == AST_CALL) {
        emit_call_sret_to_offset(arg, tmp_offset, symtab);
    } else {
        emit_lvalue(arg);
        emit("    mov rbx, rax\n");
        emit("    lea r8, [rbp");
        emit_signed_disp(tmp_offset);
        emit("]\n");

        emit_copy_bytes_with_regs(slice("rbx", 3), slice("r8", 2), struct_size);
    }

    emit("    lea rax, [rbp");
    emit_signed_disp(tmp_offset);
    emit("]\n");
    emit("    push rax\n");
    return 1;
}

func _cg_sysv_push_call_arg(arg: *AstNode, symtab: *Symtab) -> u64 {
    var arg_kind: u64 = ast_kind(arg);
    if (arg_kind == AST_CALL) {
        var call_arg: *AstCall = (*AstCall)arg;
        var fn: *AstFunc = typeinfo_find_func(slice(call_arg.name_ptr, call_arg.name_len));
        if (fn == 0) {
            fn = lower_find_func_signature_for_call(slice(call_arg.name_ptr, call_arg.name_len));
        }
        if (fn == 0) {
            var resolved_call: *NameInfo = resolve_name(slice(call_arg.name_ptr, call_arg.name_len));
            if (resolved_call != 0) {
                fn = lower_find_func_signature_for_call(slice(resolved_call.ptr, resolved_call.len));
            }
        }
        if (fn != 0) {
            if (fn.ret_type == TYPE_STRUCT && fn.ret_ptr_depth == 0) {
                var call_struct_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, slice(fn.ret_struct_name_ptr, fn.ret_struct_name_len));
                if (call_struct_size <= 8) {
                    emit_expr(arg);
                    emit("    push rax\n");
                    return 1;
                } else if (call_struct_size <= 16) {
                    emit_expr(arg);
                    emit("    push rdx\n");
                    emit("    push rax\n");
                    return 2;
                }
                var tmp_offset_call: u64 = emit_alloc_tmp_struct(symtab, call_struct_size);
                emit_call_sret_to_offset(arg, tmp_offset_call, symtab);
                emit("    lea rax, [rbp");
                emit_signed_disp(tmp_offset_call);
                emit("]\n");
                emit("    push rax\n");
                return 1;
            }
        }
    }

    var at: *TypeInfo = get_expr_type_with_symtab((*AstNode)arg, symtab);
    if (at != 0) {
        if (at.type_kind == TYPE_SLICE && at.ptr_depth == 0) {
            return emit_sysv_push_slice_arg(arg, arg_kind);
        }
        if (at.type_kind == TYPE_STRUCT && at.ptr_depth == 0) {
            var struct_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, slice(at.struct_name_ptr, at.struct_name_len));
            return emit_sysv_push_struct_arg(arg, arg_kind, struct_size, symtab);
        }
    }
    emit_expr(arg);
    emit("    push rax\n");
    return 1;
}

func emit_call_param_at(fn: *AstFunc, index: u64) -> *Param {
    if (fn == 0 || fn.params_vec == 0) { return 0; }
    if (index >= fn.params_vec.len()) { return 0; }
    return fn.params_vec.get(index);
}

func emit_call_push_arg_with_param(arg: *AstNode, expected: *Param, symtab: *Symtab) -> u64 {
    if (expected == 0) { return _cg_sysv_push_call_arg(arg, symtab); }
    if (expected.type_kind != TYPE_STRUCT) {
        return _cg_sysv_push_call_arg(arg, symtab);
    }

    var at: *TypeInfo = get_expr_type_with_symtab((*AstNode)arg, symtab);
    if (at == 0) { return _cg_sysv_push_call_arg(arg, symtab); }
    if (at.type_kind != TYPE_STRUCT) {
        return _cg_sysv_push_call_arg(arg, symtab);
    }

    var src_name_ptr: u64 = at.struct_name_ptr;
    var src_name_len: u64 = at.struct_name_len;
    var src_resolved: *NameInfo = resolve_name(slice(src_name_ptr, src_name_len));
    if (src_resolved != 0) {
        src_name_ptr = src_resolved.ptr;
        src_name_len = src_resolved.len;
    }

    var expected_name_ptr: u64 = expected.struct_name_ptr;
    var expected_name_len: u64 = expected.struct_name_len;
    var expected_resolved: *NameInfo = resolve_name(slice(expected_name_ptr, expected_name_len));
    if (expected_resolved != 0) {
        expected_name_ptr = expected_resolved.ptr;
        expected_name_len = expected_resolved.len;
    }

    // Pointer argument: keep cast-adjust path for multiple inheritance upcasts.
    if (expected.ptr_depth > 0) {
        if (at.ptr_depth == 0) { return _cg_sysv_push_call_arg(arg, symtab); }
        if (str_eq(slice(src_name_ptr, src_name_len), slice(expected_name_ptr, expected_name_len)) != 0) {
            emit_expr(arg);
            if (at.is_tagged == 1) { emit_tagged_mask(); }
            emit("    push rax\n");
            return 1;
        }

        var src_def: *AstStructDef = get_struct_def(slice(src_name_ptr, src_name_len));
        if (src_def == 0 && (src_name_ptr != at.struct_name_ptr || src_name_len != at.struct_name_len)) {
            src_def = get_struct_def(slice(at.struct_name_ptr, at.struct_name_len));
        }
        if (src_def != 0) {
            var up_offset: u64 = 0;
            var up_def: *AstStructDef = 0;
            var found_upcast: u64 = typeinfo_find_parent_offset(src_def, slice(expected_name_ptr, expected_name_len), &up_offset, &up_def);
            if (found_upcast == 0 && (expected_name_ptr != expected.struct_name_ptr || expected_name_len != expected.struct_name_len)) {
                found_upcast = typeinfo_find_parent_offset(src_def, slice(expected.struct_name_ptr, expected.struct_name_len), &up_offset, &up_def);
            }
            if (found_upcast != 0) {
                emit_expr(arg);
                if (at.is_tagged == 1) { emit_tagged_mask(); }
                emit_emit_adjust_rax_add(up_offset);
                emit("    push rax\n");
                return 1;
            }
        }
        return _cg_sysv_push_call_arg(arg, symtab);
    }

    if (at.ptr_depth != 0) { return _cg_sysv_push_call_arg(arg, symtab); }
    var expected_def: *AstStructDef = get_struct_def(slice(expected.struct_name_ptr, expected.struct_name_len));
    var expected_ti: *TypeInfo = typeinfo_make_struct(0, slice(expected.struct_name_ptr, expected.struct_name_len), expected_def);
    if (typeinfo_is_assignable(at, expected_ti) == 0) {
        return _cg_sysv_push_call_arg(arg, symtab);
    }

    var struct_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, slice(expected.struct_name_ptr, expected.struct_name_len));
    return emit_sysv_push_struct_arg(arg, ast_kind(arg), struct_size, symtab);
}

func emit_index_addr(node: u64, symtab: *Symtab) -> u64 {
    var idx: *AstIndex = (*AstIndex)node;
    var base: u64 = idx.base;
    var index: u64 = idx.index;

    var elem_size: u64 = 1;
    var use_array_addr: u64 = 0;
    var use_slice_ptr: u64 = 0;
    var use_tagged_ptr: u64 = 0;

    var bt: *TypeInfo = get_expr_type_with_symtab((*AstNode)base, symtab);
    if (bt != 0) {
        if (bt.ptr_depth > 0) {
            elem_size = get_pointee_size(bt.type_kind, bt.ptr_depth);
            if (bt.is_tagged == 1) { use_tagged_ptr = 1; }
        } else if (bt.type_kind == TYPE_ARRAY) {
            elem_size = typeinfo_elem_size_from_container(bt);
            use_array_addr = 1;
        } else if (bt.type_kind == TYPE_SLICE) {
            elem_size = typeinfo_elem_size_from_container(bt);
            use_slice_ptr = 1;
        }
    }

    if (use_array_addr == 1) {
        emit_lvalue(base);
    } else if (use_slice_ptr == 1) {
        emit_lvalue(base);
        emit("    mov rax, [rax]\n");
    } else {
        emit_expr(base);
        if (use_tagged_ptr == 1) {
            emit_tagged_mask();
        }
    }

    emit("    push rax\n");
    emit_expr(index);
    if (elem_size != 1) {
        emit("    imul rax, ");
        emit_u64(elem_size);
        emit_nl();
    }
    emit("    pop rbx\n");
    emit("    add rax, rbx\n");
    return;
}

func emit_try_materialize_operand(operand: u64, op_kind: u64, struct_size: u64, tmp_offset: u64, symtab: *Symtab) -> u64 {
    if (struct_size > 16) {
        if (op_kind == AST_CALL) {
            emit_call_sret_to_offset(operand, tmp_offset, symtab);
        } else if (op_kind == AST_METHOD_CALL) {
            emit_method_call_sret_to_offset((*AstMethodCall)operand, tmp_offset, symtab);
        } else {
            emit_lvalue(operand);
            emit("    mov rbx, rax\n");
            emit("    lea r8, [rbp");
            emit_signed_disp(tmp_offset);
            emit("]\n");
            emit_copy_bytes_with_regs(slice("rbx", 3), slice("r8", 2), struct_size);
        }
        return;
    }
    if (op_kind == AST_CALL || op_kind == AST_METHOD_CALL || op_kind == AST_CALL_PTR) {
        emit_expr(operand);
        emit("    lea rbx, [rbp");
        emit_signed_disp(tmp_offset);
        emit("]\n");
        emit("    mov [rbx], rax\n");
        if (struct_size > 8) {
            emit("    mov [rbx+8], rdx\n");
        }
    } else {
        emit_lvalue(operand);
        emit("    mov rbx, rax\n");
        emit("    lea r8, [rbp");
        emit_signed_disp(tmp_offset);
        emit("]\n");
        emit_copy_bytes_with_regs(slice("rbx", 3), slice("r8", 2), struct_size);
    }
    return;
}

func emit_try_emit_fail_return(tmp_offset: u64, check_desc: *FieldDesc, check_off: u64, ret_struct_name: []u8, label_ok: u64) -> u64 {
    emit("    lea rbx, [rbp");
    emit_signed_disp(tmp_offset);
    emit("]\n");
    var check_type_kind: u64 = TYPE_U64;
    var check_ptr_depth: u64 = 0;
    if (check_desc != 0) {
        check_type_kind = check_desc.type_kind;
        check_ptr_depth = check_desc.ptr_depth;
    }
    if (check_ptr_depth == 0 && (check_type_kind == TYPE_BOOL || check_type_kind == TYPE_U8)) {
        emit("    movzx rax, byte [rbx");
    } else if (check_ptr_depth == 0 && check_type_kind == TYPE_U16) {
        emit("    movzx rax, word [rbx");
    } else if (check_ptr_depth == 0 && check_type_kind == TYPE_U32) {
        emit("    mov eax, [rbx");
    } else if (check_ptr_depth == 0 && check_type_kind == TYPE_I8) {
        emit("    movsx rax, byte [rbx");
    } else if (check_ptr_depth == 0 && check_type_kind == TYPE_I16) {
        emit("    movsx rax, word [rbx");
    } else if (check_ptr_depth == 0 && check_type_kind == TYPE_I32) {
        emit("    movsxd rax, dword [rbx");
    } else {
        emit("    mov rax, [rbx");
    }
    if (check_off != 0) { emit("+"); emit_u64(check_off); }
    emit("]\n");
    emit("    test rax, rax\n");
    emit("    jne ");
    emit_label(label_ok);
    emit_nl();

    var ret_struct_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, slice(ret_struct_name.ptr, ret_struct_name.len));
    if (ret_struct_size > 16) {
        emit_copy_bytes_with_regs(slice("rbx", 3), slice("rdi", 3), ret_struct_size);
    } else if (ret_struct_size <= 8) {
        emit("    mov rax, [rbx]\n");
    } else {
        emit("    mov rax, [rbx]\n");
        emit("    mov rdx, [rbx+8]\n");
    }
    emit("    mov rsp, rbp\n");
    emit("    pop rbp\n");
    emit("    ret\n");
    return;
}

func emit_try_emit_value_load(value_desc: *FieldDesc, value_off: u64) -> u64 {
    var value_size: u64 = layout_field_sizeof(value_desc);
    if (value_size <= 8) {
        if (value_desc.ptr_depth == 0 && (value_desc.type_kind == TYPE_BOOL || value_desc.type_kind == TYPE_U8)) {
            emit("    movzx rax, byte [rbx");
            if (value_off != 0) { emit("+"); emit_u64(value_off); }
            emit("]\n");
        } else if (value_desc.ptr_depth == 0 && value_desc.type_kind == TYPE_U16) {
            emit("    movzx rax, word [rbx");
            if (value_off != 0) { emit("+"); emit_u64(value_off); }
            emit("]\n");
        } else if (value_desc.ptr_depth == 0 && value_desc.type_kind == TYPE_U32) {
            emit("    mov eax, [rbx");
            if (value_off != 0) { emit("+"); emit_u64(value_off); }
            emit("]\n");
        } else if (value_desc.ptr_depth == 0 && value_desc.type_kind == TYPE_I8) {
            emit("    movsx rax, byte [rbx");
            if (value_off != 0) { emit("+"); emit_u64(value_off); }
            emit("]\n");
        } else if (value_desc.ptr_depth == 0 && value_desc.type_kind == TYPE_I16) {
            emit("    movsx rax, word [rbx");
            if (value_off != 0) { emit("+"); emit_u64(value_off); }
            emit("]\n");
        } else if (value_desc.ptr_depth == 0 && value_desc.type_kind == TYPE_I32) {
            emit("    movsxd rax, dword [rbx");
            if (value_off != 0) { emit("+"); emit_u64(value_off); }
            emit("]\n");
        } else {
            emit("    mov rax, [rbx");
            if (value_off != 0) { emit("+"); emit_u64(value_off); }
            emit("]\n");
        }
        return;
    }
    if (value_size <= 16) {
        emit("    mov rax, [rbx");
        if (value_off != 0) { emit("+"); emit_u64(value_off); }
        emit("]\n");
        emit("    mov rdx, [rbx");
        if (value_off + 8 != 0) { emit("+"); emit_u64(value_off + 8); }
        emit("]\n");
        return;
    }
    diag_emit_error_tag("codegen", "try", "try value size too large for expression result");
    diag_emit_help("return the try payload through a destination slot or reduce the payload size");
    diag_force_stop_pass();
        return 0;
}

func emit_try_expr(node: u64, symtab: *Symtab) -> u64 {
    var tr: *AstTry = (*AstTry)node;
    var operand: u64 = tr.operand;

    var opt_ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)operand, symtab);
    if (opt_ti == 0) {
        diag_emit_error_tag("codegen", "try", "try operand type not found");
        diag_emit_help("ensure the try operand has a resolved type before code generation");
        diag_force_stop_pass();
        return 0;
    }
    var try_fields: CompilerTryFieldNames = try_field_names_from_typeinfo(opt_ti);
    if (try_fields.found == 0) {
        if (opt_ti.type_kind != TYPE_STRUCT || opt_ti.ptr_depth != 0) {
            diag_emit_error_tag("codegen", "try", "try operator requires try-compatible struct value");
        } else {
            diag_emit_error_tag("codegen", "try", "try operator requires try-compatible check/value fields");
            diag_emit_labelled_name("try struct: ", slice(opt_ti.struct_name_ptr, opt_ti.struct_name_len));
        }
        diag_emit_help("use a struct with compatible check/value fields");
        diag_force_stop_pass();
        return 0;
    }

    var ret_type: u64 = ret_type_current();
    var ret_ptr_depth: u64 = ret_ptr_depth_current();
    var ret_struct_name_ptr: u64 = ret_struct_name_ptr_current();
    var ret_struct_name_len: u64 = ret_struct_name_len_current();
    if (try_return_matches_type(opt_ti, ret_type, ret_ptr_depth, slice(ret_struct_name_ptr, ret_struct_name_len)) == 0) {
        if (ret_type != TYPE_STRUCT || ret_ptr_depth != 0) {
            diag_emit_error_tag("codegen", "try", "try operator requires try-compatible return type");
        } else {
            diag_emit_error_tag("codegen", "try", "try operand type must match function return type");
            diag_emit_labelled_name("function return struct: ", slice(ret_struct_name_ptr, ret_struct_name_len));
        }
        diag_emit_help("make the operand and function return type use the same try-compatible struct");
        diag_force_stop_pass();
        return 0;
    }

    var struct_def: *AstStructDef = try_resolve_struct_def(opt_ti);
    if (struct_def == 0) {
        diag_emit_error_tag("codegen", "try", "try operand struct definition not found");
        diag_emit_labelled_name("try struct: ", slice(opt_ti.struct_name_ptr, opt_ti.struct_name_len));
        diag_force_stop_pass();
        return 0;
    }

    var check_ptr: u64 = try_fields.check_ptr;
    var check_len: u64 = try_fields.check_len;
    var value_ptr: u64 = try_fields.value_ptr;
    var value_len: u64 = try_fields.value_len;

    var value_desc: *FieldDesc = get_field_desc(struct_def, slice(value_ptr, value_len));
    if (value_desc == 0) {
        diag_emit_error_tag("codegen", "try", "try value field not found");
        diag_emit_labelled_member("expected field: ", slice(struct_def.name_ptr, struct_def.name_len), slice(value_ptr, value_len));
        diag_force_stop_pass();
        return 0;
    }

    var check_desc: *FieldDesc = get_field_desc(struct_def, slice(check_ptr, check_len));
    if (check_desc == 0) {
        diag_emit_error_tag("codegen", "try", "try check field not found");
        diag_emit_labelled_member("expected field: ", slice(struct_def.name_ptr, struct_def.name_len), slice(check_ptr, check_len));
        diag_force_stop_pass();
        return 0;
    }
    var check_off: u64 = get_field_offset(struct_def, slice(check_ptr, check_len));
    var value_off: u64 = get_field_offset(struct_def, slice(value_ptr, value_len));

    var struct_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, slice(opt_ti.struct_name_ptr, opt_ti.struct_name_len));
    var tmp_offset: u64 = emit_alloc_tmp_struct(symtab, struct_size);
    var op_kind: u64 = ast_kind(operand);

    emit_try_materialize_operand(operand, op_kind, struct_size, tmp_offset, symtab);

    var label_ok: u64 = new_label();
    emit_try_emit_fail_return(tmp_offset, check_desc, check_off, slice(ret_struct_name_ptr, ret_struct_name_len), label_ok);

    emit_label_def(label_ok);
    emit_try_emit_value_load(value_desc, value_off);
    return;
}

func emit_expr_call(node: u64, symtab: *Symtab) -> u64 {
    var call: *AstCall = (*AstCall)node;
    var name_ptr: u64 = call.name_ptr;
    var name_len: u64 = call.name_len;
    var resolved_ptr: u64 = name_ptr;
    var resolved_len: u64 = name_len;
    var resolved: *NameInfo = resolve_name(slice(name_ptr, name_len));
    if (resolved != 0) {
        resolved_ptr = resolved.ptr;
        resolved_len = resolved.len;
    }

    var impl_check_ptr: u64 = name_ptr;
    var impl_check_len: u64 = name_len;
    if (sym_is_impl_method(slice(impl_check_ptr, impl_check_len)) == 0 && resolved != 0 && sym_is_impl_method(slice(resolved_ptr, resolved_len)) != 0) {
        impl_check_ptr = resolved_ptr;
        impl_check_len = resolved_len;
    }
    if (sym_is_impl_method(slice(impl_check_ptr, impl_check_len)) != 0) {
        var impl_access: u64 = sym_get_impl_method_access(slice(impl_check_ptr, impl_check_len));
        var owner: *NameInfo = sym_get_impl_method_owner(slice(impl_check_ptr, impl_check_len));
        var allow_access: u64 = 0;
        if (owner != 0) {
            allow_access = sym_can_access_member(slice(owner.ptr, owner.len), impl_access);
        }
        if (allow_access == 0) {
            emit_stderr("[ERROR] private method access denied: ");
            emit_stderr_len(impl_check_ptr, impl_check_len);
            emit_stderr("\n");
            diag_force_stop_pass();
        return 0;
        }
    }

    var var_type: *TypeInfo = symtab_get_type(symtab, slice(name_ptr, name_len));
    var is_global: u64 = is_global_var(slice(resolved_ptr, resolved_len));
    var tracked_closure_handle: u64 = closure_handle_is(slice(name_ptr, name_len));
    if (tracked_closure_handle == 0 && (resolved_ptr != name_ptr || resolved_len != name_len)) {
        tracked_closure_handle = closure_handle_is(slice(resolved_ptr, resolved_len));
    }

    var fn_call_direct: *AstFunc = typeinfo_find_func(slice(name_ptr, name_len));
    if (fn_call_direct == 0) {
        fn_call_direct = typeinfo_find_func(slice(resolved_ptr, resolved_len));
    }

    if (tracked_closure_handle != 0) {
        var callee_ident_closure: *AstNode = (*AstNode)ast_ident(slice(name_ptr, name_len));
        var call_ptr_expr_closure: *AstCallPtr = ast_call_ptr(callee_ident_closure, call.args_vec);
        emit_expr_call_ptr((u64)call_ptr_expr_closure, symtab);
        return;
    }

    if (var_type != 0 || is_global != 0) {
        // For value symbols, avoid tail-match signature lookup (can alias short locals like `d`).
        // Only exact function symbols may bypass function-pointer call path.
        if (fn_call_direct == 0) {
            var callee_ident: *AstNode = (*AstNode)ast_ident(slice(name_ptr, name_len));
            var call_ptr_expr: *AstCallPtr = ast_call_ptr(callee_ident, call.args_vec);
            emit_expr_call_ptr((u64)call_ptr_expr, symtab);
            return;
        }
    }

    if (fn_call_direct == 0) {
        fn_call_direct = lower_find_func_signature_for_call(slice(name_ptr, name_len));
    }
    if (fn_call_direct == 0) {
        fn_call_direct = lower_find_func_signature_for_call(slice(resolved_ptr, resolved_len));
    }
    var args: *Vec<*AstNode> = call.args_vec;
    var nargs: u64 = 0;
    if (args != 0) { nargs = args.len(); }
    var total_arg_words: u64 = 0;
    if (nargs != 0) {
        var i: u64 = nargs;
        while (i > 0) {
            i = i - 1;
            var arg: *AstNode = args.get(i);
            var param: *Param = emit_call_param_at(fn_call_direct, i);
            total_arg_words = total_arg_words + emit_call_push_arg_with_param(arg, param, symtab);
        }
    }
    var stack_words: u64 = _cg_sysv_pop_arg_regs(total_arg_words);
    var reserve_words: u64 = _cg_target_call_prepare(stack_words, 0);
    emit("    call ");
    emit_len(resolved_ptr, resolved_len);
    emit_nl();
    _cg_target_call_cleanup(stack_words, reserve_words);
    return;
}

func emit_expr_call_ptr(node: u64, symtab: *Symtab) -> u64 {
    var cp: *AstCallPtr = (*AstCallPtr)node;
    var args3: *Vec<*AstNode> = cp.args_vec;
    var nargs3: u64 = 0;
    if (args3 != 0) { nargs3 = args3.len(); }
    var tracked_closure_handle: u64 = emitter_closure_expr_is_lambda_handle((u64)cp.callee);

    var callee_ti: *TypeInfo = get_expr_type_with_symtab(cp.callee, symtab);
    var sig_ti: *TypeInfo = typeinfo_func_signature(callee_ti);
    var closure_sig_ti: *TypeInfo = typeinfo_try_lambda_closure_sig(callee_ti);
    var hidden_env_param: u64 = 0;
    if (sig_ti == 0 && closure_sig_ti != 0) {
        sig_ti = closure_sig_ti;
    }
    if (closure_sig_ti != 0) {
        hidden_env_param = 1;
    }
    var typed_direct_func_ptr: u64 = 0;
    if (callee_ti != 0 && callee_ti.type_kind == TYPE_FUNC && hidden_env_param == 0) {
        typed_direct_func_ptr = 1;
    }
    if (sig_ti != 0 && sig_ti.fn_params_vec != 0) {
        var expected_n: u64 = sig_ti.fn_params_vec.len();
        var param_base_idx: u64 = 0;
        if (hidden_env_param != 0) {
            if (expected_n == 0) {
                diag_emit_error_tag("codegen", "fn-ptr-call", "invalid lambda closure signature for function pointer call");
                diag_force_stop_pass();
                return 0;
            }
            param_base_idx = 1;
            expected_n = expected_n - 1;
        }
        var fixed_n: u64 = expected_n;
        var min_n: u64 = expected_n;
        if (sig_ti.fn_is_variadic != 0 && expected_n > 0) {
            fixed_n = expected_n - 1;
            min_n = fixed_n;
        }
        if (sig_ti.fn_is_variadic == 0 && nargs3 != expected_n) {
            diag_emit_error_tag("codegen", "fn-ptr-call", "function pointer call argument count mismatch");
            diag_emit_labelled_u64("expected: ", expected_n);
            diag_emit_labelled_u64("got: ", nargs3);
            diag_force_stop_pass();
            return 0;
        }
        if (sig_ti.fn_is_variadic != 0 && nargs3 < min_n) {
            diag_emit_error_tag("codegen", "fn-ptr-call", "function pointer call missing required arguments");
            diag_emit_labelled_u64("expected at least: ", min_n);
            diag_emit_labelled_u64("got: ", nargs3);
            diag_force_stop_pass();
            return 0;
        }

        for (var i_sig: u64 = 0; i_sig < fixed_n; i_sig++) {
            var expected_ti: *TypeInfo = sig_ti.fn_params_vec.get(param_base_idx + i_sig);
            var actual_ti: *TypeInfo = get_expr_type_with_symtab(args3.get(i_sig), symtab);
            if (expected_ti == 0 || actual_ti == 0) {
                diag_emit_error_tag("codegen", "fn-ptr-call", "function pointer call argument type mismatch at index");
                diag_emit_labelled_u64("index: ", i_sig);
                diag_force_stop_pass();
                return 0;
            }
            var mismatch: u64 = 0;
            if (typeinfo_is_assignable(actual_ti, expected_ti) == 0) {
                mismatch = 1;
            }
            if (mismatch != 0) {
                diag_emit_error_tag("codegen", "fn-ptr-call", "function pointer call argument type mismatch at index");
                diag_emit_labelled_u64("index: ", i_sig);
                diag_force_stop_pass();
                return 0;
            }
        }
        if (sig_ti.fn_is_variadic != 0 && expected_n > 0) {
            var rest_ti: *TypeInfo = sig_ti.fn_params_vec.get(param_base_idx + expected_n - 1);
            for (var ri: u64 = fixed_n; ri < nargs3; ri++) {
                var actual_rest_ti: *TypeInfo = get_expr_type_with_symtab(args3.get(ri), symtab);
                if (rest_ti == 0 || actual_rest_ti == 0) {
                    diag_emit_error_tag("codegen", "fn-ptr-call", "function pointer variadic argument type mismatch at index");
                    diag_emit_labelled_u64("index: ", ri);
                    diag_force_stop_pass();
                    return 0;
                }
                var mismatch2: u64 = 0;
                if (typeinfo_is_assignable(actual_rest_ti, rest_ti) == 0) {
                    mismatch2 = 1;
                }
                if (mismatch2 != 0) {
                    diag_emit_error_tag("codegen", "fn-ptr-call", "function pointer variadic argument type mismatch at index");
                    diag_emit_labelled_u64("index: ", ri);
                    diag_force_stop_pass();
                    return 0;
                }
            }
        }
    }

    // Preserve callee address across arg evaluation.
    emit_expr(cp.callee);
    emit("    push rax\n");

    var total_arg_words3: u64 = 0;
    if (nargs3 != 0) {
        var i3: u64 = nargs3;
        while (i3 > 0) {
            i3 = i3 - 1;
            var arg3: *AstNode = args3.get(i3);
            total_arg_words3 = total_arg_words3 + _cg_sysv_push_call_arg(arg3, symtab);
        }
    }

    if (hidden_env_param != 0) {
        var closure_struct_def: *AstStructDef = 0;
        if (callee_ti != 0) {
            closure_struct_def = callee_ti.struct_def;
            if (closure_struct_def == 0) {
                closure_struct_def = get_struct_def(slice(callee_ti.struct_name_ptr, callee_ti.struct_name_len));
            }
        }
        if (closure_struct_def == 0) {
            emit_stderr("[ERROR] lambda closure metadata not found for function pointer call\n");
            diag_force_stop_pass();
            return 0;
        }
        var fn_offset: u64 = 0;
        var fn_desc: *FieldDesc = 0;
        if (struct_find_field_desc_scoped(closure_struct_def, slice(0, 0), slice("fn", 2), &fn_offset, &fn_desc) == 0) {
            emit_stderr("[ERROR] lambda closure function slot not found\n");
            diag_force_stop_pass();
            return 0;
        }
        var env_offset: u64 = 0;
        var env_desc: *FieldDesc = 0;
        if (struct_find_field_desc_scoped(closure_struct_def, slice(0, 0), slice("env", 3), &env_offset, &env_desc) == 0) {
            emit_stderr("[ERROR] lambda closure env slot not found\n");
            diag_force_stop_pass();
            return 0;
        }

        emit("    mov r11, [rsp");
        if (total_arg_words3 != 0) {
            emit("+");
            emit_u64(total_arg_words3 * 8);
        }
        emit("]\n");
        emit("    mov r10, [r11");
        if (fn_offset != 0) {
            emit("+");
            emit_u64(fn_offset);
        }
        emit("]\n");
        emit("    mov r12, [r11");
        if (env_offset != 0) {
            emit("+");
            emit_u64(env_offset);
        }
        emit("]\n");
        emit("    push r12\n");
        var stack_words_closure_typed: u64 = _cg_sysv_pop_arg_regs(total_arg_words3 + 1);
        var reserve_words_closure_typed: u64 = _cg_target_call_prepare(stack_words_closure_typed + 1, 0);
        emit("    call r10\n");
        _cg_target_call_cleanup(stack_words_closure_typed + 1, reserve_words_closure_typed);
        return 0;
    }

    if (typed_direct_func_ptr != 0) {
        var stack_words_typed_direct: u64 = _cg_sysv_pop_arg_regs(total_arg_words3);
        emit("    pop rax\n");
        var reserve_words_typed_direct: u64 = _cg_target_call_prepare(stack_words_typed_direct, 0);
        emit("    call rax\n");
        _cg_target_call_cleanup(stack_words_typed_direct, reserve_words_typed_direct);
        return 0;
    }

    if (tracked_closure_handle != 0) {
        emit("    mov r11, [rsp");
        if (total_arg_words3 != 0) {
            emit("+");
            emit_u64(total_arg_words3 * 8);
        }
        emit("]\n");
        emit("    mov r10, [r11+8]\n");
        emit("    mov r12, [r11+16]\n");
        emit("    push r12\n");
        var stack_words_closure_raw: u64 = _cg_sysv_pop_arg_regs(total_arg_words3 + 1);
        var reserve_words_closure_raw: u64 = _cg_target_call_prepare(stack_words_closure_raw + 1, 0);
        emit("    call r10\n");
        _cg_target_call_cleanup(stack_words_closure_raw + 1, reserve_words_closure_raw);
        return 0;
    }

    // Runtime-dispatch between:
    // - direct function pointer call (plain pointer)
    // - heap closure object pointer with magic header
    var label_direct: u64 = new_label();
    var label_closure: u64 = new_label();
    var label_done: u64 = new_label();

    emit("    mov r11, [rsp");
    if (total_arg_words3 != 0) {
        emit("+");
        emit_u64(total_arg_words3 * 8);
    }
    emit("]\n");
    emit("    mov r10, [r11]\n");
    emit("    mov r13, ");
    emit_u64(LAMBDA_CLOSURE_MAGIC);
    emit_nl();
    emit("    cmp r10, r13\n");
    emit("    je ");
    emit_label(label_closure);
    emit_nl();
    emit("    jmp ");
    emit_label(label_direct);
    emit_nl();

    // Closure call path: prepend env pointer argument.
    emit_label_def(label_closure);
    emit("    mov r10, [r11+8]\n");
    emit("    mov r12, [r11+16]\n");
    emit("    push r12\n");
    var stack_words_closure: u64 = _cg_sysv_pop_arg_regs(total_arg_words3 + 1);
    var reserve_words_closure: u64 = _cg_target_call_prepare(stack_words_closure + 1, 0);
    emit("    call r10\n");
    _cg_target_call_cleanup(stack_words_closure + 1, reserve_words_closure);
    emit("    jmp ");
    emit_label(label_done);
    emit_nl();

    // Direct function pointer path.
    emit_label_def(label_direct);
    var stack_words3: u64 = _cg_sysv_pop_arg_regs(total_arg_words3);
    emit("    pop rax\n");
    var reserve_words3: u64 = _cg_target_call_prepare(stack_words3, 0);
    emit("    call rax\n");
    _cg_target_call_cleanup(stack_words3, reserve_words3);
    emit_label_def(label_done);
    return;
}

func emit_expr_stack_ctor(node: u64, symtab: *Symtab) -> u64 {
    var sc: *AstStackCtor = (*AstStackCtor)node;
    var sc_ti: *TypeInfo = get_expr_type_with_symtab(node, symtab);
    if (sc_ti == 0 || sc_ti.type_kind != TYPE_STRUCT || sc_ti.ptr_depth != 0) {
        emit_stderr("[ERROR] stack constructor expression requires struct value\n");
        diag_force_stop_pass();
        return 0;
    }
    var sc_size: u64 = layout_type_sizeof(TYPE_STRUCT, 0, slice(sc_ti.struct_name_ptr, sc_ti.struct_name_len));
    var tmp_offset_expr: u64 = emit_alloc_tmp_struct(symtab, sc_size);
    emit_stack_ctor_init_to_offset(sc, tmp_offset_expr, symtab);
    if (sc_size <= 8) {
        emit("    mov rax, [rbp");
        emit_signed_disp(tmp_offset_expr);
        emit("]\n");
        return;
    } else if (sc_size <= 16) {
        emit("    mov rax, [rbp");
        emit_signed_disp(tmp_offset_expr);
        emit("]\n");
        emit("    mov rdx, [rbp");
        var tmp_expr_hi: u64 = tmp_offset_expr + 8;
        emit_signed_disp(tmp_expr_hi);
        emit("]\n");
        return;
    }
    emit_stderr("[ERROR] stack constructor expression requires destination for large structs\n");
    diag_force_stop_pass();
        return 0;
}

func emit_expr_emit_local_typed(var_type: *TypeInfo, offset: u64) -> u64 {
    if (var_type == 0) { return 0; }
    if (var_type.ptr_depth != 0) { return 0; }
    if (var_type.type_kind == TYPE_ARRAY) {
        emit("    lea rax, [rbp");
        emit_signed_disp(offset);
        emit("]\n");
        return 1;
    }
    if (var_type.type_kind == TYPE_SLICE) {
        emit("    mov rax, [rbp");
        emit_signed_disp(offset);
        emit("]\n");
        return 1;
    }
    if (var_type.type_kind == TYPE_BOOL || var_type.type_kind == TYPE_U8) {
        emit("    movzx rax, byte [rbp");
        emit_signed_disp(offset);
        emit("]\n");
        return 1;
    }
    if (var_type.type_kind == TYPE_U16) {
        emit("    movzx rax, word [rbp");
        emit_signed_disp(offset);
        emit("]\n");
        return 1;
    }
    if (var_type.type_kind == TYPE_U32) {
        emit("    mov eax, [rbp");
        emit_signed_disp(offset);
        emit("]\n");
        return 1;
    }
    if (var_type.type_kind == TYPE_I8) {
        emit("    movsx rax, byte [rbp");
        emit_signed_disp(offset);
        emit("]\n");
        return 1;
    }
    if (var_type.type_kind == TYPE_I16) {
        emit("    movsx rax, word [rbp");
        emit_signed_disp(offset);
        emit("]\n");
        return 1;
    }
    if (var_type.type_kind == TYPE_I32) {
        emit("    movsxd rax, dword [rbp");
        emit_signed_disp(offset);
        emit("]\n");
        return 1;
    }
    return 0;
}

func emit_expr_emit_global_typed(gt: *TypeInfo, resolved: []u8) -> u64 {
    if (gt == 0 || gt.ptr_depth != 0) {
        return 0;
    }
    if (gt.type_kind == TYPE_ARRAY) {
        emit("    lea rax, [rel _gvar_");
        emit_len(resolved.ptr, resolved.len);
        emit("]\n");
        return 1;
    }
    if (gt.type_kind == TYPE_SLICE) {
        emit("    mov rax, [rel _gvar_");
        emit_len(resolved.ptr, resolved.len);
        emit("]\n");
        return 1;
    }
    if (gt.type_kind == TYPE_BOOL || gt.type_kind == TYPE_U8) {
        emit("    movzx rax, byte [rel _gvar_");
        emit_len(resolved.ptr, resolved.len);
        emit("]\n");
        return 1;
    }
    if (gt.type_kind == TYPE_U16) {
        emit("    movzx rax, word [rel _gvar_");
        emit_len(resolved.ptr, resolved.len);
        emit("]\n");
        return 1;
    }
    if (gt.type_kind == TYPE_U32) {
        emit("    mov eax, [rel _gvar_");
        emit_len(resolved.ptr, resolved.len);
        emit("]\n");
        return 1;
    }
    if (gt.type_kind == TYPE_I8) {
        emit("    movsx rax, byte [rel _gvar_");
        emit_len(resolved.ptr, resolved.len);
        emit("]\n");
        return 1;
    }
    if (gt.type_kind == TYPE_I16) {
        emit("    movsx rax, word [rel _gvar_");
        emit_len(resolved.ptr, resolved.len);
        emit("]\n");
        return 1;
    }
    if (gt.type_kind == TYPE_I32) {
        emit("    movsxd rax, dword [rel _gvar_");
        emit_len(resolved.ptr, resolved.len);
        emit("]\n");
        return 1;
    }
    return 0;
}

func emit_expr_ident(node: u64, symtab: *Symtab) -> u64 {
    var ident: *AstIdent = (*AstIdent)node;
    var name_ptr: u64 = ident.name_ptr;
    var name_len: u64 = ident.name_len;
    var var_type: *TypeInfo = symtab_get_type(symtab, slice(name_ptr, name_len));
    if (var_type != 0) {
        var offset0: u64 = symtab_find(symtab, slice(name_ptr, name_len));
        if (offset0 == 0) {
            diag_emit_error_tag("codegen", "name-resolution", "identifier has no stack slot in current scope");
            diag_emit_labelled_name("identifier: ", slice(name_ptr, name_len));
            diag_force_stop_pass();
            return;
        }
        if (emit_expr_emit_local_typed(var_type, offset0) != 0) {
            return;
        }
    }

    var resolved_ptr: u64 = name_ptr;
    var resolved_len: u64 = name_len;
    var resolved: *NameInfo = resolve_name(slice(name_ptr, name_len));
    if (resolved != 0) {
        resolved_ptr = resolved.ptr;
        resolved_len = resolved.len;
    }

    var result: ConstResult = const_find(slice(resolved_ptr, resolved_len));
    if (result.found == 1) {
        emit("    mov rax, ");
        emit_u64(result.value);
        emit_nl();
        return;
    }

    if (is_global_var(slice(resolved_ptr, resolved_len))) {
        var ginfo: *GlobalInfo = _cg_find_global_info(slice(resolved_ptr, resolved_len));
        if (ginfo != 0) {
            var gt: *TypeInfo = ginfo.typeinfo_ptr;
            if (emit_expr_emit_global_typed(gt, slice(resolved_ptr, resolved_len)) != 0) {
                return;
            }
        }

        emit("    mov rax, [rel _gvar_");
        emit_len(resolved_ptr, resolved_len);
        emit("]\n");
        return;
    }

    var offset: u64 = symtab_find(symtab, slice(name_ptr, name_len));
    if (offset == 0) {
        // Bare function symbol as value is allowed only when inferred as function type.
        var inferred: *TypeInfo = get_expr_type_with_symtab((*AstNode)ident, symtab);
        if (inferred != 0 && inferred.type_kind == TYPE_FUNC && sym_func_exists(slice(resolved_ptr, resolved_len)) != 0) {
            emit("    lea rax, [rel ");
            emit_len(resolved_ptr, resolved_len);
            emit("]\n");
            return;
        }
        diag_emit_error_tag("codegen", "name-resolution", "undefined identifier");
        diag_emit_labelled_name("identifier: ", slice(name_ptr, name_len));
        diag_force_stop_pass();
        return;
    }
    emit("    mov rax, [rbp");
    emit_signed_disp(offset);
    emit("]\n");
    return;
}

func emit_expr_unary(node: u64, symtab: *Symtab) -> u64 {
    var unary: *AstUnary = (*AstUnary)node;
    var op: u64 = unary.op;
    var operand: u64 = unary.operand;
    
    emit_expr(operand);
    var ot: *TypeInfo = get_expr_type_with_symtab((*AstNode)operand, symtab);
    var is_number_operand: u64 = emit_binary_is_number_type(ot);
    if (op == TOKEN_MINUS) {
        if (is_number_operand != 0) {
            emit("    sub rsp, 16\n");
            emit("    mov [rsp+8], rax\n");
            _cg_emit_mov_user_arg_imm_u64(0, 0, 0);
            _cg_emit_direct_call_name(slice("std_number__number_from_i64", str_len("std_number__number_from_i64")), 0, 2);
            emit("    mov [rsp], rax\n");
            _cg_emit_lea_user_arg_from_rsp(0, 0, 0);
            _cg_emit_lea_user_arg_from_rsp(1, 0, 8);
            _cg_emit_direct_call_name(slice("std_number__number_sub_values", str_len("std_number__number_sub_values")), 0, 2);
            emit("    add rsp, 16\n");
            return;
        }
        if (ot != 0 && ot.ptr_depth == 0 && ot.type_kind == TYPE_F64) {
            emit("    mov rbx, 1\n");
            emit("    mov rcx, 63\n");
            emit("    shl rbx, cl\n");
            emit("    movq xmm1, rbx\n");
            emit("    movq xmm0, rax\n");
            emit("    xorpd xmm0, xmm1\n");
            emit("    movq rax, xmm0\n");
            return;
        }
        emit("    neg rax\n");
    }
    else if (op == TOKEN_BANG) {
        if (is_number_operand != 0) {
            emit("    sub rsp, 16\n");
            emit("    mov [rsp], rax\n");
            _cg_emit_mov_user_arg_imm_u64(0, 0, 0);
            _cg_emit_direct_call_name(slice("std_number__number_from_i64", str_len("std_number__number_from_i64")), 0, 2);
            emit("    mov [rsp+8], rax\n");
            _cg_emit_lea_user_arg_from_rsp(0, 0, 0);
            _cg_emit_lea_user_arg_from_rsp(1, 0, 8);
            _cg_emit_direct_call_name(slice("std_number__number_cmp_ptr", str_len("std_number__number_cmp_ptr")), 0, 2);
            emit("    add rsp, 16\n");
            emit("    cmp rax, 0\n");
            emit("    sete al\n");
            emit("    movzx rax, al\n");
            return;
        }
        emit("    test rax, rax\n");
        emit("    setz al\n");
        emit("    movzx rax, al\n");
    } else if (op == TOKEN_TILDE) {
        if (is_number_operand != 0) {
            emit("    sub rsp, 8\n");
            emit("    mov [rsp], rax\n");
            _cg_emit_lea_user_arg_from_rsp(0, 0, 0);
            _cg_emit_direct_call_name(slice("std_number__number_bitnot_values", str_len("std_number__number_bitnot_values")), 0, 1);
            emit("    add rsp, 8\n");
            return;
        }
        emit("    not rax\n");
    }
    return;
}

func emit_expr_addr_of(node: u64, symtab: *Symtab) -> u64 {
    var addr_of: *AstAddrOf = (*AstAddrOf)node;
    var operand: u64 = addr_of.operand;
    if (ast_kind(operand) == AST_IDENT) {
        var ident: *AstIdent = (*AstIdent)operand;
        var name_ptr: u64 = ident.name_ptr;
        var name_len: u64 = ident.name_len;
        var offset: u64 = symtab_find(symtab, slice(name_ptr, name_len));

        if (offset != 0) {
            emit("    lea rax, [rbp");
            emit_signed_disp(offset);
            emit("]\n");
            return;
        }

        if (sym_func_exists(slice(name_ptr, name_len)) != 0) {
            var resolved_ptr: u64 = name_ptr;
            var resolved_len: u64 = name_len;
            var resolved: *NameInfo = resolve_name(slice(name_ptr, name_len));
            if (resolved != 0) {
                resolved_ptr = resolved.ptr;
                resolved_len = resolved.len;
            }
            emit("    lea rax, [rel ");
            emit_len(resolved_ptr, resolved_len);
            emit("]\n");
            return;
        }

        if (sym_global_exists(slice(name_ptr, name_len)) != 0) {
            var resolved_ptr2: u64 = name_ptr;
            var resolved_len2: u64 = name_len;
            var resolved2: *NameInfo = resolve_name(slice(name_ptr, name_len));
            if (resolved2 != 0) {
                resolved_ptr2 = resolved2.ptr;
                resolved_len2 = resolved2.len;
            }
            emit("    lea rax, [rel _gvar_");
            emit_len(resolved_ptr2, resolved_len2);
            emit("]\n");
            return;
        }
    }

    emit_lvalue(operand);
    return;
}

func emit_expr_deref(node: u64, symtab: *Symtab) -> u64 {
    var deref: *AstDeref = (*AstDeref)node;
    var operand: u64 = deref.operand;
    emit_expr(operand);
    
    var type_info: *TypeInfo = get_expr_type_with_symtab((*AstNode)operand, symtab);
    var base_type: u64 = type_info.type_kind;
    var ptr_depth: u64 = type_info.ptr_depth;
    if (ptr_depth > 0 && type_info.is_tagged == 1) {
        emit_tagged_mask();
    }
    
    if (ptr_depth == 1) {
        if (base_type == TYPE_BOOL || base_type == TYPE_U8) {
            emit("    movzx rax, byte [rax]\n");
            return;
        }
        if (base_type == TYPE_U16) {
            emit("    movzx rax, word [rax]\n");
            return;
        }
        if (base_type == TYPE_U32) {
            emit("    mov eax, [rax]\n");
            return;
        }
        if (base_type == TYPE_I8) {
            emit("    movsx rax, byte [rax]\n");
            return;
        }
        if (base_type == TYPE_I16) {
            emit("    movsx rax, word [rax]\n");
            return;
        }
        if (base_type == TYPE_I32) {
            emit("    movsxd rax, dword [rax]\n");
            return;
        }
    }
    emit("    mov rax, [rax]\n");
    return;
}

func emit_expr_deref8(node: u64, symtab: *Symtab) -> u64 {
    var deref8: *AstDeref8 = (*AstDeref8)node;
    var operand: u64 = deref8.operand;
    emit_expr(operand);
    var ti2: *TypeInfo = get_expr_type_with_symtab((*AstNode)operand, symtab);
    if (ti2 != 0) {
        if (ti2.ptr_depth > 0 && ti2.is_tagged == 1) {
            emit_tagged_mask();
        }
    }
    emit("    movzx rax, byte [rax]\n");
    return;
}

func emit_expr_index(node: u64, symtab: *Symtab) -> u64 {
    emit_index_addr(node, symtab);
    var et: *TypeInfo = get_expr_type_with_symtab((*AstNode)node, symtab);
    if (et != 0) {
        if (et.ptr_depth == 0) {
            if (et.type_kind == TYPE_BOOL || et.type_kind == TYPE_U8) {
                emit("    movzx rax, byte [rax]\n");
                return;
            }
            if (et.type_kind == TYPE_U16) {
                emit("    movzx rax, word [rax]\n");
                return;
            }
            if (et.type_kind == TYPE_U32) {
                emit("    mov eax, [rax]\n");
                return;
            }
            if (et.type_kind == TYPE_I8) {
                emit("    movsx rax, byte [rax]\n");
                return;
            }
            if (et.type_kind == TYPE_I16) {
                emit("    movsx rax, word [rax]\n");
                return;
            }
            if (et.type_kind == TYPE_I32) {
                emit("    movsxd rax, dword [rax]\n");
                return;
            }
        }
    }
    emit("    mov rax, [rax]\n");
    return;
}

func emit_expr_safe_index(node: u64, symtab: *Symtab) -> u64 {
    var idx: *AstIndex = (*AstIndex)node;
    var base: u64 = idx.base;
    var index: u64 = idx.index;

    var bt: *TypeInfo = get_expr_type_with_symtab((*AstNode)base, symtab);
    if (bt == 0) {
        diag_emit_error_tag("codegen", "safe-index", "Safe index access type not found");
        diag_force_stop_pass();
        return 0;
    }
    if (bt.ptr_depth == 0) {
        diag_emit_error_tag("codegen", "safe-index", "Safe index access requires pointer receiver");
        diag_emit_help("apply safe index access to a pointer-like receiver");
        diag_force_stop_pass();
        return 0;
    }

    var elem_size: u64 = get_pointee_size(bt.type_kind, bt.ptr_depth);
    if (bt.ptr_depth == 1 && bt.type_kind == TYPE_STRUCT) {
        elem_size = layout_type_sizeof(bt.type_kind, 0, slice(bt.struct_name_ptr, bt.struct_name_len));
    }

    var label_null: u64 = new_label();
    var label_end: u64 = new_label();

    emit_expr(base);
    if (bt.is_tagged == 1) {
        emit_tagged_mask();
    }
    emit("    mov rbx, rax\n");
    emit("    test rbx, rbx\n");
    emit("    je ");
    emit_label(label_null);
    emit_nl();

    emit_expr(index);
    if (elem_size != 1) {
        emit("    imul rax, ");
        emit_u64(elem_size);
        emit_nl();
    }
    emit("    add rax, rbx\n");

    var et: *TypeInfo = get_expr_type_with_symtab((*AstNode)node, symtab);
    if (et != 0) {
        if (et.ptr_depth == 0) {
            if (et.type_kind == TYPE_BOOL || et.type_kind == TYPE_U8) {
                emit("    movzx rax, byte [rax]\n");
            } else if (et.type_kind == TYPE_U16) {
                emit("    movzx rax, word [rax]\n");
            } else if (et.type_kind == TYPE_U32) {
                emit("    mov eax, [rax]\n");
            } else if (et.type_kind == TYPE_I8) {
                emit("    movsx rax, byte [rax]\n");
            } else if (et.type_kind == TYPE_I16) {
                emit("    movsx rax, word [rax]\n");
            } else if (et.type_kind == TYPE_I32) {
                emit("    movsxd rax, dword [rax]\n");
            } else {
                emit("    mov rax, [rax]\n");
            }
        } else {
            emit("    mov rax, [rax]\n");
        }
    } else {
        emit("    mov rax, [rax]\n");
    }
    emit("    jmp ");
    emit_label(label_end);
    emit_nl();

    emit_label_def(label_null);
    emit("    xor eax, eax\n");
    emit_label_def(label_end);
    return 0;
}

func emit_emit_adjust_rax_add(offset: u64) -> u64 {
    if (offset == 0) { return 0; }
    emit("    add rax, ");
    emit_u64(offset);
    emit_nl();
    return 0;
}

func emit_emit_adjust_rax_sub(offset: u64) -> u64 {
    if (offset == 0) { return 0; }
    emit("    sub rax, ");
    emit_u64(offset);
    emit_nl();
    return 0;
}

func emit_emit_checked_trait_to_struct_guard(expected_vtable: []u8) -> u64 {
    if (expected_vtable.ptr == 0 || expected_vtable.len == 0) { return 0; }
    var ok_label: u64 = new_label();
    emit("    mov r11, [rax]\n");
    emit("    lea r10, [rel _gvar_");
    emit_len(expected_vtable.ptr, expected_vtable.len);
    emit("]\n");
    emit("    cmp r11, r10\n");
    emit("    je ");
    emit_label(ok_label);
    emit_nl();
    emit("    ud2\n");
    emit_label_def(ok_label);
    return 0;
}

func emit_emit_checked_struct_downcast_guard(check_info: CompilerDowncastCheckInfo) -> u64 {
    if (check_info.found == 0) { return 0; }
    var ok_label: u64 = new_label();
    if (check_info.src_vptr_offset == 0) {
        emit("    mov r11, [rax]\n");
    } else {
        emit("    mov r11, [rax + ");
        emit_u64(check_info.src_vptr_offset);
        emit("]\n");
    }
    emit("    lea r10, [rel _gvar_");
    emit_len(check_info.expected_vtable_ptr, check_info.expected_vtable_len);
    emit("]\n");
    emit("    cmp r11, r10\n");
    emit("    je ");
    emit_label(ok_label);
    emit_nl();
    emit("    ud2\n");
    emit_label_def(ok_label);
    return 0;
}

func emit_try_adjust_struct_ptr_cast(src_ti: *TypeInfo, target_struct: []u8) -> u64 {
    if (src_ti == 0) { return 0; }
    if (src_ti.type_kind != TYPE_STRUCT || src_ti.ptr_depth == 0) { return 0; }
    if (target_struct.ptr == 0 || target_struct.len == 0) { return 0; }

    var src_def: *AstStructDef = get_struct_def(slice(src_ti.struct_name_ptr, src_ti.struct_name_len));
    if (src_def != 0) {
        var up_offset: u64 = 0;
        var up_def: *AstStructDef = 0;
        if (typeinfo_find_parent_offset(src_def, slice(target_struct.ptr, target_struct.len), &up_offset, &up_def) != 0) {
            emit_emit_adjust_rax_add(up_offset);
            return 1;
        }
    }

    var target_def: *AstStructDef = get_struct_def(slice(target_struct.ptr, target_struct.len));
    if (target_def != 0) {
        var down_offset: u64 = 0;
        var down_def: *AstStructDef = 0;
        if (typeinfo_find_parent_offset(target_def, slice(src_ti.struct_name_ptr, src_ti.struct_name_len), &down_offset, &down_def) != 0) {
            emit_emit_adjust_rax_sub(down_offset);
            return 1;
        }
    }

    return 0;
}

func emit_cast_is_int_scalar(kind: u64) -> u64 {
    if (kind == TYPE_BOOL) { return 1; }
    if (kind == TYPE_U8) { return 1; }
    if (kind == TYPE_U16) { return 1; }
    if (kind == TYPE_U32) { return 1; }
    if (kind == TYPE_U64) { return 1; }
    if (kind == TYPE_I8) { return 1; }
    if (kind == TYPE_I16) { return 1; }
    if (kind == TYPE_I32) { return 1; }
    if (kind == TYPE_I64) { return 1; }
    return 0;
}

func emit_cast_emit_int_truncate(target_kind: u64) -> u64 {
    if (target_kind == TYPE_BOOL || target_kind == TYPE_U8) {
        emit("    and rax, 255\n");
        return 1;
    }
    if (target_kind == TYPE_U16) {
        emit("    and rax, 65535\n");
        return 1;
    }
    if (target_kind == TYPE_U32) {
        emit("    mov eax, eax\n");
        return 1;
    }
    if (target_kind == TYPE_I8) {
        emit("    movsx rax, al\n");
        return 1;
    }
    if (target_kind == TYPE_I16) {
        emit("    movsx rax, ax\n");
        return 1;
    }
    if (target_kind == TYPE_I32) {
        emit("    movsxd rax, eax\n");
        return 1;
    }
    return 0;
}

func emit_cast_emit_u64_to_f64() -> u64 {
    var l_non_negative: u64 = new_label();
    var l_done: u64 = new_label();
    emit("    test rax, rax\n");
    emit("    jns ");
    emit_label(l_non_negative);
    emit_nl();
    emit("    shr rax, 1\n");
    emit("    adc rax, 0\n");
    emit("    cvtsi2sd xmm0, rax\n");
    emit("    addsd xmm0, xmm0\n");
    emit("    jmp ");
    emit_label(l_done);
    emit_nl();
    emit_label_def(l_non_negative);
    emit("    cvtsi2sd xmm0, rax\n");
    emit_label_def(l_done);
    emit("    movq rax, xmm0\n");
    return 1;
}

func emit_cast_emit_int_to_f64(src_kind: u64) -> u64 {
    if (src_kind == TYPE_BOOL || src_kind == TYPE_U8 || src_kind == TYPE_U16 || src_kind == TYPE_U32 ||
        src_kind == TYPE_I8 || src_kind == TYPE_I16 || src_kind == TYPE_I32) {
        emit_cast_emit_int_truncate(src_kind);
    }
    if (src_kind == TYPE_U64) {
        return emit_cast_emit_u64_to_f64();
    }
    emit("    cvtsi2sd xmm0, rax\n");
    emit("    movq rax, xmm0\n");
    return 1;
}

func emit_cast_emit_f64_to_int(target_kind: u64) -> u64 {
    emit("    movq xmm0, rax\n");
    if (target_kind == TYPE_U64) {
        var l_lt_2p63: u64 = new_label();
        var l_done: u64 = new_label();
        emit("    mov rdx, 4890909195324358656\n");
        emit("    movq xmm1, rdx\n");
        emit("    ucomisd xmm0, xmm1\n");
        emit("    jb ");
        emit_label(l_lt_2p63);
        emit_nl();
        emit("    subsd xmm0, xmm1\n");
        emit("    cvttsd2si rax, xmm0\n");
        emit("    bts rax, 63\n");
        emit("    jmp ");
        emit_label(l_done);
        emit_nl();
        emit_label_def(l_lt_2p63);
        emit("    cvttsd2si rax, xmm0\n");
        emit_label_def(l_done);
        return 1;
    }
    emit("    cvttsd2si rax, xmm0\n");
    emit_cast_emit_int_truncate(target_kind);
    return 1;
}

func emit_expr_cast(node: u64, symtab: *Symtab) -> u64 {
    var cast: *AstCast = (*AstCast)node;
    var expr: u64 = cast.expr;
    if (cast.target_type == TYPE_TRAIT) {
        var src_ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)expr, symtab);
        if (src_ti == 0 || src_ti.type_kind != TYPE_STRUCT || src_ti.ptr_depth == 0) {
            emit_stderr("[ERROR] Trait cast requires struct pointer source\n");
            diag_force_stop_pass();
        return 0;
        }
        var impl_info2: *TraitImpl = trait_find_trait_impl(slice(cast.struct_name_ptr, cast.struct_name_len), slice(src_ti.struct_name_ptr, src_ti.struct_name_len));
        if (impl_info2 == 0) {
            emit_stderr("[ERROR] Struct does not implement trait for cast: ");
            emit_stderr_len(cast.struct_name_ptr, cast.struct_name_len);
            emit_stderr("\n");
            diag_force_stop_pass();
        return 0;
        }
        var struct_def: *AstStructDef = get_struct_def(slice(src_ti.struct_name_ptr, src_ti.struct_name_len));
        var vptr_name: *NameInfo = trait_build_vptr_field_name(slice(cast.struct_name_ptr, cast.struct_name_len));
        var field_offset: u64 = 0;
        var field_desc: *FieldDesc = 0;
        var found: u64 = struct_find_field_desc_scoped(struct_def, slice(0, 0), slice(vptr_name.ptr, vptr_name.len), &field_offset, &field_desc);
        if (found == 0) {
            emit_stderr("[ERROR] vptr field not found for trait cast\n");
            diag_force_stop_pass();
        return 0;
        }
        emit_expr(expr);
        if (src_ti.is_tagged == 1) { emit_tagged_mask(); }
        emit_emit_adjust_rax_add(field_offset);
        return;
    }
    if (cast.target_type == TYPE_STRUCT) {
        var src_ti2: *TypeInfo = get_expr_type_with_symtab((*AstNode)expr, symtab);
        if (src_ti2 != 0 && src_ti2.type_kind == TYPE_TRAIT && src_ti2.ptr_depth > 0) {
            var impl2: *TraitImpl = trait_find_trait_impl(slice(src_ti2.struct_name_ptr, src_ti2.struct_name_len), slice(cast.struct_name_ptr, cast.struct_name_len));
            if (impl2 == 0) {
                emit_stderr("[ERROR] Trait cast target struct does not implement trait: ");
                emit_stderr_len(cast.struct_name_ptr, cast.struct_name_len);
                emit_stderr("\n");
                diag_force_stop_pass();
        return 0;
            }
            var struct_def2: *AstStructDef = get_struct_def(slice(cast.struct_name_ptr, cast.struct_name_len));
            var vptr_name2: *NameInfo = trait_build_vptr_field_name(slice(src_ti2.struct_name_ptr, src_ti2.struct_name_len));
            var field_offset2: u64 = 0;
            var field_desc2: *FieldDesc = 0;
            var found2: u64 = struct_find_field_desc_scoped(struct_def2, slice(0, 0), slice(vptr_name2.ptr, vptr_name2.len), &field_offset2, &field_desc2);
            if (found2 == 0) {
                emit_stderr("[ERROR] vptr field not found for trait cast\n");
                diag_force_stop_pass();
        return 0;
            }
            emit_expr(expr);
            if (src_ti2.is_tagged == 1) { emit_tagged_mask(); }
            emit_emit_checked_trait_to_struct_guard(slice(impl2.vtable_global_ptr, impl2.vtable_global_len));
            emit_emit_adjust_rax_sub(field_offset2);
            return;
        }

        if (cast.target_ptr_depth > 0 && src_ti2 != 0 && src_ti2.type_kind == TYPE_STRUCT && src_ti2.ptr_depth > 0) {
            emit_expr(expr);
            if (src_ti2.is_tagged == 1) { emit_tagged_mask(); }
            if (str_eq(slice(src_ti2.struct_name_ptr, src_ti2.struct_name_len), slice(cast.struct_name_ptr, cast.struct_name_len)) == 0 &&
                struct_is_same_or_descendant(slice(cast.struct_name_ptr, cast.struct_name_len), slice(src_ti2.struct_name_ptr, src_ti2.struct_name_len)) != 0) {
                var check_info: CompilerDowncastCheckInfo = trait_require_checked_struct_downcast_info(slice(src_ti2.struct_name_ptr, src_ti2.struct_name_len), slice(cast.struct_name_ptr, cast.struct_name_len));
                emit_emit_checked_struct_downcast_guard(check_info);
            }
            emit_try_adjust_struct_ptr_cast(src_ti2, slice(cast.struct_name_ptr, cast.struct_name_len));
            return;
        }
    }
    var src_ti3: *TypeInfo = get_expr_type_with_symtab((*AstNode)expr, symtab);
    if (src_ti3 != 0 && src_ti3.ptr_depth == 0 && cast.target_ptr_depth == 0) {
        var src_kind: u64 = src_ti3.type_kind;
        var target_kind: u64 = cast.target_type;
        if (src_kind == target_kind) {
            emit_expr(expr);
            return;
        }
        if (emit_cast_is_int_scalar(src_kind) != 0 && emit_cast_is_int_scalar(target_kind) != 0) {
            emit_expr(expr);
            emit_cast_emit_int_truncate(target_kind);
            return;
        }
        if (emit_cast_is_int_scalar(src_kind) != 0 && target_kind == TYPE_F64) {
            emit_expr(expr);
            emit_cast_emit_int_to_f64(src_kind);
            return;
        }
        if (src_kind == TYPE_F64 && emit_cast_is_int_scalar(target_kind) != 0) {
            emit_expr(expr);
            emit_cast_emit_f64_to_int(target_kind);
            return;
        }
    }
    emit_expr(expr);
    return;
}

func emit_expr_sizeof(node: u64) -> u64 {
    var sizeof_node: *AstSizeof = (*AstSizeof)node;
    var type_kind: u64 = sizeof_node.type_kind;
    var ptr_depth: u64 = sizeof_node.ptr_depth;
    var struct_name_ptr: u64 = sizeof_node.struct_name_ptr;
    var struct_name_len: u64 = sizeof_node.struct_name_len;
    var size: u64 = 0;
    if (type_kind == TYPE_ARRAY || type_kind == TYPE_SLICE) {
        if (sizeof_node.array_len_is_param != 0) {
            emit_stderr("[ERROR] sizeof array with unresolved generic length\n");
            diag_force_stop_pass();
        return 0;
        }
        var ti_ptr: *TypeInfo = 0;
        if (type_kind == TYPE_ARRAY) {
            ti_ptr = typeinfo_make_array(ptr_depth, sizeof_node.elem_type_kind, sizeof_node.elem_ptr_depth, slice(struct_name_ptr, struct_name_len), 0, sizeof_node.array_len);
        } else {
            ti_ptr = typeinfo_make_slice(ptr_depth, sizeof_node.elem_type_kind, sizeof_node.elem_ptr_depth, slice(struct_name_ptr, struct_name_len), 0);
        }
        ti_ptr.elem_typeinfo = sizeof_node.elem_typeinfo;
        size = sizeof_type_ex(ti_ptr);
    } else {
        // Calculate size at compile time
        size = layout_type_sizeof(type_kind, ptr_depth, slice(struct_name_ptr, struct_name_len));
    }
    
    // Emit as literal constant
    emit("    mov rax, ");
    emit_u64(size);
    emit_nl();
    return;
}

func emit_expr_sizeof_expr(node: u64, symtab: *Symtab) -> u64 {
    var sz_expr: *AstSizeofExpr = (*AstSizeofExpr)node;
    var ti_ptr: *TypeInfo = get_expr_type_with_symtab((*AstNode)sz_expr.expr, symtab);
    var size_val: u64 = 8;
    if (ti_ptr != 0) {
        size_val = sizeof_type_ex(ti_ptr);
    }
    emit("    mov rax, ");
    emit_u64(size_val);
    emit_nl();
    return;
}

func emit_new_alloc_zero(size: u64) -> u64 {
    var malloc_ptr: u64 = (u64)"malloc";
    var malloc_len: u64 = 6;
    var malloc_res: *NameInfo = resolve_name(slice(malloc_ptr, malloc_len));
    if (malloc_res != 0) {
        malloc_ptr = malloc_res.ptr;
        malloc_len = malloc_res.len;
    }

    _cg_emit_mov_user_arg_imm_u64(0, 0, size);
    _cg_emit_direct_call_name(slice(malloc_ptr, malloc_len), 0, 0);
    emit("    mov r12, rax\n");

    var memset_ptr: u64 = (u64)"memset";
    var memset_len: u64 = 6;
    var memset_res: *NameInfo = resolve_name(slice(memset_ptr, memset_len));
    if (memset_res != 0) {
        memset_ptr = memset_res.ptr;
        memset_len = memset_res.len;
    }

    _cg_emit_mov_user_arg_from_reg(0, 0, slice("r12", 3));
    _cg_emit_mov_user_arg_imm_u64(1, 0, 0);
    _cg_emit_mov_user_arg_imm_u64(2, 0, size);
    _cg_emit_direct_call_name(slice(memset_ptr, memset_len), 0, 0);
    return 0;
}

func emit_new_invoke_constructor(nw: *AstNew, symtab: *Symtab) -> u64 {
    if (nw.ctor_args_vec == 0) {
        return 0;
    }
    if (nw.type_kind != TYPE_STRUCT) {
        emit_stderr("[ERROR] new constructor call requires struct type\n");
        diag_force_stop_pass();
        return 0;
    }
    if (nw.struct_name_ptr == 0 || nw.struct_name_len == 0) {
        emit_stderr("[ERROR] new constructor target struct missing metadata in emitter\n");
        diag_force_stop_pass();
        return 0;
    }

    var args: *Vec<*AstNode> = nw.ctor_args_vec;
    var resolved_ctor: CompilerMethodResolveResult = emit_resolve_constructor_call(slice(nw.struct_name_ptr, nw.struct_name_len), args, symtab, slice("new", 3));
    if (resolved_ctor.found == 0 || resolved_ctor.fn == 0) {
        return 0;
    }
    var fn_ctor: *AstFunc = resolved_ctor.fn;
    var call_ptr: u64 = fn_ctor.name_ptr;
    var call_len: u64 = fn_ctor.name_len;
    var resolved_name: *NameInfo = resolve_name(slice(call_ptr, call_len));
    if (resolved_name != 0) {
        call_ptr = resolved_name.ptr;
        call_len = resolved_name.len;
    }
    var nargs: u64 = args.len();
    var total_arg_words: u64 = 0;
    if (nargs != 0) {
        var ai: u64 = nargs;
        while (ai > 0) {
            ai = ai - 1;
            var arg: *AstNode = args.get(ai);
            var param: *Param = emit_call_param_at(fn_ctor, ai + 1);
            total_arg_words = total_arg_words + emit_call_push_arg_with_param(arg, param, symtab);
        }
    }
    emit("    push r12\n");
    total_arg_words = total_arg_words + 1;
    var stack_words: u64 = _cg_sysv_pop_arg_regs(total_arg_words);

    emit("    call ");
    emit_len(call_ptr, call_len);
    emit_nl();

    if (stack_words > 0) {
        emit("    add rsp, ");
        emit_u64(stack_words * 8);
        emit_nl();
    }
    return 0;
}

func emit_expr_new(node: u64, symtab: *Symtab) -> u64 {
    var nw: *AstNew = (*AstNew)node;
    if (nw.array_len_is_param != 0) {
        emit_stderr("[ERROR] new with unresolved generic array length\n");
        diag_force_stop_pass();
        return 0;
    }

    var size: u64 = 0;
    if (nw.type_kind == TYPE_ARRAY) {
        var elem_size: u64 = 0;
        if (nw.elem_typeinfo != 0) {
            elem_size = sizeof_type_ex(nw.elem_typeinfo);
        } else {
            elem_size = layout_type_sizeof(nw.elem_type_kind, nw.elem_ptr_depth, slice(nw.struct_name_ptr, nw.struct_name_len));
        }
        size = elem_size * nw.array_len;
    } else if (nw.type_kind == TYPE_SLICE) {
        size = 16;
    } else {
        size = layout_type_sizeof(nw.type_kind, nw.ptr_depth, slice(nw.struct_name_ptr, nw.struct_name_len));
    }

    emit_new_alloc_zero(size);

    if (nw.type_kind == TYPE_STRUCT) {
        emit_emit_trait_vptr_init_at_r12(slice(nw.struct_name_ptr, nw.struct_name_len));
    }

    if (nw.literal_expr != 0) {
        if (ast_kind(nw.literal_expr) == AST_STRUCT_LITERAL) {
            emit_struct_literal_init_ptr(nw.literal_expr);
        }
    }

    emit_new_invoke_constructor(nw, symtab);

    emit("    mov rax, r12\n");
    return;
}

func emit_expr_try_immediate(kind: u64, node: u64) -> u64 {
    if (kind == AST_LITERAL) {
        var lit: *AstLiteral = (*AstLiteral)node;
        var val: u64 = lit.value;
        var signed_val: i64 = (i64)val;
        emit("    mov rax, ");
        if (signed_val < 0) {
            emit_i64(signed_val);
        } else {
            emit_u64(val);
        }
        emit_nl();
        return 1;
    }
    if (kind == AST_FLOAT) {
        var fl: *AstFloat = (*AstFloat)node;
        var label_id: u64 = float_get_label(slice(fl.str_ptr, fl.str_len));
        emit("    mov rax, [rel _flt");
        emit_u64(label_id);
        emit("]\n");
        return 1;
    }
    if (kind == AST_STRING) {
        var str: *AstString = (*AstString)node;
        var label_id: u64 = string_get_label(slice(str.str_ptr, str.str_len));
        emit("    lea rax, [rel _str");
        emit_u64(label_id);
        emit("]\n");
        return 1;
    }
    if (kind == AST_STRUCT_LITERAL) {
        emit("    xor eax, eax\n");
        return 1;
    }
    if (kind == AST_SLICE) {
        emit_stderr("[ERROR] Slice literal cannot be used as rvalue\n");
        diag_force_stop_pass();
        return 1;
    }
    return 0;
}

func emit_expr_ternary(node: u64, symtab: *Symtab) -> u64 {
    var tern: *AstTernary = (*AstTernary)node;
    var label_false: u64 = new_label();
    var label_end: u64 = new_label();

    emit_expr(tern.cond);
    emit("    test rax, rax\n");
    emit("    je ");
    emit_label(label_false);
    emit_nl();

    emit_expr(tern.then_expr);
    emit("    jmp ");
    emit_label(label_end);
    emit_nl();

    emit_label_def(label_false);
    emit_expr(tern.else_expr);
    emit_label_def(label_end);
    return 0;
}

func emit_expr_dispatch_with_symtab(kind: u64, node: u64, symtab: *Symtab) -> u64 {
    if (kind == AST_IDENT) { emit_expr_ident(node, symtab); return 1; }
    if (kind == AST_MEMBER_ACCESS) { emit_member_access_expr(node, symtab); return 1; }
    if (kind == AST_SAFE_MEMBER_ACCESS) { emit_safe_member_access_expr(node, symtab); return 1; }
    if (kind == AST_TERNARY) { emit_expr_ternary(node, symtab); return 1; }
    if (kind == AST_BINARY) { emit_binary_expr(node, symtab); return 1; }
    if (kind == AST_UNARY) { emit_expr_unary(node, symtab); return 1; }
    if (kind == AST_TRY) { emit_try_expr(node, symtab); return 1; }
    if (kind == AST_ADDR_OF) { emit_expr_addr_of(node, symtab); return 1; }
    if (kind == AST_DEREF) { emit_expr_deref(node, symtab); return 1; }
    if (kind == AST_DEREF8) { emit_expr_deref8(node, symtab); return 1; }
    if (kind == AST_INDEX) { emit_expr_index(node, symtab); return 1; }
    if (kind == AST_SAFE_INDEX) { emit_expr_safe_index(node, symtab); return 1; }
    if (kind == AST_CAST) { emit_expr_cast(node, symtab); return 1; }
    if (kind == AST_SIZEOF) { emit_expr_sizeof(node); return 1; }
    if (kind == AST_SIZEOF_EXPR) { emit_expr_sizeof_expr(node, symtab); return 1; }
    if (kind == AST_NEW) { emit_expr_new(node, symtab); return 1; }
    if (kind == AST_CALL) { emit_expr_call(node, symtab); return 1; }
    if (kind == AST_CALL_PTR) { emit_expr_call_ptr(node, symtab); return 1; }
    if (kind == AST_METHOD_CALL) { emit_method_call(node, symtab); return 1; }
    if (kind == AST_SAFE_METHOD_CALL) { emit_safe_method_call(node, symtab); return 1; }
    if (kind == AST_STACK_CTOR) { emit_expr_stack_ctor(node, symtab); return 1; }
    return 0;
}

func emit_expr(node: u64) -> u64 {
    if (diag_should_stop_pass() != 0) { return 0; }
    if (node == 0) {
        emit_stderr("[ERROR] codegen received null expression node\n");
        diag_force_stop_pass();
        emit("    xor eax, eax\n");
        return 0;
    }
    var kind: u64 = ast_kind(node);
    if (emit_expr_try_immediate(kind, node) != 0) { return; }
    var symtab: *Symtab = symtab_current();
    emit_expr_dispatch_with_symtab(kind, node, symtab);
}

func emit_struct_literal_init_ptr(init: u64) -> u64 {
    var lit: *AstStructLiteral = (*AstStructLiteral)init;
    var values: *Vec<u64> = lit.values_vec;
    var num_values: u64 = values.len();
    var fields: *Vec<*FieldDesc> = lit.struct_def.fields_vec;
    var num_fields: u64 = fields.len();

    var impls: *Vec<*TraitImpl> = sym_get_trait_impls();
    if (impls != 0) {
        var ni: u64 = impls.len();
        for (var ti: u64 = 0; ti < ni; ti++) {
            var impl_info3: *TraitImpl = impls.get(ti);
            if (!str_eq(slice(impl_info3.struct_ptr, impl_info3.struct_len), slice(lit.struct_def.name_ptr, lit.struct_def.name_len))) { continue; }
            var vptr_name: *NameInfo = trait_build_vptr_field_name(slice(impl_info3.trait_ptr, impl_info3.trait_len));
            var field_offset_v: u64 = 0;
            var field_desc_v: *FieldDesc = 0;
            var found_v: u64 = struct_find_field_desc_scoped(lit.struct_def, slice(0, 0), slice(vptr_name.ptr, vptr_name.len), &field_offset_v, &field_desc_v);
            if (found_v == 0) {
                emit_stderr("[ERROR] vptr field not found for struct literal init\n");
                diag_force_stop_pass();
        return 0;
            }
            emit("    lea rax, [rel _gvar_");
            emit_len(impl_info3.vtable_global_ptr, impl_info3.vtable_global_len);
            emit("]\n");
            emit("    mov [r12");
            if (field_offset_v != 0) { emit("+"); emit_u64(field_offset_v); }
            emit("], rax\n");
        }
    }

    var field_offset: u64 = 0;
    var value_index: u64 = 0;
    for (var fi: u64 = 0; fi < num_fields && value_index < num_values; fi++) {
        var field: *FieldDesc = fields.get(fi);
        var field_size: u64 = layout_field_sizeof(field);
        if (trait_is_vptr_field_name(slice(field.name_ptr, field.name_len)) != 0) {
            field_offset = field_offset + field_size;
            continue;
        }

        emit_expr(values.get(value_index));

        emit("    mov [r12");
        if (field_offset != 0) { emit("+"); emit_u64(field_offset); }
        emit("], rax\n");

        field_offset = field_offset + field_size;
        value_index = value_index + 1;
    }
    return 0;
}

// ============================================
// Member Access Expression
// ============================================

func emit_property_hook_find_field(member_access: *AstMemberAccess, symtab: *Symtab, out_obj_ti: **TypeInfo) -> *FieldDesc {
    if (member_access == 0 || symtab == 0) { return 0; }
    if (out_obj_ti != 0) { *out_obj_ti = 0; }

    var obj_ti: *TypeInfo = get_expr_type_with_symtab(member_access.object, symtab);
    if (obj_ti == 0) { return 0; }
    if (out_obj_ti != 0) { *out_obj_ti = obj_ti; }

    if (obj_ti.type_kind != TYPE_STRUCT) { return 0; }
    var struct_def: *AstStructDef = emit_hydrate_struct_def_from_type(obj_ti);
    if (struct_def == 0 && obj_ti.struct_name_ptr != 0) {
        struct_def = get_struct_def(slice(obj_ti.struct_name_ptr, obj_ti.struct_name_len));
    }
    if (struct_def == 0) { return 0; }

    return typeinfo_find_field_desc_scoped(struct_def, slice(member_access.parent_ptr, member_access.parent_len), slice(member_access.member_ptr, member_access.member_len));
}

func emit_property_hook_build_self_arg(member_access: *AstMemberAccess, obj_ti: *TypeInfo) -> *AstNode {
    if (member_access == 0 || obj_ti == 0) { return 0; }
    if (obj_ti.ptr_depth > 0) {
        return member_access.object;
    }
    return (*AstNode)ast_addr_of(member_access.object);
}

func emit_property_hook_emit_getter(member_access: *AstMemberAccess, symtab: *Symtab) -> u64 {
    if (member_access == 0 || symtab == 0) { return 0; }
    if (member_access.is_raw != 0) { return 0; }

    var obj_ti: *TypeInfo = 0;
    var field_desc: *FieldDesc = emit_property_hook_find_field(member_access, symtab, &obj_ti);
    if (field_desc == 0 || field_desc.getter_hook_mode == FIELD_HOOK_NONE) { return 0; }
    if (field_desc.getter_hook_ptr == 0 || field_desc.getter_hook_len == 0) { return 0; }

    var args: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((1) * sizeof(*AstNode)), 0, (1)};
    args.push(emit_property_hook_build_self_arg(member_access, obj_ti));
    var call_node: *AstCall = ast_call_with_origin(slice(field_desc.getter_hook_ptr, field_desc.getter_hook_len), args, AST_CALL_ORIGIN_DIRECT);
    emit_expr((u64)call_node);
    return 1;
}

func emit_property_hook_emit_setter(member_access: *AstMemberAccess, value: *AstNode, symtab: *Symtab) -> u64 {
    if (member_access == 0 || value == 0 || symtab == 0) { return 0; }
    if (member_access.is_raw != 0) { return 0; }

    var obj_ti: *TypeInfo = 0;
    var field_desc: *FieldDesc = emit_property_hook_find_field(member_access, symtab, &obj_ti);
    if (field_desc == 0 || field_desc.setter_hook_mode == FIELD_HOOK_NONE) { return 0; }
    if (field_desc.setter_hook_ptr == 0 || field_desc.setter_hook_len == 0) { return 0; }

    var args: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((2) * sizeof(*AstNode)), 0, (2)};
    args.push(emit_property_hook_build_self_arg(member_access, obj_ti));
    args.push(value);
    var call_node: *AstCall = ast_call_with_origin(slice(field_desc.setter_hook_ptr, field_desc.setter_hook_len), args, AST_CALL_ORIGIN_DIRECT);
    emit_expr((u64)call_node);
    return 1;
}

func emit_safe_member_access_expr(node: u64, symtab: *Symtab) -> u64 {
    var member_access: *AstMemberAccess = (*AstMemberAccess)node;
    var object: u64 = member_access.object;
    var member_ptr: u64 = member_access.member_ptr;
    var member_len: u64 = member_access.member_len;
    var parent_ptr: u64 = member_access.parent_ptr;
    var parent_len: u64 = member_access.parent_len;

    var ot: *TypeInfo = get_expr_type_with_symtab((*AstNode)object, symtab);
    if (ot == 0) {
        emit_stderr("[ERROR] Safe member access type not found\n");
        return 0;
    }
    if (ot.ptr_depth == 0) {
        emit_stderr("[ERROR] Safe member access requires pointer receiver\n");
        return 0;
    }
    if (ot.type_kind != TYPE_STRUCT) {
        emit_stderr("[ERROR] Safe member access requires struct pointer\n");
        return 0;
    }

    var label_null: u64 = new_label();
    var label_end: u64 = new_label();

    emit_expr(object);
    if (ot.is_tagged == 1) {
        emit_tagged_mask();
    }
    emit("    test rax, rax\n");
    emit("    je ");
    emit_label(label_null);
    emit_nl();

    if (ot.is_tagged == 1 && ot.tag_layout_ptr != 0) {
        var layout_info: *AstStructDef = emit_require_tagged_layout_struct(slice(ot.tag_layout_ptr, ot.tag_layout_len));
        emit_emit_tagged_layout_extract_from_rax(layout_info, slice(member_ptr, member_len));
        emit_emit_safe_null_epilogue(label_null, label_end);
        return 0;
    }

    var struct_def: *AstStructDef = emit_hydrate_struct_def_from_type(ot);
    if (struct_def == 0) {
        // Conservative fallback for unresolved Number-like pointer field access.
        if (emit_member_is_bits_field(slice(member_ptr, member_len)) != 0) {
            emit("    mov rax, [rax]\n");
            emit_emit_safe_null_epilogue(label_null, label_end);
            return 0;
        }
        emit_stderr("[ERROR] Struct definition not found for pointer type in safe member access\n");
        diag_force_stop_pass();
        emit_emit_safe_null_epilogue(label_null, label_end);
        return 0;
    }

    var field_offset2: u64 = 0;
    var field_desc: *FieldDesc = 0;
    var found2: u64 = struct_find_field_desc_scoped(struct_def, slice(parent_ptr, parent_len), slice(member_ptr, member_len), &field_offset2, &field_desc);
    if (found2 == 0) { return 0; }
    if (field_desc != 0 && check_field_access(field_desc) == 0) {
        emit_stderr("[ERROR] private field access denied: ");
        emit_stderr_len(struct_def.name_ptr, struct_def.name_len);
        emit_stderr(".");
        emit_stderr_len(member_ptr, member_len);
        emit_stderr("\n");
        return 0;
    }
    if (field_offset2 > 0) {
        emit("    add rax, ");
        emit_u64(field_offset2);
        emit("\n");
    }
    if (field_desc == 0) {
        emit_emit_safe_null_epilogue(label_null, label_end);
        return 0;
    }
    var fd: *FieldDesc = field_desc;
    if (fd.type_kind == TYPE_STRUCT && fd.ptr_depth == 0) {
        emit_emit_safe_null_epilogue(label_null, label_end);
        return 0;
    }
    if (fd.type_kind == TYPE_ARRAY) {
        emit_emit_safe_null_epilogue(label_null, label_end);
        return 0;
    }
    emit_emit_field_load_from_rax(fd);

    emit_emit_safe_null_epilogue(label_null, label_end);
    return 0;
}

func emit_member_load_sized_at_rax(size_bytes: u64) -> u64 {
    if (size_bytes == 1) {
        emit("    movzx rax, byte [rax]\n");
        return 0;
    }
    if (size_bytes == 2) {
        emit("    movzx rax, word [rax]\n");
        return 0;
    }
    if (size_bytes == 4) {
        emit("    mov eax, [rax]\n");
        return 0;
    }
    emit("    mov rax, [rax]\n");
    return 0;
}

func emit_member_emit_load_or_deref(field_desc: *FieldDesc, load_when_missing: u64) -> u64 {
    if (field_desc == 0) {
        if (load_when_missing != 0) {
            emit("    mov rax, [rax]\n");
        }
        return 1;
    }
    if (field_desc.type_kind == TYPE_ARRAY) { return 1; }
    emit_emit_field_load_from_rax(field_desc);
    return 1;
}

func emit_member_emit_struct_field_at_rax(struct_def: *AstStructDef, parent: []u8, member: []u8, load_when_missing: u64) -> u64 {
    var field_offset: u64 = 0;
    var field_desc: *FieldDesc = 0;
    var lookup_parent_ptr: u64 = parent.ptr;
    var lookup_parent_len: u64 = parent.len;
    if (struct_def != 0 && struct_def.is_union == 1) {
        // union has no parent scope; field lookup is always local.
        lookup_parent_ptr = 0;
        lookup_parent_len = 0;
    }
    var found: u64 = struct_find_field_desc_scoped(struct_def, slice(lookup_parent_ptr, lookup_parent_len), slice(member.ptr, member.len), &field_offset, &field_desc);
    if (found == 0 && lookup_parent_ptr != 0) {
        found = struct_find_field_desc_scoped(struct_def, slice(0, 0), slice(member.ptr, member.len), &field_offset, &field_desc);
    }
    if (found == 0) {
        // Name collision fallback: prefer the newest same-name type that owns this member.
        var all_structs: *Vec<*AstStructDef> = typeinfo_get_structs();
        if (all_structs != 0 && struct_def != 0) {
            var si: u64 = all_structs.len();
            while (si > 0) {
                si = si - 1;
                var alt_sd: *AstStructDef = all_structs.get(si);
                if (alt_sd == 0 || alt_sd == struct_def) { continue; }
                if (str_eq(slice(alt_sd.name_ptr, alt_sd.name_len), slice(struct_def.name_ptr, struct_def.name_len)) == 0) { continue; }
                var alt_parent_ptr: u64 = lookup_parent_ptr;
                var alt_parent_len: u64 = lookup_parent_len;
                if (alt_sd.is_union == 1) {
                    alt_parent_ptr = 0;
                    alt_parent_len = 0;
                }
                var alt_offset: u64 = 0;
                var alt_desc: *FieldDesc = 0;
                var alt_found: u64 = struct_find_field_desc_scoped(alt_sd, slice(alt_parent_ptr, alt_parent_len), slice(member.ptr, member.len), &alt_offset, &alt_desc);
                if (alt_found == 0 && alt_parent_ptr != 0) {
                    alt_found = struct_find_field_desc_scoped(alt_sd, slice(0, 0), slice(member.ptr, member.len), &alt_offset, &alt_desc);
                }
                if (alt_found != 0) {
                    struct_def = alt_sd;
                    field_offset = alt_offset;
                    field_desc = alt_desc;
                    found = 1;
                    break;
                }
            }
        }
    }
    if (found == 0) {
        emit_stderr("[ERROR] unknown member: ");
        emit_stderr_len(struct_def.name_ptr, struct_def.name_len);
        emit_stderr(".");
        emit_stderr_len(member.ptr, member.len);
        emit_stderr("\n");
        diag_force_stop_pass();
        return 0;
    }
    if (field_desc != 0 && check_field_access(field_desc) == 0) {
        emit_stderr("[ERROR] private field access denied: ");
        emit_stderr_len(struct_def.name_ptr, struct_def.name_len);
        emit_stderr(".");
        emit_stderr_len(member.ptr, member.len);
        emit_stderr("\n");
        diag_force_stop_pass();
        return 0;
    }

    emit_member_add_offset_to_rax(field_offset);
    emit_member_emit_load_or_deref(field_desc, load_when_missing);
    return 1;
}

func emit_member_expr_tagged_layout(object: u64, ot: *TypeInfo, member: []u8) -> u64 {
    var layout_info: *AstStructDef = emit_require_tagged_layout_struct(slice(ot.tag_layout_ptr, ot.tag_layout_len));
    emit_expr(object);
    emit_emit_tagged_layout_extract_from_rax(layout_info, slice(member.ptr, member.len));
    return 0;
}

func emit_member_expr_ptr_struct(object: u64, ot: *TypeInfo, parent: []u8, member: []u8) -> u64 {
    emit_expr(object);
    if (ot.is_tagged == 1) {
        emit_tagged_mask();
    }
    var struct_def_ptr: *AstStructDef = emit_hydrate_struct_def_from_type(ot);
    if (struct_def_ptr == 0) {
        // Fallback: unresolved struct pointer, but first-field access is still addressable.
        if (emit_member_is_bits_field(slice(member.ptr, member.len)) != 0) {
            emit("    mov rax, [rax]\n");
            return 0;
        }
        emit_stderr("[ERROR] Struct definition not found for pointer type in member access\n");
        diag_force_stop_pass();
        return 0;
    }
    emit_member_emit_struct_field_at_rax(struct_def_ptr, slice(parent.ptr, parent.len), slice(member.ptr, member.len), 0);
    return 0;
}

func emit_member_expr_packed_struct(object: u64, struct_info: *AstStructDef, member: []u8) -> u64 {
    var total_bits: u64 = get_packed_layout_total_bits(struct_info);
    var field_offset: u64 = get_packed_field_bit_offset(struct_info, slice(member.ptr, member.len));
    var field_width: u64 = get_packed_field_bit_width(struct_info, slice(member.ptr, member.len));
    var size_bytes: u64 = (total_bits + 7) / 8;

    if (total_bits > 64 || (field_offset + field_width) > 64) {
        var byte_offset: u64 = field_offset / 8;
        var bit_shift: u64 = field_offset % 8;
        var byte_width: u64 = (field_width + 7) / 8;

        emit_lvalue(object);
        emit_member_add_offset_to_rax(byte_offset);
        emit_member_load_sized_at_rax(byte_width);

        if (bit_shift > 0) {
            emit("    mov rcx, ");
            emit_u64(bit_shift);
            emit_nl();
            emit("    shr rax, cl\n");
        }
        if (field_width < 64) {
            emit_mask_to_rdx(field_width);
            emit("    and rax, rdx\n");
        }
        return 0;
    }

    emit_lvalue(object);
    emit_member_load_sized_at_rax(size_bytes);
    if (field_offset > 0) {
        emit("    mov rcx, ");
        emit_u64(field_offset);
        emit_nl();
        emit("    shr rax, cl\n");
    }
    if (field_width < 64) {
        emit_mask_to_rdx(field_width);
        emit("    and rax, rdx\n");
    }
    return 0;
}

func emit_member_expr_deref(object: u64, symtab: *Symtab, parent: []u8, member: []u8) -> u64 {
    var deref_obj: *AstDeref = (*AstDeref)object;
    var ptr_expr: u64 = deref_obj.operand;

    emit_expr(ptr_expr);

    var ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)ptr_expr, symtab);
    if (ti == 0) {
        emit("    ; ERROR: Cannot determine pointer type in arrow operator\n");
        return 0;
    }
    if (ti.ptr_depth > 0 && ti.is_tagged == 1) {
        emit_tagged_mask();
    }
    if (ti.ptr_depth == 0 || ti.type_kind != TYPE_STRUCT) {
        emit("    ; ERROR: Arrow operator requires pointer to struct\n");
        return 0;
    }
    var struct_def: *AstStructDef = emit_hydrate_struct_def_from_type(ti);
    if (struct_def == 0) {
        if (emit_member_is_bits_field(slice(member.ptr, member.len)) != 0) {
            emit("    mov rax, [rax]\n");
            return 0;
        }
        emit_stderr("[ERROR] Struct definition not found for pointer type in arrow member access\n");
        diag_force_stop_pass();
        return 0;
    }
    emit_member_emit_struct_field_at_rax(struct_def, slice(parent.ptr, parent.len), slice(member.ptr, member.len), 0);
    return 0;
}

func emit_member_expr_nested(object: u64, symtab: *Symtab, parent: []u8, member: []u8) -> u64 {
    var nt: *TypeInfo = get_expr_type_with_symtab((*AstNode)object, symtab);
    if (nt == 0) {
        emit("    ; ERROR: Nested member access type not found\n");
        return 0;
    }
    var nested_struct_def: *AstStructDef = emit_hydrate_struct_def_from_type(nt);
    if (nt.type_kind != TYPE_STRUCT || nested_struct_def == 0) {
        emit("    ; ERROR: Nested member access on non-struct\n");
        return 0;
    }
    emit_lvalue(object);
    emit_member_emit_struct_field_at_rax(nested_struct_def, slice(parent.ptr, parent.len), slice(member.ptr, member.len), 1);
    return 0;
}

func emit_member_expr_indexed(object: u64, symtab: *Symtab, parent: []u8, member: []u8) -> u64 {
    var it: *TypeInfo = get_expr_type_with_symtab((*AstNode)object, symtab);
    if (it == 0) {
        emit("    ; ERROR: Indexed member access type not found\n");
        return 0;
    }
    var indexed_struct_def: *AstStructDef = emit_hydrate_struct_def_from_type(it);
    if (it.type_kind != TYPE_STRUCT || indexed_struct_def == 0) {
        emit("    ; ERROR: Indexed member access on non-struct\n");
        return 0;
    }
    emit_lvalue(object);
    emit_member_emit_struct_field_at_rax(indexed_struct_def, slice(parent.ptr, parent.len), slice(member.ptr, member.len), 1);
    return 0;
}

func emit_member_emit_local_slice_member(offset: u64, member: []u8) -> u64 {
    if (str_eq(slice(member.ptr, member.len), slice("ptr", str_len("ptr"))) != 0) {
        emit("    mov rax, [rbp");
        emit_signed_disp(offset);
        emit("]\n");
        return 1;
    }
    if (str_eq(slice(member.ptr, member.len), slice("len", str_len("len"))) != 0) {
        emit("    mov rax, [rbp");
        var len_offset: u64 = offset + 8;
        emit_signed_disp(len_offset);
        emit("]\n");
        return 1;
    }
    return 0;
}

func emit_member_emit_global_slice_member(name: []u8, member: []u8) -> u64 {
    if (str_eq(slice(member.ptr, member.len), slice("ptr", str_len("ptr"))) != 0) {
        emit("    mov rax, [rel _gvar_");
        emit_len(name.ptr, name.len);
        emit("]\n");
        return 1;
    }
    if (str_eq(slice(member.ptr, member.len), slice("len", str_len("len"))) != 0) {
        emit("    mov rax, [rel _gvar_");
        emit_len(name.ptr, name.len);
        emit("+8]\n");
        return 1;
    }
    return 0;
}

func emit_member_emit_lvalue_local_slice_member(offset: u64, member: []u8) -> u64 {
    emit("    lea rax, [rbp");
    if (str_eq(slice(member.ptr, member.len), slice("ptr", str_len("ptr"))) != 0) {
        emit_signed_disp(offset);
        emit("]\n");
        return 1;
    }
    if (str_eq(slice(member.ptr, member.len), slice("len", str_len("len"))) != 0) {
        var len_offset: u64 = offset + 8;
        emit_signed_disp(len_offset);
        emit("]\n");
        return 1;
    }
    return 0;
}

func emit_member_emit_lvalue_global_slice_member(name: []u8, member: []u8) -> u64 {
    emit("    lea rax, [rel _gvar_");
    emit_len(name.ptr, name.len);
    if (str_eq(slice(member.ptr, member.len), slice("ptr", str_len("ptr"))) != 0) {
        emit("]\n");
        return 1;
    }
    if (str_eq(slice(member.ptr, member.len), slice("len", str_len("len"))) != 0) {
        emit("+8]\n");
        return 1;
    }
    return 0;
}

func emit_member_expr_ident(object: u64, symtab: *Symtab, parent: []u8, member: []u8) -> u64 {
    var obj_ident: *AstIdent = (*AstIdent)object;
    var obj_name_ptr: u64 = obj_ident.name_ptr;
    var obj_name_len: u64 = obj_ident.name_len;

    // Module namespace access: <module_alias>.<exported_symbol>
    var mod_scoped: *NameInfo = sym_resolve_module_scoped_symbol(slice(obj_name_ptr, obj_name_len), slice(member.ptr, member.len));
    if (mod_scoped != 0) {
        var cresult: ConstResult = const_find(slice(mod_scoped.ptr, mod_scoped.len));
        if (cresult.found == 1) {
            emit("    mov rax, ");
            emit_u64(cresult.value);
            emit_nl();
            return 0;
        }
        if (is_global_var(slice(mod_scoped.ptr, mod_scoped.len))) {
            emit("    mov rax, [rel _gvar_");
            emit_len(mod_scoped.ptr, mod_scoped.len);
            emit("]\n");
            return 0;
        }
    }

    var resolved_ptr: u64 = obj_name_ptr;
    var resolved_len: u64 = obj_name_len;
    var resolved: *NameInfo = resolve_name(slice(obj_name_ptr, obj_name_len));
    if (resolved != 0) {
        resolved_ptr = resolved.ptr;
        resolved_len = resolved.len;
    }

    var ginfo: *GlobalInfo = _cg_find_global_info(slice(resolved_ptr, resolved_len));
    if (ginfo == 0 && (resolved_ptr != obj_name_ptr || resolved_len != obj_name_len)) {
        ginfo = _cg_find_global_info(slice(obj_name_ptr, obj_name_len));
    }
    if (ginfo != 0) {
        var struct_def_g: *AstStructDef = 0;
        var gti: *TypeInfo = ginfo.typeinfo_ptr;
        if (gti != 0) {
            if (gti.ptr_depth == 0 && gti.type_kind == TYPE_SLICE) {
                if (emit_member_emit_global_slice_member(slice(resolved_ptr, resolved_len), slice(member.ptr, member.len)) != 0) {
                    return 0;
                }
                diag_emit_error_tag("codegen", "slice-member", "unknown slice member");
                diag_emit_labelled_name("member: ", slice(member.ptr, member.len));
                diag_force_stop_pass();
                return 0;
            }
            struct_def_g = emit_hydrate_struct_def_from_type(gti);
        }
        if (struct_def_g == 0) {
            emit("    ; ERROR: Struct definition not found in global lvalue\n");
            return 0;
        }
        emit("    lea rax, [rel _gvar_");
        emit_len(resolved_ptr, resolved_len);
        emit("]\n");
        emit_member_emit_struct_field_at_rax(struct_def_g, slice(parent.ptr, parent.len), slice(member.ptr, member.len), 1);
        return 0;
    }

    var var_offset: u64 = symtab_find(symtab, slice(obj_name_ptr, obj_name_len));
    var var_ti: *TypeInfo = symtab_get_type(symtab, slice(obj_name_ptr, obj_name_len));
    if (var_ti == 0 && var_offset == 0) {
        diag_emit_error_tag("codegen", "name-resolution", "undefined identifier");
        diag_emit_labelled_name("identifier: ", slice(obj_name_ptr, obj_name_len));
        diag_force_stop_pass();
        return 0;
    }
    if (var_ti == 0) {
        emit("    ; ERROR: Member access type not found in symtab\n");
        return 0;
    }
    if (var_offset == 0) {
        diag_emit_error_tag("codegen", "name-resolution", "identifier has no stack slot in current scope");
        diag_emit_labelled_name("identifier: ", slice(obj_name_ptr, obj_name_len));
        diag_force_stop_pass();
        return 0;
    }
    if (var_ti.ptr_depth == 0 && var_ti.type_kind == TYPE_SLICE) {
        if (emit_member_emit_local_slice_member(var_offset, slice(member.ptr, member.len)) != 0) {
            return 0;
        }
        diag_emit_error_tag("codegen", "slice-member", "unknown slice member");
        diag_emit_labelled_name("member: ", slice(member.ptr, member.len));
        diag_force_stop_pass();
        return 0;
    }
    if (var_ti.type_kind != TYPE_STRUCT) {
        diag_emit_error_tag("codegen", "member-access", "member access on non-struct identifier");
        diag_emit_labelled_name("identifier: ", slice(obj_name_ptr, obj_name_len));
        diag_force_stop_pass();
        return 0;
    }
    var struct_def: *AstStructDef = emit_hydrate_struct_def_from_type(var_ti);
    if (struct_def == 0) {
        emit("    ; ERROR: Struct definition not found in type_info\n");
        return 0;
    }

    emit("    lea rax, [rbp");
    emit_signed_disp(var_offset);
    emit("]\n");
    emit_member_emit_struct_field_at_rax(struct_def, slice(parent.ptr, parent.len), slice(member.ptr, member.len), 1);
    return 0;
}

func emit_member_access_expr(node: u64, symtab: *Symtab) -> u64 {
    var member_access: *AstMemberAccess = (*AstMemberAccess)node;
    if (emit_property_hook_emit_getter(member_access, symtab) != 0) { return 0; }
    var object: u64 = member_access.object;
    var member_ptr: u64 = member_access.member_ptr;
    var member_len: u64 = member_access.member_len;
    var parent_ptr: u64 = member_access.parent_ptr;
    var parent_len: u64 = member_access.parent_len;

    if (ast_kind(object) == AST_IDENT && parent_ptr == 0) {
        var scope_id: *AstIdent = (*AstIdent)object;
        var scope_local_ti: *TypeInfo = symtab_get_type(symtab, slice(scope_id.name_ptr, scope_id.name_len));
        var scope_global_ptr: u64 = scope_id.name_ptr;
        var scope_global_len: u64 = scope_id.name_len;
        var scope_resolved: *NameInfo = resolve_name(slice(scope_id.name_ptr, scope_id.name_len));
        if (scope_resolved != 0) {
            scope_global_ptr = scope_resolved.ptr;
            scope_global_len = scope_resolved.len;
        }
        var scope_global: *GlobalInfo = _cg_find_global_info(slice(scope_global_ptr, scope_global_len));
        if (scope_global == 0 && (scope_global_ptr != scope_id.name_ptr || scope_global_len != scope_id.name_len)) {
            scope_global = _cg_find_global_info(slice(scope_id.name_ptr, scope_id.name_len));
        }
        if (scope_local_ti == 0 && scope_global == 0) {
            var scoped_const: *ConstResult = (*ConstResult)sym_find_scoped_const(slice(scope_id.name_ptr, scope_id.name_len), slice(member_ptr, member_len));
            if (scoped_const != 0 && scoped_const.found != 0) {
                emit("    mov rax, ");
                emit_u64(scoped_const.value);
                emit_nl();
                return;
            }
        }
    }

    var ot: *TypeInfo = get_expr_type_with_symtab((*AstNode)object, symtab);
    if (ot != 0) {
        if (ot.ptr_depth > 0 && ot.is_tagged == 1 && ot.tag_layout_ptr != 0) {
            emit_member_expr_tagged_layout(object, ot, slice(member_ptr, member_len));
            return;
        }
        if (ot.ptr_depth > 0 && ot.type_kind == TYPE_STRUCT) {
            emit_member_expr_ptr_struct(object, ot, slice(parent_ptr, parent_len), slice(member_ptr, member_len));
            return;
        }
        if (ot.ptr_depth == 0 && ot.type_kind == TYPE_STRUCT && ot.struct_def != 0 && ot.struct_def.is_packed == 1) {
            emit_member_expr_packed_struct(object, ot.struct_def, slice(member_ptr, member_len));
            return;
        }
    }

    var obj_kind: u64 = ast_kind(object);
    if (obj_kind == AST_DEREF) {
        emit_member_expr_deref(object, symtab, slice(parent_ptr, parent_len), slice(member_ptr, member_len));
        return;
    }
    if (obj_kind == AST_MEMBER_ACCESS) {
        emit_member_expr_nested(object, symtab, slice(parent_ptr, parent_len), slice(member_ptr, member_len));
        return;
    }
    if (obj_kind == AST_INDEX) {
        emit_member_expr_indexed(object, symtab, slice(parent_ptr, parent_len), slice(member_ptr, member_len));
        return;
    }
    if (obj_kind == AST_IDENT) {
        emit_member_expr_ident(object, symtab, slice(parent_ptr, parent_len), slice(member_ptr, member_len));
        return;
    }

    emit("    ; ERROR: Member access on non-identifier\n");
}

// ============================================
// Binary Expression
// ============================================

func emit_binary_short_circuit_and(left: u64, right: u64) -> u64 {
    var l_false: u64 = new_label();
    var l_end: u64 = new_label();

    emit_expr(left);
    emit("    test rax, rax\n");
    emit("    jz ");
    emit_label(l_false);
    emit("\n");

    emit_expr(right);
    emit("    test rax, rax\n");
    emit("    setne al\n");
    emit("    movzx rax, al\n");
    emit("    jmp ");
    emit_label(l_end);
    emit("\n");

    emit_label_def(l_false);
    emit("    xor eax, eax\n");
    emit_label_def(l_end);
    return;
}

func emit_binary_short_circuit_or(left: u64, right: u64) -> u64 {
    var l_true: u64 = new_label();
    var l_end: u64 = new_label();

    emit_expr(left);
    emit("    test rax, rax\n");
    emit("    jnz ");
    emit_label(l_true);
    emit("\n");

    emit_expr(right);
    emit("    test rax, rax\n");
    emit("    setne al\n");
    emit("    movzx rax, al\n");
    emit("    jmp ");
    emit_label(l_end);
    emit("\n");

    emit_label_def(l_true);
    emit("    mov eax, 1\n");
    emit_label_def(l_end);
    return;
}

func emit_binary_emit_float_op(op: u64) -> u64 {
    if (op == TOKEN_PLUS) { emit("    addsd xmm0, xmm1\n"); }
    else if (op == TOKEN_MINUS) { emit("    subsd xmm0, xmm1\n"); }
    else if (op == TOKEN_STAR) { emit("    mulsd xmm0, xmm1\n"); }
    else if (op == TOKEN_SLASH) { emit("    divsd xmm0, xmm1\n"); }
    else if (op == TOKEN_LT || op == TOKEN_GT || op == TOKEN_LTEQ || op == TOKEN_GTEQ || op == TOKEN_EQEQ || op == TOKEN_BANGEQ) {
        emit("    ucomisd xmm0, xmm1\n");
        if (op == TOKEN_LT) { emit("    setb al\n"); }
        else if (op == TOKEN_GT) { emit("    seta al\n"); }
        else if (op == TOKEN_LTEQ) { emit("    setbe al\n"); }
        else if (op == TOKEN_GTEQ) { emit("    setae al\n"); }
        else if (op == TOKEN_EQEQ) { emit("    sete al\n"); }
        else if (op == TOKEN_BANGEQ) { emit("    setne al\n"); }
        emit("    movzx rax, al\n");
        return 1;
    } else {
        emit_stderr("[ERROR] Unsupported float operator\n");
        diag_force_stop_pass();
        return 0;
    }
    emit("    movq rax, xmm0\n");
    return 1;
}

func emit_binary_emit_int_op(op: u64, use_signed: u64) -> u64 {
    // Arithmetic operators
    if (op == TOKEN_PLUS) { emit("    add rax, rbx\n"); }
    else if (op == TOKEN_MINUS) { emit("    sub rax, rbx\n"); }
    else if (op == TOKEN_STAR) { emit("    imul rax, rbx\n"); }
    else if (op == TOKEN_SLASH) {
        if (use_signed == 1) {
            emit("    cqo\n");
            emit("    idiv rbx\n");
        } else {
            emit("    xor rdx, rdx\n");
            emit("    div rbx\n");
        }
    }
    else if (op == TOKEN_PERCENT) {
        if (use_signed == 1) {
            emit("    cqo\n");
            emit("    idiv rbx\n");
        } else {
            emit("    xor rdx, rdx\n");
            emit("    div rbx\n");
        }
        emit("    mov rax, rdx\n");
    }
    // Bitwise operators
    else if (op == TOKEN_CARET) { emit("    xor rax, rbx\n"); }
    else if (op == TOKEN_AMPERSAND) { emit("    and rax, rbx\n"); }
    else if (op == TOKEN_PIPE) { emit("    or rax, rbx\n"); }
    // Shift operators
    else if (op == TOKEN_LSHIFT) {
        emit("    mov rcx, rbx\n");
        emit("    shl rax, cl\n");
    }
    else if (op == TOKEN_RSHIFT) {
        emit("    mov rcx, rbx\n");
        if (use_signed == 1) { emit("    sar rax, cl\n"); }
        else { emit("    shr rax, cl\n"); }
    }
    // Comparison operators
    else if (op == TOKEN_LT) {
        emit("    cmp rax, rbx\n");
        if (use_signed == 1) { emit("    setl al\n"); }
        else { emit("    setb al\n"); }
        emit("    movzx rax, al\n");
    }
    else if (op == TOKEN_GT) {
        emit("    cmp rax, rbx\n");
        if (use_signed == 1) { emit("    setg al\n"); }
        else { emit("    seta al\n"); }
        emit("    movzx rax, al\n");
    }
    else if (op == TOKEN_LTEQ) {
        emit("    cmp rax, rbx\n");
        if (use_signed == 1) { emit("    setle al\n"); }
        else { emit("    setbe al\n"); }
        emit("    movzx rax, al\n");
    }
    else if (op == TOKEN_GTEQ) {
        emit("    cmp rax, rbx\n");
        if (use_signed == 1) { emit("    setge al\n"); }
        else { emit("    setae al\n"); }
        emit("    movzx rax, al\n");
    }
    else if (op == TOKEN_EQEQ) {
        emit("    cmp rax, rbx\n");
        emit("    sete al\n");
        emit("    movzx rax, al\n");
    }
    else if (op == TOKEN_BANGEQ) {
        emit("    cmp rax, rbx\n");
        emit("    setne al\n");
        emit("    movzx rax, al\n");
    }
    return;
}

func emit_binary_is_number_type(ti: *TypeInfo) -> u64 {
    if (ti == 0 || ti.ptr_depth != 0 || ti.type_kind != TYPE_STRUCT) { return 0; }
    if (ti.struct_name_ptr == 0 || ti.struct_name_len == 0) {
        if (ti.struct_def != 0) {
            ti.struct_name_ptr = ti.struct_def.name_ptr;
            ti.struct_name_len = ti.struct_def.name_len;
        }
    }
    if (ti.struct_name_ptr == 0 || ti.struct_name_len == 0) { return 0; }
    if (str_eq(slice(ti.struct_name_ptr, ti.struct_name_len), slice("Number", str_len("Number"))) != 0) { return 1; }
    if (str_eq(slice(ti.struct_name_ptr, ti.struct_name_len), slice("std_number__Number", str_len("std_number__Number"))) != 0) { return 1; }
    return 0;
}

func emit_binary_is_addressable(node: *AstNode) -> u64 {
    if (node == 0) { return 0; }
    var kind: u64 = ast_kind(node);
    if (kind == AST_IDENT || kind == AST_DEREF || kind == AST_DEREF8 || kind == AST_INDEX || kind == AST_MEMBER_ACCESS) {
        return 1;
    }
    return 0;
}

func emit_binary_is_integer_expr(node: *AstNode) -> u64 {
    if (node == 0) { return 0; }
    var kind: u64 = ast_kind(node);
    if (kind == AST_LITERAL) { return 1; }
    if (kind == AST_UNARY) {
        var un: *AstUnary = (*AstUnary)node;
        if (un.op == TOKEN_MINUS && un.operand != 0 && ast_kind(un.operand) == AST_LITERAL) {
            return 1;
        }
    }
    return 0;
}

func emit_method_name_is_non_number_result(method: []u8) -> u64 {
    if (method.ptr == 0 || method.len == 0) { return 0; }
    if (str_eq(slice(method.ptr, method.len), slice("to_i64_checked", str_len("to_i64_checked"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("to_u64_checked", str_len("to_u64_checked"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("to_i64_lossy", str_len("to_i64_lossy"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("to_str", str_len("to_str"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("cmp", str_len("cmp"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("cmp_i64", str_len("cmp_i64"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("eq", str_len("eq"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("eq_i64", str_len("eq_i64"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("eq_u64", str_len("eq_u64"))) != 0) { return 1; }
    return 0;
}

func emit_binary_expr_is_number(node: *AstNode, ti: *TypeInfo, symtab: *Symtab) -> u64 {
    if (node == 0) { return 0; }
    var kind: u64 = ast_kind(node);
    if (kind == AST_CALL && symtab != 0) {
        var ccall: *AstCall = (*AstCall)node;
        var callee_ti: *TypeInfo = symtab_get_type(symtab, slice(ccall.name_ptr, ccall.name_len));
        if (callee_ti == 0) {
            var resolved_callee: *NameInfo = resolve_name(slice(ccall.name_ptr, ccall.name_len));
            if (resolved_callee != 0) {
                callee_ti = symtab_get_type(symtab, slice(resolved_callee.ptr, resolved_callee.len));
            }
        }
        // Closure/function-handle calls are represented as primitive integers (u64 handle).
        // Never treat those call results as Number even if upstream inference is imprecise.
        if (callee_ti != 0 && callee_ti.ptr_depth == 0 && callee_ti.type_kind != TYPE_STRUCT) { return 0; }
    }
    if (kind == AST_METHOD_CALL || kind == AST_SAFE_METHOD_CALL) {
        var mc: *AstMethodCall = (*AstMethodCall)node;
        if (emit_method_name_is_non_number_result(slice(mc.method_ptr, mc.method_len)) != 0) { return 0; }
        if (emit_binary_expr_is_number(mc.receiver, 0, symtab) != 0) { return 1; }
    }
    if (emit_binary_is_number_type(ti) != 0) { return 1; }
    if (kind == AST_CAST) {
        var c: *AstCast = (*AstCast)node;
        return emit_binary_expr_is_number((*AstNode)c.expr, 0, symtab);
    }
    if (kind == AST_UNARY) {
        var un: *AstUnary = (*AstUnary)node;
        return emit_binary_expr_is_number(un.operand, 0, symtab);
    }
    if (kind == AST_BINARY) {
        var bin: *AstBinary = (*AstBinary)node;
        if (emit_binary_expr_is_number(bin.left, 0, symtab) != 0) { return 1; }
        if (emit_binary_expr_is_number(bin.right, 0, symtab) != 0) { return 1; }
        return 0;
    }
    if (kind == AST_IDENT && symtab != 0) {
        var idn: *AstIdent = (*AstIdent)node;
        var si: *TypeInfo = symtab_get_type(symtab, slice(idn.name_ptr, idn.name_len));
        if (si == 0) {
            var resolved_id: *NameInfo = resolve_name(slice(idn.name_ptr, idn.name_len));
            if (resolved_id != 0) {
                si = symtab_get_type(symtab, slice(resolved_id.ptr, resolved_id.len));
            }
        }
        if (si == 0 && idn.name_len > 2) {
            var tail_start: u64 = idn.name_len;
            for (var ti: u64 = 0; ti + 1 < idn.name_len; ti = ti + 1) {
                var c0: u8 = ((*u8)idn.name_ptr)[ti];
                var c1: u8 = ((*u8)idn.name_ptr)[ti + 1];
                if (c0 == 95 && c1 == 95) { tail_start = ti + 2; }
            }
            if (tail_start < idn.name_len) {
                si = symtab_get_type(symtab, slice(idn.name_ptr + tail_start, idn.name_len - tail_start));
            }
        }
        if (emit_binary_is_number_type(si) != 0) { return 1; }
    }
    if (kind == AST_CALL) {
        var c0: *AstCall = (*AstCall)node;
        var rp: u64 = c0.name_ptr;
        var rl: u64 = c0.name_len;
        var resolved: *NameInfo = resolve_name(slice(c0.name_ptr, c0.name_len));
        if (resolved != 0) {
            rp = resolved.ptr;
            rl = resolved.len;
        }
        if (str_eq(slice(rp, rl), slice("number_from_i64", str_len("number_from_i64"))) != 0 || str_eq(slice(rp, rl), slice("number_from_u64", str_len("number_from_u64"))) != 0 || str_eq(slice(rp, rl), slice("number_from_str", str_len("number_from_str"))) != 0) { return 1; }
        if (str_eq(slice(rp, rl), slice("std_number__number_from_i64", 26)) != 0 || str_eq(slice(rp, rl), slice("std_number__number_from_u64", 26)) != 0 || str_eq(slice(rp, rl), slice("std_number__number_from_str", 26)) != 0) { return 1; }
    }
    return 0;
}

func emit_binary_is_signed_integer_type(ti: *TypeInfo) -> u64 {
    if (ti == 0 || ti.ptr_depth != 0) { return 0; }
    if (ti.type_kind == TYPE_I8 || ti.type_kind == TYPE_I16 || ti.type_kind == TYPE_I32 || ti.type_kind == TYPE_I64) { return 1; }
    return 0;
}

func emit_binary_is_unsigned_integer_type(ti: *TypeInfo) -> u64 {
    if (ti == 0 || ti.ptr_depth != 0) { return 0; }
    if (ti.type_kind == TYPE_U8 || ti.type_kind == TYPE_U16 || ti.type_kind == TYPE_U32 || ti.type_kind == TYPE_U64 || ti.type_kind == TYPE_BOOL) { return 1; }
    return 0;
}

func emit_binary_emit_int_rax_normalize(ti: *TypeInfo) -> u64 {
    if (ti == 0 || ti.ptr_depth != 0) { return 0; }
    if (ti.type_kind == TYPE_I8) { emit("    movsx rax, al\n"); return 1; }
    if (ti.type_kind == TYPE_I16) { emit("    movsx rax, ax\n"); return 1; }
    if (ti.type_kind == TYPE_I32) { emit("    movsxd rax, eax\n"); return 1; }
    if (ti.type_kind == TYPE_U8 || ti.type_kind == TYPE_BOOL) { emit("    movzx eax, al\n"); return 1; }
    if (ti.type_kind == TYPE_U16) { emit("    movzx eax, ax\n"); return 1; }
    if (ti.type_kind == TYPE_U32) { emit("    mov eax, eax\n"); return 1; }
    if (ti.type_kind == TYPE_I64 || ti.type_kind == TYPE_U64) { return 1; }
    return 0;
}

func emit_binary_emit_number_from_rax(ti: *TypeInfo, node: *AstNode, symtab: *Symtab) -> u64 {
    if (emit_binary_expr_is_number(node, ti, symtab) != 0) { return 1; }
    if (node != 0 && ast_kind(node) == AST_IDENT) { return 1; }
    if (node != 0 && ti != 0 && ti.ptr_depth == 0 && emit_binary_is_integer_expr(node) == 0 &&
        (ti.type_kind == TYPE_I8 || ti.type_kind == TYPE_I16 || ti.type_kind == TYPE_I32 || ti.type_kind == TYPE_I64 ||
         ti.type_kind == TYPE_U8 || ti.type_kind == TYPE_U16 || ti.type_kind == TYPE_U32 || ti.type_kind == TYPE_U64 || ti.type_kind == TYPE_BOOL)) {
        return 1;
    }
    if (ti == 0) {
        _cg_emit_mov_user_arg_from_reg(0, 0, slice("rax", 3));
        _cg_emit_direct_call_name(slice("std_number__number_from_i64", str_len("std_number__number_from_i64")), 0, 0);
        return 1;
    }
    if (ti.ptr_depth != 0) {
        _cg_emit_mov_user_arg_from_reg(0, 0, slice("rax", 3));
        _cg_emit_direct_call_name(slice("std_number__number_from_u64", str_len("std_number__number_from_u64")), 0, 0);
        return 1;
    }
    if (emit_binary_is_signed_integer_type(ti) != 0) {
        emit_binary_emit_int_rax_normalize(ti);
        _cg_emit_mov_user_arg_from_reg(0, 0, slice("rax", 3));
        _cg_emit_direct_call_name(slice("std_number__number_from_i64", str_len("std_number__number_from_i64")), 0, 0);
        return 1;
    }
    if (emit_binary_is_unsigned_integer_type(ti) != 0) {
        emit_binary_emit_int_rax_normalize(ti);
        _cg_emit_mov_user_arg_from_reg(0, 0, slice("rax", 3));
        _cg_emit_direct_call_name(slice("std_number__number_from_u64", str_len("std_number__number_from_u64")), 0, 0);
        return 1;
    }
    _cg_emit_mov_user_arg_from_reg(0, 0, slice("rax", 3));
    _cg_emit_direct_call_name(slice("std_number__number_from_i64", str_len("std_number__number_from_i64")), 0, 0);
    return 1;
}

func emit_binary_is_number_box_op(op: u64) -> u64 {
    if (op == TOKEN_PLUS || op == TOKEN_MINUS || op == TOKEN_STAR || op == TOKEN_SLASH || op == TOKEN_PERCENT) { return 1; }
    if (op == TOKEN_AMPERSAND || op == TOKEN_PIPE || op == TOKEN_CARET) { return 1; }
    if (op == TOKEN_LSHIFT || op == TOKEN_RSHIFT) { return 1; }
    if (op == TOKEN_EQEQ || op == TOKEN_BANGEQ || op == TOKEN_LT || op == TOKEN_LTEQ || op == TOKEN_GT || op == TOKEN_GTEQ) { return 1; }
    return 0;
}

func emit_binary_emit_number_box_call(op: u64) -> u64 {
    emit("    sub rsp, 16\n");
    emit("    mov [rsp], rax\n");
    emit("    mov [rsp+8], rbx\n");
    _cg_emit_lea_user_arg_from_rsp(0, 0, 0);
    _cg_emit_lea_user_arg_from_rsp(1, 0, 8);

    if (op == TOKEN_PLUS) { _cg_emit_direct_call_name(slice("std_number__number_add_values", str_len("std_number__number_add_values")), 0, 2); emit("    add rsp, 16\n"); return 1; }
    if (op == TOKEN_MINUS) { _cg_emit_direct_call_name(slice("std_number__number_sub_values", str_len("std_number__number_sub_values")), 0, 2); emit("    add rsp, 16\n"); return 1; }
    if (op == TOKEN_STAR) { _cg_emit_direct_call_name(slice("std_number__number_mul_values", str_len("std_number__number_mul_values")), 0, 2); emit("    add rsp, 16\n"); return 1; }
    if (op == TOKEN_SLASH) { _cg_emit_direct_call_name(slice("std_number__number_div_values", str_len("std_number__number_div_values")), 0, 2); emit("    add rsp, 16\n"); return 1; }
    if (op == TOKEN_PERCENT) { _cg_emit_direct_call_name(slice("std_number__number_mod_values", str_len("std_number__number_mod_values")), 0, 2); emit("    add rsp, 16\n"); return 1; }
    if (op == TOKEN_AMPERSAND) { _cg_emit_direct_call_name(slice("std_number__number_bitand_values", str_len("std_number__number_bitand_values")), 0, 2); emit("    add rsp, 16\n"); return 1; }
    if (op == TOKEN_PIPE) { _cg_emit_direct_call_name(slice("std_number__number_bitor_values", str_len("std_number__number_bitor_values")), 0, 2); emit("    add rsp, 16\n"); return 1; }
    if (op == TOKEN_CARET) { _cg_emit_direct_call_name(slice("std_number__number_bitxor_values", str_len("std_number__number_bitxor_values")), 0, 2); emit("    add rsp, 16\n"); return 1; }
    if (op == TOKEN_LSHIFT || op == TOKEN_RSHIFT) {
        _cg_emit_lea_user_arg_from_rsp(0, 0, 8);
        _cg_emit_direct_call_name(slice("std_number__number_shift_amount_from_number", str_len("std_number__number_shift_amount_from_number")), 0, 2);
        _cg_emit_mov_user_arg_from_reg(1, 0, slice("rax", 3));
        _cg_emit_lea_user_arg_from_rsp(0, 0, 0);
        if (op == TOKEN_LSHIFT) { _cg_emit_direct_call_name(slice("std_number__number_shl_values", str_len("std_number__number_shl_values")), 0, 2); }
        else { _cg_emit_direct_call_name(slice("std_number__number_shr_values", str_len("std_number__number_shr_values")), 0, 2); }
        emit("    add rsp, 16\n");
        return 1;
    }
    if (op == TOKEN_EQEQ || op == TOKEN_BANGEQ || op == TOKEN_LT || op == TOKEN_LTEQ || op == TOKEN_GT || op == TOKEN_GTEQ) {
        _cg_emit_direct_call_name(slice("std_number__number_cmp_ptr", str_len("std_number__number_cmp_ptr")), 0, 2);
        emit("    add rsp, 16\n");
        return emit_binary_emit_cmp_from_i64(op, 0);
    }
    emit("    add rsp, 16\n");
    return 0;
}

func emit_binary_emit_number_box(binary: *AstBinary, left_ti: *TypeInfo, right_ti: *TypeInfo, symtab: *Symtab, op: u64) -> u64 {
    var left_is_number: u64 = emit_binary_expr_is_number(binary.left, left_ti, symtab);
    var right_is_number: u64 = emit_binary_expr_is_number(binary.right, right_ti, symtab);
    if (left_is_number == 0 && right_is_number == 0) { return 0; }
    if (emit_binary_is_number_box_op(op) == 0) { return 0; }

    emit_expr((u64)binary.left);
    if (emit_binary_emit_number_from_rax(left_ti, binary.left, symtab) == 0) { return 0; }
    emit("    push rax\n");

    emit_expr((u64)binary.right);
    if (emit_binary_emit_number_from_rax(right_ti, binary.right, symtab) == 0) { return 0; }
    emit("    mov rbx, rax\n");
    emit("    pop rax\n");

    return emit_binary_emit_number_box_call(op);
}

func emit_binary_emit_cmp_from_i64(op: u64, reversed: u64) -> u64 {
    emit("    cmp rax, 0\n");
    if (reversed == 0) {
        if (op == TOKEN_EQEQ) { emit("    sete al\n"); }
        else if (op == TOKEN_BANGEQ) { emit("    setne al\n"); }
        else if (op == TOKEN_LT) { emit("    setl al\n"); }
        else if (op == TOKEN_LTEQ) { emit("    setle al\n"); }
        else if (op == TOKEN_GT) { emit("    setg al\n"); }
        else if (op == TOKEN_GTEQ) { emit("    setge al\n"); }
        else { return 0; }
    } else {
        if (op == TOKEN_EQEQ) { emit("    sete al\n"); }
        else if (op == TOKEN_BANGEQ) { emit("    setne al\n"); }
        else if (op == TOKEN_LT) { emit("    setg al\n"); }
        else if (op == TOKEN_LTEQ) { emit("    setge al\n"); }
        else if (op == TOKEN_GT) { emit("    setl al\n"); }
        else if (op == TOKEN_GTEQ) { emit("    setle al\n"); }
        else { return 0; }
    }
    emit("    movzx rax, al\n");
    return 1;
}

func emit_binary_emit_number_cmp(binary: *AstBinary, left_ti: *TypeInfo, right_ti: *TypeInfo, symtab: *Symtab, op: u64) -> u64 {
    var left: *AstNode = binary.left;
    var right: *AstNode = binary.right;
    var left_is_number: u64 = emit_binary_expr_is_number(left, left_ti, symtab);
    var right_is_number: u64 = emit_binary_expr_is_number(right, right_ti, symtab);
    if (left_is_number == 0 && right_is_number == 0) { return 0; }

    if (left_is_number != 0 && right_is_number != 0 &&
        emit_binary_is_addressable(left) != 0 && emit_binary_is_addressable(right) != 0) {
        emit_lvalue((u64)left);
        emit("    push rax\n");
        emit_lvalue((u64)right);
        _cg_emit_mov_user_arg_from_reg(1, 0, slice("rax", 3));
        emit("    pop rax\n");
        _cg_emit_mov_user_arg_from_reg(0, 0, slice("rax", 3));
        _cg_emit_direct_call_name(slice("std_number__number_cmp_ptr", str_len("std_number__number_cmp_ptr")), 0, 0);
        return emit_binary_emit_cmp_from_i64(op, 0);
    }

    if (left_is_number != 0 && emit_binary_is_addressable(left) != 0 && emit_binary_is_integer_expr(right) != 0) {
        emit_lvalue((u64)left);
        emit("    push rax\n");
        emit_expr((u64)right);
        _cg_emit_mov_user_arg_from_reg(0, 0, slice("rax", 3));
        _cg_emit_direct_call_name(slice("std_number__number_from_i64", str_len("std_number__number_from_i64")), 0, 0);
        emit("    sub rsp, 8\n");
        emit("    mov [rsp], rax\n");
        _cg_emit_mov_user_arg_from_rsp(0, 0, 8);
        _cg_emit_lea_user_arg_from_rsp(1, 0, 0);
        _cg_emit_direct_call_name(slice("std_number__number_cmp_ptr", str_len("std_number__number_cmp_ptr")), 0, 2);
        emit("    add rsp, 16\n");
        return emit_binary_emit_cmp_from_i64(op, 0);
    }

    if (right_is_number != 0 && emit_binary_is_addressable(right) != 0 && emit_binary_is_integer_expr(left) != 0) {
        emit_lvalue((u64)right);
        emit("    push rax\n");
        emit_expr((u64)left);
        _cg_emit_mov_user_arg_from_reg(0, 0, slice("rax", 3));
        _cg_emit_direct_call_name(slice("std_number__number_from_i64", str_len("std_number__number_from_i64")), 0, 0);
        emit("    sub rsp, 8\n");
        emit("    mov [rsp], rax\n");
        _cg_emit_lea_user_arg_from_rsp(0, 0, 0);
        _cg_emit_mov_user_arg_from_rsp(1, 0, 8);
        _cg_emit_direct_call_name(slice("std_number__number_cmp_ptr", str_len("std_number__number_cmp_ptr")), 0, 2);
        emit("    add rsp, 16\n");
        return emit_binary_emit_cmp_from_i64(op, 0);
    }
    return emit_binary_emit_number_box(binary, left_ti, right_ti, symtab, op);
}

func emit_binary_emit_int_rax_to_f64(ti: *TypeInfo) -> u64 {
    if (ti != 0 && ti.ptr_depth == 0) {
        if (ti.type_kind == TYPE_I8) { emit("    movsx rax, al\n"); }
        else if (ti.type_kind == TYPE_I16) { emit("    movsx rax, ax\n"); }
        else if (ti.type_kind == TYPE_I32) { emit("    movsxd rax, eax\n"); }
        else if (ti.type_kind == TYPE_U8 || ti.type_kind == TYPE_BOOL) { emit("    movzx eax, al\n"); }
        else if (ti.type_kind == TYPE_U16) { emit("    movzx eax, ax\n"); }
        else if (ti.type_kind == TYPE_U32) { emit("    mov eax, eax\n"); }
    }
    emit("    cvtsi2sd xmm0, rax\n");
    return 0;
}

func emit_binary_emit_int_rbx_to_f64(ti: *TypeInfo) -> u64 {
    if (ti != 0 && ti.ptr_depth == 0) {
        if (ti.type_kind == TYPE_I8) { emit("    movsx rbx, bl\n"); }
        else if (ti.type_kind == TYPE_I16) { emit("    movsx rbx, bx\n"); }
        else if (ti.type_kind == TYPE_I32) { emit("    movsxd rbx, ebx\n"); }
        else if (ti.type_kind == TYPE_U8 || ti.type_kind == TYPE_BOOL) { emit("    movzx ebx, bl\n"); }
        else if (ti.type_kind == TYPE_U16) { emit("    movzx ebx, bx\n"); }
        else if (ti.type_kind == TYPE_U32) { emit("    mov ebx, ebx\n"); }
    }
    emit("    cvtsi2sd xmm1, rbx\n");
    return 0;
}

func emit_binary_expr(node: u64, symtab: *Symtab) -> u64 {
    var binary: *AstBinary = (*AstBinary)node;
    var op: u64 = binary.op;
    var left: u64 = binary.left;
    var right: u64 = binary.right;

    // Short-circuit evaluation for && and ||
    if (op == TOKEN_ANDAND) {
        emit_binary_short_circuit_and(left, right);
        return;
    }

    if (op == TOKEN_OROR) {
        emit_binary_short_circuit_or(left, right);
        return;
    }

    var left_ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)left, symtab);
    var right_ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)right, symtab);

    if (op == TOKEN_EQEQ || op == TOKEN_BANGEQ || op == TOKEN_LT || op == TOKEN_LTEQ || op == TOKEN_GT || op == TOKEN_GTEQ) {
        if (emit_binary_emit_number_cmp(binary, left_ti, right_ti, symtab, op) != 0) {
            return;
        }
    } else {
        if (emit_binary_emit_number_box(binary, left_ti, right_ti, symtab, op) != 0) {
            return;
        }
    }
    
    // Standard binary: evaluate both sides
    emit_expr(left);
    emit("    push rax\n");
    emit_expr(right);
    emit("    mov rbx, rax\n");
    emit("    pop rax\n");

    var l_is_f: u64 = 0;
    var r_is_f: u64 = 0;
    if (left_ti != 0) { l_is_f = (left_ti.ptr_depth == 0 && left_ti.type_kind == TYPE_F64); }
    if (right_ti != 0) { r_is_f = (right_ti.ptr_depth == 0 && right_ti.type_kind == TYPE_F64); }
    if (l_is_f != 0 || r_is_f != 0) {
        if (l_is_f == 0 && left_ti != 0 && left_ti.ptr_depth > 0) {
            emit_stderr("[ERROR] Float/integer binary operation does not support pointer operands\n");
            diag_force_stop_pass();
        return 0;
        }
        if (r_is_f == 0 && right_ti != 0 && right_ti.ptr_depth > 0) {
            emit_stderr("[ERROR] Float/integer binary operation does not support pointer operands\n");
            diag_force_stop_pass();
        return 0;
        }

        if (l_is_f != 0) { emit("    movq xmm0, rax\n"); }
        else { emit_binary_emit_int_rax_to_f64(left_ti); }

        if (r_is_f != 0) { emit("    movq xmm1, rbx\n"); }
        else { emit_binary_emit_int_rbx_to_f64(right_ti); }

        emit_binary_emit_float_op(op);
        return;
    }
    
    // Pointer arithmetic scaling
    var left_ti2: *TypeInfo = left_ti;
    if (left_ti2 == 0) { left_ti2 = typeinfo_make(TYPE_I64, 0); }
    var ptr_depth: u64 = left_ti2.ptr_depth;
    var use_signed: u64 = 0;
    if (left_ti2.ptr_depth == 0 &&
        (left_ti2.type_kind == TYPE_I8 || left_ti2.type_kind == TYPE_I16 ||
         left_ti2.type_kind == TYPE_I32 || left_ti2.type_kind == TYPE_I64)) {
        use_signed = 1;
    }
    
    if (ptr_depth > 0) {
        if (op == TOKEN_PLUS || op == TOKEN_MINUS) {
            var psize: u64 = get_pointee_size(left_ti2.type_kind, ptr_depth);
            if (psize > 1) {
                emit("    imul rbx, ");
                emit_u64(psize);
                emit_nl();
            }
        }
    }
    
    emit_binary_emit_int_op(op, use_signed);
}

// ============================================
// LValue Codegen
// ============================================

func emit_lvalue(node: u64) -> u64 {
    if (node == 0) {
        emit_stderr("[ERROR] codegen received null lvalue node\n");
        diag_force_stop_pass();
        emit("    xor eax, eax\n");
        return 0;
    }
    var kind: u64 = ast_kind(node);
    var symtab: *Symtab = symtab_current();
    
    if (kind == AST_IDENT) {
        var ident: *AstIdent = (*AstIdent)node;
        var name_ptr: u64 = ident.name_ptr;
        var name_len: u64 = ident.name_len;

        var resolved_ptr: u64 = name_ptr;
        var resolved_len: u64 = name_len;
        var resolved: *NameInfo = resolve_name(slice(name_ptr, name_len));
        if (resolved != 0) {
            resolved_ptr = resolved.ptr;
            resolved_len = resolved.len;
        }

        if (is_global_var(slice(resolved_ptr, resolved_len))) {
            emit("    lea rax, [rel _gvar_");
            emit_len(resolved_ptr, resolved_len);
            emit("]\n");
            return;
        }
        
        var offset: u64 = symtab_find(symtab, slice(name_ptr, name_len));
        if (offset == 0) {
            diag_emit_error_tag("codegen", "name-resolution", "undefined identifier");
            diag_emit_labelled_name("identifier: ", slice(name_ptr, name_len));
            diag_force_stop_pass();
            return;
        }
        
        emit("    lea rax, [rbp");
        emit_signed_disp(offset);
        emit("]\n");
        return;
    }

    if (kind == AST_CAST) {
        var cast_node: *AstCast = (*AstCast)node;
        emit_lvalue(cast_node.expr);
        return;
    }
    
    if (kind == AST_DEREF) {
        var deref: *AstDeref = (*AstDeref)node;
        var operand: u64 = deref.operand;
        emit_expr(operand);
        var ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)operand, symtab);
        if (ti != 0) {
            if (ti.ptr_depth > 0 && ti.is_tagged == 1) {
                emit_tagged_mask();
            }
        }
        return;
    }
    
    if (kind == AST_DEREF8) {
        var deref8: *AstDeref8 = (*AstDeref8)node;
        var operand: u64 = deref8.operand;
        emit_expr(operand);
        var ti2: *TypeInfo = get_expr_type_with_symtab((*AstNode)operand, symtab);
        if (ti2 != 0) {
            if (ti2.ptr_depth > 0 && ti2.is_tagged == 1) {
                emit_tagged_mask();
            }
        }
        return;
    }

    if (kind == AST_INDEX) {
        emit_index_addr(node, symtab);
        return;
    }

    if (kind == AST_SAFE_INDEX) {
        emit_stderr("[ERROR] Safe index access cannot be used as lvalue\n");
        return;
    }
    
    if (kind == AST_MEMBER_ACCESS) {
        emit_member_access_lvalue(node, symtab);
        return;
    }

    if (kind == AST_SAFE_MEMBER_ACCESS) {
        emit_stderr("[ERROR] Safe member access cannot be used as lvalue\n");
        return;
    }
}

// ============================================
// Member Access LValue
// ============================================

func emit_member_add_offset_to_rax(field_offset: u64) -> u64 {
    if (field_offset == 0) { return 0; }
    emit("    add rax, ");
    emit_u64(field_offset);
    emit("\n");
    return 0;
}

struct CgMemberFieldOffsetInfo {
    public found: u64;
    public offset: u64;
}

func emit_member_resolve_field_offset(struct_def: *AstStructDef, parent: []u8, member: []u8) -> CgMemberFieldOffsetInfo {
    var info: CgMemberFieldOffsetInfo;
    info.found = 0;
    info.offset = 0;
    if (struct_def == 0) { return info; }
    var field_offset: u64 = 0;
    var field_desc: *FieldDesc = 0;
    var found: u64 = struct_find_field_desc_scoped(struct_def, slice(parent.ptr, parent.len), slice(member.ptr, member.len), &field_offset, &field_desc);
    if (found == 0) { return info; }
    if (field_desc != 0 && check_field_access(field_desc) == 0) {
        emit_stderr("[ERROR] private field access denied: ");
        emit_stderr_len(struct_def.name_ptr, struct_def.name_len);
        emit_stderr(".");
        emit_stderr_len(member.ptr, member.len);
        emit_stderr("\n");
        diag_force_stop_pass();
        return info;
    }
    info.found = 1;
    info.offset = field_offset;
    return info;
}

func emit_member_lvalue_ptr_struct(object: u64, obj_ti: *TypeInfo, parent: []u8, member: []u8) -> u64 {
    emit_expr(object);
    if (obj_ti.is_tagged == 1) {
        emit_tagged_mask();
    }
    var struct_def_ptr: *AstStructDef = emit_hydrate_struct_def_from_type(obj_ti);
    if (struct_def_ptr == 0) {
        // Fallback for unresolved struct metadata: field-0 address equals object address.
        if (emit_member_is_bits_field(slice(member.ptr, member.len)) != 0) {
            return 1;
        }
        emit_stderr("[ERROR] Struct definition not found for pointer type in member lvalue\n");
        diag_force_stop_pass();
        return 0;
    }
    var field_info_ptr: CgMemberFieldOffsetInfo = emit_member_resolve_field_offset(struct_def_ptr, slice(parent.ptr, parent.len), slice(member.ptr, member.len));
    if (field_info_ptr.found == 0) { return 0; }
    var field_offset_ptr: u64 = field_info_ptr.offset;
    emit_member_add_offset_to_rax(field_offset_ptr);
    return 1;
}

func emit_member_lvalue_deref(object: u64, symtab: *Symtab, parent: []u8, member: []u8) -> u64 {
    var deref_obj: *AstDeref = (*AstDeref)object;
    var ptr_expr: u64 = deref_obj.operand;
    
    // Evaluate pointer expression to get pointer value
    emit_expr(ptr_expr);
    
    // Get pointer type to find struct_def
    var ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)ptr_expr, symtab);
    if (ti == 0) {
        emit("    ; ERROR: Cannot determine pointer type in arrow operator\n");
        return 1;
    }

    var base_type: u64 = ti.type_kind;
    var ptr_depth: u64 = ti.ptr_depth;
    if (ptr_depth > 0 && ti.is_tagged == 1) {
        emit_tagged_mask();
    }
    emit("    push rax\n");
    
    if (ptr_depth == 0 || base_type != TYPE_STRUCT) {
        emit("    ; ERROR: Arrow operator requires pointer to struct\n");
        return 1;
    }
    
    // Get struct_def from pointer's base type
    var struct_def: *AstStructDef = emit_hydrate_struct_def_from_type(ti);
    if (struct_def == 0) {
        if (emit_member_is_bits_field(slice(member.ptr, member.len)) != 0) {
            emit("    pop rax\n");
            return 1;
        }
        emit_stderr("[ERROR] Struct definition not found for pointer type in deref member lvalue\n");
        diag_force_stop_pass();
        return 1;
    }
    
    var field_info: CgMemberFieldOffsetInfo = emit_member_resolve_field_offset(struct_def, slice(parent.ptr, parent.len), slice(member.ptr, member.len));
    if (field_info.found == 0) { return 1; }
    var field_offset: u64 = field_info.offset;
    
    // Pop pointer value and add field offset
    emit("    pop rax\n");
    emit_member_add_offset_to_rax(field_offset);
    return 1;
}

func emit_member_lvalue_nested(object: u64, symtab: *Symtab, parent: []u8, member: []u8) -> u64 {
    // Recursively get the address of the nested object
    emit_lvalue(object);
    emit("    push rax\n");
    
    // Get the type of the nested object
    var obj_lv_ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)object, symtab);
    if (obj_lv_ti == 0) {
        emit("    ; ERROR: Cannot determine type of nested member in lvalue\n");
        return 1;
    }
    var base_type: u64 = obj_lv_ti.type_kind;
    if (base_type != TYPE_STRUCT) {
        emit("    ; ERROR: Nested member access on non-struct in lvalue\n");
        return 1;
    }
    
    var struct_def: *AstStructDef = emit_hydrate_struct_def_from_type(obj_lv_ti);
    if (struct_def == 0) {
        emit("    ; ERROR: Struct definition not found for nested lvalue\n");
        return 1;
    }
    
    var field_info2: CgMemberFieldOffsetInfo = emit_member_resolve_field_offset(struct_def, slice(parent.ptr, parent.len), slice(member.ptr, member.len));
    if (field_info2.found == 0) { return 1; }
    var field_offset: u64 = field_info2.offset;
    
    // Pop base address and add field offset
    emit("    pop rax\n");
    emit_member_add_offset_to_rax(field_offset);
    return 1;
}

func emit_member_lvalue_index(object: u64, symtab: *Symtab, parent: []u8, member: []u8) -> u64 {
    emit_lvalue(object);
    emit("    push rax\n");

    var idx_ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)object, symtab);
    if (idx_ti == 0) {
        emit("    ; ERROR: Cannot determine type of indexed member in lvalue\n");
        return 1;
    }
    if (idx_ti.type_kind != TYPE_STRUCT) {
        emit("    ; ERROR: Indexed member access on non-struct in lvalue\n");
        return 1;
    }
    var idx_struct_def: *AstStructDef = idx_ti.struct_def;
    if (idx_struct_def == 0) {
        emit("    ; ERROR: Struct definition not found for indexed lvalue\n");
        return 1;
    }

    var idx_field_info: CgMemberFieldOffsetInfo = emit_member_resolve_field_offset(idx_struct_def, slice(parent.ptr, parent.len), slice(member.ptr, member.len));
    if (idx_field_info.found == 0) { return 1; }
    var idx_field_offset: u64 = idx_field_info.offset;
    emit("    pop rax\n");
    emit_member_add_offset_to_rax(idx_field_offset);
    return 1;
}

func emit_member_lvalue_ident(object: u64, symtab: *Symtab, parent: []u8, member: []u8) -> u64 {
    var obj_ident: *AstIdent = (*AstIdent)object;
    var obj_name_ptr: u64 = obj_ident.name_ptr;
    var obj_name_len: u64 = obj_ident.name_len;

    // Module namespace member isn't assignable lvalue.
    var mod_scoped: *NameInfo = sym_resolve_module_scoped_symbol(slice(obj_name_ptr, obj_name_len), slice(member.ptr, member.len));
    if (mod_scoped != 0) {
        emit_stderr("[ERROR] assignment target is not an lvalue: ");
        emit_stderr_len(obj_name_ptr, obj_name_len);
        emit_stderr(".");
        emit_stderr_len(member.ptr, member.len);
        emit_stderr("\n");
        diag_force_stop_pass();
        return 0;
    }

    var resolved_ptr: u64 = obj_name_ptr;
    var resolved_len: u64 = obj_name_len;
    var resolved: *NameInfo = resolve_name(slice(obj_name_ptr, obj_name_len));
    if (resolved != 0) {
        resolved_ptr = resolved.ptr;
        resolved_len = resolved.len;
    }
    var ginfo: *GlobalInfo = _cg_find_global_info(slice(resolved_ptr, resolved_len));
    if (ginfo == 0 && (resolved_ptr != obj_name_ptr || resolved_len != obj_name_len)) {
        ginfo = _cg_find_global_info(slice(obj_name_ptr, obj_name_len));
    }
    if (ginfo != 0) {
        var struct_def_g: *AstStructDef = 0;
        var gti: *TypeInfo = ginfo.typeinfo_ptr;
        if (gti != 0) {
            if (gti.ptr_depth == 0 && gti.type_kind == TYPE_SLICE) {
                if (emit_member_emit_lvalue_global_slice_member(slice(resolved_ptr, resolved_len), slice(member.ptr, member.len)) != 0) {
                    return 1;
                }
                diag_emit_error_tag("codegen", "slice-member", "unknown slice member");
                diag_emit_labelled_name("member: ", slice(member.ptr, member.len));
                diag_force_stop_pass();
                return 0;
            }
            struct_def_g = emit_hydrate_struct_def_from_type(gti);
        }
        if (struct_def_g == 0) {
            emit_stderr("[ERROR] Struct definition not found in global lvalue: ");
            emit_stderr_len(resolved_ptr, resolved_len);
            emit_stderr(".");
            emit_stderr_len(member.ptr, member.len);
            emit_stderr("\n");
            diag_force_stop_pass();
            return 0;
        }
        var field_info_g: CgMemberFieldOffsetInfo = emit_member_resolve_field_offset(struct_def_g, slice(parent.ptr, parent.len), slice(member.ptr, member.len));
        if (field_info_g.found == 0) { return 0; }
        var field_offset_g: u64 = field_info_g.offset;
        emit("    lea rax, [rel _gvar_");
        emit_len(resolved_ptr, resolved_len);
        emit("]\n");
        emit_member_add_offset_to_rax(field_offset_g);
        return 1;
    }
    
    // Get variable info from symtab
    var var_offset: u64 = symtab_find(symtab, slice(obj_name_ptr, obj_name_len));
    var declared_type: *TypeInfo = symtab_get_type(symtab, slice(obj_name_ptr, obj_name_len));
    var var_type: *TypeInfo = declared_type;
    var inferred_type: *TypeInfo = get_expr_type_with_symtab((*AstNode)object, symtab);
    if (inferred_type != 0 && (var_offset != 0 || declared_type != 0)) {
        if (var_type == 0) {
            var_type = inferred_type;
        } else {
            if (var_type.type_kind != TYPE_STRUCT && inferred_type.type_kind == TYPE_STRUCT) {
                var_type = inferred_type;
            } else {
                if (var_type.struct_def == 0 && inferred_type.struct_def != 0) {
                    var_type.struct_def = inferred_type.struct_def;
                }
                if ((var_type.struct_name_ptr == 0 || var_type.struct_name_len == 0) &&
                    inferred_type.struct_name_ptr != 0 && inferred_type.struct_name_len != 0) {
                    var_type.struct_name_ptr = inferred_type.struct_name_ptr;
                    var_type.struct_name_len = inferred_type.struct_name_len;
                }
            }
        }
    }
    var struct_def_hint: *AstStructDef = emit_hydrate_struct_def_from_type(var_type);
    if (var_type == 0 && var_offset == 0) {
        diag_emit_error_tag("codegen", "name-resolution", "undefined identifier");
        diag_emit_labelled_name("identifier: ", slice(obj_name_ptr, obj_name_len));
        diag_force_stop_pass();
        return 0;
    }
    if (var_type == 0) {
        emit_stderr("[ERROR] Type info not found for lvalue: ");
        emit_stderr_len(obj_name_ptr, obj_name_len);
        emit_stderr(".");
        emit_stderr_len(member.ptr, member.len);
        emit_stderr("\n");
        diag_force_stop_pass();
        return 0;
    }
    if (var_offset == 0) {
        diag_emit_error_tag("codegen", "name-resolution", "identifier has no stack slot in current scope");
        diag_emit_labelled_name("identifier: ", slice(obj_name_ptr, obj_name_len));
        diag_force_stop_pass();
        return 0;
    }
    if (var_type.ptr_depth == 0 && var_type.type_kind == TYPE_SLICE) {
        if (emit_member_emit_lvalue_local_slice_member(var_offset, slice(member.ptr, member.len)) != 0) {
            return 1;
        }
        diag_emit_error_tag("codegen", "slice-member", "unknown slice member");
        diag_emit_labelled_name("member: ", slice(member.ptr, member.len));
        diag_force_stop_pass();
        return 0;
    }
    if (var_type.type_kind != TYPE_STRUCT) {
        diag_emit_error_tag("codegen", "member-access", "member assignment on non-struct identifier");
        diag_emit_labelled_name("identifier: ", slice(obj_name_ptr, obj_name_len));
        diag_force_stop_pass();
        return 0;
    }
    // Get struct_def directly from type_info
    var struct_def: *AstStructDef = 0;
    struct_def = struct_def_hint;
    
    if (struct_def == 0) {
        emit_stderr("[ERROR] Struct definition not found in lvalue: ");
        emit_stderr_len(obj_name_ptr, obj_name_len);
        emit_stderr(".");
        emit_stderr_len(member.ptr, member.len);
        emit_stderr("\n");
        diag_force_stop_pass();
        return 0;
    }
    
    var field_info3: CgMemberFieldOffsetInfo = emit_member_resolve_field_offset(struct_def, slice(parent.ptr, parent.len), slice(member.ptr, member.len));
    if (field_info3.found == 0) { return 0; }
    var field_offset: u64 = field_info3.offset;
    
    // Calculate address: lea rax, [rbp + var_offset + field_offset]
    emit("    lea rax, [rbp");
    var total_offset: u64 = var_offset + field_offset;
    emit_signed_disp(total_offset);
    emit("]\n");
    return 1;
}

func emit_member_access_lvalue(node: u64, symtab: *Symtab) -> u64 {
    var member_access: *AstMemberAccess = (*AstMemberAccess)node;
    var object: u64 = member_access.object;
    var member_ptr: u64 = member_access.member_ptr;
    var member_len: u64 = member_access.member_len;
    var parent_ptr: u64 = member_access.parent_ptr;
    var parent_len: u64 = member_access.parent_len;

    if (ast_kind(object) == AST_IDENT && parent_ptr == 0) {
        var scope_id2: *AstIdent = (*AstIdent)object;
        var scoped_const2: *ConstResult = (*ConstResult)sym_find_scoped_const(slice(scope_id2.name_ptr, scope_id2.name_len), slice(member_ptr, member_len));
        if (scoped_const2 != 0 && scoped_const2.found != 0) {
            diag_emit_error_tag("codegen", "const-assign", "Cannot assign to enum member constant");
            diag_emit_labelled_member("target: ", slice(scope_id2.name_ptr, scope_id2.name_len), slice(member_ptr, member_len));
            diag_force_stop_pass();
        return 0;
            return;
        }
    }

    var obj_ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)object, symtab);
    if (obj_ti != 0 && obj_ti.ptr_depth > 0 && obj_ti.type_kind == TYPE_STRUCT) {
        emit_member_lvalue_ptr_struct(object, obj_ti, slice(parent_ptr, parent_len), slice(member_ptr, member_len));
        return;
    }

    var obj_kind: u64 = ast_kind(object);

    if (obj_kind == AST_DEREF) {
        emit_member_lvalue_deref(object, symtab, slice(parent_ptr, parent_len), slice(member_ptr, member_len));
        return;
    }

    if (obj_kind == AST_MEMBER_ACCESS) {
        emit_member_lvalue_nested(object, symtab, slice(parent_ptr, parent_len), slice(member_ptr, member_len));
        return;
    }

    if (obj_kind == AST_INDEX) {
        emit_member_lvalue_index(object, symtab, slice(parent_ptr, parent_len), slice(member_ptr, member_len));
        return;
    }

    if (obj_kind == AST_IDENT) {
        emit_member_lvalue_ident(object, symtab, slice(parent_ptr, parent_len), slice(member_ptr, member_len));
        return;
    }

    emit("    ; ERROR: Member access on non-identifier in lvalue\n");
}

// ============================================
// Method Call Code Generation
// ============================================

func emit_method_push_user_args(args: *Vec<*AstNode>, nargs: u64, fn_sig: *AstFunc, param_base_index: u64, symtab: *Symtab) -> u64 {
    var total_arg_words: u64 = 0;
    if (nargs != 0) {
        var i: u64 = nargs;
        while (i > 0) {
            i = i - 1;
            var arg: *AstNode = args.get(i);
            var param: *Param = emit_call_param_at(fn_sig, param_base_index + i);
            total_arg_words = total_arg_words + emit_call_push_arg_with_param(arg, param, symtab);
        }
    }
    return total_arg_words;
}

func emit_method_push_receiver_from_tmp(tmp_offset: u64) -> u64 {
    emit("    mov rax, [rbp");
    emit_signed_disp(tmp_offset);
    emit("]\n");
    emit("    push rax\n");
    return 1;
}

func emit_method_receiver_is_addressable_expr_kind(kind: u64) -> u64 {
    if (kind == AST_IDENT) { return 1; }
    if (kind == AST_CAST) { return 1; }
    if (kind == AST_DEREF) { return 1; }
    if (kind == AST_DEREF8) { return 1; }
    if (kind == AST_INDEX) { return 1; }
    if (kind == AST_MEMBER_ACCESS) { return 1; }
    return 0;
}

func emit_method_push_receiver(receiver: u64, recv_ti: *TypeInfo, recv_is_ptr: u64, symtab: *Symtab) -> u64 {
    if (recv_is_ptr != 0) {
        emit_expr(receiver);
        if (recv_ti != 0 && recv_ti.is_tagged == 1) {
            emit_tagged_mask();
        }
        emit("    push rax\n");
        return 1;
    }

    var receiver_kind: u64 = ast_kind(receiver);
    if (emit_method_receiver_is_addressable_expr_kind(receiver_kind) != 0) {
        emit_lvalue(receiver);
        emit("    push rax\n");
        return 1;
    }

    var struct_size: u64 = 8;
    if (recv_ti != 0 && recv_ti.type_kind == TYPE_STRUCT && recv_ti.ptr_depth == 0) {
        struct_size = layout_type_sizeof(TYPE_STRUCT, 0, slice(recv_ti.struct_name_ptr, recv_ti.struct_name_len));
    }
    if (struct_size == 0) { struct_size = 8; }
    var tmp_offset: u64 = emit_alloc_tmp_struct(symtab, struct_size);

    if (receiver_kind == AST_STACK_CTOR) {
        emit_stack_ctor_init_to_offset((*AstStackCtor)receiver, tmp_offset, symtab);
    } else if (receiver_kind == AST_CALL && struct_size > 16) {
        emit_call_sret_to_offset(receiver, tmp_offset, symtab);
    } else if (receiver_kind == AST_METHOD_CALL && struct_size > 16) {
        emit_method_call_sret_to_offset((*AstMethodCall)receiver, tmp_offset, symtab);
    } else {
        emit_expr(receiver);
        if (struct_size <= 8) {
            emit("    mov [rbp");
            emit_signed_disp(tmp_offset);
            emit("], rax\n");
        } else if (struct_size <= 16) {
            emit("    mov [rbp");
            emit_signed_disp(tmp_offset);
            emit("], rax\n");
            emit("    mov [rbp");
            emit_signed_disp(tmp_offset + 8);
            emit("], rdx\n");
        } else {
            emit_stderr("[ERROR] non-addressable large struct receiver is unsupported\n");
            diag_force_stop_pass();
            return 0;
        }
    }

    emit("    lea rax, [rbp");
    emit_signed_disp(tmp_offset);
    emit("]\n");
    emit("    push rax\n");
    return 1;
}

func emit_find_trait_method_sig(trait_slice: []u8, method: []u8) -> *AstFunc {
    var trait_def: *TraitDef = sym_get_trait_def(slice(trait_slice.ptr, trait_slice.len));
    if (trait_def == 0 || trait_def.methods_vec == 0) { return 0; }
    var method_index: u64 = trait_find_trait_method_index(slice(trait_slice.ptr, trait_slice.len), slice(method.ptr, method.len));
    if (is_not_found_u64(method_index) != 0) { return 0; }
    if (method_index >= trait_def.methods_vec.len()) { return 0; }
    var method_desc: *TraitMethod = trait_def.methods_vec.get(method_index);
    if (method_desc == 0) { return 0; }
    return method_desc.sig;
}

func emit_method_try_normalize_named_args(method_call: *AstMethodCall, recv_ti: *TypeInfo) -> *AstFunc {
    if (method_call == 0) { return 0; }
    if (call_has_named_args(method_call.arg_names_vec) == 0) { return 0; }

    var args: *Vec<*AstNode> = method_call.args_vec;
    var nargs: u64 = 0;
    if (args != 0) { nargs = args.len(); }

    var fn_sig: *AstFunc = 0;
    if (recv_ti != 0 && (recv_ti.type_kind == TYPE_TRAIT || sym_is_trait_name(slice(recv_ti.struct_name_ptr, recv_ti.struct_name_len)) != 0)) {
        fn_sig = emit_find_trait_method_sig(slice(recv_ti.struct_name_ptr, recv_ti.struct_name_len), slice(method_call.method_ptr, method_call.method_len));
    } else if (recv_ti != 0 && recv_ti.type_kind == TYPE_STRUCT) {
        var owner_ptr: u64 = recv_ti.struct_name_ptr;
        var owner_len: u64 = recv_ti.struct_name_len;
        if ((owner_ptr == 0 || owner_len == 0) && recv_ti.struct_def != 0) {
            owner_ptr = recv_ti.struct_def.name_ptr;
            owner_len = recv_ti.struct_def.name_len;
        }
        if (owner_ptr != 0 && owner_len != 0) {
            var resolved: CompilerMethodResolveResult = sym_resolve_method_overload_with_count_fallback(slice(owner_ptr, owner_len), slice(method_call.method_ptr, method_call.method_len), 0, nargs);
            if (resolved.found != 0 && resolved.fn != 0) {
                fn_sig = resolved.fn;
            } else if (recv_ti.struct_def != 0) {
                fn_sig = find_method_func_in_hierarchy(recv_ti.struct_def, slice(method_call.method_ptr, method_call.method_len));
            }
        }
    }

    if (fn_sig == 0) {
        emit_stderr("[ERROR] named arguments require a known method signature: ");
        if (recv_ti != 0 && recv_ti.struct_name_ptr != 0 && recv_ti.struct_name_len != 0) {
            emit_stderr_len(recv_ti.struct_name_ptr, recv_ti.struct_name_len);
            emit_stderr(".");
        }
        emit_stderr_len(method_call.method_ptr, method_call.method_len);
        emit_stderr("\n");
        diag_force_stop_pass();
        return 0;
    }

    var params_start: u64 = sym_method_param_start_index(fn_sig);
    method_call.args_vec = lower_normalize_call_args_for_params(slice(method_call.method_ptr, method_call.method_len), fn_sig.params_vec, params_start, method_call.args_vec, method_call.arg_names_vec);
    method_call.arg_names_vec = 0;
    return fn_sig;
}

func emit_method_find_virtual_vptr_offset(recv_ti: *TypeInfo, trait_slice: []u8) -> u64 {
    if (recv_ti == 0) { return COMPILER_NOT_FOUND_U64; }
    var struct_def: *AstStructDef = recv_ti.struct_def;
    if (struct_def == 0) {
        struct_def = get_struct_def(slice(recv_ti.struct_name_ptr, recv_ti.struct_name_len));
    }
    if (struct_def == 0) { return COMPILER_NOT_FOUND_U64; }
    var vptr_name: *NameInfo = trait_build_vptr_field_name(slice(trait_slice.ptr, trait_slice.len));
    var field_offset: u64 = 0;
    var field_desc: *FieldDesc = 0;
    var found: u64 = struct_find_field_desc_scoped(struct_def, slice(0, 0), slice(vptr_name.ptr, vptr_name.len), &field_offset, &field_desc);
    if (found == 0) { return COMPILER_NOT_FOUND_U64; }
    return field_offset;
}

func emit_method_push_virtual_receiver(receiver: u64, recv_ti: *TypeInfo, trait_slice: []u8) -> u64 {
    var off: u64 = emit_method_find_virtual_vptr_offset(recv_ti, slice(trait_slice.ptr, trait_slice.len));
    if (is_not_found_u64(off) != 0) {
        emit_stderr("[ERROR] virtual dispatch vptr not found: ");
        emit_stderr_len(recv_ti.struct_name_ptr, recv_ti.struct_name_len);
        emit_stderr("\n");
        diag_force_stop_pass();
        return 0;
    }
    emit_expr(receiver);
    if (recv_ti != 0 && recv_ti.is_tagged == 1) {
        emit_tagged_mask();
    }
    if (off != 0) {
        emit("    add rax, ");
        emit_u64(off);
        emit_nl();
    }
    emit("    push rax\n");
    return 1;
}

func emit_method_push_virtual_receiver_from_tmp(tmp_offset: u64, recv_ti: *TypeInfo, trait_slice: []u8) -> u64 {
    var off: u64 = emit_method_find_virtual_vptr_offset(recv_ti, slice(trait_slice.ptr, trait_slice.len));
    if (is_not_found_u64(off) != 0) {
        emit_stderr("[ERROR] virtual dispatch vptr not found: ");
        emit_stderr_len(recv_ti.struct_name_ptr, recv_ti.struct_name_len);
        emit_stderr("\n");
        diag_force_stop_pass();
        return 0;
    }
    emit("    mov rax, [rbp");
    emit_signed_disp(tmp_offset);
    emit("]\n");
    if (off != 0) {
        emit("    add rax, ");
        emit_u64(off);
        emit_nl();
    }
    emit("    push rax\n");
    return 1;
}

func emit_method_stack_cleanup(stack_words: u64, reserve_words: u64) -> u64 {
    return _cg_target_call_cleanup(stack_words, reserve_words);
}

func emit_method_emit_trait_vtable_call(method_index: u64, stack_words: u64) -> u64 {
    emit("    mov rax, [");
    var recv_reg_name: u64 = compiler_target_user_arg_reg_name(0, 0);
    var recv_reg_len: u64 = compiler_target_user_arg_reg_name_len(0, 0);
    if (recv_reg_name != 0 && recv_reg_len != 0) {
        emit_len(recv_reg_name, recv_reg_len);
    }
    emit("]\n");
    if (method_index != 0) {
        emit("    add rax, ");
        emit_u64(method_index * 8);
        emit_nl();
    }
    emit("    mov rax, [rax]\n");
    var reserve_words: u64 = _cg_target_call_prepare(stack_words, 0);
    emit("    call rax\n");
    emit_method_stack_cleanup(stack_words, reserve_words);
    return 0;
}

func emit_method_emit_direct_call(resolved: []u8, stack_words: u64) -> u64 {
    var reserve_words: u64 = _cg_target_call_prepare(stack_words, 0);
    emit("    call ");
    emit_len(resolved.ptr, resolved.len);
    emit_nl();
    emit_method_stack_cleanup(stack_words, reserve_words);
    return 0;
}

func emit_method_prepare_safe_receiver(receiver: u64, recv_ti: *TypeInfo, label_null: u64, symtab: *Symtab, out_tmp_offset: *u64) -> u64 {
    emit_expr(receiver);
    if (recv_ti.is_tagged == 1) {
        emit_tagged_mask();
    }
    emit("    test rax, rax\n");
    emit("    je ");
    emit_label(label_null);
    emit_nl();

    var tmp_offset: u64 = emit_alloc_tmp_struct(symtab, 8);
    emit("    mov [rbp");
    emit_signed_disp(tmp_offset);
    emit("], rax\n");
    *out_tmp_offset = tmp_offset;
    return 0;
}

func emit_safe_method_call_trait_ptr(method_call: *AstMethodCall, recv_ti: *TypeInfo, args: *Vec<*AstNode>, nargs: u64, symtab: *Symtab) -> u64 {
    var receiver: u64 = method_call.receiver;
    var method_ptr: u64 = method_call.method_ptr;
    var method_len: u64 = method_call.method_len;
    var method_index: u64 = trait_find_trait_method_index(slice(recv_ti.struct_name_ptr, recv_ti.struct_name_len), slice(method_ptr, method_len));
    if (is_not_found_u64(method_index) != 0) {
        emit_stderr("[ERROR] Trait method not found: ");
        emit_stderr_len(method_ptr, method_len);
        emit_stderr("\n");
        return 0;
    }

    var label_null_t: u64 = new_label();
    var label_end_t: u64 = new_label();

    var tmp_offset_t: u64 = 0;
    emit_method_prepare_safe_receiver(receiver, recv_ti, label_null_t, symtab, &tmp_offset_t);

    var total_arg_words_t: u64 = emit_method_push_user_args(args, nargs, 0, 0, symtab);
    total_arg_words_t = total_arg_words_t + emit_method_push_receiver_from_tmp(tmp_offset_t);
    var stack_words_t: u64 = _cg_sysv_pop_arg_regs(total_arg_words_t);
    emit_method_emit_trait_vtable_call(method_index, stack_words_t);

    emit("    jmp ");
    emit_label(label_end_t);
    emit_nl();

    emit_label_def(label_null_t);
    emit("    xor eax, eax\n");
    emit_label_def(label_end_t);
    return 0;
}

func emit_safe_method_call_struct_ptr(method_call: *AstMethodCall, recv_ti: *TypeInfo, recv_mode: u64, args: *Vec<*AstNode>, nargs: u64, symtab: *Symtab) -> u64 {
    var receiver: u64 = method_call.receiver;
    var method_ptr: u64 = method_call.method_ptr;
    var method_len: u64 = method_call.method_len;
    var arg_types: *Vec<*TypeInfo> = typeinfo_collect_arg_types(args, symtab);
    if (recv_mode == COMPILER_SAFE_RECV_INVALID) {
        if (recv_ti.ptr_depth == 0) {
            emit_stderr("[ERROR] Safe method call requires pointer receiver\n");
            return 0;
        }
        emit_stderr("[ERROR] Safe method call requires struct pointer\n");
        return 0;
    }

    if (check_method_access_overload(slice(recv_ti.struct_name_ptr, recv_ti.struct_name_len), slice(method_ptr, method_len), arg_types, nargs) == 0) {
        emit_stderr("[ERROR] private method access denied: ");
        emit_stderr_len(recv_ti.struct_name_ptr, recv_ti.struct_name_len);
        emit_stderr(".");
        emit_stderr_len(method_ptr, method_len);
        emit_stderr("\n");
        return 0;
    }

    var virt_trait: *NameInfo = 0;
    if (recv_ti.ptr_depth > 0) {
        virt_trait = vdispatch_find_trait(slice(recv_ti.struct_name_ptr, recv_ti.struct_name_len), slice(method_ptr, method_len));
    }
    if (virt_trait != 0) {
        var method_index_v: u64 = trait_find_trait_method_index(slice(virt_trait.ptr, virt_trait.len), slice(method_ptr, method_len));
        if (is_not_found_u64(method_index_v) != 0) {
            emit_stderr("[ERROR] Virtual method not found: ");
            emit_stderr_len(method_ptr, method_len);
            emit_stderr("\n");
            return 0;
        }

        var label_null_v: u64 = new_label();
        var label_end_v: u64 = new_label();
        var tmp_offset_v: u64 = 0;
        emit_method_prepare_safe_receiver(receiver, recv_ti, label_null_v, symtab, &tmp_offset_v);

        var total_arg_words_v: u64 = emit_method_push_user_args(args, nargs, 0, 0, symtab);
        total_arg_words_v = total_arg_words_v + emit_method_push_virtual_receiver_from_tmp(tmp_offset_v, recv_ti, slice(virt_trait.ptr, virt_trait.len));
        var stack_words_v: u64 = _cg_sysv_pop_arg_regs(total_arg_words_v);
        emit_method_emit_trait_vtable_call(method_index_v, stack_words_v);

        emit("    jmp ");
        emit_label(label_end_v);
        emit_nl();

        emit_label_def(label_null_v);
        emit("    xor eax, eax\n");
        emit_label_def(label_end_v);
        return 0;
    }

    var resolved_ptr: u64 = 0;
    var resolved_len: u64 = 0;
    var resolved_method: CompilerMethodResolveResult = sym_resolve_method_overload(slice(recv_ti.struct_name_ptr, recv_ti.struct_name_len), slice(method_ptr, method_len), arg_types, nargs);
    var fn: *AstFunc = 0;
    if (resolved_method.found != 0 && resolved_method.fn != 0) {
        fn = resolved_method.fn;
        resolved_ptr = fn.name_ptr;
        resolved_len = fn.name_len;
    }
    if (fn == 0 && recv_ti.struct_def != 0) {
        fn = find_method_func_in_hierarchy(recv_ti.struct_def, slice(method_ptr, method_len));
        if (fn != 0) {
            resolved_ptr = fn.name_ptr;
            resolved_len = fn.name_len;
        }
    }
    if (fn == 0) {
        var name_info: *NameInfo = build_method_name(slice(recv_ti.struct_name_ptr, recv_ti.struct_name_len), slice(method_ptr, method_len));
        resolved_ptr = name_info.ptr;
        resolved_len = name_info.len;
        var resolved: *NameInfo = resolve_name(slice(name_info.ptr, name_info.len));
        if (resolved != 0) {
            resolved_ptr = resolved.ptr;
            resolved_len = resolved.len;
        }
        fn = typeinfo_find_func(slice(resolved_ptr, resolved_len));
        if (fn == 0) {
            fn = typeinfo_find_func(slice(name_info.ptr, name_info.len));
        }
    }
    var ret_type: u64 = TYPE_I64;
    var ret_ptr_depth: u64 = 0;
    if (fn != 0) {
        ret_type = fn.ret_type;
        ret_ptr_depth = fn.ret_ptr_depth;
        if (ret_type == TYPE_STRUCT && ret_ptr_depth == 0) {
            emit_stderr("[ERROR] Safe method call cannot return struct by value\n");
            return 0;
        }
    }

    var label_null: u64 = new_label();
    var label_end: u64 = new_label();

    var tmp_offset: u64 = 0;
    emit_method_prepare_safe_receiver(receiver, recv_ti, label_null, symtab, &tmp_offset);

    var total_arg_words: u64 = emit_method_push_user_args(args, nargs, fn, 1, symtab);
    total_arg_words = total_arg_words + emit_method_push_receiver_from_tmp(tmp_offset);
    var resolved_call_safe: *NameInfo = resolve_name(slice(resolved_ptr, resolved_len));
    if (resolved_call_safe != 0) {
        resolved_ptr = resolved_call_safe.ptr;
        resolved_len = resolved_call_safe.len;
    }
    var stack_words: u64 = _cg_sysv_pop_arg_regs(total_arg_words);
    emit_method_emit_direct_call(slice(resolved_ptr, resolved_len), stack_words);

    emit("    jmp ");
    emit_label(label_end);
    emit_nl();

    emit_label_def(label_null);
    if (ret_type != TYPE_VOID) {
        emit("    xor eax, eax\n");
    }
    emit_label_def(label_end);
    return 0;
}

func emit_safe_method_call(node: u64, symtab: *Symtab) -> u64 {
    var method_call: *AstMethodCall = (*AstMethodCall)node;
    var receiver: u64 = method_call.receiver;

    var recv_ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)receiver, symtab);
    if (recv_ti == 0) {
        emit_stderr("[ERROR] Safe method call receiver type not found\n");
        return 0;
    }
    emit_method_try_normalize_named_args(method_call, recv_ti);

    var args: *Vec<*AstNode> = method_call.args_vec;
    var nargs: u64 = 0;
    if (args != 0) { nargs = args.len(); }

    var recv_mode: u64 = safe_receiver_mode(recv_ti);
    if (recv_mode == COMPILER_SAFE_RECV_TRAIT_PTR) {
        return emit_safe_method_call_trait_ptr(method_call, recv_ti, args, nargs, symtab);
    }
    return emit_safe_method_call_struct_ptr(method_call, recv_ti, recv_mode, args, nargs, symtab);
}

func emit_method_call(node: u64, symtab: *Symtab) -> u64 {
    var method_call: *AstMethodCall = (*AstMethodCall)node;
    var receiver: u64 = method_call.receiver;
    var method_ptr: u64 = method_call.method_ptr;
    var method_len: u64 = method_call.method_len;

    var recv_ti: *TypeInfo = get_expr_type_with_symtab((*AstNode)receiver, symtab);
    emit_method_try_normalize_named_args(method_call, recv_ti);

    var args: *Vec<*AstNode> = method_call.args_vec;
    var nargs: u64 = 0;
    if (args != 0) { nargs = args.len(); }
    var arg_types: *Vec<*TypeInfo> = typeinfo_collect_arg_types(args, symtab);
    var total_arg_words: u64 = 0;

    var recv_is_ptr: u64 = 0;
    if (recv_ti != 0 && recv_ti.ptr_depth > 0) {
        recv_is_ptr = 1;
    }

    if (recv_ti != 0 && (recv_ti.type_kind == TYPE_TRAIT || sym_is_trait_name(slice(recv_ti.struct_name_ptr, recv_ti.struct_name_len)) != 0)) {
        var method_index: u64 = trait_find_trait_method_index(slice(recv_ti.struct_name_ptr, recv_ti.struct_name_len), slice(method_ptr, method_len));
        if (is_not_found_u64(method_index) != 0) {
            emit_stderr("[ERROR] Trait method not found: ");
            emit_stderr_len(method_ptr, method_len);
            emit_stderr("\n");
            diag_force_stop_pass();
        return 0;
        }

        total_arg_words = emit_method_push_user_args(args, nargs, 0, 0, symtab);
        total_arg_words = total_arg_words + emit_method_push_receiver(receiver, recv_ti, 1, symtab);
        var stack_words_t2: u64 = _cg_sysv_pop_arg_regs(total_arg_words);
        emit_method_emit_trait_vtable_call(method_index, stack_words_t2);
        return 0;
    }

    if (recv_ti != 0 && recv_ti.type_kind == TYPE_STRUCT) {
        if (check_method_access_overload(slice(recv_ti.struct_name_ptr, recv_ti.struct_name_len), slice(method_ptr, method_len), arg_types, nargs) == 0) {
            emit_stderr("[ERROR] private method access denied: ");
            emit_stderr_len(recv_ti.struct_name_ptr, recv_ti.struct_name_len);
            emit_stderr(".");
            emit_stderr_len(method_ptr, method_len);
            emit_stderr("\n");
            diag_force_stop_pass();
        return 0;
        }

        if (recv_ti.ptr_depth > 0) {
            var virt_trait: *NameInfo = vdispatch_find_trait(slice(recv_ti.struct_name_ptr, recv_ti.struct_name_len), slice(method_ptr, method_len));
            if (virt_trait != 0) {
                var method_index_v: u64 = trait_find_trait_method_index(slice(virt_trait.ptr, virt_trait.len), slice(method_ptr, method_len));
                if (is_not_found_u64(method_index_v) != 0) {
                    emit_stderr("[ERROR] Virtual method not found: ");
                    emit_stderr_len(method_ptr, method_len);
                    emit_stderr("\n");
                    diag_force_stop_pass();
        return 0;
                }
                total_arg_words = emit_method_push_user_args(args, nargs, 0, 0, symtab);
                total_arg_words = total_arg_words + emit_method_push_virtual_receiver(receiver, recv_ti, slice(virt_trait.ptr, virt_trait.len));
                var stack_words_v: u64 = _cg_sysv_pop_arg_regs(total_arg_words);
                emit_method_emit_trait_vtable_call(method_index_v, stack_words_v);
                return 0;
            }
        }
    }

    // Get receiver type to determine struct name
    var type_info: *TypeInfo = recv_ti;
    if (type_info == 0 || type_info.struct_name_ptr == 0 || type_info.struct_name_len == 0) {
        if (ast_kind(receiver) == AST_IDENT) {
            var rid: *AstIdent = (*AstIdent)receiver;
            var ti_alt: *TypeInfo = symtab_get_type(symtab, slice(rid.name_ptr, rid.name_len));
            if (ti_alt != 0) { type_info = ti_alt; }
        }
    }
    if (type_info != 0 && type_info.type_kind == TYPE_STRUCT) {
        var hydrated: *AstStructDef = emit_hydrate_struct_def_from_type(type_info);
        if (hydrated != 0) {
            type_info.struct_name_ptr = hydrated.name_ptr;
            type_info.struct_name_len = hydrated.name_len;
            type_info.struct_def = hydrated;
        }
    }

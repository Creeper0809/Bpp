// compiler_symbol_runtime.b - Symbol tables, resolution, traits/generics runtime helpers

import compiler;
import compiler.trait_runtime;
import compiler.core_utils;
import compiler.generic.engine;
import compiler.generic.core;
import compiler.call_utils;
import std.io;
import std.str;
import std.vec;
import std.hashmap;
import ast;
import types;
import module_utils;

func module_exports_get(module_ptr: u64, module_len: u64) -> *Vec<*ExportEntry> {
    if (g_compiler_ctx.module_exports == 0) { return 0; }
    return g_compiler_ctx.module_exports.get(module_ptr, module_len);
}

func module_export_map_get(module_ptr: u64, module_len: u64) -> *HashMap<u64, *NameInfo> {
    if (g_compiler_ctx.module_export_maps == 0) { return 0; }
    return g_compiler_ctx.module_export_maps.get(module_ptr, module_len);
}

func module_export_map_ensure(module_ptr: u64, module_len: u64) -> *HashMap<u64, *NameInfo> {
    if (g_compiler_ctx.module_export_maps == 0) {
        g_compiler_ctx.module_export_maps = new HashMap<u64, *HashMap<u64, *NameInfo>>{0, 0, 0};
        g_compiler_ctx.module_export_maps.ensure_capacity(64);
    }
    var existing: *HashMap<u64, *NameInfo> = g_compiler_ctx.module_export_maps.get(module_ptr, module_len);
    if (existing != 0) { return existing; }
    var map: *HashMap<u64, *NameInfo> = new HashMap<u64, *NameInfo>{0, 0, 0};
    map.ensure_capacity(128);
    g_compiler_ctx.module_export_maps.put(module_ptr, module_len, map);
    return map;
}

func module_exports_ensure(module_ptr: u64, module_len: u64) -> *Vec<*ExportEntry> {
    if (g_compiler_ctx.module_exports == 0) {
        g_compiler_ctx.module_exports = new HashMap<u64, *Vec<*ExportEntry>>{0, 0, 0};
        g_compiler_ctx.module_exports.ensure_capacity(64);
    }
    var existing: *Vec<*ExportEntry> = g_compiler_ctx.module_exports.get(module_ptr, module_len);
    if (existing != 0) { return existing; }
    var vec: *Vec<*ExportEntry> = new Vec<*ExportEntry>{heap_alloc((32) * sizeof(*ExportEntry)), 0, (32)};
    g_compiler_ctx.module_exports.put(module_ptr, module_len, vec);
    return vec;
}

func add_module_export(module_ptr: u64, module_len: u64, name_ptr: u64, name_len: u64, mangled_ptr: u64, mangled_len: u64) -> u64 {
    var exports: *Vec<*ExportEntry> = module_exports_ensure(module_ptr, module_len);
    var entry: *ExportEntry = new ExportEntry{name_ptr, name_len, mangled_ptr, mangled_len};
    exports.push(entry);
    var export_map: *HashMap<u64, *NameInfo> = module_export_map_ensure(module_ptr, module_len);
    if (export_map.has(name_ptr, name_len) == 0) {
        var info: *NameInfo = new NameInfo{mangled_ptr, mangled_len};
        export_map.put(name_ptr, name_len, info);
    }
    sym_invalidate_resolve_name_cache();
    return 0;
}

func module_aliases_get(module_ptr: u64, module_len: u64) -> *HashMap<u64, *NameInfo> {
    if (g_compiler_ctx.module_aliases == 0) { return 0; }
    return g_compiler_ctx.module_aliases.get(module_ptr, module_len);
}

func module_aliases_ensure(module_ptr: u64, module_len: u64) -> *HashMap<u64, *NameInfo> {
    if (g_compiler_ctx.module_aliases == 0) {
        g_compiler_ctx.module_aliases = new HashMap<u64, *HashMap<u64, *NameInfo>>{0, 0, 0};
        g_compiler_ctx.module_aliases.ensure_capacity(128);
    }
    var existing: *HashMap<u64, *NameInfo> = g_compiler_ctx.module_aliases.get(module_ptr, module_len);
    if (existing != 0) { return existing; }
    var map: *HashMap<u64, *NameInfo> = new HashMap<u64, *NameInfo>{0, 0, 0};
    map.ensure_capacity(128);
    g_compiler_ctx.module_aliases.put(module_ptr, module_len, map);
    return map;
}

func module_namespaces_get(module_ptr: u64, module_len: u64) -> *HashMap<u64, *NameInfo> {
    if (g_compiler_ctx.module_namespaces == 0) { return 0; }
    return g_compiler_ctx.module_namespaces.get(module_ptr, module_len);
}

func module_namespaces_ensure(module_ptr: u64, module_len: u64) -> *HashMap<u64, *NameInfo> {
    if (g_compiler_ctx.module_namespaces == 0) {
        g_compiler_ctx.module_namespaces = new HashMap<u64, *HashMap<u64, *NameInfo>>{0, 0, 0};
        g_compiler_ctx.module_namespaces.ensure_capacity(128);
    }
    var existing: *HashMap<u64, *NameInfo> = g_compiler_ctx.module_namespaces.get(module_ptr, module_len);
    if (existing != 0) { return existing; }
    var map: *HashMap<u64, *NameInfo> = new HashMap<u64, *NameInfo>{0, 0, 0};
    map.ensure_capacity(64);
    g_compiler_ctx.module_namespaces.put(module_ptr, module_len, map);
    return map;
}

func add_module_namespace_alias(importer_ptr: u64, importer_len: u64, alias_ptr: u64, alias_len: u64, module_ptr: u64, module_len: u64) -> u64 {
    if (alias_ptr == 0 || alias_len == 0 || module_ptr == 0 || module_len == 0) { return 0; }
    var map: *HashMap<u64, *NameInfo> = module_namespaces_ensure(importer_ptr, importer_len);
    var existing: *NameInfo = map.get(alias_ptr, alias_len);
    if (existing != 0) {
        if (existing.ptr == module_ptr && existing.len == module_len) { return 0; }
        emit_stderr("[ERROR] module namespace alias conflict: ");
        emit_stderr_len(alias_ptr, alias_len);
        emit_stderr_nl();
        diag_error("Compilation failed");
        return 0;
    }
    map.put(alias_ptr, alias_len, new NameInfo{module_ptr, module_len});
    sym_invalidate_resolve_name_cache();
    return 0;
}

func resolve_module_namespace_alias(importer_ptr: u64, importer_len: u64, alias_ptr: u64, alias_len: u64) -> *NameInfo {
    var map: *HashMap<u64, *NameInfo> = module_namespaces_get(importer_ptr, importer_len);
    if (map == 0) { return 0; }
    return map.get(alias_ptr, alias_len);
}

func sym_resolve_module_scoped_symbol(scope_ptr: u64, scope_len: u64, member_ptr: u64, member_len: u64) -> *NameInfo {
    if (scope_ptr == 0 || scope_len == 0 || member_ptr == 0 || member_len == 0) { return 0; }
    if (g_compiler_ctx.current_module_ptr == 0 || g_compiler_ctx.current_module_len == 0) { return 0; }

    var mod_info: *NameInfo = resolve_module_namespace_alias(g_compiler_ctx.current_module_ptr, g_compiler_ctx.current_module_len, scope_ptr, scope_len);
    if (mod_info == 0) { return 0; }

    var export_map: *HashMap<u64, *NameInfo> = module_export_map_get(mod_info.ptr, mod_info.len);
    if (export_map != 0) {
        var mapped: *NameInfo = export_map.get(member_ptr, member_len);
        if (mapped != 0) { return mapped; }
        return 0;
    }

    var exports: *Vec<*ExportEntry> = module_exports_get(mod_info.ptr, mod_info.len);
    if (exports == 0) { return 0; }
    var n: u64 = exports.len();
    for (var i: u64 = 0; i < n; i++) {
        var e: *ExportEntry = exports.get(i);
        if (e == 0) { continue; }
        if (str_eq(e.name_ptr, e.name_len, member_ptr, member_len) == 0) { continue; }
        return new NameInfo{e.mangled_ptr, e.mangled_len};
    }
    return 0;
}

func add_import_alias(module_ptr: u64, module_len: u64, alias_ptr: u64, alias_len: u64, mangled_ptr: u64, mangled_len: u64) -> u64 {
    var alias_map: *HashMap<u64, *NameInfo> = module_aliases_ensure(module_ptr, module_len);
    var existing: *NameInfo = alias_map.get(alias_ptr, alias_len);
    if (existing != 0) {
        var ex_ptr: u64 = existing.ptr;
        var ex_len: u64 = existing.len;
        if (ex_ptr == mangled_ptr && ex_len == mangled_len) {
            return 0;
        }
        emit_stderr("[ERROR] import alias conflict: ");
        emit_stderr_len(alias_ptr, alias_len);
        emit_stderr_nl();
        diag_error("Compilation failed");
        return 0;
    }
    var info: *NameInfo = new NameInfo{mangled_ptr, mangled_len};
    alias_map.put(alias_ptr, alias_len, info);
    sym_invalidate_resolve_name_cache();
    return 0;
}

// Best-effort alias insert used by `import <module>;`.
// If alias already exists with different target, skip instead of hard-failing.
func add_import_alias_if_absent(module_ptr: u64, module_len: u64, alias_ptr: u64, alias_len: u64, mangled_ptr: u64, mangled_len: u64) -> u64 {
    var alias_map: *HashMap<u64, *NameInfo> = module_aliases_ensure(module_ptr, module_len);
    var existing: *NameInfo = alias_map.get(alias_ptr, alias_len);
    if (existing != 0) {
        if (existing.ptr == mangled_ptr && existing.len == mangled_len) { return 1; }
        return 0;
    }
    alias_map.put(alias_ptr, alias_len, new NameInfo{mangled_ptr, mangled_len});
    sym_invalidate_resolve_name_cache();
    return 1;
}

func add_prelude_alias(alias_ptr: u64, alias_len: u64, mangled_ptr: u64, mangled_len: u64) -> u64 {
    if (g_compiler_ctx.prelude_aliases == 0) {
        g_compiler_ctx.prelude_aliases = new HashMap<u64, *NameInfo>{0, 0, 0};
        g_compiler_ctx.prelude_aliases.ensure_capacity(128);
    }
    var existing: *NameInfo = g_compiler_ctx.prelude_aliases.get(alias_ptr, alias_len);
    if (existing != 0) {
        var ex_ptr: u64 = existing.ptr;
        var ex_len: u64 = existing.len;
        if (ex_ptr == mangled_ptr && ex_len == mangled_len) {
            return 0;
        }
        emit_stderr("[ERROR] prelude alias conflict: ");
        emit_stderr_len(alias_ptr, alias_len);
        emit_stderr_nl();
        diag_error("Compilation failed");
        return 0;
    }
    var info: *NameInfo = new NameInfo{mangled_ptr, mangled_len};
    g_compiler_ctx.prelude_aliases.put(alias_ptr, alias_len, info);
    // Clear any previous negative-cache mark for this symbol.
    if (g_compiler_ctx.prelude_miss_cache != 0) {
        g_compiler_ctx.prelude_miss_cache.put(alias_ptr, alias_len, 0);
    }
    sym_invalidate_resolve_name_cache();
    return 0;
}

func resolve_import_alias(module_ptr: u64, module_len: u64, name_ptr: u64, name_len: u64) -> *NameInfo {
    var alias_map: *HashMap<u64, *NameInfo> = module_aliases_get(module_ptr, module_len);
    if (alias_map == 0) { return 0; }
    return alias_map.get(name_ptr, name_len);
}

func resolve_prelude_alias(name_ptr: u64, name_len: u64) -> *NameInfo {
    if (g_compiler_ctx.prelude_aliases == 0) { return 0; }
    return g_compiler_ctx.prelude_aliases.get(name_ptr, name_len);
}

func sym_invalidate_resolve_name_cache() -> u64 {
    g_compiler_ctx.resolve_name_hits = 0;
    g_compiler_ctx.resolve_name_misses = 0;
    return 0;
}

func resolve_name_hits_bucket_get(module_ptr: u64, module_len: u64) -> *HashMap<u64, *NameInfo> {
    if (g_compiler_ctx.resolve_name_hits == 0) { return 0; }
    return g_compiler_ctx.resolve_name_hits.get(module_ptr, module_len);
}

func resolve_name_hits_bucket_ensure(module_ptr: u64, module_len: u64) -> *HashMap<u64, *NameInfo> {
    if (g_compiler_ctx.resolve_name_hits == 0) {
        g_compiler_ctx.resolve_name_hits = new HashMap<u64, *HashMap<u64, *NameInfo>>{0, 0, 0};
        g_compiler_ctx.resolve_name_hits.ensure_capacity(64);
    }
    var bucket: *HashMap<u64, *NameInfo> = g_compiler_ctx.resolve_name_hits.get(module_ptr, module_len);
    if (bucket != 0) { return bucket; }
    var out: *HashMap<u64, *NameInfo> = new HashMap<u64, *NameInfo>{0, 0, 0};
    out.ensure_capacity(128);
    g_compiler_ctx.resolve_name_hits.put(module_ptr, module_len, out);
    return out;
}

func resolve_name_misses_bucket_get(module_ptr: u64, module_len: u64) -> *HashMap<u64, u64> {
    if (g_compiler_ctx.resolve_name_misses == 0) { return 0; }
    return g_compiler_ctx.resolve_name_misses.get(module_ptr, module_len);
}

func resolve_name_misses_bucket_ensure(module_ptr: u64, module_len: u64) -> *HashMap<u64, u64> {
    if (g_compiler_ctx.resolve_name_misses == 0) {
        g_compiler_ctx.resolve_name_misses = new HashMap<u64, *HashMap<u64, u64>>{0, 0, 0};
        g_compiler_ctx.resolve_name_misses.ensure_capacity(64);
    }
    var bucket: *HashMap<u64, u64> = g_compiler_ctx.resolve_name_misses.get(module_ptr, module_len);
    if (bucket != 0) { return bucket; }
    var out: *HashMap<u64, u64> = new HashMap<u64, u64>{0, 0, 0};
    out.ensure_capacity(128);
    g_compiler_ctx.resolve_name_misses.put(module_ptr, module_len, out);
    return out;
}

func sym_rebuild_func_lookup() -> u64 {
    if (g_compiler_ctx.all_funcs == 0) {
        g_compiler_ctx.all_funcs_map = new HashMap<u64, *AstFunc>{0, 0, 0};
        g_compiler_ctx.all_funcs_map.ensure_capacity(16);
        g_compiler_ctx.all_funcs_map_src = 0;
        g_compiler_ctx.all_funcs_map_src_len = 0;
        return 0;
    }
    var n: u64 = g_compiler_ctx.all_funcs.len();
    var cap: u64 = 16;
    if (n > 0) {
        cap = n * 2;
        if (cap < 16) { cap = 16; }
    }
    g_compiler_ctx.all_funcs_map = new HashMap<u64, *AstFunc>{0, 0, 0};
    g_compiler_ctx.all_funcs_map.ensure_capacity(cap);
    for (var i: u64 = 0; i < n; i++) {
        var fn: *AstFunc = g_compiler_ctx.all_funcs.get(i);
        if (fn == 0) { continue; }
        if (g_compiler_ctx.all_funcs_map.has(fn.name_ptr, fn.name_len) != 0) { continue; }
        g_compiler_ctx.all_funcs_map.put(fn.name_ptr, fn.name_len, fn);
    }
    g_compiler_ctx.all_funcs_map_src = g_compiler_ctx.all_funcs;
    g_compiler_ctx.all_funcs_map_src_len = n;
    return 0;
}

func sym_extend_func_lookup(from_idx: u64, to_idx: u64) -> u64 {
    if (g_compiler_ctx.all_funcs_map == 0 || g_compiler_ctx.all_funcs == 0) { return 0; }
    for (var i: u64 = from_idx; i < to_idx; i++) {
        var fn: *AstFunc = g_compiler_ctx.all_funcs.get(i);
        if (fn == 0) { continue; }
        if (g_compiler_ctx.all_funcs_map.has(fn.name_ptr, fn.name_len) != 0) { continue; }
        g_compiler_ctx.all_funcs_map.put(fn.name_ptr, fn.name_len, fn);
    }
    return 0;
}

func sym_ensure_func_lookup() -> u64 {
    if (g_compiler_ctx.all_funcs == 0) {
        if (g_compiler_ctx.all_funcs_map == 0 || g_compiler_ctx.all_funcs_map_src != 0 || g_compiler_ctx.all_funcs_map_src_len != 0) {
            sym_rebuild_func_lookup();
        }
        return 0;
    }
    var n: u64 = g_compiler_ctx.all_funcs.len();
    if (g_compiler_ctx.all_funcs_map == 0 || g_compiler_ctx.all_funcs_map_src != g_compiler_ctx.all_funcs || g_compiler_ctx.all_funcs_map_src_len > n) {
        sym_rebuild_func_lookup();
        return 0;
    }
    if (g_compiler_ctx.all_funcs_map_src_len < n) {
        sym_extend_func_lookup(g_compiler_ctx.all_funcs_map_src_len, n);
        g_compiler_ctx.all_funcs_map_src_len = n;
    }
    return 0;
}


func sym_ensure_const_lookup() -> u64 {
    if (g_compiler_ctx.all_consts == 0) {
        if (g_compiler_ctx.all_consts_map2 == 0 || g_compiler_ctx.all_consts_map2_src != 0 || g_compiler_ctx.all_consts_map2_src_len != 0) {

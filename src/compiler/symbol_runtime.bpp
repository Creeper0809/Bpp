func sym_ensure_global_lookup() -> u64 {
    if (g_compiler_ctx.all_globals == 0) {
        if (g_compiler_ctx.all_globals_map2 == 0 || g_compiler_ctx.all_globals_map2_src != 0 || g_compiler_ctx.all_globals_map2_src_len != 0) {

}

func sym_extend_const_lookup(from_idx: u64, to_idx: u64) -> u64 {
    if (g_compiler_ctx.all_consts_map2 == 0 || g_compiler_ctx.all_consts == 0) { return 0; }
    for (var i: u64 = from_idx; i < to_idx; i++) {
        var c: *AstConstDecl = g_compiler_ctx.all_consts.get(i);
        if (c == 0) { continue; }
        if (g_compiler_ctx.all_consts_map2.has(c.name) != 0) { continue; }
        g_compiler_ctx.all_consts_map2.put(c.name, c);

// compiler_validation.b - Validation/finalization pass contract

import compiler;
import compiler.trait_runtime;
import compiler.virtual_dispatch_runtime;
import compiler.core_utils;
import compiler.generic.engine;
import compiler.symbol_runtime;
import compiler.annotations;
import compiler.ast_lowering;
import module_utils;
import std.io;
import std.hashmap;
import std.str;
import std.vec;
import types;
import ast;

func property_hook_emit_field_error(field: *FieldDesc, msg: u64) -> u64 {
    diag_emit_error_tag("validation", "field-hook", msg);
    if (field != 0) {
        diag_emit_labelled_member("field: ", field.owner_struct, field.name);
    } else {
        diag_emit_note("field: <field>");
    }
    diag_note_error();
    return 0;
}

func property_hook_emit_setter_contract(field: *FieldDesc) -> u64 {
    if (field == 0 || u8_slice_ptr(field.setter_hook) == 0 || u8_slice_len(field.setter_hook) == 0) { return 0; }
    diag_emit_labelled_name("setter contract: ", field.setter_hook);
    return 0;
}

func property_hook_emit_getter_contract(field: *FieldDesc) -> u64 {
    if (field == 0 || u8_slice_ptr(field.getter_hook) == 0 || u8_slice_len(field.getter_hook) == 0) { return 0; }
    diag_emit_labelled_name("getter contract: ", field.getter_hook);
    return 0;
}

func property_hook_build_name(struct_slice: []u8, mid: []u8, field: []u8) -> *NameInfo {
    var p1: *NameInfo = module_util_build_joined_name(slice(struct_slice.ptr, struct_slice.len), slice(mid.ptr, mid.len));
    return module_util_build_joined_name(slice(p1.ptr, p1.len), slice(field.ptr, field.len));
}

func property_hook_field_matches_param(field: *FieldDesc, param: *Param) -> u64 {
    if (field == 0 || param == 0) { return 0; }
    if (param.is_variadic != 0 || param.has_default != 0) { return 0; }
    if (field.type_kind != param.type_kind) { return 0; }
    if (field.ptr_depth != param.ptr_depth) { return 0; }
    if (field.type_kind == TYPE_STRUCT || field.type_kind == TYPE_GENERIC || field.type_kind == TYPE_TRAIT) {
        if (str_eq(field.struct_name, param.struct_name) == 0 &&
            property_hook_name_matches(param.struct_name, field.struct_name) == 0 &&
            property_hook_name_matches(field.struct_name, param.struct_name) == 0) {
            return 0;
        }
    }
    return 1;
}

func property_hook_field_matches_return(field: *FieldDesc, fn: *AstFunc) -> u64 {
    if (field == 0 || fn == 0) { return 0; }
    if (field.type_kind != fn.ret_type) { return 0; }
    if (field.ptr_depth != fn.ret_ptr_depth) { return 0; }
    if (field.type_kind == TYPE_STRUCT || field.type_kind == TYPE_GENERIC || field.type_kind == TYPE_TRAIT) {
        if (str_eq(field.struct_name, fn.ret_struct_name) == 0 &&
            property_hook_name_matches(fn.ret_struct_name, field.struct_name) == 0 &&
            property_hook_name_matches(field.struct_name, fn.ret_struct_name) == 0) {
            return 0;
        }
    }
    return 1;
}

func property_hook_validate_self_param(field: *FieldDesc, self_param: *Param) -> u64 {
    if (field == 0 || self_param == 0) { return 0; }
    if (self_param.is_variadic != 0 || self_param.has_default != 0) { return 0; }
    if (self_param.type_kind != TYPE_STRUCT || self_param.ptr_depth != 1 || self_param.is_tagged != 0) { return 0; }
    if (str_eq(self_param.struct_name, field.owner_struct) == 0) {
        if (property_hook_name_matches(self_param.struct_name, field.owner_struct) == 0 &&
            property_hook_name_matches(field.owner_struct, self_param.struct_name) == 0) {
            return 0;
        }
    }
    return 1;
}

func property_hook_name_matches(cand: []u8, hook: []u8) -> u64 {
    if (cand.ptr == 0 || cand.len == 0 || hook.ptr == 0 || hook.len == 0) { return 0; }
    if (str_eq(slice(cand.ptr, cand.len), slice(hook.ptr, hook.len)) != 0) { return 1; }
    if (cand.len <= hook.len) { return 0; }
    var suffix_ptr: u64 = cand.ptr + (cand.len - hook.len);
    if (str_eq(slice(suffix_ptr, hook.len), slice(hook.ptr, hook.len)) == 0) { return 0; }
    var s: []u8 = slice(cand.ptr, cand.len);
    if (s[cand.len - hook.len - 1] != 95) { return 0; } // '_'
    return 1;
}

func property_hook_parse_field_annotations(field: *FieldDesc) -> u64 {
    if (field == 0 || field.annotations_vec == 0) { return 1; }
    var anns: *Vec<*NameInfo> = field.annotations_vec;
    var n: u64 = anns.len();
    for (var i: u64 = 0; i < n; i++) {
        var info: *NameInfo = anns.get(i);
        var ann: *CompilerAnnotationParsed = annotation_parse(info);
        if (ann == 0 || ann.parse_ok == 0 || u8_slice_ptr(ann.name) == 0 || u8_slice_len(ann.name) == 0) {
            property_hook_emit_field_error(field, "malformed field annotation");
            return 0;
        }

        if (str_eq(ann.name, slice("setter", str_len("setter"))) != 0 ||
            str_eq(ann.name, slice("getter", str_len("getter"))) != 0) {
            property_hook_emit_field_error(field, "field hooks no longer use annotation syntax");
            diag_emit_help("write property(...) before the access modifier, e.g. property(setter) public value: i32;");
            return 0;
        }
        property_hook_emit_field_error(field, "field annotations are not supported here");
        return 0;
    }
    return 1;
}

func property_hook_validate_manual_setter(field: *FieldDesc) -> u64 {
    if (field == 0) { return 1; }
    if (field.setter_hook_mode != FIELD_HOOK_MANUAL) { return 1; }
    var any_name_match: u64 = 0;

    if (g_compiler_ctx.all_funcs != 0) {
        var n: u64 = g_compiler_ctx.all_funcs.len();
        for (var i: u64 = 0; i < n; i++) {
            var fn: *AstFunc = g_compiler_ctx.all_funcs.get(i);
            if (fn == 0) { continue; }
            if (property_hook_name_matches(fn.name, field.setter_hook) == 0) { continue; }
            any_name_match = 1;
            var params: *Vec<*Param> = fn.params_vec;
            if (params == 0 || params.len() != 2) { continue; }
            var p0: *Param = params.get(0);
            var p1: *Param = params.get(1);
            if (property_hook_validate_self_param(field, p0) == 0) { continue; }
            if (property_hook_field_matches_param(field, p1) == 0) { continue; }
            if (fn.ret_type != TYPE_VOID || fn.ret_ptr_depth != 0) { continue; }
            field.setter_hook = fn.name;
            return 1;
        }
    }
    if (g_compiler_ctx.all_func_sigs != 0) {
        var sn: u64 = g_compiler_ctx.all_func_sigs.len();
        for (var j: u64 = 0; j < sn; j++) {
            var sig: *AstFunc = g_compiler_ctx.all_func_sigs.get(j);
            if (sig == 0) { continue; }
            if (property_hook_name_matches(sig.name, field.setter_hook) == 0) { continue; }
            any_name_match = 1;
            var sparams: *Vec<*Param> = sig.params_vec;
            if (sparams == 0 || sparams.len() != 2) { continue; }
            var sp0: *Param = sparams.get(0);
            var sp1: *Param = sparams.get(1);
            if (property_hook_validate_self_param(field, sp0) == 0) { continue; }
            if (property_hook_field_matches_param(field, sp1) == 0) { continue; }
            if (sig.ret_type != TYPE_VOID || sig.ret_ptr_depth != 0) { continue; }
            field.setter_hook = sig.name;
            return 1;
        }
    }

    if (any_name_match == 0) {
        property_hook_emit_field_error(field, "setter hook function not found");
        property_hook_emit_setter_contract(field);
        diag_emit_help("define a matching setter like func set_x(self: *Owner, val: FieldType) -> void, or use property(setter) for auto generation");
        return 0;
    }
    property_hook_emit_field_error(field, "setter hook signature mismatch");
    property_hook_emit_setter_contract(field);
    diag_emit_help("setter contract must be (self: *Owner, val: FieldType) -> void");
    return 0;
}

func property_hook_validate_manual_getter(field: *FieldDesc) -> u64 {
    if (field == 0) { return 1; }
    if (field.getter_hook_mode != FIELD_HOOK_MANUAL) { return 1; }
    var any_name_match: u64 = 0;

    if (g_compiler_ctx.all_funcs != 0) {
        var n: u64 = g_compiler_ctx.all_funcs.len();
        for (var i: u64 = 0; i < n; i++) {
            var fn: *AstFunc = g_compiler_ctx.all_funcs.get(i);
            if (fn == 0) { continue; }
            if (property_hook_name_matches(fn.name, field.getter_hook) == 0) { continue; }
            any_name_match = 1;
            var params: *Vec<*Param> = fn.params_vec;
            if (params == 0 || params.len() != 1) { continue; }
            var p0: *Param = params.get(0);
            if (property_hook_validate_self_param(field, p0) == 0) { continue; }
            if (property_hook_field_matches_return(field, fn) == 0) { continue; }
            field.getter_hook = fn.name;
            return 1;
        }
    }
    if (g_compiler_ctx.all_func_sigs != 0) {
        var sn: u64 = g_compiler_ctx.all_func_sigs.len();
        for (var j: u64 = 0; j < sn; j++) {
            var sig: *AstFunc = g_compiler_ctx.all_func_sigs.get(j);
            if (sig == 0) { continue; }
            if (property_hook_name_matches(sig.name, field.getter_hook) == 0) { continue; }
            any_name_match = 1;
            var sparams: *Vec<*Param> = sig.params_vec;
            if (sparams == 0 || sparams.len() != 1) { continue; }
            var sp0: *Param = sparams.get(0);
            if (property_hook_validate_self_param(field, sp0) == 0) { continue; }
            if (property_hook_field_matches_return(field, sig) == 0) { continue; }
            field.getter_hook = sig.name;
            return 1;
        }
    }

    if (any_name_match == 0) {
        property_hook_emit_field_error(field, "getter hook function not found");
        property_hook_emit_getter_contract(field);
        diag_emit_help("define a matching getter like func get_x(self: *Owner) -> FieldType, or use property(getter) for auto generation");
        return 0;
    }
    property_hook_emit_field_error(field, "getter hook signature mismatch");
    property_hook_emit_getter_contract(field);
    diag_emit_help("getter contract must be (self: *Owner) -> FieldType");
    return 0;
}

func property_hook_create_value_param(field: *FieldDesc) -> *Param {
    var p: *Param = new Param{};
    p.name = slice((u64)"val", 3);
    p.type_kind = field.type_kind;
    p.ptr_depth = field.ptr_depth;
    p.is_tagged = field.is_tagged;
    p.struct_name = field.struct_name;
    p.tag_layout = field.tag_layout;
    p.elem_type_kind = field.elem_type_kind;
    p.elem_ptr_depth = field.elem_ptr_depth;
    p.array_len = field.array_len;
    p.elem_typeinfo = field.elem_typeinfo;
    p.is_variadic = 0;
    p.has_default = 0;
    return p;
}

func property_hook_create_auto_setter(field: *FieldDesc) -> u64 {
    if (field == 0 || field.setter_hook_mode != FIELD_HOOK_AUTO) { return 1; }
    var name: *NameInfo = property_hook_build_name(field.owner_struct, slice("set", 3), field.name);
    if (sym_func_exists(slice(name.ptr, name.len)) != 0) {
        property_hook_emit_field_error(field, "auto setter name collision");
        return 0;
    }

    var params: *Vec<*Param> = new Vec<*Param>{heap_alloc((2) * sizeof(*Param)), 0, (2)};
    var self_param: *Param = new Param{};
    self_param.set_as_self_param(field.owner_struct);
    params.push(self_param);
    params.push(property_hook_create_value_param(field));

    var stmts: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((1) * sizeof(*AstNode)), 0, (1)};
    var target: *AstNode = ast_raw_member_access((*AstNode)ast_ident(slice("self", 4)), field.name);
    var value: *AstNode = ast_ident(slice("val", 3));
    stmts.push((*AstNode)ast_assign(target, value));
    var body: *AstNode = (*AstNode)ast_block(stmts);

    var fn: *AstFunc = ast_func_ex(slice(name.ptr, name.len), params, TYPE_VOID, 0, 0, slice(0, 0), slice(0, 0), body);
    if (g_compiler_ctx.all_funcs == 0) { g_compiler_ctx.all_funcs = new Vec<*AstFunc>{heap_alloc((8) * sizeof(*AstFunc)), 0, (8)}; }
    if (g_compiler_ctx.all_func_sigs == 0) { g_compiler_ctx.all_func_sigs = new Vec<*AstFunc>{heap_alloc((8) * sizeof(*AstFunc)), 0, (8)}; }
    g_compiler_ctx.all_funcs.push(fn);
    g_compiler_ctx.all_func_sigs.push(annotation_clone_sig(fn, fn.name));
    if (u8_slice_ptr(g_compiler_ctx.current_module) != 0 && u8_slice_len(g_compiler_ctx.current_module) != 0) {
        sym_assign_func_module(fn.name, g_compiler_ctx.current_module);
    }
    sym_invalidate_func_lookup();

    field.setter_hook = slice(name.ptr, name.len);
    return 1;
}

func property_hook_create_auto_getter(field: *FieldDesc) -> u64 {
    if (field == 0 || field.getter_hook_mode != FIELD_HOOK_AUTO) { return 1; }
    var name: *NameInfo = property_hook_build_name(field.owner_struct, slice("get", 3), field.name);
    if (sym_func_exists(slice(name.ptr, name.len)) != 0) {
        property_hook_emit_field_error(field, "auto getter name collision");
        return 0;
    }

    var ret_type: u64 = field.type_kind;
    var ret_ptr_depth: u64 = field.ptr_depth;
    var ret_is_tagged: u64 = field.is_tagged;
    var ret_struct_ptr: u64 = u8_slice_ptr(field.struct_name);
    var ret_struct_len: u64 = u8_slice_len(field.struct_name);
    var ret_tag_ptr: u64 = u8_slice_ptr(field.tag_layout);
    var ret_tag_len: u64 = u8_slice_len(field.tag_layout);
    if (field.type_kind == TYPE_ARRAY) {
        ret_type = field.elem_type_kind;
        ret_ptr_depth = field.elem_ptr_depth + 1;
        ret_is_tagged = 0;
        ret_tag_ptr = 0;
        ret_tag_len = 0;
    }

    var params: *Vec<*Param> = new Vec<*Param>{heap_alloc((1) * sizeof(*Param)), 0, (1)};
    var self_param: *Param = new Param{};
    self_param.set_as_self_param(field.owner_struct);
    params.push(self_param);

    var stmts: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((1) * sizeof(*AstNode)), 0, (1)};
    var value: *AstNode = ast_raw_member_access((*AstNode)ast_ident(slice("self", 4)), field.name);
    stmts.push((*AstNode)ast_return(value));
    var body: *AstNode = (*AstNode)ast_block(stmts);

    var fn: *AstFunc = ast_func_ex(slice(name.ptr, name.len), params, ret_type, ret_ptr_depth, ret_is_tagged, slice(ret_struct_ptr, ret_struct_len), slice(ret_tag_ptr, ret_tag_len), body);
    if (g_compiler_ctx.all_funcs == 0) { g_compiler_ctx.all_funcs = new Vec<*AstFunc>{heap_alloc((8) * sizeof(*AstFunc)), 0, (8)}; }
    if (g_compiler_ctx.all_func_sigs == 0) { g_compiler_ctx.all_func_sigs = new Vec<*AstFunc>{heap_alloc((8) * sizeof(*AstFunc)), 0, (8)}; }
    g_compiler_ctx.all_funcs.push(fn);
    g_compiler_ctx.all_func_sigs.push(annotation_clone_sig(fn, fn.name));
    if (u8_slice_ptr(g_compiler_ctx.current_module) != 0 && u8_slice_len(g_compiler_ctx.current_module) != 0) {
        sym_assign_func_module(fn.name, g_compiler_ctx.current_module);
    }
    sym_invalidate_func_lookup();

    field.getter_hook = slice(name.ptr, name.len);
    return 1;
}

func property_hooks_finalize() -> u64 {
    if (g_compiler_ctx.all_structs_vec == 0) { return 0; }
    var sn: u64 = g_compiler_ctx.all_structs_vec.len();
    for (var si: u64 = 0; si < sn; si++) {
        if (diag_should_stop_pass() != 0) { break; }
        var sd: *AstStructDef = g_compiler_ctx.all_structs_vec.get(si);
        if (sd == 0 || sd.fields_vec == 0) { continue; }
        var fields: *Vec<*FieldDesc> = sd.fields_vec;
        var fn: u64 = fields.len();
        for (var fi: u64 = 0; fi < fn; fi++) {
            if (diag_should_stop_pass() != 0) { break; }
            var field: *FieldDesc = fields.get(fi);
            if (field == 0) { continue; }
            if (property_hook_parse_field_annotations(field) == 0) { continue; }
            if (property_hook_create_auto_setter(field) == 0) { continue; }
            if (property_hook_create_auto_getter(field) == 0) { continue; }
            if (property_hook_validate_manual_setter(field) == 0) { continue; }
            property_hook_validate_manual_getter(field);
        }
    }
    return 0;
}

func validate_global_function_name_collisions_core() -> u64 {
    if (g_compiler_ctx.all_funcs == 0 || g_compiler_ctx.all_globals == 0) { return 0; }

    var func_n: u64 = g_compiler_ctx.all_funcs.len();
    var global_n: u64 = g_compiler_ctx.all_globals.len();
    var cap: u64 = (func_n * 2) + 16;
    var top_level_funcs: *HashMap<u64, u64> = new HashMap<u64, u64>{0, 0, 0};
    top_level_funcs.ensure_capacity(cap);

    for (var fi: u64 = 0; fi < func_n; fi++) {
        var fn: *AstFunc = g_compiler_ctx.all_funcs.get(fi);
        if (fn == 0) { continue; }
        if (u8_slice_ptr(fn.impl_owner) != 0 && u8_slice_len(fn.impl_owner) != 0) { continue; }
        top_level_funcs.put(fn.name, 1);
    }

    for (var gi: u64 = 0; gi < global_n; gi++) {
        var ginfo: *GlobalInfo = g_compiler_ctx.all_globals.get(gi);
        if (ginfo == 0) { continue; }
        if (top_level_funcs.has(ginfo.name) == 0) { continue; }
        diag_emit_error_tag("validation", "V1700", "global variable conflicts with function name");
        diag_emit_labelled_name("name: ", ginfo.name);
        diag_note_error();
    }
    return 0;
}

func validate_child_implements_abst_method(sd: *AstStructDef, mi: *NameInfo) -> u64 {
    if (sym_is_abst_method(sd.name, slice(mi.ptr, mi.len)) != 0) {
        return 0;
    }
    var found_impl: *AstFunc = find_method_func_in_hierarchy(sd, slice(mi.ptr, mi.len));
    if (found_impl == 0) {
        diag_emit_error_tag("validation", "V1701", "Missing abstract method implementation in child");
        diag_emit_labelled_member("member: ", sd.name, slice(mi.ptr, mi.len));
        diag_note_error();
    }
    return 0;
}

func validate_direct_impl_calls_core() -> u64 {
    validate_global_function_name_collisions_core();
    if (diag_should_stop_pass() != 0) { return 0; }

    if (g_compiler_ctx.all_funcs != 0) {
        var fn_count: u64 = g_compiler_ctx.all_funcs.len();
        for (var i: u64 = 0; i < fn_count; i++) {
            var fn: *AstFunc = g_compiler_ctx.all_funcs.get(i);
            if (fn == 0 || fn.body == 0) { continue; }
            var owner_info: *NameInfo = sym_get_impl_method_owner(fn.name);
            var owner_ptr: u64 = 0;
            var owner_len: u64 = 0;
            if (owner_info != 0) {
                owner_ptr = owner_info.ptr;
                owner_len = owner_info.len;
            }
            validate_direct_impl_calls_stmt(fn.body, slice(owner_ptr, owner_len));
        }
    }

    if (g_compiler_ctx.all_globals != 0) {
        var gn: u64 = g_compiler_ctx.all_globals.len();
        for (var gi: u64 = 0; gi < gn; gi++) {
            var ginfo: *GlobalInfo = g_compiler_ctx.all_globals.get(gi);
            if (ginfo == 0 || ginfo.init_expr == 0) { continue; }
            validate_direct_impl_calls_expr((*AstNode)ginfo.init_expr, slice(0, 0));
        }
    }
    return 0;
}

func finalize_traits() -> u64 {
    trait_validate_all_struct_trait_inheritance();
    if (diag_should_stop_pass() != 0) { return 0; }
    if (g_compiler_ctx.all_trait_impls_vec == 0 || g_compiler_ctx.all_trait_impls_vec.len() == 0) { return 0; }

    var num_impls: u64 = g_compiler_ctx.all_trait_impls_vec.len();
    for (var ii: u64 = 0; ii < num_impls; ii++) {
        if (diag_should_stop_pass() != 0) { break; }
        var impl_info: *TraitImpl = g_compiler_ctx.all_trait_impls_vec.get(ii);
        trait_finalize_single_trait_impl(impl_info);
    }
    return 0;
}

func validate_impl_overrides_core() -> u64 {
    if (g_compiler_ctx.all_func_sigs == 0) { return 0; }
    var n: u64 = g_compiler_ctx.all_func_sigs.len();
    for (var i: u64 = 0; i < n; i++) {
        if (diag_should_stop_pass() != 0) { break; }
        var fn_sig: *AstFunc = g_compiler_ctx.all_func_sigs.get(i);
        vdispatch_validate_single_impl_override(fn_sig);
        if (diag_should_stop_pass() != 0) { break; }
        vdispatch_validate_single_magic_method_contract(fn_sig);
    }
    return 0;
}

func apply_annotations() -> u64 {
    if (g_compiler_ctx.all_funcs == 0) { return 0; }
    property_hooks_finalize();
    if (diag_should_stop_pass() != 0) { return 0; }

    var original_count: u64 = g_compiler_ctx.all_funcs.len();
    var generated_id: u64 = 0;
    var entry_ptr: u64 = 0;
    var entry_len: u64 = 0;

    for (var i: u64 = 0; i < original_count; i++) {
        if (diag_should_stop_pass() != 0) { break; }
        var fn: *AstFunc = g_compiler_ctx.all_funcs.get(i);
        if (fn == 0) { continue; }
        if (annotation_validate_function_annotations(fn) == 0) {
            continue;
        }

        var entry_count: u64 = annotation_count_name(fn.annotations_vec, slice("entry", str_len("entry")));
        if (entry_count > 0) {
            if (u8_slice_ptr(fn.impl_owner) != 0 && u8_slice_len(fn.impl_owner) != 0) {
                diag_emit_error_tag("validation", "entry", "@[entry] is only allowed on top-level functions");
                diag_emit_labelled_name("function: ", fn.name);
                diag_emit_note("move the entry function out of the impl block");
                diag_note_error();
                continue;
            }
            var entry_param_n: u64 = 0;
            if (fn.params_vec != 0) { entry_param_n = fn.params_vec.len(); }
            if (entry_param_n != 0) {
                diag_emit_error_tag("validation", "entry", "@[entry] function must not declare parameters");
                diag_emit_labelled_name("function: ", fn.name);
                diag_emit_help("remove the parameters or use a normal function instead of @[entry]");
                diag_note_error();
                continue;
            }
            if (entry_count > 1) {
                diag_emit_error_tag("validation", "entry", "duplicate @[entry] annotation on function");
                diag_emit_labelled_name("function: ", fn.name);
                diag_emit_help("keep at most one @[entry] annotation on the same function");
                diag_note_error();
                continue;
            }
            if (entry_ptr != 0 && str_eq(slice(entry_ptr, entry_len), fn.name) == 0) {
                diag_emit_error_tag("validation", "entry", "multiple @[entry] functions are not allowed");
                diag_emit_labelled_name("first entry: ", slice(entry_ptr, entry_len));
                diag_emit_labelled_name("second entry: ", fn.name);
                diag_emit_help("keep exactly one top-level @[entry] function in the program");
                diag_note_error();
                continue;
            }
            entry_ptr = u8_slice_ptr(fn.name);
            entry_len = u8_slice_len(fn.name);
        }

        var decorators: *Vec<*NameInfo> = annotation_collect_decorators(fn);
        if (decorators == 0 || decorators.len() == 0) { continue; }

        var is_impl_method: u64 = 0;
        if (u8_slice_ptr(fn.impl_owner) != 0 && u8_slice_len(fn.impl_owner) != 0) {
            is_impl_method = 1;
        }
        if (fn.body == 0) {
            diag_emit_error_tag("validation", "decorator", "function decorator requires a function body");
            diag_emit_labelled_name("target: ", fn.name);
            diag_emit_help("add a function body or remove the decorator annotation");
            diag_note_error();
            continue;
        }
        if (is_generic_template(fn) != 0) {
            continue;
        }

        var decorators_valid: u64 = 1;
        var deco_n0: u64 = decorators.len();
        for (var di0: u64 = 0; di0 < deco_n0; di0++) {
            var deco0: *NameInfo = decorators.get(di0);
            var sig0: *AstFunc = lower_find_func_signature_for_call(slice(deco0.ptr, deco0.len));
            if (sig0 == 0) {
                diag_emit_error_tag("validation", "decorator", "unresolved decorator function");
                diag_emit_labelled_name("decorator: ", slice(deco0.ptr, deco0.len));
                diag_emit_labelled_name("target: ", fn.name);
                diag_emit_help("define the decorator function before use or fix the annotation name");
                diag_note_error();
                decorators_valid = 0;
                continue;
            }
            if (annotation_validate_decorator_signature(sig0, fn, slice(deco0.ptr, deco0.len)) == 0) {
                decorators_valid = 0;
            }
        }
        if (decorators_valid == 0) { continue; }

        var public_name: []u8 = fn.name;
        var surface_contract_annotations: *Vec<*NameInfo> = annotation_clone_complexity_contract_annotations(fn.annotations_vec);
        var method_owner_ptr: u64 = 0;
        var method_owner_len: u64 = 0;
        var method_access: u64 = ACCESS_PUBLIC;
        var method_original_name: []u8 = slice(0, 0);
        var method_is_override: u64 = 0;
        if (is_impl_method != 0) {
            method_owner_ptr = u8_slice_ptr(fn.impl_owner);
            method_owner_len = u8_slice_len(fn.impl_owner);
            method_access = fn.impl_method_access;
            method_original_name = fn.impl_original_name;
            if (u8_slice_ptr(method_original_name) == 0 || u8_slice_len(method_original_name) == 0) {
                method_original_name = public_name;
            }
            method_is_override = fn.impl_is_override;
        }

        generated_id = generated_id + 1;
        var hidden_name: *NameInfo = annotation_build_generated_name(slice("__ann_orig__", 11), public_name, generated_id);
        fn.name = slice(hidden_name.ptr, hidden_name.len);
        fn.annotations_vec = 0;
        sym_inherit_func_module(public_name, slice(hidden_name.ptr, hidden_name.len));

        if (annotation_rename_first_signature(public_name, slice(hidden_name.ptr, hidden_name.len)) == 0) {
            if (g_compiler_ctx.all_func_sigs != 0) {
                g_compiler_ctx.all_func_sigs.push(annotation_clone_sig(fn, slice(hidden_name.ptr, hidden_name.len)));
            }
        }
        if (is_impl_method != 0) {
            annotation_clear_impl_metadata(fn);
        }
        var callee_ptr: u64 = hidden_name.ptr;
        var callee_len: u64 = hidden_name.len;
        var deco_n: u64 = decorators.len();
        for (var rev: u64 = 0; rev < deco_n; rev++) {
            var di: u64 = deco_n - rev - 1;
            var deco: *NameInfo = decorators.get(di);
            var deco_sig: *AstFunc = lower_find_func_signature_for_call(slice(deco.ptr, deco.len));
            if (deco_sig == 0) {
                diag_emit_error_tag("validation", "decorator", "unresolved decorator function");
                diag_emit_labelled_name("decorator: ", slice(deco.ptr, deco.len));
                diag_emit_labelled_name("target: ", public_name);
                diag_emit_help("define the decorator function before use or fix the annotation name");
                diag_note_error();
                break;
            }
            if (annotation_validate_decorator_signature(deco_sig, fn, slice(deco.ptr, deco.len)) == 0) {
                break;
            }

            var wrapper_name: []u8 = slice(0, 0);
            if (di == 0) {
                wrapper_name = public_name;
            } else {
                generated_id = generated_id + 1;
                var wrap_name: *NameInfo = annotation_build_generated_name(slice("__ann_wrap__", 11), public_name, generated_id);
                wrapper_name = slice(wrap_name.ptr, wrap_name.len);
            }

            var keep_impl_metadata: u64 = 0;
            if (is_impl_method != 0 && di == 0) { keep_impl_metadata = 1; }
            var wrapper_fn: *AstFunc = annotation_build_wrapper_func(fn, wrapper_name, slice(deco.ptr, deco.len), slice(callee_ptr, callee_len), 0);
            if (keep_impl_metadata != 0) {
                annotation_set_impl_metadata(wrapper_fn, slice(method_owner_ptr, method_owner_len), method_access, method_original_name, method_is_override);
            }
            if (di == 0 && surface_contract_annotations != 0) {
                wrapper_fn.annotations_vec = surface_contract_annotations;
                annotation_register_surface_contract_annotations(wrapper_name, surface_contract_annotations);
            }
            g_compiler_ctx.all_funcs.push(wrapper_fn);
            sym_inherit_func_module(public_name, wrapper_fn.name);
            if (keep_impl_metadata != 0) {
                sym_register_impl_method_ex(wrapper_fn.name, slice(method_owner_ptr, method_owner_len), method_access);
                if (g_compiler_ctx.impl_method_funcs == 0) {
                    g_compiler_ctx.impl_method_funcs = new HashMap<u64, *AstFunc>{0, 0, 0};
                    g_compiler_ctx.impl_method_funcs.ensure_capacity(64);
                }
                g_compiler_ctx.impl_method_funcs.put(wrapper_fn.name, wrapper_fn);
            }
            if (g_compiler_ctx.all_func_sigs != 0) {
                g_compiler_ctx.all_func_sigs.push(annotation_clone_sig(wrapper_fn, wrapper_name));
            }
            callee_ptr = u8_slice_ptr(wrapper_name);
            callee_len = u8_slice_len(wrapper_name);
        }
    }

    g_compiler_ctx.entry_func = slice(entry_ptr, entry_len);
    sym_invalidate_func_lookup();
    if (annotation_complexity_validate_std_library_summaries() == 0) { return 0; }
    return 0;
}

func finalize_abst_methods() -> u64 {
    if (g_compiler_ctx.all_structs_vec == 0) { return 0; }
    var sn: u64 = g_compiler_ctx.all_structs_vec.len();
    for (var si: u64 = 0; si < sn; si++) {
        if (diag_should_stop_pass() != 0) { break; }
        var sd: *AstStructDef = g_compiler_ctx.all_structs_vec.get(si);
        if (sd == 0 || sd.parents_vec == 0) { continue; }
        var required: *Vec<*NameInfo> = new Vec<*NameInfo>{heap_alloc((8) * sizeof(*NameInfo)), 0, (8)};
        vdispatch_collect_abst_methods_recursive(sd, required);
        var rn: u64 = required.len();
        for (var ri: u64 = 0; ri < rn; ri++) {
            if (diag_should_stop_pass() != 0) { break; }
            var mi: *NameInfo = required.get(ri);
            validate_child_implements_abst_method(sd, mi);
        }
    }
    vdispatch_setup_traits();
    return 0;
}

func validate_direct_impl_calls_with_ctx(ctx: *CompilerCtx) -> u64 {
    if (compiler_ctx_is_active(ctx) == 0) {
        diag_emit_error_tag("validation", "internal", "validate_direct_impl_calls_with_ctx requires active compiler context");
        diag_note_error();
        return 1;
    }
    return validate_direct_impl_calls_core();
}

func validate_impl_overrides_with_ctx(ctx: *CompilerCtx) -> u64 {
    if (compiler_ctx_is_active(ctx) == 0) {
        diag_emit_error_tag("validation", "internal", "validate_impl_overrides_with_ctx requires active compiler context");
        diag_note_error();
        return 1;
    }
    return validate_impl_overrides_core();
}

func validate_finalize_abst_methods_with_ctx(ctx: *CompilerCtx) -> u64 {
    if (compiler_ctx_is_active(ctx) == 0) {
        diag_emit_error_tag("validation", "internal", "validate_finalize_abst_methods_with_ctx requires active compiler context");
        diag_note_error();
        return 1;
    }
    return finalize_abst_methods();
}

func validate_finalize_traits_with_ctx(ctx: *CompilerCtx) -> u64 {
    if (compiler_ctx_is_active(ctx) == 0) {
        diag_emit_error_tag("validation", "internal", "validate_finalize_traits_with_ctx requires active compiler context");
        diag_note_error();
        return 1;
    }
    return finalize_traits();
}

func validate_apply_annotations_with_ctx(ctx: *CompilerCtx) -> u64 {
    if (compiler_ctx_is_active(ctx) == 0) {
        diag_emit_error_tag("validation", "internal", "validate_apply_annotations_with_ctx requires active compiler context");
        diag_note_error();
        return 1;
    }
    return apply_annotations();
}

func contract_preservation_name_has_prefix(name: []u8, prefix: []u8) -> u64 {
    if (name.ptr == 0 || name.len < prefix.len) { return 0; }
    return str_eq(slice(name.ptr, prefix.len), slice(prefix.ptr, prefix.len)) != 0;
}

func contract_preservation_is_generated_decorator_name(name: []u8) -> u64 {
    if (contract_preservation_name_has_prefix(slice(name.ptr, name.len), slice("__ann_orig__", 11)) != 0) { return 1; }
    if (contract_preservation_name_has_prefix(slice(name.ptr, name.len), slice("__ann_wrap__", 11)) != 0) { return 1; }
    return 0;
}

func contract_preservation_emit_surface_for_name(name: []u8) -> u64 {
    var surface: *AnnContractSurfaceMeta = annotation_contract_surface_for_name(slice(name.ptr, name.len));
    if (surface == 0) { return 0; }
    return annotation_emit_contract_surface_notes(surface);
}

func contract_preservation_emit_surface_for_fn(fn: *AstFunc) -> u64 {
    if (fn == 0) { return 0; }
    var surface: *AnnContractSurfaceMeta = annotation_contract_surface_for_fn(fn);
    if (surface == 0) { return 0; }
    return annotation_emit_contract_surface_notes(surface);
}

func contract_preservation_emit_generated_func_error(fn: *AstFunc, msg: u64, help: u64) -> u64 {
    diag_emit_error_tag("validation", "contract-preservation", msg);
    contract_preservation_emit_surface_for_fn(fn);
    if (help != 0) {
        diag_emit_help(help);
    }
    diag_note_error();
    return 0;
}

func contract_preservation_direct_func_symbol_ok(name: []u8) -> u64 {
    if (name.ptr == 0 || name.len == 0) { return 0; }
    if (resolve_name(slice(name.ptr, name.len)) != 0) { return 1; }
    if (contract_preservation_is_generated_decorator_name(slice(name.ptr, name.len)) != 0) { return 1; }
    return 0;
}

func contract_preservation_validate_expr(node: *AstNode, owner: *AstFunc) -> u64 {
    if (node == 0 || diag_should_stop_pass() != 0) { return 1; }
    var kind: u64 = ast_kind(node);
    var nref: AstNodeTagRef;
    nref.node = node;
    match (kind) {
        case AST_BINARY:
            if (contract_preservation_validate_expr(nref.binary.left, owner) == 0) { return 0; }
            return contract_preservation_validate_expr(nref.binary.right, owner);
        case AST_UNARY:
            return contract_preservation_validate_expr(nref.unary.operand, owner);
        case AST_ADDR_OF:
            return contract_preservation_validate_expr(nref.addr_of.operand, owner);
        case AST_DEREF:
            return contract_preservation_validate_expr(nref.deref.operand, owner);
        case AST_DEREF8:
            return contract_preservation_validate_expr(nref.deref8.operand, owner);
        case AST_CAST:
            return contract_preservation_validate_expr(nref.cast_expr.expr, owner);
        case AST_MEMBER_ACCESS:
        case AST_SAFE_MEMBER_ACCESS:
            return contract_preservation_validate_expr(nref.member_access.object, owner);
        case AST_METHOD_CALL:
        case AST_SAFE_METHOD_CALL:
            if (contract_preservation_validate_expr(nref.method_call.receiver, owner) == 0) { return 0; }
            if (nref.method_call.args_vec != 0) {
                var ma_n: u64 = nref.method_call.args_vec.len();
                for (var mi: u64 = 0; mi < ma_n; mi++) {
                    if (contract_preservation_validate_expr(nref.method_call.args_vec.get(mi), owner) == 0) { return 0; }
                }
            }
            return 1;
        case AST_INDEX:
        case AST_SAFE_INDEX:
            if (contract_preservation_validate_expr(nref.index_expr.base, owner) == 0) { return 0; }
            return contract_preservation_validate_expr(nref.index_expr.index, owner);
        case AST_SLICE:
            if (contract_preservation_validate_expr(nref.slice_expr.ptr_expr, owner) == 0) { return 0; }
            return contract_preservation_validate_expr(nref.slice_expr.len_expr, owner);
        case AST_TRY:
            return contract_preservation_validate_expr(nref.try_expr.operand, owner);
        case AST_STRUCT_LITERAL:
            if (nref.struct_lit.values_vec != 0) {
                var sv_n: u64 = nref.struct_lit.values_vec.len();
                for (var svi: u64 = 0; svi < sv_n; svi++) {
                    if (contract_preservation_validate_expr(nref.struct_lit.values_vec.get(svi), owner) == 0) { return 0; }
                }
            }
            return 1;
        case AST_GENERIC_STRUCT_LITERAL:
            if (nref.generic_struct_lit.values_vec != 0) {
                var gsv_n: u64 = nref.generic_struct_lit.values_vec.len();
                for (var gsvi: u64 = 0; gsvi < gsv_n; gsvi++) {
                    if (contract_preservation_validate_expr(nref.generic_struct_lit.values_vec.get(gsvi), owner) == 0) { return 0; }
                }
            }
            return 1;
        case AST_CALL:
            var call: *AstCall = nref.call;
            if (sym_func_exists(call.name) == 0 || contract_preservation_direct_func_symbol_ok(call.name) == 0) {
                contract_preservation_emit_generated_func_error(owner,
                    "generated decorator function contains unresolved direct call",
                    "generated wrappers must keep module-aware direct calls resolvable after annotation expansion");
                diag_emit_labelled_name("callee: ", call.name);
                return 0;
            }
            if (call.args_vec != 0) {
                var ca_n: u64 = call.args_vec.len();
                for (var ci: u64 = 0; ci < ca_n; ci++) {
                    if (contract_preservation_validate_expr(call.args_vec.get(ci), owner) == 0) { return 0; }
                }
            }
            return 1;
        case AST_GENERIC_CALL:
            var gcall: *AstGenericCall = nref.generic_call;
            if (sym_func_exists(gcall.name) == 0 || contract_preservation_direct_func_symbol_ok(gcall.name) == 0) {
                contract_preservation_emit_generated_func_error(owner,
                    "generated decorator function contains unresolved direct call",
                    "generated wrappers must keep module-aware direct calls resolvable after annotation expansion");
                diag_emit_labelled_name("callee: ", gcall.name);
                return 0;
            }
            if (gcall.args_vec != 0) {
                var gc_n: u64 = gcall.args_vec.len();
                for (var gci: u64 = 0; gci < gc_n; gci++) {
                    if (contract_preservation_validate_expr(gcall.args_vec.get(gci), owner) == 0) { return 0; }
                }
            }
            return 1;
        case AST_CALL_PTR:
            var cp: *AstCallPtr = nref.call_ptr;
            if (contract_preservation_validate_expr(cp.callee, owner) == 0) { return 0; }
            if (cp.args_vec != 0) {
                var cp_n: u64 = cp.args_vec.len();
                for (var cpi: u64 = 0; cpi < cp_n; cpi++) {
                    if (contract_preservation_validate_expr(cp.args_vec.get(cpi), owner) == 0) { return 0; }
                }
            }
            return 1;
        case AST_IDENT:
            var idn: *AstIdent = nref.ident;
            if (sym_func_exists(idn.name) != 0 && contract_preservation_direct_func_symbol_ok(idn.name) == 0) {
                contract_preservation_emit_generated_func_error(owner,
                    "generated decorator function lost direct function symbol resolution",
                    "ensure generated wrappers inherit the original function module context before code generation");
                diag_emit_labelled_name("symbol: ", idn.name);
                return 0;
            }
            return 1;
    }
    return 1;
}

func contract_preservation_validate_stmt(node: *AstNode, owner: *AstFunc) -> u64 {
    if (node == 0 || diag_should_stop_pass() != 0) { return 1; }
    var kind: u64 = ast_kind(node);
    var nref: AstNodeTagRef;
    nref.node = node;
    match (kind) {
        case AST_RETURN:
            return contract_preservation_validate_expr(nref.ret_stmt.expr, owner);
        case AST_VAR_DECL:
            return contract_preservation_validate_expr(nref.var_decl.init_expr, owner);
        case AST_CONST_DECL:
            return contract_preservation_validate_expr(nref.const_decl.value, owner);
        case AST_ASSIGN:
            if (contract_preservation_validate_expr(nref.assign_stmt.target, owner) == 0) { return 0; }
            return contract_preservation_validate_expr(nref.assign_stmt.value, owner);
        case AST_EXPR_STMT:
            return contract_preservation_validate_expr(nref.expr_stmt.expr, owner);
        case AST_DEFER:
            return contract_preservation_validate_stmt(nref.defer_stmt.stmt, owner);
        case AST_IF:
            if (contract_preservation_validate_expr(nref.if_stmt.cond, owner) == 0) { return 0; }
            if (contract_preservation_validate_stmt(nref.if_stmt.then_block, owner) == 0) { return 0; }
            return contract_preservation_validate_stmt(nref.if_stmt.else_block, owner);
        case AST_WHILE:
            if (contract_preservation_validate_expr(nref.while_stmt.cond, owner) == 0) { return 0; }
            return contract_preservation_validate_stmt(nref.while_stmt.body, owner);
        case AST_DO_WHILE:
            if (contract_preservation_validate_stmt(nref.do_while_stmt.body, owner) == 0) { return 0; }
            return contract_preservation_validate_expr(nref.do_while_stmt.cond, owner);
        case AST_FOR:
            if (contract_preservation_validate_stmt(nref.for_stmt.init, owner) == 0) { return 0; }
            if (contract_preservation_validate_expr(nref.for_stmt.cond, owner) == 0) { return 0; }
            if (contract_preservation_validate_stmt(nref.for_stmt.update, owner) == 0) { return 0; }
            return contract_preservation_validate_stmt(nref.for_stmt.body, owner);
        case AST_SWITCH:
        case AST_MATCH:
            if (contract_preservation_validate_expr(nref.switch_stmt.expr, owner) == 0) { return 0; }
            if (nref.switch_stmt.cases_vec != 0) {
                var cs_n: u64 = nref.switch_stmt.cases_vec.len();
                for (var csi: u64 = 0; csi < cs_n; csi++) {
                    var cs: *AstCase = nref.switch_stmt.cases_vec.get(csi);
                    if (cs == 0) { continue; }
                    if (cs.is_default == 0 && contract_preservation_validate_expr(cs.value, owner) == 0) { return 0; }
                    if (contract_preservation_validate_stmt(cs.body, owner) == 0) { return 0; }
                }
            }
            return 1;
        case AST_BLOCK:
            if (nref.block_stmt.stmts_vec != 0) {
                var st_n: u64 = nref.block_stmt.stmts_vec.len();
                for (var si: u64 = 0; si < st_n; si++) {
                    if (contract_preservation_validate_stmt(nref.block_stmt.stmts_vec.get(si), owner) == 0) { return 0; }
                }
            }
            return 1;
    }
    return 1;
}

func contract_preservation_validate_generated_function(fn: *AstFunc) -> u64 {
    if (fn == 0) { return 1; }
    if (contract_preservation_is_generated_decorator_name(fn.name) == 0) { return 1; }
    if (fn.body == 0) {
        contract_preservation_emit_generated_func_error(fn,
            "generated decorator function is missing its function body",
            "decorator lowering must keep generated wrapper bodies intact through later passes");
        return 0;
    }
    var module_info: *NameInfo = sym_get_func_module(fn.name);
    if (module_info == 0) {
        contract_preservation_emit_generated_func_error(fn,
            "generated decorator function lost module ownership",
            "generated wrappers must inherit the original public function module before later passes run");
        return 0;
    }
    var prev_module_ptr: u64 = u8_slice_ptr(g_compiler_ctx.current_module);
    var prev_module_len: u64 = u8_slice_len(g_compiler_ctx.current_module);
    g_compiler_ctx.current_module = slice(module_info.ptr, module_info.len);
    var ok: u64 = contract_preservation_validate_stmt(fn.body, fn);
    g_compiler_ctx.current_module = slice(prev_module_ptr, prev_module_len);
    return ok;
}

func contract_preservation_validate_property_hooks() -> u64 {
    if (g_compiler_ctx.all_structs_vec == 0) { return 1; }
    var sn: u64 = g_compiler_ctx.all_structs_vec.len();
    for (var si: u64 = 0; si < sn; si++) {
        if (diag_should_stop_pass() != 0) { return 0; }
        var sd: *AstStructDef = g_compiler_ctx.all_structs_vec.get(si);
        if (sd == 0 || sd.fields_vec == 0) { continue; }
        var fn: u64 = sd.fields_vec.len();
        for (var fi: u64 = 0; fi < fn; fi++) {
            var field: *FieldDesc = sd.fields_vec.get(fi);
            if (field == 0) { continue; }
            if (u8_slice_ptr(field.setter_hook) != 0 && u8_slice_len(field.setter_hook) != 0 && sym_func_exists(field.setter_hook) == 0) {
                property_hook_emit_field_error(field, "setter contract was not preserved after annotation expansion");
                property_hook_emit_setter_contract(field);
                contract_preservation_emit_surface_for_name(field.setter_hook);
                diag_emit_help("property setter hooks must still resolve to a callable function after decorator lowering");
                return 0;
            }
            if (u8_slice_ptr(field.getter_hook) != 0 && u8_slice_len(field.getter_hook) != 0 && sym_func_exists(field.getter_hook) == 0) {
                property_hook_emit_field_error(field, "getter contract was not preserved after annotation expansion");
                property_hook_emit_getter_contract(field);
                contract_preservation_emit_surface_for_name(field.getter_hook);
                diag_emit_help("property getter hooks must still resolve to a callable function after decorator lowering");
                return 0;
            }
        }
    }
    return 1;
}

func contract_preservation_validate_complexity_surfaces() -> u64 {
    if (g_compiler_ctx.all_funcs == 0) { return 1; }
    var n: u64 = g_compiler_ctx.all_funcs.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        if (diag_should_stop_pass() != 0) { return 0; }
        var fn: *AstFunc = g_compiler_ctx.all_funcs.get(i);
        if (fn == 0) { continue; }
        var contract_annotations: *Vec<*NameInfo> = annotation_surface_contract_annotations_registered(fn.name);
        if (contract_annotations == 0 && annotation_has_surface_contract_annotation(fn) != 0) {
            contract_annotations = fn.annotations_vec;
        }
        if (contract_annotations == 0) { continue; }
        if (annotation_validate_surface_contract_annotations(fn, contract_annotations) == 0) { return 0; }
        if (contract_preservation_is_generated_decorator_name(fn.name) != 0) {
            diag_emit_error_tag("validation", "contract-preservation", "contract metadata drifted onto hidden generated function");
            contract_preservation_emit_surface_for_fn(fn);
            annotation_emit_complexity_contract_origins(contract_annotations);
            diag_emit_help("the final callable surface should own declared contracts; hidden generated wrappers should not become the public contract surface");
            diag_note_error();
            return 0;
        }
    }
    return 1;
}

func contract_preservation_validate_entry() -> u64 {
    if (u8_slice_ptr(g_compiler_ctx.entry_func) == 0 || u8_slice_len(g_compiler_ctx.entry_func) == 0) { return 1; }
    if (sym_func_exists(g_compiler_ctx.entry_func) == 0) {
        diag_emit_error_tag("validation", "contract-preservation", "entry contract was not preserved after annotation expansion");
        contract_preservation_emit_surface_for_name(g_compiler_ctx.entry_func);
        diag_emit_help("the final entry surface must remain a callable top-level function after decoration");
        diag_note_error();
        return 0;
    }
    var entry_fn: *AstFunc = sym_get_func(g_compiler_ctx.entry_func);
    if (entry_fn == 0) {
        diag_emit_error_tag("validation", "contract-preservation", "entry function metadata is missing after annotation expansion");
        contract_preservation_emit_surface_for_name(g_compiler_ctx.entry_func);
        diag_emit_help("entry lookup should still map to a concrete top-level function after decorator expansion");
        diag_note_error();
        return 0;
    }
    var entry_param_n: u64 = 0;
    if (entry_fn.params_vec != 0) { entry_param_n = entry_fn.params_vec.len(); }
    if (entry_param_n != 0) {
        diag_emit_error_tag("validation", "contract-preservation", "entry function contract drifted after annotation expansion");
        contract_preservation_emit_surface_for_fn(entry_fn);
        diag_emit_help("the final entry surface must remain zero-argument after decorator expansion");
        diag_note_error();
        return 0;
    }
    return 1;
}

func validate_contract_preservation() -> u64 {
    if (contract_preservation_validate_property_hooks() == 0) { return 1; }
    if (contract_preservation_validate_complexity_surfaces() == 0) { return 1; }
    if (g_compiler_ctx.all_funcs != 0) {
        var n: u64 = g_compiler_ctx.all_funcs.len();
        for (var i: u64 = 0; i < n; i++) {
            if (diag_should_stop_pass() != 0) { return 1; }
            if (contract_preservation_validate_generated_function(g_compiler_ctx.all_funcs.get(i)) == 0) {
                return 1;
            }
        }
    }
    if (contract_preservation_validate_entry() == 0) { return 1; }
    return 0;
}

func validate_contract_preservation_with_ctx(ctx: *CompilerCtx) -> u64 {
    if (compiler_ctx_is_active(ctx) == 0) {
        diag_emit_error_tag("validation", "internal", "validate_contract_preservation_with_ctx requires active compiler context");
        diag_note_error();
        return 1;
    }
    return validate_contract_preservation();
}

func validate_direct_impl_calls_pass() -> u64 {
    return validate_direct_impl_calls_with_ctx(compiler_ctx_current());
}

func validate_impl_overrides_pass() -> u64 {
    return validate_impl_overrides_with_ctx(compiler_ctx_current());
}

func validate_finalize_abst_methods_pass() -> u64 {
    return validate_finalize_abst_methods_with_ctx(compiler_ctx_current());
}

func validate_finalize_traits_pass() -> u64 {
    return validate_finalize_traits_with_ctx(compiler_ctx_current());
}

func validate_apply_annotations_pass() -> u64 {
    return validate_apply_annotations_with_ctx(compiler_ctx_current());
}

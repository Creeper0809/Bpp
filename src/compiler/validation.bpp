// compiler_validation.b - Validation/finalization pass contract

import compiler;
import compiler.trait_runtime;
import compiler.virtual_dispatch_runtime;
import compiler.core_utils;
import compiler.generic.engine;
import compiler.symbol_runtime;
import compiler.annotations;
import compiler.ast_lowering;
import module_utils;
import std.io;
import std.hashmap;
import std.str;
import std.vec;
import types;
import ast;

func property_hook_emit_field_error(field: *FieldDesc, msg: u64) -> u64 {
    diag_emit_error_tag("validation", "field-hook", msg);
    emit_stderr("[NOTE] field: ");
    if (field != 0) {
        emit_stderr_len(field.owner_struct_ptr, field.owner_struct_len);
        emit_stderr(".");
        emit_stderr_len(field.name_ptr, field.name_len);
    } else {
        emit_stderr("<field>");
    }
    emit_stderr_nl();
    diag_note_error();
    return 0;
}

func property_hook_build_name(struct_ptr: u64, struct_len: u64, mid_ptr: u64, mid_len: u64, field_ptr: u64, field_len: u64) -> *NameInfo {
    var p1: *NameInfo = module_util_build_joined_name(struct_ptr, struct_len, mid_ptr, mid_len);
    return module_util_build_joined_name(p1.ptr, p1.len, field_ptr, field_len);
}

func property_hook_field_matches_param(field: *FieldDesc, param: *Param) -> u64 {
    if (field == 0 || param == 0) { return 0; }
    if (param.is_variadic != 0 || param.has_default != 0) { return 0; }
    if (field.type_kind != param.type_kind) { return 0; }
    if (field.ptr_depth != param.ptr_depth) { return 0; }
    if (field.type_kind == TYPE_STRUCT || field.type_kind == TYPE_GENERIC || field.type_kind == TYPE_TRAIT) {
        if (str_eq(field.struct_name_ptr, field.struct_name_len, param.struct_name_ptr, param.struct_name_len) == 0 &&
            property_hook_name_matches(param.struct_name_ptr, param.struct_name_len, field.struct_name_ptr, field.struct_name_len) == 0 &&
            property_hook_name_matches(field.struct_name_ptr, field.struct_name_len, param.struct_name_ptr, param.struct_name_len) == 0) {
            return 0;
        }
    }
    return 1;
}

func property_hook_field_matches_return(field: *FieldDesc, fn: *AstFunc) -> u64 {
    if (field == 0 || fn == 0) { return 0; }
    if (field.type_kind != fn.ret_type) { return 0; }
    if (field.ptr_depth != fn.ret_ptr_depth) { return 0; }
    if (field.type_kind == TYPE_STRUCT || field.type_kind == TYPE_GENERIC || field.type_kind == TYPE_TRAIT) {
        if (str_eq(field.struct_name_ptr, field.struct_name_len, fn.ret_struct_name_ptr, fn.ret_struct_name_len) == 0 &&
            property_hook_name_matches(fn.ret_struct_name_ptr, fn.ret_struct_name_len, field.struct_name_ptr, field.struct_name_len) == 0 &&
            property_hook_name_matches(field.struct_name_ptr, field.struct_name_len, fn.ret_struct_name_ptr, fn.ret_struct_name_len) == 0) {
            return 0;
        }
    }
    return 1;
}

func property_hook_validate_self_param(field: *FieldDesc, self_param: *Param) -> u64 {
    if (field == 0 || self_param == 0) { return 0; }
    if (self_param.is_variadic != 0 || self_param.has_default != 0) { return 0; }
    if (self_param.type_kind != TYPE_STRUCT || self_param.ptr_depth != 1 || self_param.is_tagged != 0) { return 0; }
    if (str_eq(self_param.struct_name_ptr, self_param.struct_name_len, field.owner_struct_ptr, field.owner_struct_len) == 0) {
        if (property_hook_name_matches(self_param.struct_name_ptr, self_param.struct_name_len, field.owner_struct_ptr, field.owner_struct_len) == 0 &&
            property_hook_name_matches(field.owner_struct_ptr, field.owner_struct_len, self_param.struct_name_ptr, self_param.struct_name_len) == 0) {
            return 0;
        }
    }
    return 1;
}

func property_hook_name_matches(cand_ptr: u64, cand_len: u64, hook_ptr: u64, hook_len: u64) -> u64 {
    if (cand_ptr == 0 || cand_len == 0 || hook_ptr == 0 || hook_len == 0) { return 0; }
    if (str_eq(cand_ptr, cand_len, hook_ptr, hook_len) != 0) { return 1; }
    if (cand_len <= hook_len) { return 0; }
    var suffix_ptr: u64 = cand_ptr + (cand_len - hook_len);
    if (str_eq(suffix_ptr, hook_len, hook_ptr, hook_len) == 0) { return 0; }
    var s: []u8 = slice(cand_ptr, cand_len);
    if (s[cand_len - hook_len - 1] != 95) { return 0; } // '_'
    return 1;
}

func property_hook_parse_field_annotations(field: *FieldDesc) -> u64 {
    if (field == 0 || field.annotations_vec == 0) { return 1; }
    var anns: *Vec<*NameInfo> = field.annotations_vec;
    var n: u64 = anns.len();
    for (var i: u64 = 0; i < n; i++) {
        var info: *NameInfo = anns.get(i);
        var ann: *CompilerAnnotationParsed = annotation_parse(info);
        if (ann == 0 || ann.parse_ok == 0 || ann.name_ptr == 0 || ann.name_len == 0) {
            property_hook_emit_field_error(field, "malformed field annotation");
            return 0;
        }

        if (str_eq(ann.name_ptr, ann.name_len, "setter", 6) != 0 ||
            str_eq(ann.name_ptr, ann.name_len, "getter", 6) != 0) {
            property_hook_emit_field_error(field, "field hooks no longer use annotation syntax");
            diag_emit_help("write property(...) before the access modifier, e.g. property(setter) public value: i32;");
            return 0;
        }
        property_hook_emit_field_error(field, "field annotations are not supported here");
        return 0;
    }
    return 1;
}

func property_hook_validate_manual_setter(field: *FieldDesc) -> u64 {
    if (field == 0) { return 1; }
    if (field.setter_hook_mode != FIELD_HOOK_MANUAL) { return 1; }
    var any_name_match: u64 = 0;

    if (g_compiler_ctx.all_funcs != 0) {
        var n: u64 = g_compiler_ctx.all_funcs.len();
        for (var i: u64 = 0; i < n; i++) {
            var fn: *AstFunc = g_compiler_ctx.all_funcs.get(i);
            if (fn == 0) { continue; }
            if (property_hook_name_matches(fn.name_ptr, fn.name_len, field.setter_hook_ptr, field.setter_hook_len) == 0) { continue; }
            any_name_match = 1;
            var params: *Vec<*Param> = fn.params_vec;
            if (params == 0 || params.len() != 2) { continue; }
            var p0: *Param = params.get(0);
            var p1: *Param = params.get(1);
            if (property_hook_validate_self_param(field, p0) == 0) { continue; }
            if (property_hook_field_matches_param(field, p1) == 0) { continue; }
            if (fn.ret_type != TYPE_VOID || fn.ret_ptr_depth != 0) { continue; }
            field.setter_hook_ptr = fn.name_ptr;
            field.setter_hook_len = fn.name_len;
            return 1;
        }
    }
    if (g_compiler_ctx.all_func_sigs != 0) {
        var sn: u64 = g_compiler_ctx.all_func_sigs.len();
        for (var j: u64 = 0; j < sn; j++) {
            var sig: *AstFunc = g_compiler_ctx.all_func_sigs.get(j);
            if (sig == 0) { continue; }
            if (property_hook_name_matches(sig.name_ptr, sig.name_len, field.setter_hook_ptr, field.setter_hook_len) == 0) { continue; }
            any_name_match = 1;
            var sparams: *Vec<*Param> = sig.params_vec;
            if (sparams == 0 || sparams.len() != 2) { continue; }
            var sp0: *Param = sparams.get(0);
            var sp1: *Param = sparams.get(1);
            if (property_hook_validate_self_param(field, sp0) == 0) { continue; }
            if (property_hook_field_matches_param(field, sp1) == 0) { continue; }
            if (sig.ret_type != TYPE_VOID || sig.ret_ptr_depth != 0) { continue; }
            field.setter_hook_ptr = sig.name_ptr;
            field.setter_hook_len = sig.name_len;
            return 1;
        }
    }

    if (any_name_match == 0) {
        property_hook_emit_field_error(field, "setter hook function not found");
        return 0;
    }
    property_hook_emit_field_error(field, "setter hook signature mismatch");
    return 0;
}

func property_hook_validate_manual_getter(field: *FieldDesc) -> u64 {
    if (field == 0) { return 1; }
    if (field.getter_hook_mode != FIELD_HOOK_MANUAL) { return 1; }
    var any_name_match: u64 = 0;

    if (g_compiler_ctx.all_funcs != 0) {
        var n: u64 = g_compiler_ctx.all_funcs.len();
        for (var i: u64 = 0; i < n; i++) {
            var fn: *AstFunc = g_compiler_ctx.all_funcs.get(i);
            if (fn == 0) { continue; }
            if (property_hook_name_matches(fn.name_ptr, fn.name_len, field.getter_hook_ptr, field.getter_hook_len) == 0) { continue; }
            any_name_match = 1;
            var params: *Vec<*Param> = fn.params_vec;
            if (params == 0 || params.len() != 1) { continue; }
            var p0: *Param = params.get(0);
            if (property_hook_validate_self_param(field, p0) == 0) { continue; }
            if (property_hook_field_matches_return(field, fn) == 0) { continue; }
            field.getter_hook_ptr = fn.name_ptr;
            field.getter_hook_len = fn.name_len;
            return 1;
        }
    }
    if (g_compiler_ctx.all_func_sigs != 0) {
        var sn: u64 = g_compiler_ctx.all_func_sigs.len();
        for (var j: u64 = 0; j < sn; j++) {
            var sig: *AstFunc = g_compiler_ctx.all_func_sigs.get(j);
            if (sig == 0) { continue; }
            if (property_hook_name_matches(sig.name_ptr, sig.name_len, field.getter_hook_ptr, field.getter_hook_len) == 0) { continue; }
            any_name_match = 1;
            var sparams: *Vec<*Param> = sig.params_vec;
            if (sparams == 0 || sparams.len() != 1) { continue; }
            var sp0: *Param = sparams.get(0);
            if (property_hook_validate_self_param(field, sp0) == 0) { continue; }
            if (property_hook_field_matches_return(field, sig) == 0) { continue; }
            field.getter_hook_ptr = sig.name_ptr;
            field.getter_hook_len = sig.name_len;
            return 1;
        }
    }

    if (any_name_match == 0) {
        property_hook_emit_field_error(field, "getter hook function not found");
        return 0;
    }
    property_hook_emit_field_error(field, "getter hook signature mismatch");
    return 0;
}

func property_hook_create_value_param(field: *FieldDesc) -> *Param {
    var p: *Param = new Param{};
    p.name_ptr = (u64)"val";
    p.name_len = 3;
    p.type_kind = field.type_kind;
    p.ptr_depth = field.ptr_depth;
    p.is_tagged = field.is_tagged;
    p.struct_name_ptr = field.struct_name_ptr;
    p.struct_name_len = field.struct_name_len;
    p.tag_layout_ptr = field.tag_layout_ptr;
    p.tag_layout_len = field.tag_layout_len;
    p.elem_type_kind = field.elem_type_kind;
    p.elem_ptr_depth = field.elem_ptr_depth;
    p.array_len = field.array_len;
    p.elem_typeinfo = field.elem_typeinfo;
    p.is_variadic = 0;
    p.has_default = 0;
    return p;
}

func property_hook_create_auto_setter(field: *FieldDesc) -> u64 {
    if (field == 0 || field.setter_hook_mode != FIELD_HOOK_AUTO) { return 1; }
    var name: *NameInfo = property_hook_build_name(field.owner_struct_ptr, field.owner_struct_len, "set", 3, field.name_ptr, field.name_len);
    if (sym_func_exists(name.ptr, name.len) != 0) {
        property_hook_emit_field_error(field, "auto setter name collision");
        return 0;
    }

    var params: *Vec<*Param> = new Vec<*Param>{heap_alloc((2) * sizeof(*Param)), 0, (2)};
    var self_param: *Param = new Param{};
    self_param.set_as_self_param(field.owner_struct_ptr, field.owner_struct_len);
    params.push(self_param);
    params.push(property_hook_create_value_param(field));

    var stmts: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((1) * sizeof(*AstNode)), 0, (1)};
    var target: *AstNode = ast_raw_member_access((*AstNode)ast_ident("self", 4), field.name_ptr, field.name_len);
    var value: *AstNode = ast_ident("val", 3);
    stmts.push((*AstNode)ast_assign(target, value));
    var body: *AstNode = (*AstNode)ast_block(stmts);

    var fn: *AstFunc = ast_func_ex(name.ptr, name.len, params, TYPE_VOID, 0, 0, 0, 0, 0, 0, body);
    if (g_compiler_ctx.all_funcs == 0) { g_compiler_ctx.all_funcs = new Vec<*AstFunc>{heap_alloc((8) * sizeof(*AstFunc)), 0, (8)}; }
    if (g_compiler_ctx.all_func_sigs == 0) { g_compiler_ctx.all_func_sigs = new Vec<*AstFunc>{heap_alloc((8) * sizeof(*AstFunc)), 0, (8)}; }
    g_compiler_ctx.all_funcs.push(fn);
    g_compiler_ctx.all_func_sigs.push(annotation_clone_sig(fn, fn.name_ptr, fn.name_len));
    sym_invalidate_func_lookup();

    field.setter_hook_ptr = name.ptr;
    field.setter_hook_len = name.len;
    return 1;
}

func property_hook_create_auto_getter(field: *FieldDesc) -> u64 {
    if (field == 0 || field.getter_hook_mode != FIELD_HOOK_AUTO) { return 1; }
    var name: *NameInfo = property_hook_build_name(field.owner_struct_ptr, field.owner_struct_len, "get", 3, field.name_ptr, field.name_len);
    if (sym_func_exists(name.ptr, name.len) != 0) {
        property_hook_emit_field_error(field, "auto getter name collision");
        return 0;
    }

    var ret_type: u64 = field.type_kind;
    var ret_ptr_depth: u64 = field.ptr_depth;
    var ret_is_tagged: u64 = field.is_tagged;
    var ret_struct_ptr: u64 = field.struct_name_ptr;
    var ret_struct_len: u64 = field.struct_name_len;
    var ret_tag_ptr: u64 = field.tag_layout_ptr;
    var ret_tag_len: u64 = field.tag_layout_len;
    if (field.type_kind == TYPE_ARRAY) {
        ret_type = field.elem_type_kind;
        ret_ptr_depth = field.elem_ptr_depth + 1;
        ret_is_tagged = 0;
        ret_tag_ptr = 0;
        ret_tag_len = 0;
    }

    var params: *Vec<*Param> = new Vec<*Param>{heap_alloc((1) * sizeof(*Param)), 0, (1)};
    var self_param: *Param = new Param{};
    self_param.set_as_self_param(field.owner_struct_ptr, field.owner_struct_len);
    params.push(self_param);

    var stmts: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((1) * sizeof(*AstNode)), 0, (1)};
    var value: *AstNode = ast_raw_member_access((*AstNode)ast_ident("self", 4), field.name_ptr, field.name_len);
    stmts.push((*AstNode)ast_return(value));
    var body: *AstNode = (*AstNode)ast_block(stmts);

    var fn: *AstFunc = ast_func_ex(name.ptr, name.len, params, ret_type, ret_ptr_depth, ret_is_tagged, ret_struct_ptr, ret_struct_len, ret_tag_ptr, ret_tag_len, body);
    if (g_compiler_ctx.all_funcs == 0) { g_compiler_ctx.all_funcs = new Vec<*AstFunc>{heap_alloc((8) * sizeof(*AstFunc)), 0, (8)}; }
    if (g_compiler_ctx.all_func_sigs == 0) { g_compiler_ctx.all_func_sigs = new Vec<*AstFunc>{heap_alloc((8) * sizeof(*AstFunc)), 0, (8)}; }
    g_compiler_ctx.all_funcs.push(fn);
    g_compiler_ctx.all_func_sigs.push(annotation_clone_sig(fn, fn.name_ptr, fn.name_len));
    sym_invalidate_func_lookup();

    field.getter_hook_ptr = name.ptr;
    field.getter_hook_len = name.len;
    return 1;
}

func property_hooks_finalize() -> u64 {
    if (g_compiler_ctx.all_structs_vec == 0) { return 0; }
    var sn: u64 = g_compiler_ctx.all_structs_vec.len();
    for (var si: u64 = 0; si < sn; si++) {
        if (diag_should_stop_pass() != 0) { break; }
        var sd: *AstStructDef = g_compiler_ctx.all_structs_vec.get(si);
        if (sd == 0 || sd.fields_vec == 0) { continue; }
        var fields: *Vec<*FieldDesc> = sd.fields_vec;
        var fn: u64 = fields.len();
        for (var fi: u64 = 0; fi < fn; fi++) {
            if (diag_should_stop_pass() != 0) { break; }
            var field: *FieldDesc = fields.get(fi);
            if (field == 0) { continue; }
            if (property_hook_parse_field_annotations(field) == 0) { continue; }
            if (property_hook_create_auto_setter(field) == 0) { continue; }
            if (property_hook_create_auto_getter(field) == 0) { continue; }
            if (property_hook_validate_manual_setter(field) == 0) { continue; }
            property_hook_validate_manual_getter(field);
        }
    }
    return 0;
}

func validate_global_function_name_collisions_core() -> u64 {
    if (g_compiler_ctx.all_funcs == 0 || g_compiler_ctx.all_globals == 0) { return 0; }

    var func_n: u64 = g_compiler_ctx.all_funcs.len();
    var global_n: u64 = g_compiler_ctx.all_globals.len();
    var cap: u64 = (func_n * 2) + 16;
    var top_level_funcs: *HashMap<u64, u64> = new HashMap<u64, u64>{0, 0, 0};
    top_level_funcs.ensure_capacity(cap);

    for (var fi: u64 = 0; fi < func_n; fi++) {
        var fn: *AstFunc = g_compiler_ctx.all_funcs.get(fi);
        if (fn == 0) { continue; }
        if (fn.impl_owner_ptr != 0 && fn.impl_owner_len != 0) { continue; }
        top_level_funcs.put(fn.name_ptr, fn.name_len, 1);
    }

    for (var gi: u64 = 0; gi < global_n; gi++) {
        var ginfo: *GlobalInfo = g_compiler_ctx.all_globals.get(gi);
        if (ginfo == 0) { continue; }
        if (top_level_funcs.has(ginfo.name_ptr, ginfo.name_len) == 0) { continue; }
        emit_stderr("[ERROR] global variable conflicts with function name: ");
        emit_stderr_len(ginfo.name_ptr, ginfo.name_len);
        emit_stderr("\n");
        diag_note_error();
    }
    return 0;
}

func validate_child_implements_abst_method(sd: *AstStructDef, mi: *NameInfo) -> u64 {
    if (sym_is_abst_method(sd.name_ptr, sd.name_len, mi.ptr, mi.len) != 0) {
        return 0;
    }
    var found_impl: *AstFunc = find_method_func_in_hierarchy(sd, mi.ptr, mi.len);
    if (found_impl == 0) {
        emit_stderr("[ERROR] Missing abstract method implementation in child: ");
        emit_stderr_len(sd.name_ptr, sd.name_len);
        emit_stderr(".");
        emit_stderr_len(mi.ptr, mi.len);
        emit_stderr("\n");
        diag_note_error();
    }
    return 0;
}

func validate_direct_impl_calls_core() -> u64 {
    validate_global_function_name_collisions_core();
    if (diag_should_stop_pass() != 0) { return 0; }

    if (g_compiler_ctx.all_funcs != 0) {
        var fn_count: u64 = g_compiler_ctx.all_funcs.len();
        for (var i: u64 = 0; i < fn_count; i++) {
            var fn: *AstFunc = g_compiler_ctx.all_funcs.get(i);
            if (fn == 0 || fn.body == 0) { continue; }
            var owner_info: *NameInfo = sym_get_impl_method_owner(fn.name_ptr, fn.name_len);
            var owner_ptr: u64 = 0;
            var owner_len: u64 = 0;
            if (owner_info != 0) {
                owner_ptr = owner_info.ptr;
                owner_len = owner_info.len;
            }
            validate_direct_impl_calls_stmt(fn.body, owner_ptr, owner_len);
        }
    }

    if (g_compiler_ctx.all_globals != 0) {
        var gn: u64 = g_compiler_ctx.all_globals.len();
        for (var gi: u64 = 0; gi < gn; gi++) {
            var ginfo: *GlobalInfo = g_compiler_ctx.all_globals.get(gi);
            if (ginfo == 0 || ginfo.init_expr == 0) { continue; }
            validate_direct_impl_calls_expr((*AstNode)ginfo.init_expr, 0, 0);
        }
    }
    return 0;
}

func finalize_traits() -> u64 {
    trait_validate_all_struct_trait_inheritance();
    if (diag_should_stop_pass() != 0) { return 0; }
    if (g_compiler_ctx.all_trait_impls_vec == 0 || g_compiler_ctx.all_trait_impls_vec.len() == 0) { return 0; }

    var num_impls: u64 = g_compiler_ctx.all_trait_impls_vec.len();
    for (var ii: u64 = 0; ii < num_impls; ii++) {
        if (diag_should_stop_pass() != 0) { break; }
        var impl_info: *TraitImpl = g_compiler_ctx.all_trait_impls_vec.get(ii);
        trait_finalize_single_trait_impl(impl_info);
    }
    return 0;
}

func validate_impl_overrides_core() -> u64 {
    if (g_compiler_ctx.all_func_sigs == 0) { return 0; }
    var n: u64 = g_compiler_ctx.all_func_sigs.len();
    for (var i: u64 = 0; i < n; i++) {
        if (diag_should_stop_pass() != 0) { break; }
        var fn_sig: *AstFunc = g_compiler_ctx.all_func_sigs.get(i);
        vdispatch_validate_single_impl_override(fn_sig);
        if (diag_should_stop_pass() != 0) { break; }
        vdispatch_validate_single_magic_method_contract(fn_sig);
    }
    return 0;
}

func apply_annotations() -> u64 {
    if (g_compiler_ctx.all_funcs == 0) { return 0; }
    property_hooks_finalize();
    if (diag_should_stop_pass() != 0) { return 0; }

    var original_count: u64 = g_compiler_ctx.all_funcs.len();
    var generated_id: u64 = 0;
    var entry_ptr: u64 = 0;
    var entry_len: u64 = 0;

    for (var i: u64 = 0; i < original_count; i++) {
        if (diag_should_stop_pass() != 0) { break; }
        var fn: *AstFunc = g_compiler_ctx.all_funcs.get(i);
        if (fn == 0) { continue; }
        if (annotation_validate_function_annotations(fn) == 0) {
            continue;
        }

        var entry_count: u64 = annotation_count_name(fn.annotations_vec, "entry", 5);
        if (entry_count > 0) {
            if (fn.impl_owner_ptr != 0 && fn.impl_owner_len != 0) {
                diag_emit_error_tag("validation", "entry", "@[entry] is only allowed on top-level functions");
                diag_emit_note("move the entry function out of the impl block");
                diag_note_error();
                continue;
            }
            var entry_param_n: u64 = 0;
            if (fn.params_vec != 0) { entry_param_n = fn.params_vec.len(); }
            if (entry_param_n != 0) {
                diag_emit_error_tag("validation", "entry", "@[entry] function must not declare parameters");
                emit_stderr("[NOTE] function: ");
                emit_stderr_len(fn.name_ptr, fn.name_len);
                emit_stderr_nl();
                diag_note_error();
                continue;
            }
            if (entry_count > 1) {
                diag_emit_error_tag("validation", "entry", "duplicate @[entry] annotation on function");
                emit_stderr("[NOTE] function: ");
                emit_stderr_len(fn.name_ptr, fn.name_len);
                emit_stderr_nl();
                diag_note_error();
                continue;
            }
            if (entry_ptr != 0 && str_eq(entry_ptr, entry_len, fn.name_ptr, fn.name_len) == 0) {
                diag_emit_error_tag("validation", "entry", "multiple @[entry] functions are not allowed");
                emit_stderr("[NOTE] entries: ");
                emit_stderr_len(entry_ptr, entry_len);
                emit_stderr(" and ");
                emit_stderr_len(fn.name_ptr, fn.name_len);
                emit_stderr_nl();
                diag_note_error();
                continue;
            }
            entry_ptr = fn.name_ptr;
            entry_len = fn.name_len;
        }

        var decorators: *Vec<*NameInfo> = annotation_collect_decorators(fn);
        if (decorators == 0 || decorators.len() == 0) { continue; }

        var is_impl_method: u64 = 0;
        if (fn.impl_owner_ptr != 0 && fn.impl_owner_len != 0) {
            is_impl_method = 1;
        }
        if (fn.body == 0) {
            diag_emit_error_tag("validation", "decorator", "function decorator requires a function body");
            emit_stderr("[NOTE] function: ");
            emit_stderr_len(fn.name_ptr, fn.name_len);
            emit_stderr_nl();
            diag_note_error();
            continue;
        }
        if (is_generic_template(fn) != 0) {
            continue;
        }

        var decorators_valid: u64 = 1;
        var deco_n0: u64 = decorators.len();
        for (var di0: u64 = 0; di0 < deco_n0; di0++) {
            var deco0: *NameInfo = decorators.get(di0);
            var sig0: *AstFunc = lower_find_func_signature_for_call(deco0.ptr, deco0.len);
            if (sig0 == 0) {
                diag_emit_error_tag("validation", "decorator", "unresolved decorator function");
                emit_stderr("[NOTE] decorator: ");
                emit_stderr_len(deco0.ptr, deco0.len);
                emit_stderr_nl();
                diag_note_error();
                decorators_valid = 0;
                continue;
            }
            if (annotation_validate_decorator_signature(sig0, fn, deco0.ptr, deco0.len) == 0) {
                decorators_valid = 0;
            }
        }
        if (decorators_valid == 0) { continue; }

        var public_name_ptr: u64 = fn.name_ptr;
        var public_name_len: u64 = fn.name_len;
        var method_owner_ptr: u64 = 0;
        var method_owner_len: u64 = 0;
        var method_access: u64 = ACCESS_PUBLIC;
        var method_original_name_ptr: u64 = 0;
        var method_original_name_len: u64 = 0;
        var method_is_override: u64 = 0;
        if (is_impl_method != 0) {
            method_owner_ptr = fn.impl_owner_ptr;
            method_owner_len = fn.impl_owner_len;
            method_access = fn.impl_method_access;
            method_original_name_ptr = fn.impl_original_name_ptr;
            method_original_name_len = fn.impl_original_name_len;
            if (method_original_name_ptr == 0 || method_original_name_len == 0) {
                method_original_name_ptr = public_name_ptr;
                method_original_name_len = public_name_len;
            }
            method_is_override = fn.impl_is_override;
        }

        generated_id = generated_id + 1;
        var hidden_name: *NameInfo = annotation_build_generated_name("__ann_orig__", 11, public_name_ptr, public_name_len, generated_id);
        fn.name_ptr = hidden_name.ptr;
        fn.name_len = hidden_name.len;
        fn.annotations_vec = 0;

        if (annotation_rename_first_signature(public_name_ptr, public_name_len, hidden_name.ptr, hidden_name.len) == 0) {
            if (g_compiler_ctx.all_func_sigs != 0) {
                g_compiler_ctx.all_func_sigs.push(annotation_clone_sig(fn, hidden_name.ptr, hidden_name.len));
            }
        }
        if (is_impl_method != 0) {
            annotation_clear_impl_metadata(fn);
        }
        var callee_ptr: u64 = hidden_name.ptr;
        var callee_len: u64 = hidden_name.len;
        var deco_n: u64 = decorators.len();
        for (var rev: u64 = 0; rev < deco_n; rev++) {
            var di: u64 = deco_n - rev - 1;
            var deco: *NameInfo = decorators.get(di);
            var deco_sig: *AstFunc = lower_find_func_signature_for_call(deco.ptr, deco.len);
            if (deco_sig == 0) {
                diag_emit_error_tag("validation", "decorator", "unresolved decorator function");
                emit_stderr("[NOTE] decorator: ");
                emit_stderr_len(deco.ptr, deco.len);
                emit_stderr_nl();
                diag_note_error();
                break;
            }
            if (annotation_validate_decorator_signature(deco_sig, fn, deco.ptr, deco.len) == 0) {
                break;
            }

            var wrapper_name_ptr: u64 = 0;
            var wrapper_name_len: u64 = 0;
            if (di == 0) {
                wrapper_name_ptr = public_name_ptr;
                wrapper_name_len = public_name_len;
            } else {
                generated_id = generated_id + 1;
                var wrap_name: *NameInfo = annotation_build_generated_name("__ann_wrap__", 11, public_name_ptr, public_name_len, generated_id);
                wrapper_name_ptr = wrap_name.ptr;
                wrapper_name_len = wrap_name.len;
            }

            var keep_impl_metadata: u64 = 0;
            if (is_impl_method != 0 && di == 0) { keep_impl_metadata = 1; }
            var wrapper_fn: *AstFunc = annotation_build_wrapper_func(fn, wrapper_name_ptr, wrapper_name_len, deco.ptr, deco.len, callee_ptr, callee_len, 0);
            if (keep_impl_metadata != 0) {
                annotation_set_impl_metadata(wrapper_fn,
                    method_owner_ptr, method_owner_len, method_access,
                    method_original_name_ptr, method_original_name_len, method_is_override);
            }
            g_compiler_ctx.all_funcs.push(wrapper_fn);
            if (keep_impl_metadata != 0) {
                sym_register_impl_method_ex(wrapper_fn.name_ptr, wrapper_fn.name_len, method_owner_ptr, method_owner_len, method_access);
                if (g_compiler_ctx.impl_method_funcs == 0) {
                    g_compiler_ctx.impl_method_funcs = new HashMap<u64, *AstFunc>{0, 0, 0};
                    g_compiler_ctx.impl_method_funcs.ensure_capacity(64);
                }
                g_compiler_ctx.impl_method_funcs.put(wrapper_fn.name_ptr, wrapper_fn.name_len, wrapper_fn);
            }
            if (g_compiler_ctx.all_func_sigs != 0) {
                g_compiler_ctx.all_func_sigs.push(annotation_clone_sig(wrapper_fn, wrapper_name_ptr, wrapper_name_len));
            }
            callee_ptr = wrapper_name_ptr;
            callee_len = wrapper_name_len;
        }
    }

    g_compiler_ctx.entry_func_ptr = entry_ptr;
    g_compiler_ctx.entry_func_len = entry_len;
    sym_invalidate_func_lookup();
    if (annotation_complexity_validate_std_library_summaries() == 0) { return 0; }
    return 0;
}

func finalize_abst_methods() -> u64 {
    if (g_compiler_ctx.all_structs_vec == 0) { return 0; }
    var sn: u64 = g_compiler_ctx.all_structs_vec.len();
    for (var si: u64 = 0; si < sn; si++) {
        if (diag_should_stop_pass() != 0) { break; }
        var sd: *AstStructDef = g_compiler_ctx.all_structs_vec.get(si);
        if (sd == 0 || sd.parents_vec == 0) { continue; }
        var required: *Vec<*NameInfo> = new Vec<*NameInfo>{heap_alloc((8) * sizeof(*NameInfo)), 0, (8)};
        vdispatch_collect_abst_methods_recursive(sd, required);
        var rn: u64 = required.len();
        for (var ri: u64 = 0; ri < rn; ri++) {
            if (diag_should_stop_pass() != 0) { break; }
            var mi: *NameInfo = required.get(ri);
            validate_child_implements_abst_method(sd, mi);
        }
    }
    vdispatch_setup_traits();
    return 0;
}

func validate_direct_impl_calls_with_ctx(ctx: *CompilerCtx) -> u64 {
    if (compiler_ctx_is_active(ctx) == 0) {
        diag_emit_error_tag("validation", "internal", "validate_direct_impl_calls_with_ctx requires active compiler context");
        diag_note_error();
        return 1;
    }
    return validate_direct_impl_calls_core();
}

func validate_impl_overrides_with_ctx(ctx: *CompilerCtx) -> u64 {
    if (compiler_ctx_is_active(ctx) == 0) {
        diag_emit_error_tag("validation", "internal", "validate_impl_overrides_with_ctx requires active compiler context");
        diag_note_error();
        return 1;
    }
    return validate_impl_overrides_core();
}

func validate_finalize_abst_methods_with_ctx(ctx: *CompilerCtx) -> u64 {
    if (compiler_ctx_is_active(ctx) == 0) {
        diag_emit_error_tag("validation", "internal", "validate_finalize_abst_methods_with_ctx requires active compiler context");
        diag_note_error();
        return 1;
    }
    return finalize_abst_methods();
}

func validate_finalize_traits_with_ctx(ctx: *CompilerCtx) -> u64 {
    if (compiler_ctx_is_active(ctx) == 0) {
        diag_emit_error_tag("validation", "internal", "validate_finalize_traits_with_ctx requires active compiler context");
        diag_note_error();
        return 1;
    }
    return finalize_traits();
}

func validate_apply_annotations_with_ctx(ctx: *CompilerCtx) -> u64 {
    if (compiler_ctx_is_active(ctx) == 0) {
        diag_emit_error_tag("validation", "internal", "validate_apply_annotations_with_ctx requires active compiler context");
        diag_note_error();
        return 1;
    }
    return apply_annotations();
}

func validate_direct_impl_calls_pass() -> u64 {
    return validate_direct_impl_calls_with_ctx(compiler_ctx_current());
}

func validate_impl_overrides_pass() -> u64 {
    return validate_impl_overrides_with_ctx(compiler_ctx_current());
}

func validate_finalize_abst_methods_pass() -> u64 {
    return validate_finalize_abst_methods_with_ctx(compiler_ctx_current());
}

func validate_finalize_traits_pass() -> u64 {
    return validate_finalize_traits_with_ctx(compiler_ctx_current());
}

func validate_apply_annotations_pass() -> u64 {
    return validate_apply_annotations_with_ctx(compiler_ctx_current());
}

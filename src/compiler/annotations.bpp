                }
            }
            return 0;
        case AST_IF:
            var ifs: *AstIf = (*AstIf)stmt;
            if (annotation_complexity_expr_has_binary_op(ifs.cond, op) != 0) { return 1; }
            if (annotation_complexity_stmt_has_binary_op(ifs.then_block, op) != 0) { return 1; }

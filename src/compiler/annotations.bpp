    var fb: u64 = annotation_complexity_constraints_max(constraints_ann);
    var out: u64 = annotation_complexity_eval_expr_inner(norm.ptr, norm.len, &pos, constraints_ann, fb, &ok);
    if (ok == 0 || pos != norm.len) { return 0; }
    *out_ok = 1;
    return out;
}

func annotation_complexity_constraint_lookup_from_relations(constraints_ann: *CompilerAnnotationParsed, key_ptr: u64, key_len: u64, out_value: *u64) -> u64 {
    if (out_value == 0 || constraints_ann == 0 || constraints_ann.args_vec == 0 || key_ptr == 0 || key_len == 0) { return 0; }
    var known: *CompilerAnnotationParsed = annotation_complexity_constraints_int_only(constraints_ann);
    var rel_n: u64 = constraints_ann.args_vec.len();
    var pass_limit: u64 = rel_n + 2;
    if (pass_limit < 2) { pass_limit = 2; }
    for (var pass: u64 = 0; pass < pass_limit; pass++) {
        var changed: u64 = 0;
        for (var i: u64 = 0; i < rel_n; i++) {
            var a: *CompilerAnnotationArg = constraints_ann.args_vec.get(i);
            if (a == 0 || a.key_ptr == 0 || a.key_len == 0 || a.kind != 3) { continue; }
            if (annotation_complexity_constraints_is_relation_key(a.key_ptr, a.key_len) == 0) { continue; }
            var rel_changed: u64 = 0;
            if (annotation_complexity_apply_relation_spec(known, a.string_ptr, a.string_len, &rel_changed) == 0) { continue; }
            if (rel_changed != 0) { changed = 1; }
        }
        if (changed == 0) { break; }
    }

    return annotation_complexity_constraint_lookup_direct(known, key_ptr, key_len, out_value);
}

func annotation_complexity_constraints_scaled(constraints_ann: *CompilerAnnotationParsed, scale: u64) -> *CompilerAnnotationParsed {
    var cap: u64 = 9223372036854775807;
    var out: *CompilerAnnotationParsed = new CompilerAnnotationParsed();
    out.parse_ok = 1;
    out.args_vec = new Vec<*CompilerAnnotationArg>(0);
    if (constraints_ann == 0 || constraints_ann.args_vec == 0) { return out; }
    var n: u64 = constraints_ann.args_vec.len();
    for (var i: u64 = 0; i < n; i++) {
        var a: *CompilerAnnotationArg = constraints_ann.args_vec.get(i);
        if (a == 0 || a.key_ptr == 0 || a.key_len == 0) { continue; }
        var b: *CompilerAnnotationArg = new CompilerAnnotationArg();
        b.key_ptr = a.key_ptr;
        b.key_len = a.key_len;
        b.kind = a.kind;
        b.string_ptr = a.string_ptr;
        b.string_len = a.string_len;
        b.ident_ptr = a.ident_ptr;
        b.ident_len = a.ident_len;
        b.bool_value = a.bool_value;
        b.int_value = a.int_value;
        if (a.kind == 2 && scale > 1) {
            b.int_value = annotation_complexity_sat_mul(a.int_value, scale, cap);
        }
        out.args_vec.push(b);
    }
    return out;
}

func annotation_complexity_apply_input_aliases(fn: *AstFunc, constraints_ann: *CompilerAnnotationParsed) -> *CompilerAnnotationParsed {
    if (fn == 0 || constraints_ann == 0) { return constraints_ann; }
    var input_ann: *CompilerAnnotationParsed = annotation_complexity_get_single(fn, "complexity_input", 16);
    if (input_ann == 0 || input_ann.args_vec == 0) { return constraints_ann; }

    var out: *CompilerAnnotationParsed = annotation_complexity_constraints_scaled(constraints_ann, 1);
    if (out == 0 || out.args_vec == 0) { return constraints_ann; }

    var n: u64 = input_ann.args_vec.len();
    for (var i: u64 = 0; i < n; i++) {
        var map_arg: *CompilerAnnotationArg = input_ann.args_vec.get(i);
        if (map_arg == 0 || map_arg.key_ptr == 0 || map_arg.key_len == 0) { continue; }
        var target_ptr: u64 = 0;
        var target_len: u64 = 0;
        if (annotation_complexity_extract_input_target_ident(map_arg, &target_ptr, &target_len) == 0) { continue; }

        var key_v: u64 = 0;
        var target_v: u64 = 0;
        var has_key: u64 = annotation_complexity_constraint_lookup(out, map_arg.key_ptr, map_arg.key_len, &key_v);
        var has_target: u64 = annotation_complexity_constraint_lookup(out, target_ptr, target_len, &target_v);
        if (has_key != 0 && has_target == 0) {
            annotation_complexity_constraints_upsert_int(out, target_ptr, target_len, key_v);
        } else if (has_target != 0 && has_key == 0) {
            annotation_complexity_constraints_upsert_int(out, map_arg.key_ptr, map_arg.key_len, target_v);
        } else if (has_target != 0 && has_key != 0) {
            var merged: u64 = key_v;
            if (target_v < merged) { merged = target_v; }
            annotation_complexity_constraints_upsert_int(out, map_arg.key_ptr, map_arg.key_len, merged);
            annotation_complexity_constraints_upsert_int(out, target_ptr, target_len, merged);
        }
    }
    return out;
}

func annotation_complexity_constraints_expand_relations(constraints_ann: *CompilerAnnotationParsed) -> *CompilerAnnotationParsed {
    if (constraints_ann == 0) { return 0; }
    var out: *CompilerAnnotationParsed = annotation_complexity_constraints_scaled(constraints_ann, 1);
    if (out == 0 || out.args_vec == 0) { return constraints_ann; }
    var rel_n: u64 = out.args_vec.len();
    var pass_limit: u64 = rel_n + 2;
    if (pass_limit < 2) { pass_limit = 2; }
    for (var pass: u64 = 0; pass < pass_limit; pass++) {
        var changed: u64 = 0;
        for (var i: u64 = 0; i < rel_n; i++) {
            var a: *CompilerAnnotationArg = out.args_vec.get(i);
            if (a == 0 || a.key_ptr == 0 || a.key_len == 0 || a.kind != 3) { continue; }
            if (annotation_complexity_constraints_is_relation_key(a.key_ptr, a.key_len) == 0) { continue; }
            var rel_changed: u64 = 0;
            if (annotation_complexity_apply_relation_spec(out, a.string_ptr, a.string_len, &rel_changed) == 0) { continue; }
            if (rel_changed != 0) { changed = 1; }
        }
        if (changed == 0) { break; }
    }
    return out;
}

func annotation_complexity_expr_growth_exceeds(lhs_ptr: u64, lhs_len: u64, rhs_ptr: u64, rhs_len: u64, constraints_ann: *CompilerAnnotationParsed, out_ok: *u64) -> u64 {
    if (out_ok == 0) { return 0; }
    *out_ok = 0;
    if (lhs_ptr == 0 || lhs_len == 0 || rhs_ptr == 0 || rhs_len == 0 || constraints_ann == 0) { return 0; }
    var cap: u64 = 9223372036854775807;
    var have_any: u64 = 0;
    for (var si: u64 = 0; si < 3; si++) {
        var sc: u64 = 1;
        if (si == 1) { sc = 2; }
        else if (si == 2) { sc = 4; }
        var cs: *CompilerAnnotationParsed = annotation_complexity_constraints_scaled(constraints_ann, sc);
        var ok_l: u64 = 0;
        var ok_r: u64 = 0;
        var lv: u64 = annotation_complexity_eval_o_expr_ops(lhs_ptr, lhs_len, cs, &ok_l);
        var rv: u64 = annotation_complexity_eval_o_expr_ops(rhs_ptr, rhs_len, cs, &ok_r);
        if (ok_l == 0 || ok_r == 0 || rv == 0) { continue; }
        have_any = 1;
        var rhs_slack: u64 = annotation_complexity_sat_mul(rv, 3, cap);
        if (lv > rhs_slack) {
            *out_ok = 1;
            return 1;
        }
    }
    if (have_any != 0) {
        *out_ok = 1;
        return 0;
    }
    return 0;
}

func annotation_complexity_expr_dominated_by(lhs_ptr: u64, lhs_len: u64, rhs_ptr: u64, rhs_len: u64, constraints_ann: *CompilerAnnotationParsed, out_decidable: *u64, out_conf: *u64) -> u64 {
    if (out_decidable == 0 || out_conf == 0) { return 0; }
    *out_decidable = 0;
    *out_conf = ANN_COMPLEXITY_CONF_UNKNOWN;
    if (lhs_ptr == 0 || lhs_len == 0 || rhs_ptr == 0 || rhs_len == 0) { return 0; }
    var lhs_norm: *NameInfo = annotation_complexity_normalize(lhs_ptr, lhs_len);
    var rhs_norm: *NameInfo = annotation_complexity_normalize(rhs_ptr, rhs_len);
    if (lhs_norm != 0 && rhs_norm != 0 &&
        lhs_norm.ptr != 0 && rhs_norm.ptr != 0 &&
        lhs_norm.len != 0 && rhs_norm.len != 0 &&
        str_eq(lhs_norm.ptr, lhs_norm.len, rhs_norm.ptr, rhs_norm.len) != 0) {
        *out_decidable = 1;
        *out_conf = ANN_COMPLEXITY_CONF_PROVEN;
        return 1;
    }

    var lhs_rank: u64 = annotation_complexity_rank_from_expr(lhs_ptr, lhs_len);
    var rhs_rank: u64 = annotation_complexity_rank_from_expr(rhs_ptr, rhs_len);
    var rank_says_leq: u64 = 0;
    if (lhs_rank != 0 && rhs_rank != 0 && annotation_complexity_rank_exceeds(lhs_rank, rhs_rank) == 0) {
        rank_says_leq = 1;
    }

    if (lhs_rank != 0 && rhs_rank != 0 && rank_says_leq != 0) {
        var lhs_sym_count: u64 = 0;
        var rhs_sym_count: u64 = 0;
        var lhs_sym_ptr: u64 = 0;
        var lhs_sym_len: u64 = 0;
        var rhs_sym_ptr: u64 = 0;
        var rhs_sym_len: u64 = 0;
        annotation_complexity_expr_symbol_profile(lhs_ptr, lhs_len, &lhs_sym_count, &lhs_sym_ptr, &lhs_sym_len);
        annotation_complexity_expr_symbol_profile(rhs_ptr, rhs_len, &rhs_sym_count, &rhs_sym_ptr, &rhs_sym_len);

        var proven_ok: u64 = 0;
        if (lhs_sym_count == 0 && rhs_sym_count == 0) {
            proven_ok = 1;
        } else if (lhs_sym_count == 0 && rhs_sym_count == 1) {
            proven_ok = 1;
        } else if (lhs_sym_count == 1 && rhs_sym_count == 1 &&
                   str_eq(lhs_sym_ptr, lhs_sym_len, rhs_sym_ptr, rhs_sym_len) != 0) {
            proven_ok = 1;
        }
        if (proven_ok != 0) {
            *out_decidable = 1;
            *out_conf = ANN_COMPLEXITY_CONF_PROVEN;
            return 1;
        }
    }

    var valid_samples: u64 = 0;
    var cap: u64 = 9223372036854775807;
    if (constraints_ann != 0) {
        for (var si: u64 = 0; si < 6; si = si + 1) {
            var sc: u64 = 1;
            if (si == 1) { sc = 2; }
            else if (si == 2) { sc = 4; }
            else if (si == 3) { sc = 8; }
            else if (si == 4) { sc = 16; }
            else if (si == 5) { sc = 32; }
            var cs: *CompilerAnnotationParsed = annotation_complexity_constraints_scaled(constraints_ann, sc);
            var ok_l: u64 = 0;
            var ok_r: u64 = 0;
            var lv: u64 = annotation_complexity_eval_o_expr_ops(lhs_ptr, lhs_len, cs, &ok_l);
            var rv: u64 = annotation_complexity_eval_o_expr_ops(rhs_ptr, rhs_len, cs, &ok_r);
            if (ok_l == 0 || ok_r == 0 || rv == 0) { continue; }
            valid_samples = valid_samples + 1;
            // Slack for constant factors and parser simplifications.
            if (lv > annotation_complexity_sat_mul(rv, 3, cap)) {
                *out_decidable = 1;
                *out_conf = ANN_COMPLEXITY_CONF_HEURISTIC;
                return 0;
            }
        }
    }

    if (valid_samples >= 3) {
        *out_decidable = 1;
        *out_conf = ANN_COMPLEXITY_CONF_HEURISTIC;
        return 1;
    }
    if (rank_says_leq != 0) {
        *out_decidable = 1;
        *out_conf = ANN_COMPLEXITY_CONF_HEURISTIC;
        return 1;
    }
    return 0;
}

func annotation_complexity_expr_bound(expr: *AstNode, constraints_ann: *CompilerAnnotationParsed, fallback_bound: u64) -> u64 {
    var cap: u64 = 9223372036854775807;
    if (expr == 0) { return fallback_bound; }
    var kind: u64 = ast_kind(expr);
    if (kind == AST_LITERAL) { return ((*AstLiteral)expr).value; }
    if (kind == AST_IDENT) {
        var id: *AstIdent = (*AstIdent)expr;
        var v: u64 = 0;
        if (annotation_complexity_constraint_lookup(constraints_ann, id.name_ptr, id.name_len, &v) != 0) { return v; }
        return fallback_bound;
    }
    if (kind == AST_BINARY) {
        var b: *AstBinary = (*AstBinary)expr;
        var l: u64 = annotation_complexity_expr_bound(b.left, constraints_ann, fallback_bound);
        var r: u64 = annotation_complexity_expr_bound(b.right, constraints_ann, fallback_bound);
        match (b.op) {
            case TOKEN_PLUS: return annotation_complexity_sat_add(l, r, cap);
            case TOKEN_MINUS:
                if (l > r) { return l - r; }
                return 0;
            case TOKEN_STAR: return annotation_complexity_sat_mul(l, r, cap);
            case TOKEN_SLASH:
                if (r == 0) { return fallback_bound; }
                return l / r;
            case TOKEN_RSHIFT:
                if (r >= 63) { return 0; }
                return l >> r;
            case TOKEN_LSHIFT:
                if (r >= 63) { return cap; }
                return annotation_complexity_sat_mul(l, (1 << r), cap);
        }
    }
    return fallback_bound;
}

const ANN_LOOP_UPDATE_NONE = 0;
const ANN_LOOP_UPDATE_LINEAR_INC = 1;
const ANN_LOOP_UPDATE_LINEAR_DEC = 2;
const ANN_LOOP_UPDATE_GEO_INC = 3;
const ANN_LOOP_UPDATE_GEO_DEC = 4;

func annotation_complexity_expr_literal_u64(expr: *AstNode, out_v: *u64) -> u64 {
    if (expr == 0 || out_v == 0) { return 0; }
    if (ast_kind(expr) != AST_LITERAL) { return 0; }
    *out_v = ((*AstLiteral)expr).value;
    return 1;
}

func annotation_complexity_cond_var_bound(cond: *AstNode, out_var_ptr: *u64, out_var_len: *u64, out_bound: **AstNode, out_dir: *u64) -> u64 {
    // out_dir: 1 => var should increase, 2 => var should decrease
    if (cond == 0 || out_var_ptr == 0 || out_var_len == 0 || out_bound == 0 || out_dir == 0) { return 0; }
    if (ast_kind(cond) != AST_BINARY) { return 0; }
    var b: *AstBinary = (*AstBinary)cond;
    if (b.op != TOKEN_LT && b.op != TOKEN_LTEQ && b.op != TOKEN_GT && b.op != TOKEN_GTEQ) { return 0; }

    if (b.left != 0 && ast_kind(b.left) == AST_IDENT) {
        var li: *AstIdent = (*AstIdent)b.left;
        *out_var_ptr = li.name_ptr;
        *out_var_len = li.name_len;
        *out_bound = b.right;
        if (b.op == TOKEN_LT || b.op == TOKEN_LTEQ) { *out_dir = 1; }
        else { *out_dir = 2; }
        return 1;
    }
    if (b.right != 0 && ast_kind(b.right) == AST_IDENT) {
        var ri: *AstIdent = (*AstIdent)b.right;
        *out_var_ptr = ri.name_ptr;
        *out_var_len = ri.name_len;
        *out_bound = b.left;
        if (b.op == TOKEN_LT || b.op == TOKEN_LTEQ) { *out_dir = 2; }
        else { *out_dir = 1; }
        return 1;
    }
    return 0;
}

func annotation_complexity_expr_is_square_ident(expr: *AstNode, out_var_ptr: *u64, out_var_len: *u64) -> u64 {
    if (expr == 0 || out_var_ptr == 0 || out_var_len == 0) { return 0; }
    if (ast_kind(expr) != AST_BINARY) { return 0; }
    var b: *AstBinary = (*AstBinary)expr;
    if (b.op != TOKEN_STAR || b.left == 0 || b.right == 0) { return 0; }
    if (ast_kind(b.left) != AST_IDENT || ast_kind(b.right) != AST_IDENT) { return 0; }
    var li: *AstIdent = (*AstIdent)b.left;
    var ri: *AstIdent = (*AstIdent)b.right;
    if (str_eq(li.name_ptr, li.name_len, ri.name_ptr, ri.name_len) == 0) { return 0; }
    *out_var_ptr = li.name_ptr;
    *out_var_len = li.name_len;
    return 1;
}

func annotation_complexity_cond_square_var_bound(cond: *AstNode, out_var_ptr: *u64, out_var_len: *u64, out_bound: **AstNode, out_dir: *u64) -> u64 {
    // Recognize patterns like i*i < n, n > i*i, ...
    // out_dir: 1 => var should increase, 2 => var should decrease
    if (cond == 0 || out_var_ptr == 0 || out_var_len == 0 || out_bound == 0 || out_dir == 0) { return 0; }
    if (ast_kind(cond) != AST_BINARY) { return 0; }
    var b: *AstBinary = (*AstBinary)cond;
    if (b.op != TOKEN_LT && b.op != TOKEN_LTEQ && b.op != TOKEN_GT && b.op != TOKEN_GTEQ) { return 0; }

    var var_ptr: u64 = 0;
    var var_len: u64 = 0;
    if (annotation_complexity_expr_is_square_ident(b.left, &var_ptr, &var_len) != 0) {
        *out_var_ptr = var_ptr;
        *out_var_len = var_len;
        *out_bound = b.right;
        if (b.op == TOKEN_LT || b.op == TOKEN_LTEQ) { *out_dir = 1; }
        else { *out_dir = 2; }
        return 1;
    }
    if (annotation_complexity_expr_is_square_ident(b.right, &var_ptr, &var_len) != 0) {
        *out_var_ptr = var_ptr;
        *out_var_len = var_len;
        *out_bound = b.left;
        if (b.op == TOKEN_LT || b.op == TOKEN_LTEQ) { *out_dir = 2; }
        else { *out_dir = 1; }
        return 1;
    }
    return 0;
}

func annotation_complexity_update_kind_from_value(value: *AstNode, var_ptr: u64, var_len: u64) -> u64 {
    if (value == 0 || ast_kind(value) != AST_BINARY) { return ANN_LOOP_UPDATE_NONE; }
    var b: *AstBinary = (*AstBinary)value;

    if (b.op == TOKEN_PLUS) {
        var left_is_var: u64 = annotation_complexity_expr_is_ident(b.left, var_ptr, var_len);
        var right_is_var: u64 = annotation_complexity_expr_is_ident(b.right, var_ptr, var_len);
        if (left_is_var != 0 && right_is_var != 0) { return ANN_LOOP_UPDATE_GEO_INC; } // i = i + i
        if (left_is_var != 0 && annotation_complexity_expr_contains_ident(b.right, var_ptr, var_len) == 0) { return ANN_LOOP_UPDATE_LINEAR_INC; }
        if (right_is_var != 0 && annotation_complexity_expr_contains_ident(b.left, var_ptr, var_len) == 0) { return ANN_LOOP_UPDATE_LINEAR_INC; }
        return ANN_LOOP_UPDATE_NONE;
    }
    if (b.op == TOKEN_MINUS) {
        if (annotation_complexity_expr_is_ident(b.left, var_ptr, var_len) != 0 &&
            annotation_complexity_expr_contains_ident(b.right, var_ptr, var_len) == 0) {
            return ANN_LOOP_UPDATE_LINEAR_DEC;
        }
        return ANN_LOOP_UPDATE_NONE;
    }
    if (b.op == TOKEN_STAR) {
        var factor_expr: *AstNode = 0;
        if (annotation_complexity_expr_is_ident(b.left, var_ptr, var_len) != 0 &&
            annotation_complexity_expr_contains_ident(b.right, var_ptr, var_len) == 0) {
            factor_expr = b.right;
        } else if (annotation_complexity_expr_is_ident(b.right, var_ptr, var_len) != 0 &&
                   annotation_complexity_expr_contains_ident(b.left, var_ptr, var_len) == 0) {
            factor_expr = b.left;
        }
        if (factor_expr != 0) {
            var fv: u64 = 0;
            if (annotation_complexity_expr_literal_u64(factor_expr, &fv) != 0) {
                if (fv >= 2) { return ANN_LOOP_UPDATE_GEO_INC; }
                return ANN_LOOP_UPDATE_NONE;
            }
        }
        return ANN_LOOP_UPDATE_NONE;
    }
    if (b.op == TOKEN_SLASH) {
        if (annotation_complexity_expr_is_ident(b.left, var_ptr, var_len) != 0 &&
            annotation_complexity_expr_contains_ident(b.right, var_ptr, var_len) == 0) {
            var dv: u64 = 0;
            if (annotation_complexity_expr_literal_u64(b.right, &dv) != 0) {
                if (dv >= 2) { return ANN_LOOP_UPDATE_GEO_DEC; }
            }
        }
        return ANN_LOOP_UPDATE_NONE;
    }
    if (b.op == TOKEN_LSHIFT) {
        if (annotation_complexity_expr_is_ident(b.left, var_ptr, var_len) != 0) {
            var shv: u64 = 0;
            if (annotation_complexity_expr_literal_u64(b.right, &shv) != 0 && shv >= 1) {
                return ANN_LOOP_UPDATE_GEO_INC;
            }
        }
        return ANN_LOOP_UPDATE_NONE;
    }
    if (b.op == TOKEN_RSHIFT) {
        if (annotation_complexity_expr_is_ident(b.left, var_ptr, var_len) != 0) {
            var shv2: u64 = 0;
            if (annotation_complexity_expr_literal_u64(b.right, &shv2) != 0 && shv2 >= 1) {
                return ANN_LOOP_UPDATE_GEO_DEC;
            }
        }
        return ANN_LOOP_UPDATE_NONE;
    }
    return ANN_LOOP_UPDATE_NONE;
}

func annotation_complexity_stmt_annotations(stmt: *AstNode) -> *Vec<*NameInfo> {
    if (stmt == 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    match (kind) {
        case AST_VAR_DECL: return ((*AstVarDecl)stmt).annotations_vec;
        case AST_ASSIGN: return ((*AstAssign)stmt).annotations_vec;
        case AST_EXPR_STMT: return ((*AstExprStmt)stmt).annotations_vec;
        case AST_IF: return ((*AstIf)stmt).annotations_vec;
        case AST_WHILE: return ((*AstWhile)stmt).annotations_vec;
        case AST_FOR: return ((*AstFor)stmt).annotations_vec;
        case AST_DO_WHILE: return ((*AstDoWhile)stmt).annotations_vec;
        case AST_SWITCH:
        case AST_MATCH:
            return ((*AstSwitch)stmt).annotations_vec;
        case AST_CASE: return ((*AstCase)stmt).annotations_vec;
        case AST_BREAK: return ((*AstBreak)stmt).annotations_vec;
        case AST_CONTINUE: return ((*AstContinue)stmt).annotations_vec;
        case AST_RETURN: return ((*AstReturn)stmt).annotations_vec;
        case AST_DEFER: return ((*AstDefer)stmt).annotations_vec;
        case AST_DELETE: return ((*AstDelete)stmt).annotations_vec;
        case AST_THROW_STMT: return ((*AstThrowStmt)stmt).annotations_vec;
        case AST_TRY_STMT: return ((*AstTryStmt)stmt).annotations_vec;
        case AST_ASM: return ((*AstAsm)stmt).annotations_vec;
        case AST_ALIAS: return ((*AstAlias)stmt).annotations_vec;
        case AST_BLOCK: return ((*AstBlock)stmt).annotations_vec;
    }
    return 0;
}

func annotation_complexity_stmt_has_skip(stmt: *AstNode) -> u64 {
    var anns: *Vec<*NameInfo> = annotation_complexity_stmt_annotations(stmt);
    if (anns == 0) { return 0; }
    var n: u64 = anns.len();
    for (var i: u64 = 0; i < n; i++) {
        var info: *NameInfo = anns.get(i);
        if (info == 0) { continue; }
        var ann: *CompilerAnnotationParsed = annotation_parse(info);
        if (ann == 0 || ann.parse_ok == 0) { continue; }
        if (str_eq(ann.name_ptr, ann.name_len, "complexity_ignore", 17) != 0) { return 1; }
    }
    return 0;
}

func annotation_complexity_update_kind_from_stmt(stmt: *AstNode, var_ptr: u64, var_len: u64) -> u64 {
    if (stmt == 0) { return ANN_LOOP_UPDATE_NONE; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return ANN_LOOP_UPDATE_NONE; }
    var kind: u64 = ast_kind(stmt);
    if (kind == AST_EXPR_STMT) {
        return annotation_complexity_update_kind_from_stmt(((*AstExprStmt)stmt).expr, var_ptr, var_len);
    }
    if (kind == AST_BINARY) {
        var bx: *AstBinary = (*AstBinary)stmt;
        if (bx.op == TOKEN_EQ) {
            if (annotation_complexity_expr_is_ident(bx.left, var_ptr, var_len) == 0) { return ANN_LOOP_UPDATE_NONE; }
            return annotation_complexity_update_kind_from_value(bx.right, var_ptr, var_len);
        }
        if (bx.op == TOKEN_PLUS_EQ) {
            if (annotation_complexity_expr_is_ident(bx.left, var_ptr, var_len) == 0) { return ANN_LOOP_UPDATE_NONE; }
            if (annotation_complexity_expr_contains_ident(bx.right, var_ptr, var_len) != 0) { return ANN_LOOP_UPDATE_NONE; }
            return ANN_LOOP_UPDATE_LINEAR_INC;
        }
        if (bx.op == TOKEN_MINUS_EQ) {
            if (annotation_complexity_expr_is_ident(bx.left, var_ptr, var_len) == 0) { return ANN_LOOP_UPDATE_NONE; }
            if (annotation_complexity_expr_contains_ident(bx.right, var_ptr, var_len) != 0) { return ANN_LOOP_UPDATE_NONE; }
            return ANN_LOOP_UPDATE_LINEAR_DEC;
        }
        if (bx.op == TOKEN_STAR_EQ) {
            if (annotation_complexity_expr_is_ident(bx.left, var_ptr, var_len) == 0) { return ANN_LOOP_UPDATE_NONE; }
            if (annotation_complexity_expr_contains_ident(bx.right, var_ptr, var_len) != 0) { return ANN_LOOP_UPDATE_NONE; }
            var fv: u64 = 0;
            if (annotation_complexity_expr_literal_u64(bx.right, &fv) != 0 && fv >= 2) { return ANN_LOOP_UPDATE_GEO_INC; }
            return ANN_LOOP_UPDATE_NONE;
        }
        if (bx.op == TOKEN_SLASH_EQ) {
            if (annotation_complexity_expr_is_ident(bx.left, var_ptr, var_len) == 0) { return ANN_LOOP_UPDATE_NONE; }
            if (annotation_complexity_expr_contains_ident(bx.right, var_ptr, var_len) != 0) { return ANN_LOOP_UPDATE_NONE; }
            var dv: u64 = 0;
            if (annotation_complexity_expr_literal_u64(bx.right, &dv) != 0 && dv >= 2) { return ANN_LOOP_UPDATE_GEO_DEC; }
            return ANN_LOOP_UPDATE_NONE;
        }
    }
    if (kind == AST_ASSIGN) {
        var asn: *AstAssign = (*AstAssign)stmt;
        if (annotation_complexity_expr_is_ident(asn.target, var_ptr, var_len) == 0) { return ANN_LOOP_UPDATE_NONE; }
        return annotation_complexity_update_kind_from_value(asn.value, var_ptr, var_len);
    }
    if (kind == AST_BLOCK) {
        var blk: *AstBlock = (*AstBlock)stmt;
        if (blk.stmts_vec == 0) { return ANN_LOOP_UPDATE_NONE; }
        var seen_linear: u64 = 0;
        var n: u64 = blk.stmts_vec.len();
        for (var i: u64 = 0; i < n; i++) {
            var k: u64 = annotation_complexity_update_kind_from_stmt(blk.stmts_vec.get(i), var_ptr, var_len);
            if (k == ANN_LOOP_UPDATE_GEO_INC || k == ANN_LOOP_UPDATE_GEO_DEC) { return k; }
            if (k == ANN_LOOP_UPDATE_LINEAR_INC || k == ANN_LOOP_UPDATE_LINEAR_DEC) { seen_linear = k; }
        }
        return seen_linear;
    }
    if (kind == AST_IF) {
        var ifs: *AstIf = (*AstIf)stmt;
        var t: u64 = annotation_complexity_update_kind_from_stmt(ifs.then_block, var_ptr, var_len);
        var e: u64 = annotation_complexity_update_kind_from_stmt(ifs.else_block, var_ptr, var_len);
        if (t != 0 && t == e) { return t; }
        return ANN_LOOP_UPDATE_NONE;
    }
    if (kind == AST_CASE) { return annotation_complexity_update_kind_from_stmt(((*AstCase)stmt).body, var_ptr, var_len); }
    if (kind == AST_DEFER) { return annotation_complexity_update_kind_from_stmt(((*AstDefer)stmt).stmt, var_ptr, var_len); }
    if (kind == AST_SWITCH || kind == AST_MATCH) {
        var sw: *AstSwitch = (*AstSwitch)stmt;
        if (sw.cases_vec == 0) { return ANN_LOOP_UPDATE_NONE; }
        var agreed: u64 = 0;
        var cn: u64 = sw.cases_vec.len();
        for (var ci: u64 = 0; ci < cn; ci++) {
            var ck: u64 = annotation_complexity_update_kind_from_stmt(sw.cases_vec.get(ci), var_ptr, var_len);
            if (ck == 0) { return ANN_LOOP_UPDATE_NONE; }
            if (agreed == 0) { agreed = ck; }
            else if (agreed != ck) { return ANN_LOOP_UPDATE_NONE; }
        }
        return agreed;
    }
    return ANN_LOOP_UPDATE_NONE;
}

func annotation_complexity_linear_step_from_value(value: *AstNode, var_ptr: u64, var_len: u64, out_dir: *u64, out_step: *u64) -> u64 {
    if (value == 0 || out_dir == 0 || out_step == 0) { return 0; }
    if (ast_kind(value) != AST_BINARY) { return 0; }
    var b: *AstBinary = (*AstBinary)value;
    var lit: u64 = 0;
    if (b.op == TOKEN_PLUS) {
        if (annotation_complexity_expr_is_ident(b.left, var_ptr, var_len) != 0 && annotation_complexity_expr_literal_u64(b.right, &lit) != 0 && lit > 0) {
            *out_dir = 1;
            *out_step = lit;
            return 1;
        }
        if (annotation_complexity_expr_is_ident(b.right, var_ptr, var_len) != 0 && annotation_complexity_expr_literal_u64(b.left, &lit) != 0 && lit > 0) {
            *out_dir = 1;
            *out_step = lit;
            return 1;
        }
        return 0;
    }
    if (b.op == TOKEN_MINUS) {
        if (annotation_complexity_expr_is_ident(b.left, var_ptr, var_len) != 0 && annotation_complexity_expr_literal_u64(b.right, &lit) != 0 && lit > 0) {
            *out_dir = 2;
            *out_step = lit;
            return 1;
        }
        return 0;
    }
    return 0;
}

func annotation_complexity_linear_step_from_expr(expr: *AstNode, var_ptr: u64, var_len: u64, out_dir: *u64, out_step: *u64) -> u64 {
    if (expr == 0 || out_dir == 0 || out_step == 0) { return 0; }
    var kind: u64 = ast_kind(expr);
    if (kind == AST_EXPR_STMT) {
        return annotation_complexity_linear_step_from_expr(((*AstExprStmt)expr).expr, var_ptr, var_len, out_dir, out_step);
    }
    if (kind == AST_ASSIGN) {
        var asn: *AstAssign = (*AstAssign)expr;
        if (annotation_complexity_expr_is_ident(asn.target, var_ptr, var_len) == 0) { return 0; }
        return annotation_complexity_linear_step_from_value(asn.value, var_ptr, var_len, out_dir, out_step);
    }
    if (kind != AST_BINARY) { return 0; }
    var b: *AstBinary = (*AstBinary)expr;
    var lit: u64 = 0;
    if (b.op == TOKEN_PLUS_EQ && annotation_complexity_expr_is_ident(b.left, var_ptr, var_len) != 0 &&
        annotation_complexity_expr_literal_u64(b.right, &lit) != 0 && lit > 0) {
        *out_dir = 1;
        *out_step = lit;
        return 1;
    }
    if (b.op == TOKEN_MINUS_EQ && annotation_complexity_expr_is_ident(b.left, var_ptr, var_len) != 0 &&
        annotation_complexity_expr_literal_u64(b.right, &lit) != 0 && lit > 0) {
        *out_dir = 2;
        *out_step = lit;
        return 1;
    }
    if (b.op == TOKEN_EQ && annotation_complexity_expr_is_ident(b.left, var_ptr, var_len) != 0) {
        return annotation_complexity_linear_step_from_value(b.right, var_ptr, var_len, out_dir, out_step);
    }
    return 0;
}

func annotation_complexity_for_init_value(stmt: *AstNode, var_ptr: u64, var_len: u64, constraints_ann: *CompilerAnnotationParsed, fallback_bound: u64, out_ok: *u64, out_v: *u64) -> u64 {
    if (out_ok == 0 || out_v == 0) { return 0; }
    *out_ok = 0;
    if (stmt == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    if (kind == AST_VAR_DECL) {
        var vd: *AstVarDecl = (*AstVarDecl)stmt;
        if (str_eq(vd.name_ptr, vd.name_len, var_ptr, var_len) == 0) { return 0; }
        *out_v = annotation_complexity_expr_bound(vd.init_expr, constraints_ann, fallback_bound);
        *out_ok = 1;
        return 1;
    }
    if (kind == AST_ASSIGN) {
        var asn: *AstAssign = (*AstAssign)stmt;
        if (annotation_complexity_expr_is_ident(asn.target, var_ptr, var_len) == 0) { return 0; }
        *out_v = annotation_complexity_expr_bound(asn.value, constraints_ann, fallback_bound);
        *out_ok = 1;
        return 1;
    }
    if (kind == AST_EXPR_STMT) {
        return annotation_complexity_for_init_value(((*AstExprStmt)stmt).expr, var_ptr, var_len, constraints_ann, fallback_bound, out_ok, out_v);
    }
    if (kind == AST_BINARY) {
        var b: *AstBinary = (*AstBinary)stmt;
        if (b.op == TOKEN_EQ && annotation_complexity_expr_is_ident(b.left, var_ptr, var_len) != 0) {
            *out_v = annotation_complexity_expr_bound(b.right, constraints_ann, fallback_bound);
            *out_ok = 1;
            return 1;
        }
    }
    return 0;
}

func annotation_complexity_for_iterations_precise_with_status(fr: *AstFor, constraints_ann: *CompilerAnnotationParsed, fallback_bound: u64, out_known: *u64) -> u64 {
    if (out_known != 0) { *out_known = 0; }
    if (fr == 0 || fr.cond == 0) { return 0; }
    if (ast_kind(fr.cond) != AST_BINARY) { return 0; }
    var cb: *AstBinary = (*AstBinary)fr.cond;
    if (cb.op != TOKEN_LT && cb.op != TOKEN_LTEQ && cb.op != TOKEN_GT && cb.op != TOKEN_GTEQ) { return 0; }

    var var_ptr: u64 = 0;
    var var_len: u64 = 0;
    var bound_expr: *AstNode = 0;
    var dir: u64 = 0;
    if (annotation_complexity_cond_var_bound(fr.cond, &var_ptr, &var_len, &bound_expr, &dir) == 0) { return 0; }

    var step_dir: u64 = 0;
    var step_v: u64 = 0;
    if (annotation_complexity_linear_step_from_expr(fr.update, var_ptr, var_len, &step_dir, &step_v) == 0) { return 0; }
    if (step_v == 0 || step_dir != dir) { return 0; }

    var init_ok: u64 = 0;
    var init_v: u64 = 0;
    annotation_complexity_for_init_value(fr.init, var_ptr, var_len, constraints_ann, fallback_bound, &init_ok, &init_v);
    if (init_ok == 0) { return 0; }

    var bound_v: u64 = annotation_complexity_expr_bound(bound_expr, constraints_ann, fallback_bound);
    var strict: u64 = 0;
    if (cb.op == TOKEN_LT || cb.op == TOKEN_GT) { strict = 1; }
    if (out_known != 0) { *out_known = 1; }

    if (dir == 1) {
        if (strict != 0) {
            if (init_v >= bound_v) { return 0; }
            var diff_s: u64 = bound_v - init_v;
            return (diff_s + step_v - 1) / step_v;
        }
        if (init_v > bound_v) { return 0; }
        var diff_i: u64 = bound_v - init_v;
        return (diff_i / step_v) + 1;
    }
    if (dir == 2) {
        if (strict != 0) {
            if (init_v <= bound_v) { return 0; }
            var diff_ds: u64 = init_v - bound_v;
            return (diff_ds + step_v - 1) / step_v;
        }
        if (init_v < bound_v) { return 0; }
        var diff_di: u64 = init_v - bound_v;
        return (diff_di / step_v) + 1;
    }
    if (out_known != 0) { *out_known = 0; }
    return 0;
}

func annotation_complexity_for_iterations_precise(fr: *AstFor, constraints_ann: *CompilerAnnotationParsed, fallback_bound: u64) -> u64 {
    var known: u64 = 0;
    return annotation_complexity_for_iterations_precise_with_status(fr, constraints_ann, fallback_bound, &known);
}

func annotation_complexity_loop_iterations_with_ctx(cond: *AstNode, update_stmt: *AstNode, body_stmt: *AstNode, constraints_ann: *CompilerAnnotationParsed, fallback_bound: u64) -> u64 {
    var cap: u64 = 9223372036854775807;
    if (cond == 0 || ast_kind(cond) != AST_BINARY) { return fallback_bound; }
    var b: *AstBinary = (*AstBinary)cond;
    if (b.op != TOKEN_LT && b.op != TOKEN_LTEQ && b.op != TOKEN_GT && b.op != TOKEN_GTEQ) { return fallback_bound; }

    var var_ptr: u64 = 0;
    var var_len: u64 = 0;
    var bound_expr: *AstNode = 0;
    var dir: u64 = 0;
    var sqrt_mode: u64 = 0;
    if (annotation_complexity_cond_square_var_bound(cond, &var_ptr, &var_len, &bound_expr, &dir) != 0) {
        sqrt_mode = 1;
    } else if (annotation_complexity_cond_var_bound(cond, &var_ptr, &var_len, &bound_expr, &dir) == 0) {
        if (ast_kind(b.left) == AST_IDENT) { return annotation_complexity_expr_bound(b.right, constraints_ann, fallback_bound); }
        if (ast_kind(b.right) == AST_IDENT) { return annotation_complexity_expr_bound(b.left, constraints_ann, fallback_bound); }
        return fallback_bound;
    }

    var bound_v: u64 = annotation_complexity_expr_bound(bound_expr, constraints_ann, fallback_bound);
    var update_kind: u64 = ANN_LOOP_UPDATE_NONE;
    if (update_stmt != 0) { update_kind = annotation_complexity_update_kind_from_stmt(update_stmt, var_ptr, var_len); }
    if (update_kind == ANN_LOOP_UPDATE_NONE && body_stmt != 0) {
        update_kind = annotation_complexity_update_kind_from_stmt(body_stmt, var_ptr, var_len);
    }

    if (dir == 1) {
        if (update_kind == ANN_LOOP_UPDATE_GEO_INC) {
            if (sqrt_mode != 0) { return annotation_complexity_log2_floor(annotation_complexity_isqrt_floor(bound_v) + 1) + 1; }
            return annotation_complexity_log2_floor(bound_v + 1) + 1;
        }
        if (update_kind == ANN_LOOP_UPDATE_LINEAR_INC) {
            if (sqrt_mode != 0) { return annotation_complexity_isqrt_floor(bound_v) + 1; }
            return bound_v;
        }
    } else if (dir == 2) {
        if (update_kind == ANN_LOOP_UPDATE_GEO_DEC) {
            if (sqrt_mode != 0) { return annotation_complexity_log2_floor(annotation_complexity_isqrt_floor(bound_v) + 1) + 1; }
            return annotation_complexity_log2_floor(bound_v + 1) + 1;
        }
        if (update_kind == ANN_LOOP_UPDATE_LINEAR_DEC) {
            if (sqrt_mode != 0) { return annotation_complexity_isqrt_floor(bound_v) + 1; }
            return bound_v;
        }
    }

    if (sqrt_mode != 0) { return annotation_complexity_isqrt_floor(bound_v) + 1; }
    if (bound_v > cap) { return cap; }
    return bound_v;
}

func annotation_complexity_loop_iteration_rank_with_ctx(cond: *AstNode, update_stmt: *AstNode, body_stmt: *AstNode, constraints_ann: *CompilerAnnotationParsed, fallback_bound: u64) -> u64 {
    var var_ptr: u64 = 0;
    var var_len: u64 = 0;
    var bound_expr: *AstNode = 0;
    var dir: u64 = 0;
    var sqrt_mode: u64 = 0;
    if (annotation_complexity_cond_square_var_bound(cond, &var_ptr, &var_len, &bound_expr, &dir) != 0) {
        sqrt_mode = 1;
    } else if (annotation_complexity_cond_var_bound(cond, &var_ptr, &var_len, &bound_expr, &dir) == 0) {
        return 3;
    }
    var update_kind: u64 = ANN_LOOP_UPDATE_NONE;
    if (update_stmt != 0) { update_kind = annotation_complexity_update_kind_from_stmt(update_stmt, var_ptr, var_len); }
    if (update_kind == ANN_LOOP_UPDATE_NONE && body_stmt != 0) {
        update_kind = annotation_complexity_update_kind_from_stmt(body_stmt, var_ptr, var_len);
    }

    if (dir == 1 && update_kind == ANN_LOOP_UPDATE_GEO_INC) { return 2; }
    if (dir == 2 && update_kind == ANN_LOOP_UPDATE_GEO_DEC) { return 2; }
    if (dir == 1 && update_kind == ANN_LOOP_UPDATE_LINEAR_INC) {
        if (sqrt_mode != 0) { return 10; }
        if (annotation_complexity_expr_bound(bound_expr, constraints_ann, fallback_bound) <= 1) { return 1; }
        return 3;
    }
    if (dir == 2 && update_kind == ANN_LOOP_UPDATE_LINEAR_DEC) {
        if (sqrt_mode != 0) { return 10; }
        if (annotation_complexity_expr_bound(bound_expr, constraints_ann, fallback_bound) <= 1) { return 1; }
        return 3;
    }
    if (sqrt_mode != 0) { return 10; }
    return 3;
}

func annotation_complexity_loop_has_unresolved_pattern(cond: *AstNode, update_stmt: *AstNode, body_stmt: *AstNode, constraints_ann: *CompilerAnnotationParsed, fallback_bound: u64) -> u64 {
    var var_ptr: u64 = 0;
    var var_len: u64 = 0;
    var bound_expr: *AstNode = 0;
    var dir: u64 = 0;
    var sqrt_mode: u64 = 0;
    if (annotation_complexity_cond_square_var_bound(cond, &var_ptr, &var_len, &bound_expr, &dir) != 0) {
        sqrt_mode = 1;
    } else if (annotation_complexity_cond_var_bound(cond, &var_ptr, &var_len, &bound_expr, &dir) == 0) {
        return 1;
    }

    var update_kind: u64 = ANN_LOOP_UPDATE_NONE;
    if (update_stmt != 0) { update_kind = annotation_complexity_update_kind_from_stmt(update_stmt, var_ptr, var_len); }
    if (update_kind == ANN_LOOP_UPDATE_NONE && body_stmt != 0) {
        update_kind = annotation_complexity_update_kind_from_stmt(body_stmt, var_ptr, var_len);
    }

    if (dir == 1 && update_kind == ANN_LOOP_UPDATE_GEO_INC) { return 0; }
    if (dir == 2 && update_kind == ANN_LOOP_UPDATE_GEO_DEC) { return 0; }
    if (dir == 1 && update_kind == ANN_LOOP_UPDATE_LINEAR_INC) { return 0; }
    if (dir == 2 && update_kind == ANN_LOOP_UPDATE_LINEAR_DEC) { return 0; }

    if (bound_expr != 0 && annotation_complexity_expr_bound(bound_expr, constraints_ann, fallback_bound) <= 1) { return 0; }
    if (sqrt_mode != 0) { return 1; }
    return 1;
}

func annotation_complexity_stmt_has_unresolved_loop(stmt: *AstNode, constraints_ann: *CompilerAnnotationParsed, fallback_bound: u64) -> u64 {
    if (stmt == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    if (kind == AST_WHILE) {
        var wl: *AstWhile = (*AstWhile)stmt;
        if (annotation_complexity_loop_has_unresolved_pattern(wl.cond, 0, wl.body, constraints_ann, fallback_bound) != 0) { return 1; }
        return annotation_complexity_stmt_has_unresolved_loop(wl.body, constraints_ann, fallback_bound);
    }
    if (kind == AST_FOR) {
        var fr: *AstFor = (*AstFor)stmt;
        if (annotation_complexity_loop_has_unresolved_pattern(fr.cond, fr.update, fr.body, constraints_ann, fallback_bound) != 0) { return 1; }
        if (annotation_complexity_stmt_has_unresolved_loop(fr.init, constraints_ann, fallback_bound) != 0) { return 1; }
        return annotation_complexity_stmt_has_unresolved_loop(fr.body, constraints_ann, fallback_bound);
    }
    if (kind == AST_DO_WHILE) {
        var dw: *AstDoWhile = (*AstDoWhile)stmt;
        if (annotation_complexity_loop_has_unresolved_pattern(dw.cond, 0, dw.body, constraints_ann, fallback_bound) != 0) { return 1; }
        return annotation_complexity_stmt_has_unresolved_loop(dw.body, constraints_ann, fallback_bound);
    }
    if (kind == AST_BLOCK) {
        var blk: *AstBlock = (*AstBlock)stmt;
        if (blk.stmts_vec != 0) {
            var bn: u64 = blk.stmts_vec.len();
            for (var bi: u64 = 0; bi < bn; bi++) {
                if (annotation_complexity_stmt_has_unresolved_loop(blk.stmts_vec.get(bi), constraints_ann, fallback_bound) != 0) { return 1; }
            }
        }
        return 0;
    }
    if (kind == AST_IF) {
        var ifs: *AstIf = (*AstIf)stmt;
        if (annotation_complexity_stmt_has_unresolved_loop(ifs.then_block, constraints_ann, fallback_bound) != 0) { return 1; }
        return annotation_complexity_stmt_has_unresolved_loop(ifs.else_block, constraints_ann, fallback_bound);
    }
    if (kind == AST_SWITCH || kind == AST_MATCH) {
        var sw: *AstSwitch = (*AstSwitch)stmt;
        if (sw.cases_vec != 0) {
            var cn: u64 = sw.cases_vec.len();
            for (var ci: u64 = 0; ci < cn; ci++) {
                if (annotation_complexity_stmt_has_unresolved_loop(sw.cases_vec.get(ci), constraints_ann, fallback_bound) != 0) { return 1; }
            }
        }
        return 0;
    }
    if (kind == AST_CASE) { return annotation_complexity_stmt_has_unresolved_loop(((*AstCase)stmt).body, constraints_ann, fallback_bound); }
    if (kind == AST_DEFER) { return annotation_complexity_stmt_has_unresolved_loop(((*AstDefer)stmt).stmt, constraints_ann, fallback_bound); }
    return 0;
}

func annotation_complexity_loop_iterations(cond: *AstNode, constraints_ann: *CompilerAnnotationParsed, fallback_bound: u64) -> u64 {
    return annotation_complexity_loop_iterations_with_ctx(cond, 0, 0, constraints_ann, fallback_bound);
}

func annotation_complexity_rank_mul(lhs_rank: u64, rhs_rank: u64) -> u64 {
    if (lhs_rank == 0) { return rhs_rank; }
    if (rhs_rank == 0) { return lhs_rank; }
    if (lhs_rank == 1) { return rhs_rank; }
    if (rhs_rank == 1) { return lhs_rank; }
    if (lhs_rank == 13 || rhs_rank == 13) { return 13; }
    if (lhs_rank == 8 || rhs_rank == 8) { return 13; }
    if (lhs_rank == 7 || rhs_rank == 7) { return 7; }
    if (lhs_rank == 12 && rhs_rank == 12) { return 12; } // polylog * polylog -> polylog
    if ((lhs_rank == 12 && rhs_rank == 2) || (lhs_rank == 2 && rhs_rank == 12)) { return 12; }
    // Conservative uplift for missing fractional-polylog buckets.
    if ((lhs_rank == 12 && rhs_rank == 11) || (lhs_rank == 11 && rhs_rank == 12)) { return 10; }
    if ((lhs_rank == 12 && rhs_rank == 10) || (lhs_rank == 10 && rhs_rank == 12)) { return 3; }
    if ((lhs_rank == 12 && rhs_rank == 3) || (lhs_rank == 3 && rhs_rank == 12)) { return 5; } // n*polylog ~= conservative n^2
    if ((lhs_rank == 12 && rhs_rank == 9) || (lhs_rank == 9 && rhs_rank == 12)) { return 5; }
    if ((lhs_rank == 12 && rhs_rank == 4) || (lhs_rank == 4 && rhs_rank == 12)) { return 5; }
    if ((lhs_rank == 12 && rhs_rank == 5) || (lhs_rank == 5 && rhs_rank == 12)) { return 6; }
    if (lhs_rank == 11 && rhs_rank == 11) { return 10; } // n^(1/4)*n^(1/4)=sqrt(n)
    if ((lhs_rank == 11 && rhs_rank == 10) || (lhs_rank == 10 && rhs_rank == 11)) { return 3; } // n^(3/4) -> n bucket
    if ((lhs_rank == 11 && rhs_rank == 2) || (lhs_rank == 2 && rhs_rank == 11)) { return 10; } // conservative uplift
    if ((lhs_rank == 11 && rhs_rank == 3) || (lhs_rank == 3 && rhs_rank == 11)) { return 5; } // n^(5/4) -> n^2 bucket
    if ((lhs_rank == 11 && rhs_rank == 9) || (lhs_rank == 9 && rhs_rank == 11)) { return 5; }
    if ((lhs_rank == 11 && rhs_rank == 4) || (lhs_rank == 4 && rhs_rank == 11)) { return 6; }
    if ((lhs_rank == 11 && rhs_rank == 5) || (lhs_rank == 5 && rhs_rank == 11)) { return 6; }
    if (lhs_rank == 10 && rhs_rank == 10) { return 3; } // sqrt(n)*sqrt(n)=n
    if ((lhs_rank == 10 && rhs_rank == 2) || (lhs_rank == 2 && rhs_rank == 10)) { return 3; } // sqrt(n)logn ~ n bucket
    if ((lhs_rank == 10 && rhs_rank == 3) || (lhs_rank == 3 && rhs_rank == 10)) { return 5; } // n^1.5 -> conservative n^2
    if ((lhs_rank == 10 && rhs_rank == 9) || (lhs_rank == 9 && rhs_rank == 10)) { return 5; }
    if ((lhs_rank == 10 && rhs_rank == 4) || (lhs_rank == 4 && rhs_rank == 10)) { return 6; }
    if ((lhs_rank == 10 && rhs_rank == 5) || (lhs_rank == 5 && rhs_rank == 10)) { return 6; }
    if (lhs_rank == 2 && rhs_rank == 2) { return 12; } // log^2 n
    if ((lhs_rank == 2 && rhs_rank == 3) || (lhs_rank == 3 && rhs_rank == 2)) { return 4; } // n log n
    if ((lhs_rank == 2 && rhs_rank == 9) || (lhs_rank == 9 && rhs_rank == 2)) { return 4; }
    if ((lhs_rank == 3 && rhs_rank == 3)) { return 5; } // n^2
    if ((lhs_rank == 3 && rhs_rank == 9) || (lhs_rank == 9 && rhs_rank == 3)) { return 5; } // n^2 loglogn ~= n^2
    if ((lhs_rank == 4 && rhs_rank == 3) || (lhs_rank == 3 && rhs_rank == 4)) { return 6; } // n^2 logn ~= n^3 bucket
    if ((lhs_rank == 5 && rhs_rank == 3) || (lhs_rank == 3 && rhs_rank == 5)) { return 6; } // n^3
    if ((lhs_rank == 4 && rhs_rank == 2) || (lhs_rank == 2 && rhs_rank == 4)) { return 5; }
    if ((lhs_rank == 5 && rhs_rank == 2) || (lhs_rank == 2 && rhs_rank == 5)) { return 6; }
    if ((lhs_rank == 4 && rhs_rank == 4) || (lhs_rank == 5 && rhs_rank == 5)) { return 6; }
    if ((lhs_rank == 9 && rhs_rank == 9)) { return 5; }
    if (lhs_rank > rhs_rank) { return lhs_rank; }
    return rhs_rank;
}

func annotation_complexity_stmt_infer_rank(stmt: *AstNode, constraints_ann: *CompilerAnnotationParsed, fallback_bound: u64) -> u64 {
    if (stmt == 0) { return 1; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 1; }
    var kind: u64 = ast_kind(stmt);
    match (kind) {
        case AST_BLOCK:
            var blk: *AstBlock = (*AstBlock)stmt;
            if (blk.stmts_vec == 0) { return 1; }
            var best_blk: u64 = 1;
            var bn: u64 = blk.stmts_vec.len();
            for (var bi: u64 = 0; bi < bn; bi++) {
                var r_blk: u64 = annotation_complexity_stmt_infer_rank(blk.stmts_vec.get(bi), constraints_ann, fallback_bound);
                if (annotation_complexity_rank_order(r_blk) > annotation_complexity_rank_order(best_blk)) { best_blk = r_blk; }
            }
            return best_blk;
        case AST_IF:
            var ifs: *AstIf = (*AstIf)stmt;
            var tr: u64 = annotation_complexity_stmt_infer_rank(ifs.then_block, constraints_ann, fallback_bound);
            var er: u64 = annotation_complexity_stmt_infer_rank(ifs.else_block, constraints_ann, fallback_bound);
            if (annotation_complexity_rank_order(tr) >= annotation_complexity_rank_order(er)) { return tr; }
            return er;
        case AST_WHILE:
            var wl: *AstWhile = (*AstWhile)stmt;
            var it_rw: u64 = annotation_complexity_loop_iteration_rank_with_ctx(wl.cond, 0, wl.body, constraints_ann, fallback_bound);
            var body_rw: u64 = annotation_complexity_stmt_infer_rank(wl.body, constraints_ann, fallback_bound);
            return annotation_complexity_rank_mul(it_rw, body_rw);
        case AST_FOR:
            var fr: *AstFor = (*AstFor)stmt;
            var init_rf: u64 = annotation_complexity_stmt_infer_rank(fr.init, constraints_ann, fallback_bound);
            var it_rf: u64 = annotation_complexity_loop_iteration_rank_with_ctx(fr.cond, fr.update, fr.body, constraints_ann, fallback_bound);
            var it_rf_known: u64 = 0;
            var it_rf_precise: u64 = annotation_complexity_for_iterations_precise_with_status(fr, constraints_ann, fallback_bound, &it_rf_known);
            if (it_rf_known != 0 && it_rf_precise <= 1) { it_rf = 1; }
            var body_rf: u64 = annotation_complexity_stmt_infer_rank(fr.body, constraints_ann, fallback_bound);
            var loop_rf: u64 = annotation_complexity_rank_mul(it_rf, body_rf);
            if (annotation_complexity_rank_order(loop_rf) >= annotation_complexity_rank_order(init_rf)) { return loop_rf; }
            return init_rf;
        case AST_DO_WHILE:
            var dw: *AstDoWhile = (*AstDoWhile)stmt;
            var it_rd: u64 = annotation_complexity_loop_iteration_rank_with_ctx(dw.cond, 0, dw.body, constraints_ann, fallback_bound);
            var body_rd: u64 = annotation_complexity_stmt_infer_rank(dw.body, constraints_ann, fallback_bound);
            return annotation_complexity_rank_mul(it_rd, body_rd);
        case AST_SWITCH:
        case AST_MATCH:
            var sw: *AstSwitch = (*AstSwitch)stmt;
            if (sw.cases_vec == 0) { return 1; }
            var best_sw: u64 = 1;
            var cn: u64 = sw.cases_vec.len();
            for (var ci: u64 = 0; ci < cn; ci++) {
                var r_sw: u64 = annotation_complexity_stmt_infer_rank(sw.cases_vec.get(ci), constraints_ann, fallback_bound);
                if (annotation_complexity_rank_order(r_sw) > annotation_complexity_rank_order(best_sw)) { best_sw = r_sw; }
            }
            return best_sw;
        case AST_CASE:
            return annotation_complexity_stmt_infer_rank(((*AstCase)stmt).body, constraints_ann, fallback_bound);
        case AST_DEFER:
            return annotation_complexity_stmt_infer_rank(((*AstDefer)stmt).stmt, constraints_ann, fallback_bound);
        default:
            return 1;
    }
}

func annotation_complexity_estimate_stmt_ops(stmt: *AstNode, constraints_ann: *CompilerAnnotationParsed, fallback_bound: u64) -> u64 {
    var cap: u64 = 9223372036854775807;
    if (stmt == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    match (kind) {
        case AST_BLOCK:
            var blk: *AstBlock = (*AstBlock)stmt;
            if (blk.stmts_vec == 0) { return 0; }
            var sum: u64 = 0;
            var bn: u64 = blk.stmts_vec.len();
            for (var bi: u64 = 0; bi < bn; bi++) {
                sum = annotation_complexity_sat_add(sum, annotation_complexity_estimate_stmt_ops(blk.stmts_vec.get(bi), constraints_ann, fallback_bound), cap);
            }
            return sum;
        case AST_IF:
            var ifs: *AstIf = (*AstIf)stmt;
            var t_ops: u64 = annotation_complexity_estimate_stmt_ops(ifs.then_block, constraints_ann, fallback_bound);
            var e_ops: u64 = annotation_complexity_estimate_stmt_ops(ifs.else_block, constraints_ann, fallback_bound);
            if (t_ops > e_ops) { return annotation_complexity_sat_add(t_ops, 1, cap); }
            return annotation_complexity_sat_add(e_ops, 1, cap);
        case AST_WHILE:
            var wl: *AstWhile = (*AstWhile)stmt;
            var it_w: u64 = annotation_complexity_loop_iterations_with_ctx(wl.cond, 0, wl.body, constraints_ann, fallback_bound);
            var body_w: u64 = annotation_complexity_estimate_stmt_ops(wl.body, constraints_ann, fallback_bound);
            return annotation_complexity_sat_mul(it_w, annotation_complexity_sat_add(body_w, 1, cap), cap);
        case AST_FOR:
            var fr: *AstFor = (*AstFor)stmt;
            var init_ops: u64 = annotation_complexity_estimate_stmt_ops(fr.init, constraints_ann, fallback_bound);
            var it_f_known: u64 = 0;
            var it_f: u64 = annotation_complexity_for_iterations_precise_with_status(fr, constraints_ann, fallback_bound, &it_f_known);
            if (it_f_known == 0) {
                it_f = annotation_complexity_loop_iterations_with_ctx(fr.cond, fr.update, fr.body, constraints_ann, fallback_bound);
            }
            var body_f: u64 = annotation_complexity_estimate_stmt_ops(fr.body, constraints_ann, fallback_bound);
            var loop_total: u64 = annotation_complexity_sat_mul(it_f, annotation_complexity_sat_add(body_f, 1, cap), cap);
            return annotation_complexity_sat_add(init_ops, loop_total, cap);
        case AST_DO_WHILE:
            var dw: *AstDoWhile = (*AstDoWhile)stmt;
            var it_d: u64 = annotation_complexity_loop_iterations_with_ctx(dw.cond, 0, dw.body, constraints_ann, fallback_bound);
            var body_d: u64 = annotation_complexity_estimate_stmt_ops(dw.body, constraints_ann, fallback_bound);
            return annotation_complexity_sat_mul(it_d, annotation_complexity_sat_add(body_d, 1, cap), cap);
        case AST_SWITCH:
        case AST_MATCH:
            var sw: *AstSwitch = (*AstSwitch)stmt;
            if (sw.cases_vec == 0) { return 1; }
            var mx: u64 = 0;
            var cn: u64 = sw.cases_vec.len();
            for (var ci: u64 = 0; ci < cn; ci++) {
                var c_ops: u64 = annotation_complexity_estimate_stmt_ops(sw.cases_vec.get(ci), constraints_ann, fallback_bound);
                if (c_ops > mx) { mx = c_ops; }
            }
            return annotation_complexity_sat_add(mx, 1, cap);
        case AST_CASE:
            return annotation_complexity_estimate_stmt_ops(((*AstCase)stmt).body, constraints_ann, fallback_bound);
        case AST_DEFER:
            return annotation_complexity_estimate_stmt_ops(((*AstDefer)stmt).stmt, constraints_ann, fallback_bound);
        default:
            return 1;
    }
}

func annotation_complexity_estimate_ast_ops(fn: *AstFunc, constraints_ann: *CompilerAnnotationParsed) -> u64 {
    if (fn == 0 || fn.body == 0) { return 0; }
    var fb: u64 = annotation_complexity_constraints_max(constraints_ann);
    return annotation_complexity_estimate_stmt_ops(fn.body, constraints_ann, fb);
}

func annotation_complexity_estimate_ops(rank: u64, n_bound: u64) -> u64 {
    var cap: u64 = 9223372036854775807;
    if (rank == 1) { return 1; }
    if (rank == 2) { return annotation_complexity_log2_floor(n_bound + 1); }
    if (rank == 12) {
        var lg2: u64 = annotation_complexity_log2_floor(n_bound + 1);
        return annotation_complexity_sat_mul(lg2, lg2, cap);
    }
    if (rank == 11) { return annotation_complexity_ifourth_root_floor(n_bound); }
    if (rank == 10) { return annotation_complexity_isqrt_floor(n_bound); }
    if (rank == 3) { return n_bound; }
    if (rank == 9) {
        var lg: u64 = annotation_complexity_log2_floor(n_bound + 1);
        var lglg: u64 = annotation_complexity_log2_floor(lg + 1);
        return annotation_complexity_sat_mul(n_bound, lglg, cap);
    }
    if (rank == 4) {
        return annotation_complexity_sat_mul(n_bound, annotation_complexity_log2_floor(n_bound + 1), cap);
    }
    if (rank == 5) {
        return annotation_complexity_sat_mul(n_bound, n_bound, cap);
    }
    if (rank == 6) {
        var sq: u64 = annotation_complexity_sat_mul(n_bound, n_bound, cap);
        return annotation_complexity_sat_mul(sq, n_bound, cap);
    }
    if (rank == 7) {
        // Exponential growth.
        if (n_bound >= 63) { return cap; }
        return (1 << n_bound);
    }
    if (rank == 8) {
        // Factorial growth (strictly stronger than exponential).
        if (n_bound >= 21) { return cap; }
        var fac: u64 = 1;
        for (var i: u64 = 2; i <= n_bound; i++) {
            fac = annotation_complexity_sat_mul(fac, i, cap);
        }
        return fac;
    }
    if (rank == 13) {
        // n! multiplied by at least polynomial/log factors.
        if (n_bound >= 20) { return cap; }
        var fac2: u64 = 1;
        for (var j: u64 = 2; j <= n_bound; j++) {
            fac2 = annotation_complexity_sat_mul(fac2, j, cap);
        }
        return annotation_complexity_sat_mul(fac2, n_bound + 1, cap);
    }
    return 0;
}

func annotation_complexity_rank_order(rank: u64) -> u64 {
    match (rank) {
        case 1: return 1; // O(1)
        case 2: return 2; // O(log n)
        case 12: return 3; // O(log^2 n)
        case 11: return 4; // O(n^(1/4))
        case 10: return 5; // O(sqrt n)
        case 3: return 6; // O(n)
        case 9: return 7; // O(n log log n)
        case 4: return 8; // O(n log n)
        case 5: return 9; // O(n^2)
        case 6: return 10; // O(n^3)
        case 7: return 11; // O(2^n)
        case 8: return 12; // O(n!)
        case 13: return 13; // O(n!*poly)
    }
    return 0;
}

func annotation_complexity_rank_exceeds(lhs_rank: u64, rhs_rank: u64) -> u64 {
    var l: u64 = annotation_complexity_rank_order(lhs_rank);
    var r: u64 = annotation_complexity_rank_order(rhs_rank);
    if (l == 0 || r == 0) { return 0; }
    if (l > r) { return 1; }
    return 0;
}

func annotation_complexity_memo_state_count_from_arg(arg: *CompilerAnnotationArg) -> u64 {
    if (arg == 0) { return 0; }
    if (arg.kind == 1) {
        if (annotation_complexity_is_ident_token(arg.ident_ptr, arg.ident_len) != 0) { return 1; }
        return 0;
    }
    if (arg.kind != 3) { return 0; }
    var norm: *NameInfo = annotation_complexity_normalize(arg.string_ptr, arg.string_len);
    if (norm == 0 || norm.ptr == 0 || norm.len == 0) { return 0; }
    var p: u64 = norm.ptr;
    var n: u64 = norm.len;
    var s: []u8 = slice(p, n);
    var count: u64 = 0;
    var start: u64 = 0;
    for (var i: u64 = 0; i <= n; i++) {
        if (i == n || s[i] == 44) { // ','
            if (i <= start) { return 0; }
            var tok_len: u64 = i - start;
            if (annotation_complexity_is_ident_token(p + start, tok_len) == 0) { return 0; }
            count = count + 1;
            start = i + 1;
        }
    }
    return count;
}

func annotation_complexity_validate_annotation_args(fn: *AstFunc, ann: *CompilerAnnotationParsed) -> u64 {
    if (ann == 0) { return 0; }
    var args_n: u64 = 0;
    if (ann.args_vec != 0) { args_n = ann.args_vec.len(); }

    if (str_eq(ann.name_ptr, ann.name_len, "complexity", 10) != 0 ||
        str_eq(ann.name_ptr, ann.name_len, "complexity_budget", 17) != 0) {
        if (args_n == 0) {
            return annotation_emit_invalid_args(fn, ann, "requires at least time=\"O(...)\"/expr=\"O(...)\" or space=\"O(...)\"");
        }
        var has_time_or_space: u64 = 0;
        for (var i: u64 = 0; i < args_n; i++) {
            var arg: *CompilerAnnotationArg = ann.args_vec.get(i);
            if (arg == 0 || arg.key_ptr == 0 || arg.key_len == 0) {
                return annotation_emit_invalid_args(fn, ann, "requires key=value arguments");
            }
            if (str_eq(arg.key_ptr, arg.key_len, "time", 4) != 0 ||
                str_eq(arg.key_ptr, arg.key_len, "space", 5) != 0 ||
                str_eq(arg.key_ptr, arg.key_len, "expr", 4) != 0) {
                if (arg.kind != 3) {
                    return annotation_emit_invalid_args(fn, ann, "time/space/expr must be string complexity expressions");
                }
                has_time_or_space = 1;
                if (annotation_complexity_is_valid_o_string(arg.string_ptr, arg.string_len) == 0) {
                    return annotation_emit_invalid_args(fn, ann, "complexity expression must look like O(...)");
                }
            } else if (str_eq(arg.key_ptr, arg.key_len, "mode", 4) != 0) {
                if (annotation_complexity_parse_mode_arg(arg) == ANN_COMPLEXITY_MODE_UNSPEC) {
                    return annotation_emit_invalid_args(fn, ann, "mode must be one of: worst, expected, high_prob, amortized");
                }
            } else if (str_eq(arg.key_ptr, arg.key_len, "memo_state", 10) != 0) {
                if (arg.kind != 1 && arg.kind != 3) {
                    return annotation_emit_invalid_args(fn, ann, "memo_state must be identifier or string");
                }
                if (annotation_complexity_memo_state_count_from_arg(arg) == 0) {
                    return annotation_emit_invalid_args(fn, ann, "memo_state must be identifier or comma-separated identifiers");
                }
            } else if (str_eq(arg.key_ptr, arg.key_len, "memo_transition", 15) != 0) {
                if (arg.kind != 3 || annotation_complexity_is_valid_o_string(arg.string_ptr, arg.string_len) == 0) {
                    return annotation_emit_invalid_args(fn, ann, "memo_transition must be string O(...)");
                }
            } else {
                return annotation_emit_invalid_args(fn, ann, "only 'time', 'expr', 'space', 'mode', 'memo_state', 'memo_transition' are allowed");
            }
        }
        if (has_time_or_space == 0) {
            return annotation_emit_invalid_args(fn, ann, "requires at least one of: time, expr, space");
        }
        return 1;
    }

    if (str_eq(ann.name_ptr, ann.name_len, "complexity_input", 16) != 0) {
        if (args_n == 0) {
            return annotation_emit_invalid_args(fn, ann, "requires at least one named input mapping");
        }
        for (var j: u64 = 0; j < args_n; j++) {
            var arg2: *CompilerAnnotationArg = ann.args_vec.get(j);
            if (arg2 == 0 || arg2.key_ptr == 0 || arg2.key_len == 0) {
                return annotation_emit_invalid_args(fn, ann, "all arguments must be key=value pairs");
            }
            if (arg2.kind != 3 && arg2.kind != 1) {
                return annotation_emit_invalid_args(fn, ann, "input mappings must be string/identifier expressions");
            }
            var mapped_ptr: u64 = 0;
            var mapped_len: u64 = 0;
            if (annotation_complexity_extract_input_target_ident(arg2, &mapped_ptr, &mapped_len) == 0) {
                return annotation_emit_invalid_args(fn, ann, "input mapping values must be identifier or len(x)/size(x)/length(x)");
            }
            for (var k: u64 = 0; k < j; k++) {
                var prev: *CompilerAnnotationArg = ann.args_vec.get(k);
                if (prev != 0 && prev.key_ptr != 0 && prev.key_len != 0 &&
                    str_eq(prev.key_ptr, prev.key_len, arg2.key_ptr, arg2.key_len) != 0) {
                    return annotation_emit_invalid_args(fn, ann, "duplicate complexity_input key is not allowed");
                }
            }
        }
        return 1;
    }

    if (str_eq(ann.name_ptr, ann.name_len, "complexity_memo", 15) != 0) {
        if (args_n == 0) {
            return annotation_emit_invalid_args(fn, ann, "requires state=\"n\" or state=\"n,m,...\"");
        }
        var state_arg: *CompilerAnnotationArg = annotation_complexity_find_named_arg(ann, "state", 5);
        if (state_arg == 0 || annotation_complexity_memo_state_count_from_arg(state_arg) == 0) {
            return annotation_emit_invalid_args(fn, ann, "complexity_memo requires state as identifier or comma-separated identifier string");
        }
        for (var jm: u64 = 0; jm < args_n; jm++) {
            var marg: *CompilerAnnotationArg = ann.args_vec.get(jm);
            if (marg == 0 || marg.key_ptr == 0 || marg.key_len == 0) {
                return annotation_emit_invalid_args(fn, ann, "complexity_memo arguments must be key=value");
            }
            if (str_eq(marg.key_ptr, marg.key_len, "state", 5) != 0) {
                if (marg.kind != 1 && marg.kind != 3) {
                    return annotation_emit_invalid_args(fn, ann, "complexity_memo state must be identifier or string");
                }
            } else if (str_eq(marg.key_ptr, marg.key_len, "transition", 10) != 0) {
                if (marg.kind != 3 || annotation_complexity_is_valid_o_string(marg.string_ptr, marg.string_len) == 0) {
                    return annotation_emit_invalid_args(fn, ann, "complexity_memo transition must be string O(...)");
                }
            } else {
                return annotation_emit_invalid_args(fn, ann, "complexity_memo only allows state and transition");
            }
        }
        return 1;
    }

    if (str_eq(ann.name_ptr, ann.name_len, "complexity_ignore", 17) != 0) {
        if (args_n != 1) {
            return annotation_emit_invalid_args(fn, ann, "requires exactly one argument: reason=\"...\"");
        }
        var reason_arg: *CompilerAnnotationArg = ann.args_vec.get(0);
        if (reason_arg == 0 || reason_arg.key_ptr == 0 || reason_arg.kind != 3 ||
            str_eq(reason_arg.key_ptr, reason_arg.key_len, "reason", 6) == 0) {
            return annotation_emit_invalid_args(fn, ann, "requires reason=\"...\"");
        }
        return 1;
    }

    if (str_eq(ann.name_ptr, ann.name_len, "constraints", 11) != 0) {
        if (args_n == 0) {
            return annotation_emit_invalid_args(fn, ann, "requires at least one named upper bound like n=200000");
        }
        for (var k: u64 = 0; k < args_n; k++) {
            var arg3: *CompilerAnnotationArg = ann.args_vec.get(k);
            if (arg3 == 0 || arg3.key_ptr == 0 || arg3.key_len == 0) {
                return annotation_emit_invalid_args(fn, ann, "constraints expects key=value pairs");
            }
            if (arg3.kind == 2) { continue; }
            if (arg3.kind == 3 && annotation_complexity_constraints_is_relation_key(arg3.key_ptr, arg3.key_len) != 0) { continue; }
            return annotation_emit_invalid_args(fn, ann, "constraints expects key=int and optional relation strings (rel*=...)");
        }
        return 1;
    }

    if (str_eq(ann.name_ptr, ann.name_len, "time_limit", 10) != 0) {
        var ms_arg: *CompilerAnnotationArg = annotation_complexity_find_named_arg(ann, "ms", 2);
        if (ms_arg == 0 || ms_arg.kind != 2) {
            return annotation_emit_invalid_args(fn, ann, "time_limit requires ms=<int>");
        }
        for (var t: u64 = 0; t < args_n; t++) {
            var arg4: *CompilerAnnotationArg = ann.args_vec.get(t);
            if (arg4 == 0 || arg4.key_ptr == 0 || arg4.key_len == 0) {
                return annotation_emit_invalid_args(fn, ann, "time_limit arguments must be key=value");
            }
            if (str_eq(arg4.key_ptr, arg4.key_len, "ms", 2) != 0) {
                if (arg4.kind != 2) {
                    return annotation_emit_invalid_args(fn, ann, "time_limit ms must be integer");
                }
            } else if (str_eq(arg4.key_ptr, arg4.key_len, "machine", 7) != 0) {
                if (arg4.kind != 3 && arg4.kind != 1) {
                    return annotation_emit_invalid_args(fn, ann, "time_limit machine must be string/identifier");
                }
            } else if (str_eq(arg4.key_ptr, arg4.key_len, "ops_per_ms", 10) != 0) {
                if (arg4.kind != 2) {
                    return annotation_emit_invalid_args(fn, ann, "time_limit ops_per_ms must be integer");
                }
            } else {
                return annotation_emit_invalid_args(fn, ann, "time_limit only allows ms, machine, ops_per_ms");
            }
        }
        return 1;
    }

    if (str_eq(ann.name_ptr, ann.name_len, "complexity_debug", 16) != 0) {
        if (args_n == 0) { return 1; }
        for (var d: u64 = 0; d < args_n; d++) {
            var dbg_arg: *CompilerAnnotationArg = ann.args_vec.get(d);
            if (dbg_arg == 0 || dbg_arg.key_ptr == 0 || dbg_arg.key_len == 0) {
                return annotation_emit_invalid_args(fn, ann, "complexity_debug arguments must be key=value");
            }
            if (dbg_arg.kind != 4) {
                return annotation_emit_invalid_args(fn, ann, "complexity_debug values must be bool");
            }
            if (str_eq(dbg_arg.key_ptr, dbg_arg.key_len, "enabled", 7) == 0 &&
                str_eq(dbg_arg.key_ptr, dbg_arg.key_len, "strict_input", 12) == 0 &&
                str_eq(dbg_arg.key_ptr, dbg_arg.key_len, "warnings_as_errors", 18) == 0) {
                return annotation_emit_invalid_args(fn, ann, "complexity_debug only allows enabled, strict_input, warnings_as_errors");
            }
        }
        return 1;
    }

    return 1;
}

func annotation_complexity_scan_expr_for_self_calls(expr: *AstNode, fn_name_ptr: u64, fn_name_len: u64, call_count: *u64) -> u64 {
    if (expr == 0 || call_count == 0) { return 0; }
    var kind: u64 = ast_kind(expr);
    var nref: AstNodeTagRef;
    nref.node = expr;
    match (kind) {
        case AST_CALL:
            if (annotation_complexity_name_matches_self_call(nref.call.name_ptr, nref.call.name_len, fn_name_ptr, fn_name_len) != 0) {
                *call_count = *call_count + 1;
            }
            if (nref.call.args_vec != 0) {
                var an: u64 = nref.call.args_vec.len();
                for (var i: u64 = 0; i < an; i++) {
                    annotation_complexity_scan_expr_for_self_calls(nref.call.args_vec.get(i), fn_name_ptr, fn_name_len, call_count);
                }
            }
            return 0;
        case AST_GENERIC_CALL:
            if (annotation_complexity_name_matches_self_call(nref.generic_call.name_ptr, nref.generic_call.name_len, fn_name_ptr, fn_name_len) != 0) {
                *call_count = *call_count + 1;
            }
            if (nref.generic_call.args_vec != 0) {
                var gn: u64 = nref.generic_call.args_vec.len();
                for (var gi: u64 = 0; gi < gn; gi++) {
                    annotation_complexity_scan_expr_for_self_calls(nref.generic_call.args_vec.get(gi), fn_name_ptr, fn_name_len, call_count);
                }
            }
            return 0;
        case AST_BINARY:
            annotation_complexity_scan_expr_for_self_calls(nref.binary.left, fn_name_ptr, fn_name_len, call_count);
            annotation_complexity_scan_expr_for_self_calls(nref.binary.right, fn_name_ptr, fn_name_len, call_count);
            return 0;
        case AST_UNARY:
            annotation_complexity_scan_expr_for_self_calls(nref.unary.operand, fn_name_ptr, fn_name_len, call_count);
            return 0;
        case AST_METHOD_CALL:
        case AST_SAFE_METHOD_CALL:
            annotation_complexity_scan_expr_for_self_calls(nref.method_call.receiver, fn_name_ptr, fn_name_len, call_count);
            if (nref.method_call.args_vec != 0) {
                var mn: u64 = nref.method_call.args_vec.len();
                for (var j: u64 = 0; j < mn; j++) {
                    annotation_complexity_scan_expr_for_self_calls(nref.method_call.args_vec.get(j), fn_name_ptr, fn_name_len, call_count);
                }
            }
            return 0;
        case AST_CALL_PTR:
            if (nref.call_ptr.callee != 0 && ast_kind(nref.call_ptr.callee) == AST_IDENT) {
                var cid: *AstIdent = (*AstIdent)nref.call_ptr.callee;
                if (annotation_complexity_name_matches_self_call(cid.name_ptr, cid.name_len, fn_name_ptr, fn_name_len) != 0) {
                    *call_count = *call_count + 1;
                }
            }
            annotation_complexity_scan_expr_for_self_calls(nref.call_ptr.callee, fn_name_ptr, fn_name_len, call_count);
            if (nref.call_ptr.args_vec != 0) {
                var pn: u64 = nref.call_ptr.args_vec.len();
                for (var k: u64 = 0; k < pn; k++) {
                    annotation_complexity_scan_expr_for_self_calls(nref.call_ptr.args_vec.get(k), fn_name_ptr, fn_name_len, call_count);
                }
            }
            return 0;
        case AST_INDEX:
        case AST_SAFE_INDEX:
            annotation_complexity_scan_expr_for_self_calls(nref.index_expr.base, fn_name_ptr, fn_name_len, call_count);
            annotation_complexity_scan_expr_for_self_calls(nref.index_expr.index, fn_name_ptr, fn_name_len, call_count);
            return 0;
        case AST_MEMBER_ACCESS:
        case AST_SAFE_MEMBER_ACCESS:
            annotation_complexity_scan_expr_for_self_calls(nref.member_access.object, fn_name_ptr, fn_name_len, call_count);
            return 0;
        case AST_CAST:
            annotation_complexity_scan_expr_for_self_calls(nref.cast_expr.expr, fn_name_ptr, fn_name_len, call_count);
            return 0;
        case AST_ADDR_OF:
            annotation_complexity_scan_expr_for_self_calls(nref.addr_of.operand, fn_name_ptr, fn_name_len, call_count);
            return 0;
        case AST_DEREF:
            annotation_complexity_scan_expr_for_self_calls(nref.deref.operand, fn_name_ptr, fn_name_len, call_count);
            return 0;
        case AST_DEREF8:
            annotation_complexity_scan_expr_for_self_calls(nref.deref8.operand, fn_name_ptr, fn_name_len, call_count);
            return 0;
        case AST_TRY:
            annotation_complexity_scan_expr_for_self_calls(nref.try_expr.operand, fn_name_ptr, fn_name_len, call_count);
            return 0;
        case AST_TERNARY:
            annotation_complexity_scan_expr_for_self_calls(nref.ternary_expr.cond, fn_name_ptr, fn_name_len, call_count);
            annotation_complexity_scan_expr_for_self_calls(nref.ternary_expr.then_expr, fn_name_ptr, fn_name_len, call_count);
            annotation_complexity_scan_expr_for_self_calls(nref.ternary_expr.else_expr, fn_name_ptr, fn_name_len, call_count);
            return 0;
    }
    return 0;
}

func annotation_complexity_name_matches_mangled_suffix(full_ptr: u64, full_len: u64, target_ptr: u64, target_len: u64) -> u64 {
    if (full_ptr == 0 || full_len == 0 || target_ptr == 0 || target_len == 0) { return 0; }
    if (full_len < target_len + 2) { return 0; }
    var off: u64 = full_len - target_len;
    var full: []u8 = slice(full_ptr, full_len);
    if (full[off - 1] == 95 && full[off - 2] == 95 &&
        str_eq(full_ptr + off, target_len, target_ptr, target_len) != 0) {
        return 1;
    }
    return 0;
}

func annotation_complexity_name_matches_self_call(call_ptr: u64, call_len: u64, fn_ptr: u64, fn_len: u64) -> u64 {
    if (call_ptr == 0 || call_len == 0 || fn_ptr == 0 || fn_len == 0) { return 0; }
    if (str_eq(call_ptr, call_len, fn_ptr, fn_len) != 0) { return 1; }
    if (annotation_complexity_name_matches_mangled_suffix(call_ptr, call_len, fn_ptr, fn_len) != 0) { return 1; }
    if (annotation_complexity_name_matches_mangled_suffix(fn_ptr, fn_len, call_ptr, call_len) != 0) { return 1; }
    return 0;
}

func annotation_complexity_expr_is_self_receiver(expr: *AstNode) -> u64 {
    if (expr == 0) { return 0; }
    var kind: u64 = ast_kind(expr);
    if (kind == AST_IDENT) {
        var id: *AstIdent = (*AstIdent)expr;
        if (id != 0 && id.name_ptr != 0 && id.name_len == 4 && str_eq(id.name_ptr, id.name_len, "self", 4) != 0) {
            return 1;
        }
        return 0;
    }
    if (kind == AST_CAST) { return annotation_complexity_expr_is_self_receiver(((*AstCast)expr).expr); }
    if (kind == AST_ADDR_OF) { return annotation_complexity_expr_is_self_receiver(((*AstAddrOf)expr).operand); }
    if (kind == AST_DEREF) { return annotation_complexity_expr_is_self_receiver(((*AstDeref)expr).operand); }
    if (kind == AST_DEREF8) { return annotation_complexity_expr_is_self_receiver(((*AstDeref8)expr).operand); }
    if (kind == AST_MEMBER_ACCESS || kind == AST_SAFE_MEMBER_ACCESS) {
        return annotation_complexity_expr_is_self_receiver(((*AstMemberAccess)expr).object);
    }
    if (kind == AST_INDEX || kind == AST_SAFE_INDEX) {
        return annotation_complexity_expr_is_self_receiver(((*AstIndex)expr).base);
    }
    if (kind == AST_TRY) {
        return annotation_complexity_expr_is_self_receiver(((*AstTry)expr).operand);
    }
    return 0;
}

func annotation_complexity_method_call_is_self_recursive(mc: *AstMethodCall, self_fn: *AstFunc) -> u64 {
    if (mc == 0 || self_fn == 0) { return 0; }
    if (annotation_complexity_expr_is_self_receiver(mc.receiver) == 0) { return 0; }

    var owner_ptr: u64 = self_fn.impl_owner_ptr;
    var owner_len: u64 = self_fn.impl_owner_len;
    if (owner_ptr == 0 || owner_len == 0) {
        var owner_info: *NameInfo = sym_get_impl_method_owner(self_fn.name_ptr, self_fn.name_len);
        if (owner_info != 0) {
            owner_ptr = owner_info.ptr;
            owner_len = owner_info.len;
        }
    }
    if (owner_ptr == 0 || owner_len == 0) { return 0; }

    var self_method_ptr: u64 = self_fn.impl_original_name_ptr;
    var self_method_len: u64 = self_fn.impl_original_name_len;
    if (self_method_ptr == 0 || self_method_len == 0) {
        self_method_ptr = self_fn.name_ptr;
        self_method_len = self_fn.name_len;
    }
    if (self_method_ptr == 0 || self_method_len == 0) { return 0; }

    if (str_eq(mc.method_ptr, mc.method_len, self_method_ptr, self_method_len) != 0) { return 1; }
    if (annotation_complexity_name_matches_self_call(mc.method_ptr, mc.method_len, self_method_ptr, self_method_len) != 0) { return 1; }
    if (annotation_complexity_name_matches_self_call(mc.method_ptr, mc.method_len, self_fn.name_ptr, self_fn.name_len) != 0) { return 1; }
    return 0;
}

func annotation_complexity_scan_stmt(stmt: *AstNode, fn_name_ptr: u64, fn_name_len: u64, depth: u64, max_depth: *u64, self_calls: *u64) -> u64 {
    if (stmt == 0 || max_depth == 0 || self_calls == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    if (kind == AST_WHILE || kind == AST_FOR || kind == AST_DO_WHILE) {
        var loop_depth: u64 = depth + 1;
        if (loop_depth > *max_depth) { *max_depth = loop_depth; }
        if (kind == AST_WHILE) {
            var wl: *AstWhile = (*AstWhile)stmt;
            annotation_complexity_scan_expr_for_self_calls(wl.cond, fn_name_ptr, fn_name_len, self_calls);
            annotation_complexity_scan_stmt(wl.body, fn_name_ptr, fn_name_len, loop_depth, max_depth, self_calls);
            return 0;
        }
        if (kind == AST_FOR) {
            var fr: *AstFor = (*AstFor)stmt;
            annotation_complexity_scan_stmt(fr.init, fn_name_ptr, fn_name_len, loop_depth, max_depth, self_calls);
            annotation_complexity_scan_expr_for_self_calls(fr.cond, fn_name_ptr, fn_name_len, self_calls);
            annotation_complexity_scan_expr_for_self_calls(fr.update, fn_name_ptr, fn_name_len, self_calls);
            annotation_complexity_scan_stmt(fr.body, fn_name_ptr, fn_name_len, loop_depth, max_depth, self_calls);
            return 0;
        }
        var dw: *AstDoWhile = (*AstDoWhile)stmt;
        annotation_complexity_scan_stmt(dw.body, fn_name_ptr, fn_name_len, loop_depth, max_depth, self_calls);
        annotation_complexity_scan_expr_for_self_calls(dw.cond, fn_name_ptr, fn_name_len, self_calls);
        return 0;
    }

    match (kind) {
        case AST_BLOCK:
            var blk: *AstBlock = (*AstBlock)stmt;
            if (blk.stmts_vec != 0) {
                var n: u64 = blk.stmts_vec.len();
                for (var i: u64 = 0; i < n; i++) {
                    annotation_complexity_scan_stmt(blk.stmts_vec.get(i), fn_name_ptr, fn_name_len, depth, max_depth, self_calls);
                }
            }
            return 0;
        case AST_IF:
            var ifs: *AstIf = (*AstIf)stmt;
            annotation_complexity_scan_expr_for_self_calls(ifs.cond, fn_name_ptr, fn_name_len, self_calls);
            annotation_complexity_scan_stmt(ifs.then_block, fn_name_ptr, fn_name_len, depth, max_depth, self_calls);
            annotation_complexity_scan_stmt(ifs.else_block, fn_name_ptr, fn_name_len, depth, max_depth, self_calls);
            return 0;
        case AST_SWITCH:
        case AST_MATCH:
            var sw: *AstSwitch = (*AstSwitch)stmt;
            annotation_complexity_scan_expr_for_self_calls(sw.expr, fn_name_ptr, fn_name_len, self_calls);
            if (sw.cases_vec != 0) {
                var cn: u64 = sw.cases_vec.len();
                for (var c: u64 = 0; c < cn; c++) {
                    annotation_complexity_scan_stmt(sw.cases_vec.get(c), fn_name_ptr, fn_name_len, depth, max_depth, self_calls);
                }
            }
            return 0;
        case AST_CASE:
            var cs: *AstCase = (*AstCase)stmt;
            annotation_complexity_scan_expr_for_self_calls(cs.value, fn_name_ptr, fn_name_len, self_calls);
            annotation_complexity_scan_stmt(cs.body, fn_name_ptr, fn_name_len, depth, max_depth, self_calls);
            return 0;
        case AST_RETURN:
            annotation_complexity_scan_expr_for_self_calls(((*AstReturn)stmt).expr, fn_name_ptr, fn_name_len, self_calls);
            return 0;
        case AST_VAR_DECL:
            annotation_complexity_scan_expr_for_self_calls(((*AstVarDecl)stmt).init_expr, fn_name_ptr, fn_name_len, self_calls);
            return 0;
        case AST_ASSIGN:
            annotation_complexity_scan_expr_for_self_calls(((*AstAssign)stmt).target, fn_name_ptr, fn_name_len, self_calls);
            annotation_complexity_scan_expr_for_self_calls(((*AstAssign)stmt).value, fn_name_ptr, fn_name_len, self_calls);
            return 0;
        case AST_EXPR_STMT:
            annotation_complexity_scan_expr_for_self_calls(((*AstExprStmt)stmt).expr, fn_name_ptr, fn_name_len, self_calls);
            return 0;
        case AST_DEFER:
            annotation_complexity_scan_stmt(((*AstDefer)stmt).stmt, fn_name_ptr, fn_name_len, depth, max_depth, self_calls);
            return 0;
        case AST_DELETE:
            annotation_complexity_scan_expr_for_self_calls(((*AstDelete)stmt).expr, fn_name_ptr, fn_name_len, self_calls);
            return 0;
        case AST_THROW_STMT:
            annotation_complexity_scan_expr_for_self_calls(((*AstThrowStmt)stmt).expr, fn_name_ptr, fn_name_len, self_calls);
            return 0;
    }
    return 0;
}

func annotation_complexity_expr_is_ident(expr: *AstNode, name_ptr: u64, name_len: u64) -> u64 {
    if (expr == 0) { return 0; }
    if (ast_kind(expr) != AST_IDENT) { return 0; }
    var id: *AstIdent = (*AstIdent)expr;
    if (str_eq(id.name_ptr, id.name_len, name_ptr, name_len) != 0) { return 1; }
    return 0;
}

func annotation_complexity_expr_square_ident(expr: *AstNode, out_ptr: *u64, out_len: *u64) -> u64 {
    if (expr == 0 || out_ptr == 0 || out_len == 0) { return 0; }
    if (ast_kind(expr) != AST_BINARY) { return 0; }
    var b: *AstBinary = (*AstBinary)expr;
    if (b.op != TOKEN_STAR || b.left == 0 || b.right == 0) { return 0; }
    if (ast_kind(b.left) != AST_IDENT || ast_kind(b.right) != AST_IDENT) { return 0; }
    var li: *AstIdent = (*AstIdent)b.left;
    var ri: *AstIdent = (*AstIdent)b.right;
    if (str_eq(li.name_ptr, li.name_len, ri.name_ptr, ri.name_len) == 0) { return 0; }
    *out_ptr = li.name_ptr;
    *out_len = li.name_len;
    return 1;
}

func annotation_complexity_expr_contains_ident(expr: *AstNode, name_ptr: u64, name_len: u64) -> u64 {
    if (expr == 0) { return 0; }
    var kind: u64 = ast_kind(expr);
    if (kind == AST_IDENT) {
        var id: *AstIdent = (*AstIdent)expr;
        if (str_eq(id.name_ptr, id.name_len, name_ptr, name_len) != 0) { return 1; }
        return 0;
    }
    var nref: AstNodeTagRef;
    nref.node = expr;
    match (kind) {
        case AST_BINARY:
            if (annotation_complexity_expr_contains_ident(nref.binary.left, name_ptr, name_len) != 0) { return 1; }
            if (annotation_complexity_expr_contains_ident(nref.binary.right, name_ptr, name_len) != 0) { return 1; }
            return 0;
        case AST_UNARY:
            return annotation_complexity_expr_contains_ident(nref.unary.operand, name_ptr, name_len);
        case AST_CALL:
            if (nref.call.args_vec != 0) {
                var an: u64 = nref.call.args_vec.len();
                for (var i: u64 = 0; i < an; i++) {
                    if (annotation_complexity_expr_contains_ident(nref.call.args_vec.get(i), name_ptr, name_len) != 0) { return 1; }
                }
            }
            return 0;
        case AST_GENERIC_CALL:
            if (nref.generic_call.args_vec != 0) {
                var gn: u64 = nref.generic_call.args_vec.len();
                for (var gi: u64 = 0; gi < gn; gi++) {
                    if (annotation_complexity_expr_contains_ident(nref.generic_call.args_vec.get(gi), name_ptr, name_len) != 0) { return 1; }
                }
            }
            return 0;
        case AST_STATIC_GENERIC_CALL:
            if (nref.static_generic_call.args_vec != 0) {
                var sn: u64 = nref.static_generic_call.args_vec.len();
                for (var si: u64 = 0; si < sn; si++) {
                    if (annotation_complexity_expr_contains_ident(nref.static_generic_call.args_vec.get(si), name_ptr, name_len) != 0) { return 1; }
                }
            }
            return 0;
        case AST_METHOD_CALL:
        case AST_SAFE_METHOD_CALL:
            if (annotation_complexity_expr_contains_ident(nref.method_call.receiver, name_ptr, name_len) != 0) { return 1; }
            if (nref.method_call.args_vec != 0) {
                var mn: u64 = nref.method_call.args_vec.len();
                for (var j: u64 = 0; j < mn; j++) {
                    if (annotation_complexity_expr_contains_ident(nref.method_call.args_vec.get(j), name_ptr, name_len) != 0) { return 1; }
                }
            }
            return 0;
        case AST_CALL_PTR:
            if (annotation_complexity_expr_contains_ident(nref.call_ptr.callee, name_ptr, name_len) != 0) { return 1; }
            if (nref.call_ptr.args_vec != 0) {
                var pn: u64 = nref.call_ptr.args_vec.len();
                for (var k: u64 = 0; k < pn; k++) {
                    if (annotation_complexity_expr_contains_ident(nref.call_ptr.args_vec.get(k), name_ptr, name_len) != 0) { return 1; }
                }
            }
            return 0;
        case AST_INDEX:
        case AST_SAFE_INDEX:
            if (annotation_complexity_expr_contains_ident(nref.index_expr.base, name_ptr, name_len) != 0) { return 1; }
            if (annotation_complexity_expr_contains_ident(nref.index_expr.index, name_ptr, name_len) != 0) { return 1; }
            return 0;
        case AST_MEMBER_ACCESS:
        case AST_SAFE_MEMBER_ACCESS:
            return annotation_complexity_expr_contains_ident(nref.member_access.object, name_ptr, name_len);
        case AST_CAST:
            return annotation_complexity_expr_contains_ident(nref.cast_expr.expr, name_ptr, name_len);
        case AST_NEW:
            if (nref.new_expr.literal_expr != 0 &&
                annotation_complexity_expr_contains_ident(nref.new_expr.literal_expr, name_ptr, name_len) != 0) { return 1; }
            if (nref.new_expr.ctor_args_vec != 0) {
                var nn: u64 = nref.new_expr.ctor_args_vec.len();
                for (var ni: u64 = 0; ni < nn; ni++) {
                    if (annotation_complexity_expr_contains_ident(nref.new_expr.ctor_args_vec.get(ni), name_ptr, name_len) != 0) { return 1; }
                }
            }
            return 0;
        case AST_STACK_CTOR:
            if (nref.stack_ctor.ctor_args_vec != 0) {
                var stn: u64 = nref.stack_ctor.ctor_args_vec.len();
                for (var sti: u64 = 0; sti < stn; sti++) {
                    if (annotation_complexity_expr_contains_ident(nref.stack_ctor.ctor_args_vec.get(sti), name_ptr, name_len) != 0) { return 1; }
                }
            }
            return 0;
        case AST_SIZEOF_EXPR:
            return annotation_complexity_expr_contains_ident(nref.sizeof_expr.expr, name_ptr, name_len);
        case AST_ADDR_OF:
            return annotation_complexity_expr_contains_ident(nref.addr_of.operand, name_ptr, name_len);
        case AST_DEREF:
            return annotation_complexity_expr_contains_ident(nref.deref.operand, name_ptr, name_len);
        case AST_DEREF8:
            return annotation_complexity_expr_contains_ident(nref.deref8.operand, name_ptr, name_len);
        case AST_TRY:
            return annotation_complexity_expr_contains_ident(nref.try_expr.operand, name_ptr, name_len);
        case AST_TERNARY:
            if (annotation_complexity_expr_contains_ident(nref.ternary_expr.cond, name_ptr, name_len) != 0) { return 1; }
            if (annotation_complexity_expr_contains_ident(nref.ternary_expr.then_expr, name_ptr, name_len) != 0) { return 1; }
            if (annotation_complexity_expr_contains_ident(nref.ternary_expr.else_expr, name_ptr, name_len) != 0) { return 1; }
            return 0;
    }
    return 0;
}

func annotation_complexity_popcount_u64(v: u64) -> u64 {
    var x: u64 = v;
    var out: u64 = 0;
    while (x != 0) {
        out = out + (x & 1);
        x = x >> 1;
    }
    return out;
}

func annotation_complexity_expr_param_mask(expr: *AstNode, fn: *AstFunc) -> u64 {
    if (expr == 0 || fn == 0 || fn.params_vec == 0) { return 0; }
    var mask: u64 = 0;
    var n: u64 = fn.params_vec.len();
    if (n > 63) { n = 63; }
    for (var i: u64 = 0; i < n; i = i + 1) {
        var p: *Param = fn.params_vec.get(i);
        if (p == 0 || p.name_ptr == 0 || p.name_len == 0) { continue; }
        if (annotation_complexity_expr_contains_ident(expr, p.name_ptr, p.name_len) != 0) {
            mask = mask | (1 << i);
        }
    }
    return mask;
}

func annotation_complexity_expr_index_signature(expr: *AstNode, fn: *AstFunc, out_base_ptr: *u64, out_base_len: *u64, out_dims: *u64, out_param_mask: *u64) -> u64 {
    if (expr == 0 || out_base_ptr == 0 || out_base_len == 0 || out_dims == 0 || out_param_mask == 0) { return 0; }
    var cur: *AstNode = expr;
    var dims: u64 = 0;
    var mask: u64 = 0;
    while (cur != 0) {
        var kind: u64 = ast_kind(cur);
        if (kind != AST_INDEX && kind != AST_SAFE_INDEX) { break; }
        var ix: *AstIndex = (*AstIndex)cur;
        mask = mask | annotation_complexity_expr_param_mask(ix.index, fn);
        dims = dims + 1;
        cur = ix.base;
    }
    if (dims == 0 || cur == 0 || ast_kind(cur) != AST_IDENT) { return 0; }
    var id: *AstIdent = (*AstIdent)cur;
    *out_base_ptr = id.name_ptr;
    *out_base_len = id.name_len;
    *out_dims = dims;
    *out_param_mask = mask;
    return 1;
}

func annotation_complexity_expr_index_same_base_dims(lhs: *AstNode, rhs: *AstNode, fn: *AstFunc) -> u64 {
    var lptr: u64 = 0;
    var llen: u64 = 0;
    var ldims: u64 = 0;
    var lmask: u64 = 0;
    if (annotation_complexity_expr_index_signature(lhs, fn, &lptr, &llen, &ldims, &lmask) == 0) { return 0; }
    var rptr: u64 = 0;
    var rlen: u64 = 0;
    var rdims: u64 = 0;
    var rmask: u64 = 0;
    if (annotation_complexity_expr_index_signature(rhs, fn, &rptr, &rlen, &rdims, &rmask) == 0) { return 0; }
    if (ldims != rdims) { return 0; }
    if (str_eq(lptr, llen, rptr, rlen) == 0) { return 0; }
    return 1;
}

func annotation_complexity_stmt_single_return_expr(stmt: *AstNode) -> *AstNode {
    if (stmt == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    if (kind == AST_RETURN) { return ((*AstReturn)stmt).expr; }
    if (kind != AST_BLOCK) { return 0; }
    var blk: *AstBlock = (*AstBlock)stmt;
    if (blk.stmts_vec == 0 || blk.stmts_vec.len() != 1) { return 0; }
    var st: *AstNode = blk.stmts_vec.get(0);
    if (st == 0 || ast_kind(st) != AST_RETURN) { return 0; }
    return ((*AstReturn)st).expr;
}

func annotation_complexity_stmt_has_return_index_base(stmt: *AstNode, fn: *AstFunc, base_ptr: u64, base_len: u64, dims: u64) -> u64 {
    if (stmt == 0 || base_ptr == 0 || base_len == 0 || dims == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    match (kind) {
        case AST_RETURN:
            return annotation_complexity_expr_is_index_base_dims(((*AstReturn)stmt).expr, fn, base_ptr, base_len, dims);
        case AST_BLOCK:
            var blk: *AstBlock = (*AstBlock)stmt;
            if (blk.stmts_vec != 0) {
                var bn: u64 = blk.stmts_vec.len();
                for (var bi: u64 = 0; bi < bn; bi++) {
                    if (annotation_complexity_stmt_has_return_index_base(blk.stmts_vec.get(bi), fn, base_ptr, base_len, dims) != 0) { return 1; }
                }
            }
            return 0;
        case AST_IF:
            var ifs: *AstIf = (*AstIf)stmt;
            if (annotation_complexity_stmt_has_return_index_base(ifs.then_block, fn, base_ptr, base_len, dims) != 0) { return 1; }
            return annotation_complexity_stmt_has_return_index_base(ifs.else_block, fn, base_ptr, base_len, dims);
        case AST_WHILE:
            return annotation_complexity_stmt_has_return_index_base(((*AstWhile)stmt).body, fn, base_ptr, base_len, dims);
        case AST_FOR:
            return annotation_complexity_stmt_has_return_index_base(((*AstFor)stmt).body, fn, base_ptr, base_len, dims);
        case AST_DO_WHILE:
            return annotation_complexity_stmt_has_return_index_base(((*AstDoWhile)stmt).body, fn, base_ptr, base_len, dims);
        case AST_SWITCH:
        case AST_MATCH:
            var sw: *AstSwitch = (*AstSwitch)stmt;
            if (sw.cases_vec != 0) {
                var cn: u64 = sw.cases_vec.len();
                for (var ci: u64 = 0; ci < cn; ci++) {
                    if (annotation_complexity_stmt_has_return_index_base(sw.cases_vec.get(ci), fn, base_ptr, base_len, dims) != 0) { return 1; }
                }
            }
            return 0;
        case AST_CASE:
            return annotation_complexity_stmt_has_return_index_base(((*AstCase)stmt).body, fn, base_ptr, base_len, dims);
        case AST_DEFER:
            return annotation_complexity_stmt_has_return_index_base(((*AstDefer)stmt).stmt, fn, base_ptr, base_len, dims);
    }
    return 0;
}

func annotation_complexity_if_is_memo_hit_guard(ifs: *AstIf, fn: *AstFunc, out_base_ptr: *u64, out_base_len: *u64, out_dims: *u64, out_param_mask: *u64) -> u64 {
    if (ifs == 0 || ifs.cond == 0 || out_base_ptr == 0 || out_base_len == 0 || out_dims == 0 || out_param_mask == 0) { return 0; }
    if (ast_kind(ifs.cond) != AST_BINARY) { return 0; }
    var cond: *AstBinary = (*AstBinary)ifs.cond;
    if (cond.op != TOKEN_EQEQ && cond.op != TOKEN_BANGEQ) { return 0; }

    var cptr: u64 = 0;
    var clen: u64 = 0;
    var cdims: u64 = 0;
    var cmask: u64 = 0;
    var has_cache_operand: u64 = 0;
    if (annotation_complexity_expr_index_signature(cond.left, fn, &cptr, &clen, &cdims, &cmask) != 0) {
        has_cache_operand = 1;
    } else if (annotation_complexity_expr_index_signature(cond.right, fn, &cptr, &clen, &cdims, &cmask) != 0) {
        has_cache_operand = 1;
    }
    if (has_cache_operand == 0) { return 0; }

    if (annotation_complexity_stmt_has_return_index_base(ifs.then_block, fn, cptr, clen, cdims) != 0 ||
        annotation_complexity_stmt_has_return_index_base(ifs.else_block, fn, cptr, clen, cdims) != 0) {
        *out_base_ptr = cptr;
        *out_base_len = clen;
        *out_dims = cdims;
        *out_param_mask = cmask;
        return 1;
    }

    return 0;
}

func annotation_complexity_expr_is_index_base_dims(expr: *AstNode, fn: *AstFunc, base_ptr: u64, base_len: u64, dims: u64) -> u64 {
    if (expr == 0 || base_ptr == 0 || base_len == 0 || dims == 0) { return 0; }
    var p: u64 = 0;
    var l: u64 = 0;
    var d: u64 = 0;
    var m: u64 = 0;
    if (annotation_complexity_expr_index_signature(expr, fn, &p, &l, &d, &m) == 0) { return 0; }
    if (d != dims) { return 0; }
    if (str_eq(p, l, base_ptr, base_len) == 0) { return 0; }
    return 1;
}

func annotation_complexity_stmt_has_index_assign_base(stmt: *AstNode, fn: *AstFunc, base_ptr: u64, base_len: u64, dims: u64) -> u64 {
    if (stmt == 0 || base_ptr == 0 || base_len == 0 || dims == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    match (kind) {
        case AST_BLOCK:
            var blk: *AstBlock = (*AstBlock)stmt;
            if (blk.stmts_vec != 0) {
                var bn: u64 = blk.stmts_vec.len();
                for (var bi: u64 = 0; bi < bn; bi++) {
                    if (annotation_complexity_stmt_has_index_assign_base(blk.stmts_vec.get(bi), fn, base_ptr, base_len, dims) != 0) { return 1; }
                }
            }
            return 0;
        case AST_IF:
            var ifs: *AstIf = (*AstIf)stmt;
            if (annotation_complexity_stmt_has_index_assign_base(ifs.then_block, fn, base_ptr, base_len, dims) != 0) { return 1; }
            return annotation_complexity_stmt_has_index_assign_base(ifs.else_block, fn, base_ptr, base_len, dims);
        case AST_WHILE:
            return annotation_complexity_stmt_has_index_assign_base(((*AstWhile)stmt).body, fn, base_ptr, base_len, dims);
        case AST_FOR:
            var fr: *AstFor = (*AstFor)stmt;
            if (annotation_complexity_stmt_has_index_assign_base(fr.init, fn, base_ptr, base_len, dims) != 0) { return 1; }
            if (annotation_complexity_stmt_has_index_assign_base(fr.body, fn, base_ptr, base_len, dims) != 0) { return 1; }
            if (annotation_complexity_expr_is_index_base_dims(fr.update, fn, base_ptr, base_len, dims) != 0) { return 1; }
            return 0;
        case AST_DO_WHILE:
            return annotation_complexity_stmt_has_index_assign_base(((*AstDoWhile)stmt).body, fn, base_ptr, base_len, dims);
        case AST_SWITCH:
        case AST_MATCH:
            var sw: *AstSwitch = (*AstSwitch)stmt;
            if (sw.cases_vec != 0) {
                var cn: u64 = sw.cases_vec.len();
                for (var ci: u64 = 0; ci < cn; ci++) {
                    if (annotation_complexity_stmt_has_index_assign_base(sw.cases_vec.get(ci), fn, base_ptr, base_len, dims) != 0) { return 1; }
                }
            }
            return 0;
        case AST_CASE:
            return annotation_complexity_stmt_has_index_assign_base(((*AstCase)stmt).body, fn, base_ptr, base_len, dims);
        case AST_DEFER:
            return annotation_complexity_stmt_has_index_assign_base(((*AstDefer)stmt).stmt, fn, base_ptr, base_len, dims);
        case AST_ASSIGN:
            var asn: *AstAssign = (*AstAssign)stmt;
            if (annotation_complexity_expr_is_index_base_dims(asn.target, fn, base_ptr, base_len, dims) != 0) { return 1; }
            return 0;
        case AST_EXPR_STMT:
            var ex: *AstNode = ((*AstExprStmt)stmt).expr;
            if (ex != 0 && ast_kind(ex) == AST_BINARY) {
                var bx: *AstBinary = (*AstBinary)ex;
                if (bx.op == TOKEN_EQ && annotation_complexity_expr_is_index_base_dims(bx.left, fn, base_ptr, base_len, dims) != 0) { return 1; }
            }
            return 0;
    }
    return 0;
}

func annotation_complexity_find_memo_guard_stmt(stmt: *AstNode, fn: *AstFunc, out_base_ptr: *u64, out_base_len: *u64, out_dims: *u64, out_param_mask: *u64) -> u64 {
    if (stmt == 0 || out_base_ptr == 0 || out_base_len == 0 || out_dims == 0 || out_param_mask == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    match (kind) {
        case AST_BLOCK:
            var blk: *AstBlock = (*AstBlock)stmt;
            if (blk.stmts_vec != 0) {
                var bn: u64 = blk.stmts_vec.len();
                for (var bi: u64 = 0; bi < bn; bi++) {
                    if (annotation_complexity_find_memo_guard_stmt(blk.stmts_vec.get(bi), fn, out_base_ptr, out_base_len, out_dims, out_param_mask) != 0) { return 1; }
                }
            }
            return 0;
        case AST_IF:
            var ifs: *AstIf = (*AstIf)stmt;
            if (annotation_complexity_if_is_memo_hit_guard(ifs, fn, out_base_ptr, out_base_len, out_dims, out_param_mask) != 0) { return 1; }
            if (annotation_complexity_find_memo_guard_stmt(ifs.then_block, fn, out_base_ptr, out_base_len, out_dims, out_param_mask) != 0) { return 1; }
            return annotation_complexity_find_memo_guard_stmt(ifs.else_block, fn, out_base_ptr, out_base_len, out_dims, out_param_mask);
        case AST_WHILE:
            return annotation_complexity_find_memo_guard_stmt(((*AstWhile)stmt).body, fn, out_base_ptr, out_base_len, out_dims, out_param_mask);
        case AST_FOR:
            var fr: *AstFor = (*AstFor)stmt;
            if (annotation_complexity_find_memo_guard_stmt(fr.init, fn, out_base_ptr, out_base_len, out_dims, out_param_mask) != 0) { return 1; }
            return annotation_complexity_find_memo_guard_stmt(fr.body, fn, out_base_ptr, out_base_len, out_dims, out_param_mask);
        case AST_DO_WHILE:
            return annotation_complexity_find_memo_guard_stmt(((*AstDoWhile)stmt).body, fn, out_base_ptr, out_base_len, out_dims, out_param_mask);
        case AST_SWITCH:
        case AST_MATCH:
            var sw: *AstSwitch = (*AstSwitch)stmt;
            if (sw.cases_vec != 0) {
                var cn: u64 = sw.cases_vec.len();
                for (var ci: u64 = 0; ci < cn; ci++) {
                    if (annotation_complexity_find_memo_guard_stmt(sw.cases_vec.get(ci), fn, out_base_ptr, out_base_len, out_dims, out_param_mask) != 0) { return 1; }
                }
            }
            return 0;
        case AST_CASE:
            return annotation_complexity_find_memo_guard_stmt(((*AstCase)stmt).body, fn, out_base_ptr, out_base_len, out_dims, out_param_mask);
        case AST_DEFER:
            return annotation_complexity_find_memo_guard_stmt(((*AstDefer)stmt).stmt, fn, out_base_ptr, out_base_len, out_dims, out_param_mask);
    }
    return 0;
}

func annotation_complexity_state_rank_from_dims(mask: u64, dims: u64) -> u64 {
    var vars: u64 = annotation_complexity_popcount_u64(mask);
    if (vars == 0) { vars = dims; }
    if (vars <= 1) { return 3; }
    if (vars == 2) { return 5; }
    return 6;
}

func annotation_complexity_infer_topdown_memo_rank(fn: *AstFunc, constraints_ann: *CompilerAnnotationParsed, out_rank: *u64) -> u64 {
    if (fn == 0 || fn.body == 0 || out_rank == 0) { return 0; }
    *out_rank = 0;

    var max_depth: u64 = 0;
    var self_calls: u64 = 0;
    annotation_complexity_scan_stmt(fn.body, fn.name_ptr, fn.name_len, 0, &max_depth, &self_calls);
    if (self_calls == 0) { return 0; }

    var base_ptr: u64 = 0;
    var base_len: u64 = 0;
    var dims: u64 = 0;
    var param_mask: u64 = 0;
    if (annotation_complexity_find_memo_guard_stmt(fn.body, fn, &base_ptr, &base_len, &dims, &param_mask) == 0) { return 0; }
    if (annotation_complexity_stmt_has_index_assign_base(fn.body, fn, base_ptr, base_len, dims) == 0) { return 0; }

    var state_rank: u64 = annotation_complexity_state_rank_from_dims(param_mask, dims);
    var fallback_bound: u64 = annotation_complexity_constraints_max(constraints_ann);
    var transition_rank: u64 = annotation_complexity_stmt_infer_rank(fn.body, constraints_ann, fallback_bound);
    if (transition_rank == 0) { transition_rank = 1; }

    var total_rank: u64 = annotation_complexity_rank_mul(state_rank, transition_rank);
    if (total_rank == 0) { total_rank = state_rank; }
    if (annotation_complexity_rank_order(total_rank) < annotation_complexity_rank_order(state_rank)) {
        total_rank = state_rank;
    }
    *out_rank = total_rank;
    return 1;
}

func annotation_complexity_state_rank_from_var_count(vars: u64) -> u64 {
    if (vars <= 1) { return 3; }
    if (vars == 2) { return 5; }
    return 6;
}

func annotation_complexity_find_memo_hint_arg(fn: *AstFunc, key_ptr: u64, key_len: u64) -> *CompilerAnnotationArg {
    if (fn == 0) { return 0; }
    var ann_cplx: *CompilerAnnotationParsed = annotation_complexity_get_single(fn, "complexity", 10);
    if (ann_cplx != 0) {
        var arg_cplx: *CompilerAnnotationArg = annotation_complexity_find_named_arg(ann_cplx, key_ptr, key_len);
        if (arg_cplx != 0) { return arg_cplx; }
    }
    var ann_budget: *CompilerAnnotationParsed = annotation_complexity_get_single(fn, "complexity_budget", 17);
    if (ann_budget != 0) {
        var arg_budget: *CompilerAnnotationArg = annotation_complexity_find_named_arg(ann_budget, key_ptr, key_len);
        if (arg_budget != 0) { return arg_budget; }
    }
    return 0;
}

func annotation_complexity_infer_memo_hint_rank(fn: *AstFunc, constraints_ann: *CompilerAnnotationParsed, out_rank: *u64) -> u64 {
    if (fn == 0 || fn.body == 0 || out_rank == 0) { return 0; }
    *out_rank = 0;

    var state_arg: *CompilerAnnotationArg = annotation_complexity_find_memo_hint_arg(fn, "memo_state", 10);
    var transition_arg: *CompilerAnnotationArg = annotation_complexity_find_memo_hint_arg(fn, "memo_transition", 15);
    if (state_arg == 0) {
        // Backward compatibility: dedicated complexity_memo annotation.
        var ann: *CompilerAnnotationParsed = annotation_complexity_get_single(fn, "complexity_memo", 15);
        if (ann == 0) { return 0; }
        state_arg = annotation_complexity_find_named_arg(ann, "state", 5);
        transition_arg = annotation_complexity_find_named_arg(ann, "transition", 10);
    }
    var vars: u64 = annotation_complexity_memo_state_count_from_arg(state_arg);
    if (vars == 0) { return 0; }

    var state_rank: u64 = annotation_complexity_state_rank_from_var_count(vars);
    var transition_rank: u64 = 1;
    if (transition_arg != 0 && transition_arg.kind == 3) {
        var tr: u64 = annotation_complexity_rank_from_expr(transition_arg.string_ptr, transition_arg.string_len);
        if (tr != 0) { transition_rank = tr; }
    } else {
        var fb: u64 = annotation_complexity_constraints_max(constraints_ann);
        var structural_rank: u64 = annotation_complexity_stmt_infer_rank(fn.body, constraints_ann, fb);
        if (structural_rank != 0) { transition_rank = structural_rank; }
    }

    var total_rank: u64 = annotation_complexity_rank_mul(state_rank, transition_rank);
    if (total_rank == 0) { total_rank = state_rank; }
    if (annotation_complexity_rank_order(total_rank) < annotation_complexity_rank_order(state_rank)) {
        total_rank = state_rank;
    }
    *out_rank = total_rank;
    return 1;
}

func annotation_complexity_infer_memo_hint_state_rank(fn: *AstFunc, out_rank: *u64) -> u64 {
    if (fn == 0 || out_rank == 0) { return 0; }
    *out_rank = 0;
    var state_arg: *CompilerAnnotationArg = annotation_complexity_find_memo_hint_arg(fn, "memo_state", 10);
    if (state_arg == 0) {
        var ann: *CompilerAnnotationParsed = annotation_complexity_get_single(fn, "complexity_memo", 15);
        if (ann == 0) { return 0; }
        state_arg = annotation_complexity_find_named_arg(ann, "state", 5);
    }
    var vars: u64 = annotation_complexity_memo_state_count_from_arg(state_arg);
    if (vars == 0) { return 0; }
    *out_rank = annotation_complexity_state_rank_from_var_count(vars);
    return 1;
}

func annotation_complexity_infer_topdown_memo_state_rank(fn: *AstFunc, out_rank: *u64) -> u64 {
    if (fn == 0 || fn.body == 0 || out_rank == 0) { return 0; }
    *out_rank = 0;

    var max_depth: u64 = 0;
    var self_calls: u64 = 0;
    annotation_complexity_scan_stmt(fn.body, fn.name_ptr, fn.name_len, 0, &max_depth, &self_calls);
    if (self_calls == 0) { return 0; }

    var base_ptr: u64 = 0;
    var base_len: u64 = 0;
    var dims: u64 = 0;
    var param_mask: u64 = 0;
    if (annotation_complexity_find_memo_guard_stmt(fn.body, fn, &base_ptr, &base_len, &dims, &param_mask) == 0) { return 0; }
    if (annotation_complexity_stmt_has_index_assign_base(fn.body, fn, base_ptr, base_len, dims) == 0) { return 0; }
    *out_rank = annotation_complexity_state_rank_from_dims(param_mask, dims);
    return 1;
}

func annotation_complexity_expr_infer_alloc_space_rank(expr: *AstNode) -> u64 {
    if (expr == 0) { return 1; }
    var kind: u64 = ast_kind(expr);
    var nref: AstNodeTagRef;
    nref.node = expr;
    match (kind) {
        case AST_NEW:
            var nw: *AstNew = nref.new_expr;
            if (nw.array_len_is_param != 0 && nw.array_len_param_ptr != 0 && nw.array_len_param_len != 0) { return 3; }
            return 1;
        case AST_CALL:
            var call_rank: u64 = 1;
            if (annotation_complexity_name_contains_token(nref.call.name_ptr, nref.call.name_len, "alloc", 5) != 0 ||
                annotation_complexity_name_contains_token(nref.call.name_ptr, nref.call.name_len, "reserve", 7) != 0 ||
                annotation_complexity_name_contains_token(nref.call.name_ptr, nref.call.name_len, "resize", 6) != 0 ||
                annotation_complexity_name_contains_token(nref.call.name_ptr, nref.call.name_len, "capacity", 8) != 0 ||
                annotation_complexity_name_contains_token(nref.call.name_ptr, nref.call.name_len, "grow", 4) != 0) {
                call_rank = 3;
            }
            if (nref.call.args_vec != 0) {
                var an: u64 = nref.call.args_vec.len();
                for (var i: u64 = 0; i < an; i++) {
                    var ar: u64 = annotation_complexity_expr_infer_alloc_space_rank(nref.call.args_vec.get(i));
                    call_rank = annotation_complexity_rank_pick_heavier(call_rank, ar);
                }
            }
            return call_rank;
        case AST_GENERIC_CALL:
            var gen_rank: u64 = 1;
            if (annotation_complexity_name_contains_token(nref.generic_call.name_ptr, nref.generic_call.name_len, "alloc", 5) != 0 ||
                annotation_complexity_name_contains_token(nref.generic_call.name_ptr, nref.generic_call.name_len, "reserve", 7) != 0 ||
                annotation_complexity_name_contains_token(nref.generic_call.name_ptr, nref.generic_call.name_len, "resize", 6) != 0 ||
                annotation_complexity_name_contains_token(nref.generic_call.name_ptr, nref.generic_call.name_len, "capacity", 8) != 0 ||
                annotation_complexity_name_contains_token(nref.generic_call.name_ptr, nref.generic_call.name_len, "grow", 4) != 0) {
                gen_rank = 3;
            }
            if (nref.generic_call.args_vec != 0) {
                var gn: u64 = nref.generic_call.args_vec.len();
                for (var gi: u64 = 0; gi < gn; gi++) {
                    var gar: u64 = annotation_complexity_expr_infer_alloc_space_rank(nref.generic_call.args_vec.get(gi));
                    gen_rank = annotation_complexity_rank_pick_heavier(gen_rank, gar);
                }
            }
            return gen_rank;
        case AST_METHOD_CALL:
        case AST_SAFE_METHOD_CALL:
            var mr: u64 = annotation_complexity_expr_infer_alloc_space_rank(nref.method_call.receiver);
            if (annotation_complexity_name_contains_token(nref.method_call.method_ptr, nref.method_call.method_len, "alloc", 5) != 0 ||
                annotation_complexity_name_contains_token(nref.method_call.method_ptr, nref.method_call.method_len, "reserve", 7) != 0 ||
                annotation_complexity_name_contains_token(nref.method_call.method_ptr, nref.method_call.method_len, "resize", 6) != 0 ||
                annotation_complexity_name_contains_token(nref.method_call.method_ptr, nref.method_call.method_len, "capacity", 8) != 0 ||
                annotation_complexity_name_contains_token(nref.method_call.method_ptr, nref.method_call.method_len, "grow", 4) != 0) {
                mr = annotation_complexity_rank_pick_heavier(mr, 3);
            }
            if (nref.method_call.args_vec != 0) {
                var mn: u64 = nref.method_call.args_vec.len();
                for (var mi: u64 = 0; mi < mn; mi++) {
                    var mar: u64 = annotation_complexity_expr_infer_alloc_space_rank(nref.method_call.args_vec.get(mi));
                    mr = annotation_complexity_rank_pick_heavier(mr, mar);
                }
            }
            return mr;
        case AST_CALL_PTR:
            var pr: u64 = annotation_complexity_expr_infer_alloc_space_rank(nref.call_ptr.callee);
            if (nref.call_ptr.args_vec != 0) {
                var pn: u64 = nref.call_ptr.args_vec.len();
                for (var pi: u64 = 0; pi < pn; pi++) {
                    var par: u64 = annotation_complexity_expr_infer_alloc_space_rank(nref.call_ptr.args_vec.get(pi));
                    pr = annotation_complexity_rank_pick_heavier(pr, par);
                }
            }
            return pr;
        case AST_BINARY:
            var l: u64 = annotation_complexity_expr_infer_alloc_space_rank(nref.binary.left);
            var r: u64 = annotation_complexity_expr_infer_alloc_space_rank(nref.binary.right);
            return annotation_complexity_rank_pick_heavier(l, r);
        case AST_UNARY:
            return annotation_complexity_expr_infer_alloc_space_rank(nref.unary.operand);
        case AST_TERNARY:
            var c: u64 = annotation_complexity_expr_infer_alloc_space_rank(nref.ternary_expr.cond);
            var t: u64 = annotation_complexity_expr_infer_alloc_space_rank(nref.ternary_expr.then_expr);
            var e: u64 = annotation_complexity_expr_infer_alloc_space_rank(nref.ternary_expr.else_expr);
            return annotation_complexity_rank_pick_heavier(c, annotation_complexity_rank_pick_heavier(t, e));
        case AST_CAST:
            return annotation_complexity_expr_infer_alloc_space_rank(nref.cast_expr.expr);
        case AST_ADDR_OF:
            return annotation_complexity_expr_infer_alloc_space_rank(nref.addr_of.operand);
        case AST_DEREF:
            return annotation_complexity_expr_infer_alloc_space_rank(nref.deref.operand);
        case AST_DEREF8:
            return annotation_complexity_expr_infer_alloc_space_rank(nref.deref8.operand);
        case AST_INDEX:
        case AST_SAFE_INDEX:
            var br: u64 = annotation_complexity_expr_infer_alloc_space_rank(nref.index_expr.base);
            var ir: u64 = annotation_complexity_expr_infer_alloc_space_rank(nref.index_expr.index);
            return annotation_complexity_rank_pick_heavier(br, ir);
        case AST_MEMBER_ACCESS:
        case AST_SAFE_MEMBER_ACCESS:
            return annotation_complexity_expr_infer_alloc_space_rank(nref.member_access.object);
    }
    return 1;
}

func annotation_complexity_stmt_infer_local_space_rank(stmt: *AstNode) -> u64 {
    if (stmt == 0) { return 1; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 1; }
    var kind: u64 = ast_kind(stmt);
    match (kind) {
        case AST_VAR_DECL:
            var vd: *AstVarDecl = (*AstVarDecl)stmt;
            var decl_rank: u64 = 1;
            if (vd.array_len_is_param != 0 && vd.array_len_param_ptr != 0 && vd.array_len_param_len != 0) {
                decl_rank = annotation_complexity_rank_pick_heavier(decl_rank, 3);
            }
            decl_rank = annotation_complexity_rank_pick_heavier(decl_rank, annotation_complexity_expr_infer_alloc_space_rank(vd.init_expr));
            return decl_rank;
        case AST_ASSIGN:
            return annotation_complexity_expr_infer_alloc_space_rank(((*AstAssign)stmt).value);
        case AST_EXPR_STMT:
            return annotation_complexity_expr_infer_alloc_space_rank(((*AstExprStmt)stmt).expr);
        case AST_RETURN:
            return annotation_complexity_expr_infer_alloc_space_rank(((*AstReturn)stmt).expr);
        case AST_BLOCK:
            var blk: *AstBlock = (*AstBlock)stmt;
            var best_blk: u64 = 1;
            if (blk.stmts_vec != 0) {
                var bn: u64 = blk.stmts_vec.len();
                for (var bi: u64 = 0; bi < bn; bi++) {
                    var br: u64 = annotation_complexity_stmt_infer_local_space_rank(blk.stmts_vec.get(bi));
                    best_blk = annotation_complexity_rank_pick_heavier(best_blk, br);
                }
            }
            return best_blk;
        case AST_IF:
            var ifs: *AstIf = (*AstIf)stmt;
            var tr: u64 = annotation_complexity_stmt_infer_local_space_rank(ifs.then_block);
            var er: u64 = annotation_complexity_stmt_infer_local_space_rank(ifs.else_block);
            return annotation_complexity_rank_pick_heavier(tr, er);
        case AST_WHILE:
            return annotation_complexity_stmt_infer_local_space_rank(((*AstWhile)stmt).body);
        case AST_FOR:
            var fr: *AstFor = (*AstFor)stmt;
            var ir: u64 = annotation_complexity_stmt_infer_local_space_rank(fr.init);
            var br2: u64 = annotation_complexity_stmt_infer_local_space_rank(fr.body);
            return annotation_complexity_rank_pick_heavier(ir, br2);
        case AST_DO_WHILE:
            return annotation_complexity_stmt_infer_local_space_rank(((*AstDoWhile)stmt).body);
        case AST_SWITCH:
        case AST_MATCH:
            var sw: *AstSwitch = (*AstSwitch)stmt;
            var best_sw: u64 = 1;
            if (sw.cases_vec != 0) {
                var sn: u64 = sw.cases_vec.len();
                for (var si: u64 = 0; si < sn; si++) {
                    var sr: u64 = annotation_complexity_stmt_infer_local_space_rank(sw.cases_vec.get(si));
                    best_sw = annotation_complexity_rank_pick_heavier(best_sw, sr);
                }
            }
            return best_sw;
        case AST_CASE:
            return annotation_complexity_stmt_infer_local_space_rank(((*AstCase)stmt).body);
        case AST_DEFER:
            return annotation_complexity_stmt_infer_local_space_rank(((*AstDefer)stmt).stmt);
    }
    return 1;
}

func annotation_complexity_infer_stack_space_rank(fn: *AstFunc) -> u64 {
    if (fn == 0 || fn.body == 0) { return 1; }
    var recur_total: u64 = 0;
    var recur_half: u64 = 0;
    var recur_minus: u64 = 0;
    var recur_same: u64 = 0;
    annotation_complexity_scan_stmt_self_call_patterns(fn.body, fn.name_ptr, fn.name_len, &recur_total, &recur_half, &recur_minus, &recur_same);

    var max_depth: u64 = 0;
    var self_calls: u64 = 0;
    annotation_complexity_scan_stmt(fn.body, fn.name_ptr, fn.name_len, 0, &max_depth, &self_calls);
    if (self_calls == 0) { return 1; }

    if (recur_total >= 1 && recur_half >= 1 && recur_minus == 0 && recur_same == 0) { return 2; }
    return 3;
}

func annotation_complexity_infer_space_rank_with_meta(fn: *AstFunc, constraints_ann: *CompilerAnnotationParsed, out_conf: *u64) -> u64 {
    if (out_conf != 0) { *out_conf = ANN_COMPLEXITY_CONF_UNKNOWN; }
    if (fn == 0 || fn.body == 0) {
        if (out_conf != 0) { *out_conf = ANN_COMPLEXITY_CONF_HEURISTIC; }
        return 1;
    }

    var best: u64 = 1;
    var memo_hint_state: u64 = 0;
    if (annotation_complexity_infer_memo_hint_state_rank(fn, &memo_hint_state) != 0 && memo_hint_state != 0) {
        best = annotation_complexity_rank_pick_heavier(best, memo_hint_state);
    }
    var memo_auto_state: u64 = 0;
    if (annotation_complexity_infer_topdown_memo_state_rank(fn, &memo_auto_state) != 0 && memo_auto_state != 0) {
        best = annotation_complexity_rank_pick_heavier(best, memo_auto_state);
    }

    var local_rank: u64 = annotation_complexity_stmt_infer_local_space_rank(fn.body);
    best = annotation_complexity_rank_pick_heavier(best, local_rank);

    var stack_rank: u64 = annotation_complexity_infer_stack_space_rank(fn);
    best = annotation_complexity_rank_pick_heavier(best, stack_rank);

    if (constraints_ann != 0) {
        // Keep parameter to support future precision improvements without changing API shape.
        best = annotation_complexity_rank_pick_heavier(best, 1);
    }
    if (out_conf != 0) { *out_conf = ANN_COMPLEXITY_CONF_HEURISTIC; }
    return best;
}

func annotation_complexity_stmt_has_ident_plus_assign(stmt: *AstNode, dst_ptr: u64, dst_len: u64, step_ptr: u64, step_len: u64) -> u64 {
    if (stmt == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    if (kind == AST_BLOCK) {
        var blk: *AstBlock = (*AstBlock)stmt;
        if (blk.stmts_vec != 0) {
            var bn: u64 = blk.stmts_vec.len();
            for (var bi: u64 = 0; bi < bn; bi++) {
                if (annotation_complexity_stmt_has_ident_plus_assign(blk.stmts_vec.get(bi), dst_ptr, dst_len, step_ptr, step_len) != 0) {
                    return 1;
                }
            }
        }
        return 0;
    }
    if (kind == AST_IF) {
        var ifs: *AstIf = (*AstIf)stmt;
        if (annotation_complexity_stmt_has_ident_plus_assign(ifs.then_block, dst_ptr, dst_len, step_ptr, step_len) != 0) { return 1; }
        return annotation_complexity_stmt_has_ident_plus_assign(ifs.else_block, dst_ptr, dst_len, step_ptr, step_len);
    }
    if (kind == AST_WHILE) { return annotation_complexity_stmt_has_ident_plus_assign(((*AstWhile)stmt).body, dst_ptr, dst_len, step_ptr, step_len); }
    if (kind == AST_FOR) { return annotation_complexity_stmt_has_ident_plus_assign(((*AstFor)stmt).body, dst_ptr, dst_len, step_ptr, step_len); }
    if (kind == AST_DO_WHILE) { return annotation_complexity_stmt_has_ident_plus_assign(((*AstDoWhile)stmt).body, dst_ptr, dst_len, step_ptr, step_len); }
    if (kind == AST_CASE) { return annotation_complexity_stmt_has_ident_plus_assign(((*AstCase)stmt).body, dst_ptr, dst_len, step_ptr, step_len); }
    if (kind == AST_DEFER) { return annotation_complexity_stmt_has_ident_plus_assign(((*AstDefer)stmt).stmt, dst_ptr, dst_len, step_ptr, step_len); }
    if (kind == AST_SWITCH || kind == AST_MATCH) {
        var sw: *AstSwitch = (*AstSwitch)stmt;
        if (sw.cases_vec != 0) {
            var cn: u64 = sw.cases_vec.len();
            for (var ci: u64 = 0; ci < cn; ci++) {
                if (annotation_complexity_stmt_has_ident_plus_assign(sw.cases_vec.get(ci), dst_ptr, dst_len, step_ptr, step_len) != 0) { return 1; }
            }
        }
        return 0;
    }
    if (kind != AST_ASSIGN) { return 0; }
    var asn: *AstAssign = (*AstAssign)stmt;
    if (annotation_complexity_expr_is_ident(asn.target, dst_ptr, dst_len) == 0) { return 0; }
    if (asn.value == 0 || ast_kind(asn.value) != AST_BINARY) { return 0; }
    var b: *AstBinary = (*AstBinary)asn.value;
    if (b.op != TOKEN_PLUS) { return 0; }
    if (annotation_complexity_expr_is_ident(b.left, dst_ptr, dst_len) != 0 &&
        annotation_complexity_expr_contains_ident(b.right, step_ptr, step_len) != 0) { return 1; }
    if (annotation_complexity_expr_is_ident(b.right, dst_ptr, dst_len) != 0 &&
        annotation_complexity_expr_contains_ident(b.left, step_ptr, step_len) != 0) { return 1; }
    return 0;
}

func annotation_complexity_stmt_has_self_increment(stmt: *AstNode, dst_ptr: u64, dst_len: u64) -> u64 {
    if (stmt == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    if (kind == AST_BLOCK) {
        var blk: *AstBlock = (*AstBlock)stmt;
        if (blk.stmts_vec != 0) {
            var bn: u64 = blk.stmts_vec.len();
            for (var bi: u64 = 0; bi < bn; bi++) {
                if (annotation_complexity_stmt_has_self_increment(blk.stmts_vec.get(bi), dst_ptr, dst_len) != 0) { return 1; }
            }
        }
        return 0;
    }
    if (kind == AST_IF) {
        var ifs: *AstIf = (*AstIf)stmt;
        if (annotation_complexity_stmt_has_self_increment(ifs.then_block, dst_ptr, dst_len) != 0) { return 1; }
        return annotation_complexity_stmt_has_self_increment(ifs.else_block, dst_ptr, dst_len);
    }
    if (kind == AST_WHILE) { return annotation_complexity_stmt_has_self_increment(((*AstWhile)stmt).body, dst_ptr, dst_len); }
    if (kind == AST_FOR) { return annotation_complexity_stmt_has_self_increment(((*AstFor)stmt).body, dst_ptr, dst_len); }
    if (kind == AST_DO_WHILE) { return annotation_complexity_stmt_has_self_increment(((*AstDoWhile)stmt).body, dst_ptr, dst_len); }
    if (kind == AST_CASE) { return annotation_complexity_stmt_has_self_increment(((*AstCase)stmt).body, dst_ptr, dst_len); }
    if (kind == AST_DEFER) { return annotation_complexity_stmt_has_self_increment(((*AstDefer)stmt).stmt, dst_ptr, dst_len); }
    if (kind == AST_SWITCH || kind == AST_MATCH) {
        var sw: *AstSwitch = (*AstSwitch)stmt;
        if (sw.cases_vec != 0) {
            var cn: u64 = sw.cases_vec.len();
            for (var ci: u64 = 0; ci < cn; ci++) {
                if (annotation_complexity_stmt_has_self_increment(sw.cases_vec.get(ci), dst_ptr, dst_len) != 0) { return 1; }
            }
        }
        return 0;
    }
    if (kind != AST_ASSIGN) { return 0; }
    var asn: *AstAssign = (*AstAssign)stmt;
    if (annotation_complexity_expr_is_ident(asn.target, dst_ptr, dst_len) == 0) { return 0; }
    if (asn.value == 0 || ast_kind(asn.value) != AST_BINARY) { return 0; }
    var b: *AstBinary = (*AstBinary)asn.value;
    if (b.op != TOKEN_PLUS) { return 0; }
    if (annotation_complexity_expr_is_ident(b.left, dst_ptr, dst_len) != 0 &&
        annotation_complexity_expr_contains_ident(b.right, dst_ptr, dst_len) == 0) { return 1; }
    if (annotation_complexity_expr_is_ident(b.right, dst_ptr, dst_len) != 0 &&
        annotation_complexity_expr_contains_ident(b.left, dst_ptr, dst_len) == 0) { return 1; }
    return 0;
}

func annotation_complexity_stmt_has_sieve_inner_pair(stmt: *AstNode, i_ptr: u64, i_len: u64) -> u64 {
    if (stmt == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    if (kind == AST_BLOCK) {
        var blk: *AstBlock = (*AstBlock)stmt;
        if (blk.stmts_vec == 0) { return 0; }
        var n: u64 = blk.stmts_vec.len();
        for (var si: u64 = 0; si < n; si++) {
            var st: *AstNode = blk.stmts_vec.get(si);
            if (si > 0 && st != 0 && ast_kind(st) == AST_WHILE) {
                var init_stmt: *AstNode = blk.stmts_vec.get(si - 1);
                if (init_stmt != 0 && ast_kind(init_stmt) == AST_VAR_DECL) {
                    var j_decl: *AstVarDecl = (*AstVarDecl)init_stmt;
                    if (j_decl.init_expr != 0) {
                        var init_sq_ptr: u64 = 0;
                        var init_sq_len: u64 = 0;
                        if (annotation_complexity_expr_square_ident(j_decl.init_expr, &init_sq_ptr, &init_sq_len) != 0 &&
                            str_eq(init_sq_ptr, init_sq_len, i_ptr, i_len) != 0) {
                            var inner_w: *AstWhile = (*AstWhile)st;
                            if (inner_w.cond != 0 && ast_kind(inner_w.cond) == AST_BINARY) {
                                var ic: *AstBinary = (*AstBinary)inner_w.cond;
                                if (ic.op == TOKEN_LT || ic.op == TOKEN_LTEQ || ic.op == TOKEN_GT || ic.op == TOKEN_GTEQ) {
                                    var j_on_left: u64 = annotation_complexity_expr_is_ident(ic.left, j_decl.name_ptr, j_decl.name_len);
                                    var j_on_right: u64 = annotation_complexity_expr_is_ident(ic.right, j_decl.name_ptr, j_decl.name_len);
                                    if (j_on_left != 0 || j_on_right != 0) {
                                        var bound_ok: u64 = 1;
                                        if (j_on_left != 0 && annotation_complexity_expr_contains_ident(ic.right, i_ptr, i_len) != 0) { bound_ok = 0; }
                                        if (j_on_right != 0 && annotation_complexity_expr_contains_ident(ic.left, i_ptr, i_len) != 0) { bound_ok = 0; }
                                        if (bound_ok != 0 &&
                                            annotation_complexity_stmt_has_ident_plus_assign(inner_w.body, j_decl.name_ptr, j_decl.name_len, i_ptr, i_len) != 0) {
                                            return 1;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
            if (annotation_complexity_stmt_has_sieve_inner_pair(st, i_ptr, i_len) != 0) { return 1; }
        }
        return 0;
    }
    if (kind == AST_IF) {
        var ifs: *AstIf = (*AstIf)stmt;
        if (annotation_complexity_stmt_has_sieve_inner_pair(ifs.then_block, i_ptr, i_len) != 0) { return 1; }
        return annotation_complexity_stmt_has_sieve_inner_pair(ifs.else_block, i_ptr, i_len);
    }
    if (kind == AST_WHILE) { return annotation_complexity_stmt_has_sieve_inner_pair(((*AstWhile)stmt).body, i_ptr, i_len); }
    if (kind == AST_FOR) { return annotation_complexity_stmt_has_sieve_inner_pair(((*AstFor)stmt).body, i_ptr, i_len); }
    if (kind == AST_DO_WHILE) { return annotation_complexity_stmt_has_sieve_inner_pair(((*AstDoWhile)stmt).body, i_ptr, i_len); }
    if (kind == AST_CASE) { return annotation_complexity_stmt_has_sieve_inner_pair(((*AstCase)stmt).body, i_ptr, i_len); }
    if (kind == AST_DEFER) { return annotation_complexity_stmt_has_sieve_inner_pair(((*AstDefer)stmt).stmt, i_ptr, i_len); }
    if (kind == AST_SWITCH || kind == AST_MATCH) {
        var sw: *AstSwitch = (*AstSwitch)stmt;
        if (sw.cases_vec != 0) {
            var cn: u64 = sw.cases_vec.len();
            for (var ci: u64 = 0; ci < cn; ci++) {
                if (annotation_complexity_stmt_has_sieve_inner_pair(sw.cases_vec.get(ci), i_ptr, i_len) != 0) { return 1; }
            }
        }
        return 0;
    }
    return 0;
}

func annotation_complexity_is_sieve_like_outer_while(wl: *AstWhile) -> u64 {
    if (wl == 0 || wl.cond == 0 || wl.body == 0) { return 0; }
    if (ast_kind(wl.cond) != AST_BINARY) { return 0; }
    var c: *AstBinary = (*AstBinary)wl.cond;
    if (c.op != TOKEN_LT && c.op != TOKEN_LTEQ && c.op != TOKEN_GT && c.op != TOKEN_GTEQ) { return 0; }

    var i_ptr: u64 = 0;
    var i_len: u64 = 0;
    if (annotation_complexity_expr_square_ident(c.left, &i_ptr, &i_len) != 0) {
    } else if (annotation_complexity_expr_square_ident(c.right, &i_ptr, &i_len) != 0) {
    } else {
        return 0;
    }

    if (ast_kind(wl.body) != AST_BLOCK) { return 0; }
    var inner_found: u64 = annotation_complexity_stmt_has_sieve_inner_pair(wl.body, i_ptr, i_len);
    var outer_update_found: u64 = annotation_complexity_stmt_has_self_increment(wl.body, i_ptr, i_len);
    if (inner_found != 0 && outer_update_found != 0) { return 1; }
    return 0;
}

func annotation_complexity_has_sieve_like_pattern_stmt(stmt: *AstNode) -> u64 {
    if (stmt == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    var nref: AstNodeTagRef;
    nref.node = stmt;
    match (kind) {
        case AST_BLOCK:
            if (nref.block_stmt.stmts_vec != 0) {
                var bn: u64 = nref.block_stmt.stmts_vec.len();
                for (var bi: u64 = 0; bi < bn; bi++) {
                    if (annotation_complexity_has_sieve_like_pattern_stmt(nref.block_stmt.stmts_vec.get(bi)) != 0) { return 1; }
                }
            }
            return 0;
        case AST_WHILE:
            if (annotation_complexity_is_sieve_like_outer_while(nref.while_stmt) != 0) { return 1; }
            return annotation_complexity_has_sieve_like_pattern_stmt(nref.while_stmt.body);
        case AST_FOR:
            if (annotation_complexity_has_sieve_like_pattern_stmt(nref.for_stmt.init) != 0) { return 1; }
            return annotation_complexity_has_sieve_like_pattern_stmt(nref.for_stmt.body);
        case AST_DO_WHILE:
            return annotation_complexity_has_sieve_like_pattern_stmt(nref.do_while_stmt.body);
        case AST_IF:
            if (annotation_complexity_has_sieve_like_pattern_stmt(nref.if_stmt.then_block) != 0) { return 1; }
            return annotation_complexity_has_sieve_like_pattern_stmt(nref.if_stmt.else_block);
        case AST_SWITCH:
        case AST_MATCH:
            if (nref.switch_stmt.cases_vec != 0) {
                var cn: u64 = nref.switch_stmt.cases_vec.len();
                for (var ci: u64 = 0; ci < cn; ci++) {
                    if (annotation_complexity_has_sieve_like_pattern_stmt(nref.switch_stmt.cases_vec.get(ci)) != 0) { return 1; }
                }
            }
            return 0;
        case AST_CASE:
            return annotation_complexity_has_sieve_like_pattern_stmt(nref.case_stmt.body);
        case AST_DEFER:
            return annotation_complexity_has_sieve_like_pattern_stmt(nref.defer_stmt.stmt);
    }
    return 0;
}

func annotation_complexity_name_contains(name_ptr: u64, name_len: u64, needle_ptr: u64, needle_len: u64) -> u64 {
    if (name_ptr == 0 || name_len == 0 || needle_ptr == 0 || needle_len == 0 || needle_len > name_len) { return 0; }
    var i: u64 = 0;
    while (i + needle_len <= name_len) {
        if (str_eq(name_ptr + i, needle_len, needle_ptr, needle_len) != 0) { return 1; }
        i = i + 1;
    }
    return 0;
}

func annotation_complexity_name_token_char(ch: u64) -> u64 {
    if ((ch >= 65 && ch <= 90) || (ch >= 97 && ch <= 122)) { return 1; }
    return 0;
}

func annotation_complexity_name_contains_token(name_ptr: u64, name_len: u64, token_ptr: u64, token_len: u64) -> u64 {
    if (name_ptr == 0 || name_len == 0 || token_ptr == 0 || token_len == 0 || token_len > name_len) { return 0; }
    var s: []u8 = slice(name_ptr, name_len);
    var i: u64 = 0;

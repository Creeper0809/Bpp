            if (annotation_complexity_expr_has_binary_op(fr.cond, op) != 0) { return 1; }
            if (annotation_complexity_expr_has_binary_op(fr.update, op) != 0) { return 1; }
            return annotation_complexity_stmt_has_binary_op(fr.body, op);
        case AST_DO_WHILE:
            var dw: *AstDoWhile = (*AstDoWhile)stmt;
            if (annotation_complexity_stmt_has_binary_op(dw.body, op) != 0) { return 1; }
            return annotation_complexity_expr_has_binary_op(dw.cond, op);
        case AST_SWITCH:
        case AST_MATCH:
            var sw: *AstSwitch = (*AstSwitch)stmt;
            if (annotation_complexity_expr_has_binary_op(sw.expr, op) != 0) { return 1; }
            if (sw.cases_vec != 0) {
                var cn: u64 = sw.cases_vec.len();
                for (var ci: u64 = 0; ci < cn; ci++) {
                    if (annotation_complexity_stmt_has_binary_op(sw.cases_vec.get(ci), op) != 0) { return 1; }
                }
            }
            return 0;
        case AST_CASE:
            var cs: *AstCase = (*AstCase)stmt;
            if (annotation_complexity_expr_has_binary_op(cs.value, op) != 0) { return 1; }
            return annotation_complexity_stmt_has_binary_op(cs.body, op);
        case AST_DEFER:
            return annotation_complexity_stmt_has_binary_op(((*AstDefer)stmt).stmt, op);
        case AST_VAR_DECL:
            return annotation_complexity_expr_has_binary_op(((*AstVarDecl)stmt).init_expr, op);
        case AST_ASSIGN:
            var asn: *AstAssign = (*AstAssign)stmt;

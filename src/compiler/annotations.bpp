            else if (annotation_complexity_name_token_char(s[i - 1]) == 0) { left_ok = 1; }
            var end_idx: u64 = i + token_len;
            if (end_idx >= name_len) { right_ok = 1; }
            else if (annotation_complexity_name_token_char(s[end_idx]) == 0) { right_ok = 1; }
            if (left_ok != 0 && right_ok != 0) { return 1; }
        }

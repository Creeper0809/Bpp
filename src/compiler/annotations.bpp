// compiler_annotations.b - Annotation parsing/validation helpers

import compiler;
import compiler.core_utils;
import compiler.generic.engine;
import compiler.symbol_runtime;
import compiler.generic.core;
import compiler.call_utils;
import compiler.ast_lowering;
import std.io;
import std.str;
import std.vec;
import ast;
import types;
import module_utils;
import ssa;
import ssa.core;
import ssa.datastruct;
import run as to_ssa from ssa.mem2reg;

var g_symbolic_report_enabled: u64 = 0;
var g_complexity_require_std_summaries: u64 = 0;

struct AnnComplexitySSASummary {
    public fn_ptr: u64;
    public fn_len: u64;
    public local_rank: u64;
    public total_rank: u64;
    public conf: u64;
    public unresolved_calls: u64;
    public call_count: u64;
    public self_calls: u64;
    public call_ptr_count: u64;
    public phi_count: u64;
    public backedge_count: u64;
    public loop_depth: u64;
}

impl AnnComplexitySSASummary {
    public constructor() {
        self.fn_ptr = 0;
        self.fn_len = 0;
        self.local_rank = 0;
        self.total_rank = 0;
        self.conf = 0;
        self.unresolved_calls = 0;
        self.call_count = 0;
        self.self_calls = 0;
        self.call_ptr_count = 0;
        self.phi_count = 0;
        self.backedge_count = 0;
        self.loop_depth = 0;
    }
}

var g_complexity_ssa_summary_map: *HashMap<u64, *AnnComplexitySSASummary> = 0;

func annotation_set_symbolic_report_enabled(enabled: u64) -> u64 {
    if (enabled != 0) { g_symbolic_report_enabled = 1; }
    else { g_symbolic_report_enabled = 0; }
    return 0;
}

func annotation_symbolic_report_enabled() -> u64 {
    return g_symbolic_report_enabled;
}

func annotation_set_complexity_require_std_summaries(enabled: u64) -> u64 {
    if (enabled != 0) { g_complexity_require_std_summaries = 1; }
    else { g_complexity_require_std_summaries = 0; }
    return 0;
}

func annotation_complexity_require_std_summaries() -> u64 {
    return g_complexity_require_std_summaries;
}

func annotation_complexity_alias_name(name_ptr: u64, name_len: u64, out_ptr: *u64, out_len: *u64) -> u64 {
    if (out_ptr == 0 || out_len == 0) { return 0; }
    *out_ptr = 0;
    *out_len = 0;
    if (name_ptr == 0 || name_len == 0) { return 0; }

    if (str_eq(name_ptr, name_len, "symbolic_expect", 15) != 0) {
        *out_ptr = (u64)"complexity";
        *out_len = 10;
        return 1;
    }
    if (str_eq(name_ptr, name_len, "symbolic_assume", 15) != 0) {
        *out_ptr = (u64)"constraints";
        *out_len = 11;
        return 1;
    }
    if (str_eq(name_ptr, name_len, "symbolic_input", 14) != 0) {
        *out_ptr = (u64)"complexity_input";
        *out_len = 16;
        return 1;
    }
    if (str_eq(name_ptr, name_len, "symbolic_budget", 15) != 0) {
        *out_ptr = (u64)"complexity_budget";
        *out_len = 17;
        return 1;
    }
    if (str_eq(name_ptr, name_len, "symbolic_memo", 13) != 0) {
        *out_ptr = (u64)"complexity_memo";
        *out_len = 15;
        return 1;
    }
    if (str_eq(name_ptr, name_len, "symbolic_ignore", 15) != 0) {
        *out_ptr = (u64)"complexity_ignore";
        *out_len = 17;
        return 1;
    }
    if (str_eq(name_ptr, name_len, "symbolic_debug", 14) != 0) {
        *out_ptr = (u64)"complexity_debug";
        *out_len = 16;
        return 1;
    }
    return 0;
}

func annotation_complexity_canonicalize_parsed_name(parsed: *CompilerAnnotationParsed) -> u64 {
    if (parsed == 0 || parsed.name_ptr == 0 || parsed.name_len == 0) { return 0; }
    var alias_ptr: u64 = 0;
    var alias_len: u64 = 0;
    if (annotation_complexity_alias_name(parsed.name_ptr, parsed.name_len, &alias_ptr, &alias_len) != 0) {
        parsed.name_ptr = alias_ptr;
        parsed.name_len = alias_len;
        return 1;
    }
    return 0;
}

func annotation_is_space(ch: u64) -> u64 {
    if (ch == 32 || ch == 9 || ch == 10 || ch == 13) { return 1; }
    return 0;
}

func annotation_is_ident_start(ch: u64) -> u64 {
    if ((ch >= 65 && ch <= 90) || (ch >= 97 && ch <= 122) || ch == 95) { return 1; }
    return 0;
}

func annotation_is_ident_continue(ch: u64) -> u64 {
    if (annotation_is_ident_start(ch) != 0) { return 1; }
    if (ch >= 48 && ch <= 57) { return 1; }
    return 0;
}

func annotation_skip_ws(src_ptr: u64, src_len: u64, pos: *u64) -> u64 {
    if (pos == 0) { return 0; }
    var p: u64 = *pos;
    var s: []u8 = slice(src_ptr, src_len);
    while (p < src_len && annotation_is_space(s[p]) != 0) {
        p = p + 1;
    }
    *pos = p;
    return 0;
}

func annotation_parse_ident(src_ptr: u64, src_len: u64, pos: *u64, out_ptr: *u64, out_len: *u64) -> u64 {
    if (pos == 0 || out_ptr == 0 || out_len == 0) { return 0; }
    annotation_skip_ws(src_ptr, src_len, pos);
    var p: u64 = *pos;
    if (p >= src_len) { return 0; }
    var s: []u8 = slice(src_ptr, src_len);
    if (annotation_is_ident_start(s[p]) == 0) { return 0; }
    var start: u64 = p;
    p = p + 1;
    while (p < src_len && annotation_is_ident_continue(s[p]) != 0) {
        p = p + 1;
    }
    *out_ptr = src_ptr + start;
    *out_len = p - start;
    *pos = p;
    return 1;
}

func annotation_parse_uint(src_ptr: u64, src_len: u64, pos: *u64, out_value: *u64) -> u64 {
    if (pos == 0 || out_value == 0) { return 0; }
    annotation_skip_ws(src_ptr, src_len, pos);
    var p: u64 = *pos;
    if (p >= src_len) { return 0; }
    var s: []u8 = slice(src_ptr, src_len);
    if (s[p] < 48 || s[p] > 57) { return 0; }
    var v: u64 = 0;
    while (p < src_len) {
        var ch: u64 = s[p];
        if (ch < 48 || ch > 57) { break; }
        var d: u64 = ch - 48;
        v = v * 10 + d;
        p = p + 1;
    }
    *out_value = v;
    *pos = p;
    return 1;
}

func annotation_parse_string(src_ptr: u64, src_len: u64, pos: *u64, out_ptr: *u64, out_len: *u64) -> u64 {
    if (pos == 0 || out_ptr == 0 || out_len == 0) { return 0; }
    annotation_skip_ws(src_ptr, src_len, pos);
    var p: u64 = *pos;
    if (p >= src_len) { return 0; }
    var s: []u8 = slice(src_ptr, src_len);
    if (s[p] != 34) { return 0; }
    p = p + 1;
    var start: u64 = p;
    while (p < src_len) {
        var ch: u64 = s[p];
        if (ch == 92) {
            p = p + 1;
            if (p >= src_len) { return 0; }
            p = p + 1;
            continue;
        }
        if (ch == 34) {
            *out_ptr = src_ptr + start;
            *out_len = p - start;
            *pos = p + 1;
            return 1;
        }
        p = p + 1;
    }
    return 0;
}

func annotation_parse_arg_value(src_ptr: u64, src_len: u64, pos: *u64, arg: *CompilerAnnotationArg) -> u64 {
    if (arg == 0) { return 0; }

    var str_ptr: u64 = 0;
    var str_len: u64 = 0;
    if (annotation_parse_string(src_ptr, src_len, pos, &str_ptr, &str_len) != 0) {
        arg.kind = 3;
        arg.string_ptr = str_ptr;
        arg.string_len = str_len;
        return 1;
    }

    var int_value: u64 = 0;
    if (annotation_parse_uint(src_ptr, src_len, pos, &int_value) != 0) {
        arg.kind = 2;
        arg.int_value = int_value;
        return 1;
    }

    var id_ptr: u64 = 0;
    var id_len: u64 = 0;
    if (annotation_parse_ident(src_ptr, src_len, pos, &id_ptr, &id_len) != 0) {
        if (id_len == 4 && str_eq(id_ptr, id_len, "true", 4) != 0) {
            arg.kind = 4;
            arg.bool_value = 1;
            return 1;
        }
        if (id_len == 5 && str_eq(id_ptr, id_len, "false", 5) != 0) {
            arg.kind = 4;
            arg.bool_value = 0;
            return 1;
        }
        arg.kind = 1;
        arg.ident_ptr = id_ptr;
        arg.ident_len = id_len;
        return 1;
    }
    return 0;
}

func annotation_parse_arg_entry(src_ptr: u64, src_len: u64, pos: *u64, arg: *CompilerAnnotationArg) -> u64 {
    if (arg == 0 || pos == 0) { return 0; }
    annotation_skip_ws(src_ptr, src_len, pos);
    var save: u64 = *pos;

    var key_ptr: u64 = 0;
    var key_len: u64 = 0;
    if (annotation_parse_ident(src_ptr, src_len, pos, &key_ptr, &key_len) != 0) {
        annotation_skip_ws(src_ptr, src_len, pos);
        var p: u64 = *pos;
        var s: []u8 = slice(src_ptr, src_len);
        if (p < src_len && s[p] == 61) { // '='
            *pos = p + 1;
            arg.key_ptr = key_ptr;
            arg.key_len = key_len;
            if (annotation_parse_arg_value(src_ptr, src_len, pos, arg) == 0) {
                return 0;
            }
            return 1;
        }
    }

    *pos = save;
    return annotation_parse_arg_value(src_ptr, src_len, pos, arg);
}

func annotation_parse(info: *NameInfo) -> *CompilerAnnotationParsed {
    var parsed: *CompilerAnnotationParsed = new CompilerAnnotationParsed();
    if (info == 0 || info.ptr == 0 || info.len == 0) { return parsed; }

    parsed.raw_ptr = info.ptr;
    parsed.raw_len = info.len;
    parsed.name_ptr = info.ptr;
    var raw_name_len: u64 = annotation_base_len(info.ptr, info.len);
    parsed.name_len = raw_name_len;
    parsed.parse_ok = 1;

    if (raw_name_len == info.len) {
        parsed.args_vec = new Vec<*CompilerAnnotationArg>(0);
        annotation_complexity_canonicalize_parsed_name(parsed);
        return parsed;
    }
    if (raw_name_len == 0 || raw_name_len + 1 >= info.len) {
        parsed.parse_ok = 0;
        return parsed;
    }

    var s: []u8 = slice(info.ptr, info.len);
    if (s[raw_name_len] != 40 || s[info.len - 1] != 41) {
        parsed.parse_ok = 0;
        return parsed;
    }

    var args: *Vec<*CompilerAnnotationArg> = new Vec<*CompilerAnnotationArg>(2);
    var pos: u64 = raw_name_len + 1;
    var args_end: u64 = info.len - 1;
    annotation_skip_ws(info.ptr, info.len, &pos);
    if (pos >= args_end) {
        parsed.args_vec = args;
        return parsed;
    }

    while (pos < args_end) {
        var arg: *CompilerAnnotationArg = new CompilerAnnotationArg();
        if (annotation_parse_arg_entry(info.ptr, info.len, &pos, arg) == 0) {
            parsed.parse_ok = 0;
            parsed.args_vec = args;
            return parsed;
        }
        args.push(arg);
        annotation_skip_ws(info.ptr, info.len, &pos);
        if (pos >= args_end) { break; }
        var s2: []u8 = slice(info.ptr, info.len);
        if (s2[pos] != 44) { // ','
            parsed.parse_ok = 0;
            parsed.args_vec = args;
            return parsed;
        }
        pos = pos + 1;
        annotation_skip_ws(info.ptr, info.len, &pos);
        if (pos >= args_end) {
            parsed.parse_ok = 0;
            parsed.args_vec = args;
            return parsed;
        }
    }

    parsed.args_vec = args;
    annotation_complexity_canonicalize_parsed_name(parsed);
    return parsed;
}

func annotation_emit_invalid_args(fn: *AstFunc, ann: *CompilerAnnotationParsed, detail: u64) -> u64 {
    emit_stderr("[ERROR] invalid annotation arguments on function ");
    if (fn != 0) {
        emit_stderr_len(fn.name_ptr, fn.name_len);
    } else {
        emit_stderr("<unknown>");
    }
    emit_stderr(": ");
    if (ann != 0) {
        emit_stderr_len(ann.name_ptr, ann.name_len);
    } else {
        emit_stderr("<annotation>");
    }
    emit_stderr(" - ");
    emit_stderr(detail);
    emit_stderr("\n");
    diag_note_error();
    return 0;
}

func annotation_arg_key_eq(arg: *CompilerAnnotationArg, key_ptr: u64, key_len: u64) -> u64 {
    if (arg == 0 || arg.key_ptr == 0) { return 0; }
    if (str_eq(arg.key_ptr, arg.key_len, key_ptr, key_len) != 0) { return 1; }
    return 0;
}

func annotation_complexity_find_named_arg(ann: *CompilerAnnotationParsed, key_ptr: u64, key_len: u64) -> *CompilerAnnotationArg {
    if (ann == 0 || ann.args_vec == 0) { return 0; }
    var n: u64 = ann.args_vec.len();
    for (var i: u64 = 0; i < n; i++) {
        var arg: *CompilerAnnotationArg = ann.args_vec.get(i);
        if (annotation_arg_key_eq(arg, key_ptr, key_len) != 0) { return arg; }
    }
    return 0;
}

func annotation_complexity_find_time_arg(ann: *CompilerAnnotationParsed) -> *CompilerAnnotationArg {
    var t: *CompilerAnnotationArg = annotation_complexity_find_named_arg(ann, "time", 4);
    if (t != 0) { return t; }
    return annotation_complexity_find_named_arg(ann, "expr", 4);
}

func annotation_complexity_count_name(fn: *AstFunc, name_ptr: u64, name_len: u64) -> u64 {
    if (fn == 0 || fn.annotations_vec == 0) { return 0; }
    var n: u64 = fn.annotations_vec.len();
    var count: u64 = 0;
    for (var i: u64 = 0; i < n; i++) {
        var info: *NameInfo = fn.annotations_vec.get(i);
        if (info == 0) { continue; }
        var ann: *CompilerAnnotationParsed = annotation_parse(info);
        if (ann == 0 || ann.parse_ok == 0) { continue; }
        if (str_eq(ann.name_ptr, ann.name_len, name_ptr, name_len) != 0) {
            count = count + 1;
        }
    }
    return count;
}

func annotation_complexity_get_single(fn: *AstFunc, name_ptr: u64, name_len: u64) -> *CompilerAnnotationParsed {
    if (fn == 0 || fn.annotations_vec == 0) { return 0; }
    var n: u64 = fn.annotations_vec.len();
    for (var i: u64 = 0; i < n; i++) {
        var info: *NameInfo = fn.annotations_vec.get(i);
        if (info == 0) { continue; }
        var ann: *CompilerAnnotationParsed = annotation_parse(info);
        if (ann == 0 || ann.parse_ok == 0) { continue; }
        if (str_eq(ann.name_ptr, ann.name_len, name_ptr, name_len) != 0) {
            return ann;
        }
    }
    return 0;
}

func annotation_complexity_is_valid_o_string(expr_ptr: u64, expr_len: u64) -> u64 {
    if (expr_ptr == 0 || expr_len < 4) { return 0; }
    var s: []u8 = slice(expr_ptr, expr_len);
    if (s[0] != 79 || s[1] != 40 || s[expr_len - 1] != 41) { return 0; } // O(...)
    return 1;
}

func annotation_complexity_normalize(src_ptr: u64, src_len: u64) -> *NameInfo {
    if (src_ptr == 0 || src_len == 0) { return 0; }
    var src: []u8 = slice(src_ptr, src_len);
    var out_ptr: u64 = heap_alloc((src_len + 1) * sizeof(u8));
    var out: []u8 = slice(out_ptr, src_len + 1);
    var j: u64 = 0;
    for (var i: u64 = 0; i < src_len; i++) {
        var ch: u64 = src[i];
        if (ch == 32 || ch == 9 || ch == 10 || ch == 13) { continue; }
        if (ch >= 65 && ch <= 90) { ch = ch + 32; }
        out[j] = ch;
        j = j + 1;
    }
    out[j] = 0;
    return new NameInfo{out_ptr, j};
}

func annotation_complexity_rank_order(rank: u64) -> u64;
func annotation_complexity_rank_mul(lhs_rank: u64, rhs_rank: u64) -> u64;
func annotation_complexity_rank_expr_inner(src_ptr: u64, src_len: u64) -> u64;

func annotation_complexity_rank_pick_heavier(lhs: u64, rhs: u64) -> u64 {
    if (lhs == 0) { return rhs; }
    if (rhs == 0) { return lhs; }
    if (annotation_complexity_rank_order(lhs) >= annotation_complexity_rank_order(rhs)) { return lhs; }
    return rhs;
}

func annotation_complexity_parse_u64_token(src_ptr: u64, src_len: u64, out_v: *u64) -> u64 {
    if (out_v == 0 || src_ptr == 0 || src_len == 0) { return 0; }
    var pos: u64 = 0;
    var v: u64 = 0;
    if (annotation_parse_uint(src_ptr, src_len, &pos, &v) == 0) { return 0; }
    if (pos != src_len) { return 0; }
    *out_v = v;
    return 1;
}

func annotation_complexity_trim_outer_parens(src_ptr: u64, src_len: u64, out_ptr: *u64, out_len: *u64) -> u64 {
    if (out_ptr == 0 || out_len == 0) { return 0; }
    var p: u64 = src_ptr;
    var n: u64 = src_len;
    var changed: u64 = 1;
    while (changed != 0) {
        changed = 0;
        if (n < 2) { break; }
        var s: []u8 = slice(p, n);
        if (s[0] != 40 || s[n - 1] != 41) { break; }
        var depth: u64 = 0;
        var encloses_all: u64 = 1;
        var valid: u64 = 1;
        for (var i: u64 = 0; i < n; i++) {
            var ch: u64 = s[i];
            if (ch == 40) {
                depth = depth + 1;
                continue;
            }
            if (ch == 41) {
                if (depth == 0) { valid = 0; break; }
                depth = depth - 1;
                if (depth == 0 && i + 1 < n) {
                    encloses_all = 0;
                    break;
                }
            }
        }
        if (valid == 0 || depth != 0 || encloses_all == 0) { break; }
        p = p + 1;
        n = n - 2;
        changed = 1;
    }
    *out_ptr = p;
    *out_len = n;
    return 1;
}

func annotation_complexity_contains_substr(src_ptr: u64, src_len: u64, needle_ptr: u64, needle_len: u64) -> u64 {
    if (src_ptr == 0 || src_len == 0 || needle_ptr == 0 || needle_len == 0 || needle_len > src_len) { return 0; }
    for (var i: u64 = 0; i + needle_len <= src_len; i++) {
        if (str_eq(src_ptr + i, needle_len, needle_ptr, needle_len) != 0) { return 1; }
    }
    return 0;
}

func annotation_complexity_is_ident_token(src_ptr: u64, src_len: u64) -> u64 {
    if (src_ptr == 0 || src_len == 0) { return 0; }
    var s: []u8 = slice(src_ptr, src_len);
    if (annotation_is_ident_start(s[0]) == 0) { return 0; }
    for (var i: u64 = 1; i < src_len; i++) {
        if (annotation_is_ident_continue(s[i]) == 0) { return 0; }
    }
    return 1;
}

func annotation_complexity_split_call(src_ptr: u64, src_len: u64, prefix_ptr: u64, prefix_len: u64, out_inner_ptr: *u64, out_inner_len: *u64) -> u64 {
    if (out_inner_ptr == 0 || out_inner_len == 0) { return 0; }
    if (src_ptr == 0 || src_len <= prefix_len + 2) { return 0; }
    if (str_eq(src_ptr, prefix_len, prefix_ptr, prefix_len) == 0) { return 0; }
    var s: []u8 = slice(src_ptr, src_len);
    if (s[prefix_len] != 40 || s[src_len - 1] != 41) { return 0; }
    var depth: u64 = 0;
    for (var i: u64 = prefix_len; i < src_len; i++) {
        var ch: u64 = s[i];
        if (ch == 40) {
            depth = depth + 1;
            continue;
        }
        if (ch == 41) {
            if (depth == 0) { return 0; }
            depth = depth - 1;
            if (depth == 0 && i + 1 < src_len) { return 0; }
        }
    }
    if (depth != 0) { return 0; }
    *out_inner_ptr = src_ptr + prefix_len + 1;
    *out_inner_len = src_len - (prefix_len + 2);
    return 1;
}

func annotation_complexity_rank_expr_inner(src_ptr: u64, src_len: u64) -> u64 {
    var p: u64 = src_ptr;
    var n: u64 = src_len;
    annotation_complexity_trim_outer_parens(p, n, &p, &n);
    if (n == 0) { return 0; }
    var s: []u8 = slice(p, n);

    // + / - (top-level): complexity of sum is max(term complexities).
    var depth_add: u64 = 0;
    var start_add: u64 = 0;
    var found_add: u64 = 0;
    var best_add: u64 = 0;
    for (var i: u64 = 0; i < n; i++) {
        var ch: u64 = s[i];
        if (ch == 40) { depth_add = depth_add + 1; continue; }
        if (ch == 41) { if (depth_add > 0) { depth_add = depth_add - 1; } continue; }
        if (depth_add != 0) { continue; }
        if (ch != 43 && ch != 45) { continue; }
        // Treat unary +/- as part of token.
        if (i == start_add) { continue; }
        var term_rank: u64 = annotation_complexity_rank_expr_inner(p + start_add, i - start_add);
        best_add = annotation_complexity_rank_pick_heavier(best_add, term_rank);
        start_add = i + 1;
        found_add = 1;
    }
    if (found_add != 0) {
        var last_rank: u64 = annotation_complexity_rank_expr_inner(p + start_add, n - start_add);
        best_add = annotation_complexity_rank_pick_heavier(best_add, last_rank);
        return best_add;
    }

    // * / (top-level): multiply/divide factors left-to-right.
    var depth_mul: u64 = 0;
    var start_mul: u64 = 0;
    var found_mul: u64 = 0;
    var acc_rank: u64 = 1;
    var pending_op: u64 = 42; // '*'
    for (var j: u64 = 0; j < n; j++) {
        var ch2: u64 = s[j];
        if (ch2 == 40) { depth_mul = depth_mul + 1; continue; }
        if (ch2 == 41) { if (depth_mul > 0) { depth_mul = depth_mul - 1; } continue; }
        if (depth_mul != 0) { continue; }
        if (ch2 != 42 && ch2 != 47) { continue; } // * or /
        if (j == start_mul) { continue; }
        var part_rank: u64 = annotation_complexity_rank_expr_inner(p + start_mul, j - start_mul);
        if (part_rank == 0) { return 0; }
        if (pending_op == 42) {
            acc_rank = annotation_complexity_rank_mul(acc_rank, part_rank);
        } else {
            // Division never increases asymptotic order; treat as no-op for rank.
            if (acc_rank == 0) { acc_rank = part_rank; }
        }
        start_mul = j + 1;
        pending_op = ch2;
        found_mul = 1;
    }
    if (found_mul != 0) {
        var tail_rank: u64 = annotation_complexity_rank_expr_inner(p + start_mul, n - start_mul);
        if (tail_rank == 0) { return 0; }
        if (pending_op == 42) {
            acc_rank = annotation_complexity_rank_mul(acc_rank, tail_rank);
        }
        return acc_rank;
    }

    // Top-level power.
    var depth_pow: u64 = 0;
    var caret_idx: u64 = n;
    for (var k: u64 = 0; k < n; k++) {
        var ch3: u64 = s[k];
        if (ch3 == 40) { depth_pow = depth_pow + 1; continue; }
        if (ch3 == 41) { if (depth_pow > 0) { depth_pow = depth_pow - 1; } continue; }
        if (depth_pow == 0 && ch3 == 94) { caret_idx = k; }
    }
    if (caret_idx < n) {
        var base_rank: u64 = annotation_complexity_rank_expr_inner(p, caret_idx);
        if (base_rank == 0) { return 0; }
        var exp_ptr: u64 = p + caret_idx + 1;
        var exp_len: u64 = n - (caret_idx + 1);
        annotation_complexity_trim_outer_parens(exp_ptr, exp_len, &exp_ptr, &exp_len);
        var e_int: u64 = 0;
        if (annotation_complexity_parse_u64_token(exp_ptr, exp_len, &e_int) != 0) {
            if (e_int == 0) { return 1; }
            var r_pow: u64 = 1;
            for (var pi: u64 = 0; pi < e_int; pi++) {
                r_pow = annotation_complexity_rank_mul(r_pow, base_rank);
                if (annotation_complexity_rank_order(r_pow) > annotation_complexity_rank_order(6)) { return 6; }
            }
            return r_pow;
        }
        if (str_eq(exp_ptr, exp_len, "0.5", 3) != 0 || str_eq(exp_ptr, exp_len, "1/2", 3) != 0) { return 10; }
        if (str_eq(exp_ptr, exp_len, "0.25", 4) != 0 || str_eq(exp_ptr, exp_len, "1/4", 3) != 0) { return 11; }
        var base_num: u64 = 0;
        if (annotation_complexity_parse_u64_token(p, caret_idx, &base_num) != 0 && base_num == 2) {
            if (annotation_complexity_is_ident_token(exp_ptr, exp_len) != 0) { return 7; }
        }
        return 0;
    }

    // Function calls.
    var inner_ptr: u64 = 0;
    var inner_len: u64 = 0;
    if (annotation_complexity_split_call(p, n, "sqrt", 4, &inner_ptr, &inner_len) != 0) {
        if (annotation_complexity_rank_expr_inner(inner_ptr, inner_len) == 0) { return 0; }
        return 10;
    }
    if (annotation_complexity_split_call(p, n, "loglog", 6, &inner_ptr, &inner_len) != 0) {
        if (annotation_complexity_rank_expr_inner(inner_ptr, inner_len) == 0) { return 0; }
        return 2;
    }
    if (annotation_complexity_split_call(p, n, "log", 3, &inner_ptr, &inner_len) != 0) {
        if (annotation_complexity_rank_expr_inner(inner_ptr, inner_len) == 0) { return 0; }
        return 2;
    }

    // Common shorthand tokens.
    if (str_eq(p, n, "logn", 4) != 0) { return 2; }
    if (str_eq(p, n, "loglogn", 7) != 0) { return 2; }
    if (annotation_complexity_contains_substr(p, n, "loglog", 6) != 0) { return 9; }
    if (annotation_complexity_contains_substr(p, n, "log", 3) != 0) { return 4; }

    // Factorial.
    if (s[n - 1] == 33) { return 8; } // !

    // Primitive tokens.
    var lit_v: u64 = 0;
    if (annotation_complexity_parse_u64_token(p, n, &lit_v) != 0) { return 1; }
    if (annotation_complexity_is_ident_token(p, n) != 0) { return 3; }
    return 0;
}

func annotation_complexity_rank_from_expr(expr_ptr: u64, expr_len: u64) -> u64 {
    if (annotation_complexity_is_valid_o_string(expr_ptr, expr_len) == 0) { return 0; }
    var norm: *NameInfo = annotation_complexity_normalize(expr_ptr, expr_len);
    if (norm == 0 || norm.len == 0) { return 0; }
    if (str_eq(norm.ptr, norm.len, "o(1)", 4) != 0) { return 1; }
    if (str_eq(norm.ptr, norm.len, "o(logn)", 7) != 0) { return 2; }
    if (str_eq(norm.ptr, norm.len, "o(log(n)^2)", 11) != 0) { return 12; }
    if (str_eq(norm.ptr, norm.len, "o((log(n))^2)", 13) != 0) { return 12; }
    if (str_eq(norm.ptr, norm.len, "o((logn)^2)", 11) != 0) { return 12; }
    if (str_eq(norm.ptr, norm.len, "o(logn*logn)", 12) != 0) { return 12; }
    if (str_eq(norm.ptr, norm.len, "o(log(n)*log(n))", 15) != 0) { return 12; }
    if (str_eq(norm.ptr, norm.len, "o(n^(1/4))", 10) != 0) { return 11; }
    if (str_eq(norm.ptr, norm.len, "o(p^(1/4))", 10) != 0) { return 11; }
    if (str_eq(norm.ptr, norm.len, "o(n^0.25)", 9) != 0) { return 11; }
    if (str_eq(norm.ptr, norm.len, "o(p^0.25)", 9) != 0) { return 11; }
    if (str_eq(norm.ptr, norm.len, "o(sqrtn)", 8) != 0) { return 10; }
    if (str_eq(norm.ptr, norm.len, "o(sqrt(n))", 10) != 0) { return 10; }
    if (str_eq(norm.ptr, norm.len, "o(sqrt(p))", 10) != 0) { return 10; }
    if (str_eq(norm.ptr, norm.len, "o(n)", 4) != 0) { return 3; }
    if (str_eq(norm.ptr, norm.len, "o(nloglogn)", 11) != 0) { return 9; }
    if (str_eq(norm.ptr, norm.len, "o(nlogn)", 8) != 0) { return 4; }
    if (str_eq(norm.ptr, norm.len, "o(n^2)", 6) != 0) { return 5; }
    if (str_eq(norm.ptr, norm.len, "o(n^3)", 6) != 0) { return 6; }
    if (str_eq(norm.ptr, norm.len, "o(2^n)", 6) != 0) { return 7; }
    if (str_eq(norm.ptr, norm.len, "o(n!)", 5) != 0) { return 8; }
    // Multi-variable common forms (rank-only approximation).
    if (str_eq(norm.ptr, norm.len, "o(v+e)", 6) != 0) { return 3; }
    if (str_eq(norm.ptr, norm.len, "o(n+m)", 6) != 0) { return 3; }
    if (str_eq(norm.ptr, norm.len, "o(v*e)", 6) != 0) { return 5; }
    if (str_eq(norm.ptr, norm.len, "o(e*v)", 6) != 0) { return 5; }
    if (str_eq(norm.ptr, norm.len, "o(n*m)", 6) != 0) { return 5; }
    if (str_eq(norm.ptr, norm.len, "o(m*n)", 6) != 0) { return 5; }
    if (str_eq(norm.ptr, norm.len, "o(n^2+m)", 8) != 0) { return 5; }
    if (str_eq(norm.ptr, norm.len, "o(m+n^2)", 8) != 0) { return 5; }
    // Generic parser fallback for richer forms:
    // O(2*n*log(m)), O((n+m)*log(n)), O(n^(1/2)), O(n^(1/4)), ...
    var inner_ptr: u64 = norm.ptr + 2;
    var inner_len: u64 = norm.len - 3;
    var generic_rank: u64 = annotation_complexity_rank_expr_inner(inner_ptr, inner_len);
    if (generic_rank != 0) { return generic_rank; }
    // Still unknown: numeric evaluator may enforce budget if constraints exist.
    return 0;
}

func annotation_complexity_symbol_is_builtin_token(tok_ptr: u64, tok_len: u64) -> u64 {
    if (tok_ptr == 0 || tok_len == 0) { return 1; }
    if (str_eq(tok_ptr, tok_len, "log", 3) != 0) { return 1; }
    if (str_eq(tok_ptr, tok_len, "loglog", 6) != 0) { return 1; }
    if (str_eq(tok_ptr, tok_len, "sqrt", 4) != 0) { return 1; }
    if (str_eq(tok_ptr, tok_len, "min", 3) != 0) { return 1; }
    if (str_eq(tok_ptr, tok_len, "max", 3) != 0) { return 1; }
    if (str_eq(tok_ptr, tok_len, "poly", 4) != 0) { return 1; }
    if (str_eq(tok_ptr, tok_len, "o", 1) != 0) { return 1; }
    return 0;
}

func annotation_complexity_expr_symbol_profile(expr_ptr: u64, expr_len: u64, out_count: *u64, out_ptr: *u64, out_len: *u64) -> u64 {
    if (out_count == 0 || out_ptr == 0 || out_len == 0) { return 0; }
    *out_count = 0;
    *out_ptr = 0;
    *out_len = 0;
    if (annotation_complexity_is_valid_o_string(expr_ptr, expr_len) == 0) { return 0; }
    var norm: *NameInfo = annotation_complexity_normalize(expr_ptr, expr_len);
    if (norm == 0 || norm.ptr == 0 || norm.len < 4) { return 0; }
    var inner_ptr: u64 = norm.ptr + 2;
    var inner_len: u64 = norm.len - 3;
    if (inner_len == 0) { return 1; }
    var s: []u8 = slice(inner_ptr, inner_len);
    var first_ptr: u64 = 0;
    var first_len: u64 = 0;
    var count: u64 = 0;
    var i: u64 = 0;
    while (i < inner_len) {
        if (annotation_is_ident_start(s[i]) == 0) {
            i = i + 1;
            continue;
        }
        var start: u64 = i;
        i = i + 1;
        while (i < inner_len && annotation_is_ident_continue(s[i]) != 0) { i = i + 1; }
        var tok_ptr: u64 = inner_ptr + start;
        var tok_len: u64 = i - start;
        if (annotation_complexity_symbol_is_builtin_token(tok_ptr, tok_len) != 0) { continue; }
        if (count == 0) {
            first_ptr = tok_ptr;
            first_len = tok_len;
            count = 1;
            continue;
        }
        if (str_eq(first_ptr, first_len, tok_ptr, tok_len) == 0) {
            count = 2;
            break;
        }
    }
    *out_count = count;
    if (count == 1) {
        *out_ptr = first_ptr;
        *out_len = first_len;
    }
    return 1;
}

func annotation_complexity_rank_name(rank: u64) -> u64 {
    match (rank) {
        case 1: return "O(1)";
        case 2: return "O(log n)";
        case 12: return "O(log^2 n)";
        case 11: return "O(n^(1/4))";
        case 10: return "O(sqrt n)";
        case 3: return "O(n)";
        case 9: return "O(n log log n)";
        case 4: return "O(n log n)";
        case 5: return "O(n^2)";
        case 6: return "O(n^3)";
        case 7: return "O(2^n)";
        case 8: return "O(n!)";
        case 13: return "O(n!*poly)";
    }
    return "unknown";
}

const ANN_COMPLEXITY_MODE_UNSPEC = 0;
const ANN_COMPLEXITY_MODE_WORST = 1;
const ANN_COMPLEXITY_MODE_EXPECTED = 2;
const ANN_COMPLEXITY_MODE_HIGH_PROB = 3;
const ANN_COMPLEXITY_MODE_AMORTIZED = 4;

func annotation_complexity_mode_name(mode: u64) -> u64 {
    match (mode) {
        case ANN_COMPLEXITY_MODE_WORST: return "worst";
        case ANN_COMPLEXITY_MODE_EXPECTED: return "expected";
        case ANN_COMPLEXITY_MODE_HIGH_PROB: return "high_prob";
        case ANN_COMPLEXITY_MODE_AMORTIZED: return "amortized";
    }
    return "unspecified";
}

func annotation_complexity_parse_mode_text(ptr: u64, len: u64) -> u64 {
    if (ptr == 0 || len == 0) { return ANN_COMPLEXITY_MODE_UNSPEC; }
    var norm: *NameInfo = annotation_complexity_normalize(ptr, len);
    if (norm == 0 || norm.ptr == 0 || norm.len == 0) { return ANN_COMPLEXITY_MODE_UNSPEC; }
    if (str_eq(norm.ptr, norm.len, "worst", 5) != 0) { return ANN_COMPLEXITY_MODE_WORST; }
    if (str_eq(norm.ptr, norm.len, "expected", 8) != 0) { return ANN_COMPLEXITY_MODE_EXPECTED; }
    if (str_eq(norm.ptr, norm.len, "avg", 3) != 0) { return ANN_COMPLEXITY_MODE_EXPECTED; }
    if (str_eq(norm.ptr, norm.len, "average", 7) != 0) { return ANN_COMPLEXITY_MODE_EXPECTED; }
    if (str_eq(norm.ptr, norm.len, "highprob", 8) != 0) { return ANN_COMPLEXITY_MODE_HIGH_PROB; }
    if (str_eq(norm.ptr, norm.len, "high_prob", 9) != 0) { return ANN_COMPLEXITY_MODE_HIGH_PROB; }
    if (str_eq(norm.ptr, norm.len, "w.h.p", 5) != 0) { return ANN_COMPLEXITY_MODE_HIGH_PROB; }
    if (str_eq(norm.ptr, norm.len, "amortized", 9) != 0) { return ANN_COMPLEXITY_MODE_AMORTIZED; }
    return ANN_COMPLEXITY_MODE_UNSPEC;
}

func annotation_complexity_parse_mode_arg(arg: *CompilerAnnotationArg) -> u64 {
    if (arg == 0) { return ANN_COMPLEXITY_MODE_UNSPEC; }
    if (arg.kind == 3) { return annotation_complexity_parse_mode_text(arg.string_ptr, arg.string_len); }
    if (arg.kind == 1) { return annotation_complexity_parse_mode_text(arg.ident_ptr, arg.ident_len); }
    return ANN_COMPLEXITY_MODE_UNSPEC;
}

func annotation_complexity_extract_input_target_ident(arg: *CompilerAnnotationArg, out_ptr: *u64, out_len: *u64) -> u64 {
    if (out_ptr == 0 || out_len == 0 || arg == 0) { return 0; }
    if (arg.kind == 1 && annotation_complexity_is_ident_token(arg.ident_ptr, arg.ident_len) != 0) {
        *out_ptr = arg.ident_ptr;
        *out_len = arg.ident_len;
        return 1;
    }
    if (arg.kind != 3 || arg.string_ptr == 0 || arg.string_len == 0) { return 0; }
    var norm: *NameInfo = annotation_complexity_normalize(arg.string_ptr, arg.string_len);
    if (norm == 0 || norm.ptr == 0 || norm.len == 0) { return 0; }
    if (annotation_complexity_is_ident_token(norm.ptr, norm.len) != 0) {
        *out_ptr = norm.ptr;
        *out_len = norm.len;
        return 1;
    }

    var inner_ptr: u64 = 0;
    var inner_len: u64 = 0;
    if (annotation_complexity_split_call(norm.ptr, norm.len, "len", 3, &inner_ptr, &inner_len) != 0 ||
        annotation_complexity_split_call(norm.ptr, norm.len, "size", 4, &inner_ptr, &inner_len) != 0 ||
        annotation_complexity_split_call(norm.ptr, norm.len, "length", 6, &inner_ptr, &inner_len) != 0) {
        if (annotation_complexity_is_ident_token(inner_ptr, inner_len) != 0) {
            *out_ptr = inner_ptr;
            *out_len = inner_len;
            return 1;
        }
    }
    return 0;
}

func annotation_complexity_expr_contains_ident_token(src_ptr: u64, src_len: u64, ident_ptr: u64, ident_len: u64) -> u64 {
    if (src_ptr == 0 || src_len == 0 || ident_ptr == 0 || ident_len == 0 || ident_len > src_len) { return 0; }
    var norm: *NameInfo = annotation_complexity_normalize(src_ptr, src_len);
    if (norm == 0 || norm.ptr == 0 || norm.len == 0 || ident_len > norm.len) { return 0; }
    var s: []u8 = slice(norm.ptr, norm.len);
    var i: u64 = 0;
    while (i + ident_len <= norm.len) {
        if (str_eq(norm.ptr + i, ident_len, ident_ptr, ident_len) != 0) {
            var left_ok: u64 = 0;
            var right_ok: u64 = 0;
            if (i == 0) { left_ok = 1; }
            else if (annotation_is_ident_continue(s[i - 1]) == 0) { left_ok = 1; }
            var r: u64 = i + ident_len;
            if (r >= norm.len) { right_ok = 1; }
            else if (annotation_is_ident_continue(s[r]) == 0) { right_ok = 1; }
            if (left_ok != 0 && right_ok != 0) { return 1; }
        }
        i = i + 1;
    }
    return 0;
}

func annotation_complexity_fn_has_param(fn: *AstFunc, name_ptr: u64, name_len: u64) -> u64 {
    if (fn == 0 || fn.params_vec == 0 || name_ptr == 0 || name_len == 0) { return 0; }
    var n: u64 = fn.params_vec.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var p: *Param = fn.params_vec.get(i);
        if (p != 0 && p.name_ptr != 0 && p.name_len != 0 &&
            str_eq(p.name_ptr, p.name_len, name_ptr, name_len) != 0) {
            return 1;
        }
    }
    return 0;
}

func annotation_complexity_log2_floor(n: u64) -> u64 {
    if (n <= 1) { return 0; }
    var v: u64 = n;
    var out: u64 = 0;
    while (v > 1) {
        v = v >> 1;
        out = out + 1;
    }
    return out;
}

func annotation_complexity_sat_mul(a: u64, b: u64, cap: u64) -> u64 {
    if (a == 0 || b == 0) { return 0; }
    if (a > cap / b) { return cap; }
    return a * b;
}

func annotation_complexity_sat_add(a: u64, b: u64, cap: u64) -> u64 {
    if (a > cap - b) { return cap; }
    return a + b;
}

func annotation_complexity_isqrt_floor(n: u64) -> u64 {
    if (n <= 1) { return n; }
    var lo: u64 = 0;
    var hi: u64 = n;
    if (hi > 3037000500) { hi = 3037000500; }
    while (lo < hi) {
        var mid: u64 = lo + ((hi - lo + 1) >> 1);
        if (mid <= n / mid) { lo = mid; }
        else { hi = mid - 1; }
    }
    return lo;
}

func annotation_complexity_ifourth_root_floor(n: u64) -> u64 {
    return annotation_complexity_isqrt_floor(annotation_complexity_isqrt_floor(n));
}

func annotation_complexity_constraints_max(constraints_ann: *CompilerAnnotationParsed) -> u64 {
    if (constraints_ann == 0 || constraints_ann.args_vec == 0) { return 1; }
    var n: u64 = constraints_ann.args_vec.len();
    var out: u64 = 1;
    for (var i: u64 = 0; i < n; i++) {
        var a: *CompilerAnnotationArg = constraints_ann.args_vec.get(i);
        if (a != 0 && a.kind == 2 && a.int_value > out) { out = a.int_value; }
    }
    return out;
}

func annotation_complexity_constraint_lookup_from_relations(constraints_ann: *CompilerAnnotationParsed, key_ptr: u64, key_len: u64, out_value: *u64) -> u64;

func annotation_complexity_constraint_lookup_direct(constraints_ann: *CompilerAnnotationParsed, key_ptr: u64, key_len: u64, out_value: *u64) -> u64 {
    if (out_value == 0) { return 0; }
    if (constraints_ann == 0 || constraints_ann.args_vec == 0 || key_ptr == 0 || key_len == 0) { return 0; }
    var n: u64 = constraints_ann.args_vec.len();
    for (var i: u64 = 0; i < n; i++) {
        var a: *CompilerAnnotationArg = constraints_ann.args_vec.get(i);
        if (a == 0 || a.kind != 2 || a.key_ptr == 0 || a.key_len == 0) { continue; }
        if (str_eq(a.key_ptr, a.key_len, key_ptr, key_len) != 0) {
            *out_value = a.int_value;
            return 1;
        }
    }
    return 0;
}

func annotation_complexity_constraint_lookup(constraints_ann: *CompilerAnnotationParsed, key_ptr: u64, key_len: u64, out_value: *u64) -> u64 {
    if (out_value == 0 || constraints_ann == 0 || key_ptr == 0 || key_len == 0) { return 0; }
    var direct_ok: u64 = 0;
    var relation_ok: u64 = 0;
    var direct_v: u64 = 0;
    var relation_v: u64 = 0;
    direct_ok = annotation_complexity_constraint_lookup_direct(constraints_ann, key_ptr, key_len, &direct_v);
    relation_ok = annotation_complexity_constraint_lookup_from_relations(constraints_ann, key_ptr, key_len, &relation_v);
    if (direct_ok != 0 && relation_ok != 0) {
        if (relation_v < direct_v) { *out_value = relation_v; }
        else { *out_value = direct_v; }
        return 1;
    }
    if (direct_ok != 0) { *out_value = direct_v; return 1; }
    if (relation_ok != 0) { *out_value = relation_v; return 1; }
    return 0;
}

func annotation_complexity_parse_ident_token(src_ptr: u64, src_len: u64, pos: *u64, out_ptr: *u64, out_len: *u64) -> u64 {
    if (pos == 0 || out_ptr == 0 || out_len == 0) { return 0; }
    var p: u64 = *pos;
    if (p >= src_len) { return 0; }
    var s: []u8 = slice(src_ptr, src_len);
    if (annotation_is_ident_start(s[p]) == 0) { return 0; }
    var start: u64 = p;
    p = p + 1;
    while (p < src_len && annotation_is_ident_continue(s[p]) != 0) { p = p + 1; }
    *out_ptr = src_ptr + start;
    *out_len = p - start;
    *pos = p;
    return 1;
}

func annotation_complexity_sat_factorial(v: u64, cap: u64) -> u64 {
    if (v <= 1) { return 1; }
    var out: u64 = 1;
    for (var i: u64 = 2; i <= v; i = i + 1) {
        out = annotation_complexity_sat_mul(out, i, cap);
        if (out == cap) { break; }
    }
    return out;
}

func annotation_complexity_eval_apply_postfix(src_ptr: u64, src_len: u64, pos: *u64, value: u64, ok: *u64) -> u64 {
    if (ok == 0 || *ok == 0 || pos == 0) { return 0; }
    var cap: u64 = 9223372036854775807;
    var p: u64 = *pos;
    if (p >= src_len) { return value; }
    var s: []u8 = slice(src_ptr, src_len);
    var out: u64 = value;
    while (p < src_len && s[p] == 33) { // '!'
        out = annotation_complexity_sat_factorial(out, cap);
        p = p + 1;
    }
    *pos = p;
    return out;
}

func annotation_complexity_eval_expr_inner(src_ptr: u64, src_len: u64, pos: *u64, constraints_ann: *CompilerAnnotationParsed, fallback_bound: u64, ok: *u64) -> u64;
func annotation_complexity_eval_term_inner(src_ptr: u64, src_len: u64, pos: *u64, constraints_ann: *CompilerAnnotationParsed, fallback_bound: u64, ok: *u64) -> u64;
func annotation_complexity_eval_factor_inner(src_ptr: u64, src_len: u64, pos: *u64, constraints_ann: *CompilerAnnotationParsed, fallback_bound: u64, ok: *u64) -> u64;

func annotation_complexity_eval_factor_inner(src_ptr: u64, src_len: u64, pos: *u64, constraints_ann: *CompilerAnnotationParsed, fallback_bound: u64, ok: *u64) -> u64 {
    if (ok == 0 || *ok == 0) { return 0; }
    var cap: u64 = 9223372036854775807;
    var p: u64 = *pos;
    if (p >= src_len) { *ok = 0; return 0; }
    var s: []u8 = slice(src_ptr, src_len);

    if (s[p] == 40) { // '('
        p = p + 1;
        *pos = p;
        var v_paren: u64 = annotation_complexity_eval_expr_inner(src_ptr, src_len, pos, constraints_ann, fallback_bound, ok);
        if (*ok == 0) { return 0; }
        p = *pos;
        if (p >= src_len || s[p] != 41) { *ok = 0; return 0; }
        p = p + 1;
        *pos = p;
        return annotation_complexity_eval_apply_postfix(src_ptr, src_len, pos, v_paren, ok);
    }

    var num_pos: u64 = p;
    var num_v: u64 = 0;
    if (annotation_parse_uint(src_ptr, src_len, &num_pos, &num_v) != 0 && num_pos > p) {
        p = num_pos;
        *pos = p;
        return annotation_complexity_eval_apply_postfix(src_ptr, src_len, pos, num_v, ok);
    }

    if (p + 4 <= src_len && str_eq(src_ptr + p, 4, "min(", 4) != 0) {
        p = p + 4;
        *pos = p;
        var left_min: u64 = annotation_complexity_eval_expr_inner(src_ptr, src_len, pos, constraints_ann, fallback_bound, ok);
        if (*ok == 0) { return 0; }
        p = *pos;
        if (p >= src_len || s[p] != 44) { *ok = 0; return 0; } // ','
        p = p + 1;
        *pos = p;
        var right_min: u64 = annotation_complexity_eval_expr_inner(src_ptr, src_len, pos, constraints_ann, fallback_bound, ok);
        if (*ok == 0) { return 0; }
        p = *pos;
        if (p >= src_len || s[p] != 41) { *ok = 0; return 0; } // ')'
        p = p + 1;
        *pos = p;
        if (left_min < right_min) { return annotation_complexity_eval_apply_postfix(src_ptr, src_len, pos, left_min, ok); }
        return annotation_complexity_eval_apply_postfix(src_ptr, src_len, pos, right_min, ok);
    }

    if (p + 4 <= src_len && str_eq(src_ptr + p, 4, "max(", 4) != 0) {
        p = p + 4;
        *pos = p;
        var left_max: u64 = annotation_complexity_eval_expr_inner(src_ptr, src_len, pos, constraints_ann, fallback_bound, ok);
        if (*ok == 0) { return 0; }
        p = *pos;
        if (p >= src_len || s[p] != 44) { *ok = 0; return 0; } // ','
        p = p + 1;
        *pos = p;
        var right_max: u64 = annotation_complexity_eval_expr_inner(src_ptr, src_len, pos, constraints_ann, fallback_bound, ok);
        if (*ok == 0) { return 0; }
        p = *pos;
        if (p >= src_len || s[p] != 41) { *ok = 0; return 0; } // ')'
        p = p + 1;
        *pos = p;
        if (left_max > right_max) { return annotation_complexity_eval_apply_postfix(src_ptr, src_len, pos, left_max, ok); }
        return annotation_complexity_eval_apply_postfix(src_ptr, src_len, pos, right_max, ok);
    }

    if (p + 4 <= src_len && str_eq(src_ptr + p, 4, "log(", 4) != 0) {
        p = p + 4;
        *pos = p;
        var inner_log: u64 = annotation_complexity_eval_expr_inner(src_ptr, src_len, pos, constraints_ann, fallback_bound, ok);
        if (*ok == 0) { return 0; }
        p = *pos;
        if (p >= src_len || s[p] != 41) { *ok = 0; return 0; }
        p = p + 1;
        *pos = p;
        return annotation_complexity_eval_apply_postfix(src_ptr, src_len, pos, annotation_complexity_log2_floor(inner_log + 1), ok);
    }

    if (p + 7 <= src_len && str_eq(src_ptr + p, 7, "loglog(", 7) != 0) {
        p = p + 7;
        *pos = p;
        var inner_lglg: u64 = annotation_complexity_eval_expr_inner(src_ptr, src_len, pos, constraints_ann, fallback_bound, ok);
        if (*ok == 0) { return 0; }
        p = *pos;
        if (p >= src_len || s[p] != 41) { *ok = 0; return 0; }
        p = p + 1;
        *pos = p;
        var lg: u64 = annotation_complexity_log2_floor(inner_lglg + 1);
        return annotation_complexity_eval_apply_postfix(src_ptr, src_len, pos, annotation_complexity_log2_floor(lg + 1), ok);
    }

    if (p + 5 <= src_len && str_eq(src_ptr + p, 5, "sqrt(", 5) != 0) {
        p = p + 5;
        *pos = p;
        var inner_sqrt: u64 = annotation_complexity_eval_expr_inner(src_ptr, src_len, pos, constraints_ann, fallback_bound, ok);
        if (*ok == 0) { return 0; }
        p = *pos;
        if (p >= src_len || s[p] != 41) { *ok = 0; return 0; }
        p = p + 1;
        *pos = p;
        return annotation_complexity_eval_apply_postfix(src_ptr, src_len, pos, annotation_complexity_isqrt_floor(inner_sqrt), ok);
    }

    var id_ptr: u64 = 0;
    var id_len: u64 = 0;
    if (annotation_complexity_parse_ident_token(src_ptr, src_len, &p, &id_ptr, &id_len) != 0) {
        var base_val: u64 = 0;
        if (annotation_complexity_constraint_lookup(constraints_ann, id_ptr, id_len, &base_val) == 0) {
            // shorthand aliases: nlogn / nloglogn
            if (id_len > 4 && str_eq(id_ptr + (id_len - 4), 4, "logn", 4) != 0) {
                var pre_len: u64 = id_len - 4;
                var pre_val: u64 = 0;
                if (annotation_complexity_constraint_lookup(constraints_ann, id_ptr, pre_len, &pre_val) != 0) {
                    base_val = annotation_complexity_sat_mul(pre_val, annotation_complexity_log2_floor(pre_val + 1), cap);
                } else {
                    *ok = 0;
                    return 0;
                }
            } else if (id_len > 7 && str_eq(id_ptr + (id_len - 7), 7, "loglogn", 7) != 0) {
                var pre_len2: u64 = id_len - 7;
                var pre_val2: u64 = 0;
                if (annotation_complexity_constraint_lookup(constraints_ann, id_ptr, pre_len2, &pre_val2) != 0) {
                    var lg2: u64 = annotation_complexity_log2_floor(pre_val2 + 1);
                    base_val = annotation_complexity_sat_mul(pre_val2, annotation_complexity_log2_floor(lg2 + 1), cap);
                } else {
                    *ok = 0;
                    return 0;
                }
            } else {
                *ok = 0;
                return 0;
            }
        }
        *pos = p;
        if (p < src_len && s[p] == 94) { // ^
            p = p + 1;
            if (p < src_len && s[p] == 40) { // '('
                p = p + 1;
                var num_pos: u64 = p;
                var num_v: u64 = 0;
                if (annotation_parse_uint(src_ptr, src_len, &num_pos, &num_v) == 0 || num_pos == p) { *ok = 0; return 0; }
                p = num_pos;
                if (p >= src_len || s[p] != 47) { *ok = 0; return 0; } // '/'
                p = p + 1;
                var den_pos: u64 = p;
                var den_v: u64 = 0;
                if (annotation_parse_uint(src_ptr, src_len, &den_pos, &den_v) == 0 || den_pos == p) { *ok = 0; return 0; }
                p = den_pos;
                if (p >= src_len || s[p] != 41) { *ok = 0; return 0; } // ')'
                p = p + 1;
                *pos = p;
                if (num_v == 1 && den_v == 2) { return annotation_complexity_eval_apply_postfix(src_ptr, src_len, pos, annotation_complexity_isqrt_floor(base_val), ok); }
                if (num_v == 1 && den_v == 4) { return annotation_complexity_eval_apply_postfix(src_ptr, src_len, pos, annotation_complexity_ifourth_root_floor(base_val), ok); }
                *ok = 0;
                return 0;
            }

            var exp_pos: u64 = p;
            var e: u64 = 0;
            if (annotation_parse_uint(src_ptr, src_len, &exp_pos, &e) == 0 || exp_pos == p) { *ok = 0; return 0; }
            p = exp_pos;
            *pos = p;
            var out_pow: u64 = 1;
            for (var pi: u64 = 0; pi < e; pi++) {
                out_pow = annotation_complexity_sat_mul(out_pow, base_val, cap);
            }
            return annotation_complexity_eval_apply_postfix(src_ptr, src_len, pos, out_pow, ok);
        }
        return annotation_complexity_eval_apply_postfix(src_ptr, src_len, pos, base_val, ok);
    }

    *ok = 0;
    return 0;
}

func annotation_complexity_eval_term_inner(src_ptr: u64, src_len: u64, pos: *u64, constraints_ann: *CompilerAnnotationParsed, fallback_bound: u64, ok: *u64) -> u64 {
    var cap: u64 = 9223372036854775807;
    var out: u64 = annotation_complexity_eval_factor_inner(src_ptr, src_len, pos, constraints_ann, fallback_bound, ok);
    if (ok == 0 || *ok == 0) { return 0; }
    var s: []u8 = slice(src_ptr, src_len);
    while (*pos < src_len && (s[*pos] == 42 || s[*pos] == 47)) { // '*' or '/'
        var op: u8 = s[*pos];
        *pos = *pos + 1;
        var rhs: u64 = annotation_complexity_eval_factor_inner(src_ptr, src_len, pos, constraints_ann, fallback_bound, ok);
        if (*ok == 0) { return 0; }
        if (op == 42) {
            out = annotation_complexity_sat_mul(out, rhs, cap);
        } else {
            if (rhs == 0) { *ok = 0; return 0; }
            out = out / rhs;
        }
    }
    return out;
}

func annotation_complexity_eval_expr_inner(src_ptr: u64, src_len: u64, pos: *u64, constraints_ann: *CompilerAnnotationParsed, fallback_bound: u64, ok: *u64) -> u64 {
    var cap: u64 = 9223372036854775807;
    var out: u64 = annotation_complexity_eval_term_inner(src_ptr, src_len, pos, constraints_ann, fallback_bound, ok);
    if (ok == 0 || *ok == 0) { return 0; }
    var s: []u8 = slice(src_ptr, src_len);
    while (*pos < src_len && (s[*pos] == 43 || s[*pos] == 45)) { // '+' or '-'
        var op: u8 = s[*pos];
        *pos = *pos + 1;
        var rhs: u64 = annotation_complexity_eval_term_inner(src_ptr, src_len, pos, constraints_ann, fallback_bound, ok);
        if (*ok == 0) { return 0; }
        if (op == 43) {
            out = annotation_complexity_sat_add(out, rhs, cap);
        } else {
            if (out > rhs) { out = out - rhs; }
            else { out = 0; }
        }
    }
    return out;
}

func annotation_complexity_eval_o_expr_ops(expr_ptr: u64, expr_len: u64, constraints_ann: *CompilerAnnotationParsed, out_ok: *u64) -> u64 {
    if (out_ok == 0) { return 0; }
    *out_ok = 0;
    if (annotation_complexity_is_valid_o_string(expr_ptr, expr_len) == 0) { return 0; }
    var norm: *NameInfo = annotation_complexity_normalize(expr_ptr, expr_len);
    if (norm == 0 || norm.len < 4) { return 0; }
    if (norm.ptr == 0 || norm.len < 4) { return 0; }
    // "o(...)" -> evaluate inside.
    var inner_ptr: u64 = norm.ptr + 2;
    var inner_len: u64 = norm.len - 3;
    var pos: u64 = 0;
    var ok: u64 = 1;
    var fallback_bound: u64 = annotation_complexity_constraints_max(constraints_ann);
    var out: u64 = annotation_complexity_eval_expr_inner(inner_ptr, inner_len, &pos, constraints_ann, fallback_bound, &ok);
    if (ok == 0 || pos != inner_len) { return 0; }
    *out_ok = 1;
    return out;
}

func annotation_complexity_constraints_is_relation_key(key_ptr: u64, key_len: u64) -> u64 {
    if (key_ptr == 0 || key_len == 0) { return 0; }
    if (str_eq(key_ptr, key_len, "where", 5) != 0) { return 1; }
    if (str_eq(key_ptr, key_len, "relation", 8) != 0) { return 1; }
    if (str_eq(key_ptr, key_len, "assume", 6) != 0) { return 1; }
    if (key_len >= 3 && str_eq(key_ptr, 3, "rel", 3) != 0) { return 1; }
    return 0;
}

func annotation_complexity_constraints_int_only(constraints_ann: *CompilerAnnotationParsed) -> *CompilerAnnotationParsed {
    var out: *CompilerAnnotationParsed = new CompilerAnnotationParsed();
    out.parse_ok = 1;
    out.args_vec = new Vec<*CompilerAnnotationArg>(0);
    if (constraints_ann == 0 || constraints_ann.args_vec == 0) { return out; }
    var n: u64 = constraints_ann.args_vec.len();
    for (var i: u64 = 0; i < n; i++) {
        var a: *CompilerAnnotationArg = constraints_ann.args_vec.get(i);
        if (a == 0 || a.kind != 2 || a.key_ptr == 0 || a.key_len == 0) { continue; }
        var b: *CompilerAnnotationArg = new CompilerAnnotationArg();
        b.key_ptr = a.key_ptr;
        b.key_len = a.key_len;
        b.kind = 2;
        b.int_value = a.int_value;
        out.args_vec.push(b);
    }
    return out;
}

func annotation_complexity_constraints_upsert_int(constraints_ann: *CompilerAnnotationParsed, key_ptr: u64, key_len: u64, value: u64) -> u64 {
    if (constraints_ann == 0 || constraints_ann.args_vec == 0 || key_ptr == 0 || key_len == 0) { return 0; }
    var n: u64 = constraints_ann.args_vec.len();
    for (var i: u64 = 0; i < n; i++) {
        var a: *CompilerAnnotationArg = constraints_ann.args_vec.get(i);
        if (a == 0 || a.kind != 2 || a.key_ptr == 0 || a.key_len == 0) { continue; }
        if (str_eq(a.key_ptr, a.key_len, key_ptr, key_len) == 0) { continue; }
        if (value < a.int_value) {
            a.int_value = value;
            return 1;
        }
        return 0;
    }
    var b: *CompilerAnnotationArg = new CompilerAnnotationArg();
    b.key_ptr = key_ptr;
    b.key_len = key_len;
    b.kind = 2;
    b.int_value = value;
    constraints_ann.args_vec.push(b);
    return 1;
}

func annotation_complexity_parse_relation_spec(spec_ptr: u64, spec_len: u64, out_lhs_ptr: *u64, out_lhs_len: *u64, out_rhs_ptr: *u64, out_rhs_len: *u64, out_op: *u64) -> u64 {
    // out_op: 1 <=, 2 <, 3 >=, 4 >, 5 ==
    if (spec_ptr == 0 || spec_len == 0 || out_lhs_ptr == 0 || out_lhs_len == 0 || out_rhs_ptr == 0 || out_rhs_len == 0 || out_op == 0) { return 0; }
    var norm: *NameInfo = annotation_complexity_normalize(spec_ptr, spec_len);
    if (norm == 0 || norm.ptr == 0 || norm.len < 3) { return 0; }
    var s: []u8 = slice(norm.ptr, norm.len);
    var op_pos: u64 = norm.len;
    var op_code: u64 = 0;
    var op_w: u64 = 0;
    for (var i: u64 = 0; i < norm.len; i++) {
        if (s[i] == 60) { // '<'
            op_pos = i;
            op_w = 1;
            op_code = 2;
            if (i + 1 < norm.len && s[i + 1] == 61) { op_w = 2; op_code = 1; }
            break;
        }
        if (s[i] == 62) { // '>'
            op_pos = i;
            op_w = 1;
            op_code = 4;
            if (i + 1 < norm.len && s[i + 1] == 61) { op_w = 2; op_code = 3; }
            break;
        }
        if (s[i] == 61) { // '='
            op_pos = i;
            op_w = 1;
            op_code = 5;
            if (i + 1 < norm.len && s[i + 1] == 61) { op_w = 2; op_code = 5; }
            break;
        }
    }
    if (op_code == 0 || op_pos == 0 || op_pos + op_w >= norm.len) { return 0; }
    var lhs_ptr: u64 = norm.ptr;
    var lhs_len: u64 = op_pos;
    if (annotation_complexity_is_ident_token(lhs_ptr, lhs_len) == 0) { return 0; }
    var rhs_ptr: u64 = norm.ptr + op_pos + op_w;
    var rhs_len: u64 = norm.len - (op_pos + op_w);
    if (rhs_len == 0) { return 0; }
    annotation_complexity_trim_outer_parens(rhs_ptr, rhs_len, &rhs_ptr, &rhs_len);
    if (rhs_len == 0) { return 0; }
    *out_lhs_ptr = lhs_ptr;
    *out_lhs_len = lhs_len;
    *out_rhs_ptr = rhs_ptr;
    *out_rhs_len = rhs_len;
    *out_op = op_code;
    return 1;
}

func annotation_complexity_parse_relation_op_from(src_ptr: u64, src_len: u64, pos: u64, out_op: *u64, out_w: *u64) -> u64 {
    if (src_ptr == 0 || src_len == 0 || pos >= src_len || out_op == 0 || out_w == 0) { return 0; }
    var s: []u8 = slice(src_ptr, src_len);
    if (s[pos] == 60) { // <
        *out_op = 2;
        *out_w = 1;
        if (pos + 1 < src_len && s[pos + 1] == 61) { *out_op = 1; *out_w = 2; }
        return 1;
    }
    if (s[pos] == 62) { // >
        *out_op = 4;
        *out_w = 1;
        if (pos + 1 < src_len && s[pos + 1] == 61) { *out_op = 3; *out_w = 2; }
        return 1;
    }
    if (s[pos] == 61) { // =
        *out_op = 5;
        *out_w = 1;
        if (pos + 1 < src_len && s[pos + 1] == 61) { *out_w = 2; }
        return 1;
    }
    return 0;
}

func annotation_complexity_find_relation_op(src_ptr: u64, src_len: u64, start: u64, out_pos: *u64, out_op: *u64, out_w: *u64) -> u64 {
    if (src_ptr == 0 || src_len == 0 || start >= src_len || out_pos == 0 || out_op == 0 || out_w == 0) { return 0; }
    var s: []u8 = slice(src_ptr, src_len);
    var depth: u64 = 0;
    for (var i: u64 = start; i < src_len; i = i + 1) {
        var ch: u64 = s[i];
        if (ch == 40) { // '('
            depth = depth + 1;
            continue;
        }
        if (ch == 41) { // ')'
            if (depth > 0) { depth = depth - 1; }
            continue;
        }
        if (depth != 0) { continue; }
        var op: u64 = 0;
        var w: u64 = 0;
        if (annotation_complexity_parse_relation_op_from(src_ptr, src_len, i, &op, &w) != 0) {
            *out_pos = i;
            *out_op = op;
            *out_w = w;
            return 1;
        }
    }
    return 0;
}

func annotation_complexity_apply_relation_step(known: *CompilerAnnotationParsed, lhs_ptr0: u64, lhs_len0: u64, rhs_ptr0: u64, rhs_len0: u64, op0: u64, out_changed: *u64) -> u64 {
    if (known == 0 || known.args_vec == 0) { return 0; }
    if (lhs_ptr0 == 0 || lhs_len0 == 0 || rhs_ptr0 == 0 || rhs_len0 == 0) { return 0; }
    if (out_changed != 0) { *out_changed = 0; }

    var lhs_ptr: u64 = lhs_ptr0;
    var lhs_len: u64 = lhs_len0;
    var rhs_ptr: u64 = rhs_ptr0;
    var rhs_len: u64 = rhs_len0;
    annotation_complexity_trim_outer_parens(lhs_ptr, lhs_len, &lhs_ptr, &lhs_len);
    annotation_complexity_trim_outer_parens(rhs_ptr, rhs_len, &rhs_ptr, &rhs_len);
    if (lhs_len == 0 || rhs_len == 0) { return 0; }

    var op: u64 = op0;
    var lhs_ident: u64 = annotation_complexity_is_ident_token(lhs_ptr, lhs_len);
    var rhs_ident: u64 = annotation_complexity_is_ident_token(rhs_ptr, rhs_len);

    // Canonicalize `const <= x` / `expr < x` / `expr = x` into identifier-on-left form.
    if ((op == 1 || op == 2 || op == 5) && lhs_ident == 0 && rhs_ident != 0) {
        var tp: u64 = lhs_ptr;
        var tl: u64 = lhs_len;
        lhs_ptr = rhs_ptr;
        lhs_len = rhs_len;
        rhs_ptr = tp;
        rhs_len = tl;
        if (op == 1) { op = 3; }
        else if (op == 2) { op = 4; }
        lhs_ident = 1;
        rhs_ident = annotation_complexity_is_ident_token(rhs_ptr, rhs_len);
    }

    var candidate: u64 = 0;
    var candidate_ok: u64 = 0;
    if (op == 1 || op == 2) {
        if (lhs_ident == 0) { return 1; }
        candidate = annotation_complexity_eval_raw_expr_ops(rhs_ptr, rhs_len, known, &candidate_ok);
        if (candidate_ok != 0 && op == 2 && candidate > 0) { candidate = candidate - 1; }
        if (candidate_ok != 0 && annotation_complexity_constraints_upsert_int(known, lhs_ptr, lhs_len, candidate) != 0) {
            if (out_changed != 0) { *out_changed = 1; }
        }
        return 1;
    }
    if (op == 3 || op == 4) {
        if (rhs_ident == 0) { return 1; }
        candidate = annotation_complexity_eval_raw_expr_ops(lhs_ptr, lhs_len, known, &candidate_ok);
        if (candidate_ok != 0 && op == 4 && candidate > 0) { candidate = candidate - 1; }
        if (candidate_ok != 0 && annotation_complexity_constraints_upsert_int(known, rhs_ptr, rhs_len, candidate) != 0) {
            if (out_changed != 0) { *out_changed = 1; }
        }
        return 1;
    }
    if (op == 5) {
        if (lhs_ident != 0) {
            candidate = annotation_complexity_eval_raw_expr_ops(rhs_ptr, rhs_len, known, &candidate_ok);
            if (candidate_ok != 0 && annotation_complexity_constraints_upsert_int(known, lhs_ptr, lhs_len, candidate) != 0) {
                if (out_changed != 0) { *out_changed = 1; }
            }
        }
        if (rhs_ident != 0) {
            var back: u64 = 0;
            var back_ok: u64 = 0;
            back = annotation_complexity_eval_raw_expr_ops(lhs_ptr, lhs_len, known, &back_ok);
            if (back_ok != 0 && annotation_complexity_constraints_upsert_int(known, rhs_ptr, rhs_len, back) != 0) {
                if (out_changed != 0) { *out_changed = 1; }
            }
        }
        return 1;
    }
    return 0;
}

func annotation_complexity_apply_relation_spec(known: *CompilerAnnotationParsed, spec_ptr: u64, spec_len: u64, out_changed: *u64) -> u64 {
    if (out_changed != 0) { *out_changed = 0; }
    if (known == 0 || known.args_vec == 0 || spec_ptr == 0 || spec_len == 0) { return 0; }
    var norm: *NameInfo = annotation_complexity_normalize(spec_ptr, spec_len);
    if (norm == 0 || norm.ptr == 0 || norm.len < 3) { return 0; }

    var first_pos: u64 = 0;
    var first_op: u64 = 0;
    var first_w: u64 = 0;
    if (annotation_complexity_find_relation_op(norm.ptr, norm.len, 0, &first_pos, &first_op, &first_w) == 0) { return 0; }

    var lhs_ptr: u64 = norm.ptr;
    var lhs_len: u64 = first_pos;
    annotation_complexity_trim_outer_parens(lhs_ptr, lhs_len, &lhs_ptr, &lhs_len);
    if (lhs_len == 0) { return 0; }

    var pos: u64 = first_pos;
    var pairs: u64 = 0;
    while (pos < norm.len) {
        var op: u64 = 0;
        var op_w: u64 = 0;
        if (annotation_complexity_parse_relation_op_from(norm.ptr, norm.len, pos, &op, &op_w) == 0) { return 0; }
        var rhs_start: u64 = pos + op_w;
        if (rhs_start >= norm.len) { return 0; }

        var next_pos: u64 = 0;
        var next_op: u64 = 0;
        var next_w: u64 = 0;
        var has_next: u64 = annotation_complexity_find_relation_op(norm.ptr, norm.len, rhs_start, &next_pos, &next_op, &next_w);

        var rhs_ptr: u64 = norm.ptr + rhs_start;
        var rhs_len: u64 = 0;
        if (has_next != 0) { rhs_len = next_pos - rhs_start; }
        else { rhs_len = norm.len - rhs_start; }
        annotation_complexity_trim_outer_parens(rhs_ptr, rhs_len, &rhs_ptr, &rhs_len);
        if (rhs_len == 0) { return 0; }

        var local_changed: u64 = 0;
        if (annotation_complexity_apply_relation_step(known, lhs_ptr, lhs_len, rhs_ptr, rhs_len, op, &local_changed) == 0) { return 0; }
        if (local_changed != 0 && out_changed != 0) { *out_changed = 1; }
        pairs = pairs + 1;

        if (has_next == 0) { break; }
        lhs_ptr = rhs_ptr;
        lhs_len = rhs_len;
        pos = next_pos;
    }
    return pairs != 0;
}

func annotation_complexity_eval_raw_expr_ops(expr_ptr: u64, expr_len: u64, constraints_ann: *CompilerAnnotationParsed, out_ok: *u64) -> u64 {

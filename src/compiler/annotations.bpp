            if (nref.call_ptr.args_vec != 0) {
                var pn: u64 = nref.call_ptr.args_vec.len();
                for (var pi: u64 = 0; pi < pn; pi++) {
                    if (annotation_complexity_expr_has_call_name(nref.call_ptr.args_vec.get(pi), needle_ptr, needle_len) != 0) { return 1; }
                }
            }
            return 0;
        case AST_BINARY:
            if (annotation_complexity_expr_has_call_name(nref.binary.left, needle_ptr, needle_len) != 0) { return 1; }
            if (annotation_complexity_expr_has_call_name(nref.binary.right, needle_ptr, needle_len) != 0) { return 1; }
            return 0;
        case AST_UNARY:
            return annotation_complexity_expr_has_call_name(nref.unary.operand, needle_ptr, needle_len);
        case AST_INDEX:
        case AST_SAFE_INDEX:
            if (annotation_complexity_expr_has_call_name(nref.index_expr.base, needle_ptr, needle_len) != 0) { return 1; }
            if (annotation_complexity_expr_has_call_name(nref.index_expr.index, needle_ptr, needle_len) != 0) { return 1; }
            return 0;
        case AST_MEMBER_ACCESS:
        case AST_SAFE_MEMBER_ACCESS:
            return annotation_complexity_expr_has_call_name(nref.member_access.object, needle_ptr, needle_len);
        case AST_CAST:
            return annotation_complexity_expr_has_call_name(nref.cast_expr.expr, needle_ptr, needle_len);
        case AST_ADDR_OF:
            return annotation_complexity_expr_has_call_name(nref.addr_of.operand, needle_ptr, needle_len);
        case AST_DEREF:
            return annotation_complexity_expr_has_call_name(nref.deref.operand, needle_ptr, needle_len);
        case AST_DEREF8:
            return annotation_complexity_expr_has_call_name(nref.deref8.operand, needle_ptr, needle_len);
        case AST_TRY:
            return annotation_complexity_expr_has_call_name(nref.try_expr.operand, needle_ptr, needle_len);
        case AST_TERNARY:
            if (annotation_complexity_expr_has_call_name(nref.ternary_expr.cond, needle_ptr, needle_len) != 0) { return 1; }
            if (annotation_complexity_expr_has_call_name(nref.ternary_expr.then_expr, needle_ptr, needle_len) != 0) { return 1; }
            if (annotation_complexity_expr_has_call_name(nref.ternary_expr.else_expr, needle_ptr, needle_len) != 0) { return 1; }
            return 0;
    }
    return 0;
}

func annotation_complexity_expr_has_binary_op(expr: *AstNode, op: u64) -> u64 {
    if (expr == 0) { return 0; }
    var kind: u64 = ast_kind(expr);
    var nref: AstNodeTagRef;
    nref.node = expr;
    match (kind) {
        case AST_BINARY:
            if (nref.binary.op == op) { return 1; }
            if (annotation_complexity_expr_has_binary_op(nref.binary.left, op) != 0) { return 1; }
            if (annotation_complexity_expr_has_binary_op(nref.binary.right, op) != 0) { return 1; }
            return 0;
        case AST_UNARY:
            return annotation_complexity_expr_has_binary_op(nref.unary.operand, op);
        case AST_CALL:
            if (nref.call.args_vec != 0) {
                var an: u64 = nref.call.args_vec.len();
                for (var i: u64 = 0; i < an; i++) {
                    if (annotation_complexity_expr_has_binary_op(nref.call.args_vec.get(i), op) != 0) { return 1; }
                }
            }
            return 0;
        case AST_METHOD_CALL:
        case AST_SAFE_METHOD_CALL:
            if (annotation_complexity_expr_has_binary_op(nref.method_call.receiver, op) != 0) { return 1; }
            if (nref.method_call.args_vec != 0) {
                var mn: u64 = nref.method_call.args_vec.len();
                for (var mi: u64 = 0; mi < mn; mi++) {
                    if (annotation_complexity_expr_has_binary_op(nref.method_call.args_vec.get(mi), op) != 0) { return 1; }
                }
            }
            return 0;
        case AST_CALL_PTR:
            if (annotation_complexity_expr_has_binary_op(nref.call_ptr.callee, op) != 0) { return 1; }
            if (nref.call_ptr.args_vec != 0) {
                var pn: u64 = nref.call_ptr.args_vec.len();
                for (var pi: u64 = 0; pi < pn; pi++) {
                    if (annotation_complexity_expr_has_binary_op(nref.call_ptr.args_vec.get(pi), op) != 0) { return 1; }
                }
            }
            return 0;
        case AST_INDEX:
        case AST_SAFE_INDEX:
            if (annotation_complexity_expr_has_binary_op(nref.index_expr.base, op) != 0) { return 1; }
            if (annotation_complexity_expr_has_binary_op(nref.index_expr.index, op) != 0) { return 1; }
            return 0;
        case AST_MEMBER_ACCESS:
        case AST_SAFE_MEMBER_ACCESS:
            return annotation_complexity_expr_has_binary_op(nref.member_access.object, op);
        case AST_CAST:
            return annotation_complexity_expr_has_binary_op(nref.cast_expr.expr, op);
        case AST_ADDR_OF:
            return annotation_complexity_expr_has_binary_op(nref.addr_of.operand, op);
        case AST_DEREF:
            return annotation_complexity_expr_has_binary_op(nref.deref.operand, op);
        case AST_DEREF8:
            return annotation_complexity_expr_has_binary_op(nref.deref8.operand, op);
        case AST_TRY:
            return annotation_complexity_expr_has_binary_op(nref.try_expr.operand, op);
        case AST_TERNARY:
            if (annotation_complexity_expr_has_binary_op(nref.ternary_expr.cond, op) != 0) { return 1; }
            if (annotation_complexity_expr_has_binary_op(nref.ternary_expr.then_expr, op) != 0) { return 1; }
            if (annotation_complexity_expr_has_binary_op(nref.ternary_expr.else_expr, op) != 0) { return 1; }
            return 0;
    }
    return 0;
}

func annotation_complexity_stmt_has_call_name(stmt: *AstNode, needle_ptr: u64, needle_len: u64) -> u64 {
    if (stmt == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    match (kind) {
        case AST_BLOCK:
            var blk: *AstBlock = (*AstBlock)stmt;
            if (blk.stmts_vec != 0) {
                var bn: u64 = blk.stmts_vec.len();
                for (var bi: u64 = 0; bi < bn; bi++) {
                    if (annotation_complexity_stmt_has_call_name(blk.stmts_vec.get(bi), needle_ptr, needle_len) != 0) { return 1; }
                }
            }
            return 0;
        case AST_IF:
            var ifs: *AstIf = (*AstIf)stmt;
            if (annotation_complexity_expr_has_call_name(ifs.cond, needle_ptr, needle_len) != 0) { return 1; }
            if (annotation_complexity_stmt_has_call_name(ifs.then_block, needle_ptr, needle_len) != 0) { return 1; }
            return annotation_complexity_stmt_has_call_name(ifs.else_block, needle_ptr, needle_len);
        case AST_WHILE:
            var wl: *AstWhile = (*AstWhile)stmt;
            if (annotation_complexity_expr_has_call_name(wl.cond, needle_ptr, needle_len) != 0) { return 1; }
            return annotation_complexity_stmt_has_call_name(wl.body, needle_ptr, needle_len);
        case AST_FOR:
            var fr: *AstFor = (*AstFor)stmt;
            if (annotation_complexity_stmt_has_call_name(fr.init, needle_ptr, needle_len) != 0) { return 1; }
            if (annotation_complexity_expr_has_call_name(fr.cond, needle_ptr, needle_len) != 0) { return 1; }
            if (annotation_complexity_expr_has_call_name(fr.update, needle_ptr, needle_len) != 0) { return 1; }
            return annotation_complexity_stmt_has_call_name(fr.body, needle_ptr, needle_len);
        case AST_DO_WHILE:
            var dw: *AstDoWhile = (*AstDoWhile)stmt;
            if (annotation_complexity_stmt_has_call_name(dw.body, needle_ptr, needle_len) != 0) { return 1; }
            return annotation_complexity_expr_has_call_name(dw.cond, needle_ptr, needle_len);
        case AST_SWITCH:
        case AST_MATCH:
            var sw: *AstSwitch = (*AstSwitch)stmt;
            if (annotation_complexity_expr_has_call_name(sw.expr, needle_ptr, needle_len) != 0) { return 1; }
            if (sw.cases_vec != 0) {
                var cn: u64 = sw.cases_vec.len();
                for (var ci: u64 = 0; ci < cn; ci++) {
                    if (annotation_complexity_stmt_has_call_name(sw.cases_vec.get(ci), needle_ptr, needle_len) != 0) { return 1; }
                }
            }
            return 0;
        case AST_CASE:
            var cs: *AstCase = (*AstCase)stmt;
            if (annotation_complexity_expr_has_call_name(cs.value, needle_ptr, needle_len) != 0) { return 1; }
            return annotation_complexity_stmt_has_call_name(cs.body, needle_ptr, needle_len);
        case AST_DEFER:
            return annotation_complexity_stmt_has_call_name(((*AstDefer)stmt).stmt, needle_ptr, needle_len);
        case AST_VAR_DECL:
            return annotation_complexity_expr_has_call_name(((*AstVarDecl)stmt).init_expr, needle_ptr, needle_len);
        case AST_ASSIGN:
            var asn: *AstAssign = (*AstAssign)stmt;
            if (annotation_complexity_expr_has_call_name(asn.target, needle_ptr, needle_len) != 0) { return 1; }
            return annotation_complexity_expr_has_call_name(asn.value, needle_ptr, needle_len);
        case AST_EXPR_STMT:
            return annotation_complexity_expr_has_call_name(((*AstExprStmt)stmt).expr, needle_ptr, needle_len);
        case AST_RETURN:
            return annotation_complexity_expr_has_call_name(((*AstReturn)stmt).expr, needle_ptr, needle_len);
        case AST_DELETE:
            return annotation_complexity_expr_has_call_name(((*AstDelete)stmt).expr, needle_ptr, needle_len);
        case AST_THROW_STMT:
            return annotation_complexity_expr_has_call_name(((*AstThrowStmt)stmt).expr, needle_ptr, needle_len);
    }
    return 0;
}

func annotation_complexity_stmt_has_binary_op(stmt: *AstNode, op: u64) -> u64 {
    if (stmt == 0) { return 0; }

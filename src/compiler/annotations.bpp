func annotation_complexity_name_matches_symbol(name_ptr: u64, name_len: u64, needle_ptr: u64, needle_len: u64) -> u64 {
    if (name_ptr == 0 || name_len == 0 || needle_ptr == 0 || needle_len == 0) { return 0; }
    if (str_eq(name_ptr, name_len, needle_ptr, needle_len) != 0) { return 1; }
    if (name_len < needle_len + 2) { return 0; }
    var off: u64 = name_len - needle_len;
    var full: []u8 = slice(name_ptr, name_len);
    if (full[off - 1] == 95 && full[off - 2] == 95 &&
        str_eq(name_ptr + off, needle_len, needle_ptr, needle_len) != 0) {
        return 1;
    }
    return 0;
}


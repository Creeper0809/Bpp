func annotation_complexity_stmt_assign_ident_from_call(stmt: *AstNode, id_ptr: u64, id_len: u64, call_name_ptr: u64, call_name_len: u64) -> u64 {
    if (stmt == 0 || id_ptr == 0 || id_len == 0 || call_name_ptr == 0 || call_name_len == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    if (kind == AST_BLOCK) {
        var blk: *AstBlock = (*AstBlock)stmt;
        if (blk.stmts_vec != 0) {
            var bn: u64 = blk.stmts_vec.len();
            for (var bi: u64 = 0; bi < bn; bi++) {
                if (annotation_complexity_stmt_assign_ident_from_call(blk.stmts_vec.get(bi), id_ptr, id_len, call_name_ptr, call_name_len) != 0) { return 1; }
            }
        }
        return 0;
    }
    if (kind == AST_IF) {
        var ifs: *AstIf = (*AstIf)stmt;
        if (annotation_complexity_stmt_assign_ident_from_call(ifs.then_block, id_ptr, id_len, call_name_ptr, call_name_len) != 0) { return 1; }
        return annotation_complexity_stmt_assign_ident_from_call(ifs.else_block, id_ptr, id_len, call_name_ptr, call_name_len);
    }
    if (kind == AST_WHILE) { return annotation_complexity_stmt_assign_ident_from_call(((*AstWhile)stmt).body, id_ptr, id_len, call_name_ptr, call_name_len); }
    if (kind == AST_FOR) { return annotation_complexity_stmt_assign_ident_from_call(((*AstFor)stmt).body, id_ptr, id_len, call_name_ptr, call_name_len); }
    if (kind == AST_DO_WHILE) { return annotation_complexity_stmt_assign_ident_from_call(((*AstDoWhile)stmt).body, id_ptr, id_len, call_name_ptr, call_name_len); }
    if (kind == AST_CASE) { return annotation_complexity_stmt_assign_ident_from_call(((*AstCase)stmt).body, id_ptr, id_len, call_name_ptr, call_name_len); }
    if (kind == AST_DEFER) { return annotation_complexity_stmt_assign_ident_from_call(((*AstDefer)stmt).stmt, id_ptr, id_len, call_name_ptr, call_name_len); }
    if (kind == AST_SWITCH || kind == AST_MATCH) {
        var sw: *AstSwitch = (*AstSwitch)stmt;
        if (sw.cases_vec != 0) {
            var cn: u64 = sw.cases_vec.len();
            for (var ci: u64 = 0; ci < cn; ci++) {
                if (annotation_complexity_stmt_assign_ident_from_call(sw.cases_vec.get(ci), id_ptr, id_len, call_name_ptr, call_name_len) != 0) { return 1; }
            }
        }
        return 0;
    }
    if (kind != AST_ASSIGN) { return 0; }
    var asn: *AstAssign = (*AstAssign)stmt;
    if (annotation_complexity_expr_is_ident(asn.target, id_ptr, id_len) == 0) { return 0; }
    if (annotation_complexity_expr_has_call_name(asn.value, call_name_ptr, call_name_len) != 0) { return 1; }
    return 0;
}

func annotation_complexity_stmt_count_self_recurrent_assign(stmt: *AstNode) -> u64 {
    if (stmt == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    if (kind == AST_BLOCK) {
        var blk: *AstBlock = (*AstBlock)stmt;
        var sum: u64 = 0;
        if (blk.stmts_vec != 0) {
            var bn: u64 = blk.stmts_vec.len();
            for (var bi: u64 = 0; bi < bn; bi++) {
                sum = sum + annotation_complexity_stmt_count_self_recurrent_assign(blk.stmts_vec.get(bi));
            }
        }
        return sum;
    }
    if (kind == AST_IF) {
        var ifs: *AstIf = (*AstIf)stmt;
        var a: u64 = annotation_complexity_stmt_count_self_recurrent_assign(ifs.then_block);
        var b: u64 = annotation_complexity_stmt_count_self_recurrent_assign(ifs.else_block);
        if (a > b) { return a; }
        return b;
    }
    if (kind == AST_WHILE) { return annotation_complexity_stmt_count_self_recurrent_assign(((*AstWhile)stmt).body); }
    if (kind == AST_FOR) { return annotation_complexity_stmt_count_self_recurrent_assign(((*AstFor)stmt).body); }
    if (kind == AST_DO_WHILE) { return annotation_complexity_stmt_count_self_recurrent_assign(((*AstDoWhile)stmt).body); }
    if (kind == AST_CASE) { return annotation_complexity_stmt_count_self_recurrent_assign(((*AstCase)stmt).body); }
    if (kind == AST_DEFER) { return annotation_complexity_stmt_count_self_recurrent_assign(((*AstDefer)stmt).stmt); }
    if (kind == AST_SWITCH || kind == AST_MATCH) {
        var sw: *AstSwitch = (*AstSwitch)stmt;
        var best: u64 = 0;
        if (sw.cases_vec != 0) {
            var cn: u64 = sw.cases_vec.len();
            for (var ci: u64 = 0; ci < cn; ci++) {
                var c: u64 = annotation_complexity_stmt_count_self_recurrent_assign(sw.cases_vec.get(ci));
                if (c > best) { best = c; }
            }
        }
        return best;
    }
    if (kind != AST_ASSIGN) { return 0; }
    var asn: *AstAssign = (*AstAssign)stmt;
    if (asn.target == 0 || asn.value == 0 || ast_kind(asn.target) != AST_IDENT) { return 0; }
    var id: *AstIdent = (*AstIdent)asn.target;
    if (annotation_complexity_expr_contains_ident(asn.value, id.name_ptr, id.name_len) != 0) { return 1; }
    return 0;
}

func annotation_complexity_cond_eq_one_ident(cond: *AstNode, out_id_ptr: *u64, out_id_len: *u64) -> u64 {
    if (cond == 0 || out_id_ptr == 0 || out_id_len == 0) { return 0; }
    if (ast_kind(cond) != AST_BINARY) { return 0; }
    var b: *AstBinary = (*AstBinary)cond;
    if (b.op != TOKEN_EQEQ) { return 0; }
    var lit: u64 = 0;
    if (b.left != 0 && ast_kind(b.left) == AST_IDENT && annotation_complexity_expr_literal_u64(b.right, &lit) != 0 && lit == 1) {
        var li: *AstIdent = (*AstIdent)b.left;
        *out_id_ptr = li.name_ptr;
        *out_id_len = li.name_len;
        return 1;
    }
    if (b.right != 0 && ast_kind(b.right) == AST_IDENT && annotation_complexity_expr_literal_u64(b.left, &lit) != 0 && lit == 1) {
        var ri: *AstIdent = (*AstIdent)b.right;
        *out_id_ptr = ri.name_ptr;
        *out_id_len = ri.name_len;
        return 1;
    }
    return 0;
}

func annotation_complexity_is_pollard_rho_like_while(wl: *AstWhile) -> u64 {
    if (wl == 0 || wl.cond == 0 || wl.body == 0) { return 0; }
    var d_ptr: u64 = 0;
    var d_len: u64 = 0;
    if (annotation_complexity_cond_eq_one_ident(wl.cond, &d_ptr, &d_len) == 0) { return 0; }
    if (annotation_complexity_stmt_assign_ident_from_call(wl.body, d_ptr, d_len, "gcd", 3) == 0) { return 0; }
    if (annotation_complexity_stmt_has_call_name(wl.body, "gcd", 3) == 0) { return 0; }
    if (annotation_complexity_stmt_count_self_recurrent_assign(wl.body) < 3) { return 0; }
    return 1;
}

func annotation_complexity_has_pollard_rho_like_pattern_stmt(stmt: *AstNode) -> u64 {
    if (stmt == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    var nref: AstNodeTagRef;
    nref.node = stmt;
    match (kind) {
        case AST_BLOCK:
            if (nref.block_stmt.stmts_vec != 0) {
                var bn: u64 = nref.block_stmt.stmts_vec.len();
                for (var bi: u64 = 0; bi < bn; bi++) {
                    if (annotation_complexity_has_pollard_rho_like_pattern_stmt(nref.block_stmt.stmts_vec.get(bi)) != 0) { return 1; }
                }
            }
            return 0;
        case AST_WHILE:
            if (annotation_complexity_is_pollard_rho_like_while(nref.while_stmt) != 0) { return 1; }
            return annotation_complexity_has_pollard_rho_like_pattern_stmt(nref.while_stmt.body);
        case AST_FOR:
            if (annotation_complexity_has_pollard_rho_like_pattern_stmt(nref.for_stmt.init) != 0) { return 1; }
            return annotation_complexity_has_pollard_rho_like_pattern_stmt(nref.for_stmt.body);
        case AST_DO_WHILE:
            return annotation_complexity_has_pollard_rho_like_pattern_stmt(nref.do_while_stmt.body);
        case AST_IF:
            if (annotation_complexity_has_pollard_rho_like_pattern_stmt(nref.if_stmt.then_block) != 0) { return 1; }
            return annotation_complexity_has_pollard_rho_like_pattern_stmt(nref.if_stmt.else_block);
        case AST_SWITCH:
        case AST_MATCH:
            if (nref.switch_stmt.cases_vec != 0) {
                var cn: u64 = nref.switch_stmt.cases_vec.len();
                for (var ci: u64 = 0; ci < cn; ci++) {
                    if (annotation_complexity_has_pollard_rho_like_pattern_stmt(nref.switch_stmt.cases_vec.get(ci)) != 0) { return 1; }
                }
            }
            return 0;
        case AST_CASE:
            return annotation_complexity_has_pollard_rho_like_pattern_stmt(nref.case_stmt.body);
        case AST_DEFER:
            return annotation_complexity_has_pollard_rho_like_pattern_stmt(nref.defer_stmt.stmt);
    }
    return 0;
}

const ANN_COMPLEXITY_REASON_UNKNOWN = 0;
const ANN_COMPLEXITY_REASON_POLLARD = 1;
const ANN_COMPLEXITY_REASON_SIEVE = 2;
const ANN_COMPLEXITY_REASON_RECURRENCE = 3;
const ANN_COMPLEXITY_REASON_STRUCTURAL = 4;
const ANN_COMPLEXITY_REASON_DEPTH_FALLBACK = 5;
const ANN_COMPLEXITY_REASON_DP_MEMO = 6;
const ANN_COMPLEXITY_REASON_DP_MEMO_HINT = 7;
const ANN_COMPLEXITY_REASON_INTERPROC = 8;
const ANN_COMPLEXITY_REASON_SSA_SYMBOLIC = 9;

func annotation_complexity_reason_name(reason: u64) -> u64 {
    match (reason) {
        case ANN_COMPLEXITY_REASON_POLLARD: return "pollard_pattern";
        case ANN_COMPLEXITY_REASON_SIEVE: return "sieve_pattern";
        case ANN_COMPLEXITY_REASON_RECURRENCE: return "recurrence_heuristic";
        case ANN_COMPLEXITY_REASON_STRUCTURAL: return "loop_structural";
        case ANN_COMPLEXITY_REASON_DEPTH_FALLBACK: return "depth_fallback";
        case ANN_COMPLEXITY_REASON_DP_MEMO: return "dp_memo_pattern";
        case ANN_COMPLEXITY_REASON_DP_MEMO_HINT: return "dp_memo_hint";
        case ANN_COMPLEXITY_REASON_INTERPROC: return "interproc_summary";
        case ANN_COMPLEXITY_REASON_SSA_SYMBOLIC: return "ssa_symbolic";
    }
    return "unknown";
}

const ANN_COMPLEXITY_CONF_UNKNOWN = 0;
const ANN_COMPLEXITY_CONF_PROVEN = 1;
const ANN_COMPLEXITY_CONF_HEURISTIC = 2;

func annotation_complexity_confidence_name(conf: u64) -> u64 {
    match (conf) {
        case ANN_COMPLEXITY_CONF_PROVEN: return "proven";
        case ANN_COMPLEXITY_CONF_HEURISTIC: return "heuristic";
    }
    return "unknown";
}

func annotation_complexity_ssa_block_dominates(dom: *SSABlock, node: *SSABlock) -> u64 {
    if (dom == 0 || node == 0) { return 0; }
    var cur: *SSABlock = node;
    while (cur != 0) {
        if (cur == dom) { return 1; }
        cur = cur.dom_parent;
    }
    return 0;
}

func annotation_complexity_ssa_local_rank(loop_depth: u64, backedges: u64) -> u64 {
    if (backedges == 0) { return 1; }
    if (loop_depth <= 1) { return 3; }
    if (loop_depth == 2) { return 5; }
    return 6;
}

func annotation_complexity_ssa_collect_call(summary: *AnnComplexitySSASummary, inst: *SSAInstruction) -> u64 {
    if (summary == 0 || inst == 0) { return 0; }
    var op: u64 = op_of(inst);
    if (op == SSA_OP_CALL) {
        summary.call_count = summary.call_count + 1;
        if (operand_is_const(inst.src1) == 0) {
            summary.unresolved_calls = summary.unresolved_calls + 1;
            return 0;
        }
        var ci: *SSACallInfo = (*SSACallInfo)operand_value(inst.src1);
        if (ci == 0 || ci.name_ptr == 0 || ci.name_len == 0) {
            summary.unresolved_calls = summary.unresolved_calls + 1;
            return 0;
        }
        if (annotation_complexity_name_matches_self_call(ci.name_ptr, ci.name_len, summary.fn_ptr, summary.fn_len) != 0) {
            summary.self_calls = summary.self_calls + 1;
        } else {
            summary.unresolved_calls = summary.unresolved_calls + 1;
        }
        return 0;
    }
    if (op == SSA_OP_CALL_PTR) {
        summary.call_count = summary.call_count + 1;
        summary.call_ptr_count = summary.call_ptr_count + 1;
        summary.unresolved_calls = summary.unresolved_calls + 1;
        return 0;
    }
    if (op == SSA_OP_CALL_SLICE_STORE) {
        summary.call_count = summary.call_count + 1;
        if (operand_is_const(inst.src1) == 0) {
            summary.unresolved_calls = summary.unresolved_calls + 1;
            return 0;
        }
        var si: *SSACallSliceStoreInfo = (*SSACallSliceStoreInfo)operand_value(inst.src1);
        if (si == 0) {
            summary.unresolved_calls = summary.unresolved_calls + 1;
            return 0;
        }
        if (si.is_ptr != 0) {
            summary.call_ptr_count = summary.call_ptr_count + 1;
            summary.unresolved_calls = summary.unresolved_calls + 1;
            return 0;
        }
        if (si.name_ptr == 0 || si.name_len == 0) {
            summary.unresolved_calls = summary.unresolved_calls + 1;
            return 0;
        }
        if (annotation_complexity_name_matches_self_call(si.name_ptr, si.name_len, summary.fn_ptr, summary.fn_len) != 0) {
            summary.self_calls = summary.self_calls + 1;
        } else {
            summary.unresolved_calls = summary.unresolved_calls + 1;
        }
        return 0;
    }
    return 0;
}

func annotation_complexity_ssa_build_summary(ssa_fn: *SSAFunction) -> *AnnComplexitySSASummary {
    if (ssa_fn == 0) { return 0; }
    var summary: *AnnComplexitySSASummary = new AnnComplexitySSASummary();
    summary.fn_ptr = ssa_fn.name_ptr;
    summary.fn_len = ssa_fn.name_len;

    var blocks: []*SSABlock = ssa_fn.blocks;
    var bn: u64 = slice_len(blocks);
    if (bn == 0) {
        summary.local_rank = 1;
        summary.total_rank = 1;
        summary.conf = ANN_COMPLEXITY_CONF_PROVEN;
        return summary;
    }

    var slots: u64 = ssa_fn.next_local_block_id + 1;
    if (slots < 4) { slots = 4; }
    var loop_header_flags: *u64 = (*u64)heap_alloc(slots * 8);
    for (var z: u64 = 0; z < slots; z = z + 1) { loop_header_flags[z] = 0; }

    for (var bi: u64 = 0; bi < bn; bi = bi + 1) {
        var b: *SSABlock = blocks[bi];
        if (b == 0) { continue; }
        var succs: []*SSABlock = b.succs;
        var sn: u64 = slice_len(succs);
        for (var si: u64 = 0; si < sn; si = si + 1) {
            var succ: *SSABlock = succs[si];
            if (succ == 0) { continue; }
            if (annotation_complexity_ssa_block_dominates(succ, b) != 0) {
                summary.backedge_count = summary.backedge_count + 1;
                if (succ.id < slots) { loop_header_flags[succ.id] = 1; }
            }
        }
    }

    var max_loop_depth: u64 = 0;
    for (var bj: u64 = 0; bj < bn; bj = bj + 1) {
        var cur_block: *SSABlock = blocks[bj];
        var depth: u64 = 0;
        while (cur_block != 0) {
            if (cur_block.id < slots && loop_header_flags[cur_block.id] != 0) {
                depth = depth + 1;
            }
            cur_block = cur_block.dom_parent;
        }
        if (depth > max_loop_depth) { max_loop_depth = depth; }
    }
    summary.loop_depth = max_loop_depth;

    for (var bk: u64 = 0; bk < bn; bk = bk + 1) {
        var bb: *SSABlock = blocks[bk];
        if (bb == 0) { continue; }
        var phi: *SSAInstruction = bb.phi_head;
        while (phi != 0) {
            summary.phi_count = summary.phi_count + 1;
            phi = phi.next;
        }
        var inst: *SSAInstruction = bb.inst_head;
        while (inst != 0) {
            annotation_complexity_ssa_collect_call(summary, inst);
            inst = inst.next;
        }
    }

    summary.local_rank = annotation_complexity_ssa_local_rank(summary.loop_depth, summary.backedge_count);
    summary.total_rank = summary.local_rank;
    if (summary.self_calls >= 2) { summary.total_rank = annotation_complexity_rank_pick_heavier(summary.total_rank, 7); }
    else if (summary.self_calls == 1) { summary.total_rank = annotation_complexity_rank_pick_heavier(summary.total_rank, 3); }
    if (summary.unresolved_calls != 0) { summary.conf = ANN_COMPLEXITY_CONF_UNKNOWN; }
    else if (summary.call_count == 0 && summary.backedge_count == 0) { summary.conf = ANN_COMPLEXITY_CONF_PROVEN; }
    else { summary.conf = ANN_COMPLEXITY_CONF_HEURISTIC; }
    return summary;
}

func annotation_complexity_ssa_prepare() -> u64 {
    if (g_complexity_ssa_summary_map == 0) {
        g_complexity_ssa_summary_map = new HashMap<u64, *AnnComplexitySSASummary>(128);
    }
    return 1;
}

func annotation_complexity_ssa_build_for_function(fn: *AstFunc) -> *AnnComplexitySSASummary {
    if (fn == 0 || fn.name_ptr == 0 || fn.name_len == 0 || fn.body == 0) { return 0; }
    var funcs: *Vec<*AstFunc> = new Vec<*AstFunc>(1);
    funcs.push(fn);
    var dummy_imports: *Vec<u64> = new Vec<u64>(1);
    var prog: *AstProgram = ast_program(funcs, g_compiler_ctx.all_consts, dummy_imports);
    prog.globals_vec = g_compiler_ctx.all_globals;
    prog.structs_vec = g_compiler_ctx.all_structs_vec;

    var ssa_ctx: *SSAContext = build_program(prog);
    if (ssa_ctx == 0) { return 0; }
    to_ssa(ssa_ctx);

    var ssa_funcs: []*SSAFunction = ssa_ctx.funcs;
    var sn: u64 = slice_len(ssa_funcs);
    for (var i: u64 = 0; i < sn; i = i + 1) {
        var sf: *SSAFunction = ssa_funcs[i];
        if (sf == 0 || sf.name_ptr == 0 || sf.name_len == 0) { continue; }
        if (str_eq(sf.name_ptr, sf.name_len, fn.name_ptr, fn.name_len) != 0) {
            return annotation_complexity_ssa_build_summary(sf);
        }
    }
    return 0;
}

func annotation_complexity_ssa_summary_for(fn: *AstFunc) -> *AnnComplexitySSASummary {
    if (fn == 0 || fn.name_ptr == 0 || fn.name_len == 0) { return 0; }
    if (annotation_complexity_ssa_prepare() == 0) { return 0; }
    if (g_complexity_ssa_summary_map == 0) { return 0; }
    var cached: *AnnComplexitySSASummary = g_complexity_ssa_summary_map.get(fn.name_ptr, fn.name_len);
    if (cached != 0) { return cached; }
    var built: *AnnComplexitySSASummary = annotation_complexity_ssa_build_for_function(fn);
    if (built != 0) {
        g_complexity_ssa_summary_map.put(fn.name_ptr, fn.name_len, built);
        return built;
    }
    return 0;
}

func annotation_complexity_ssa_infer_time_rank(fn: *AstFunc, out_conf: *u64) -> u64 {
    if (out_conf != 0) { *out_conf = ANN_COMPLEXITY_CONF_UNKNOWN; }
    var summary: *AnnComplexitySSASummary = annotation_complexity_ssa_summary_for(fn);
    if (summary == 0) { return 0; }
    if (out_conf != 0) { *out_conf = summary.conf; }
    return summary.total_rank;
}

func annotation_complexity_budget_slack_multiplier(mode: u64, conf: u64) -> u64 {
    if (conf == ANN_COMPLEXITY_CONF_PROVEN) {
        if (mode == ANN_COMPLEXITY_MODE_WORST || mode == ANN_COMPLEXITY_MODE_UNSPEC) { return 2; }
        if (mode == ANN_COMPLEXITY_MODE_HIGH_PROB) { return 2; }
        if (mode == ANN_COMPLEXITY_MODE_EXPECTED) { return 3; }
        if (mode == ANN_COMPLEXITY_MODE_AMORTIZED) { return 4; }
        return 3;
    }
    if (mode == ANN_COMPLEXITY_MODE_HIGH_PROB) { return 3; }
    if (mode == ANN_COMPLEXITY_MODE_EXPECTED) { return 4; }
    if (mode == ANN_COMPLEXITY_MODE_AMORTIZED) { return 5; }
    return 3;
}

func annotation_complexity_time_limit_slack_ppm(mode: u64, conf: u64) -> u64 {
    // parts-per-million multiplier
    if (conf == ANN_COMPLEXITY_CONF_PROVEN) {
        if (mode == ANN_COMPLEXITY_MODE_WORST || mode == ANN_COMPLEXITY_MODE_UNSPEC) { return 1100000; }
        if (mode == ANN_COMPLEXITY_MODE_HIGH_PROB) { return 1150000; }
        if (mode == ANN_COMPLEXITY_MODE_EXPECTED) { return 1200000; }
        if (mode == ANN_COMPLEXITY_MODE_AMORTIZED) { return 1300000; }
        return 1200000;
    }
    if (mode == ANN_COMPLEXITY_MODE_HIGH_PROB) { return 1300000; }
    if (mode == ANN_COMPLEXITY_MODE_EXPECTED) { return 1500000; }
    if (mode == ANN_COMPLEXITY_MODE_AMORTIZED) { return 1800000; }
    return 1300000;
}

func annotation_complexity_self_call_arg_pattern(arg_expr: *AstNode) -> u64 {
    // 1: divide/halve, 2: decrement, 3: same
    if (arg_expr == 0) { return 0; }
    if (ast_kind(arg_expr) == AST_IDENT) { return 3; }
    if (ast_kind(arg_expr) != AST_BINARY) { return 0; }
    var b: *AstBinary = (*AstBinary)arg_expr;
    if (b.left == 0 || b.right == 0) { return 0; }
    var lit: u64 = 0;
    if (b.op == TOKEN_SLASH && ast_kind(b.left) == AST_IDENT && annotation_complexity_expr_literal_u64(b.right, &lit) != 0 && lit >= 2) { return 1; }
    if (b.op == TOKEN_RSHIFT && ast_kind(b.left) == AST_IDENT && annotation_complexity_expr_literal_u64(b.right, &lit) != 0 && lit >= 1) { return 1; }
    if (b.op == TOKEN_MINUS && ast_kind(b.left) == AST_IDENT && annotation_complexity_expr_literal_u64(b.right, &lit) != 0 && lit >= 1) { return 2; }
    return 0;
}

func annotation_complexity_scan_expr_self_call_patterns(expr: *AstNode, fn_ptr: u64, fn_len: u64, out_total: *u64, out_half: *u64, out_minus: *u64, out_same: *u64) -> u64 {
    if (expr == 0 || out_total == 0 || out_half == 0 || out_minus == 0 || out_same == 0) { return 0; }
    var kind: u64 = ast_kind(expr);
    var nref: AstNodeTagRef;
    nref.node = expr;
    if (kind == AST_CALL) {
        if (annotation_complexity_name_matches_self_call(nref.call.name_ptr, nref.call.name_len, fn_ptr, fn_len) != 0) {
            *out_total = *out_total + 1;
            if (nref.call.args_vec != 0 && nref.call.args_vec.len() > 0) {
                var p: u64 = annotation_complexity_self_call_arg_pattern(nref.call.args_vec.get(0));
                if (p == 1) { *out_half = *out_half + 1; }
                else if (p == 2) { *out_minus = *out_minus + 1; }
                else if (p == 3) { *out_same = *out_same + 1; }
            }
        }
        if (nref.call.args_vec != 0) {
            var an: u64 = nref.call.args_vec.len();
            for (var i: u64 = 0; i < an; i++) {
                annotation_complexity_scan_expr_self_call_patterns(nref.call.args_vec.get(i), fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            }
        }
        return 0;
    }
    if (kind == AST_GENERIC_CALL) {
        if (annotation_complexity_name_matches_self_call(nref.generic_call.name_ptr, nref.generic_call.name_len, fn_ptr, fn_len) != 0) {
            *out_total = *out_total + 1;
            if (nref.generic_call.args_vec != 0 && nref.generic_call.args_vec.len() > 0) {
                var gp: u64 = annotation_complexity_self_call_arg_pattern(nref.generic_call.args_vec.get(0));
                if (gp == 1) { *out_half = *out_half + 1; }
                else if (gp == 2) { *out_minus = *out_minus + 1; }
                else if (gp == 3) { *out_same = *out_same + 1; }
            }
        }
        if (nref.generic_call.args_vec != 0) {
            var gn: u64 = nref.generic_call.args_vec.len();
            for (var gi: u64 = 0; gi < gn; gi++) {
                annotation_complexity_scan_expr_self_call_patterns(nref.generic_call.args_vec.get(gi), fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            }
        }
        return 0;
    }
    if (kind == AST_BINARY) {
        annotation_complexity_scan_expr_self_call_patterns(nref.binary.left, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
        annotation_complexity_scan_expr_self_call_patterns(nref.binary.right, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
        return 0;
    }
    if (kind == AST_UNARY) {
        annotation_complexity_scan_expr_self_call_patterns(nref.unary.operand, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
        return 0;
    }
    if (kind == AST_TERNARY) {
        annotation_complexity_scan_expr_self_call_patterns(nref.ternary_expr.cond, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
        annotation_complexity_scan_expr_self_call_patterns(nref.ternary_expr.then_expr, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
        annotation_complexity_scan_expr_self_call_patterns(nref.ternary_expr.else_expr, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
        return 0;
    }
    if (kind == AST_METHOD_CALL || kind == AST_SAFE_METHOD_CALL) {
        annotation_complexity_scan_expr_self_call_patterns(nref.method_call.receiver, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
        if (nref.method_call.args_vec != 0) {
            var mn: u64 = nref.method_call.args_vec.len();
            for (var mi: u64 = 0; mi < mn; mi++) {
                annotation_complexity_scan_expr_self_call_patterns(nref.method_call.args_vec.get(mi), fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            }
        }
        return 0;
    }
    if (kind == AST_CALL_PTR) {
        if (nref.call_ptr.callee != 0 && ast_kind(nref.call_ptr.callee) == AST_IDENT) {
            var cid: *AstIdent = (*AstIdent)nref.call_ptr.callee;
            if (annotation_complexity_name_matches_self_call(cid.name_ptr, cid.name_len, fn_ptr, fn_len) != 0) {
                *out_total = *out_total + 1;
                if (nref.call_ptr.args_vec != 0 && nref.call_ptr.args_vec.len() > 0) {
                    var pp: u64 = annotation_complexity_self_call_arg_pattern(nref.call_ptr.args_vec.get(0));
                    if (pp == 1) { *out_half = *out_half + 1; }
                    else if (pp == 2) { *out_minus = *out_minus + 1; }
                    else if (pp == 3) { *out_same = *out_same + 1; }
                }
            }
        }
        annotation_complexity_scan_expr_self_call_patterns(nref.call_ptr.callee, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
        if (nref.call_ptr.args_vec != 0) {
            var pn: u64 = nref.call_ptr.args_vec.len();
            for (var pi: u64 = 0; pi < pn; pi++) {
                annotation_complexity_scan_expr_self_call_patterns(nref.call_ptr.args_vec.get(pi), fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            }
        }
        return 0;
    }
    return 0;
}

func annotation_complexity_scan_stmt_self_call_patterns(stmt: *AstNode, fn_ptr: u64, fn_len: u64, out_total: *u64, out_half: *u64, out_minus: *u64, out_same: *u64) -> u64 {
    if (stmt == 0 || out_total == 0 || out_half == 0 || out_minus == 0 || out_same == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    match (kind) {
        case AST_BLOCK:
            var blk: *AstBlock = (*AstBlock)stmt;
            if (blk.stmts_vec != 0) {
                var bn: u64 = blk.stmts_vec.len();
                for (var bi: u64 = 0; bi < bn; bi++) {
                    annotation_complexity_scan_stmt_self_call_patterns(blk.stmts_vec.get(bi), fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
                }
            }
            return 0;
        case AST_IF:
            var ifs: *AstIf = (*AstIf)stmt;
            annotation_complexity_scan_expr_self_call_patterns(ifs.cond, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            annotation_complexity_scan_stmt_self_call_patterns(ifs.then_block, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            annotation_complexity_scan_stmt_self_call_patterns(ifs.else_block, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            return 0;
        case AST_WHILE:
            var wl: *AstWhile = (*AstWhile)stmt;
            annotation_complexity_scan_expr_self_call_patterns(wl.cond, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            annotation_complexity_scan_stmt_self_call_patterns(wl.body, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            return 0;
        case AST_FOR:
            var fr: *AstFor = (*AstFor)stmt;
            annotation_complexity_scan_stmt_self_call_patterns(fr.init, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            annotation_complexity_scan_expr_self_call_patterns(fr.cond, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            annotation_complexity_scan_expr_self_call_patterns(fr.update, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            annotation_complexity_scan_stmt_self_call_patterns(fr.body, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            return 0;
        case AST_DO_WHILE:
            var dw: *AstDoWhile = (*AstDoWhile)stmt;
            annotation_complexity_scan_stmt_self_call_patterns(dw.body, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            annotation_complexity_scan_expr_self_call_patterns(dw.cond, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            return 0;
        case AST_SWITCH:
        case AST_MATCH:
            var sw: *AstSwitch = (*AstSwitch)stmt;
            annotation_complexity_scan_expr_self_call_patterns(sw.expr, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            if (sw.cases_vec != 0) {
                var cn: u64 = sw.cases_vec.len();
                for (var ci: u64 = 0; ci < cn; ci++) {
                    annotation_complexity_scan_stmt_self_call_patterns(sw.cases_vec.get(ci), fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
                }
            }
            return 0;
        case AST_CASE:
            var cs: *AstCase = (*AstCase)stmt;
            annotation_complexity_scan_expr_self_call_patterns(cs.value, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            annotation_complexity_scan_stmt_self_call_patterns(cs.body, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            return 0;
        case AST_DEFER:
            annotation_complexity_scan_stmt_self_call_patterns(((*AstDefer)stmt).stmt, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            return 0;
        case AST_VAR_DECL:
            annotation_complexity_scan_expr_self_call_patterns(((*AstVarDecl)stmt).init_expr, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            return 0;
        case AST_ASSIGN:
            var asn: *AstAssign = (*AstAssign)stmt;
            annotation_complexity_scan_expr_self_call_patterns(asn.target, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            annotation_complexity_scan_expr_self_call_patterns(asn.value, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            return 0;
        case AST_EXPR_STMT:
            annotation_complexity_scan_expr_self_call_patterns(((*AstExprStmt)stmt).expr, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            return 0;
        case AST_RETURN:
            annotation_complexity_scan_expr_self_call_patterns(((*AstReturn)stmt).expr, fn_ptr, fn_len, out_total, out_half, out_minus, out_same);
            return 0;
    }
    return 0;
}

func annotation_complexity_find_func_by_name(name_ptr: u64, name_len: u64) -> *AstFunc {
    if (name_ptr == 0 || name_len == 0 || g_compiler_ctx.all_funcs == 0) { return 0; }
    var n: u64 = g_compiler_ctx.all_funcs.len();
    var exact: *AstFunc = 0;
    var tail: *AstFunc = 0;
    for (var i: u64 = 0; i < n; i++) {
        var fn: *AstFunc = g_compiler_ctx.all_funcs.get(i);
        if (fn == 0 || fn.name_ptr == 0 || fn.name_len == 0) { continue; }
        if (str_eq(fn.name_ptr, fn.name_len, name_ptr, name_len) != 0) {
            if (exact == 0 || fn.name_len < exact.name_len) { exact = fn; }
            continue;
        }
        if (fn.name_len > name_len + 2) {
            var off: u64 = fn.name_len - name_len;
            var full: []u8 = slice(fn.name_ptr, fn.name_len);
            if (full[off - 1] == 95 && full[off - 2] == 95 &&
                str_eq(fn.name_ptr + off, name_len, name_ptr, name_len) != 0) {
                if (tail == 0 || fn.name_len < tail.name_len) { tail = fn; }
            }
        }
    }
    if (exact != 0) { return exact; }
    if (tail != 0) { return tail; }
    return 0;
}

func annotation_complexity_param_is_self_like(p: *Param) -> u64 {
    if (p == 0) { return 0; }
    if (p.name_ptr != 0 && p.name_len == 4 && str_eq(p.name_ptr, p.name_len, "self", 4) != 0) { return 1; }
    return 0;
}

func annotation_complexity_method_symbol_matches(fn: *AstFunc, call_name_ptr: u64, call_name_len: u64) -> u64 {
    if (fn == 0 || call_name_ptr == 0 || call_name_len == 0) { return 0; }
    var orig_ptr: u64 = fn.impl_original_name_ptr;
    var orig_len: u64 = fn.impl_original_name_len;
    if (orig_ptr != 0 && orig_len != 0) {
        if (str_eq(orig_ptr, orig_len, call_name_ptr, call_name_len) != 0) { return 1; }
    }
    if (fn.name_ptr != 0 && fn.name_len != 0) {
        if (str_eq(fn.name_ptr, fn.name_len, call_name_ptr, call_name_len) != 0) { return 1; }
        if (annotation_complexity_name_matches_symbol(fn.name_ptr, fn.name_len, call_name_ptr, call_name_len) != 0) { return 1; }
    }
    return 0;
}

func annotation_complexity_fn_accepts_call_shape(fn: *AstFunc, explicit_arg_count: u64, include_implicit_self: u64, arg_names: *Vec<*NameInfo>) -> u64 {
    if (fn == 0) { return 0; }
    var params: *Vec<*Param> = fn.params_vec;
    if (params == 0) {
        if (call_has_named_args(arg_names) != 0) { return 0; }
        if (explicit_arg_count == 0) { return 1; }
        return 0;
    }

    var start_idx: u64 = 0;
    var pn: u64 = params.len();
    if (include_implicit_self != 0 && pn > 0) {
        var first: *Param = params.get(0);
        if (annotation_complexity_param_is_self_like(first) != 0) { start_idx = 1; }
    }
    if (start_idx > pn) { start_idx = pn; }

    var required: u64 = 0;
    var max_fixed: u64 = 0;
    var has_variadic: u64 = 0;
    var variadic_name_ptr: u64 = 0;
    var variadic_name_len: u64 = 0;
    for (var i: u64 = start_idx; i < pn; i++) {
        var p: *Param = params.get(i);
        if (p == 0) { continue; }
        if (p.is_variadic != 0) {
            has_variadic = 1;
            variadic_name_ptr = p.name_ptr;
            variadic_name_len = p.name_len;
            continue;
        }
        max_fixed = max_fixed + 1;
        if (p.has_default == 0) { required = required + 1; }
    }

    if (call_has_named_args(arg_names) == 0) {
        if (explicit_arg_count < required) { return 0; }
        if (has_variadic == 0 && explicit_arg_count > max_fixed) { return 0; }
        return 1;
    }

    var assigned: *Vec<u64> = new Vec<u64>(max_fixed + 1);
    for (var si: u64 = 0; si < max_fixed; si++) {
        assigned.push(0);
    }

    var seen_named: u64 = 0;
    var next_positional: u64 = 0;
    for (var ai: u64 = 0; ai < explicit_arg_count; ai++) {
        var arg_name: *NameInfo = call_named_at(arg_names, ai);
        if (arg_name != 0) {
            seen_named = 1;
            var named_idx: u64 = call_find_param_index_by_name(params, start_idx, max_fixed, arg_name.ptr, arg_name.len);
            if (named_idx == COMPILER_CALL_UTILS_NOT_FOUND_U64) {
                if (has_variadic != 0 && variadic_name_ptr != 0 && variadic_name_len != 0 &&
                    str_eq(variadic_name_ptr, variadic_name_len, arg_name.ptr, arg_name.len) != 0) {
                    // Named argument targeting variadic parameter is invalid.
                    return 0;
                }
                return 0;
            }
            if (assigned.get(named_idx) != 0) { return 0; }
            assigned.set(named_idx, 1);
            continue;
        }

        if (seen_named != 0) { return 0; }
        if (next_positional < max_fixed) {
            assigned.set(next_positional, 1);
            next_positional = next_positional + 1;
            continue;
        }
        if (has_variadic == 0) { return 0; }
    }

    for (var fi: u64 = 0; fi < max_fixed; fi++) {
        if (assigned.get(fi) != 0) { continue; }
        var param: *Param = params.get(start_idx + fi);
        if (param == 0 || param.has_default == 0) { return 0; }
    }
    return 1;
}

func annotation_complexity_collect_time_rank_for_name(name_ptr: u64, name_len: u64, method_only: u64, explicit_arg_count: u64, include_implicit_self: u64, arg_names: *Vec<*NameInfo>, out_rank: *u64, out_unknown: *u64, out_seen: *u64) -> u64 {
    if (out_rank != 0) { *out_rank = 0; }
    if (out_unknown != 0) { *out_unknown = 0; }
    if (out_seen != 0) { *out_seen = 0; }
    if (name_ptr == 0 || name_len == 0 || g_compiler_ctx.all_funcs == 0) {
        if (out_unknown != 0) { *out_unknown = 1; }
        return 0;
    }

    var max_rank: u64 = 0;
    var unknown_hit: u64 = 0;
    var seen: u64 = 0;
    var n: u64 = g_compiler_ctx.all_funcs.len();
    var exact_exists: u64 = 0;
    var preferred_len: u64 = 0;
    for (var ei: u64 = 0; ei < n; ei++) {
        var efn: *AstFunc = g_compiler_ctx.all_funcs.get(ei);
        if (efn == 0 || efn.name_ptr == 0 || efn.name_len == 0) { continue; }
        if (str_eq(efn.name_ptr, efn.name_len, name_ptr, name_len) == 0) { continue; }
        if (method_only != 0) {
            var eowner: *NameInfo = sym_get_impl_method_owner(efn.name_ptr, efn.name_len);
            if ((efn.impl_owner_ptr == 0 || efn.impl_owner_len == 0) && eowner == 0) { continue; }
            if (annotation_complexity_method_symbol_matches(efn, name_ptr, name_len) == 0) { continue; }
        }
        if (annotation_complexity_fn_accepts_call_shape(efn, explicit_arg_count, include_implicit_self, arg_names) == 0) { continue; }
        exact_exists = 1;
        break;
    }

    for (var pi: u64 = 0; pi < n; pi++) {
        var pfn: *AstFunc = g_compiler_ctx.all_funcs.get(pi);
        if (pfn == 0 || pfn.name_ptr == 0 || pfn.name_len == 0) { continue; }
        if (annotation_complexity_name_matches_symbol(pfn.name_ptr, pfn.name_len, name_ptr, name_len) == 0) { continue; }
        if (exact_exists != 0 && str_eq(pfn.name_ptr, pfn.name_len, name_ptr, name_len) == 0) { continue; }
        if (method_only != 0) {
            var powner: *NameInfo = sym_get_impl_method_owner(pfn.name_ptr, pfn.name_len);
            if ((pfn.impl_owner_ptr == 0 || pfn.impl_owner_len == 0) && powner == 0) { continue; }
            if (annotation_complexity_method_symbol_matches(pfn, name_ptr, name_len) == 0) { continue; }
        }
        if (annotation_complexity_fn_accepts_call_shape(pfn, explicit_arg_count, include_implicit_self, arg_names) == 0) { continue; }
        if (preferred_len == 0 || pfn.name_len < preferred_len) { preferred_len = pfn.name_len; }
    }

    for (var i: u64 = 0; i < n; i++) {
        var fn: *AstFunc = g_compiler_ctx.all_funcs.get(i);
        if (fn == 0 || fn.name_ptr == 0 || fn.name_len == 0) { continue; }
        if (annotation_complexity_name_matches_symbol(fn.name_ptr, fn.name_len, name_ptr, name_len) == 0) { continue; }
        if (exact_exists != 0 && str_eq(fn.name_ptr, fn.name_len, name_ptr, name_len) == 0) { continue; }
        if (preferred_len != 0 && fn.name_len != preferred_len) { continue; }
        if (method_only != 0) {
            var owner: *NameInfo = sym_get_impl_method_owner(fn.name_ptr, fn.name_len);
            if ((fn.impl_owner_ptr == 0 || fn.impl_owner_len == 0) && owner == 0) { continue; }
            if (annotation_complexity_method_symbol_matches(fn, name_ptr, name_len) == 0) { continue; }
        }
        if (annotation_complexity_fn_accepts_call_shape(fn, explicit_arg_count, include_implicit_self, arg_names) == 0) { continue; }
        seen = 1;
        var r: u64 = annotation_complexity_declared_or_budget_time_rank(fn);
        if (r == 0) {
            unknown_hit = 1;
        } else if (annotation_complexity_rank_order(r) > annotation_complexity_rank_order(max_rank)) {
            max_rank = r;
        }
    }

    if (out_rank != 0) { *out_rank = max_rank; }
    if (out_unknown != 0) {
        if (seen == 0 || unknown_hit != 0) { *out_unknown = 1; }
        else { *out_unknown = 0; }
    }
    if (out_seen != 0) { *out_seen = seen; }
    return seen;
}

func annotation_complexity_declared_or_budget_time_rank(fn: *AstFunc) -> u64 {
    if (fn == 0) { return 0; }
    var ann_c: *CompilerAnnotationParsed = annotation_complexity_get_single(fn, "complexity", 10);
    if (ann_c != 0) {
        var t_c: *CompilerAnnotationArg = annotation_complexity_find_time_arg(ann_c);
        if (t_c != 0 && t_c.kind == 3) {
            var r_c: u64 = annotation_complexity_rank_from_expr(t_c.string_ptr, t_c.string_len);
            if (r_c != 0) { return r_c; }
        }
    }
    var ann_b: *CompilerAnnotationParsed = annotation_complexity_get_single(fn, "complexity_budget", 17);
    if (ann_b != 0) {
        var t_b: *CompilerAnnotationArg = annotation_complexity_find_time_arg(ann_b);
        if (t_b != 0 && t_b.kind == 3) {
            var r_b: u64 = annotation_complexity_rank_from_expr(t_b.string_ptr, t_b.string_len);
            if (r_b != 0) { return r_b; }
        }
    }
    return 0;
}

func annotation_complexity_prefix_match(src_ptr: u64, src_len: u64, prefix_ptr: u64, prefix_len: u64) -> u64 {
    if (src_ptr == 0 || src_len == 0 || prefix_ptr == 0 || prefix_len == 0) { return 0; }
    if (src_len < prefix_len) { return 0; }
    return str_eq(src_ptr, prefix_len, prefix_ptr, prefix_len) != 0;
}

func annotation_complexity_fn_is_generated_wrapper(fn: *AstFunc) -> u64 {
    if (fn == 0 || fn.name_ptr == 0 || fn.name_len == 0) { return 0; }
    if (annotation_complexity_prefix_match(fn.name_ptr, fn.name_len, "__ann_orig__", 11) != 0) { return 1; }
    if (annotation_complexity_prefix_match(fn.name_ptr, fn.name_len, "__ann_wrap__", 11) != 0) { return 1; }
    return 0;
}

func annotation_complexity_module_for_func(fn: *AstFunc) -> *NameInfo {
    if (fn == 0 || fn.name_ptr == 0 || fn.name_len == 0) { return 0; }
    if (g_compiler_ctx.func_module_map == 0) { return 0; }
    return g_compiler_ctx.func_module_map.get(fn.name_ptr, fn.name_len);
}

func annotation_complexity_is_std_module(module_ptr: u64, module_len: u64) -> u64 {
    if (module_ptr == 0 || module_len == 0) { return 0; }
    if (module_len == 3 && str_eq(module_ptr, module_len, "std", 3) != 0) { return 1; }
    if (annotation_complexity_prefix_match(module_ptr, module_len, "std.", 4) != 0) { return 1; }
    return 0;
}

func annotation_complexity_is_std_io_module(module_ptr: u64, module_len: u64) -> u64 {
    if (module_ptr == 0 || module_len == 0) { return 0; }
    if (module_len == 6 && str_eq(module_ptr, module_len, "std.io", 6) != 0) { return 1; }
    if (annotation_complexity_prefix_match(module_ptr, module_len, "std.io.", 7) != 0) { return 1; }
    if (module_len == 8 && str_eq(module_ptr, module_len, "std.diag", 8) != 0) { return 1; }
    if (annotation_complexity_prefix_match(module_ptr, module_len, "std.diag.", 9) != 0) { return 1; }
    if (module_len == 8 && str_eq(module_ptr, module_len, "std.emit", 8) != 0) { return 1; }
    if (annotation_complexity_prefix_match(module_ptr, module_len, "std.emit.", 9) != 0) { return 1; }
    return 0;
}

func annotation_complexity_is_std_mangled_name(fn_ptr: u64, fn_len: u64) -> u64 {
    if (fn_ptr == 0 || fn_len == 0) { return 0; }
    if (annotation_complexity_prefix_match(fn_ptr, fn_len, "std__", 5) != 0) { return 1; }
    if (annotation_complexity_prefix_match(fn_ptr, fn_len, "std_", 4) != 0) { return 1; }
    return 0;
}

func annotation_complexity_is_std_io_mangled_name(fn_ptr: u64, fn_len: u64) -> u64 {
    if (fn_ptr == 0 || fn_len == 0) { return 0; }
    if (annotation_complexity_prefix_match(fn_ptr, fn_len, "std_io__", 8) != 0) { return 1; }
    if (annotation_complexity_prefix_match(fn_ptr, fn_len, "std_diag__", 10) != 0) { return 1; }
    if (annotation_complexity_prefix_match(fn_ptr, fn_len, "std_emit__", 10) != 0) { return 1; }
    return 0;
}

func annotation_complexity_fn_is_std_core_candidate(fn: *AstFunc, module: *NameInfo) -> u64 {
    if (fn == 0) { return 0; }
    if (fn.body == 0) { return 0; }
    if (annotation_complexity_fn_is_generated_wrapper(fn) != 0) { return 0; }
    if (module != 0 && module.ptr != 0 && module.len != 0) {
        if (annotation_complexity_is_std_module(module.ptr, module.len) == 0) { return 0; }
        if (annotation_complexity_is_std_io_module(module.ptr, module.len) != 0) { return 0; }
        return 1;
    }
    if (annotation_complexity_is_std_mangled_name(fn.name_ptr, fn.name_len) == 0) { return 0; }
    if (annotation_complexity_is_std_io_mangled_name(fn.name_ptr, fn.name_len) != 0) { return 0; }
    return 1;
}

func annotation_complexity_validate_std_library_summaries() -> u64 {
    if (annotation_complexity_require_std_summaries() == 0) { return 1; }
    if (g_compiler_ctx.all_funcs == 0) { return 1; }

    var ok: u64 = 1;
    var n: u64 = g_compiler_ctx.all_funcs.len();
    for (var i: u64 = 0; i < n; i++) {
        if (diag_should_stop_pass() != 0) { break; }
        var fn: *AstFunc = g_compiler_ctx.all_funcs.get(i);
        if (fn == 0) { continue; }
        var module: *NameInfo = annotation_complexity_module_for_func(fn);
        if (annotation_complexity_fn_is_std_core_candidate(fn, module) == 0) { continue; }

        var rank: u64 = annotation_complexity_declared_or_budget_time_rank(fn);
        if (rank != 0) { continue; }

        emit_stderr("[ERROR] missing complexity summary on std core function ");
        emit_stderr_len(fn.name_ptr, fn.name_len);
        emit_stderr(" (module=");
        if (module != 0 && module.ptr != 0) { emit_stderr_len(module.ptr, module.len); }
        else { emit_stderr("unknown"); }
        emit_stderr("): add @[complexity(time=\"O(...)\")] or @[complexity_budget(time=\"O(...)\")]\n");
        diag_note_error();
        ok = 0;
    }
    return ok;
}

func annotation_complexity_scan_expr_external_call_summary(expr: *AstNode, self_fn: *AstFunc, self_symtab: *HashMap<u64, *TypeInfo>, self_ptr: u64, self_len: u64, out_max_rank: *u64, out_unknown: *u64, out_calls: *u64) -> u64 {
    if (expr == 0 || out_max_rank == 0 || out_unknown == 0 || out_calls == 0) { return 0; }
    var kind: u64 = ast_kind(expr);
    var nref: AstNodeTagRef;
    nref.node = expr;

    if (kind == AST_CALL) {
        if (annotation_complexity_name_matches_self_call(nref.call.name_ptr, nref.call.name_len, self_ptr, self_len) == 0) {
            *out_calls = *out_calls + 1;
            var call_rank: u64 = 0;
            var call_unknown: u64 = 0;
            var call_seen: u64 = 0;
            var call_argc: u64 = 0;
            if (nref.call.args_vec != 0) { call_argc = nref.call.args_vec.len(); }
            annotation_complexity_collect_time_rank_for_name(nref.call.name_ptr, nref.call.name_len, 0, call_argc, 0, nref.call.arg_names_vec, &call_rank, &call_unknown, &call_seen);
            if (call_seen == 0) {
                *out_unknown = *out_unknown + 1;
            } else {
                if (call_unknown != 0) { *out_unknown = *out_unknown + 1; }
                if (annotation_complexity_rank_order(call_rank) > annotation_complexity_rank_order(*out_max_rank)) { *out_max_rank = call_rank; }
            }
        }
        if (nref.call.args_vec != 0) {
            var an: u64 = nref.call.args_vec.len();
            for (var i: u64 = 0; i < an; i++) {
                annotation_complexity_scan_expr_external_call_summary(nref.call.args_vec.get(i), self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            }
        }
        return 0;
    }
    if (kind == AST_GENERIC_CALL) {
        if (annotation_complexity_name_matches_self_call(nref.generic_call.name_ptr, nref.generic_call.name_len, self_ptr, self_len) == 0) {
            *out_calls = *out_calls + 1;
            var gen_rank: u64 = 0;
            var gen_unknown: u64 = 0;
            var gen_seen: u64 = 0;
            var gen_argc: u64 = 0;
            if (nref.generic_call.args_vec != 0) { gen_argc = nref.generic_call.args_vec.len(); }
            annotation_complexity_collect_time_rank_for_name(nref.generic_call.name_ptr, nref.generic_call.name_len, 0, gen_argc, 0, nref.generic_call.arg_names_vec, &gen_rank, &gen_unknown, &gen_seen);
            if (gen_seen == 0) {
                *out_unknown = *out_unknown + 1;
            } else {
                if (gen_unknown != 0) { *out_unknown = *out_unknown + 1; }
                if (annotation_complexity_rank_order(gen_rank) > annotation_complexity_rank_order(*out_max_rank)) { *out_max_rank = gen_rank; }
            }
        }
        if (nref.generic_call.args_vec != 0) {
            var gn: u64 = nref.generic_call.args_vec.len();
            for (var gi: u64 = 0; gi < gn; gi++) {
                annotation_complexity_scan_expr_external_call_summary(nref.generic_call.args_vec.get(gi), self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            }
        }
        return 0;
    }
    if (kind == AST_STATIC_GENERIC_CALL) {
        if (annotation_complexity_name_matches_self_call(nref.static_generic_call.method_ptr, nref.static_generic_call.method_len, self_ptr, self_len) == 0) {
            *out_calls = *out_calls + 1;
            var sg_rank: u64 = 0;
            var sg_unknown: u64 = 0;
            var sg_seen: u64 = 0;
            var sg_argc: u64 = 0;
            if (nref.static_generic_call.args_vec != 0) { sg_argc = nref.static_generic_call.args_vec.len(); }
            annotation_complexity_collect_time_rank_for_name(nref.static_generic_call.method_ptr, nref.static_generic_call.method_len, 0, sg_argc, 0, nref.static_generic_call.arg_names_vec, &sg_rank, &sg_unknown, &sg_seen);
            if (sg_seen == 0) {
                *out_unknown = *out_unknown + 1;
            } else {
                if (sg_unknown != 0) { *out_unknown = *out_unknown + 1; }
                if (annotation_complexity_rank_order(sg_rank) > annotation_complexity_rank_order(*out_max_rank)) { *out_max_rank = sg_rank; }
            }
        }
        if (nref.static_generic_call.args_vec != 0) {
            var sgn: u64 = nref.static_generic_call.args_vec.len();
            for (var sgi: u64 = 0; sgi < sgn; sgi++) {
                annotation_complexity_scan_expr_external_call_summary(nref.static_generic_call.args_vec.get(sgi), self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            }
        }
        return 0;
    }
    if (kind == AST_METHOD_CALL || kind == AST_SAFE_METHOD_CALL) {
        if (annotation_complexity_method_call_is_self_recursive(nref.method_call, self_fn) == 0) {
            *out_calls = *out_calls + 1;
            var method_rank: u64 = 0;
            var method_unknown: u64 = 0;
            var method_seen: u64 = 0;
            var method_argc: u64 = 0;
            if (nref.method_call.args_vec != 0) { method_argc = nref.method_call.args_vec.len(); }

            // Prefer receiver-type-qualified method symbol to avoid suffix-based false matches.
            var recv_ti: *TypeInfo = generic_infer_expr_type(nref.method_call.receiver, self_symtab);
            var recv_owner_ptr: u64 = 0;
            var recv_owner_len: u64 = 0;
            var recv_owner_known: u64 = 0;
            if (recv_ti != 0 && recv_ti.type_kind == TYPE_STRUCT) {
                recv_owner_ptr = recv_ti.struct_name_ptr;
                recv_owner_len = recv_ti.struct_name_len;
                if ((recv_owner_ptr == 0 || recv_owner_len == 0) && recv_ti.struct_def != 0) {
                    recv_owner_ptr = recv_ti.struct_def.name_ptr;
                    recv_owner_len = recv_ti.struct_def.name_len;
                }
            }
            if (recv_owner_ptr != 0 && recv_owner_len != 0 && get_struct_def(recv_owner_ptr, recv_owner_len) != 0) {
                recv_owner_known = 1;
            }
            if (recv_owner_ptr != 0 && recv_owner_len != 0) {
                var resolved_method: *NameInfo = build_method_name(recv_owner_ptr, recv_owner_len, nref.method_call.method_ptr, nref.method_call.method_len);
                if (resolved_method != 0 && resolved_method.ptr != 0 && resolved_method.len != 0) {
                    annotation_complexity_collect_time_rank_for_name(resolved_method.ptr, resolved_method.len, 1, method_argc, 1, nref.method_call.arg_names_vec, &method_rank, &method_unknown, &method_seen);
                    if (method_seen == 0) {
                        annotation_complexity_collect_time_rank_for_name(resolved_method.ptr, resolved_method.len, 1, method_argc, 0, nref.method_call.arg_names_vec, &method_rank, &method_unknown, &method_seen);
                    }
                }
            }

            if (method_seen == 0 && recv_owner_known == 0) {
                annotation_complexity_collect_time_rank_for_name(nref.method_call.method_ptr, nref.method_call.method_len, 1, method_argc, 1, nref.method_call.arg_names_vec, &method_rank, &method_unknown, &method_seen);
                if (method_seen == 0) {
                    // Method-call syntax should stay method-only; free-function fallback causes false positives.
                    annotation_complexity_collect_time_rank_for_name(nref.method_call.method_ptr, nref.method_call.method_len, 1, method_argc, 0, nref.method_call.arg_names_vec, &method_rank, &method_unknown, &method_seen);
                }
            }
            if (method_seen == 0) {
                *out_unknown = *out_unknown + 1;
            } else {
                if (method_unknown != 0) { *out_unknown = *out_unknown + 1; }
                if (annotation_complexity_rank_order(method_rank) > annotation_complexity_rank_order(*out_max_rank)) { *out_max_rank = method_rank; }
            }
        }
        annotation_complexity_scan_expr_external_call_summary(nref.method_call.receiver, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
        if (nref.method_call.args_vec != 0) {
            var mn: u64 = nref.method_call.args_vec.len();
            for (var mi: u64 = 0; mi < mn; mi++) {
                annotation_complexity_scan_expr_external_call_summary(nref.method_call.args_vec.get(mi), self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            }
        }
        return 0;
    }
    if (kind == AST_CALL_PTR) {
        *out_calls = *out_calls + 1;
        if (nref.call_ptr.callee != 0 && ast_kind(nref.call_ptr.callee) == AST_IDENT) {
            var cid: *AstIdent = (*AstIdent)nref.call_ptr.callee;
            if (annotation_complexity_name_matches_self_call(cid.name_ptr, cid.name_len, self_ptr, self_len) == 0) {
                var ptr_rank: u64 = 0;
                var ptr_unknown: u64 = 0;
                var ptr_seen: u64 = 0;
                var ptr_argc: u64 = 0;
                if (nref.call_ptr.args_vec != 0) { ptr_argc = nref.call_ptr.args_vec.len(); }
                annotation_complexity_collect_time_rank_for_name(cid.name_ptr, cid.name_len, 0, ptr_argc, 0, 0, &ptr_rank, &ptr_unknown, &ptr_seen);
                if (ptr_seen == 0) {
                    *out_unknown = *out_unknown + 1;
                } else {
                    if (ptr_unknown != 0) { *out_unknown = *out_unknown + 1; }
                    if (annotation_complexity_rank_order(ptr_rank) > annotation_complexity_rank_order(*out_max_rank)) { *out_max_rank = ptr_rank; }
                }
            }
        } else {
            *out_unknown = *out_unknown + 1;
        }
        annotation_complexity_scan_expr_external_call_summary(nref.call_ptr.callee, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
        if (nref.call_ptr.args_vec != 0) {
            var pn: u64 = nref.call_ptr.args_vec.len();
            for (var pi: u64 = 0; pi < pn; pi++) {
                annotation_complexity_scan_expr_external_call_summary(nref.call_ptr.args_vec.get(pi), self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            }
        }
        return 0;
    }

    if (kind == AST_BINARY) {
        annotation_complexity_scan_expr_external_call_summary(nref.binary.left, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
        annotation_complexity_scan_expr_external_call_summary(nref.binary.right, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
        return 0;
    }
    if (kind == AST_UNARY) {
        annotation_complexity_scan_expr_external_call_summary(nref.unary.operand, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
        return 0;
    }
    if (kind == AST_TERNARY) {
        annotation_complexity_scan_expr_external_call_summary(nref.ternary_expr.cond, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
        annotation_complexity_scan_expr_external_call_summary(nref.ternary_expr.then_expr, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
        annotation_complexity_scan_expr_external_call_summary(nref.ternary_expr.else_expr, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
        return 0;
    }
    return 0;
}

func annotation_complexity_scan_stmt_external_call_summary(stmt: *AstNode, self_fn: *AstFunc, self_symtab: *HashMap<u64, *TypeInfo>, self_ptr: u64, self_len: u64, out_max_rank: *u64, out_unknown: *u64, out_calls: *u64) -> u64 {
    if (stmt == 0 || out_max_rank == 0 || out_unknown == 0 || out_calls == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    match (kind) {
        case AST_BLOCK:
            var blk: *AstBlock = (*AstBlock)stmt;
            if (blk.stmts_vec != 0) {
                var bn: u64 = blk.stmts_vec.len();
                for (var bi: u64 = 0; bi < bn; bi++) {
                    annotation_complexity_scan_stmt_external_call_summary(blk.stmts_vec.get(bi), self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
                }
            }
            return 0;
        case AST_IF:
            var ifs: *AstIf = (*AstIf)stmt;
            annotation_complexity_scan_expr_external_call_summary(ifs.cond, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            annotation_complexity_scan_stmt_external_call_summary(ifs.then_block, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            annotation_complexity_scan_stmt_external_call_summary(ifs.else_block, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            return 0;
        case AST_WHILE:
            var wl: *AstWhile = (*AstWhile)stmt;
            annotation_complexity_scan_expr_external_call_summary(wl.cond, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            annotation_complexity_scan_stmt_external_call_summary(wl.body, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            return 0;
        case AST_FOR:
            var fr: *AstFor = (*AstFor)stmt;
            annotation_complexity_scan_stmt_external_call_summary(fr.init, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            annotation_complexity_scan_expr_external_call_summary(fr.cond, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            annotation_complexity_scan_expr_external_call_summary(fr.update, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            annotation_complexity_scan_stmt_external_call_summary(fr.body, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            return 0;
        case AST_DO_WHILE:
            var dw: *AstDoWhile = (*AstDoWhile)stmt;
            annotation_complexity_scan_stmt_external_call_summary(dw.body, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            annotation_complexity_scan_expr_external_call_summary(dw.cond, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            return 0;
        case AST_SWITCH:
        case AST_MATCH:
            var sw: *AstSwitch = (*AstSwitch)stmt;
            annotation_complexity_scan_expr_external_call_summary(sw.expr, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            if (sw.cases_vec != 0) {
                var cn: u64 = sw.cases_vec.len();
                for (var ci: u64 = 0; ci < cn; ci++) {
                    annotation_complexity_scan_stmt_external_call_summary(sw.cases_vec.get(ci), self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
                }
            }
            return 0;
        case AST_CASE:
            var cs: *AstCase = (*AstCase)stmt;
            annotation_complexity_scan_expr_external_call_summary(cs.value, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            annotation_complexity_scan_stmt_external_call_summary(cs.body, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            return 0;
        case AST_DEFER:
            annotation_complexity_scan_stmt_external_call_summary(((*AstDefer)stmt).stmt, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            return 0;
        case AST_VAR_DECL:
            annotation_complexity_scan_expr_external_call_summary(((*AstVarDecl)stmt).init_expr, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            return 0;
        case AST_ASSIGN:
            var asn: *AstAssign = (*AstAssign)stmt;
            annotation_complexity_scan_expr_external_call_summary(asn.target, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            annotation_complexity_scan_expr_external_call_summary(asn.value, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            return 0;
        case AST_EXPR_STMT:
            annotation_complexity_scan_expr_external_call_summary(((*AstExprStmt)stmt).expr, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            return 0;
        case AST_BINARY:
        case AST_UNARY:
        case AST_TERNARY:
        case AST_CALL:
        case AST_GENERIC_CALL:
        case AST_STATIC_GENERIC_CALL:
        case AST_METHOD_CALL:
        case AST_SAFE_METHOD_CALL:
        case AST_CALL_PTR:
            annotation_complexity_scan_expr_external_call_summary(stmt, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            return 0;
        case AST_RETURN:
            annotation_complexity_scan_expr_external_call_summary(((*AstReturn)stmt).expr, self_fn, self_symtab, self_ptr, self_len, out_max_rank, out_unknown, out_calls);
            return 0;
    }
    return 0;
}

func annotation_complexity_has_random_like_call(stmt: *AstNode) -> u64 {
    if (stmt == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    if (annotation_complexity_stmt_has_call_token(stmt, "rand", 4) != 0) { return 1; }
    if (annotation_complexity_stmt_has_call_token(stmt, "random", 6) != 0) { return 1; }
    if (annotation_complexity_stmt_has_call_token(stmt, "random_u64", 10) != 0) { return 1; }
    if (annotation_complexity_stmt_has_call_token(stmt, "xorshift", 8) != 0) { return 1; }
    return 0;
}

func annotation_complexity_collect_loop_stats(stmt: *AstNode, constraints_ann: *CompilerAnnotationParsed, fallback_bound: u64, out_loops: *u64, out_sqrt: *u64, out_geo: *u64, out_linear: *u64) -> u64 {
    if (stmt == 0 || out_loops == 0 || out_sqrt == 0 || out_geo == 0 || out_linear == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    if (kind == AST_WHILE) {
        var wl: *AstWhile = (*AstWhile)stmt;
        *out_loops = *out_loops + 1;
        var rk: u64 = annotation_complexity_loop_iteration_rank_with_ctx(wl.cond, 0, wl.body, constraints_ann, fallback_bound);
        if (rk == 10) { *out_sqrt = *out_sqrt + 1; }
        else if (rk == 2) { *out_geo = *out_geo + 1; }
        else if (rk == 3) { *out_linear = *out_linear + 1; }
        annotation_complexity_collect_loop_stats(wl.body, constraints_ann, fallback_bound, out_loops, out_sqrt, out_geo, out_linear);
        return 0;
    }
    if (kind == AST_FOR) {
        var fr: *AstFor = (*AstFor)stmt;
        *out_loops = *out_loops + 1;
        var frk: u64 = annotation_complexity_loop_iteration_rank_with_ctx(fr.cond, fr.update, fr.body, constraints_ann, fallback_bound);
        var fiter_known: u64 = 0;
        var fiter: u64 = annotation_complexity_for_iterations_precise_with_status(fr, constraints_ann, fallback_bound, &fiter_known);
        if (fiter_known != 0 && fiter <= 1) { frk = 1; }
        if (frk == 10) { *out_sqrt = *out_sqrt + 1; }
        else if (frk == 2) { *out_geo = *out_geo + 1; }
        else if (frk == 3) { *out_linear = *out_linear + 1; }
        annotation_complexity_collect_loop_stats(fr.init, constraints_ann, fallback_bound, out_loops, out_sqrt, out_geo, out_linear);
        annotation_complexity_collect_loop_stats(fr.body, constraints_ann, fallback_bound, out_loops, out_sqrt, out_geo, out_linear);
        return 0;
    }
    if (kind == AST_DO_WHILE) {
        var dw: *AstDoWhile = (*AstDoWhile)stmt;
        *out_loops = *out_loops + 1;
        var drk: u64 = annotation_complexity_loop_iteration_rank_with_ctx(dw.cond, 0, dw.body, constraints_ann, fallback_bound);
        if (drk == 10) { *out_sqrt = *out_sqrt + 1; }
        else if (drk == 2) { *out_geo = *out_geo + 1; }
        else if (drk == 3) { *out_linear = *out_linear + 1; }
        annotation_complexity_collect_loop_stats(dw.body, constraints_ann, fallback_bound, out_loops, out_sqrt, out_geo, out_linear);
        return 0;
    }
    if (kind == AST_BLOCK) {
        var blk: *AstBlock = (*AstBlock)stmt;
        if (blk.stmts_vec != 0) {
            var bn: u64 = blk.stmts_vec.len();
            for (var bi: u64 = 0; bi < bn; bi++) {
                annotation_complexity_collect_loop_stats(blk.stmts_vec.get(bi), constraints_ann, fallback_bound, out_loops, out_sqrt, out_geo, out_linear);
            }
        }
        return 0;
    }
    if (kind == AST_IF) {
        var ifs: *AstIf = (*AstIf)stmt;
        annotation_complexity_collect_loop_stats(ifs.then_block, constraints_ann, fallback_bound, out_loops, out_sqrt, out_geo, out_linear);
        annotation_complexity_collect_loop_stats(ifs.else_block, constraints_ann, fallback_bound, out_loops, out_sqrt, out_geo, out_linear);
        return 0;
    }
    if (kind == AST_SWITCH || kind == AST_MATCH) {
        var sw: *AstSwitch = (*AstSwitch)stmt;
        if (sw.cases_vec != 0) {
            var cn: u64 = sw.cases_vec.len();
            for (var ci: u64 = 0; ci < cn; ci++) {
                annotation_complexity_collect_loop_stats(sw.cases_vec.get(ci), constraints_ann, fallback_bound, out_loops, out_sqrt, out_geo, out_linear);
            }
        }
        return 0;
    }
    if (kind == AST_CASE) { annotation_complexity_collect_loop_stats(((*AstCase)stmt).body, constraints_ann, fallback_bound, out_loops, out_sqrt, out_geo, out_linear); return 0; }
    if (kind == AST_DEFER) { annotation_complexity_collect_loop_stats(((*AstDefer)stmt).stmt, constraints_ann, fallback_bound, out_loops, out_sqrt, out_geo, out_linear); return 0; }
    return 0;
}

func annotation_complexity_infer_mode(fn: *AstFunc) -> u64 {
    if (fn == 0 || fn.body == 0) { return ANN_COMPLEXITY_MODE_UNSPEC; }
    var has_pollard: u64 = annotation_complexity_has_pollard_rho_like_pattern_stmt(fn.body);
    var has_random: u64 = annotation_complexity_has_random_like_call(fn.body);
    if (has_pollard != 0 || has_random != 0) {
        var loop_total: u64 = 0;
        var loop_sqrt: u64 = 0;
        var loop_geo: u64 = 0;
        var loop_linear: u64 = 0;
        annotation_complexity_collect_loop_stats(fn.body, 0, 1, &loop_total, &loop_sqrt, &loop_geo, &loop_linear);
        if (loop_geo != 0) { return ANN_COMPLEXITY_MODE_HIGH_PROB; }
        return ANN_COMPLEXITY_MODE_EXPECTED;
    }
    var recur_total: u64 = 0;
    var recur_half: u64 = 0;
    var recur_minus: u64 = 0;
    var recur_same: u64 = 0;
    annotation_complexity_scan_stmt_self_call_patterns(fn.body, fn.name_ptr, fn.name_len, &recur_total, &recur_half, &recur_minus, &recur_same);
    var loop_total2: u64 = 0;
    var loop_sqrt2: u64 = 0;
    var loop_geo2: u64 = 0;
    var loop_linear2: u64 = 0;
    annotation_complexity_collect_loop_stats(fn.body, 0, 1, &loop_total2, &loop_sqrt2, &loop_geo2, &loop_linear2);
    if (recur_total == 0 && loop_total2 >= 2 && annotation_complexity_stmt_has_one_sided_loop_if(fn.body) != 0) {
        return ANN_COMPLEXITY_MODE_AMORTIZED;
    }
    return ANN_COMPLEXITY_MODE_WORST;
}

func annotation_complexity_infer_time_rank_with_meta(fn: *AstFunc, constraints_ann: *CompilerAnnotationParsed, out_reason: *u64, out_mode: *u64, out_conf: *u64) -> u64 {
    if (out_reason != 0) { *out_reason = ANN_COMPLEXITY_REASON_UNKNOWN; }
    if (out_mode != 0) { *out_mode = annotation_complexity_infer_mode(fn); }
    if (out_conf != 0) { *out_conf = ANN_COMPLEXITY_CONF_UNKNOWN; }
    if (fn == 0 || fn.body == 0) { return 1; }
    var ssa_conf_hint: u64 = ANN_COMPLEXITY_CONF_UNKNOWN;
    var ssa_rank_hint: u64 = annotation_complexity_ssa_infer_time_rank(fn, &ssa_conf_hint);
    var fallback_bound: u64 = annotation_complexity_constraints_max(constraints_ann);
    var unresolved_loop: u64 = annotation_complexity_stmt_has_unresolved_loop(fn.body, constraints_ann, fallback_bound);
    var memo_hint_rank: u64 = 0;
    if (annotation_complexity_infer_memo_hint_rank(fn, constraints_ann, &memo_hint_rank) != 0 && memo_hint_rank != 0) {
        if (out_reason != 0) { *out_reason = ANN_COMPLEXITY_REASON_DP_MEMO_HINT; }
        if (out_conf != 0) { *out_conf = ANN_COMPLEXITY_CONF_HEURISTIC; }
        return memo_hint_rank;
    }
    if (annotation_complexity_has_pollard_rho_like_pattern_stmt(fn.body) != 0) {
        if (out_reason != 0) { *out_reason = ANN_COMPLEXITY_REASON_POLLARD; }
        if (out_conf != 0) { *out_conf = ANN_COMPLEXITY_CONF_HEURISTIC; }
        return 11;
    }
    if (annotation_complexity_has_sieve_like_pattern_stmt(fn.body) != 0) {
        if (out_reason != 0) { *out_reason = ANN_COMPLEXITY_REASON_SIEVE; }
        if (out_conf != 0) { *out_conf = ANN_COMPLEXITY_CONF_HEURISTIC; }
        return 9;
    }
    var memo_rank: u64 = 0;
    if (annotation_complexity_infer_topdown_memo_rank(fn, constraints_ann, &memo_rank) != 0 && memo_rank != 0) {
        if (out_reason != 0) { *out_reason = ANN_COMPLEXITY_REASON_DP_MEMO; }
        if (out_conf != 0) { *out_conf = ANN_COMPLEXITY_CONF_HEURISTIC; }
        return memo_rank;
    }

    var recur_total: u64 = 0;
    var recur_half: u64 = 0;
    var recur_minus: u64 = 0;
    var recur_same: u64 = 0;
    annotation_complexity_scan_stmt_self_call_patterns(fn.body, fn.name_ptr, fn.name_len, &recur_total, &recur_half, &recur_minus, &recur_same);
    if (recur_total >= 2 && recur_half >= 2) {
        if (out_reason != 0) { *out_reason = ANN_COMPLEXITY_REASON_RECURRENCE; }
        if (out_conf != 0) {
            if (unresolved_loop != 0) { *out_conf = ANN_COMPLEXITY_CONF_UNKNOWN; }
            else { *out_conf = ANN_COMPLEXITY_CONF_HEURISTIC; }
        }
        return 4; // conservative divide-and-conquer bucket
    }
    if (recur_total >= 1 && recur_half >= 1) {
        if (out_reason != 0) { *out_reason = ANN_COMPLEXITY_REASON_RECURRENCE; }
        if (out_conf != 0) {
            if (unresolved_loop != 0) { *out_conf = ANN_COMPLEXITY_CONF_UNKNOWN; }
            else { *out_conf = ANN_COMPLEXITY_CONF_HEURISTIC; }
        }
        return 2; // T(n)=T(n/2)+...
    }
    if (recur_total == 1 && recur_minus >= 1) {
        if (out_reason != 0) { *out_reason = ANN_COMPLEXITY_REASON_RECURRENCE; }
        if (out_conf != 0) {
            if (unresolved_loop != 0) { *out_conf = ANN_COMPLEXITY_CONF_UNKNOWN; }
            else { *out_conf = ANN_COMPLEXITY_CONF_HEURISTIC; }
        }
        return 3;
    }
    if (recur_total >= 2 && recur_minus >= 2) {
        if (out_reason != 0) { *out_reason = ANN_COMPLEXITY_REASON_RECURRENCE; }
        if (out_conf != 0) {
            if (unresolved_loop != 0) { *out_conf = ANN_COMPLEXITY_CONF_UNKNOWN; }
            else { *out_conf = ANN_COMPLEXITY_CONF_HEURISTIC; }
        }
        return 7; // branching linear-depth recursion
    }

    var structural_rank: u64 = annotation_complexity_stmt_infer_rank(fn.body, constraints_ann, fallback_bound);
    var ext_max_rank: u64 = 0;
    var ext_unknown: u64 = 0;
    var ext_calls: u64 = 0;
    var ext_symtab: *HashMap<u64, *TypeInfo> = generic_build_symtab_for_func(fn);
    annotation_complexity_scan_stmt_external_call_summary(fn.body, fn, ext_symtab, fn.name_ptr, fn.name_len, &ext_max_rank, &ext_unknown, &ext_calls);
    if (ext_max_rank == 0 && ext_unknown > 0 && annotation_complexity_has_random_like_call(fn.body) == 0) {
        // Conservative fallback: unresolved helper calls are treated as at least linear work.
        ext_max_rank = 3;
    }
    if (ext_max_rank != 0) {
        structural_rank = annotation_complexity_rank_mul(structural_rank, ext_max_rank);
        if (structural_rank == 0) { structural_rank = ext_max_rank; }
    }
    var max_depth: u64 = 0;
    var self_calls: u64 = 0;
    annotation_complexity_scan_stmt(fn.body, fn.name_ptr, fn.name_len, 0, &max_depth, &self_calls);
    if (self_calls >= 2) {
        if (out_reason != 0) { *out_reason = ANN_COMPLEXITY_REASON_RECURRENCE; }
        if (out_conf != 0) { *out_conf = ANN_COMPLEXITY_CONF_HEURISTIC; }
        return 7;
    }
    if (self_calls == 1) {
        if (out_reason != 0) { *out_reason = ANN_COMPLEXITY_REASON_RECURRENCE; }
        if (out_conf != 0) { *out_conf = ANN_COMPLEXITY_CONF_HEURISTIC; }
        if (max_depth >= 1 || annotation_complexity_rank_order(structural_rank) > annotation_complexity_rank_order(1)) { return 7; }
        return 3;
    }
    if (structural_rank != 0) {
        var selected_rank: u64 = structural_rank;
        var selected_reason: u64 = ANN_COMPLEXITY_REASON_STRUCTURAL;
        if (ext_max_rank != 0) { selected_reason = ANN_COMPLEXITY_REASON_INTERPROC; }
        if (out_reason != 0) {
            *out_reason = selected_reason;
        }
        if (out_conf != 0) {
            if (unresolved_loop != 0) {
                *out_conf = ANN_COMPLEXITY_CONF_UNKNOWN;
            } else if (ext_unknown > 0 && annotation_complexity_has_random_like_call(fn.body) == 0) {
                *out_conf = ANN_COMPLEXITY_CONF_UNKNOWN;
            } else {
                *out_conf = ANN_COMPLEXITY_CONF_HEURISTIC;
            }
        }
        if (ssa_rank_hint != 0 &&
            out_conf != 0 && *out_conf == ANN_COMPLEXITY_CONF_UNKNOWN &&
            ssa_conf_hint != ANN_COMPLEXITY_CONF_UNKNOWN &&
            unresolved_loop == 0 &&
            annotation_complexity_rank_exceeds(ssa_rank_hint, selected_rank) == 0) {
            *out_conf = ssa_conf_hint;
            if (out_reason != 0) { *out_reason = ANN_COMPLEXITY_REASON_SSA_SYMBOLIC; }
        }
        return selected_rank;
    }
    if (ssa_rank_hint != 0) {
        if (out_reason != 0) { *out_reason = ANN_COMPLEXITY_REASON_SSA_SYMBOLIC; }
        if (out_conf != 0) { *out_conf = ssa_conf_hint; }
        return ssa_rank_hint;
    }
    if (out_reason != 0) { *out_reason = ANN_COMPLEXITY_REASON_DEPTH_FALLBACK; }
    if (out_conf != 0) { *out_conf = ANN_COMPLEXITY_CONF_UNKNOWN; }
    if (max_depth == 0) { return 1; }
    if (max_depth == 1) { return 3; }
    if (max_depth == 2) { return 5; }
    return 6;
}

func annotation_complexity_infer_time_rank(fn: *AstFunc, constraints_ann: *CompilerAnnotationParsed) -> u64 {
    return annotation_complexity_infer_time_rank_with_meta(fn, constraints_ann, 0, 0, 0);
}

func annotation_complexity_validate_contract(fn: *AstFunc) -> u64 {
    if (fn == 0) { return 1; }
    var symbolic_report_enabled: u64 = annotation_symbolic_report_enabled();

    if (annotation_complexity_count_name(fn, "complexity", 10) > 1 ||
        annotation_complexity_count_name(fn, "complexity_input", 16) > 1 ||
        annotation_complexity_count_name(fn, "complexity_budget", 17) > 1 ||
        annotation_complexity_count_name(fn, "complexity_memo", 15) > 1 ||
        annotation_complexity_count_name(fn, "complexity_ignore", 17) > 1 ||
        annotation_complexity_count_name(fn, "complexity_debug", 16) > 1 ||
        annotation_complexity_count_name(fn, "constraints", 11) > 1 ||
        annotation_complexity_count_name(fn, "time_limit", 10) > 1) {
        emit_stderr("[ERROR] duplicate complexity-related annotation on function ");
        emit_stderr_len(fn.name_ptr, fn.name_len);
        emit_stderr("\n");
        diag_note_error();
        return 0;
    }

    var ignore_ann: *CompilerAnnotationParsed = annotation_complexity_get_single(fn, "complexity_ignore", 17);
    if (ignore_ann != 0) {
        if (symbolic_report_enabled != 0) {
            emit_stderr("[SYMBOLIC_REPORT] function=");
            emit_stderr_len(fn.name_ptr, fn.name_len);
            emit_stderr(" status=ignored reason=annotation\n");
        }
        return 1;
    }

    var complexity_ann: *CompilerAnnotationParsed = annotation_complexity_get_single(fn, "complexity", 10);
    var budget_ann: *CompilerAnnotationParsed = annotation_complexity_get_single(fn, "complexity_budget", 17);
    var debug_ann: *CompilerAnnotationParsed = annotation_complexity_get_single(fn, "complexity_debug", 16);
    var constraints_ann: *CompilerAnnotationParsed = annotation_complexity_get_single(fn, "constraints", 11);
    var constraints_eval: *CompilerAnnotationParsed = annotation_complexity_apply_input_aliases(fn, constraints_ann);
    constraints_eval = annotation_complexity_constraints_expand_relations(constraints_eval);
    var limit_ann: *CompilerAnnotationParsed = annotation_complexity_get_single(fn, "time_limit", 10);

    var infer_reason: u64 = ANN_COMPLEXITY_REASON_UNKNOWN;
    var inferred_mode: u64 = ANN_COMPLEXITY_MODE_UNSPEC;
    var inferred_conf: u64 = ANN_COMPLEXITY_CONF_UNKNOWN;
    var inferred_space_conf: u64 = ANN_COMPLEXITY_CONF_UNKNOWN;
    var declared_time_rank: u64 = 0;
    var declared_space_rank: u64 = 0;
    var declared_time_arg: *CompilerAnnotationArg = 0;
    var declared_space_arg: *CompilerAnnotationArg = 0;
    var budget_time_arg: *CompilerAnnotationArg = 0;
    var budget_space_arg: *CompilerAnnotationArg = 0;
    var declared_mode: u64 = ANN_COMPLEXITY_MODE_UNSPEC;
    var budget_mode: u64 = ANN_COMPLEXITY_MODE_UNSPEC;
    var inferred_time_rank: u64 = annotation_complexity_infer_time_rank_with_meta(fn, constraints_eval, &infer_reason, &inferred_mode, &inferred_conf);
    var inferred_space_rank: u64 = annotation_complexity_infer_space_rank_with_meta(fn, constraints_eval, &inferred_space_conf);
    if (complexity_ann != 0) {
        declared_time_arg = annotation_complexity_find_time_arg(complexity_ann);
        if (declared_time_arg != 0 && declared_time_arg.kind == 3) {
            declared_time_rank = annotation_complexity_rank_from_expr(declared_time_arg.string_ptr, declared_time_arg.string_len);
        }
        declared_space_arg = annotation_complexity_find_named_arg(complexity_ann, "space", 5);
        if (declared_space_arg != 0 && declared_space_arg.kind == 3) {
            declared_space_rank = annotation_complexity_rank_from_expr(declared_space_arg.string_ptr, declared_space_arg.string_len);
        }
        declared_mode = annotation_complexity_parse_mode_arg(annotation_complexity_find_named_arg(complexity_ann, "mode", 4));
    }
    if (budget_ann != 0) {
        budget_mode = annotation_complexity_parse_mode_arg(annotation_complexity_find_named_arg(budget_ann, "mode", 4));
        budget_time_arg = annotation_complexity_find_time_arg(budget_ann);
        budget_space_arg = annotation_complexity_find_named_arg(budget_ann, "space", 5);
    }

    var debug_enabled: u64 = 0;
    var debug_strict_input: u64 = 0;
    var debug_warnings_as_errors: u64 = 0;
    if (debug_ann != 0) {
        debug_enabled = 1;
        var enabled_arg: *CompilerAnnotationArg = annotation_complexity_find_named_arg(debug_ann, "enabled", 7);
        if (enabled_arg != 0 && enabled_arg.kind == 4 && enabled_arg.bool_value == 0) {
            debug_enabled = 0;
        }
        var strict_input_arg: *CompilerAnnotationArg = annotation_complexity_find_named_arg(debug_ann, "strict_input", 12);
        if (strict_input_arg != 0 && strict_input_arg.kind == 4 && strict_input_arg.bool_value != 0) {
            debug_strict_input = 1;
        }
        var wae_arg: *CompilerAnnotationArg = annotation_complexity_find_named_arg(debug_ann, "warnings_as_errors", 18);
        if (wae_arg != 0 && wae_arg.kind == 4 && wae_arg.bool_value != 0) {
            debug_warnings_as_errors = 1;
        }
    }

    var input_ann: *CompilerAnnotationParsed = annotation_complexity_get_single(fn, "complexity_input", 16);
    if (input_ann != 0 && input_ann.args_vec != 0) {
        var in_n: u64 = input_ann.args_vec.len();
        for (var ii: u64 = 0; ii < in_n; ii = ii + 1) {
            var in_arg: *CompilerAnnotationArg = input_ann.args_vec.get(ii);
            if (in_arg == 0 || in_arg.key_ptr == 0 || in_arg.key_len == 0) { continue; }
            var key_used: u64 = 0;
            if (declared_time_arg != 0 && declared_time_arg.kind == 3 &&
                annotation_complexity_expr_contains_ident_token(declared_time_arg.string_ptr, declared_time_arg.string_len, in_arg.key_ptr, in_arg.key_len) != 0) { key_used = 1; }
            if (declared_space_arg != 0 && declared_space_arg.kind == 3 &&
                annotation_complexity_expr_contains_ident_token(declared_space_arg.string_ptr, declared_space_arg.string_len, in_arg.key_ptr, in_arg.key_len) != 0) { key_used = 1; }
            if (budget_time_arg != 0 && budget_time_arg.kind == 3 &&
                annotation_complexity_expr_contains_ident_token(budget_time_arg.string_ptr, budget_time_arg.string_len, in_arg.key_ptr, in_arg.key_len) != 0) { key_used = 1; }
            if (budget_space_arg != 0 && budget_space_arg.kind == 3 &&
                annotation_complexity_expr_contains_ident_token(budget_space_arg.string_ptr, budget_space_arg.string_len, in_arg.key_ptr, in_arg.key_len) != 0) { key_used = 1; }
            if (key_used == 0 && constraints_eval != 0) {
                var key_bound_chk: u64 = 0;
                if (annotation_complexity_constraint_lookup(constraints_eval, in_arg.key_ptr, in_arg.key_len, &key_bound_chk) != 0) { key_used = 1; }
            }

            var mapped_ptr: u64 = 0;
            var mapped_len: u64 = 0;
            var target_known: u64 = 0;
            if (annotation_complexity_extract_input_target_ident(in_arg, &mapped_ptr, &mapped_len) != 0) {
                if (annotation_complexity_fn_has_param(fn, mapped_ptr, mapped_len) != 0) { target_known = 1; }
                if (target_known == 0 && constraints_eval != 0) {
                    var mapped_bound_chk: u64 = 0;
                    if (annotation_complexity_constraint_lookup(constraints_eval, mapped_ptr, mapped_len, &mapped_bound_chk) != 0) { target_known = 1; }
                }
            }

            if (key_used == 0) {
                if (debug_strict_input != 0 || debug_warnings_as_errors != 0) {
                    emit_stderr("[ERROR] complexity_input key appears unused on function ");
                    emit_stderr_len(fn.name_ptr, fn.name_len);
                    emit_stderr(": ");
                    emit_stderr_len(in_arg.key_ptr, in_arg.key_len);
                    emit_stderr("\n");
                    diag_note_error();
                    return 0;
                } else {
                    emit_stderr("[WARN] complexity_input key appears unused on function ");
                    emit_stderr_len(fn.name_ptr, fn.name_len);
                    emit_stderr(": ");
                    emit_stderr_len(in_arg.key_ptr, in_arg.key_len);
                    emit_stderr("\n");
                }
            }
            if (target_known == 0 && mapped_ptr != 0 && mapped_len != 0) {
                if (debug_strict_input != 0 || debug_warnings_as_errors != 0) {
                    emit_stderr("[ERROR] complexity_input target is not a known parameter/constraint symbol on function ");
                    emit_stderr_len(fn.name_ptr, fn.name_len);
                    emit_stderr(": ");
                    emit_stderr_len(mapped_ptr, mapped_len);
                    emit_stderr("\n");
                    diag_note_error();
                    return 0;
                } else {
                    emit_stderr("[WARN] complexity_input target is not a known parameter/constraint symbol on function ");
                    emit_stderr_len(fn.name_ptr, fn.name_len);
                    emit_stderr(": ");
                    emit_stderr_len(mapped_ptr, mapped_len);
                    emit_stderr("\n");
                }
            }
        }
    }

    var compare_time_rank: u64 = inferred_time_rank;
    if (declared_time_rank != 0 && annotation_complexity_rank_order(declared_time_rank) > annotation_complexity_rank_order(compare_time_rank)) {
        compare_time_rank = declared_time_rank;
    }
    if (compare_time_rank == 0) { compare_time_rank = declared_time_rank; }
    var compare_space_rank: u64 = inferred_space_rank;
    if (declared_space_rank != 0 && annotation_complexity_rank_order(declared_space_rank) > annotation_complexity_rank_order(compare_space_rank)) {
        compare_space_rank = declared_space_rank;
    }
    if (compare_space_rank == 0) { compare_space_rank = declared_space_rank; }
    var compare_mode: u64 = declared_mode;
    if (compare_mode == ANN_COMPLEXITY_MODE_UNSPEC) { compare_mode = inferred_mode; }
    if (declared_mode != ANN_COMPLEXITY_MODE_UNSPEC &&
        inferred_mode != ANN_COMPLEXITY_MODE_UNSPEC &&
        declared_mode != inferred_mode) {
        if (debug_warnings_as_errors != 0) {
            emit_stderr("[ERROR] declared complexity mode disagrees with inferred mode on function ");
            emit_stderr_len(fn.name_ptr, fn.name_len);
            emit_stderr(": declared=");
            emit_stderr(annotation_complexity_mode_name(declared_mode));
            emit_stderr(", inferred=");
            emit_stderr(annotation_complexity_mode_name(inferred_mode));
            emit_stderr("\n");
            diag_note_error();
            return 0;
        } else {
            emit_stderr("[WARN] declared complexity mode disagrees with inferred mode on function ");
            emit_stderr_len(fn.name_ptr, fn.name_len);
            emit_stderr(": declared=");
            emit_stderr(annotation_complexity_mode_name(declared_mode));
            emit_stderr(", inferred=");
            emit_stderr(annotation_complexity_mode_name(inferred_mode));
            emit_stderr("\n");
        }
    }
    if (declared_time_rank != 0 && inferred_time_rank != 0 &&
        annotation_complexity_rank_exceeds(inferred_time_rank, declared_time_rank) != 0) {
        emit_stderr("[ERROR] declared complexity underestimates inferred complexity on function ");
        emit_stderr_len(fn.name_ptr, fn.name_len);
        emit_stderr(": inferred=");
        emit_stderr(annotation_complexity_rank_name(inferred_time_rank));
        emit_stderr(", declared=");
        emit_stderr(annotation_complexity_rank_name(declared_time_rank));
        if (inferred_conf == ANN_COMPLEXITY_CONF_UNKNOWN) { emit_stderr(", confidence=unknown"); }
        emit_stderr("\n");
        diag_note_error();
        return 0;
    }
    if (declared_space_rank != 0 && inferred_space_rank != 0 &&
        annotation_complexity_rank_exceeds(inferred_space_rank, declared_space_rank) != 0) {
        emit_stderr("[ERROR] declared complexity underestimates inferred space complexity on function ");
        emit_stderr_len(fn.name_ptr, fn.name_len);
        emit_stderr(": inferred=");
        emit_stderr(annotation_complexity_rank_name(inferred_space_rank));
        emit_stderr(", declared=");
        emit_stderr(annotation_complexity_rank_name(declared_space_rank));
        if (inferred_space_conf == ANN_COMPLEXITY_CONF_UNKNOWN) { emit_stderr(", confidence=unknown"); }
        emit_stderr("\n");
        diag_note_error();
        return 0;
    }
    if (budget_mode != ANN_COMPLEXITY_MODE_UNSPEC && compare_mode != ANN_COMPLEXITY_MODE_UNSPEC && budget_mode != compare_mode) {
        emit_stderr("[ERROR] complexity mode mismatch on function ");
        emit_stderr_len(fn.name_ptr, fn.name_len);
        emit_stderr(": inferred/declared mode=");
        emit_stderr(annotation_complexity_mode_name(compare_mode));
        emit_stderr(", budget mode=");
        emit_stderr(annotation_complexity_mode_name(budget_mode));
        emit_stderr("\n");
        diag_note_error();
        return 0;
    }
    var inferred_ops_precise: u64 = 0;
    var inferred_space_precise: u64 = 0;
    if (constraints_eval != 0) {
        var max_bound_precise: u64 = annotation_complexity_constraints_max(constraints_eval);
        if (inferred_time_rank == 9 || inferred_time_rank == 10 || inferred_time_rank == 11) {
            inferred_ops_precise = annotation_complexity_estimate_ops(inferred_time_rank, max_bound_precise);
        } else {
            inferred_ops_precise = annotation_complexity_estimate_ast_ops(fn, constraints_eval);
        }
        inferred_space_precise = annotation_complexity_estimate_ops(compare_space_rank, max_bound_precise);
    }

    var budget_rank_debug: u64 = 0;
    var budget_space_rank_debug: u64 = 0;
    if (budget_ann != 0) {
        var budget_time_debug: *CompilerAnnotationArg = annotation_complexity_find_time_arg(budget_ann);
        if (budget_time_debug != 0 && budget_time_debug.kind == 3) {
            budget_rank_debug = annotation_complexity_rank_from_expr(budget_time_debug.string_ptr, budget_time_debug.string_len);
        }
        var budget_space_debug: *CompilerAnnotationArg = annotation_complexity_find_named_arg(budget_ann, "space", 5);
        if (budget_space_debug != 0 && budget_space_debug.kind == 3) {
            budget_space_rank_debug = annotation_complexity_rank_from_expr(budget_space_debug.string_ptr, budget_space_debug.string_len);
        }
    }

    var loop_total: u64 = 0;
    var loop_sqrt: u64 = 0;
    var loop_geo: u64 = 0;
    var loop_linear: u64 = 0;
    var recur_total_dbg: u64 = 0;
    var recur_half_dbg: u64 = 0;
    var recur_minus_dbg: u64 = 0;
    var recur_same_dbg: u64 = 0;
    var max_depth_dbg: u64 = 0;
    var self_calls_dbg: u64 = 0;
    var ext_calls_dbg: u64 = 0;
    var ext_unknown_dbg: u64 = 0;
    var ext_rank_dbg: u64 = 0;
    var ssa_summary_dbg: *AnnComplexitySSASummary = annotation_complexity_ssa_summary_for(fn);
    if (fn != 0 && fn.body != 0) {
        var fb_dbg: u64 = annotation_complexity_constraints_max(constraints_eval);
        var ext_symtab_dbg: *HashMap<u64, *TypeInfo> = generic_build_symtab_for_func(fn);
        annotation_complexity_collect_loop_stats(fn.body, constraints_eval, fb_dbg, &loop_total, &loop_sqrt, &loop_geo, &loop_linear);
        annotation_complexity_scan_stmt_self_call_patterns(fn.body, fn.name_ptr, fn.name_len, &recur_total_dbg, &recur_half_dbg, &recur_minus_dbg, &recur_same_dbg);
        annotation_complexity_scan_stmt(fn.body, fn.name_ptr, fn.name_len, 0, &max_depth_dbg, &self_calls_dbg);
        annotation_complexity_scan_stmt_external_call_summary(fn.body, fn, ext_symtab_dbg, fn.name_ptr, fn.name_len, &ext_rank_dbg, &ext_unknown_dbg, &ext_calls_dbg);
    }

    if (debug_enabled != 0) {
        emit_stderr("[COMPLEXITY_DEBUG] function=");
        emit_stderr_len(fn.name_ptr, fn.name_len);
        emit_stderr(" inferred_time=");
        emit_stderr(annotation_complexity_rank_name(inferred_time_rank));
        emit_stderr(" inferred_space=");
        emit_stderr(annotation_complexity_rank_name(inferred_space_rank));
        emit_stderr(" declared_time=");
        if (declared_time_rank != 0) { emit_stderr(annotation_complexity_rank_name(declared_time_rank)); }
        else { emit_stderr("none"); }
        emit_stderr(" declared_space=");
        if (declared_space_rank != 0) { emit_stderr(annotation_complexity_rank_name(declared_space_rank)); }
        else { emit_stderr("none"); }
        emit_stderr(" compare_time=");
        emit_stderr(annotation_complexity_rank_name(compare_time_rank));
        emit_stderr(" compare_space=");
        emit_stderr(annotation_complexity_rank_name(compare_space_rank));
        emit_stderr(" budget_time=");
        if (budget_rank_debug != 0) { emit_stderr(annotation_complexity_rank_name(budget_rank_debug)); }
        else { emit_stderr("none"); }
        emit_stderr(" budget_space=");
        if (budget_space_rank_debug != 0) { emit_stderr(annotation_complexity_rank_name(budget_space_rank_debug)); }
        else { emit_stderr("none"); }
        emit_stderr(" reason=");
        emit_stderr(annotation_complexity_reason_name(infer_reason));
        emit_stderr(" mode=");
        emit_stderr(annotation_complexity_mode_name(compare_mode));
        emit_stderr(" confidence=");
        emit_stderr(annotation_complexity_confidence_name(inferred_conf));
        emit_stderr(" space_confidence=");
        emit_stderr(annotation_complexity_confidence_name(inferred_space_conf));
        emit_stderr(" loops=");
        emit_u64_stderr(loop_total);
        emit_stderr(" sqrt_loops=");
        emit_u64_stderr(loop_sqrt);
        emit_stderr(" geo_loops=");
        emit_u64_stderr(loop_geo);
        emit_stderr(" linear_loops=");
        emit_u64_stderr(loop_linear);
        emit_stderr(" recur_total=");
        emit_u64_stderr(recur_total_dbg);
        emit_stderr(" recur_half=");
        emit_u64_stderr(recur_half_dbg);
        emit_stderr(" recur_minus=");
        emit_u64_stderr(recur_minus_dbg);
        emit_stderr(" recur_same=");
        emit_u64_stderr(recur_same_dbg);
        emit_stderr(" self_calls=");
        emit_u64_stderr(self_calls_dbg);
        emit_stderr(" max_depth=");
        emit_u64_stderr(max_depth_dbg);
        emit_stderr(" ext_calls=");
        emit_u64_stderr(ext_calls_dbg);
        emit_stderr(" ext_unknown=");
        emit_u64_stderr(ext_unknown_dbg);
        emit_stderr(" ext_rank=");
        emit_stderr(annotation_complexity_rank_name(ext_rank_dbg));
        if (ssa_summary_dbg != 0) {
            emit_stderr(" ssa_time=");
            emit_stderr(annotation_complexity_rank_name(ssa_summary_dbg.total_rank));
            emit_stderr(" ssa_conf=");
            emit_stderr(annotation_complexity_confidence_name(ssa_summary_dbg.conf));
            emit_stderr(" ssa_backedges=");
            emit_u64_stderr(ssa_summary_dbg.backedge_count);
            emit_stderr(" ssa_loop_depth=");
            emit_u64_stderr(ssa_summary_dbg.loop_depth);
            emit_stderr(" ssa_phi=");
            emit_u64_stderr(ssa_summary_dbg.phi_count);
            emit_stderr(" ssa_calls=");
            emit_u64_stderr(ssa_summary_dbg.call_count);
            emit_stderr(" ssa_call_ptr=");
            emit_u64_stderr(ssa_summary_dbg.call_ptr_count);
        }
        emit_stderr("\n");
    }

    if (budget_ann != 0) {
        var budget_time_conf_arg: *CompilerAnnotationArg = annotation_complexity_find_time_arg(budget_ann);
        var budget_space_conf_arg: *CompilerAnnotationArg = annotation_complexity_find_named_arg(budget_ann, "space", 5);
        if (budget_time_conf_arg != 0 && inferred_conf == ANN_COMPLEXITY_CONF_UNKNOWN) {
            emit_stderr("[ERROR] complexity confidence UNKNOWN on function ");
            emit_stderr_len(fn.name_ptr, fn.name_len);
            emit_stderr(" (cannot enforce complexity_budget.time safely)\n");
            diag_note_error();
            return 0;
        }
        if (budget_space_conf_arg != 0 && inferred_space_conf == ANN_COMPLEXITY_CONF_UNKNOWN) {
            emit_stderr("[ERROR] complexity space confidence UNKNOWN on function ");
            emit_stderr_len(fn.name_ptr, fn.name_len);
            emit_stderr(" (cannot enforce complexity_budget.space safely)\n");
            diag_note_error();
            return 0;
        }
    }

    if (budget_ann != 0) {
        var budget_slack_mult: u64 = annotation_complexity_budget_slack_multiplier(compare_mode, inferred_conf);
        var space_budget_slack_mult: u64 = annotation_complexity_budget_slack_multiplier(compare_mode, inferred_space_conf);
        var budget_time: *CompilerAnnotationArg = annotation_complexity_find_time_arg(budget_ann);
        if (budget_time != 0 && budget_time.kind == 3) {
            var budget_rank: u64 = annotation_complexity_rank_from_expr(budget_time.string_ptr, budget_time.string_len);
            var budget_ops_ok: u64 = 0;
            var budget_ops_expr: u64 = 0;
            if (constraints_eval != 0) {
                budget_ops_expr = annotation_complexity_eval_o_expr_ops(budget_time.string_ptr, budget_time.string_len, constraints_eval, &budget_ops_ok);
            }
            var budget_fail_threshold: u64 = annotation_complexity_sat_mul(budget_ops_expr, budget_slack_mult, 9223372036854775807);
            if (constraints_eval != 0 && budget_rank == 0 && budget_ops_ok == 0) {
                emit_stderr("[ERROR] complexity budget on function ");
                emit_stderr_len(fn.name_ptr, fn.name_len);
                emit_stderr(" is not enforceable: unsupported time expression for numeric evaluation\n");
                diag_note_error();
                return 0;
            }
            if (budget_ops_ok != 0 && inferred_ops_precise != 0 && budget_ops_expr != 0 &&
                inferred_ops_precise > budget_fail_threshold) {
                emit_stderr("[ERROR] complexity budget violated on function ");
                emit_stderr_len(fn.name_ptr, fn.name_len);
                emit_stderr(": estimated ops ");
                emit_u64_stderr(inferred_ops_precise);
                emit_stderr(" exceeds budget ops (with constant-factor slack) ");
                emit_u64_stderr(budget_ops_expr);
                emit_stderr(" x");
                emit_u64_stderr(budget_slack_mult);
                emit_stderr("\n");
                diag_note_error();
                return 0;
            }
            if (constraints_eval != 0 && declared_time_arg != 0 && declared_time_arg.kind == 3) {
                var dom_decidable: u64 = 0;
                var dom_conf: u64 = ANN_COMPLEXITY_CONF_UNKNOWN;
                var dom_ok: u64 = annotation_complexity_expr_dominated_by(
                    declared_time_arg.string_ptr, declared_time_arg.string_len,
                    budget_time.string_ptr, budget_time.string_len,
                    constraints_eval, &dom_decidable, &dom_conf
                );
                if (dom_decidable != 0) {
                    if (dom_ok == 0) {
                        emit_stderr("[ERROR] complexity budget violated on function ");
                        emit_stderr_len(fn.name_ptr, fn.name_len);
                        emit_stderr(": declared time expression is not dominated by budget expression (confidence=");
                        emit_stderr(annotation_complexity_confidence_name(dom_conf));
                        emit_stderr(") declared=");
                        emit_stderr_len(declared_time_arg.string_ptr, declared_time_arg.string_len);
                        emit_stderr(" budget=");
                        emit_stderr_len(budget_time.string_ptr, budget_time.string_len);
                        emit_stderr(")\n");
                        diag_note_error();
                        return 0;
                    }
                } else {
                    var growth_ok: u64 = 0;
                    if (annotation_complexity_expr_growth_exceeds(declared_time_arg.string_ptr, declared_time_arg.string_len,
                                                                  budget_time.string_ptr, budget_time.string_len,
                                                                  constraints_eval, &growth_ok) != 0 && growth_ok != 0) {
                        emit_stderr("[ERROR] complexity budget violated on function ");
                        emit_stderr_len(fn.name_ptr, fn.name_len);
                        emit_stderr(": declared time expression grows faster than budget expression under constraints (declared=");
                        emit_stderr_len(declared_time_arg.string_ptr, declared_time_arg.string_len);
                        emit_stderr(", budget=");
                        emit_stderr_len(budget_time.string_ptr, budget_time.string_len);
                        emit_stderr(")\n");
                        diag_note_error();
                        return 0;
                    }
                }
            }
            if (budget_rank != 0 && compare_time_rank != 0 &&
                annotation_complexity_rank_exceeds(compare_time_rank, budget_rank) != 0) {
                emit_stderr("[ERROR] complexity budget violated on function ");
                emit_stderr_len(fn.name_ptr, fn.name_len);
                emit_stderr(": inferred/declared ");
                emit_stderr(annotation_complexity_rank_name(compare_time_rank));
                emit_stderr(" exceeds budget ");
                emit_stderr(annotation_complexity_rank_name(budget_rank));
                emit_stderr(" (confidence=");
                emit_stderr(annotation_complexity_confidence_name(inferred_conf));
                emit_stderr(")");
                emit_stderr("\n");
                diag_note_error();
                return 0;
            }
        }

        var budget_space: *CompilerAnnotationArg = annotation_complexity_find_named_arg(budget_ann, "space", 5);
        if (budget_space != 0 && budget_space.kind == 3) {
            var budget_space_rank: u64 = annotation_complexity_rank_from_expr(budget_space.string_ptr, budget_space.string_len);
            var budget_space_ok: u64 = 0;
            var budget_space_expr: u64 = 0;
            if (constraints_eval != 0) {
                budget_space_expr = annotation_complexity_eval_o_expr_ops(budget_space.string_ptr, budget_space.string_len, constraints_eval, &budget_space_ok);
            }
            var budget_space_fail_threshold: u64 = annotation_complexity_sat_mul(budget_space_expr, space_budget_slack_mult, 9223372036854775807);
            if (constraints_eval != 0 && budget_space_rank == 0 && budget_space_ok == 0) {
                emit_stderr("[ERROR] complexity budget on function ");
                emit_stderr_len(fn.name_ptr, fn.name_len);
                emit_stderr(" is not enforceable: unsupported space expression for numeric evaluation\n");
                diag_note_error();
                return 0;
            }
            if (budget_space_ok != 0 && inferred_space_precise != 0 && budget_space_expr != 0 &&
                inferred_space_precise > budget_space_fail_threshold) {
                emit_stderr("[ERROR] complexity space budget violated on function ");
                emit_stderr_len(fn.name_ptr, fn.name_len);
                emit_stderr(": estimated units ");
                emit_u64_stderr(inferred_space_precise);
                emit_stderr(" exceed budget units (with constant-factor slack) ");
                emit_u64_stderr(budget_space_expr);
                emit_stderr(" x");
                emit_u64_stderr(space_budget_slack_mult);
                emit_stderr("\n");
                diag_note_error();
                return 0;
            }
            if (constraints_eval != 0 && declared_space_arg != 0 && declared_space_arg.kind == 3) {
                var sdom_decidable: u64 = 0;
                var sdom_conf: u64 = ANN_COMPLEXITY_CONF_UNKNOWN;
                var sdom_ok: u64 = annotation_complexity_expr_dominated_by(
                    declared_space_arg.string_ptr, declared_space_arg.string_len,
                    budget_space.string_ptr, budget_space.string_len,
                    constraints_eval, &sdom_decidable, &sdom_conf
                );
                if (sdom_decidable != 0) {
                    if (sdom_ok == 0) {
                        emit_stderr("[ERROR] complexity space budget violated on function ");
                        emit_stderr_len(fn.name_ptr, fn.name_len);
                        emit_stderr(": declared space expression is not dominated by budget expression (confidence=");
                        emit_stderr(annotation_complexity_confidence_name(sdom_conf));
                        emit_stderr(") declared=");
                        emit_stderr_len(declared_space_arg.string_ptr, declared_space_arg.string_len);
                        emit_stderr(" budget=");
                        emit_stderr_len(budget_space.string_ptr, budget_space.string_len);
                        emit_stderr(")\n");
                        diag_note_error();
                        return 0;
                    }
                } else {
                    var sgrowth_ok: u64 = 0;
                    if (annotation_complexity_expr_growth_exceeds(declared_space_arg.string_ptr, declared_space_arg.string_len,
                                                                  budget_space.string_ptr, budget_space.string_len,
                                                                  constraints_eval, &sgrowth_ok) != 0 && sgrowth_ok != 0) {
                        emit_stderr("[ERROR] complexity space budget violated on function ");
                        emit_stderr_len(fn.name_ptr, fn.name_len);
                        emit_stderr(": declared space expression grows faster than budget expression under constraints (declared=");
                        emit_stderr_len(declared_space_arg.string_ptr, declared_space_arg.string_len);
                        emit_stderr(", budget=");
                        emit_stderr_len(budget_space.string_ptr, budget_space.string_len);
                        emit_stderr(")\n");
                        diag_note_error();
                        return 0;
                    }
                }
            }
            if (budget_space_rank != 0 && compare_space_rank != 0 &&
                annotation_complexity_rank_exceeds(compare_space_rank, budget_space_rank) != 0) {
                emit_stderr("[ERROR] complexity space budget violated on function ");
                emit_stderr_len(fn.name_ptr, fn.name_len);
                emit_stderr(": inferred/declared ");
                emit_stderr(annotation_complexity_rank_name(compare_space_rank));
                emit_stderr(" exceeds budget ");
                emit_stderr(annotation_complexity_rank_name(budget_space_rank));
                emit_stderr(" (confidence=");
                emit_stderr(annotation_complexity_confidence_name(inferred_space_conf));
                emit_stderr(")");
                emit_stderr("\n");
                diag_note_error();
                return 0;
            }
        }
    }

    if (limit_ann != 0) {
        var ms_arg: *CompilerAnnotationArg = annotation_complexity_find_named_arg(limit_ann, "ms", 2);
        if (ms_arg != 0 && ms_arg.kind == 2) {
            if (constraints_eval == 0) {
                emit_stderr("[ERROR] time_limit on function ");
                emit_stderr_len(fn.name_ptr, fn.name_len);
                emit_stderr(" requires @constraints(...) for bounded static estimation\n");
                diag_note_error();
                return 0;
            }
            var max_bound: u64 = annotation_complexity_constraints_max(constraints_eval);

            var ops_est: u64 = annotation_complexity_estimate_ops(compare_time_rank, max_bound);
            if (inferred_ops_precise != 0) { ops_est = inferred_ops_precise; }
            if (ops_est == 0) {
                emit_stderr("[ERROR] time_limit on function ");
                emit_stderr_len(fn.name_ptr, fn.name_len);
                emit_stderr(" is not enforceable: unknown complexity estimate\n");
                diag_note_error();
                return 0;
            }
            var ops_per_ms: u64 = 200000;
            var machine_arg: *CompilerAnnotationArg = annotation_complexity_find_named_arg(limit_ann, "machine", 7);
            if (machine_arg != 0) {
                if (machine_arg.kind == 3 && str_eq(machine_arg.string_ptr, machine_arg.string_len, "ref_v1", 6) != 0) {
                    ops_per_ms = 200000;
                } else if (machine_arg.kind == 3 && str_eq(machine_arg.string_ptr, machine_arg.string_len, "ref_v2", 6) != 0) {
                    ops_per_ms = 350000;
                }
            }
            var ops_override_arg: *CompilerAnnotationArg = annotation_complexity_find_named_arg(limit_ann, "ops_per_ms", 10);
            if (ops_override_arg != 0 && ops_override_arg.kind == 2 && ops_override_arg.int_value > 0) {
                ops_per_ms = ops_override_arg.int_value;
            }

            var budget_ops: u64 = annotation_complexity_sat_mul(ms_arg.int_value, ops_per_ms, 9223372036854775807);
            var fail_slack_ppm: u64 = annotation_complexity_time_limit_slack_ppm(compare_mode, inferred_conf);
            var fail_threshold: u64 = annotation_complexity_sat_mul(budget_ops, fail_slack_ppm, 9223372036854775807) / 1000000;
            if (debug_enabled != 0) {
                emit_stderr("[COMPLEXITY_DEBUG] function=");
                emit_stderr_len(fn.name_ptr, fn.name_len);
                emit_stderr(" max_bound=");
                emit_u64_stderr(max_bound);
                emit_stderr(" estimated_ops=");
                emit_u64_stderr(ops_est);
                emit_stderr(" estimated_ops_ast=");
                emit_u64_stderr(inferred_ops_precise);
                emit_stderr(" budget_ops=");
                emit_u64_stderr(budget_ops);
                emit_stderr(" time_limit_ms=");
                emit_u64_stderr(ms_arg.int_value);
                emit_stderr(" ops_per_ms=");
                emit_u64_stderr(ops_per_ms);
                emit_stderr("\n");

                emit_stderr("[COMPLEXITY_METRIC] function=");
                emit_stderr_len(fn.name_ptr, fn.name_len);
                emit_stderr(" mode=");
                emit_stderr(annotation_complexity_mode_name(compare_mode));
                emit_stderr(" reason=");
                emit_stderr(annotation_complexity_reason_name(infer_reason));
                emit_stderr(" confidence=");
                emit_stderr(annotation_complexity_confidence_name(inferred_conf));
                emit_stderr(" estimated_ops=");
                emit_u64_stderr(ops_est);
                emit_stderr(" budget_ops=");
                emit_u64_stderr(budget_ops);
                emit_stderr(" utilization_ppm=");
                if (budget_ops == 0) { emit_u64_stderr(0); }
                else { emit_u64_stderr(annotation_complexity_sat_mul(ops_est, 1000000, 9223372036854775807) / budget_ops); }
                emit_stderr("\n");
            }
            if (budget_ops != 0 && ops_est > fail_threshold) {
                emit_stderr("[ERROR] time-limit prediction FAIL on function ");
                emit_stderr_len(fn.name_ptr, fn.name_len);
                emit_stderr(" (estimated ops exceed budget)\n");
                diag_note_error();
                return 0;
            }
            if (budget_ops != 0 && ops_est > (budget_ops * 6) / 10) {
                if (debug_warnings_as_errors != 0) {
                    emit_stderr("[ERROR] time-limit prediction RISK on function ");
                    emit_stderr_len(fn.name_ptr, fn.name_len);
                    emit_stderr(" (warnings_as_errors=true)\n");
                    diag_note_error();
                    return 0;
                } else {
                    emit_stderr("[WARN] time-limit prediction RISK on function ");
                    emit_stderr_len(fn.name_ptr, fn.name_len);
                    emit_stderr("\n");
                }
            }
        }
    }

    if (symbolic_report_enabled != 0) {
        emit_stderr("[SYMBOLIC_REPORT] function=");
        emit_stderr_len(fn.name_ptr, fn.name_len);
        emit_stderr(" time=");
        emit_stderr(annotation_complexity_rank_name(inferred_time_rank));
        emit_stderr(" space=");
        emit_stderr(annotation_complexity_rank_name(inferred_space_rank));
        emit_stderr(" mode=");
        emit_stderr(annotation_complexity_mode_name(compare_mode));
        emit_stderr(" reason=");
        emit_stderr(annotation_complexity_reason_name(infer_reason));
        emit_stderr(" confidence=");
        emit_stderr(annotation_complexity_confidence_name(inferred_conf));
        if (ssa_summary_dbg != 0) {
            emit_stderr(" ssa_time=");
            emit_stderr(annotation_complexity_rank_name(ssa_summary_dbg.total_rank));
            emit_stderr(" ssa_conf=");
            emit_stderr(annotation_complexity_confidence_name(ssa_summary_dbg.conf));
            emit_stderr(" ssa_loop_depth=");
            emit_u64_stderr(ssa_summary_dbg.loop_depth);
            emit_stderr(" ssa_calls=");
            emit_u64_stderr(ssa_summary_dbg.call_count);
            emit_stderr(" ssa_unresolved_calls=");
            emit_u64_stderr(ssa_summary_dbg.unresolved_calls);
        }
        if (constraints_eval != 0) {
            emit_stderr(" max_bound=");
            emit_u64_stderr(annotation_complexity_constraints_max(constraints_eval));
        }
        emit_stderr("\n");
    }

    return 1;
}

func annotation_validate_builtin_args(fn: *AstFunc, ann: *CompilerAnnotationParsed) -> u64 {
    if (ann == 0) { return 0; }
    var args_n: u64 = 0;
    if (ann.args_vec != 0) { args_n = ann.args_vec.len(); }

    if (str_eq(ann.name_ptr, ann.name_len, "trace", 5) != 0) {
        for (var i: u64 = 0; i < args_n; i++) {
            var arg: *CompilerAnnotationArg = ann.args_vec.get(i);
            if (arg == 0) { return annotation_emit_invalid_args(fn, ann, "trace only accepts bool/int scalar arguments"); }
            if (arg.key_ptr != 0) {
                if (str_eq(arg.key_ptr, arg.key_len, "enabled", 7) == 0 &&
                    str_eq(arg.key_ptr, arg.key_len, "level", 5) == 0) {
                    return annotation_emit_invalid_args(fn, ann, "trace supports named args: enabled=bool, level=int");
                }
            }
            if (arg.kind != 4 && arg.kind != 2) {
                return annotation_emit_invalid_args(fn, ann, "trace only accepts bool/int scalar arguments");
            }
        }
        return 1;
    }

    if (str_eq(ann.name_ptr, ann.name_len, "config", 6) != 0) {
        if (args_n == 0) {
            return annotation_emit_invalid_args(fn, ann, "config requires at least one key=value argument");
        }
        for (var i2: u64 = 0; i2 < args_n; i2++) {
            var arg2: *CompilerAnnotationArg = ann.args_vec.get(i2);
            if (arg2 == 0 || arg2.key_ptr == 0 || arg2.key_len == 0) {
                return annotation_emit_invalid_args(fn, ann, "config arguments must be key=value pairs");
            }
            if (arg2.kind != 3 && arg2.kind != 2 && arg2.kind != 4) {
                return annotation_emit_invalid_args(fn, ann, "config values must be string/int/bool");
            }
        }
        return 1;
    }

    if (str_eq(ann.name_ptr, ann.name_len, "complexity", 10) != 0 ||
        str_eq(ann.name_ptr, ann.name_len, "complexity_input", 16) != 0 ||
        str_eq(ann.name_ptr, ann.name_len, "complexity_budget", 17) != 0 ||
        str_eq(ann.name_ptr, ann.name_len, "complexity_memo", 15) != 0 ||
        str_eq(ann.name_ptr, ann.name_len, "complexity_ignore", 17) != 0 ||
        str_eq(ann.name_ptr, ann.name_len, "complexity_debug", 16) != 0 ||
        str_eq(ann.name_ptr, ann.name_len, "constraints", 11) != 0 ||
        str_eq(ann.name_ptr, ann.name_len, "time_limit", 10) != 0) {
        return annotation_complexity_validate_annotation_args(fn, ann);
    }

    if (args_n != 0) {
        return annotation_emit_invalid_args(fn, ann, "this built-in annotation does not take arguments");
    }
    return 1;
}

func annotation_validate_function_annotations(fn: *AstFunc) -> u64 {
    if (fn == 0) { return 1; }
    if (fn.annotations_vec == 0) {
        if (annotation_symbolic_report_enabled() != 0) {
            return annotation_complexity_validate_contract(fn);
        }
        return 1;
    }
    var ok: u64 = 1;
    var n: u64 = fn.annotations_vec.len();
    for (var i: u64 = 0; i < n; i++) {
        if (diag_should_stop_pass() != 0) { break; }
        var info: *NameInfo = fn.annotations_vec.get(i);
        var ann: *CompilerAnnotationParsed = annotation_parse(info);
        if (ann.parse_ok == 0 || ann.name_ptr == 0 || ann.name_len == 0) {
            emit_stderr("[ERROR] malformed annotation on function ");
            emit_stderr_len(fn.name_ptr, fn.name_len);
            emit_stderr(": ");
            if (info != 0) { emit_stderr_len(info.ptr, info.len); }
            emit_stderr("\n");
            diag_note_error();
            ok = 0;
            continue;
        }
        if (annotation_is_builtin_name(ann.name_ptr, ann.name_len) != 0) {
            if (annotation_validate_builtin_args(fn, ann) == 0) {
                ok = 0;
            }
        } else {
            var args_n: u64 = 0;
            if (ann.args_vec != 0) { args_n = ann.args_vec.len(); }
            if (args_n != 0) {
                annotation_emit_invalid_args(fn, ann, "decorator annotations currently do not accept arguments");
                ok = 0;
            }
        }
    }
    if (ok != 0) {
        var hot_count: u64 = annotation_count_name(fn.annotations_vec, "hot", 3);
        var cold_count: u64 = annotation_count_name(fn.annotations_vec, "cold", 4);
        if (hot_count > 0 && cold_count > 0) {
            emit_stderr("[ERROR] @[hot] and @[cold] cannot be used together on function: ");
            emit_stderr_len(fn.name_ptr, fn.name_len);
            emit_stderr("\n");
            diag_note_error();
            ok = 0;
        }
        if (ok != 0) {
            if (annotation_complexity_validate_contract(fn) == 0) {
                ok = 0;
            }
        }
    }
    return ok;
}

func annotation_base_len(name_ptr: u64, name_len: u64) -> u64 {
    if (name_ptr == 0 || name_len == 0) { return 0; }
    var s: []u8 = slice(name_ptr, name_len);
    for (var i: u64 = 0; i < name_len; i++) {
        if (s[i] == 40) { // '('
            return i;
        }
    }
    return name_len;
}

func annotation_is_builtin_name(name_ptr: u64, name_len: u64) -> u64 {
    var base_len: u64 = annotation_base_len(name_ptr, name_len);
    if (str_eq(name_ptr, base_len, "override", 8) != 0) { return 1; }
    if (str_eq(name_ptr, base_len, "entry", 5) != 0) { return 1; }
    if (str_eq(name_ptr, base_len, "used", 4) != 0) { return 1; }
    if (str_eq(name_ptr, base_len, "hot", 3) != 0) { return 1; }
    if (str_eq(name_ptr, base_len, "cold", 4) != 0) { return 1; }
    if (str_eq(name_ptr, base_len, "trace", 5) != 0) { return 1; }
    if (str_eq(name_ptr, base_len, "config", 6) != 0) { return 1; }
    if (str_eq(name_ptr, base_len, "complexity", 10) != 0) { return 1; }
    if (str_eq(name_ptr, base_len, "complexity_input", 16) != 0) { return 1; }
    if (str_eq(name_ptr, base_len, "complexity_budget", 17) != 0) { return 1; }
    if (str_eq(name_ptr, base_len, "complexity_memo", 15) != 0) { return 1; }
    if (str_eq(name_ptr, base_len, "complexity_ignore", 17) != 0) { return 1; }
    if (str_eq(name_ptr, base_len, "complexity_debug", 16) != 0) { return 1; }
    if (str_eq(name_ptr, base_len, "constraints", 11) != 0) { return 1; }
    if (str_eq(name_ptr, base_len, "time_limit", 10) != 0) { return 1; }
    return 0;
}

func annotation_count_name(annotations: *Vec<*NameInfo>, name_ptr: u64, name_len: u64) -> u64 {
    if (annotations == 0) { return 0; }
    var n: u64 = annotations.len();
    var count: u64 = 0;
    for (var i: u64 = 0; i < n; i++) {
        var ann: *NameInfo = annotations.get(i);
        var base_len: u64 = annotation_base_len(ann.ptr, ann.len);
        if (base_len == name_len && str_eq(ann.ptr, base_len, name_ptr, name_len) != 0) {
            count = count + 1;
        }
    }
    return count;
}

func annotation_param_shape_equal(a: *Param, b: *Param) -> u64 {
    if (a == 0 || b == 0) { return 0; }
    if (a.type_kind != b.type_kind) { return 0; }
    if (a.ptr_depth != b.ptr_depth) { return 0; }
    if (a.is_tagged != b.is_tagged) { return 0; }
    if (a.elem_type_kind != b.elem_type_kind) { return 0; }
    if (a.elem_ptr_depth != b.elem_ptr_depth) { return 0; }
    if (a.array_len != b.array_len) { return 0; }
    if (a.array_len_is_param != b.array_len_is_param) { return 0; }
    if (a.array_len_is_param != 0) {
        if (str_eq(a.array_len_param_ptr, a.array_len_param_len, b.array_len_param_ptr, b.array_len_param_len) == 0) {
            return 0;
        }
    }
    if (a.type_kind == TYPE_STRUCT || a.type_kind == TYPE_GENERIC || a.type_kind == TYPE_TRAIT || a.type_kind == TYPE_ARRAY || a.type_kind == TYPE_SLICE) {
        if (str_eq(a.struct_name_ptr, a.struct_name_len, b.struct_name_ptr, b.struct_name_len) == 0) {
            return 0;
        }
    }
    if (a.type_kind == TYPE_FUNC) {
        if ((a.elem_typeinfo == 0) != (b.elem_typeinfo == 0)) { return 0; }
        if (a.elem_typeinfo != 0 && generic_type_equal(a.elem_typeinfo, b.elem_typeinfo) == 0) {
            return 0;
        }
    }
    if (a.is_tagged != 0) {
        if (str_eq(a.tag_layout_ptr, a.tag_layout_len, b.tag_layout_ptr, b.tag_layout_len) == 0) {
            return 0;
        }
    }
    return 1;
}

func annotation_return_shape_equal(lhs: *AstFunc, rhs: *AstFunc) -> u64 {
    if (lhs == 0 || rhs == 0) { return 0; }
    if (lhs.ret_type != rhs.ret_type) { return 0; }
    if (lhs.ret_ptr_depth != rhs.ret_ptr_depth) { return 0; }
    if (lhs.ret_is_tagged != rhs.ret_is_tagged) { return 0; }
    if (lhs.ret_type == TYPE_STRUCT || lhs.ret_type == TYPE_GENERIC || lhs.ret_type == TYPE_TRAIT || lhs.ret_type == TYPE_ARRAY || lhs.ret_type == TYPE_SLICE) {
        if (str_eq(lhs.ret_struct_name_ptr, lhs.ret_struct_name_len, rhs.ret_struct_name_ptr, rhs.ret_struct_name_len) == 0) {
            return 0;
        }
    }
    if (lhs.ret_is_tagged != 0) {
        if (str_eq(lhs.ret_tag_layout_ptr, lhs.ret_tag_layout_len, rhs.ret_tag_layout_ptr, rhs.ret_tag_layout_len) == 0) {
            return 0;
        }
    }
    return 1;
}

func annotation_clone_params(params: *Vec<*Param>) -> *Vec<*Param> {
    if (params == 0) { return new Vec<*Param>(1); }
    var n: u64 = params.len();
    var out: *Vec<*Param> = new Vec<*Param>(n + 1);
    for (var i: u64 = 0; i < n; i++) {
        out.push(module_util_clone_param(params.get(i)));
    }
    return out;
}

func annotation_clone_sig(template: *AstFunc, new_name_ptr: u64, new_name_len: u64) -> *AstFunc {
    var params_out: *Vec<*Param> = annotation_clone_params(template.params_vec);
    var sig_out: *AstFunc = ast_func_ex(new_name_ptr, new_name_len, params_out,
                                        template.ret_type, template.ret_ptr_depth, template.ret_is_tagged,
                                        template.ret_struct_name_ptr, template.ret_struct_name_len,
                                        template.ret_tag_layout_ptr, template.ret_tag_layout_len, 0);
    sig_out.annotations_vec = 0;
    return sig_out;
}

func annotation_build_generated_name(prefix_ptr: u64, prefix_len: u64, base_ptr: u64, base_len: u64, id: u64) -> *NameInfo {
    var id_buf: u64 = heap_alloc(32 * sizeof(u8));
    var id_len: u64 = io_u64_to_ascii(id_buf, id);
    var sep_len: u64 = 2;
    var total_len: u64 = prefix_len + base_len + sep_len + id_len;
    var out_ptr: u64 = heap_alloc((total_len + 1) * sizeof(u8));
    var out_u8: []u8 = slice(out_ptr, total_len + 1);
    str_copy(out_ptr, prefix_ptr, prefix_len);
    str_copy(out_ptr + prefix_len, base_ptr, base_len);
    out_u8[prefix_len + base_len] = 95;
    out_u8[prefix_len + base_len + 1] = 95;
    str_copy(out_ptr + prefix_len + base_len + sep_len, id_buf, id_len);
    out_u8[total_len] = 0;
    return new NameInfo{out_ptr, total_len};
}

func annotation_collect_decorators(fn: *AstFunc) -> *Vec<*NameInfo> {
    if (fn == 0 || fn.annotations_vec == 0) { return 0; }

    var annotations: *Vec<*NameInfo> = fn.annotations_vec;
    var n: u64 = annotations.len();
    var out: *Vec<*NameInfo> = 0;
    for (var i: u64 = 0; i < n; i++) {
        if (diag_should_stop_pass() != 0) { break; }
        var ann_info: *NameInfo = annotations.get(i);
        var ann: *CompilerAnnotationParsed = annotation_parse(ann_info);
        if (ann.parse_ok == 0 || ann.name_ptr == 0 || ann.name_len == 0) {
            emit_stderr("[ERROR] malformed decorator annotation on function ");
            emit_stderr_len(fn.name_ptr, fn.name_len);
            emit_stderr(": ");
            if (ann_info != 0) { emit_stderr_len(ann_info.ptr, ann_info.len); }
            emit_stderr("\n");
            diag_note_error();
            continue;
        }
        if (annotation_is_builtin_name(ann.name_ptr, ann.name_len) != 0) { continue; }
        var args_n: u64 = 0;
        if (ann.args_vec != 0) { args_n = ann.args_vec.len(); }
        if (args_n != 0) {
            annotation_emit_invalid_args(fn, ann, "decorator annotations currently do not accept arguments");
            continue;
        }
        var deco_name: *NameInfo = new NameInfo{ann.name_ptr, ann.name_len};

        var deco_sig: *AstFunc = lower_find_func_signature_for_call(deco_name.ptr, deco_name.len);
        if (deco_sig == 0) { continue; }
        if (call_name_matches_tail(fn.name_ptr, fn.name_len, deco_name.ptr, deco_name.len) != 0) {
            emit_stderr("[ERROR] function cannot decorate itself: ");
            emit_stderr_len(fn.name_ptr, fn.name_len);
            emit_stderr("\n");
            diag_note_error();
            continue;
        }

        if (out == 0) {
            out = new Vec<*NameInfo>(2);
        } else {
            var dup: u64 = 0;
            var on: u64 = out.len();
            for (var j: u64 = 0; j < on; j++) {
                var prev: *NameInfo = out.get(j);
                if (str_eq(prev.ptr, prev.len, deco_name.ptr, deco_name.len) != 0) {
                    dup = 1;
                    break;
                }
            }
            if (dup != 0) { continue; }
        }
        out.push(deco_name);
    }
    return out;
}

func annotation_validate_decorator_signature(deco_sig: *AstFunc, target: *AstFunc, deco_ptr: u64, deco_len: u64) -> u64 {
    var ok: u64 = 1;
    if (deco_sig == 0 || target == 0) {
        emit_stderr("[ERROR] internal: decorator signature validation received null function\n");
        diag_note_error();
        return 0;
    }

    if (annotation_return_shape_equal(deco_sig, target) == 0) {
        emit_stderr("[ERROR] decorator return type must match target function: ");
        emit_stderr_len(deco_ptr, deco_len);
        emit_stderr("\n");
        diag_note_error();
        ok = 0;
    }

    var target_params: *Vec<*Param> = target.params_vec;
    var target_n: u64 = 0;
    if (target_params != 0) { target_n = target_params.len(); }

    var deco_params: *Vec<*Param> = deco_sig.params_vec;
    if (deco_params == 0 || deco_params.len() != target_n + 1) {
        emit_stderr("[ERROR] decorator must have signature: (next: u64, <target params...>) -> <target return>: ");
        emit_stderr_len(deco_ptr, deco_len);
        emit_stderr("\n");
        diag_note_error();
        return 0;
    }

    var next_param: *Param = deco_params.get(0);
    if (next_param.type_kind != TYPE_U64 || next_param.ptr_depth != 0 || next_param.is_variadic != 0 || next_param.has_default != 0) {
        emit_stderr("[ERROR] decorator first parameter must be plain u64 function pointer: ");
        emit_stderr_len(deco_ptr, deco_len);
        emit_stderr("\n");
        diag_note_error();
        ok = 0;
    }

    for (var i: u64 = 0; i < target_n; i++) {
        var tp: *Param = target_params.get(i);
        var dp: *Param = deco_params.get(i + 1);
        if (tp.is_variadic != 0 || tp.has_default != 0) {
            emit_stderr("[ERROR] decorated target cannot use variadic/default parameters: ");
            emit_stderr_len(target.name_ptr, target.name_len);
            emit_stderr("\n");
            diag_note_error();
            ok = 0;
        }
        if (dp.is_variadic != 0 || dp.has_default != 0) {
            emit_stderr("[ERROR] decorator cannot use variadic/default parameters: ");
            emit_stderr_len(deco_ptr, deco_len);
            emit_stderr("\n");
            diag_note_error();
            ok = 0;
        }
        if (annotation_param_shape_equal(tp, dp) == 0) {
            emit_stderr("[ERROR] decorator parameter list must match target function after the first parameter: ");
            emit_stderr_len(deco_ptr, deco_len);
            emit_stderr("\n");
            diag_note_error();
            ok = 0;
        }
    }
    return ok;
}

func annotation_build_wrapper_body(template: *AstFunc, decorator_ptr: u64, decorator_len: u64, callee_ptr: u64, callee_len: u64, wrapper_params: *Vec<*Param>) -> *AstNode {
    var n_params: u64 = 0;
    if (wrapper_params != 0) { n_params = wrapper_params.len(); }

    var args: *Vec<*AstNode> = new Vec<*AstNode>(n_params + 1);
    args.push((*AstNode)ast_addr_of((*AstNode)ast_ident(callee_ptr, callee_len)));
    for (var i: u64 = 0; i < n_params; i++) {
        var p: *Param = wrapper_params.get(i);
        args.push((*AstNode)ast_ident(p.name_ptr, p.name_len));
    }

    var call_node: *AstNode = (*AstNode)ast_call_with_origin_named(decorator_ptr, decorator_len, args, 0, AST_CALL_ORIGIN_DIRECT);
    var stmts: *Vec<*AstNode> = new Vec<*AstNode>(1);
    if (template.ret_type == TYPE_VOID && template.ret_ptr_depth == 0) {
        stmts.push((*AstNode)ast_expr_stmt(call_node));
    } else {
        stmts.push((*AstNode)ast_return(call_node));
    }
    return (*AstNode)ast_block(stmts);
}

func annotation_clear_impl_metadata(fn: *AstFunc) -> u64 {
    if (fn == 0) { return 0; }
    fn.impl_owner_ptr = 0;
    fn.impl_owner_len = 0;
    fn.impl_method_access = ACCESS_PRIVATE;
    fn.impl_original_name_ptr = 0;
    fn.impl_original_name_len = 0;
    fn.impl_name_finalized = 0;
    fn.impl_is_override = 0;
    return 0;
}

func annotation_copy_impl_metadata(dst: *AstFunc, src: *AstFunc) -> u64 {
    if (dst == 0 || src == 0) { return 0; }
    dst.impl_owner_ptr = src.impl_owner_ptr;
    dst.impl_owner_len = src.impl_owner_len;
    dst.impl_method_access = src.impl_method_access;
    dst.impl_original_name_ptr = src.impl_original_name_ptr;
    dst.impl_original_name_len = src.impl_original_name_len;
    dst.impl_name_finalized = src.impl_name_finalized;
    dst.impl_is_override = src.impl_is_override;
    return 0;
}

func annotation_set_impl_metadata(fn: *AstFunc, owner_ptr: u64, owner_len: u64, access: u64, original_name_ptr: u64, original_name_len: u64, is_override: u64) -> u64 {
    if (fn == 0) { return 0; }
    fn.impl_owner_ptr = owner_ptr;
    fn.impl_owner_len = owner_len;
    fn.impl_method_access = access;
    fn.impl_original_name_ptr = original_name_ptr;
    fn.impl_original_name_len = original_name_len;
    fn.impl_name_finalized = 1;
    fn.impl_is_override = is_override;
    return 0;
}

func annotation_build_wrapper_func(template: *AstFunc, wrapper_name_ptr: u64, wrapper_name_len: u64, decorator_ptr: u64, decorator_len: u64, callee_ptr: u64, callee_len: u64, keep_impl_metadata: u64) -> *AstFunc {
    var params_out: *Vec<*Param> = annotation_clone_params(template.params_vec);
    var body_out: *AstNode = annotation_build_wrapper_body(template, decorator_ptr, decorator_len, callee_ptr, callee_len, params_out);
    var fn_out: *AstFunc = ast_func_ex(wrapper_name_ptr, wrapper_name_len, params_out,
                                       template.ret_type, template.ret_ptr_depth, template.ret_is_tagged,
                                       template.ret_struct_name_ptr, template.ret_struct_name_len,
                                       template.ret_tag_layout_ptr, template.ret_tag_layout_len, body_out);
    fn_out.annotations_vec = 0;
    if (keep_impl_metadata != 0) {
        annotation_copy_impl_metadata(fn_out, template);
        fn_out.name_ptr = wrapper_name_ptr;
        fn_out.name_len = wrapper_name_len;
        fn_out.impl_name_finalized = 1;
    } else {
        annotation_clear_impl_metadata(fn_out);
    }
    return fn_out;
}

func annotation_rename_first_signature(old_ptr: u64, old_len: u64, new_ptr: u64, new_len: u64) -> u64 {
    if (g_compiler_ctx.all_func_sigs == 0) { return 0; }
    var n: u64 = g_compiler_ctx.all_func_sigs.len();
    for (var i: u64 = 0; i < n; i++) {
        var sig: *AstFunc = g_compiler_ctx.all_func_sigs.get(i);
        if (sig == 0) { continue; }
        if (str_eq(sig.name_ptr, sig.name_len, old_ptr, old_len) == 0) { continue; }
        sig.name_ptr = new_ptr;
        sig.name_len = new_len;
        return 1;
    }
    return 0;
}

func annotation_complexity_stmt_has_loop(stmt: *AstNode) -> u64 {
    if (stmt == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    if (kind == AST_WHILE || kind == AST_FOR || kind == AST_DO_WHILE) { return 1; }
    if (kind == AST_BLOCK) {
        var blk: *AstBlock = (*AstBlock)stmt;
        if (blk.stmts_vec != 0) {
            var n: u64 = blk.stmts_vec.len();
            for (var i: u64 = 0; i < n; i++) {
                if (annotation_complexity_stmt_has_loop(blk.stmts_vec.get(i)) != 0) { return 1; }
            }
        }
        return 0;
    }
    if (kind == AST_IF) {
        var ifs: *AstIf = (*AstIf)stmt;
        if (annotation_complexity_stmt_has_loop(ifs.then_block) != 0) { return 1; }
        return annotation_complexity_stmt_has_loop(ifs.else_block);
    }
    if (kind == AST_SWITCH || kind == AST_MATCH) {
        var sw: *AstSwitch = (*AstSwitch)stmt;
        if (sw.cases_vec != 0) {
            var cn: u64 = sw.cases_vec.len();
            for (var ci: u64 = 0; ci < cn; ci++) {
                if (annotation_complexity_stmt_has_loop(sw.cases_vec.get(ci)) != 0) { return 1; }
            }
        }
        return 0;
    }
    if (kind == AST_CASE) { return annotation_complexity_stmt_has_loop(((*AstCase)stmt).body); }
    if (kind == AST_DEFER) { return annotation_complexity_stmt_has_loop(((*AstDefer)stmt).stmt); }
    return 0;
}

func annotation_complexity_stmt_has_one_sided_loop_if(stmt: *AstNode) -> u64 {
    if (stmt == 0) { return 0; }
    if (annotation_complexity_stmt_has_skip(stmt) != 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    if (kind == AST_IF) {
        var ifs: *AstIf = (*AstIf)stmt;
        var t_has: u64 = annotation_complexity_stmt_has_loop(ifs.then_block);
        var e_has: u64 = annotation_complexity_stmt_has_loop(ifs.else_block);
        if ((t_has != 0 && e_has == 0) || (t_has == 0 && e_has != 0)) { return 1; }
        if (annotation_complexity_stmt_has_one_sided_loop_if(ifs.then_block) != 0) { return 1; }
        return annotation_complexity_stmt_has_one_sided_loop_if(ifs.else_block);
    }
    if (kind == AST_BLOCK) {
        var blk: *AstBlock = (*AstBlock)stmt;
        if (blk.stmts_vec != 0) {
            var n: u64 = blk.stmts_vec.len();
            for (var i: u64 = 0; i < n; i++) {
                if (annotation_complexity_stmt_has_one_sided_loop_if(blk.stmts_vec.get(i)) != 0) { return 1; }
            }
        }
        return 0;
    }
    if (kind == AST_WHILE) { return annotation_complexity_stmt_has_one_sided_loop_if(((*AstWhile)stmt).body); }
    if (kind == AST_FOR) {
        var fr: *AstFor = (*AstFor)stmt;
        if (annotation_complexity_stmt_has_one_sided_loop_if(fr.init) != 0) { return 1; }
        return annotation_complexity_stmt_has_one_sided_loop_if(fr.body);
    }
    if (kind == AST_DO_WHILE) { return annotation_complexity_stmt_has_one_sided_loop_if(((*AstDoWhile)stmt).body); }
    if (kind == AST_SWITCH || kind == AST_MATCH) {
        var sw: *AstSwitch = (*AstSwitch)stmt;
        if (sw.cases_vec != 0) {
            var cn: u64 = sw.cases_vec.len();
            for (var ci: u64 = 0; ci < cn; ci++) {
                if (annotation_complexity_stmt_has_one_sided_loop_if(sw.cases_vec.get(ci)) != 0) { return 1; }
            }
        }
        return 0;
    }
    if (kind == AST_CASE) { return annotation_complexity_stmt_has_one_sided_loop_if(((*AstCase)stmt).body); }
    if (kind == AST_DEFER) { return annotation_complexity_stmt_has_one_sided_loop_if(((*AstDefer)stmt).stmt); }
    return 0;
}

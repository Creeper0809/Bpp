// compiler_pass_runner.b - Compiler pass sequencing contract

import std.io;
import std.vec;
import compiler;
import compiler.resolver;
import compiler.lowering;
import compiler.monomorph;
import compiler.validation;

const COMPILER_PASS_FINALIZE_IMPORT_ALIASES = 1;
const COMPILER_PASS_LOWER_EXCEPTIONS = 2;
const COMPILER_PASS_LOWER_PARSE_SUGAR = 3;
const COMPILER_PASS_FINALIZE_GLOBAL_INIT_KINDS = 4;
const COMPILER_PASS_VALIDATE_DIRECT_IMPL_CALLS = 5;
const COMPILER_PASS_INSERT_DEFAULT_CONSTRUCTORS = 6;
const COMPILER_PASS_INSERT_AUTO_SUPER_CHAINS = 7;
const COMPILER_PASS_INSERT_GLOBAL_INIT_FUNC = 8;
const COMPILER_PASS_RESOLVE_SUPER_REFERENCES = 9;
const COMPILER_PASS_VALIDATE_IMPL_OVERRIDES = 10;
const COMPILER_PASS_MONOMORPHIZE_GENERICS = 11;
const COMPILER_PASS_FINALIZE_ABST_METHODS = 12;
const COMPILER_PASS_FINALIZE_TRAITS = 13;
const COMPILER_PASS_APPLY_ANNOTATIONS = 14;

func compiler_pass_name(pass_id: u64) -> u64 {
    switch (pass_id) {
        case COMPILER_PASS_FINALIZE_IMPORT_ALIASES: return "finalize_import_aliases";
        case COMPILER_PASS_LOWER_EXCEPTIONS: return "compiler_lower_exceptions";
        case COMPILER_PASS_LOWER_PARSE_SUGAR: return "compiler_lower_parse_sugar";
        case COMPILER_PASS_FINALIZE_GLOBAL_INIT_KINDS: return "compiler_finalize_global_init_kinds";
        case COMPILER_PASS_VALIDATE_DIRECT_IMPL_CALLS: return "compiler_validate_direct_impl_calls";
        case COMPILER_PASS_INSERT_DEFAULT_CONSTRUCTORS: return "compiler_insert_default_constructors";
        case COMPILER_PASS_INSERT_AUTO_SUPER_CHAINS: return "compiler_insert_auto_super_constructor_chains";
        case COMPILER_PASS_INSERT_GLOBAL_INIT_FUNC: return "compiler_insert_global_init_func";
        case COMPILER_PASS_RESOLVE_SUPER_REFERENCES: return "compiler_resolve_super_references";
        case COMPILER_PASS_VALIDATE_IMPL_OVERRIDES: return "compiler_validate_impl_overrides";
        case COMPILER_PASS_MONOMORPHIZE_GENERICS: return "compiler_monomorphize_generics";
        case COMPILER_PASS_FINALIZE_ABST_METHODS: return "compiler_finalize_abst_methods";
        case COMPILER_PASS_FINALIZE_TRAITS: return "compiler_finalize_traits";
        case COMPILER_PASS_APPLY_ANNOTATIONS: return "compiler_apply_annotations";
    }
    return "unknown_pass";
}

func compiler_run_pass(pass_id: u64) -> u64 {
    return compiler_run_pass_with_ctx(compiler_ctx_current(), pass_id);
}

func compiler_run_pass_with_ctx(ctx: *CompilerCtx, pass_id: u64) -> u64 {
    if (compiler_ctx_is_active(ctx) == 0) {
        emit_stderr("[ERROR] compiler_run_pass_with_ctx currently requires active compiler context\n");
        return 1;
    }
    switch (pass_id) {
        case COMPILER_PASS_FINALIZE_IMPORT_ALIASES:
            compiler_pass_resolver_finalize_import_aliases();
            return 0;
        case COMPILER_PASS_LOWER_EXCEPTIONS:
            compiler_pass_lowering_exceptions();
            return 0;
        case COMPILER_PASS_LOWER_PARSE_SUGAR:
            compiler_pass_lowering_parse_sugar();
            return 0;
        case COMPILER_PASS_FINALIZE_GLOBAL_INIT_KINDS:
            compiler_pass_lowering_finalize_global_init_kinds();
            return 0;
        case COMPILER_PASS_VALIDATE_DIRECT_IMPL_CALLS:
            compiler_pass_validation_direct_impl_calls();
            return 0;
        case COMPILER_PASS_INSERT_DEFAULT_CONSTRUCTORS:
            compiler_pass_lowering_insert_default_constructors();
            return 0;
        case COMPILER_PASS_INSERT_AUTO_SUPER_CHAINS:
            compiler_pass_lowering_insert_auto_super_constructor_chains();
            return 0;
        case COMPILER_PASS_INSERT_GLOBAL_INIT_FUNC:
            compiler_pass_lowering_insert_global_init_func();
            return 0;
        case COMPILER_PASS_RESOLVE_SUPER_REFERENCES:
            compiler_pass_resolver_resolve_super_references();
            return 0;
        case COMPILER_PASS_VALIDATE_IMPL_OVERRIDES:
            compiler_pass_validation_impl_overrides();
            return 0;
        case COMPILER_PASS_MONOMORPHIZE_GENERICS:
            compiler_pass_monomorphize_generics();
            return 0;
        case COMPILER_PASS_FINALIZE_ABST_METHODS:
            compiler_pass_validation_finalize_abst_methods();
            return 0;
        case COMPILER_PASS_FINALIZE_TRAITS:
            compiler_pass_validation_finalize_traits();
            return 0;
        case COMPILER_PASS_APPLY_ANNOTATIONS:
            compiler_pass_validation_apply_annotations();
            return 0;
        default:
            emit_stderr("[ERROR] unknown compiler pipeline pass id: ");
            emit_u64_stderr(pass_id);
            emit_stderr("\n");
            return 1;
    }
}

func compiler_default_passes() -> *Vec<u64> {
    return compiler_default_passes_with_ctx(compiler_ctx_current());
}

func compiler_default_passes_with_ctx(ctx: *CompilerCtx) -> *Vec<u64> {
    if (compiler_ctx_is_active(ctx) == 0) { return new Vec<u64>(0); }
    var passes: *Vec<u64> = new Vec<u64>(16);
    passes.push(COMPILER_PASS_FINALIZE_IMPORT_ALIASES);
    passes.push(COMPILER_PASS_LOWER_EXCEPTIONS);
    passes.push(COMPILER_PASS_LOWER_PARSE_SUGAR);
    passes.push(COMPILER_PASS_FINALIZE_GLOBAL_INIT_KINDS);
    passes.push(COMPILER_PASS_VALIDATE_DIRECT_IMPL_CALLS);
    passes.push(COMPILER_PASS_INSERT_DEFAULT_CONSTRUCTORS);
    passes.push(COMPILER_PASS_INSERT_AUTO_SUPER_CHAINS);
    passes.push(COMPILER_PASS_INSERT_GLOBAL_INIT_FUNC);
    passes.push(COMPILER_PASS_RESOLVE_SUPER_REFERENCES);
    passes.push(COMPILER_PASS_VALIDATE_IMPL_OVERRIDES);
    passes.push(COMPILER_PASS_MONOMORPHIZE_GENERICS);
    passes.push(COMPILER_PASS_FINALIZE_ABST_METHODS);
    passes.push(COMPILER_PASS_FINALIZE_TRAITS);
    passes.push(COMPILER_PASS_APPLY_ANNOTATIONS);
    return passes;
}

// compiler_pass_runner.b - Compiler pass sequencing contract

import std.io;
import std.vec;
import compiler;
import compiler.core_utils;
import compiler.generic.engine;
import compiler.symbol_runtime;
import compiler.resolver;
import compiler.lowering;
import compiler.monomorph;
import compiler.validation;

const COMPILER_PASS_FINALIZE_IMPORT_ALIASES = 1;
const COMPILER_PASS_LOWER_EXCEPTIONS = 2;
const COMPILER_PASS_LOWER_PARSE_SUGAR = 3;
const COMPILER_PASS_FINALIZE_GLOBAL_INIT_KINDS = 4;
const COMPILER_PASS_VALIDATE_DIRECT_IMPL_CALLS = 5;
const COMPILER_PASS_INSERT_DEFAULT_CONSTRUCTORS = 6;
const COMPILER_PASS_INSERT_AUTO_SUPER_CHAINS = 7;
const COMPILER_PASS_INSERT_GLOBAL_INIT_FUNC = 8;
const COMPILER_PASS_RESOLVE_SUPER_REFERENCES = 9;
const COMPILER_PASS_VALIDATE_IMPL_OVERRIDES = 10;
const COMPILER_PASS_MONOMORPHIZE_GENERICS = 11;
const COMPILER_PASS_FINALIZE_ABST_METHODS = 12;
const COMPILER_PASS_FINALIZE_TRAITS = 13;
const COMPILER_PASS_APPLY_ANNOTATIONS = 14;

func pass_name(pass_id: u64) -> u64 {
    match (pass_id) {
        case COMPILER_PASS_FINALIZE_IMPORT_ALIASES: return "finalize_import_aliases";
        case COMPILER_PASS_LOWER_EXCEPTIONS: return "lower_exceptions";
        case COMPILER_PASS_LOWER_PARSE_SUGAR: return "lower_parse_sugar";
        case COMPILER_PASS_FINALIZE_GLOBAL_INIT_KINDS: return "lower_finalize_global_init_kinds";
        case COMPILER_PASS_VALIDATE_DIRECT_IMPL_CALLS: return "validate_direct_impl_calls";
        case COMPILER_PASS_INSERT_DEFAULT_CONSTRUCTORS: return "lower_insert_default_constructors";
        case COMPILER_PASS_INSERT_AUTO_SUPER_CHAINS: return "lower_insert_auto_super_constructor_chains";
        case COMPILER_PASS_INSERT_GLOBAL_INIT_FUNC: return "lower_insert_global_init_func";
        case COMPILER_PASS_RESOLVE_SUPER_REFERENCES: return "lower_super_references";
        case COMPILER_PASS_VALIDATE_IMPL_OVERRIDES: return "validate_impl_overrides";
        case COMPILER_PASS_MONOMORPHIZE_GENERICS: return "monomorphize_generics";
        case COMPILER_PASS_FINALIZE_ABST_METHODS: return "finalize_abst_methods";
        case COMPILER_PASS_FINALIZE_TRAITS: return "finalize_traits";
        case COMPILER_PASS_APPLY_ANNOTATIONS: return "apply_annotations";
    }
    return "unknown_pass";
}

func run_pass(pass_id: u64) -> u64 {
    return run_pass_with_ctx(compiler_ctx_current(), pass_id);
}

func run_pass_with_ctx(ctx: *CompilerCtx, pass_id: u64) -> u64 {
    if (compiler_ctx_is_active(ctx) == 0) {
        emit_stderr("[ERROR] run_pass_with_ctx currently requires active compiler context\n");
        return 1;
    }
    match (pass_id) {
        case COMPILER_PASS_FINALIZE_IMPORT_ALIASES:
            return finalize_import_aliases_with_ctx(ctx);
        case COMPILER_PASS_LOWER_EXCEPTIONS:
            return lower_exceptions_with_ctx(ctx);
        case COMPILER_PASS_LOWER_PARSE_SUGAR:
            return lower_parse_sugar_with_ctx(ctx);
        case COMPILER_PASS_FINALIZE_GLOBAL_INIT_KINDS:
            return lower_finalize_global_init_kinds_with_ctx(ctx);
        case COMPILER_PASS_VALIDATE_DIRECT_IMPL_CALLS:
            return validate_direct_impl_calls_with_ctx(ctx);
        case COMPILER_PASS_INSERT_DEFAULT_CONSTRUCTORS:
            return lower_insert_default_constructors_with_ctx(ctx);
        case COMPILER_PASS_INSERT_AUTO_SUPER_CHAINS:
            return lower_insert_auto_super_constructor_chains_with_ctx(ctx);
        case COMPILER_PASS_INSERT_GLOBAL_INIT_FUNC:
            return lower_insert_global_init_func_with_ctx(ctx);
        case COMPILER_PASS_RESOLVE_SUPER_REFERENCES:
            return lower_super_references_with_ctx(ctx);
        case COMPILER_PASS_VALIDATE_IMPL_OVERRIDES:
            return validate_impl_overrides_with_ctx(ctx);
        case COMPILER_PASS_MONOMORPHIZE_GENERICS:
            return monomorphize_generics_with_ctx(ctx);
        case COMPILER_PASS_FINALIZE_ABST_METHODS:
            return validate_finalize_abst_methods_with_ctx(ctx);
        case COMPILER_PASS_FINALIZE_TRAITS:
            return validate_finalize_traits_with_ctx(ctx);
        case COMPILER_PASS_APPLY_ANNOTATIONS:
            return validate_apply_annotations_with_ctx(ctx);
        default:
            emit_stderr("[ERROR] unknown compiler pipeline pass id: ");
            emit_u64_stderr(pass_id);
            emit_stderr("\n");
            return 1;
    }
}

func default_passes() -> *Vec<u64> {
    return default_passes_with_ctx(compiler_ctx_current());
}

func default_passes_with_ctx(ctx: *CompilerCtx) -> *Vec<u64> {
    if (compiler_ctx_is_active(ctx) == 0) { return new Vec<u64>{heap_alloc((0) * sizeof(u64)), 0, (0)}; }
    var passes: *Vec<u64> = new Vec<u64>{heap_alloc((16) * sizeof(u64)), 0, (16)};
    passes.push(COMPILER_PASS_FINALIZE_IMPORT_ALIASES);
    passes.push(COMPILER_PASS_LOWER_EXCEPTIONS);
    passes.push(COMPILER_PASS_LOWER_PARSE_SUGAR);
    passes.push(COMPILER_PASS_FINALIZE_GLOBAL_INIT_KINDS);
    passes.push(COMPILER_PASS_VALIDATE_DIRECT_IMPL_CALLS);
    passes.push(COMPILER_PASS_INSERT_DEFAULT_CONSTRUCTORS);
    passes.push(COMPILER_PASS_INSERT_AUTO_SUPER_CHAINS);
    passes.push(COMPILER_PASS_INSERT_GLOBAL_INIT_FUNC);
    passes.push(COMPILER_PASS_RESOLVE_SUPER_REFERENCES);
    passes.push(COMPILER_PASS_VALIDATE_IMPL_OVERRIDES);
    passes.push(COMPILER_PASS_MONOMORPHIZE_GENERICS);
    passes.push(COMPILER_PASS_FINALIZE_ABST_METHODS);
    passes.push(COMPILER_PASS_FINALIZE_TRAITS);
    passes.push(COMPILER_PASS_APPLY_ANNOTATIONS);
    return passes;
}

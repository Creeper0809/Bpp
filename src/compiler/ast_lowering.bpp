// compiler_ast_lowering.b - Call sugar + exception + AST lowering helpers

import compiler;
import compiler.core_utils;
import compiler.generic.engine;
import compiler.symbol_runtime;
import compiler.generic.core;
import compiler.call_utils;
import std.io;
import std.str;
import std.vec;
import std.hashmap;
import ast;
import types;

var g_lower_parse_sugar_symtab: *HashMap<u64, *TypeInfo> = 0;
var g_lower_parse_sugar_final_phase: u64 = 0;
var g_lower_parse_sugar_return_ti: *TypeInfo = 0;

func lower_parse_sugar_set_symtab(symtab: *HashMap<u64, *TypeInfo>) -> u64 {
    g_lower_parse_sugar_symtab = symtab;
    return 0;
}

func lower_parse_sugar_set_final_phase(final_phase: u64) -> u64 {
    g_lower_parse_sugar_final_phase = final_phase;
    return 0;
}

func lower_parse_sugar_set_return_typeinfo(ti: *TypeInfo) -> u64 {
    g_lower_parse_sugar_return_ti = ti;
    return 0;
}

func lower_parse_sugar_current_return_typeinfo() -> *TypeInfo {
    return g_lower_parse_sugar_return_ti;
}

func lower_try_resolve_struct_name(name: []u8) -> CompilerResolvedStructName {
    var result: CompilerResolvedStructName;
    result.found = 0;
    result.resolved = name;
    result.struct_def = 0;

    var resolved_ptr: u64 = name.ptr;
    var resolved_len: u64 = name.len;
    var struct_def: *AstStructDef = get_struct_def(slice(resolved_ptr, resolved_len));
    if (struct_def == 0) {
        var resolved_name: *NameInfo = resolve_name(slice(name.ptr, name.len));
        if (resolved_name != 0) {
            var resolved_def: *AstStructDef = get_struct_def(slice(resolved_name.ptr, resolved_name.len));
            if (resolved_def != 0) {
                resolved_ptr = resolved_name.ptr;
                resolved_len = resolved_name.len;
                struct_def = resolved_def;
            }
        }
    }
    if (struct_def == 0) { return result; }
    result.found = 1;
    result.resolved = slice(resolved_ptr, resolved_len);
    result.struct_def = struct_def;
    return result;
}

func lower_try_resolve_generic_struct_template(name: []u8) -> *GenericStructTemplate {
    var tpl: *GenericStructTemplate = sym_find_generic_struct_template_by_name(slice(name.ptr, name.len));
    if (tpl == 0) {
        var resolved_name: *NameInfo = resolve_name(slice(name.ptr, name.len));
        if (resolved_name != 0) {
            tpl = sym_find_generic_struct_template_by_name(slice(resolved_name.ptr, resolved_name.len));
        }
    }
    return tpl;
}

func lower_try_resolve_generic_struct_type_instance(name: []u8, generic_args: *Vec<*GenericArg>, out_name_info: **NameInfo) -> u64 {
    var tpl: *GenericStructTemplate = lower_try_resolve_generic_struct_template(slice(name.ptr, name.len));
    if (tpl == 0) {
        return 0;
    }
    var bindings: *Vec<*GenericBinding> = generic_build_bindings_for_struct(tpl, generic_args);
    var name_info: *NameInfo = generic_struct_get_or_create_instance(tpl, bindings);
    if (name_info == 0) { return 0; }
    *out_name_info = name_info;
    return 1;
}

func lower_clone_default_expr(expr_u64: u64) -> *AstNode {
    if (expr_u64 == 0) { return 0; }
    return generic_clone_expr((*AstNode)expr_u64, 0);
}

func call_fill_missing_defaults(call_name: []u8, params: *Vec<*Param>, params_start: u64, fixed_count: u64, out_fixed: *Vec<*AstNode>, assigned: *Vec<u64>) -> u64 {
    for (var fi: u64 = 0; fi < fixed_count; fi++) {
        if (assigned.get(fi) != 0) { continue; }
        var param: *Param = params.get(params_start + fi);
        if (param != 0 && param.has_default != 0) {
            var def_expr: *AstNode = lower_clone_default_expr(param.default_expr);
            out_fixed.set(fi, lower_parse_sugar_expr(def_expr));
            assigned.set(fi, 1);
            continue;
        }
        diag_emit_error_tag("lowering", "L1000", "missing required argument");
        if (param != 0) {
            diag_emit_labelled_name("parameter: ", param.name);
        }
        diag_emit_labelled_name("call: ", slice(call_name.ptr, call_name.len));
        diag_error("Compiler error");
        return 0;
    }
    return 0;
}

func lower_param_expects_u8_slice(param: *Param) -> u64 {
    if (param == 0) { return 0; }
    if (param.type_kind != TYPE_SLICE || param.ptr_depth != 0) { return 0; }
    if (param.elem_type_kind != TYPE_U8 || param.elem_ptr_depth != 0) { return 0; }
    return 1;
}

func lower_should_consume_legacy_string_len_arg(arg_expr: *AstNode, arg_names: *Vec<*NameInfo>, arg_index: u64, arg_count: u64, param: *Param, next_positional: u64, fixed_count: u64, has_variadic: u64) -> u64 {
    if (arg_expr == 0 || ast_kind(arg_expr) != AST_STRING) { return 0; }
    if (lower_param_expects_u8_slice(param) == 0) { return 0; }
    if (has_variadic != 0) { return 0; }
    if (arg_index + 1 >= arg_count) { return 0; }
    if (call_named_at(arg_names, arg_index + 1) != 0) { return 0; }

    var input_remaining: u64 = arg_count - arg_index;
    var params_remaining: u64 = fixed_count - next_positional;
    if (input_remaining > params_remaining) { return 1; }
    return 0;
}

func lower_normalize_call_args_for_params(call_name: []u8, params: *Vec<*Param>, params_start: u64, args: *Vec<*AstNode>, arg_names: *Vec<*NameInfo>) -> *Vec<*AstNode> {
    var input_args: *Vec<*AstNode> = args;
    if (input_args == 0) { input_args = new Vec<*AstNode>{heap_alloc((0) * sizeof(*AstNode)), 0, (0)}; }
    if (params == 0) {
        if (call_has_named_args(arg_names) != 0) {
            error_callsite("named arguments require a resolvable function signature", slice(call_name.ptr, call_name.len));
        }
        return input_args;
    }

    var param_count: u64 = params.len();
    if (params_start > param_count) { params_start = param_count; }
    var effective_count: u64 = param_count - params_start;

    var has_variadic: u64 = call_has_variadic_param(params, param_count, effective_count);
    var should_normalize: u64 = call_params_need_normalize(params, params_start, arg_names);
    if (should_normalize == 0) {
        var simple_fixed_count: u64 = effective_count;
        if (has_variadic != 0 && simple_fixed_count > 0) {
            simple_fixed_count = simple_fixed_count - 1;
        }
        var simple_arg_count: u64 = input_args.len();
        var simple_out: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((simple_arg_count + 1) * sizeof(*AstNode)), 0, (simple_arg_count + 1)};
        var simple_needs_out: u64 = 0;
        var simple_pos: u64 = 0;
        for (var sai: u64 = 0; sai < simple_arg_count && simple_pos < simple_fixed_count; sai++) {
            var simple_arg_expr: *AstNode = input_args.get(sai);
            var simple_param: *Param = params.get(params_start + simple_pos);
            var simple_lowered: *AstNode = lower_parse_sugar_expr_for_type(simple_arg_expr, lower_make_typeinfo_from_param(simple_param));
            if (simple_needs_out != 0) {
                simple_out.push(simple_lowered);
            } else {
                input_args.set(sai, simple_lowered);
            }
            if (lower_should_consume_legacy_string_len_arg(simple_arg_expr, arg_names, sai, simple_arg_count, simple_param, simple_pos, simple_fixed_count, has_variadic) != 0) {
                if (simple_needs_out == 0) {
                    for (var copy_i: u64 = 0; copy_i <= simple_pos; copy_i++) {
                        simple_out.push(input_args.get(copy_i));
                    }
                    simple_needs_out = 1;
                }
                sai = sai + 1;
            }
            simple_pos = simple_pos + 1;
        }
        if (simple_needs_out != 0) { return simple_out; }
        return input_args;
    }

    var fixed_count: u64 = effective_count;
    if (has_variadic != 0 && fixed_count > 0) {
        fixed_count = fixed_count - 1;
    }

    var out_fixed: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((fixed_count + 2) * sizeof(*AstNode)), 0, (fixed_count + 2)};
    var assigned: *Vec<u64> = new Vec<u64>{heap_alloc((fixed_count + 2) * sizeof(u64)), 0, (fixed_count + 2)};
    for (var i: u64 = 0; i < fixed_count; i++) {
        out_fixed.push(0);
        assigned.push(0);
    }
    var variadic_args: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((4) * sizeof(*AstNode)), 0, (4)};

    var seen_named: u64 = 0;
    var next_positional: u64 = 0;
    var arg_count: u64 = input_args.len();
    for (var ai: u64 = 0; ai < arg_count; ai++) {
        var arg_expr: *AstNode = input_args.get(ai);
        var arg_name: *NameInfo = call_named_at(arg_names, ai);
        if (arg_name != 0) {
            seen_named = 1;
            var named_idx: u64 = call_find_param_index_by_name(params, params_start, fixed_count, slice(arg_name.ptr, arg_name.len));
            if (named_idx == COMPILER_NOT_FOUND_U64) {
                if (has_variadic != 0) {
                    var variadic_param: *Param = params.get(param_count - 1);
                    if (variadic_param != 0 && str_eq(variadic_param.name, slice(arg_name.ptr, arg_name.len)) != 0) {
                        diag_emit_error_tag("lowering", "L1001", "named argument cannot target variadic parameter");
                        diag_emit_labelled_name("argument: ", slice(arg_name.ptr, arg_name.len));
                        diag_error("Compiler error");
                        return 0;
                    }
                }
                diag_emit_error_tag("lowering", "L1002", "unknown named argument");
                diag_emit_labelled_name("argument: ", slice(arg_name.ptr, arg_name.len));
                diag_emit_labelled_name("call: ", slice(call_name.ptr, call_name.len));
                diag_error("Compiler error");
                return 0;
            }
            if (assigned.get(named_idx) != 0) {
                diag_emit_error_tag("lowering", "L1003", "duplicate argument for parameter");
                diag_emit_labelled_name("parameter: ", slice(arg_name.ptr, arg_name.len));
                diag_emit_labelled_name("call: ", slice(call_name.ptr, call_name.len));
                diag_error("Compiler error");
                return 0;
            }
            var named_param: *Param = params.get(params_start + named_idx);
            out_fixed.set(named_idx, lower_parse_sugar_expr_for_type(arg_expr, lower_make_typeinfo_from_param(named_param)));
            assigned.set(named_idx, 1);
            continue;
        }

        if (seen_named != 0) {
            error_callsite("positional argument cannot follow named arguments in call", slice(call_name.ptr, call_name.len));
        }

        if (next_positional < fixed_count) {
            var positional_param: *Param = params.get(params_start + next_positional);
            out_fixed.set(next_positional, lower_parse_sugar_expr_for_type(arg_expr, lower_make_typeinfo_from_param(positional_param)));
            assigned.set(next_positional, 1);
            if (lower_should_consume_legacy_string_len_arg(arg_expr, arg_names, ai, arg_count, positional_param, next_positional, fixed_count, has_variadic) != 0) {
                ai = ai + 1;
            }
            next_positional = next_positional + 1;
            continue;
        }

        if (has_variadic == 0) {
            error_callsite("too many arguments in call", slice(call_name.ptr, call_name.len));
        }
        variadic_args.push(arg_expr);
    }

    call_fill_missing_defaults(slice(call_name.ptr, call_name.len), params, params_start, fixed_count, out_fixed, assigned);

    if (has_variadic == 0) {
        return out_fixed;
    }
    return call_pack_variadic_args(out_fixed, variadic_args);
}

func lower_method_func_name_matches(fn: *AstFunc, method: []u8) -> u64 {
    if (fn == 0 || method.ptr == 0 || method.len == 0) { return 0; }
    var cand_ptr: u64 = u8_slice_ptr(fn.impl_original_name);
    var cand_len: u64 = u8_slice_len(fn.impl_original_name);
    if (cand_ptr == 0 || cand_len == 0) {
        cand_ptr = u8_slice_ptr(fn.name);
        cand_len = u8_slice_len(fn.name);
    }
    if (cand_ptr == 0 || cand_len == 0) { return 0; }
    if (str_eq(slice(cand_ptr, cand_len), slice(method.ptr, method.len)) != 0) { return 1; }
    return 0;
}

func lower_method_signature_can_normalize_args(fn: *AstFunc, mc: *AstMethodCall) -> u64 {
    if (fn == 0 || mc == 0 || fn.params_vec == 0) { return 0; }
    var params: *Vec<*Param> = fn.params_vec;
    var param_count: u64 = params.len();
    var params_start: u64 = sym_method_param_start_index(fn);
    if (params_start > param_count) { params_start = param_count; }
    var effective_count: u64 = param_count - params_start;
    var has_variadic: u64 = call_has_variadic_param(params, param_count, effective_count);
    var fixed_count: u64 = effective_count;
    if (has_variadic != 0 && fixed_count > 0) {
        fixed_count = fixed_count - 1;
    }

    var assigned: *Vec<u64> = new Vec<u64>{heap_alloc((fixed_count + 1) * sizeof(u64)), 0, (fixed_count + 1)};
    for (var i: u64 = 0; i < fixed_count; i++) {
        assigned.push(0);
    }

    var seen_named: u64 = 0;
    var next_positional: u64 = 0;
    var arg_count: u64 = 0;
    if (mc.args_vec != 0) { arg_count = mc.args_vec.len(); }
    for (var ai: u64 = 0; ai < arg_count; ai++) {
        var arg_name: *NameInfo = call_named_at(mc.arg_names_vec, ai);
        if (arg_name != 0) {
            seen_named = 1;
            var named_idx: u64 = call_find_param_index_by_name(params, params_start, fixed_count, slice(arg_name.ptr, arg_name.len));
            if (named_idx == COMPILER_CALL_UTILS_NOT_FOUND_U64) { return 0; }
            if (assigned.get(named_idx) != 0) { return 0; }
            assigned.set(named_idx, 1);
            continue;
        }

        if (seen_named != 0) { return 0; }
        if (next_positional < fixed_count) {
            var positional_param: *Param = params.get(params_start + next_positional);
            assigned.set(next_positional, 1);
            if (lower_should_consume_legacy_string_len_arg(mc.args_vec.get(ai), mc.arg_names_vec, ai, arg_count, positional_param, next_positional, fixed_count, has_variadic) != 0) {
                ai = ai + 1;
            }
            next_positional = next_positional + 1;
            continue;
        }
        if (has_variadic == 0) { return 0; }
    }

    for (var fi: u64 = 0; fi < fixed_count; fi++) {
        if (assigned.get(fi) != 0) { continue; }
        var p: *Param = params.get(params_start + fi);
        if (p == 0 || p.has_default == 0) { return 0; }
    }
    return 1;
}

func lower_find_method_signature_by_name_for_call_in_vec(funcs: *Vec<*AstFunc>, recv_struct: []u8, method: []u8, mc: *AstMethodCall) -> *AstFunc {
    if (funcs == 0) { return 0; }
    var best_fn: *AstFunc = 0;
    var best_dist: u64 = COMPILER_INHERIT_DIST_NOT_FOUND;
    var ambiguous: u64 = 0;
    var n: u64 = funcs.len();
    for (var i: u64 = 0; i < n; i++) {
        var fn: *AstFunc = funcs.get(i);
        if (fn == 0) { continue; }
        if (u8_slice_ptr(fn.impl_owner) == 0 || u8_slice_len(fn.impl_owner) == 0) { continue; }
        if (lower_method_func_name_matches(fn, slice(method.ptr, method.len)) == 0) { continue; }
        var dist: u64 = sym_struct_distance_to_ancestor(slice(recv_struct.ptr, recv_struct.len), fn.impl_owner);
        if (dist == COMPILER_INHERIT_DIST_NOT_FOUND) { continue; }
        if (lower_method_signature_can_normalize_args(fn, mc) == 0) { continue; }
        if (best_fn == 0 || dist < best_dist) {
            best_fn = fn;
            best_dist = dist;
            ambiguous = 0;
            continue;
        }
        if (dist == best_dist && best_fn != fn) {
            ambiguous = 1;
        }
    }
    if (ambiguous != 0) {
        diag_emit_error_tag("lowering", "method-overload", "ambiguous method signature for argument normalization");
        diag_emit_labelled_member("method: ", slice(recv_struct.ptr, recv_struct.len), slice(method.ptr, method.len));
        diag_error("Compiler error");
        return 0;
    }
    return best_fn;
}

func lower_find_method_signature_by_name_for_call(recv_struct: []u8, method: []u8, mc: *AstMethodCall) -> *AstFunc {
    var found: *AstFunc = lower_find_method_signature_by_name_for_call_in_vec(g_compiler_ctx.all_funcs, slice(recv_struct.ptr, recv_struct.len), slice(method.ptr, method.len), mc);
    if (found != 0) { return found; }
    return lower_find_method_signature_by_name_for_call_in_vec(g_compiler_ctx.all_func_sigs, slice(recv_struct.ptr, recv_struct.len), slice(method.ptr, method.len), mc);
}

func lower_find_func_signature_for_call(name: []u8) -> *AstFunc {
    var fn: *AstFunc = sym_get_func(slice(name.ptr, name.len));
    if (fn != 0) { return fn; }

    var found: *AstFunc = 0;
    if (g_compiler_ctx.all_funcs != 0) {
        var n: u64 = g_compiler_ctx.all_funcs.len();
        for (var i: u64 = 0; i < n; i++) {
            var cand: *AstFunc = g_compiler_ctx.all_funcs.get(i);
            if (cand == 0) { continue; }
            if (call_name_matches_tail(cand.name, slice(name.ptr, name.len)) == 0) { continue; }
            if (found == 0 || u8_slice_len(cand.name) < u8_slice_len(found.name)) {
                found = cand;
            }
        }
    }
    if (found != 0) { return found; }

    if (g_compiler_ctx.all_func_sigs != 0) {
        var sn: u64 = g_compiler_ctx.all_func_sigs.len();
        for (var j: u64 = 0; j < sn; j++) {
            var sig: *AstFunc = g_compiler_ctx.all_func_sigs.get(j);
            if (sig == 0) { continue; }
            if (call_name_matches_tail(sig.name, slice(name.ptr, name.len)) == 0) { continue; }
            if (found == 0 || u8_slice_len(sig.name) < u8_slice_len(found.name)) {
                found = sig;
            }
        }
    }
    return found;
}

func lower_find_generic_template_for_call(name: []u8) -> *GenericFuncTemplate {
    var tpl: *GenericFuncTemplate = sym_find_generic_template_by_name(slice(name.ptr, name.len));
    if (tpl != 0) { return tpl; }
    var resolved: *NameInfo = resolve_name(slice(name.ptr, name.len));
    if (resolved != 0) {
        tpl = sym_find_generic_template_by_name(slice(resolved.ptr, resolved.len));
        if (tpl != 0) { return tpl; }
        tpl = sym_find_generic_template_by_mangled(slice(resolved.ptr, resolved.len));
        if (tpl != 0) { return tpl; }
    }

    var found: *GenericFuncTemplate = 0;
    if (g_compiler_ctx.generic_func_ptrs != 0) {
        var n: u64 = g_compiler_ctx.generic_func_ptrs.len();
        for (var i: u64 = 0; i < n; i++) {
            var cand: *GenericFuncTemplate = g_compiler_ctx.generic_func_ptrs.get(i);
            if (cand == 0) { continue; }
            var cand_mangled: []u8 = cand.mangled_name;
            if (call_name_matches_tail(cand.name, slice(name.ptr, name.len)) == 0 &&
                call_name_matches_tail(cand_mangled, slice(name.ptr, name.len)) == 0) {
                continue;
            }
            if (found == 0 || u8_slice_len(cand.name) < u8_slice_len(found.name)) {
                found = cand;
            }
        }
    }
    return found;
}

func lower_normalize_direct_call_args(call: *AstCall) -> u64 {
    if (call == 0) { return 0; }
    var fn: *AstFunc = lower_find_func_signature_for_call(call.name);
    if (fn == 0) {
        if (call_has_named_args(call.arg_names_vec) != 0) {
            diag_emit_error_tag("lowering", "L1004", "named arguments require a known function signature");
            diag_emit_labelled_name("call: ", call.name);
            diag_error("Compiler error");
            return 0;
        }
        return 0;
    }
    call.args_vec = lower_normalize_call_args_for_params(call.name, fn.params_vec, 0, call.args_vec, call.arg_names_vec);
    call.arg_names_vec = 0;
    return 0;
}

func lower_normalize_generic_call_args(gcall: *AstGenericCall) -> u64 {
    if (gcall == 0) { return 0; }
    var tpl: *GenericFuncTemplate = lower_find_generic_template_for_call(gcall.name);
    if (tpl == 0) {
        if (call_has_named_args(gcall.arg_names_vec) != 0) {
            diag_emit_error_tag("lowering", "L1005", "named arguments require a known generic function signature");
            diag_emit_labelled_name("call: ", gcall.name);
            diag_error("Compiler error");
            return 0;
        }
        return 0;
    }
    var fn: *AstFunc = tpl.func_def;
    if (fn == 0) { fn = tpl.func_sig; }
    if (fn == 0) {
        diag_emit_error_tag("lowering", "L1006", "missing generic function signature for call");
        diag_emit_labelled_name("call: ", gcall.name);
        diag_error("Compiler error");
        return 0;
    }
    gcall.args_vec = lower_normalize_call_args_for_params(gcall.name, fn.params_vec, 0, gcall.args_vec, gcall.arg_names_vec);
    gcall.arg_names_vec = 0;
    return 0;
}

func lower_normalize_method_call_args_for_func(mc: *AstMethodCall, fn: *AstFunc) -> u64 {
    if (mc == 0 || fn == 0) { return 0; }
    mc.args_vec = lower_normalize_call_args_for_params(mc.method, fn.params_vec, sym_method_param_start_index(fn), mc.args_vec, mc.arg_names_vec);
    mc.arg_names_vec = 0;
    return 0;
}

func lower_normalize_method_call_args(mc: *AstMethodCall) -> u64 {
    if (mc == 0) { return 0; }
    var recv_ti: *TypeInfo = generic_infer_expr_type(mc.receiver, g_lower_parse_sugar_symtab);
    if (recv_ti == 0 || recv_ti.type_kind != TYPE_STRUCT) { return 0; }
    if (u8_slice_ptr(recv_ti.struct_name) == 0 || u8_slice_len(recv_ti.struct_name) == 0) {
        if (recv_ti.struct_def != 0) {
            recv_ti.struct_name = recv_ti.struct_def.name;
        }
    }
    if (u8_slice_ptr(recv_ti.struct_name) == 0 || u8_slice_len(recv_ti.struct_name) == 0) { return 0; }

    var arg_count_hint: u64 = 0;
    if (mc.args_vec != 0) { arg_count_hint = mc.args_vec.len(); }
    var arg_types: *Vec<*TypeInfo> = generic_collect_call_arg_types(mc.args_vec, g_lower_parse_sugar_symtab);
    var resolved: CompilerMethodResolveResult =
        sym_resolve_method_overload_with_count_fallback(recv_ti.struct_name, mc.method, arg_types, arg_count_hint);
    if (resolved.found == 0 || resolved.fn == 0) {
        var fallback_fn: *AstFunc = lower_find_method_signature_by_name_for_call(recv_ti.struct_name, mc.method, mc);
        if (fallback_fn != 0) {
            return lower_normalize_method_call_args_for_func(mc, fallback_fn);
        }
        if (call_has_named_args(mc.arg_names_vec) != 0) {
            diag_emit_error_tag("lowering", "L1007", "named arguments require a known method signature");
            diag_emit_labelled_name("method: ", mc.method);
            diag_error("Compiler error");
            return 0;
        }
        return 0;
    }

    return lower_normalize_method_call_args_for_func(mc, resolved.fn);
}

func lower_call_name_matches(name: []u8, target: []u8) -> u64 {
    if (str_eq(slice(name.ptr, name.len), slice(target.ptr, target.len)) != 0) { return 1; }
    if (call_name_matches_tail(slice(name.ptr, name.len), slice(target.ptr, target.len)) != 0) { return 1; }
    return 0;
}

func lower_call_is_direct_named(call: *AstCall, target: []u8) -> u64 {
    if (call == 0 || call.origin != AST_CALL_ORIGIN_DIRECT) { return 0; }
    return lower_call_name_matches(call.name, slice(target.ptr, target.len));
}

func lower_make_empty_args_vec() -> *Vec<*AstNode> {
    return new Vec<*AstNode>{heap_alloc((0) * sizeof(*AstNode)), 0, (0)};
}

func lower_make_single_arg_vec(arg0: *AstNode) -> *Vec<*AstNode> {
    var args: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((1) * sizeof(*AstNode)), 0, (1)};
    args.push(arg0);
    return args;
}

func lower_make_two_arg_vec(arg0: *AstNode, arg1: *AstNode) -> *Vec<*AstNode> {
    var args: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((2) * sizeof(*AstNode)), 0, (2)};
    args.push(arg0);
    args.push(arg1);
    return args;
}

func lower_make_direct_call0(name: []u8) -> *AstNode {
    return (*AstNode)ast_call(slice(name.ptr, name.len), lower_make_empty_args_vec());
}

func lower_make_direct_call1(name: []u8, arg0: *AstNode) -> *AstNode {
    return (*AstNode)ast_call(slice(name.ptr, name.len), lower_make_single_arg_vec(arg0));
}

func lower_make_direct_call2(name: []u8, arg0: *AstNode, arg1: *AstNode) -> *AstNode {
    return (*AstNode)ast_call(slice(name.ptr, name.len), lower_make_two_arg_vec(arg0, arg1));
}

func lower_number_static_method_name(method: []u8) -> *NameInfo {
    return build_method_name(slice("std_number__Number", 18), slice(method.ptr, method.len));
}

func lower_make_number_static_call_named(method: []u8, args: *Vec<*AstNode>, arg_names: *Vec<*NameInfo>) -> *AstNode {
    var name: *NameInfo = lower_number_static_method_name(slice(method.ptr, method.len));
    var call: *AstCall = ast_call_with_origin_named(
        slice(name.ptr, name.len),
        args,
        arg_names,
        AST_CALL_ORIGIN_MEMBER_LOWERED
    );
    lower_normalize_direct_call_args(call);
    return (*AstNode)call;
}

func lower_make_number_static_call(method: []u8, args: *Vec<*AstNode>) -> *AstNode {
    return lower_make_number_static_call_named(slice(method.ptr, method.len), args, 0);
}

func lower_make_number_from_i64_call(args: *Vec<*AstNode>) -> *AstNode {
    return lower_make_number_static_call(slice("from_i64", 8), args);
}

func lower_make_number_from_u64_call(args: *Vec<*AstNode>) -> *AstNode {
    return lower_make_number_static_call(slice("from_u64", 8), args);
}

func lower_make_number_from_f64_call(args: *Vec<*AstNode>) -> *AstNode {
    return lower_make_number_static_call(slice("from_f64", 8), args);
}

func lower_number_ctor_method_for_integer_kind(kind: u64) -> []u8 {
    if (kind == TYPE_I8) { return slice("from_i8", 7); }
    if (kind == TYPE_I16) { return slice("from_i16", 8); }
    if (kind == TYPE_I32) { return slice("from_i32", 8); }
    if (kind == TYPE_I64) { return slice("from_i64", 8); }
    if (kind == TYPE_U8) { return slice("from_u8", 7); }
    if (kind == TYPE_U16) { return slice("from_u16", 8); }
    if (kind == TYPE_U32) { return slice("from_u32", 8); }
    if (kind == TYPE_U64) { return slice("from_u64", 8); }
    if (kind == TYPE_BOOL) { return slice("from_u8", 7); }
    return slice(0, 0);
}

func lower_make_number_from_integer_kind_call(args: *Vec<*AstNode>, kind: u64) -> *AstNode {
    var method: []u8 = lower_number_ctor_method_for_integer_kind(kind);
    if (method.ptr == 0 || method.len == 0) { return lower_make_number_from_i64_call(args); }
    return lower_make_number_static_call(slice(method.ptr, method.len), args);
}

func lower_make_scalar_cast(expr: *AstNode, target_type: u64) -> *AstNode {
    return (*AstNode)ast_cast_ex(expr, target_type, 0, 0, slice(0, 0), slice(0, 0));
}

func lower_make_ast_string_literal(raw: []u8) -> *AstNode {
    var lit_ptr: u64 = heap_alloc((raw.len + 3) * sizeof(u8));
    if (lit_ptr == 0) { return 0; }
    var lit_u8: *u8 = (*u8)lit_ptr;
    lit_u8[0] = 34;
    str_copy(lit_ptr + 1, raw.ptr, raw.len);
    lit_u8[raw.len + 1] = 34;
    lit_u8[raw.len + 2] = 0;
    return (*AstNode)ast_string(slice(lit_ptr, raw.len + 2));
}

func lower_ti_is_unsigned_scalar(ti: *TypeInfo) -> u64 {
    if (ti == 0 || ti.ptr_depth != 0) { return 0; }
    if (ti.type_kind == TYPE_U8) { return 1; }
    if (ti.type_kind == TYPE_U16) { return 1; }
    if (ti.type_kind == TYPE_U32) { return 1; }
    if (ti.type_kind == TYPE_U64) { return 1; }
    return 0;
}

func lower_ti_is_signed_scalar(ti: *TypeInfo) -> u64 {
    if (ti == 0 || ti.ptr_depth != 0) { return 0; }
    if (ti.type_kind == TYPE_I8) { return 1; }
    if (ti.type_kind == TYPE_I16) { return 1; }
    if (ti.type_kind == TYPE_I32) { return 1; }
    if (ti.type_kind == TYPE_I64) { return 1; }
    return 0;
}

func lower_type_kind_is_unsigned_integer(kind: u64) -> u64 {
    if (kind == TYPE_U8) { return 1; }
    if (kind == TYPE_U16) { return 1; }
    if (kind == TYPE_U32) { return 1; }
    if (kind == TYPE_U64) { return 1; }
    return 0;
}

func lower_type_kind_is_signed_integer(kind: u64) -> u64 {
    if (kind == TYPE_I8) { return 1; }
    if (kind == TYPE_I16) { return 1; }
    if (kind == TYPE_I32) { return 1; }
    if (kind == TYPE_I64) { return 1; }
    return 0;
}

func lower_type_kind_is_integer(kind: u64) -> u64 {
    if (lower_type_kind_is_unsigned_integer(kind) != 0) { return 1; }
    if (lower_type_kind_is_signed_integer(kind) != 0) { return 1; }
    return 0;
}

func lower_type_kind_integer_width(kind: u64) -> u64 {
    match (kind) {
        case TYPE_U8:
        case TYPE_I8:
            return 8;
        case TYPE_U16:
        case TYPE_I16:
            return 16;
        case TYPE_U32:
        case TYPE_I32:
            return 32;
        case TYPE_U64:
        case TYPE_I64:
            return 64;
    }
    return 0;
}

func lower_can_implicit_integer_widen(src_kind: u64, dst_kind: u64) -> u64 {
    var src_width: u64 = lower_type_kind_integer_width(src_kind);
    var dst_width: u64 = lower_type_kind_integer_width(dst_kind);
    if (src_width == 0 || dst_width == 0 || src_width > dst_width) { return 0; }
    if (lower_type_kind_is_unsigned_integer(src_kind) != 0 && lower_type_kind_is_unsigned_integer(dst_kind) != 0) { return 1; }
    if (lower_type_kind_is_signed_integer(src_kind) != 0 && lower_type_kind_is_signed_integer(dst_kind) != 0) { return 1; }
    return 0;
}

func lower_prepare_named_typeinfo(ti: *TypeInfo) -> *TypeInfo {
    if (ti == 0) { return 0; }
    if ((ti.type_kind == TYPE_STRUCT || ti.type_kind == TYPE_TRAIT) && ti.struct_def != 0) {
        ti.struct_name = ti.struct_def.name;
    }
    if (ti.type_kind != TYPE_STRUCT) { return ti; }
    if (ti.struct_def == 0 && u8_slice_ptr(ti.struct_name) != 0 && u8_slice_len(ti.struct_name) != 0) {
        var struct_def: *AstStructDef = get_struct_def(ti.struct_name);
        if (struct_def == 0) {
            var resolved_name: *NameInfo = resolve_name(ti.struct_name);
            if (resolved_name != 0) {
                struct_def = get_struct_def(slice(resolved_name.ptr, resolved_name.len));
                if (struct_def != 0) {
                    ti.struct_name = slice(resolved_name.ptr, resolved_name.len);
                }
            }
        }
        ti.struct_def = struct_def;
    }
    return ti;
}

func lower_type_has_generic_suffix(name: []u8) -> u64 {
    if (name.ptr == 0 || name.len == 0) { return 0; }
    if (sym_find_generic_suffix_index(slice(name.ptr, name.len)) < name.len) { return 1; }
    return 0;
}

func lower_build_struct_meta_to_str_expr(name: []u8) -> *AstNode {
    return lower_make_direct_call2(slice("to_str_struct_meta", 18), lower_make_ast_string_literal(slice("struct", 6)), (*AstNode)ast_literal(6));
}

func lower_build_to_str_expr(expr: *AstNode, ti: *TypeInfo) -> *AstNode {
    if (expr == 0 || ti == 0) { return 0; }

    if (ti.ptr_depth == 1 && ti.type_kind == TYPE_U8) {
        return expr;
    }

    if (ti.type_kind == TYPE_STRUCT || ti.type_kind == TYPE_TRAIT) {
        ti = lower_prepare_named_typeinfo(ti);
        if (u8_slice_ptr(ti.struct_name) != 0 && u8_slice_len(ti.struct_name) != 0) {
            var resolved: CompilerMethodResolveResult = sym_resolve_method_overload_with_count_fallback(ti.struct_name, slice("to_str", 6), 0, 0);
            if (resolved.found != 0) {
                if (check_method_access_overload(ti.struct_name, slice("to_str", 6), 0, 0) == 0) {
                    diag_emit_error_tag("lowering", "L1700", "Cannot access overloaded operator method");
                    diag_emit_labelled_member("method: ", ti.struct_name, slice("to_str", 6));
                    diag_error("Compiler error");
                    return 0;
                }
                return (*AstNode)ast_method_call(expr, slice("to_str", 6), lower_make_empty_args_vec());
            }
            if (lower_type_has_generic_suffix(ti.struct_name) != 0 &&
                g_lower_parse_sugar_final_phase == 0) {
                return 0;
            }
        }

        if (ti.ptr_depth > 0) {
            return lower_make_direct_call1(slice("to_str_ptr_value", 16), lower_make_scalar_cast(expr, TYPE_U64));
        }
        if (u8_slice_ptr(ti.struct_name) != 0 && u8_slice_len(ti.struct_name) != 0) {
            return lower_build_struct_meta_to_str_expr(ti.struct_name);
        }
        if (ti.type_kind == TYPE_TRAIT) {
            return lower_make_direct_call2(slice("to_str_struct_meta", 18), lower_make_ast_string_literal(slice("trait", 5)), (*AstNode)ast_literal(5));
        }
        return lower_build_struct_meta_to_str_expr(slice(0, 0));
    }

    if (ti.ptr_depth > 0) {
        return lower_make_direct_call1(slice("to_str_ptr_value", 16), lower_make_scalar_cast(expr, TYPE_U64));
    }

    if (ti.type_kind == TYPE_BOOL) {
        return lower_make_direct_call1(slice("to_str_bool", 11), lower_make_scalar_cast(expr, TYPE_U64));
    }
    if (lower_ti_is_unsigned_scalar(ti) != 0) {
        return lower_make_direct_call1(slice("to_str_u64", 10), lower_make_scalar_cast(expr, TYPE_U64));
    }
    if (lower_ti_is_signed_scalar(ti) != 0) {
        return lower_make_direct_call1(slice("to_str_i64", 10), lower_make_scalar_cast(expr, TYPE_I64));
    }
    if (ti.type_kind == TYPE_F64) {
        return lower_make_direct_call1(slice("to_str_f64", 10), expr);
    }
    if (ti.type_kind == TYPE_NULL) {
        return lower_make_direct_call0(slice("to_str_null", 11));
    }
    if (ti.type_kind == TYPE_SLICE) {
        if (ti.elem_type_kind == TYPE_U8 && ti.elem_ptr_depth == 0) {
            return lower_make_direct_call1(slice("to_str_u8_slice", 15), expr);
        }
        return lower_make_direct_call1(slice("to_str_slice", 12), expr);
    }
    if (ti.type_kind == TYPE_ARRAY) {
        return lower_make_direct_call1(slice("to_str_array_meta", 17), (*AstNode)ast_literal(ti.array_len));
    }
    if (ti.type_kind == TYPE_FUNC) {
        return lower_make_direct_call0(slice("to_str_func_meta", 16));
    }
    return 0;
}

func lower_parse_sugar_ctor_call(call: *AstCall) -> *AstNode {
    if (call == 0) { return 0; }
    if (call.origin != AST_CALL_ORIGIN_DIRECT) { return (*AstNode)call; }

    var ctor_struct: CompilerResolvedStructName = lower_try_resolve_struct_name(call.name);
    if (ctor_struct.found == 0) {
        return (*AstNode)call;
    }

    var ctor_name: *NameInfo = _compiler_build_constructor_name(ctor_struct.resolved);
    var ctor_fn: *AstFunc = lower_find_func_signature_for_call(slice(ctor_name.ptr, ctor_name.len));
    if (ctor_fn != 0) {
        call.args_vec = lower_normalize_call_args_for_params(slice(ctor_name.ptr, ctor_name.len), ctor_fn.params_vec, 1, call.args_vec, call.arg_names_vec);
        call.arg_names_vec = 0;
    } else if (call_has_named_args(call.arg_names_vec) != 0) {
        diag_emit_error_tag("lowering", "L1007", "named constructor arguments require a known constructor signature");
        diag_emit_labelled_name("type: ", call.name);
        diag_error("Compiler error");
        return 0;
    }

    return (*AstNode)ast_stack_ctor(TYPE_STRUCT, 0, 0, ctor_struct.resolved, slice(0, 0), 0, 0, 0, 0, slice(0, 0), 0, call.args_vec);
}

func lower_parse_sugar_generic_ctor_call(gcall: *AstGenericCall) -> *AstNode {
    if (gcall == 0) { return 0; }
    if (gcall.origin != AST_CALL_ORIGIN_DIRECT) { return (*AstNode)gcall; }

    var tpl: *GenericStructTemplate = lower_try_resolve_generic_struct_template(gcall.name);
    if (tpl == 0) {
        return (*AstNode)gcall;
    }

    var bindings: *Vec<*GenericBinding> = generic_build_bindings_for_struct(tpl, gcall.generic_args_vec);
    var name_info: *NameInfo = generic_struct_get_or_create_instance(tpl, bindings);
    gcall.arg_names_vec = 0;
    return (*AstNode)ast_stack_ctor(TYPE_STRUCT, 0, 0, slice(name_info.ptr, name_info.len), slice(0, 0), 0, 0, 0, 0, slice(0, 0), 0, gcall.args_vec);
}

func lower_parse_sugar_generic_struct_literal(gsl: *AstGenericStructLiteral) -> *AstNode {
    if (gsl == 0) { return 0; }

    var tpl: *GenericStructTemplate = lower_try_resolve_generic_struct_template(gsl.name);
    if (tpl == 0) {
        diag_emit_error_tag("lowering", "L1008", "Generic struct template not found");
        diag_emit_labelled_name("template: ", gsl.name);
        diag_error("Compiler error");
        return 0;
    }

    var bindings: *Vec<*GenericBinding> = generic_build_bindings_for_struct(tpl, gsl.generic_args_vec);
    var name_info: *NameInfo = generic_struct_get_or_create_instance(tpl, bindings);
    var struct_def: *AstStructDef = get_struct_def(slice(name_info.ptr, name_info.len));
    if (struct_def == 0) {
        diag_emit_error_tag("lowering", "L1009", "Generic struct definition is missing");
        diag_emit_labelled_name("instance: ", slice(name_info.ptr, name_info.len));
        diag_error("Compiler error");
        return 0;
    }
    if (struct_def.is_union == 1 && gsl.values_vec != 0 && gsl.values_vec.len() > 1) {
        diag_emit_error_tag("lowering", "L1010", "union literal accepts at most one initializer");
        diag_error("Compiler error");
        return 0;
    }
    return (*AstNode)ast_struct_literal(struct_def, gsl.values_vec);
}

func lower_parse_sugar_static_generic_method_call(sgc: *AstStaticGenericCall) -> *AstNode {
    if (sgc == 0) { return 0; }

    var static_struct: CompilerResolvedStructName = lower_try_resolve_struct_name(sgc.struct_name);
    if (static_struct.found == 0) {
        diag_emit_error_tag("lowering", "L1011", "static generic method owner type not found");
        diag_emit_labelled_name("owner: ", sgc.struct_name);
        diag_error("Compiler error");
        return 0;
    }

    var lowered_name: *NameInfo = build_method_name(static_struct.resolved, sgc.method);
    var lowered_call: *AstGenericCall = ast_generic_call_with_origin_named(slice(lowered_name.ptr, lowered_name.len), sgc.generic_args_vec, sgc.args_vec, sgc.arg_names_vec, AST_CALL_ORIGIN_MEMBER_LOWERED);
    lower_normalize_generic_call_args(lowered_call);
    return (*AstNode)lowered_call;
}

func lower_parse_sugar_static_method_call(mc: *AstMethodCall, is_safe: u64) -> *AstNode {
    if (mc == 0 || mc.receiver == 0) { return (*AstNode)mc; }
    if (ast_kind(mc.receiver) != AST_IDENT) { return (*AstNode)mc; }

    var recv_id: *AstIdent = (*AstIdent)mc.receiver;
    var module_target: *NameInfo = sym_resolve_module_scoped_symbol(recv_id.name, mc.method);
    if (module_target != 0) {
        if (is_safe != 0) {
            diag_emit_error_tag("lowering", "L1012", "safe navigation is not allowed for module-qualified call");
            diag_error("Compiler error");
            return 0;
        }
        var mod_call: *AstCall = ast_call_with_origin_named(slice(module_target.ptr, module_target.len), mc.args_vec, mc.arg_names_vec, AST_CALL_ORIGIN_MEMBER_LOWERED);
        lower_normalize_direct_call_args(mod_call);
        return (*AstNode)mod_call;
    }

    var static_recv_struct: CompilerResolvedStructName = lower_try_resolve_struct_name(recv_id.name);
    if (static_recv_struct.found == 0) {
        return (*AstNode)mc;
    }

    if (is_safe != 0) {
        diag_emit_error_tag("lowering", "L1013", "safe navigation is not allowed for static method call");
        diag_error("Compiler error");
        return 0;
    }

    var lowered_name: *NameInfo = build_method_name(static_recv_struct.resolved, mc.method);
    var lowered_call: *AstCall = ast_call_with_origin_named(slice(lowered_name.ptr, lowered_name.len), mc.args_vec, mc.arg_names_vec, AST_CALL_ORIGIN_MEMBER_LOWERED);
    lower_normalize_direct_call_args(lowered_call);
    return (*AstNode)lowered_call;
}

func lower_magic_method_expected_call_arity(kind: u64) -> u64 {
    if (kind == COMPILER_MAGIC_METHOD_TO_STR || kind == COMPILER_MAGIC_METHOD_HASH) { return 1; }
    if (kind == COMPILER_MAGIC_METHOD_EQ || kind == COMPILER_MAGIC_METHOD_CMP) { return 2; }
    return 0;
}

func lower_parse_sugar_builtin_to_str_call(call: *AstCall) -> *AstNode {
    if (lower_call_is_direct_named(call, slice("to_str", 6)) == 0) { return (*AstNode)call; }
    if (call.args_vec == 0 || call.args_vec.len() != 1) { return (*AstNode)call; }
    if (call_has_named_args(call.arg_names_vec) != 0) { return (*AstNode)call; }

    var exact_fn: *AstFunc = sym_get_func(call.name);
    if (exact_fn != 0 && (u8_slice_ptr(exact_fn.impl_owner) == 0 || u8_slice_len(exact_fn.impl_owner) == 0)) {
        return (*AstNode)call;
    }

    var arg: *AstNode = call.args_vec.get(0);
    var arg_ti: *TypeInfo = generic_infer_expr_type(arg, g_lower_parse_sugar_symtab);
    if (arg_ti == 0) { return (*AstNode)call; }

    var lowered: *AstNode = lower_build_to_str_expr(arg, arg_ti);
    if (lowered == 0) { return (*AstNode)call; }
    return lowered;
}

func lower_parse_sugar_print_direct_call(call: *AstCall) -> *AstNode {
    if (call == 0 || call.origin != AST_CALL_ORIGIN_DIRECT) { return (*AstNode)call; }
    if (call.args_vec == 0 || call.args_vec.len() != 1) { return (*AstNode)call; }
    if (call_has_named_args(call.arg_names_vec) != 0) { return (*AstNode)call; }

    var emit_name: []u8 = slice(0, 0);
    if (lower_call_name_matches(call.name, slice("print", 5)) != 0) {
        emit_name = slice("print_cstr", 10);
    } else if (lower_call_name_matches(call.name, slice("println", 7)) != 0) {
        emit_name = slice("println_cstr", 12);
    } else {
        return (*AstNode)call;
    }

    var to_str_call: *AstCall = ast_call(slice("to_str", 6), lower_make_single_arg_vec(call.args_vec.get(0)));
    var lowered_arg: *AstNode = lower_parse_sugar_expr((*AstNode)to_str_call);
    var lowered_emit: *AstCall = ast_call(emit_name, lower_make_single_arg_vec(lowered_arg));
    return lower_parse_sugar_expr((*AstNode)lowered_emit);
}

func lower_raw_emit_arg_is_cstr_compatible(arg: *AstNode, ti: *TypeInfo) -> u64 {
    if (arg == 0) { return 1; }
    if (ast_kind(arg) == AST_STRING) { return 1; }
    if (ti == 0) { return 1; }
    if (ti.ptr_depth != 0) { return 1; }
    if (ti.type_kind == TYPE_U64) { return 1; }
    return 0;
}

func lower_parse_sugar_validate_raw_emit_direct_call(call: *AstCall) -> u64 {
    if (call == 0 || call.origin != AST_CALL_ORIGIN_DIRECT) { return 0; }
    if (call.args_vec == 0 || call.args_vec.len() != 1) { return 0; }
    if (call_has_named_args(call.arg_names_vec) != 0) { return 0; }
    if (lower_call_name_matches(call.name, slice("emit", 4)) == 0 &&
        lower_call_name_matches(call.name, slice("emitln", 6)) == 0) {
        return 0;
    }

    var arg: *AstNode = call.args_vec.get(0);
    var arg_ti: *TypeInfo = generic_infer_expr_type(arg, g_lower_parse_sugar_symtab);
    if (lower_raw_emit_arg_is_cstr_compatible(arg, arg_ti) != 0) { return 0; }

    diag_emit_error_tag("lowering", "L1201", "raw emit expects a C-string pointer");
    emit_stderr("  callee: ");
    emit_stderr_len(u8_slice_ptr(call.name), u8_slice_len(call.name));
    emit_stderr_nl();
    diag_emit_help("use println(value) for buffered formatted output");
    diag_emit_help("use emitln(value.to_str()) when you want explicit raw text emission");
    if (arg_ti != 0) {
        emit_stderr("  argument type: ");
        lower_exc_emit_type_name(arg_ti);
        emit_stderr_nl();
    }
    diag_error("Compilation failed");
    return 0;
}

func lower_parse_sugar_magic_direct_call(call: *AstCall) -> *AstNode {
    if (call == 0) { return 0; }
    if (call.origin != AST_CALL_ORIGIN_DIRECT) { return (*AstNode)call; }
    var exact_fn: *AstFunc = sym_get_func(call.name);
    if (exact_fn != 0 && (u8_slice_ptr(exact_fn.impl_owner) == 0 || u8_slice_len(exact_fn.impl_owner) == 0)) {
        return (*AstNode)call;
    }

    var kind: u64 = sym_magic_method_kind(call.name);
    if (kind == COMPILER_MAGIC_METHOD_NONE) { return (*AstNode)call; }
    if (call.args_vec == 0 || call.args_vec.len() == 0) { return (*AstNode)call; }

    var expected_arity: u64 = lower_magic_method_expected_call_arity(kind);
    if (expected_arity == 0 || call.args_vec.len() != expected_arity) { return (*AstNode)call; }
    var method_arity: u64 = expected_arity - 1;
    var receiver: *AstNode = call.args_vec.get(0);
    var recv_ti: *TypeInfo = lower_operator_receiver_type(receiver);
    if (recv_ti == 0) { return (*AstNode)call; }
    var method_args: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((method_arity) * sizeof(*AstNode)), 0, (method_arity)};
    var method_arg_names: *Vec<*NameInfo> = 0;
    if (method_arity == 1) {
        method_args.push(call.args_vec.get(1));
        if (call.arg_names_vec != 0 && call.arg_names_vec.len() == call.args_vec.len()) {
            method_arg_names = new Vec<*NameInfo>{heap_alloc((1) * sizeof(*NameInfo)), 0, (1)};
            method_arg_names.push(call.arg_names_vec.get(1));
        }
    }
    return (*AstNode)ast_method_call_named(receiver, call.name, method_args, method_arg_names);
}

func lower_make_struct_typeinfo_if_defined(name: []u8) -> *TypeInfo {
    if (get_struct_def(slice(name.ptr, name.len)) == 0) { return 0; }
    return generic_make_typeinfo_from_fields(TYPE_STRUCT, 0, 0, slice(name.ptr, name.len), slice(0, 0), 0, 0, 0, 0, slice(0, 0));
}

func lower_make_number_struct_typeinfo() -> *TypeInfo {
    var local_ti: *TypeInfo = lower_make_struct_typeinfo_if_defined(slice("Number", 6));
    if (local_ti != 0) { return local_ti; }
    return lower_make_struct_typeinfo_if_defined(slice("std_number__Number", 18));
}

func lower_make_string_struct_typeinfo() -> *TypeInfo {
    var local_ti: *TypeInfo = lower_make_struct_typeinfo_if_defined(slice("string", 6));
    if (local_ti != 0) { return local_ti; }
    return lower_make_struct_typeinfo_if_defined(slice("std_string__string", 18));
}

func lower_make_u8_slice_typeinfo() -> *TypeInfo {
    return generic_make_typeinfo_from_fields(TYPE_SLICE, 0, 0, slice(0, 0), slice(0, 0), TYPE_U8, 0, 0, 0, slice(0, 0));
}

func lower_make_primitive_typeinfo(type_kind: u64, ptr_depth: u64) -> *TypeInfo {
    return generic_make_typeinfo_from_fields(type_kind, ptr_depth, 0, slice(0, 0), slice(0, 0), 0, 0, 0, 0, slice(0, 0));
}

func lower_infer_known_call_type(expr: *AstNode) -> *TypeInfo {
    if (expr == 0 || ast_kind(expr) != AST_CALL) { return 0; }
    var call: *AstCall = (*AstCall)expr;
    if (lower_call_is_direct_named(call, slice("input", 5)) != 0) { return lower_make_primitive_typeinfo(TYPE_U8, 1); }
    if (lower_call_is_direct_named(call, slice("input_slice", 11)) != 0) { return lower_make_u8_slice_typeinfo(); }
    if (lower_call_is_direct_named(call, slice("string_input", 12)) != 0) { return lower_make_string_struct_typeinfo(); }
    if (lower_call_name_matches(call.name, slice("std_number__Number_input", str_len("std_number__Number_input"))) != 0) { return lower_make_number_struct_typeinfo(); }
    if (lower_call_is_direct_named(call, slice("input_bool", 10)) != 0) { return lower_make_primitive_typeinfo(TYPE_BOOL, 0); }
    if (lower_call_is_direct_named(call, slice("input_u8", 8)) != 0) { return lower_make_primitive_typeinfo(TYPE_U8, 0); }
    if (lower_call_is_direct_named(call, slice("input_u16", 9)) != 0) { return lower_make_primitive_typeinfo(TYPE_U16, 0); }
    if (lower_call_is_direct_named(call, slice("input_u32", 9)) != 0) { return lower_make_primitive_typeinfo(TYPE_U32, 0); }
    if (lower_call_is_direct_named(call, slice("input_u64", 9)) != 0) { return lower_make_primitive_typeinfo(TYPE_U64, 0); }
    if (lower_call_is_direct_named(call, slice("input_i8", 8)) != 0) { return lower_make_primitive_typeinfo(TYPE_I8, 0); }
    if (lower_call_is_direct_named(call, slice("input_i16", 9)) != 0) { return lower_make_primitive_typeinfo(TYPE_I16, 0); }
    if (lower_call_is_direct_named(call, slice("input_i32", 9)) != 0) { return lower_make_primitive_typeinfo(TYPE_I32, 0); }
    if (lower_call_is_direct_named(call, slice("input_i64", 9)) != 0) { return lower_make_primitive_typeinfo(TYPE_I64, 0); }
    if (lower_call_is_direct_named(call, slice("input_f64", 9)) != 0) { return lower_make_primitive_typeinfo(TYPE_F64, 0); }
    return 0;
}

func lower_operator_receiver_type(expr: *AstNode) -> *TypeInfo {
    if (expr == 0) { return 0; }
    if (ast_kind(expr) == AST_CALL) {
        var c: *AstCall = (*AstCall)expr;
        if (lower_call_expr_returns_number(c) != 0) {
            var number_ti: *TypeInfo = lower_make_number_struct_typeinfo();
            if (number_ti != 0) { return number_ti; }
        }
    }
    var ti: *TypeInfo = generic_infer_expr_type(expr, g_lower_parse_sugar_symtab);
    if (ti == 0 || ti.type_kind != TYPE_STRUCT) { return 0; }
    if (u8_slice_ptr(ti.struct_name) == 0 || u8_slice_len(ti.struct_name) == 0) {
        if (ti.struct_def != 0) {
            ti.struct_name = ti.struct_def.name;
        }
    }
    if (u8_slice_ptr(ti.struct_name) == 0 || u8_slice_len(ti.struct_name) == 0) { return 0; }
    if (get_struct_def(ti.struct_name) == 0) { return 0; }
    return ti;
}

func lower_operator_arg_type_for_overload(arg: *AstNode) -> *TypeInfo {
    if (lower_is_integer_literal_expr(arg) != 0) {
        if (lower_integer_literal_is_negative(arg) != 0) {
            return generic_make_typeinfo_from_fields(TYPE_I64, 0, 0, slice(0, 0), slice(0, 0), 0, 0, 0, 0, slice(0, 0));
        }
        return generic_make_typeinfo_from_fields(TYPE_U64, 0, 0, slice(0, 0), slice(0, 0), 0, 0, 0, 0, slice(0, 0));
    }
    return generic_infer_expr_type(arg, g_lower_parse_sugar_symtab);
}

func lower_operator_arg_type_vec1(arg0: *AstNode) -> *Vec<*TypeInfo> {
    var out: *Vec<*TypeInfo> = new Vec<*TypeInfo>{heap_alloc((1) * sizeof(*TypeInfo)), 0, (1)};
    out.push(lower_operator_arg_type_for_overload(arg0));
    return out;
}

func lower_operator_arg_type_vec2(arg0: *AstNode, arg1: *AstNode) -> *Vec<*TypeInfo> {
    var out: *Vec<*TypeInfo> = new Vec<*TypeInfo>{heap_alloc((2) * sizeof(*TypeInfo)), 0, (2)};
    out.push(lower_operator_arg_type_for_overload(arg0));
    out.push(lower_operator_arg_type_for_overload(arg1));
    return out;
}

func lower_operator_can_dispatch(receiver: *AstNode, method: []u8, arg_types: *Vec<*TypeInfo>, arg_count_hint: u64) -> u64 {
    var recv_ti: *TypeInfo = lower_operator_receiver_type(receiver);
    if (recv_ti == 0) { return 0; }
    if (recv_ti.ptr_depth != 0) { return 0; }

    var resolved: CompilerMethodResolveResult = sym_resolve_method_overload_with_count_fallback(recv_ti.struct_name, slice(method.ptr, method.len), arg_types, arg_count_hint);
    if (resolved.found == 0) { return 0; }

    if (check_method_access_overload(recv_ti.struct_name, slice(method.ptr, method.len), arg_types, arg_count_hint) == 0) {
        diag_emit_error_tag("lowering", "L1700", "Cannot access overloaded operator method");
        diag_emit_labelled_member("method: ", recv_ti.struct_name, slice(method.ptr, method.len));
        diag_error("Compiler error");
    }
    return 1;
}

func lower_name_is_number_type(name: []u8) -> u64 {
    return lower_name_matches_aliases(slice(name.ptr, name.len), slice("Number", 6), slice("std_number__Number", 18));
}

func lower_name_is_string_type(name: []u8) -> u64 {
    return lower_name_matches_aliases(slice(name.ptr, name.len), slice("string", 6), slice("std_string__string", 18));
}

func lower_name_matches_aliases(name: []u8, local: []u8, fq: []u8) -> u64 {
    if (name.ptr == 0 || name.len == 0) { return 0; }
    if (str_eq(slice(name.ptr, name.len), slice(local.ptr, local.len)) != 0) { return 1; }
    if (str_eq(slice(name.ptr, name.len), slice(fq.ptr, fq.len)) != 0) { return 1; }
    return 0;
}

func lower_name_is_number_builtin(name: []u8, base: []u8) -> u64 {
    if (name.ptr == 0 || name.len == 0 || base.ptr == 0 || base.len == 0) { return 0; }
    if (str_eq(slice(name.ptr, name.len), slice(base.ptr, base.len)) != 0) { return 1; }
    var prefix_ptr: u64 = (u64)"std_number__";
    var prefix_len: u64 = 12;
    if (name.len == prefix_len + base.len &&
        str_eq(slice(name.ptr, prefix_len), slice(prefix_ptr, prefix_len)) != 0 &&
        str_eq(slice(name.ptr + prefix_len, base.len), slice(base.ptr, base.len)) != 0) {
        return 1;
    }
    return 0;
}

func lower_name_is_number_returning_builtin(name: []u8) -> u64 {
    if (lower_name_is_number_builtin(name, slice("Number_from_i8", 14)) != 0) { return 1; }
    if (lower_name_is_number_builtin(name, slice("Number_from_i16", 15)) != 0) { return 1; }
    if (lower_name_is_number_builtin(name, slice("Number_from_i32", 15)) != 0) { return 1; }
    if (lower_name_is_number_builtin(name, slice("Number_from_i64", 15)) != 0) { return 1; }
    if (lower_name_is_number_builtin(name, slice("Number_from_u8", 14)) != 0) { return 1; }
    if (lower_name_is_number_builtin(name, slice("Number_from_u16", 15)) != 0) { return 1; }
    if (lower_name_is_number_builtin(name, slice("Number_from_u32", 15)) != 0) { return 1; }
    if (lower_name_is_number_builtin(name, slice("Number_from_u64", 15)) != 0) { return 1; }
    if (lower_name_is_number_builtin(name, slice("Number_from_f64", 15)) != 0) { return 1; }
    if (lower_name_is_number_builtin(name, slice("Number_from_complex", 19)) != 0) { return 1; }
    if (lower_name_is_number_builtin(name, slice("Number_from_complex_f64", 23)) != 0) { return 1; }
    if (lower_name_is_number_builtin(name, slice("Number_from_rational", str_len("Number_from_rational"))) != 0) { return 1; }
    if (lower_name_is_number_builtin(name, slice("Number_from_decimal", str_len("Number_from_decimal"))) != 0) { return 1; }
    if (lower_name_is_number_builtin(name, slice("Number_from_bigfloat", str_len("Number_from_bigfloat"))) != 0) { return 1; }
    if (str_eq(slice(name.ptr, name.len), slice("std_number__Number_from_str", str_len("std_number__Number_from_str"))) != 0) { return 1; }
    if (str_eq(slice(name.ptr, name.len), slice("Number_from_str", str_len("Number_from_str"))) != 0) { return 1; }
    if (str_eq(slice(name.ptr, name.len), slice("std_number__Number_input", str_len("std_number__Number_input"))) != 0) { return 1; }
    if (str_eq(slice(name.ptr, name.len), slice("Number_input", str_len("Number_input"))) != 0) { return 1; }
    return 0;
}

func lower_call_expr_returns_number(call: *AstCall) -> u64 {
    if (call == 0) { return 0; }
    if (lower_name_is_number_returning_builtin(call.name) != 0) { return 1; }
    var resolved: *NameInfo = resolve_name(call.name);
    if (resolved != 0 && lower_name_is_number_returning_builtin(slice(resolved.ptr, resolved.len)) != 0) { return 1; }
    var fn: *AstFunc = lower_find_func_signature_for_call(call.name);
    if (fn != 0) {
        var ret_ti: *TypeInfo = lower_make_typeinfo_from_func_return(fn);
        if (lower_is_number_struct_type(ret_ti) != 0) { return 1; }
    }
    return 0;
}

func lower_number_method_returns_number(method: []u8) -> u64 {
    if (method.ptr == 0 || method.len == 0) { return 0; }
    if (str_eq(slice(method.ptr, method.len), slice("clone", str_len("clone"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("negated", str_len("negated"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("abs_with_sign", str_len("abs_with_sign"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("add_values", str_len("add_values"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("sub_values", str_len("sub_values"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("mul_values", str_len("mul_values"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("div_values", str_len("div_values"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("mod_values", str_len("mod_values"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("mul_small", str_len("mul_small"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("abs_clone", str_len("abs_clone"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("div_small_abs", str_len("div_small_abs"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("bitwise_nonneg_abs", str_len("bitwise_nonneg_abs"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("bitwise_values", str_len("bitwise_values"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("bitnot_values", str_len("bitnot_values"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("shl_values", str_len("shl_values"))) != 0) { return 1; }
    if (str_eq(slice(method.ptr, method.len), slice("shr_values", str_len("shr_values"))) != 0) { return 1; }
    return 0;
}

func lower_method_expr_returns_number(expr: *AstNode) -> u64 {
    if (expr == 0) { return 0; }
    var expr_kind: u64 = ast_kind(expr);
    if (expr_kind != AST_METHOD_CALL && expr_kind != AST_SAFE_METHOD_CALL) { return 0; }
    var mc: *AstMethodCall = (*AstMethodCall)expr;
    if (lower_number_method_returns_number(mc.method) == 0) { return 0; }
    var receiver_ti: *TypeInfo = generic_infer_expr_type(mc.receiver, g_lower_parse_sugar_symtab);
    return lower_is_number_struct_type(receiver_ti);
}

func lower_is_number_struct_type(ti: *TypeInfo) -> u64 {
    return lower_is_struct_type_named(ti, slice("Number", 6), slice("std_number__Number", 18));
}

func lower_is_string_struct_type(ti: *TypeInfo) -> u64 {
    return lower_is_struct_type_named(ti, slice("string", 6), slice("std_string__string", 18));
}

func lower_is_struct_type_named(ti: *TypeInfo, local: []u8, fq: []u8) -> u64 {
    if (ti == 0 || ti.type_kind != TYPE_STRUCT || ti.ptr_depth != 0) { return 0; }
    if (lower_name_matches_aliases(ti.struct_name, slice(local.ptr, local.len), slice(fq.ptr, fq.len)) != 0) { return 1; }
    if (ti.struct_def != 0 && lower_name_matches_aliases(ti.struct_def.name, slice(local.ptr, local.len), slice(fq.ptr, fq.len)) != 0) { return 1; }
    return 0;
}

func lower_is_integer_literal_expr(expr: *AstNode) -> u64 {
    if (expr == 0) { return 0; }
    var k: u64 = ast_kind(expr);
    if (k == AST_LITERAL) { return 1; }
    if (k == AST_UNARY) {
        var un: *AstUnary = (*AstUnary)expr;
        if (un.op == TOKEN_MINUS && un.operand != 0 && ast_kind(un.operand) == AST_LITERAL) {
            return 1;
        }
    }
    return 0;
}

func lower_is_integer_const_expr(expr: *AstNode) -> u64 {
    if (expr == 0) { return 0; }
    if (lower_is_integer_literal_expr(expr) != 0) { return 1; }
    var k: u64 = ast_kind(expr);
    if (k == AST_UNARY) {
        var un: *AstUnary = (*AstUnary)expr;
        if (un.op != TOKEN_PLUS && un.op != TOKEN_MINUS && un.op != TOKEN_TILDE) { return 0; }
        return lower_is_integer_const_expr(un.operand);
    }
    if (k == AST_BINARY) {
        var bin: *AstBinary = (*AstBinary)expr;
        if (generic_number_binary_result_op(bin.op) == 0) { return 0; }
        if (lower_is_integer_const_expr(bin.left) == 0) { return 0; }
        if (lower_is_integer_const_expr(bin.right) == 0) { return 0; }
        return 1;
    }
    return 0;
}

func lower_typeinfo_is_integer_scalar(ti: *TypeInfo) -> u64 {
    if (ti == 0 || ti.ptr_depth != 0) { return 0; }
    return lower_type_kind_is_integer(ti.type_kind);
}

func lower_binary_uses_number_semantics_with_types(bin: *AstBinary, left_ti: *TypeInfo, right_ti: *TypeInfo) -> u64 {
    if (bin == 0) { return 0; }
    var left_is_number: u64 = lower_is_number_struct_type(left_ti);
    var right_is_number: u64 = lower_is_number_struct_type(right_ti);
    if (left_is_number == 0 && ast_kind(bin.left) == AST_CALL && lower_call_expr_returns_number((*AstCall)bin.left) != 0) {
        left_is_number = 1;
    }
    if (right_is_number == 0 && ast_kind(bin.right) == AST_CALL && lower_call_expr_returns_number((*AstCall)bin.right) != 0) {
        right_is_number = 1;
    }
    if (left_is_number == 0 && lower_method_expr_returns_number(bin.left) != 0) {
        left_is_number = 1;
    }
    if (right_is_number == 0 && lower_method_expr_returns_number(bin.right) != 0) {
        right_is_number = 1;
    }
    if (left_is_number == 0 && right_is_number == 0) { return 0; }

    if (left_is_number != 0 &&
        lower_is_integer_literal_expr(bin.left) != 0 &&
        lower_typeinfo_is_integer_scalar(right_ti) != 0) {
        left_is_number = 0;
    }
    if (right_is_number != 0 &&
        lower_is_integer_literal_expr(bin.right) != 0 &&
        lower_typeinfo_is_integer_scalar(left_ti) != 0) {
        right_is_number = 0;
    }
    if (left_is_number != 0 &&
        lower_is_integer_literal_expr(bin.left) != 0 &&
        right_ti != 0 && right_ti.type_kind == TYPE_STRUCT &&
        lower_is_number_struct_type(right_ti) == 0) {
        left_is_number = 0;
    }
    if (right_is_number != 0 &&
        lower_is_integer_literal_expr(bin.right) != 0 &&
        left_ti != 0 && left_ti.type_kind == TYPE_STRUCT &&
        lower_is_number_struct_type(left_ti) == 0) {
        right_is_number = 0;
    }
    if (left_is_number != 0 || right_is_number != 0) { return 1; }
    return 0;
}

func lower_integer_literal_is_negative(expr: *AstNode) -> u64 {
    if (expr == 0 || ast_kind(expr) != AST_UNARY) { return 0; }
    var un: *AstUnary = (*AstUnary)expr;
    if (un.op == TOKEN_MINUS && un.operand != 0 && ast_kind(un.operand) == AST_LITERAL) {
        return 1;
    }
    return 0;
}

func lower_integer_literal_magnitude(expr: *AstNode) -> u64 {
    if (expr == 0) { return 0; }
    if (ast_kind(expr) == AST_LITERAL) {
        var lit: *AstLiteral = (*AstLiteral)expr;
        return lit.value;
    }
    if (lower_integer_literal_is_negative(expr) != 0) {
        var un: *AstUnary = (*AstUnary)expr;
        var neg_lit: *AstLiteral = (*AstLiteral)un.operand;
        return neg_lit.value;
    }
    return 0;
}

func lower_unsigned_integer_max(kind: u64) -> u64 {
    match (kind) {
        case TYPE_U8: return 255;
        case TYPE_U16: return 65535;
        case TYPE_U32: return 4294967295;
        case TYPE_U64: return 0 - 1;
    }
    return 0;
}

func lower_signed_integer_positive_max(kind: u64) -> u64 {
    match (kind) {
        case TYPE_I8: return 127;
        case TYPE_I16: return 32767;
        case TYPE_I32: return 2147483647;
        case TYPE_I64: return 9223372036854775807;
    }
    return 0;
}

func lower_signed_integer_negative_max_mag(kind: u64) -> u64 {
    match (kind) {
        case TYPE_I8: return 128;
        case TYPE_I16: return 32768;
        case TYPE_I32: return 2147483648;
        case TYPE_I64: return 9223372036854775808;
    }
    return 0;
}

func lower_integer_literal_fits_type(expr: *AstNode, target_kind: u64) -> u64 {
    if (lower_is_integer_literal_expr(expr) == 0) { return 0; }
    var value: u64 = lower_integer_literal_magnitude(expr);
    if (lower_type_kind_is_unsigned_integer(target_kind) != 0) {
        if (lower_integer_literal_is_negative(expr) != 0) { return 0; }
        if (value <= lower_unsigned_integer_max(target_kind)) { return 1; }
        return 0;
    }
    if (lower_type_kind_is_signed_integer(target_kind) != 0) {
        if (lower_integer_literal_is_negative(expr) != 0) {
            if (value <= lower_signed_integer_negative_max_mag(target_kind)) { return 1; }
            return 0;
        }
        if (value <= lower_signed_integer_positive_max(target_kind)) { return 1; }
        return 0;
    }
    return 0;
}

func lower_number_literal_ctor_kind(expr: *AstNode) -> u64 {
    var value: u64 = lower_integer_literal_magnitude(expr);
    if (lower_integer_literal_is_negative(expr) != 0) {
        if (value <= lower_signed_integer_negative_max_mag(TYPE_I8)) { return TYPE_I8; }
        if (value <= lower_signed_integer_negative_max_mag(TYPE_I16)) { return TYPE_I16; }
        if (value <= lower_signed_integer_negative_max_mag(TYPE_I32)) { return TYPE_I32; }
        return TYPE_I64;
    }
    if (value <= lower_unsigned_integer_max(TYPE_U8)) { return TYPE_U8; }
    if (value <= lower_unsigned_integer_max(TYPE_U16)) { return TYPE_U16; }
    if (value <= lower_unsigned_integer_max(TYPE_U32)) { return TYPE_U32; }
    return TYPE_U64;
}

func lower_wrap_integer_literal_to_number(expr: *AstNode) -> *AstNode {
    if (lower_is_integer_literal_expr(expr) == 0) { return 0; }
    var args: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((1) * sizeof(*AstNode)), 0, (1)};
    args.push(expr);
    return lower_make_number_from_integer_kind_call(args, lower_number_literal_ctor_kind(expr));
}

func lower_wrap_integer_const_expr_parts_to_number(expr: *AstNode) -> *AstNode {
    if (expr == 0) { return 0; }
    if (lower_is_integer_literal_expr(expr) != 0) {
        return lower_wrap_integer_literal_to_number(expr);
    }

    var k: u64 = ast_kind(expr);
    if (k == AST_UNARY) {
        var un: *AstUnary = (*AstUnary)expr;
        if (un.op != TOKEN_PLUS && un.op != TOKEN_MINUS && un.op != TOKEN_TILDE) { return 0; }
        var wrapped_operand: *AstNode = lower_wrap_integer_const_expr_parts_to_number(un.operand);
        if (wrapped_operand == 0) { return 0; }
        return (*AstNode)ast_unary(un.op, wrapped_operand);
    }
    if (k == AST_BINARY) {
        var bin: *AstBinary = (*AstBinary)expr;
        if (generic_number_binary_result_op(bin.op) == 0) { return 0; }
        var wrapped_left: *AstNode = lower_wrap_integer_const_expr_parts_to_number(bin.left);
        var wrapped_right: *AstNode = lower_wrap_integer_const_expr_parts_to_number(bin.right);
        if (wrapped_left == 0 || wrapped_right == 0) { return 0; }
        return (*AstNode)ast_binary(bin.op, wrapped_left, wrapped_right);
    }
    return 0;
}

func lower_make_cast_for_typeinfo(expr: *AstNode, expected_ti: *TypeInfo) -> *AstNode {
    if (expr == 0 || expected_ti == 0) { return expr; }
    return (*AstNode)ast_cast_ex(expr, expected_ti.type_kind, expected_ti.ptr_depth, expected_ti.is_tagged, expected_ti.struct_name, expected_ti.tag_layout);
}

func lower_expr_already_number_semantic(expr: *AstNode, actual_ti: *TypeInfo) -> u64 {
    if (expr == 0) { return 0; }
    if (lower_is_number_struct_type(actual_ti) != 0) { return 1; }
    var expr_kind: u64 = ast_kind(expr);
    if (expr_kind == AST_CALL && lower_call_expr_returns_number((*AstCall)expr) != 0) { return 1; }
    if (lower_method_expr_returns_number(expr) != 0) { return 1; }
    if (expr_kind == AST_BINARY) {
        var bin: *AstBinary = (*AstBinary)expr;
        var left_ti: *TypeInfo = generic_infer_expr_type(bin.left, g_lower_parse_sugar_symtab);
        var right_ti: *TypeInfo = generic_infer_expr_type(bin.right, g_lower_parse_sugar_symtab);
        if (lower_binary_uses_number_semantics_with_types(bin, left_ti, right_ti) != 0) { return 1; }
    }
    if (expr_kind == AST_UNARY) {
        var un: *AstUnary = (*AstUnary)expr;
        if (lower_is_number_struct_type(lower_operator_receiver_type(un.operand)) != 0) { return 1; }
    }
    return 0;
}

func lower_binary_operator_returns_bool(op: u64) -> u64 {
    if (op == TOKEN_EQEQ || op == TOKEN_BANGEQ || op == TOKEN_LT || op == TOKEN_LTEQ || op == TOKEN_GT || op == TOKEN_GTEQ) { return 1; }
    if (op == TOKEN_ANDAND || op == TOKEN_OROR) { return 1; }
    return 0;
}

func lower_expr_returns_number_value(expr: *AstNode, actual_ti: *TypeInfo) -> u64 {
    if (expr == 0) { return 0; }
    if (lower_is_number_struct_type(actual_ti) != 0) { return 1; }
    var expr_kind: u64 = ast_kind(expr);
    if (expr_kind == AST_CALL && lower_call_expr_returns_number((*AstCall)expr) != 0) { return 1; }
    if (lower_method_expr_returns_number(expr) != 0) { return 1; }
    if (expr_kind == AST_BINARY) {
        var bin: *AstBinary = (*AstBinary)expr;
        if (lower_binary_operator_returns_bool(bin.op) != 0) { return 0; }
        var left_ti: *TypeInfo = generic_infer_expr_type(bin.left, g_lower_parse_sugar_symtab);
        var right_ti: *TypeInfo = generic_infer_expr_type(bin.right, g_lower_parse_sugar_symtab);
        if (lower_binary_uses_number_semantics_with_types(bin, left_ti, right_ti) != 0) { return 1; }
    }
    if (expr_kind == AST_UNARY) {
        var un: *AstUnary = (*AstUnary)expr;
        if (un.op == TOKEN_BANG) { return 0; }
        if (lower_is_number_struct_type(lower_operator_receiver_type(un.operand)) != 0) { return 1; }
    }
    if (expr_kind == AST_CAST) {
        var cast_expr: *AstCast = (*AstCast)expr;
        if (cast_expr.target_type == TYPE_STRUCT && cast_expr.target_ptr_depth == 0 &&
            lower_name_is_number_type(cast_expr.struct_name) != 0) {
            return 1;
        }
    }
    return 0;
}

func lower_number_to_integer_method_name(kind: u64) -> *NameInfo {
    match (kind) {
        case TYPE_I8: return new NameInfo{(u64)"to_i8_checked_value", str_len("to_i8_checked_value")};
        case TYPE_I16: return new NameInfo{(u64)"to_i16_checked_value", str_len("to_i16_checked_value")};
        case TYPE_I32: return new NameInfo{(u64)"to_i32_checked_value", str_len("to_i32_checked_value")};
        case TYPE_I64: return new NameInfo{(u64)"to_i64_checked_value", str_len("to_i64_checked_value")};
        case TYPE_U8: return new NameInfo{(u64)"to_u8_checked_value", str_len("to_u8_checked_value")};
        case TYPE_U16: return new NameInfo{(u64)"to_u16_checked_value", str_len("to_u16_checked_value")};
        case TYPE_U32: return new NameInfo{(u64)"to_u32_checked_value", str_len("to_u32_checked_value")};
        case TYPE_U64: return new NameInfo{(u64)"to_u64_checked_value", str_len("to_u64_checked_value")};
    }
    return 0;
}

func lower_wrap_number_expr_to_integer(expr: *AstNode, target_kind: u64, actual_ti: *TypeInfo) -> *AstNode {
    if (expr == 0) { return 0; }
    if (lower_type_kind_is_integer(target_kind) == 0) { return 0; }
    if (lower_expr_returns_number_value(expr, actual_ti) == 0) { return 0; }
    var method: *NameInfo = lower_number_to_integer_method_name(target_kind);
    if (method == 0) { return 0; }
    return (*AstNode)ast_method_call(
        expr,
        slice(method.ptr, method.len),
        lower_make_empty_args_vec()
    );
}

func lower_wrap_integer_expr_to_number(expr: *AstNode, actual_ti: *TypeInfo) -> *AstNode {
    if (expr == 0) { return 0; }
    if (lower_is_integer_literal_expr(expr) != 0) {
        return lower_wrap_integer_literal_to_number(expr);
    }
    if (lower_is_integer_const_expr(expr) != 0) {
        return lower_wrap_integer_const_expr_parts_to_number(expr);
    }
    var expr_kind: u64 = ast_kind(expr);
    if (expr_kind == AST_STRUCT_LITERAL || expr_kind == AST_GENERIC_STRUCT_LITERAL || expr_kind == AST_STACK_CTOR || expr_kind == AST_NEW) {
        return 0;
    }
    if (expr_kind == AST_CALL && lower_call_expr_returns_number((*AstCall)expr) != 0) {
        return 0;
    }
    if (actual_ti == 0 || actual_ti.ptr_depth != 0) { return 0; }
    if (lower_expr_already_number_semantic(expr, actual_ti) != 0) { return 0; }

    var target_kind: u64 = 0;
    if (lower_type_kind_is_unsigned_integer(actual_ti.type_kind) != 0) {
        target_kind = actual_ti.type_kind;
    } else if (lower_type_kind_is_signed_integer(actual_ti.type_kind) != 0) {
        target_kind = actual_ti.type_kind;
    } else if (actual_ti.type_kind == TYPE_BOOL) {
        target_kind = TYPE_U8;
    } else {
        return 0;
    }

    var arg: *AstNode = expr;
    if (actual_ti.type_kind != target_kind) {
        arg = lower_make_scalar_cast(expr, target_kind);
    }
    var args: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((1) * sizeof(*AstNode)), 0, (1)};
    args.push(arg);
    return lower_make_number_from_integer_kind_call(args, target_kind);
}

func lower_wrap_float_expr_to_number(expr: *AstNode, actual_ti: *TypeInfo) -> *AstNode {
    if (expr == 0) { return 0; }
    var expr_kind: u64 = ast_kind(expr);
    if (expr_kind == AST_STRUCT_LITERAL || expr_kind == AST_GENERIC_STRUCT_LITERAL || expr_kind == AST_STACK_CTOR || expr_kind == AST_NEW) {
        return 0;
    }
    if (expr_kind == AST_CALL && lower_call_expr_returns_number((*AstCall)expr) != 0) {
        return 0;
    }
    if (lower_expr_already_number_semantic(expr, actual_ti) != 0) { return 0; }
    if (expr_kind != AST_FLOAT) {
        if (actual_ti == 0 || actual_ti.ptr_depth != 0 || actual_ti.type_kind != TYPE_F64) {
            return 0;
        }
    }
    var args: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((1) * sizeof(*AstNode)), 0, (1)};
    args.push(expr);
    return lower_make_number_from_f64_call(args);
}

func lower_number_integer_ctor_call_fallback_kind(call: *AstCall) -> u64 {
    if (call == 0) { return 0; }
    if (lower_name_is_number_builtin(call.name, slice("Number_from_i64", 15)) != 0) { return TYPE_I64; }
    if (lower_name_is_number_builtin(call.name, slice("Number_from_u64", 15)) != 0) { return TYPE_U64; }
    return 0;
}

func lower_number_ctor_rewrite_kind_from_arg(arg: *AstNode, fallback_kind: u64, out_arg: **AstNode) -> u64 {
    if (out_arg != 0) { out_arg[0] = arg; }
    if (arg == 0) { return fallback_kind; }
    if (ast_kind(arg) == AST_CAST) {
        var c: *AstCast = (*AstCast)arg;
        if (lower_is_integer_literal_expr(c.expr) != 0) {
            if (out_arg != 0) { out_arg[0] = c.expr; }
            return lower_number_literal_ctor_kind(c.expr);
        }
        if (lower_type_kind_is_integer(c.target_type) != 0 || c.target_type == TYPE_BOOL) {
            return c.target_type;
        }
    }
    if (lower_is_integer_literal_expr(arg) != 0) {
        return lower_number_literal_ctor_kind(arg);
    }
    var ti: *TypeInfo = generic_infer_expr_type(arg, g_lower_parse_sugar_symtab);
    if (ti != 0 && ti.ptr_depth == 0) {
        if (lower_type_kind_is_unsigned_integer(ti.type_kind) != 0 ||
            lower_type_kind_is_signed_integer(ti.type_kind) != 0 ||
            ti.type_kind == TYPE_BOOL) {
            return ti.type_kind;
        }
    }
    return fallback_kind;
}

func lower_rewrite_number_integer_ctor_call(call: *AstCall) -> *AstNode {
    var fallback_kind: u64 = lower_number_integer_ctor_call_fallback_kind(call);
    if (fallback_kind == 0) { return (*AstNode)call; }
    var args: *Vec<*AstNode> = call.args_vec;
    if (args == 0 || args.len() != 1) { return (*AstNode)call; }
    var arg: *AstNode = args.get(0);
    var narrowed_arg: *AstNode = arg;
    var target_kind: u64 = lower_number_ctor_rewrite_kind_from_arg(arg, fallback_kind, &narrowed_arg);
    if (target_kind == fallback_kind) { return (*AstNode)call; }
    if (narrowed_arg == 0) { narrowed_arg = arg; }
    if (target_kind != TYPE_BOOL && lower_type_kind_is_integer(target_kind) == 0) { return (*AstNode)call; }
    if (ast_kind(narrowed_arg) != AST_CAST) {
        narrowed_arg = lower_make_scalar_cast(narrowed_arg, target_kind);
    }
    var out_args: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((1) * sizeof(*AstNode)), 0, (1)};
    out_args.push(narrowed_arg);
    return lower_make_number_from_integer_kind_call(out_args, target_kind);
}

func lower_number_storage_ctor_kind(name: []u8) -> u64 {
    if (lower_name_is_number_builtin(name, slice("Number_from_i8", 14)) != 0) { return TYPE_I8; }
    if (lower_name_is_number_builtin(name, slice("Number_from_i16", 15)) != 0) { return TYPE_I16; }
    if (lower_name_is_number_builtin(name, slice("Number_from_i32", 15)) != 0) { return TYPE_I32; }
    if (lower_name_is_number_builtin(name, slice("Number_from_i64", 15)) != 0) { return TYPE_I64; }
    if (lower_name_is_number_builtin(name, slice("Number_from_u8", 14)) != 0) { return TYPE_U8; }
    if (lower_name_is_number_builtin(name, slice("Number_from_u16", 15)) != 0) { return TYPE_U16; }
    if (lower_name_is_number_builtin(name, slice("Number_from_u32", 15)) != 0) { return TYPE_U32; }
    if (lower_name_is_number_builtin(name, slice("Number_from_u64", 15)) != 0) { return TYPE_U64; }
    if (lower_name_is_number_builtin(name, slice("Number_from_f64", 15)) != 0) { return TYPE_F64; }
    return 0;
}

func lower_number_storage_ctor_kind_from_expr(expr: *AstNode) -> u64 {
    if (expr == 0 || ast_kind(expr) != AST_CALL) { return 0; }
    var call: *AstCall = (*AstCall)expr;
    if (call.args_vec == 0 || call.args_vec.len() != 1) { return 0; }
    return lower_number_storage_ctor_kind(call.name);
}

func lower_number_storage_decl_initial_kind(vd: *AstVarDecl) -> u64 {
    if (vd == 0) { return 0; }
    if (vd.type_kind != TYPE_STRUCT || vd.ptr_depth != 0) { return 0; }
    if (lower_name_is_number_type(vd.struct_name) == 0) { return 0; }
    return lower_number_storage_ctor_kind_from_expr(vd.init_expr);
}

func lower_number_storage_clear_stmt(stmt: u64) -> u64 {
    if (stmt == 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    var nref: AstNodeTagRef;
    nref.node = (*AstNode)stmt;
    match (kind) {
        case AST_VAR_DECL:
            var vd: *AstVarDecl = nref.var_decl;
            vd.number_storage_kind = 0;
            return 0;
        case AST_DEFER:
            var df: *AstDefer = nref.defer_stmt;
            return lower_number_storage_clear_stmt(df.stmt);
        case AST_IF:
            var ifs: *AstIf = nref.if_stmt;
            lower_number_storage_clear_stmt(ifs.then_block);
            lower_number_storage_clear_stmt(ifs.else_block);
            return 0;
        case AST_WHILE:
            var wl: *AstWhile = nref.while_stmt;
            return lower_number_storage_clear_stmt(wl.body);
        case AST_FOR:
            var fr: *AstFor = nref.for_stmt;
            lower_number_storage_clear_stmt(fr.init);
            return lower_number_storage_clear_stmt(fr.body);
        case AST_DO_WHILE:
            var dw: *AstDoWhile = nref.do_while_stmt;
            return lower_number_storage_clear_stmt(dw.body);
        case AST_SWITCH:
        case AST_MATCH:
            var sw: *AstSwitch = nref.switch_stmt;
            if (sw.cases_vec != 0) {
                var cn: u64 = sw.cases_vec.len();
                for (var ci: u64 = 0; ci < cn; ci++) {
                    lower_number_storage_clear_stmt(sw.cases_vec.get(ci));
                }
            }
            return 0;
        case AST_CASE:
            var cs: *AstCase = nref.case_stmt;
            return lower_number_storage_clear_stmt(cs.body);
        case AST_BLOCK:
            var blk: *AstBlock = nref.block_stmt;
            if (blk.stmts_vec != 0) {
                var n: u64 = blk.stmts_vec.len();
                for (var i: u64 = 0; i < n; i++) {
                    lower_number_storage_clear_stmt(blk.stmts_vec.get(i));
                }
            }
            return 0;
    }
    return 0;
}

func lower_number_storage_stmt_contains_inline_asm(stmt: u64) -> u64 {
    if (stmt == 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    var nref: AstNodeTagRef;
    nref.node = (*AstNode)stmt;
    match (kind) {
        case AST_ASM: return 1;
        case AST_DEFER:
            var df: *AstDefer = nref.defer_stmt;
            return lower_number_storage_stmt_contains_inline_asm(df.stmt);
        case AST_IF:
            var ifs: *AstIf = nref.if_stmt;
            if (lower_number_storage_stmt_contains_inline_asm(ifs.then_block) != 0) { return 1; }
            return lower_number_storage_stmt_contains_inline_asm(ifs.else_block);
        case AST_WHILE:
            var wl: *AstWhile = nref.while_stmt;
            return lower_number_storage_stmt_contains_inline_asm(wl.body);
        case AST_FOR:
            var fr: *AstFor = nref.for_stmt;
            if (lower_number_storage_stmt_contains_inline_asm(fr.init) != 0) { return 1; }
            return lower_number_storage_stmt_contains_inline_asm(fr.body);
        case AST_DO_WHILE:
            var dw: *AstDoWhile = nref.do_while_stmt;
            return lower_number_storage_stmt_contains_inline_asm(dw.body);
        case AST_SWITCH:
        case AST_MATCH:
            var sw: *AstSwitch = nref.switch_stmt;
            if (sw.cases_vec == 0) { return 0; }
            var cn: u64 = sw.cases_vec.len();
            for (var ci: u64 = 0; ci < cn; ci++) {
                if (lower_number_storage_stmt_contains_inline_asm(sw.cases_vec.get(ci)) != 0) { return 1; }
            }
            return 0;
        case AST_CASE:
            var cs: *AstCase = nref.case_stmt;
            return lower_number_storage_stmt_contains_inline_asm(cs.body);
        case AST_BLOCK:
            var blk: *AstBlock = nref.block_stmt;
            if (blk.stmts_vec == 0) { return 0; }
            var n: u64 = blk.stmts_vec.len();
            for (var i: u64 = 0; i < n; i++) {
                if (lower_number_storage_stmt_contains_inline_asm(blk.stmts_vec.get(i)) != 0) { return 1; }
            }
            return 0;
    }
    return 0;
}

func lower_number_storage_name_is_valid(name: []u8) -> u64 {
    if (name.ptr < 4096 || name.len == 0 || name.len > 1024) { return 0; }
    return 1;
}

func lower_number_storage_block_name(candidates: *HashMap<u64, u64>, blocked: *HashMap<u64, u64>, name: []u8) -> u64 {
    if (candidates == 0) { return 0; }
    if (blocked == 0) { return 0; }
    var key: []u8 = name;
    if (lower_number_storage_name_is_valid(key) == 0) { return 0; }
    if (candidates.has(key) == 0) { return 0; }
    blocked.put(key, 1);
    return 0;
}

func lower_number_storage_scan_expr_vec(candidates: *HashMap<u64, u64>, blocked: *HashMap<u64, u64>, exprs: *Vec<*AstNode>) -> u64 {
    if (exprs == 0) { return 0; }
    var n: u64 = exprs.len();
    for (var i: u64 = 0; i < n; i++) {
        lower_number_storage_scan_expr(candidates, blocked, exprs.get(i));
    }
    return 0;
}

func lower_number_storage_scan_pair(candidates: *HashMap<u64, u64>, blocked: *HashMap<u64, u64>, lhs: u64, rhs: u64) -> u64 {
    lower_number_storage_scan_expr(candidates, blocked, lhs);
    lower_number_storage_scan_expr(candidates, blocked, rhs);
    return 0;
}

func lower_number_storage_scan_expr(candidates: *HashMap<u64, u64>, blocked: *HashMap<u64, u64>, expr: u64) -> u64 {
    if (expr == 0) { return 0; }
    var kind: u64 = ast_kind(expr);
    var nref: AstNodeTagRef;
    nref.node = (*AstNode)expr;
    match (kind) {
        case AST_ASSIGN:
            var asn_expr: *AstAssign = nref.assign_stmt;
            if (asn_expr.target != 0 && ast_kind(asn_expr.target) == AST_IDENT) {
                var asn_id_ref: AstNodeTagRef;
                asn_id_ref.node = asn_expr.target;
                lower_number_storage_block_name(candidates, blocked, asn_id_ref.ident.name);
            }
            lower_number_storage_scan_expr(candidates, blocked, asn_expr.target);
            lower_number_storage_scan_expr(candidates, blocked, asn_expr.value);
            return 0;
        case AST_ADDR_OF:
            var ao: *AstAddrOf = nref.addr_of;
            if (ao.operand != 0 && ast_kind(ao.operand) == AST_IDENT) {
                var id_ref: AstNodeTagRef;
                id_ref.node = ao.operand;
                lower_number_storage_block_name(candidates, blocked, id_ref.ident.name);
            } else {
                lower_number_storage_scan_expr(candidates, blocked, ao.operand);
            }
            return 0;
        case AST_BINARY:
            var bin: *AstBinary = nref.binary;
            return lower_number_storage_scan_pair(candidates, blocked, bin.left, bin.right);
        case AST_TERNARY:
            var tern: *AstTernary = nref.ternary_expr;
            lower_number_storage_scan_expr(candidates, blocked, tern.cond);
            lower_number_storage_scan_expr(candidates, blocked, tern.then_expr);
            lower_number_storage_scan_expr(candidates, blocked, tern.else_expr);
            return 0;
        case AST_UNARY:
            var un: *AstUnary = nref.unary;
            return lower_number_storage_scan_expr(candidates, blocked, un.operand);
        case AST_TRY:
            var tr: *AstTry = nref.try_expr;
            return lower_number_storage_scan_expr(candidates, blocked, tr.operand);
        case AST_CAST:
            var cs: *AstCast = nref.cast_expr;
            return lower_number_storage_scan_expr(candidates, blocked, cs.expr);
        case AST_DEREF:
            var dr: *AstDeref = nref.deref;
            return lower_number_storage_scan_expr(candidates, blocked, dr.operand);
        case AST_DEREF8:
            var dr8: *AstDeref8 = nref.deref8;
            return lower_number_storage_scan_expr(candidates, blocked, dr8.operand);
        case AST_INDEX:
        case AST_SAFE_INDEX:
            var ix: *AstIndex = nref.index_expr;
            return lower_number_storage_scan_pair(candidates, blocked, ix.base, ix.index);
        case AST_MEMBER_ACCESS:
        case AST_SAFE_MEMBER_ACCESS:
            var ma: *AstMemberAccess = nref.member_access;
            if (ma.object != 0 && ast_kind(ma.object) == AST_IDENT) {
                var obj_ref: AstNodeTagRef;
                obj_ref.node = ma.object;
                lower_number_storage_block_name(candidates, blocked, obj_ref.ident.name);
            }
            return lower_number_storage_scan_expr(candidates, blocked, ma.object);
        case AST_CALL:
            var call: *AstCall = nref.call;
            return lower_number_storage_scan_expr_vec(candidates, blocked, call.args_vec);
        case AST_GENERIC_CALL:
            var gcall: *AstGenericCall = nref.generic_call;
            return lower_number_storage_scan_expr_vec(candidates, blocked, gcall.args_vec);
        case AST_STATIC_GENERIC_CALL:
            var sgc: *AstStaticGenericCall = nref.static_generic_call;
            return lower_number_storage_scan_expr_vec(candidates, blocked, sgc.args_vec);
        case AST_METHOD_CALL:
        case AST_SAFE_METHOD_CALL:
            var mc: *AstMethodCall = nref.method_call;
            if (mc.receiver != 0 && ast_kind(mc.receiver) == AST_IDENT) {
                var recv_ref: AstNodeTagRef;
                recv_ref.node = mc.receiver;
                lower_number_storage_block_name(candidates, blocked, recv_ref.ident.name);
            }
            lower_number_storage_scan_expr(candidates, blocked, mc.receiver);
            lower_number_storage_scan_expr_vec(candidates, blocked, mc.args_vec);
            return 0;
        case AST_CALL_PTR:
            var cp: *AstCallPtr = nref.call_ptr;
            lower_number_storage_scan_expr(candidates, blocked, cp.callee);
            lower_number_storage_scan_expr_vec(candidates, blocked, cp.args_vec);
            return 0;
        case AST_SLICE:
            var sl: *AstSlice = nref.slice_expr;
            return lower_number_storage_scan_pair(candidates, blocked, sl.ptr_expr, sl.len_expr);
        case AST_SIZEOF_EXPR:
            var se: *AstSizeofExpr = nref.sizeof_expr;
            return lower_number_storage_scan_expr(candidates, blocked, se.expr);
        case AST_STRUCT_LITERAL:
            var st: *AstStructLiteral = nref.struct_lit;
            return lower_number_storage_scan_expr_vec(candidates, blocked, st.values_vec);
        case AST_GENERIC_STRUCT_LITERAL:
            var gst: *AstGenericStructLiteral = nref.generic_struct_lit;
            return lower_number_storage_scan_expr_vec(candidates, blocked, gst.values_vec);
        case AST_NEW:
            var nw: *AstNew = nref.new_expr;
            lower_number_storage_scan_expr(candidates, blocked, nw.literal_expr);
            lower_number_storage_scan_expr_vec(candidates, blocked, nw.ctor_args_vec);
            return 0;
        case AST_STACK_CTOR:
            var sc: *AstStackCtor = nref.stack_ctor;
            return lower_number_storage_scan_expr_vec(candidates, blocked, sc.ctor_args_vec);
    }
    return 0;
}

func lower_number_storage_collect_candidates(stmt: u64, candidates: *HashMap<u64, u64>, blocked: *HashMap<u64, u64>) -> u64 {
    if (stmt == 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    var nref: AstNodeTagRef;
    nref.node = (*AstNode)stmt;
    match (kind) {
        case AST_VAR_DECL:
            var vd: *AstVarDecl = nref.var_decl;
            vd.number_storage_kind = 0;
            var storage_kind: u64 = lower_number_storage_decl_initial_kind(vd);
            if (storage_kind != 0) {
                var vd_name: []u8 = vd.name;
                if (lower_number_storage_name_is_valid(vd_name) == 0) { return 0; }
                if (candidates.has(vd_name) != 0) {
                    lower_number_storage_block_name(candidates, blocked, vd_name);
                } else {
                    candidates.put(vd_name, storage_kind);
                }
                return 1;
            }
            return 0;
        case AST_DEFER:
            var df: *AstDefer = nref.defer_stmt;
            return lower_number_storage_collect_candidates(df.stmt, candidates, blocked);
        case AST_IF:
            var ifs: *AstIf = nref.if_stmt;
            var if_found: u64 = lower_number_storage_collect_candidates(ifs.then_block, candidates, blocked);
            if_found = if_found + lower_number_storage_collect_candidates(ifs.else_block, candidates, blocked);
            return if_found;
        case AST_WHILE:
            var wl: *AstWhile = nref.while_stmt;
            return lower_number_storage_collect_candidates(wl.body, candidates, blocked);
        case AST_FOR:
            var fr: *AstFor = nref.for_stmt;
            var for_found: u64 = lower_number_storage_collect_candidates(fr.init, candidates, blocked);
            for_found = for_found + lower_number_storage_collect_candidates(fr.body, candidates, blocked);
            return for_found;
        case AST_DO_WHILE:
            var dw: *AstDoWhile = nref.do_while_stmt;
            return lower_number_storage_collect_candidates(dw.body, candidates, blocked);
        case AST_SWITCH:
        case AST_MATCH:
            var sw: *AstSwitch = nref.switch_stmt;
            var switch_found: u64 = 0;
            if (sw.cases_vec != 0) {
                var cn: u64 = sw.cases_vec.len();
                for (var ci: u64 = 0; ci < cn; ci++) {
                    switch_found = switch_found + lower_number_storage_collect_candidates(sw.cases_vec.get(ci), candidates, blocked);
                }
            }
            return switch_found;
        case AST_CASE:
            var cs: *AstCase = nref.case_stmt;
            return lower_number_storage_collect_candidates(cs.body, candidates, blocked);
        case AST_BLOCK:
            var blk: *AstBlock = nref.block_stmt;
            var block_found: u64 = 0;
            if (blk.stmts_vec != 0) {
                var n: u64 = blk.stmts_vec.len();
                for (var i: u64 = 0; i < n; i++) {
                    block_found = block_found + lower_number_storage_collect_candidates(blk.stmts_vec.get(i), candidates, blocked);
                }
            }
            return block_found;
    }
    return 0;
}

func lower_number_storage_scan_stmt(stmt: u64, candidates: *HashMap<u64, u64>, blocked: *HashMap<u64, u64>) -> u64 {
    if (stmt == 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    var nref: AstNodeTagRef;
    nref.node = (*AstNode)stmt;
    match (kind) {
        case AST_VAR_DECL:
            var vd: *AstVarDecl = nref.var_decl;
            return lower_number_storage_scan_expr(candidates, blocked, vd.init_expr);
        case AST_ASSIGN:
            var asn: *AstAssign = nref.assign_stmt;
            if (asn.target != 0 && ast_kind(asn.target) == AST_IDENT) {
                var id_ref: AstNodeTagRef;
                id_ref.node = asn.target;
                lower_number_storage_block_name(candidates, blocked, id_ref.ident.name);
            }
            lower_number_storage_scan_expr(candidates, blocked, asn.target);
            lower_number_storage_scan_expr(candidates, blocked, asn.value);
            return 0;
        case AST_EXPR_STMT:
            var es: *AstExprStmt = nref.expr_stmt;
            return lower_number_storage_scan_expr(candidates, blocked, es.expr);
        case AST_DEFER:
            var df: *AstDefer = nref.defer_stmt;
            return lower_number_storage_scan_stmt(df.stmt, candidates, blocked);
        case AST_DELETE:
            var dl: *AstDelete = nref.delete_stmt;
            return lower_number_storage_scan_expr(candidates, blocked, dl.expr);
        case AST_RETURN:
            var ret: *AstReturn = nref.ret_stmt;
            return lower_number_storage_scan_expr(candidates, blocked, ret.expr);
        case AST_IF:
            var ifs: *AstIf = nref.if_stmt;
            lower_number_storage_scan_expr(candidates, blocked, ifs.cond);
            lower_number_storage_scan_stmt(ifs.then_block, candidates, blocked);
            lower_number_storage_scan_stmt(ifs.else_block, candidates, blocked);
            return 0;
        case AST_WHILE:
            var wl: *AstWhile = nref.while_stmt;
            lower_number_storage_scan_expr(candidates, blocked, wl.cond);
            return lower_number_storage_scan_stmt(wl.body, candidates, blocked);
        case AST_FOR:
            var fr: *AstFor = nref.for_stmt;
            lower_number_storage_scan_stmt(fr.init, candidates, blocked);
            lower_number_storage_scan_expr(candidates, blocked, fr.cond);
            lower_number_storage_scan_expr(candidates, blocked, fr.update);
            lower_number_storage_scan_stmt(fr.body, candidates, blocked);
            return 0;
        case AST_DO_WHILE:
            var dw: *AstDoWhile = nref.do_while_stmt;
            lower_number_storage_scan_stmt(dw.body, candidates, blocked);
            lower_number_storage_scan_expr(candidates, blocked, dw.cond);
            return 0;
        case AST_SWITCH:
        case AST_MATCH:
            var sw: *AstSwitch = nref.switch_stmt;
            lower_number_storage_scan_expr(candidates, blocked, sw.expr);
            if (sw.cases_vec != 0) {
                var cn: u64 = sw.cases_vec.len();
                for (var ci: u64 = 0; ci < cn; ci++) {
                    lower_number_storage_scan_stmt(sw.cases_vec.get(ci), candidates, blocked);
                }
            }
            return 0;
        case AST_CASE:
            var cs: *AstCase = nref.case_stmt;
            return lower_number_storage_scan_stmt(cs.body, candidates, blocked);
        case AST_BLOCK:
            var blk: *AstBlock = nref.block_stmt;
            if (blk.stmts_vec != 0) {
                var n: u64 = blk.stmts_vec.len();
                for (var i: u64 = 0; i < n; i++) {
                    lower_number_storage_scan_stmt(blk.stmts_vec.get(i), candidates, blocked);
                }
            }
            return 0;
    }
    return 0;
}

func lower_number_storage_apply_stmt(stmt: u64, candidates: *HashMap<u64, u64>, blocked: *HashMap<u64, u64>) -> u64 {
    if (stmt == 0) { return 0; }
    var kind: u64 = ast_kind(stmt);
    var nref: AstNodeTagRef;
    nref.node = (*AstNode)stmt;
    match (kind) {
        case AST_VAR_DECL:
            var vd: *AstVarDecl = nref.var_decl;
            vd.number_storage_kind = 0;
            var vd_name: []u8 = vd.name;
            if (lower_number_storage_name_is_valid(vd_name) == 0) { return 0; }
            if (candidates.has(vd_name) != 0) {
                if (blocked.get(vd_name) != 0) { return 0; }
                var storage_kind: u64 = candidates.get(vd_name);
                if (storage_kind != 0 && lower_number_storage_decl_initial_kind(vd) == storage_kind) {
                    vd.number_storage_kind = storage_kind;
                }
            }
            return 0;
        case AST_DEFER:
            var df: *AstDefer = nref.defer_stmt;
            return lower_number_storage_apply_stmt(df.stmt, candidates, blocked);
        case AST_IF:
            var ifs: *AstIf = nref.if_stmt;
            lower_number_storage_apply_stmt(ifs.then_block, candidates, blocked);
            lower_number_storage_apply_stmt(ifs.else_block, candidates, blocked);
            return 0;
        case AST_WHILE:
            var wl: *AstWhile = nref.while_stmt;
            return lower_number_storage_apply_stmt(wl.body, candidates, blocked);
        case AST_FOR:
            var fr: *AstFor = nref.for_stmt;
            lower_number_storage_apply_stmt(fr.init, candidates, blocked);
            return lower_number_storage_apply_stmt(fr.body, candidates, blocked);
        case AST_DO_WHILE:
            var dw: *AstDoWhile = nref.do_while_stmt;
            return lower_number_storage_apply_stmt(dw.body, candidates, blocked);
        case AST_SWITCH:
        case AST_MATCH:
            var sw: *AstSwitch = nref.switch_stmt;
            if (sw.cases_vec != 0) {
                var cn: u64 = sw.cases_vec.len();
                for (var ci: u64 = 0; ci < cn; ci++) {
                    lower_number_storage_apply_stmt(sw.cases_vec.get(ci), candidates, blocked);
                }
            }
            return 0;
        case AST_CASE:
            var cs: *AstCase = nref.case_stmt;
            return lower_number_storage_apply_stmt(cs.body, candidates, blocked);
        case AST_BLOCK:
            var blk: *AstBlock = nref.block_stmt;
            if (blk.stmts_vec != 0) {
                var n: u64 = blk.stmts_vec.len();
                for (var i: u64 = 0; i < n; i++) {
                    lower_number_storage_apply_stmt(blk.stmts_vec.get(i), candidates, blocked);
                }
            }
            return 0;
    }
    return 0;
}

func lower_number_storage_prepare_function(fn: *AstFunc) -> u64 {
    if (fn == 0 || fn.body == 0) { return 0; }
    lower_number_storage_clear_stmt(fn.body);
    if (lower_number_storage_stmt_contains_inline_asm(fn.body) != 0) { return 0; }

    var candidates: *HashMap<u64, u64> = new HashMap<u64, u64>{0, 0, 0};
    candidates.ensure_capacity(32);
    var blocked: *HashMap<u64, u64> = new HashMap<u64, u64>{0, 0, 0};
    blocked.ensure_capacity(32);

    if (lower_number_storage_collect_candidates(fn.body, candidates, blocked) == 0) { return 0; }
    lower_number_storage_scan_stmt(fn.body, candidates, blocked);
    lower_number_storage_apply_stmt(fn.body, candidates, blocked);
    return 0;
}

func lower_make_typeinfo_from_vardecl(vd: *AstVarDecl) -> *TypeInfo {
    if (vd == 0) { return 0; }
    var ti: *TypeInfo = generic_make_typeinfo_from_fields(vd.type_kind, vd.ptr_depth, vd.is_tagged, vd.struct_name, vd.tag_layout, vd.elem_type_kind, vd.elem_ptr_depth, vd.array_len, vd.array_len_is_param, vd.array_len_param);
    if (ti != 0) { ti.elem_typeinfo = vd.elem_typeinfo; }
    return ti;
}

func lower_var_decl_needs_inference(vd: *AstVarDecl) -> u64 {
    if (vd == 0) { return 0; }
    if (vd.type_kind != TYPE_VOID) { return 0; }
    if (vd.ptr_depth != 0) { return 0; }
    return 1;
}

func lower_var_decl_register_typeinfo(vd: *AstVarDecl, ti: *TypeInfo) -> u64 {
    if (vd == 0 || ti == 0) { return 0; }
    if (g_lower_parse_sugar_symtab == 0) { return 0; }
    g_lower_parse_sugar_symtab.put(vd.name, ti);
    return 0;
}

func lower_var_decl_infer_from_init(vd: *AstVarDecl) -> u64 {
    if (vd == 0 || vd.init_expr == 0) { return 0; }
    if (lower_var_decl_needs_inference(vd) == 0) {
        lower_var_decl_register_typeinfo(vd, lower_make_typeinfo_from_vardecl(vd));
        return 1;
    }

    var inferred_ti: *TypeInfo = lower_infer_known_call_type(vd.init_expr);
    if (inferred_ti == 0) {
        inferred_ti = generic_infer_expr_type(vd.init_expr, g_lower_parse_sugar_symtab);
    }
    if (inferred_ti == 0 || (inferred_ti.type_kind == TYPE_VOID && inferred_ti.ptr_depth == 0)) {
        diag_emit_error_tag("lowering", "L1204", "cannot infer local variable type from initializer");
        diag_emit_labelled_name("variable: ", vd.name);
        diag_emit_help("add an explicit type annotation, for example `var x: u64 = ...;`");
        diag_error("Compiler error");
        return 0;
    }
    if (inferred_ti.type_kind == TYPE_NULL && inferred_ti.ptr_depth == 0) {
        diag_emit_error_tag("lowering", "L1205", "cannot infer local variable type from null");
        diag_emit_labelled_name("variable: ", vd.name);
        diag_emit_help("add an explicit pointer or nullable target type before assigning `null`");
        diag_error("Compiler error");
        return 0;
    }

    lower_exc_apply_typeinfo_to_vardecl(vd, inferred_ti);
    if (vd.type_kind == TYPE_STRUCT && vd.ptr_depth == 0 &&
        u8_slice_ptr(vd.struct_name) == 0 && u8_slice_len(vd.struct_name) == 0 &&
        inferred_ti.struct_def != 0) {
        vd.struct_name = inferred_ti.struct_def.name;
    }
    lower_var_decl_register_typeinfo(vd, lower_make_typeinfo_from_vardecl(vd));
    return 1;
}

func lower_make_typeinfo_from_param(param: *Param) -> *TypeInfo {
    if (param == 0) { return 0; }
    var ti: *TypeInfo = generic_make_typeinfo_from_fields(param.type_kind, param.ptr_depth, param.is_tagged, param.struct_name, param.tag_layout, param.elem_type_kind, param.elem_ptr_depth, param.array_len, param.array_len_is_param, param.array_len_param);
    if (ti != 0) { ti.elem_typeinfo = param.elem_typeinfo; }
    return ti;
}

func lower_make_typeinfo_from_func_return(fn: *AstFunc) -> *TypeInfo {
    if (fn == 0) { return 0; }
    return generic_make_typeinfo_from_fields(fn.ret_type, fn.ret_ptr_depth, fn.ret_is_tagged, fn.ret_struct_name, fn.ret_tag_layout, 0, 0, 0, 0, slice(0, 0));
}

func lower_is_direct_input_call(expr: *AstNode) -> *AstCall {
    if (expr == 0 || ast_kind(expr) != AST_CALL) { return 0; }
    var call: *AstCall = (*AstCall)expr;
    if (call.origin != AST_CALL_ORIGIN_DIRECT) { return 0; }
    if (str_eq(call.name, slice("input", str_len("input"))) == 0) { return 0; }
    return call;
}

func lower_input_call_as(call: *AstCall, name: []u8) -> *AstNode {
    if (call == 0) { return 0; }
    return (*AstNode)ast_call_with_origin_named(slice(name.ptr, name.len), call.args_vec, call.arg_names_vec, AST_CALL_ORIGIN_DIRECT);
}

func lower_make_direct_call_from_generic_input(gcall: *AstGenericCall, name: []u8) -> *AstCall {
    if (gcall == 0) { return 0; }
    var call: *AstCall = ast_call_with_origin_named(slice(name.ptr, name.len), gcall.args_vec, gcall.arg_names_vec, AST_CALL_ORIGIN_DIRECT);
    lower_normalize_direct_call_args(call);
    return call;
}

func lower_input_generic_target_type(gcall: *AstGenericCall) -> *TypeInfo {
    if (gcall == 0 || gcall.generic_args_vec == 0) { return 0; }
    if (gcall.generic_args_vec.len() != 1) {
        diag_emit_error_tag("lowering", "L1200", "input<T>() requires exactly one type argument");
        diag_emit_help("use input<number>() or input<string>()");
        diag_error("Compiler error");
        return 0;
    }
    var garg: *GenericArg = gcall.generic_args_vec.get(0);
    if (garg == 0 || garg.kind != GENERIC_KIND_TYPE || garg.type_ptr == 0) {
        diag_emit_error_tag("lowering", "L1201", "input<T>() requires a type argument");
        diag_emit_help("example: input<number>()");
        diag_error("Compiler error");
        return 0;
    }
    return garg.type_ptr;
}

func lower_parse_sugar_input_generic_call(gcall: *AstGenericCall) -> *AstNode {
    if (gcall == 0) { return 0; }
    if (gcall.origin != AST_CALL_ORIGIN_DIRECT) { return (*AstNode)gcall; }
    if (lower_call_name_matches(gcall.name, slice("input", 5)) == 0) { return (*AstNode)gcall; }

    var target_ti: *TypeInfo = lower_input_generic_target_type(gcall);
    if (target_ti == 0) { return 0; }

    if (lower_is_string_struct_type(target_ti) != 0) {
        return (*AstNode)lower_make_direct_call_from_generic_input(gcall, slice("string_input", 12));
    }

    if (target_ti.type_kind == TYPE_SLICE && target_ti.ptr_depth == 0 &&
        target_ti.elem_type_kind == TYPE_U8 && target_ti.elem_ptr_depth == 0) {
        return (*AstNode)lower_make_direct_call_from_generic_input(gcall, slice("input_slice", 11));
    }

    if (target_ti.ptr_depth == 1 && target_ti.type_kind == TYPE_U8) {
        var raw_call: *AstCall = lower_make_direct_call_from_generic_input(gcall, slice("input", 5));
        return (*AstNode)ast_cast_ex((*AstNode)raw_call, TYPE_U8, 1, 0, slice(0, 0), slice(0, 0));
    }

    if (target_ti.ptr_depth != 0) {
        diag_emit_error_tag("lowering", "L1202", "input<T>() does not support this pointer target");
        diag_emit_help("supported forms include input<*u8>() and value types such as input<number>()");
        diag_error("Compiler error");
        return 0;
    }

    if (lower_is_number_struct_type(target_ti) != 0) {
        return lower_make_number_static_call_named(slice("input", 5), gcall.args_vec, gcall.arg_names_vec);
    }

    match (target_ti.type_kind) {
        case TYPE_BOOL:
            return (*AstNode)lower_make_direct_call_from_generic_input(gcall, slice("input_bool", 10));
        case TYPE_U8:
            return (*AstNode)lower_make_direct_call_from_generic_input(gcall, slice("input_u8", 8));
        case TYPE_U16:
            return (*AstNode)lower_make_direct_call_from_generic_input(gcall, slice("input_u16", 9));
        case TYPE_U32:
            return (*AstNode)lower_make_direct_call_from_generic_input(gcall, slice("input_u32", 9));
        case TYPE_U64:
            return (*AstNode)lower_make_direct_call_from_generic_input(gcall, slice("input_u64", 9));
        case TYPE_I8:
            return (*AstNode)lower_make_direct_call_from_generic_input(gcall, slice("input_i8", 8));
        case TYPE_I16:
            return (*AstNode)lower_make_direct_call_from_generic_input(gcall, slice("input_i16", 9));
        case TYPE_I32:
            return (*AstNode)lower_make_direct_call_from_generic_input(gcall, slice("input_i32", 9));
        case TYPE_I64:
            return (*AstNode)lower_make_direct_call_from_generic_input(gcall, slice("input_i64", 9));
        case TYPE_F64:
            return (*AstNode)lower_make_direct_call_from_generic_input(gcall, slice("input_f64", 9));
    }

    diag_emit_error_tag("lowering", "L1203", "input<T>() target type is not supported");
    diag_emit_help("supported targets include number, string, []u8, *u8, bool, integer types, and f64");
    diag_error("Compiler error");
    return 0;
}

func lower_parse_sugar_string_literal_for_type(expr: *AstNode, expected_ti: *TypeInfo) -> *AstNode {
    if (expr == 0 || expected_ti == 0) { return expr; }
    if (expected_ti.type_kind == TYPE_SLICE && expected_ti.ptr_depth == 0 &&
        expected_ti.elem_type_kind == TYPE_U8 && expected_ti.elem_ptr_depth == 0 &&
        ast_kind(expr) == AST_STRING) {
        var str_lit: *AstString = (*AstString)expr;
        return (*AstNode)ast_slice(expr, (*AstNode)ast_literal(lower_string_literal_value_len(str_lit)));
    }
    if (lower_is_string_struct_type(expected_ti) == 0) { return expr; }

    if (ast_kind(expr) == AST_STRING) {
        return lower_make_direct_call1(slice("string_from_cstr", 16), expr);
    }

    return expr;
}

func lower_parse_sugar_input_for_type(expr: *AstNode, expected_ti: *TypeInfo) -> *AstNode {
    return expr;
}

func lower_string_literal_value_len(str_lit: *AstString) -> u64 {
    if (str_lit == 0 || u8_slice_len(str_lit.str) < 2) { return 0; }
    var s: []u8 = str_lit.str;
    var out_len: u64 = 0;
    for (var i: u64 = 1; i + 1 < u8_slice_len(str_lit.str); i = i + 1) {
        if (s[i] == 92 && i + 1 < u8_slice_len(str_lit.str) - 1) {
            i = i + 1;
        }
        out_len = out_len + 1;
    }
    return out_len;
}

func lower_parse_sugar_numeric_for_type(expr: *AstNode, expected_ti: *TypeInfo) -> *AstNode {
    if (expr == 0 || expected_ti == 0 || expected_ti.ptr_depth != 0) { return expr; }

    var actual_ti: *TypeInfo = generic_infer_expr_type(expr, g_lower_parse_sugar_symtab);

    if (lower_is_number_struct_type(expected_ti) != 0) {
        var boxed: *AstNode = lower_wrap_integer_expr_to_number(expr, actual_ti);
        if (boxed != 0) { return boxed; }
        boxed = lower_wrap_float_expr_to_number(expr, actual_ti);
        if (boxed != 0) { return boxed; }
        return expr;
    }

    if (lower_type_kind_is_integer(expected_ti.type_kind) != 0) {
        if (actual_ti != 0 && actual_ti.ptr_depth == 0 && actual_ti.type_kind == expected_ti.type_kind) {
            return expr;
        }

        if (lower_is_integer_literal_expr(expr) != 0) {
            if (lower_integer_literal_fits_type(expr, expected_ti.type_kind) != 0) {
                return lower_make_cast_for_typeinfo(expr, expected_ti);
            }
            return expr;
        }
        if (lower_is_integer_const_expr(expr) != 0) {
            return lower_make_cast_for_typeinfo(expr, expected_ti);
        }

        var unboxed: *AstNode = lower_wrap_number_expr_to_integer(expr, expected_ti.type_kind, actual_ti);
        if (unboxed != 0) { return unboxed; }

        if (actual_ti != 0 && actual_ti.ptr_depth == 0 &&
            lower_can_implicit_integer_widen(actual_ti.type_kind, expected_ti.type_kind) != 0) {
            return lower_make_cast_for_typeinfo(expr, expected_ti);
        }
        return expr;
    }

    if (expected_ti.type_kind == TYPE_F64) {
        if (lower_is_integer_literal_expr(expr) != 0) {
            return lower_make_cast_for_typeinfo(expr, expected_ti);
        }
        if (actual_ti != 0 && actual_ti.ptr_depth == 0 &&
            lower_type_kind_is_integer(actual_ti.type_kind) != 0) {
            return lower_make_cast_for_typeinfo(expr, expected_ti);
        }
    }

    return expr;
}

func lower_parse_sugar_cast_expr(cast_expr: *AstCast) -> *AstNode {
    if (cast_expr == 0 || cast_expr.expr == 0) { return (*AstNode)cast_expr; }
    if (cast_expr.target_ptr_depth != 0) { return (*AstNode)cast_expr; }
    if (lower_type_kind_is_integer(cast_expr.target_type) == 0) { return (*AstNode)cast_expr; }
    if (lower_is_integer_const_expr(cast_expr.expr) != 0) { return (*AstNode)cast_expr; }
    var actual_ti: *TypeInfo = generic_infer_expr_type(cast_expr.expr, g_lower_parse_sugar_symtab);
    var lowered: *AstNode = lower_wrap_number_expr_to_integer(cast_expr.expr, cast_expr.target_type, actual_ti);
    if (lowered != 0) { return lowered; }
    return (*AstNode)cast_expr;
}

func lower_parse_sugar_expr_for_type(expr: *AstNode, expected_ti: *TypeInfo) -> *AstNode {
    var string_expr: *AstNode = lower_parse_sugar_string_literal_for_type(expr, expected_ti);
    if (string_expr != expr) { return string_expr; }
    return lower_parse_sugar_numeric_for_type(expr, expected_ti);
}

func lower_parse_sugar_binary_operator(bin: *AstBinary) -> *AstNode {
    if (bin == 0) { return 0; }
    var literal_method_name: *NameInfo = compiler_operator_binary_name(bin.op);
    if (literal_method_name != 0 && lower_is_integer_literal_expr(bin.right) != 0) {
        var literal_recv_ti: *TypeInfo = lower_operator_receiver_type(bin.left);
        if (literal_recv_ti != 0 && lower_is_number_struct_type(literal_recv_ti) == 0) {
            var literal_target_type: u64 = TYPE_U64;
            if (lower_integer_literal_is_negative(bin.right) != 0) { literal_target_type = TYPE_I64; }
            bin.right = lower_make_scalar_cast(bin.right, literal_target_type);
        }
    }

    var left_actual_ti: *TypeInfo = generic_infer_expr_type(bin.left, g_lower_parse_sugar_symtab);
    var right_actual_ti: *TypeInfo = generic_infer_expr_type(bin.right, g_lower_parse_sugar_symtab);
    if (lower_binary_uses_number_semantics_with_types(bin, left_actual_ti, right_actual_ti) != 0) {
        return (*AstNode)bin;
    }

    var left_ti: *TypeInfo = lower_operator_receiver_type(bin.left);
    var right_ti: *TypeInfo = lower_operator_receiver_type(bin.right);
    var left_is_number: u64 = lower_is_number_struct_type(left_ti);
    var right_is_number: u64 = lower_is_number_struct_type(right_ti);
    if (left_is_number != 0 || right_is_number != 0) { return (*AstNode)bin; }

    var method_name: *NameInfo = compiler_operator_binary_name(bin.op);
    if (method_name == 0) { return (*AstNode)bin; }

    var arg_types: *Vec<*TypeInfo> = lower_operator_arg_type_vec1(bin.right);
    if (lower_operator_can_dispatch(bin.left, slice(method_name.ptr, method_name.len), arg_types, 1) == 0) {
        return (*AstNode)bin;
    }

    var args: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((1) * sizeof(*AstNode)), 0, (1)};
    args.push(bin.right);
    return (*AstNode)ast_method_call(bin.left, slice(method_name.ptr, method_name.len), args);
}

func lower_parse_sugar_unary_operator(un: *AstUnary) -> *AstNode {
    if (un == 0) { return 0; }
    var operand_ti: *TypeInfo = lower_operator_receiver_type(un.operand);
    if (lower_is_number_struct_type(operand_ti) != 0) { return (*AstNode)un; }

    var method_name: *NameInfo = compiler_operator_unary_name(un.op);
    if (method_name == 0) { return (*AstNode)un; }

    if (lower_operator_can_dispatch(un.operand, slice(method_name.ptr, method_name.len), 0, 0) == 0) {
        return (*AstNode)un;
    }

    var args: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((0) * sizeof(*AstNode)), 0, (0)};
    return (*AstNode)ast_method_call(un.operand, slice(method_name.ptr, method_name.len), args);
}

func lower_parse_sugar_index_operator(ix: *AstIndex) -> *AstNode {
    if (ix == 0) { return 0; }
    var method_name: *NameInfo = compiler_operator_index_get_name();
    var arg_types: *Vec<*TypeInfo> = lower_operator_arg_type_vec1(ix.index);
    if (lower_operator_can_dispatch(ix.base, slice(method_name.ptr, method_name.len), arg_types, 1) == 0) {
        var base_ti: *TypeInfo = generic_infer_expr_type(ix.base, g_lower_parse_sugar_symtab);
        if (base_ti != 0 &&
            (base_ti.ptr_depth != 0 || base_ti.type_kind == TYPE_ARRAY || base_ti.type_kind == TYPE_SLICE)) {
            ix.index = lower_parse_sugar_expr_for_type(ix.index, generic_type_u64());
        }
        return (*AstNode)ix;
    }

    var args: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((1) * sizeof(*AstNode)), 0, (1)};
    args.push(ix.index);
    return (*AstNode)ast_method_call(ix.base, slice(method_name.ptr, method_name.len), args);
}

const COMPILER_EXC_STATE_NONE = 0;
const COMPILER_EXC_STATE_THROWN = 1;

struct CompilerExceptionLowerCtx {
    public flag_ptr_stack: *Vec<u64>;
    public flag_len_stack: *Vec<u64>;
    public value_ptr_stack: *Vec<u64>;
    public value_len_stack: *Vec<u64>;
    public value_type_stack: *Vec<*TypeInfo>;
    public counter: u64;
}

func lower_exc_ctx_new() -> CompilerExceptionLowerCtx {
    var ctx: CompilerExceptionLowerCtx;
    ctx.flag_ptr_stack = 0;
    ctx.flag_len_stack = 0;
    ctx.value_ptr_stack = 0;
    ctx.value_len_stack = 0;
    ctx.value_type_stack = 0;
    ctx.counter = 0;
    return ctx;
}

func lower_exc_build_internal_name(prefix: []u8, id: u64) -> *NameInfo {
    var id_buf: u64 = heap_alloc(32 * sizeof(u8));
    var id_len: u64 = io_u64_to_ascii(id_buf, id);
    var total_len: u64 = prefix.len + id_len;
    var out_ptr: u64 = heap_alloc((total_len + 1) * sizeof(u8));
    var out_u8: []u8 = slice(out_ptr, total_len + 1);
    str_copy(out_ptr, prefix.ptr, prefix.len);
    str_copy(out_ptr + prefix.len, id_buf, id_len);
    out_u8[total_len] = 0;
    return new NameInfo{out_ptr, total_len};
}

func lower_exc_ensure_context_struct() -> *AstStructDef {
    var existing: *AstStructDef = get_struct_def(slice("__BppTryContext", 15));
    if (existing != 0) { return existing; }

    var fields: *Vec<*FieldDesc> = new Vec<*FieldDesc>{heap_alloc((1) * sizeof(*FieldDesc)), 0, (1)};
    var state_field: *FieldDesc = new FieldDesc{};
    state_field.access = ACCESS_PUBLIC;
    state_field.name = slice((u64)"state", 5);
    state_field.type_kind = TYPE_U64;
    state_field.ptr_depth = 0;
    state_field.is_tagged = 0;
    state_field.struct_name = slice(0, 0);
    state_field.tag_layout = slice(0, 0);
    state_field.bit_width = 0;
    state_field.offset = 0;
    state_field.elem_type_kind = 0;
    state_field.elem_ptr_depth = 0;
    state_field.array_len = 0;
    state_field.elem_typeinfo = 0;
    state_field.access = ACCESS_PUBLIC;
    state_field.owner_struct = slice((u64)"__BppTryContext", 15);
    fields.push(state_field);

    var ctx_def: *AstStructDef = ast_struct_def(slice("__BppTryContext", 15), 0, fields, 0, 0, 0);
    register_struct_type(ctx_def);
    return ctx_def;
}

func lower_exc_ctx_push(ctx: *CompilerExceptionLowerCtx, flag: []u8, value: []u8, value_type: *TypeInfo) -> u64 {
    if (ctx.flag_ptr_stack == 0) {
        ctx.flag_ptr_stack = new Vec<u64>{heap_alloc((8) * sizeof(u64)), 0, (8)};
        ctx.flag_len_stack = new Vec<u64>{heap_alloc((8) * sizeof(u64)), 0, (8)};
        ctx.value_ptr_stack = new Vec<u64>{heap_alloc((8) * sizeof(u64)), 0, (8)};
        ctx.value_len_stack = new Vec<u64>{heap_alloc((8) * sizeof(u64)), 0, (8)};
        ctx.value_type_stack = new Vec<*TypeInfo>{heap_alloc((8) * sizeof(*TypeInfo)), 0, (8)};
    }
    ctx.flag_ptr_stack.push(flag.ptr);
    ctx.flag_len_stack.push(flag.len);
    ctx.value_ptr_stack.push(value.ptr);
    ctx.value_len_stack.push(value.len);
    ctx.value_type_stack.push(value_type);
    return 0;
}

func lower_exc_ctx_pop(ctx: *CompilerExceptionLowerCtx) -> u64 {
    if (ctx.flag_ptr_stack == 0 || ctx.flag_ptr_stack.len() == 0) { return 0; }
    ctx.flag_ptr_stack.pop();
    ctx.flag_len_stack.pop();
    ctx.value_ptr_stack.pop();
    ctx.value_len_stack.pop();
    if (ctx.value_type_stack != 0) {
        ctx.value_type_stack.pop();
    }
    return 0;
}

func lower_exc_ctx_active(ctx: *CompilerExceptionLowerCtx) -> u64 {
    if (ctx == 0 || ctx.flag_ptr_stack == 0) { return 0; }
    if (ctx.flag_ptr_stack.len() == 0) { return 0; }
    return 1;
}

func lower_exc_ctx_current_flag_ptr(ctx: *CompilerExceptionLowerCtx) -> u64 {
    if (lower_exc_ctx_active(ctx) == 0) { return 0; }
    var top_idx: u64 = ctx.flag_ptr_stack.len() - 1;
    return ctx.flag_ptr_stack.get(top_idx);
}

func lower_exc_ctx_current_flag_len(ctx: *CompilerExceptionLowerCtx) -> u64 {
    if (lower_exc_ctx_active(ctx) == 0) { return 0; }
    var top_idx: u64 = ctx.flag_len_stack.len() - 1;
    return ctx.flag_len_stack.get(top_idx);
}

func lower_exc_ctx_current_value_ptr(ctx: *CompilerExceptionLowerCtx) -> u64 {
    if (lower_exc_ctx_active(ctx) == 0) { return 0; }
    var top_idx: u64 = ctx.value_ptr_stack.len() - 1;
    return ctx.value_ptr_stack.get(top_idx);
}

func lower_exc_ctx_current_value_len(ctx: *CompilerExceptionLowerCtx) -> u64 {
    if (lower_exc_ctx_active(ctx) == 0) { return 0; }
    var top_idx: u64 = ctx.value_len_stack.len() - 1;
    return ctx.value_len_stack.get(top_idx);
}

func lower_exc_ctx_current_value_type(ctx: *CompilerExceptionLowerCtx) -> *TypeInfo {
    if (lower_exc_ctx_active(ctx) == 0 || ctx.value_type_stack == 0 || ctx.value_type_stack.len() == 0) { return 0; }
    var top_idx: u64 = ctx.value_type_stack.len() - 1;
    return ctx.value_type_stack.get(top_idx);
}

func lower_exc_scalar_size(type_kind: u64) -> u64 {
    match (type_kind) {
        case TYPE_BOOL:
        case TYPE_U8:
        case TYPE_I8:
            return 1;
        case TYPE_U16:
        case TYPE_I16:
            return 2;
        case TYPE_U32:
        case TYPE_I32:
            return 4;
        case TYPE_U64:
        case TYPE_I64:
        case TYPE_F64:
            return 8;
    }
    return 0;
}

func lower_exc_emit_type_name(ti: *TypeInfo) -> u64 {
    if (ti == 0) {
        emit_stderr("<unknown>");
        return 0;
    }
    if (ti.ptr_depth > 0) {
        for (var i: u64 = 0; i < ti.ptr_depth; i++) {
            emit_stderr("*");
        }
    }
    match (ti.type_kind) {
        case TYPE_VOID: emit_stderr("void"); return 0;
        case TYPE_BOOL: emit_stderr("bool"); return 0;
        case TYPE_U8: emit_stderr("u8"); return 0;
        case TYPE_U16: emit_stderr("u16"); return 0;
        case TYPE_U32: emit_stderr("u32"); return 0;
        case TYPE_U64: emit_stderr("u64"); return 0;
        case TYPE_I8: emit_stderr("i8"); return 0;
        case TYPE_I16: emit_stderr("i16"); return 0;
        case TYPE_I32: emit_stderr("i32"); return 0;
        case TYPE_I64: emit_stderr("i64"); return 0;
        case TYPE_F64: emit_stderr("f64"); return 0;
        case TYPE_NULL: emit_stderr("null"); return 0;
        case TYPE_STRUCT:
        case TYPE_TRAIT:
        case TYPE_GENERIC:
            if (u8_slice_ptr(ti.struct_name) != 0 && u8_slice_len(ti.struct_name) != 0) {
                emit_stderr_len(u8_slice_ptr(ti.struct_name), u8_slice_len(ti.struct_name));
            } else {
                emit_stderr("<struct>");
            }
            return 0;
        case TYPE_ARRAY: emit_stderr("array"); return 0;
        case TYPE_SLICE: emit_stderr("slice"); return 0;
        case TYPE_FUNC: emit_stderr("func"); return 0;
    }
    emit_stderr("<type>");
    return 0;
}

func lower_exc_try_infer_throw_expr_type(expr: *AstNode) -> *TypeInfo {
    if (expr == 0) { return 0; }
    var kind: u64 = ast_kind(expr);
    match (kind) {
        case AST_CAST:
            var c: *AstCast = (*AstCast)expr;
            return generic_make_typeinfo_from_fields(c.target_type, c.target_ptr_depth, c.target_is_tagged, c.struct_name, c.tag_layout, 0, 0, 0, 0, slice(0, 0));
        case AST_LITERAL:
            return generic_make_typeinfo_from_fields(TYPE_I64, 0, 0, slice(0, 0), slice(0, 0), 0, 0, 0, 0, slice(0, 0));
        case AST_FLOAT:
            return generic_make_typeinfo_from_fields(TYPE_F64, 0, 0, slice(0, 0), slice(0, 0), 0, 0, 0, 0, slice(0, 0));
        case AST_STRING:
            return generic_make_typeinfo_from_fields(TYPE_U8, 1, 0, slice(0, 0), slice(0, 0), 0, 0, 0, 0, slice(0, 0));
        default:
            return 0;
    }
}

func lower_exc_throw_type_compatible(actual_ti: *TypeInfo, expected_ti: *TypeInfo) -> u64 {
    if (actual_ti == 0 || expected_ti == 0) { return 1; }
    if (actual_ti.type_kind == TYPE_NULL && actual_ti.ptr_depth == 0) {
        if (expected_ti.type_kind == TYPE_NULL && expected_ti.ptr_depth == 0) { return 1; }
        if (expected_ti.ptr_depth > 0) { return 1; }
        return 0;
    }
    if (expected_ti.type_kind == TYPE_NULL && expected_ti.ptr_depth == 0) {
        if (actual_ti.type_kind == TYPE_NULL && actual_ti.ptr_depth == 0) { return 1; }
        return 0;
    }

    if (actual_ti.ptr_depth != expected_ti.ptr_depth) { return 0; }

    if (actual_ti.ptr_depth > 0) {
        if (actual_ti.type_kind != expected_ti.type_kind) { return 0; }
        if (actual_ti.type_kind == TYPE_STRUCT || actual_ti.type_kind == TYPE_TRAIT || actual_ti.type_kind == TYPE_GENERIC) {
            if (!str_eq(actual_ti.struct_name, expected_ti.struct_name)) { return 0; }
        }
        return 1;
    }

    if (actual_ti.type_kind == expected_ti.type_kind) {
        if (actual_ti.type_kind == TYPE_STRUCT || actual_ti.type_kind == TYPE_TRAIT || actual_ti.type_kind == TYPE_GENERIC) {
            if (!str_eq(actual_ti.struct_name, expected_ti.struct_name)) { return 0; }
        }
        return 1;
    }

    var actual_size: u64 = lower_exc_scalar_size(actual_ti.type_kind);
    var expected_size: u64 = lower_exc_scalar_size(expected_ti.type_kind);
    if (actual_size != 0 && actual_size == expected_size) { return 1; }
    return 0;
}

func lower_exc_state_expr(ctx: []u8) -> *AstNode {
    return (*AstNode)ast_member_access((*AstNode)ast_ident(slice(ctx.ptr, ctx.len)), slice("state", 5));
}

func lower_exc_build_not_thrown_cond(ctx: []u8) -> *AstNode {
    if (ctx.ptr == 0 || ctx.len == 0) { return (*AstNode)ast_literal(1); }
    return (*AstNode)ast_binary(TOKEN_EQEQ, lower_exc_state_expr(slice(ctx.ptr, ctx.len)), (*AstNode)ast_literal(COMPILER_EXC_STATE_NONE));
}

func lower_exc_build_break_guard(ctx: []u8) -> *AstNode {
    if (ctx.ptr == 0 || ctx.len == 0) { return 0; }
    var cond: *AstNode = (*AstNode)ast_binary(TOKEN_BANGEQ, lower_exc_state_expr(slice(ctx.ptr, ctx.len)), (*AstNode)ast_literal(COMPILER_EXC_STATE_NONE));
    var then_stmts: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((1) * sizeof(*AstNode)), 0, (1)};
    then_stmts.push((*AstNode)ast_break());
    return (*AstNode)ast_if(cond, (*AstNode)ast_block(then_stmts), 0);
}

func lower_exc_wrap_stmt_if_not_thrown(stmt: *AstNode, ctx: []u8) -> *AstNode {
    if (stmt == 0) { return 0; }
    if (ctx.ptr == 0 || ctx.len == 0) { return stmt; }
    var then_stmts: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((1) * sizeof(*AstNode)), 0, (1)};
    then_stmts.push(stmt);
    return (*AstNode)ast_if(lower_exc_build_not_thrown_cond(slice(ctx.ptr, ctx.len)), (*AstNode)ast_block(then_stmts), 0);
}

func lower_exc_wrap_loop_body_with_guard(body: *AstNode, ctx: []u8) -> *AstNode {
    if (body == 0) { return 0; }
    if (ctx.ptr == 0 || ctx.len == 0) { return body; }

    var wrapped: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((8) * sizeof(*AstNode)), 0, (8)};
    if (ast_kind(body) == AST_BLOCK) {
        var blk: *AstBlock = (*AstBlock)body;
        if (blk.stmts_vec != 0) {
            var n: u64 = blk.stmts_vec.len();
            for (var i: u64 = 0; i < n; i++) {
                wrapped.push(lower_exc_wrap_stmt_if_not_thrown(blk.stmts_vec.get(i), slice(ctx.ptr, ctx.len)));
            }
        }
    } else {
        wrapped.push(lower_exc_wrap_stmt_if_not_thrown(body, slice(ctx.ptr, ctx.len)));
    }
    wrapped.push(lower_exc_build_break_guard(slice(ctx.ptr, ctx.len)));
    return (*AstNode)ast_block(wrapped);
}

func lower_exc_build_unhandled_throw_stmt() -> *AstNode {
    var args: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((3) * sizeof(*AstNode)), 0, (3)};
    args.push(lower_make_ast_string_literal(slice("unhandled throw", 15)));
    args.push((*AstNode)ast_literal(15));
    args.push((*AstNode)ast_literal(0));
    var call: *AstCall = ast_call(slice("debug_fail", 10), args);
    return ast_expr_stmt((*AstNode)call);
}

func lower_exc_apply_typeinfo_to_vardecl(decl: *AstVarDecl, ti: *TypeInfo) -> u64 {
    if (decl == 0 || ti == 0) { return 0; }
    decl.type_kind = ti.type_kind;
    decl.ptr_depth = ti.ptr_depth;
    decl.is_tagged = ti.is_tagged;
    decl.struct_name = ti.struct_name;
    decl.tag_layout = ti.tag_layout;
    decl.elem_type_kind = ti.elem_type_kind;
    decl.elem_ptr_depth = ti.elem_ptr_depth;
    decl.array_len = ti.array_len;
    decl.array_len_is_param = ti.array_len_is_param;
    decl.array_len_param = ti.array_len_param;
    if (ti.type_kind == TYPE_FUNC) {
        decl.elem_typeinfo = ti;
    } else {
        decl.elem_typeinfo = ti.elem_typeinfo;
    }
    return 0;
}

func lower_exc_append_lowered_wrapped_stmts(ctx: *CompilerExceptionLowerCtx, dst: *Vec<*AstNode>, block_node: *AstNode, flag_name: []u8) -> u64 {
    if (block_node == 0) { return 0; }
    if (ast_kind(block_node) == AST_BLOCK) {
        var blk: *AstBlock = (*AstBlock)block_node;
        if (blk.stmts_vec == 0) { return 0; }
        var n: u64 = blk.stmts_vec.len();
        for (var i: u64 = 0; i < n; i++) {
            var lowered_stmt: *AstNode = lower_exception_stmt(ctx, blk.stmts_vec.get(i));
            dst.push(lower_exc_wrap_stmt_if_not_thrown(lowered_stmt, slice(flag_name.ptr, flag_name.len)));
        }
        return 0;
    }

    var lowered_single: *AstNode = lower_exception_stmt(ctx, block_node);
    dst.push(lower_exc_wrap_stmt_if_not_thrown(lowered_single, slice(flag_name.ptr, flag_name.len)));
    return 0;
}

func lower_exception_stmt(ctx: *CompilerExceptionLowerCtx, stmt: *AstNode) -> *AstNode {
    if (stmt == 0) { return 0; }

    var kind: u64 = ast_kind(stmt);
    match (kind) {
        case AST_BLOCK:
            var blk: *AstBlock = (*AstBlock)stmt;
            if (blk.stmts_vec != 0) {
                var n: u64 = blk.stmts_vec.len();
                for (var i: u64 = 0; i < n; i++) {
                    blk.stmts_vec.set(i, lower_exception_stmt(ctx, blk.stmts_vec.get(i)));
                }
            }
            return stmt;
        case AST_IF:
            var ifs: *AstIf = (*AstIf)stmt;
            ifs.then_block = lower_exception_stmt(ctx, ifs.then_block);
            ifs.else_block = lower_exception_stmt(ctx, ifs.else_block);
            return stmt;
        case AST_WHILE:
            var wl: *AstWhile = (*AstWhile)stmt;
            wl.body = lower_exception_stmt(ctx, wl.body);
            if (lower_exc_ctx_active(ctx) != 0) {
                wl.body = lower_exc_wrap_loop_body_with_guard(wl.body, slice(lower_exc_ctx_current_flag_ptr(ctx), lower_exc_ctx_current_flag_len(ctx)));
            }
            return stmt;
        case AST_FOR:
            var fr: *AstFor = (*AstFor)stmt;
            fr.init = lower_exception_stmt(ctx, fr.init);
            fr.body = lower_exception_stmt(ctx, fr.body);
            if (lower_exc_ctx_active(ctx) != 0) {
                fr.body = lower_exc_wrap_loop_body_with_guard(fr.body, slice(lower_exc_ctx_current_flag_ptr(ctx), lower_exc_ctx_current_flag_len(ctx)));
            }
            return stmt;
        case AST_SWITCH:
        case AST_MATCH:
            var sw: *AstSwitch = (*AstSwitch)stmt;
            if (sw.cases_vec != 0) {
                var cn: u64 = sw.cases_vec.len();
                for (var ci: u64 = 0; ci < cn; ci++) {
                    sw.cases_vec.set(ci, lower_exception_stmt(ctx, sw.cases_vec.get(ci)));
                }
            }
            return stmt;
        case AST_CASE:
            var cs: *AstCase = (*AstCase)stmt;
            cs.body = lower_exception_stmt(ctx, cs.body);
            return stmt;
        case AST_DEFER:
            var df: *AstDefer = (*AstDefer)stmt;
            df.stmt = lower_exception_stmt(ctx, df.stmt);
            return stmt;
        case AST_TRY_STMT:
            var tr: *AstTryStmt = (*AstTryStmt)stmt;

            if (tr.catch_block == 0 && tr.finally_block == 0) {
                emit_stderr("[INTERNAL] invalid AST_TRY_STMT: missing catch/finally\n");
                diag_error("Compiler error");
                return stmt;
            }

            ctx.counter = ctx.counter + 1;
            var ctx_name: *NameInfo = lower_exc_build_internal_name(slice("__try_ctx_", 10), ctx.counter);
            var value_name: *NameInfo = lower_exc_build_internal_name(slice("__try_payload_", 14), ctx.counter);

            var outer_ctx_ptr: u64 = 0;
            var outer_ctx_len: u64 = 0;
            var outer_value_ptr: u64 = 0;
            var outer_value_len: u64 = 0;
            var outer_value_type: *TypeInfo = 0;
            if (lower_exc_ctx_active(ctx) != 0) {
                outer_ctx_ptr = lower_exc_ctx_current_flag_ptr(ctx);
                outer_ctx_len = lower_exc_ctx_current_flag_len(ctx);
                outer_value_ptr = lower_exc_ctx_current_value_ptr(ctx);
                outer_value_len = lower_exc_ctx_current_value_len(ctx);
                outer_value_type = lower_exc_ctx_current_value_type(ctx);
            }

            var lowered_stmts: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((6) * sizeof(*AstNode)), 0, (6)};
            var ctx_struct: *AstStructDef = lower_exc_ensure_context_struct();
            var ctx_decl: *AstVarDecl = ast_var_decl(slice(ctx_name.ptr, ctx_name.len), TYPE_STRUCT, 0, 0);
            ctx_decl.struct_name = ctx_struct.name;
            lowered_stmts.push((*AstNode)ctx_decl);
            lowered_stmts.push((*AstNode)ast_assign(lower_exc_state_expr(slice(ctx_name.ptr, ctx_name.len)), (*AstNode)ast_literal(COMPILER_EXC_STATE_NONE)));
            if (u8_slice_ptr(tr.catch_name) != 0 && u8_slice_len(tr.catch_name) != 0 && tr.catch_value_type == 0) {
                emit_stderr("[INTERNAL] invalid AST_TRY_STMT: catch binding missing payload type\n");
                diag_error("Compiler error");
                return stmt;
            }

            var payload_ptr: u64 = 0;
            var payload_len: u64 = 0;
            var payload_type: *TypeInfo = 0;

            if (tr.catch_value_type != 0) {
                payload_ptr = value_name.ptr;
                payload_len = value_name.len;
                payload_type = tr.catch_value_type;
                var value_decl: *AstVarDecl = ast_var_decl(slice(value_name.ptr, value_name.len), payload_type.type_kind, payload_type.ptr_depth, (*AstNode)ast_literal(0));
                lower_exc_apply_typeinfo_to_vardecl(value_decl, payload_type);
                lowered_stmts.push((*AstNode)value_decl);
            } else if (outer_value_ptr != 0 && outer_value_len != 0 && outer_value_type != 0) {
                payload_ptr = outer_value_ptr;
                payload_len = outer_value_len;
                payload_type = outer_value_type;
            }

            lower_exc_ctx_push(ctx, slice(ctx_name.ptr, ctx_name.len), slice(payload_ptr, payload_len), payload_type);
            lower_exc_append_lowered_wrapped_stmts(ctx, lowered_stmts, tr.try_block, slice(ctx_name.ptr, ctx_name.len));
            lower_exc_ctx_pop(ctx);

            if (tr.catch_block != 0) {
                var catch_wrapped: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((8) * sizeof(*AstNode)), 0, (8)};
                catch_wrapped.push((*AstNode)ast_assign(lower_exc_state_expr(slice(ctx_name.ptr, ctx_name.len)), (*AstNode)ast_literal(COMPILER_EXC_STATE_NONE)));

                if (u8_slice_ptr(tr.catch_name) != 0 && u8_slice_len(tr.catch_name) != 0) {
                    if (payload_type == 0 || payload_ptr == 0 || payload_len == 0) {
                        diag_emit_error_tag("lowering", "L1701", "catch binding requires payload storage");
                        diag_emit_labelled_name("binding: ", tr.catch_name);
                        diag_error("Compilation failed");
                        return stmt;
                    }
                    var catch_decl: *AstVarDecl = ast_var_decl(tr.catch_name, payload_type.type_kind, payload_type.ptr_depth, (*AstNode)ast_ident(slice(payload_ptr, payload_len)));
                    lower_exc_apply_typeinfo_to_vardecl(catch_decl, payload_type);
                    catch_wrapped.push((*AstNode)catch_decl);
                }

                lower_exc_append_lowered_wrapped_stmts(ctx, catch_wrapped, tr.catch_block, slice(ctx_name.ptr, ctx_name.len));

                var thrown_cond2: *AstNode = (*AstNode)ast_binary(TOKEN_BANGEQ, lower_exc_state_expr(slice(ctx_name.ptr, ctx_name.len)), (*AstNode)ast_literal(COMPILER_EXC_STATE_NONE));
                lowered_stmts.push((*AstNode)ast_if(thrown_cond2, (*AstNode)ast_block(catch_wrapped), 0));
            }

            if (tr.finally_block != 0) {
                var pending_name: *NameInfo = lower_exc_build_internal_name(slice("__try_pending_", 14), ctx.counter);
                lowered_stmts.push((*AstNode)ast_var_decl(slice(pending_name.ptr, pending_name.len), TYPE_U64, 0, lower_exc_state_expr(slice(ctx_name.ptr, ctx_name.len))));
                lowered_stmts.push((*AstNode)ast_assign(lower_exc_state_expr(slice(ctx_name.ptr, ctx_name.len)), (*AstNode)ast_literal(COMPILER_EXC_STATE_NONE)));

                lower_exc_append_lowered_wrapped_stmts(ctx, lowered_stmts, tr.finally_block, slice(ctx_name.ptr, ctx_name.len));

                var restore_stmts: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((1) * sizeof(*AstNode)), 0, (1)};
                restore_stmts.push((*AstNode)ast_assign(lower_exc_state_expr(slice(ctx_name.ptr, ctx_name.len)), (*AstNode)ast_ident(slice(pending_name.ptr, pending_name.len))));
                var restore_cond: *AstNode = (*AstNode)ast_binary(TOKEN_EQEQ, lower_exc_state_expr(slice(ctx_name.ptr, ctx_name.len)), (*AstNode)ast_literal(COMPILER_EXC_STATE_NONE));
                lowered_stmts.push((*AstNode)ast_if(restore_cond, (*AstNode)ast_block(restore_stmts), 0));
            }

            var post_throw_cond: *AstNode = (*AstNode)ast_binary(TOKEN_BANGEQ, lower_exc_state_expr(slice(ctx_name.ptr, ctx_name.len)), (*AstNode)ast_literal(COMPILER_EXC_STATE_NONE));
            if (outer_ctx_ptr != 0 && outer_ctx_len != 0 && outer_value_ptr != 0 && outer_value_len != 0) {
                var propagate_stmts: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((3) * sizeof(*AstNode)), 0, (3)};
                if (payload_ptr != 0 && payload_len != 0 && (payload_ptr != outer_value_ptr || payload_len != outer_value_len)) {
                    propagate_stmts.push((*AstNode)ast_assign((*AstNode)ast_ident(slice(outer_value_ptr, outer_value_len)), (*AstNode)ast_ident(slice(payload_ptr, payload_len))));
                }
                propagate_stmts.push((*AstNode)ast_assign(lower_exc_state_expr(slice(outer_ctx_ptr, outer_ctx_len)), (*AstNode)ast_literal(COMPILER_EXC_STATE_THROWN)));
                lowered_stmts.push((*AstNode)ast_if(post_throw_cond, (*AstNode)ast_block(propagate_stmts), 0));
            } else {
                var fail_stmts: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((1) * sizeof(*AstNode)), 0, (1)};
                fail_stmts.push(lower_exc_build_unhandled_throw_stmt());
                lowered_stmts.push((*AstNode)ast_if(post_throw_cond, (*AstNode)ast_block(fail_stmts), 0));
            }

            return (*AstNode)ast_block(lowered_stmts);
        case AST_THROW_STMT:
            var th: *AstThrowStmt = (*AstThrowStmt)stmt;
            if (lower_exc_ctx_active(ctx) == 0) {
                var unhandled_stmts: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((2) * sizeof(*AstNode)), 0, (2)};
                unhandled_stmts.push(ast_expr_stmt(th.expr));
                unhandled_stmts.push(lower_exc_build_unhandled_throw_stmt());
                return (*AstNode)ast_block(unhandled_stmts);
            }
            var throw_stmts: *Vec<*AstNode> = new Vec<*AstNode>{heap_alloc((2) * sizeof(*AstNode)), 0, (2)};
            var cur_value_ptr: u64 = lower_exc_ctx_current_value_ptr(ctx);
            var cur_value_len: u64 = lower_exc_ctx_current_value_len(ctx);
            var cur_value_type: *TypeInfo = lower_exc_ctx_current_value_type(ctx);
            if (cur_value_ptr != 0 && cur_value_len != 0) {
                var throw_expr_type: *TypeInfo = lower_exc_try_infer_throw_expr_type(th.expr);
                if (lower_exc_throw_type_compatible(throw_expr_type, cur_value_type) == 0) {
                    diag_emit_error_tag("lowering", "L1702", "throw payload type mismatch");
                    emit_stderr("[NOTE] expected: ");
                    lower_exc_emit_type_name(cur_value_type);
                    emit_stderr("\n");
                    emit_stderr("[NOTE] actual: ");
                    lower_exc_emit_type_name(throw_expr_type);
                    emit_stderr("\n");
                    diag_error("Compilation failed");
                    return stmt;
                }
                throw_stmts.push((*AstNode)ast_assign((*AstNode)ast_ident(slice(cur_value_ptr, cur_value_len)), th.expr));
            }
            throw_stmts.push((*AstNode)ast_assign(lower_exc_state_expr(slice(lower_exc_ctx_current_flag_ptr(ctx), lower_exc_ctx_current_flag_len(ctx))), (*AstNode)ast_literal(COMPILER_EXC_STATE_THROWN)));
            return (*AstNode)ast_block(throw_stmts);
        default:
            return stmt;
    }
}

func lower_exceptions_stmt(stmt: *AstNode) -> u64 {
    var ctx: CompilerExceptionLowerCtx = lower_exc_ctx_new();
    lower_exception_stmt(&ctx, stmt);
    return 0;
}


func lower_parse_sugar_expr(expr: *AstNode) -> *AstNode {
    var walker: CompilerAstWalker = ast_walker_new(COMPILER_AST_WALK_LOWER_PARSE_SUGAR, slice(0, 0));
    return ast_walker_walk_expr(&walker, expr);
}

func lower_parse_sugar_stmt(stmt: *AstNode) -> u64 {
    var walker: CompilerAstWalker = ast_walker_new(COMPILER_AST_WALK_LOWER_PARSE_SUGAR, slice(0, 0));
    return ast_walker_walk_stmt(&walker, stmt);
}

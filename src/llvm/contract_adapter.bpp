func annotation_dump_llvm_ll_skeleton_fd(program: *AstProgram, adapter: *AnnLLVMContractAdapter, fd: u64) -> u64 {
    return llvm_contract_dump_ll_skeleton_fd_impl(program, adapter, fd);
}

func annotation_dump_llvm_ll_skeleton_to_path(program: *AstProgram, path: []u8) -> u64 {
    if (program == 0 || path.ptr == 0 || path.len == 0) { return 0; }
    var opts: *LLVMSSALoweringOptions = new LLVMSSALoweringOptions{};
    var module: *LLVMSSAModuleSketch = llvm_ssa_collect_module_sketch_from_program(program, 0, opts);
    if (module == 0) { return 0; }
    if (llvm_ssa_validate_module_sketch(module) == 0) { return 0; }
    var graph: *AnnLoweredContractGraph = annotation_build_lowered_contract_graph(program);
    if (graph == 0 || graph.nodes == 0) { return 0; }
    var envelope: *AnnBackendContractEnvelope = annotation_build_backend_contract_envelope(graph);
    if (envelope == 0 || envelope.atoms == 0) { return 0; }
    var adapter: *AnnLLVMContractAdapter = annotation_build_llvm_contract_adapter(envelope);
    if (adapter == 0 || adapter.atoms == 0) { return 0; }
    var flags: u64 = OS_O_WRONLY + OS_O_CREAT + OS_O_TRUNC;
    var fd_i: i64 = (i64)sys_open(path.ptr, flags, 420);
    if (fd_i < 0) { return 0; }
    var fd: u64 = (u64)fd_i;
    llvm_contract_dump_ll_skeleton_from_module_fd_impl(module, adapter, fd);
    sys_close(fd);
    return 1;
}

func annotation_dump_llvm_contract_adapter_to_path(program: *AstProgram, path: []u8) -> u64 {
    if (program == 0 || path.ptr == 0 || path.len == 0) { return 0; }
    var graph: *AnnLoweredContractGraph = annotation_build_lowered_contract_graph(program);
    if (graph == 0 || graph.nodes == 0) { return 0; }
    var envelope: *AnnBackendContractEnvelope = annotation_build_backend_contract_envelope(graph);
    if (envelope == 0 || envelope.atoms == 0) { return 0; }
    var adapter: *AnnLLVMContractAdapter = annotation_build_llvm_contract_adapter(envelope);
    if (adapter == 0 || adapter.atoms == 0) { return 0; }
    var flags: u64 = OS_O_WRONLY + OS_O_CREAT + OS_O_TRUNC;
    var fd_i: i64 = (i64)sys_open(path.ptr, flags, 420);
    if (fd_i < 0) { return 0; }
    var fd: u64 = (u64)fd_i;
    annotation_dump_llvm_contract_adapter_fd(adapter, fd);
    sys_close(fd);
    return 1;
}

func annotation_dump_llvm_contract_adapter_stderr(program: *AstProgram) -> u64 {
    if (program == 0) { return 0; }
    var graph: *AnnLoweredContractGraph = annotation_build_lowered_contract_graph(program);
    if (graph == 0 || graph.nodes == 0) { return 0; }
    var envelope: *AnnBackendContractEnvelope = annotation_build_backend_contract_envelope(graph);

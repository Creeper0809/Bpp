func annotation_dump_llvm_ll_skeleton_stdout(program: *AstProgram) -> u64 {
    if (program == 0) { return 0; }
    var opts: *LLVMSSALoweringOptions = new LLVMSSALoweringOptions{};
    var module: *LLVMSSAModuleSketch = llvm_ssa_collect_module_sketch_from_program(program, 0, opts);
    if (module == 0) { return 0; }
    if (llvm_ssa_validate_module_sketch(module) == 0) { return 0; }
    var graph: *AnnLoweredContractGraph = annotation_build_lowered_contract_graph(program);
    if (graph == 0 || graph.nodes == 0) { return 0; }
    var envelope: *AnnBackendContractEnvelope = annotation_build_backend_contract_envelope(graph);
    if (envelope == 0 || envelope.atoms == 0) { return 0; }
    var adapter: *AnnLLVMContractAdapter = annotation_build_llvm_contract_adapter(envelope);
    if (adapter == 0 || adapter.atoms == 0) { return 0; }
    llvm_contract_dump_ll_skeleton_from_module_fd_impl(module, adapter, IO_STDOUT_FD);
    return 1;
}

func annotation_build_expected_post_llvm_contract_records(envelope: *AnnBackendContractEnvelope) -> *Vec<*AnnPostLLVMContractRecord> {
    return llvm_build_expected_post_llvm_contract_records_impl(envelope);
}

func annotation_validate_post_llvm_contract_metadata(envelope: *AnnBackendContractEnvelope, records: *Vec<*AnnPostLLVMContractRecord>) -> u64 {
    return llvm_validate_post_llvm_contract_metadata_impl(envelope, records);
}

func annotation_validate_post_llvm_contract_metadata_scaffold(program: *AstProgram) -> u64 {
    var graph: *AnnLoweredContractGraph = annotation_build_lowered_contract_graph(program);
    if (graph == 0 || graph.nodes == 0) { return 1; }
    var envelope: *AnnBackendContractEnvelope = annotation_build_backend_contract_envelope(graph);
    if (envelope == 0 || envelope.atoms == 0) { return 1; }
    if (annotation_validate_backend_contract_envelope(graph, envelope) == 0) { return 0; }
    var records: *Vec<*AnnPostLLVMContractRecord> = annotation_build_expected_post_llvm_contract_records(envelope);
    if (records == 0) { return 1; }
    return annotation_validate_post_llvm_contract_metadata(envelope, records);
}

func annotation_validate_llvm_contract_adapter_scaffold(program: *AstProgram) -> u64 {
    var graph: *AnnLoweredContractGraph = annotation_build_lowered_contract_graph(program);
    if (graph == 0 || graph.nodes == 0) { return 1; }
    var envelope: *AnnBackendContractEnvelope = annotation_build_backend_contract_envelope(graph);
    if (envelope == 0 || envelope.atoms == 0) { return 1; }
    if (annotation_validate_backend_contract_envelope(graph, envelope) == 0) { return 0; }
    var adapter: *AnnLLVMContractAdapter = annotation_build_llvm_contract_adapter(envelope);
    if (adapter == 0 || adapter.atoms == 0) { return 1; }
    return annotation_validate_llvm_contract_adapter(envelope, adapter);
}

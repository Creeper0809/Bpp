                        sketch.ast_ret_type == TYPE_U16 || sketch.ast_ret_type == TYPE_I16 ||
                        sketch.ast_ret_type == TYPE_U32 || sketch.ast_ret_type == TYPE_I32) {
                        emit("  %retcast");
                        print_u64(block.id);
                        emit("_");
                        print_u64(i);
                        emit(" = trunc i64 %r");
                        print_u64(inst.src1_value);
                        emit(" to ");
                        if (sketch.ast_ret_type == TYPE_U8 || sketch.ast_ret_type == TYPE_I8) { emit("i8"); }
                        else if (sketch.ast_ret_type == TYPE_U16 || sketch.ast_ret_type == TYPE_I16) { emit("i16"); }
                        else { emit("i32"); }
                        emit("\n");
                        emit("  ret ");
                        if (sketch.ast_ret_type == TYPE_U8 || sketch.ast_ret_type == TYPE_I8) { emit("i8 "); }
                        else if (sketch.ast_ret_type == TYPE_U16 || sketch.ast_ret_type == TYPE_I16) { emit("i16 "); }
                        else { emit("i32 "); }

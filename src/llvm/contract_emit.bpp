    emit(" body_params=");
    print_u64(sketch.ll_body_param_types);
    emit(" tag_direct=");
    print_u64(sketch.tag_direct_summary_bits);
    emit(" tag_bits=");
    print_u64(sketch.tag_summary_bits);
    emit(" tag_interproc=");
    print_u64(sketch.tag_interproc_summary_bits);
    emit(" tag_callees=");
    print_u64(sketch.tag_interproc_callee_count);
    emit(" tag_folds=");
    print_u64(sketch.tag_fold_count);
    emit(" tag_packs=");
    print_u64(sketch.tag_pack_count);
    emit(" tag_predicates=");
    print_u64(sketch.tag_predicate_fold_count);
    emit(" tag_raw=");
    print_u64(sketch.tag_raw_elision_count);
    emit(" tag_hot=");
    print_u64(sketch.tag_hot_path_fold_count);
    emit(" tag_profile=");
    print_u64(sketch.tag_profile_fold_count);
    emit(" tag_ic=");
    print_u64(sketch.tag_inline_cache_fold_count);
    emit(" tag_calls=");
    print_u64(sketch.tag_callsite_count);
    emit(" tag_callgraph=");
    print_u64(sketch.tag_call_graph_cached);
    emit(" stack_new=");
    print_u64(sketch.stack_new_lower_count);
    emit(" stack_noescape=");
    print_u64(sketch.stack_new_noescape_callsite_count);
    emit(" stack_tag_policy=");
    print_u64(sketch.stack_new_tag_policy_count);
    emit(" stack_sroa=");
    print_u64(sketch.stack_new_sroa_field_count);
    emit(" stack_scalar=");
    print_u64(sketch.stack_new_sroa_scalar_count);
    emit("\n");
    if (sketch.blocks != 0) {
        emit("; bpp.ssa.ops=");
        var first: u64 = 1;
        var nb: u64 = sketch.blocks.len();
        for (var bi: u64 = 0; bi < nb; bi = bi + 1) {
            var block: *LLVMSSABlockSketch = sketch.blocks.get(bi);
            if (block == 0 || block.insts == 0) { continue; }
            var ni: u64 = block.insts.len();
            for (var ii: u64 = 0; ii < ni; ii = ii + 1) {
                var inst: *LLVMSSAInstSketch = block.insts.get(ii);
                if (inst == 0) { continue; }
                if (first == 0) { emit(","); }
                first = 0;
                print_u64(inst.op);
            }
        }
        emit("\n");
    }
    var has_counted_loop: u64 = llvm_contract_sketch_has_counted_loop_candidate_impl(sketch);
    var has_tagged_access: u64 = llvm_contract_sketch_has_tagged_access_candidate_impl(sketch);

            part.struct_size = info.ret_struct_size;
        }
        if (part.found == 0) {
            part.found = 1;
            part.type_kind = TYPE_U64;
            part.ptr_depth = 0;
            part.role = LLVM_ABI_ROLE_SCALAR;
        }

        return llvm_contract_ll_find_reg_local_base_offset_impl(sketch, inst.src1_value, block_limit, inst_limit, depth + 1, base_enc_out, offset_out);
    }
    if (inst.op == SSA_OP_ADD) {
        var rhs_const: u64 = 0;
        if (inst.has_src2 != 0 && inst.src2_is_const != 0) { rhs_const = inst.src2_value; }
        else if (inst.has_src2 != 0 && inst.src2_is_const == 0 && llvm_contract_ll_try_eval_const_reg_impl(sketch, inst.src2_value, block_limit, inst_limit, depth + 1, &rhs_const) != 0) {
        }
        else { rhs_const = 18446744073709551615; }
        if (inst.has_src1 != 0 && inst.src1_is_const == 0 && rhs_const != 18446744073709551615) {
            var ok1: u64 = llvm_contract_ll_find_reg_local_base_offset_impl(sketch, inst.src1_value, block_limit, inst_limit, depth + 1, base_enc_out, offset_out);
            if (ok1 != 0) {
                *offset_out = *offset_out + rhs_const;
                return 1;
            }
        }
        var lhs_const: u64 = 0;
        if (inst.has_src1 != 0 && inst.src1_is_const != 0) { lhs_const = inst.src1_value; }
        else if (inst.has_src1 != 0 && inst.src1_is_const == 0 && llvm_contract_ll_try_eval_const_reg_impl(sketch, inst.src1_value, block_limit, inst_limit, depth + 1, &lhs_const) != 0) {
        }
        else { lhs_const = 18446744073709551615; }
        if (inst.has_src2 != 0 && inst.src2_is_const == 0 && lhs_const != 18446744073709551615) {
            var ok2: u64 = llvm_contract_ll_find_reg_local_base_offset_impl(sketch, inst.src2_value, block_limit, inst_limit, depth + 1, base_enc_out, offset_out);
            if (ok2 != 0) {
                *offset_out = *offset_out + lhs_const;

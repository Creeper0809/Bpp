    emitln("  br i1 %any_null, label %ret_no, label %check");
    emitln("check:");
    emitln("  %g_shape = load i64, ptr %p0");
    emitln("  %g_elem_ptr = getelementptr i8, ptr %p0, i64 8");
    emitln("  %g_elem = load i64, ptr %g_elem_ptr");
    emitln("  %g_len_class_ptr = getelementptr i8, ptr %p0, i64 16");
    emitln("  %g_len_class = load i64, ptr %g_len_class_ptr");
    emitln("  %g_profiled_ptr = getelementptr i8, ptr %p0, i64 24");
    emitln("  %g_profiled = load i64, ptr %g_profiled_ptr");
    emitln("  %g_hot_ptr = getelementptr i8, ptr %p0, i64 32");
    emitln("  %g_hot = load i64, ptr %g_hot_ptr");
    emitln("  %g_epoch_ptr = getelementptr i8, ptr %p0, i64 40");
    emitln("  %g_epoch = load i64, ptr %g_epoch_ptr");
    emitln("  %tagged = load i64, ptr %p1");
    emitln("  %len_ptr = getelementptr i8, ptr %p1, i64 8");
    emitln("  %len = load i64, ptr %len_ptr");
    emitln("  %shape_shift = lshr i64 %tagged, 59");
    emitln("  %shape = and i64 %shape_shift, 15");
    emitln("  %profiled_shift = lshr i64 %tagged, 63");
    emitln("  %profiled = and i64 %profiled_shift, 1");
    emitln("  %is_empty = icmp eq i64 %len, 0");
    emitln("  %is_tiny = icmp ult i64 %len, 4");
    emitln("  %is_small = icmp ult i64 %len, 16");
    emitln("  %is_medium = icmp ult i64 %len, 1024");
    emitln("  %lc_medium_large = select i1 %is_medium, i64 3, i64 4");
    emitln("  %lc_small = select i1 %is_small, i64 2, i64 %lc_medium_large");
    emitln("  %lc_tiny = select i1 %is_tiny, i64 1, i64 %lc_small");
    emitln("  %len_class = select i1 %is_empty, i64 0, i64 %lc_tiny");
    emitln("  %profile_null = icmp eq ptr %p2, null");
    emitln("  br i1 %profile_null, label %hot_done_null, label %hot_load");
    emitln("hot_load:");
    emitln("  %iterations = load i64, ptr %p2");
    emitln("  %threshold_ptr = getelementptr i8, ptr %p2, i64 16");
    emitln("  %threshold = load i64, ptr %threshold_ptr");
    emitln("  %hot_cmp = icmp uge i64 %iterations, %threshold");
    emitln("  %hot_val = zext i1 %hot_cmp to i64");
    emitln("  br label %hot_done");
    emitln("hot_done_null:");
    emitln("  br label %hot_done");
    emitln("hot_done:");
    emitln("  %hot = phi i64 [ %hot_val, %hot_load ], [ 0, %hot_done_null ]");
    emitln("  %shape_ok = icmp eq i64 %g_shape, %shape");
    emit("  %elem_ok = icmp eq i64 %g_elem, ");
    print_u64(elem_size);
    emit("\n");
    emitln("  %len_ok = icmp eq i64 %g_len_class, %len_class");
    emitln("  %profiled_ok = icmp eq i64 %g_profiled, %profiled");
    emitln("  %hot_ok = icmp eq i64 %g_hot, %hot");
    emitln("  %epoch_ok = icmp eq i64 %g_epoch, %p3");
    emitln("  %ok0 = and i1 %shape_ok, %elem_ok");
    emitln("  %ok1 = and i1 %len_ok, %profiled_ok");
    emitln("  %ok2 = and i1 %hot_ok, %epoch_ok");
    emitln("  %ok3 = and i1 %ok0, %ok1");
    emitln("  %ok = and i1 %ok3, %ok2");
    emitln("  %ret = zext i1 %ok to i64");
    emitln("  ret i64 %ret");
    emitln("ret_no:");
    emitln("  ret i64 0");

        return llvm_contract_ll_emit_slice_proof_vector_plan_body_impl();
    }
    var from_prefix: []u8 = slice("std_mem__bpp_slice_proof_from_tagged__G__T_", str_len("std_mem__bpp_slice_proof_from_tagged__G__T_"));
    if (llvm_contract_name_has_prefix_impl(owner, from_prefix) != 0) {

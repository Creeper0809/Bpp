func llvm_contract_ll_emit_shape_cache_select_fast_path_len_body_impl() -> u64 {
    emitln(" {");
    emitln("entry:");
    emitln("  ; bpp.tag.shape_cache_select = direct-fast-path");
    emitln("  %len_zero = icmp eq i64 %p3, 0");
    emitln("  br i1 %len_zero, label %chosen_none, label %shape_check");
    emitln("shape_check:");

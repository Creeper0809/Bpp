func llvm_contract_ll_emit_tag_slice_find_eq_i64_vector_body_impl(is_signed: u64) -> u64 {
    emitln(" {");
    emitln("entry:");
    emit("  ; bpp.vector.lowering = tagged-slice-find-eq-");
    if (is_signed != 0) { emitln("i64x4"); }
    else { emitln("u64x4"); }
    emitln("  %slice_is_null = icmp eq ptr %p0, null");
    emitln("  br i1 %slice_is_null, label %done.notfound, label %load");
    emitln("load:");
    emitln("  %tagged = load i64, ptr %p0");
    emitln("  %lenptr = getelementptr i8, ptr %p0, i64 8");
    emitln("  %len = load i64, ptr %lenptr");
    emitln("  %raw = and i64 %tagged, 281474976710655");
    emitln("  %raw_is_null = icmp eq i64 %raw, 0");
    emitln("  %len_is_zero = icmp eq i64 %len, 0");
    emitln("  %empty = or i1 %raw_is_null, %len_is_zero");
    emitln("  br i1 %empty, label %done.notfound, label %prep");
    emitln("prep:");
    emitln("  %base = inttoptr i64 %raw to ptr");
    emitln("  %needle0 = insertelement <4 x i64> zeroinitializer, i64 %p1, i32 0");
    emitln("  %needle1 = insertelement <4 x i64> %needle0, i64 %p1, i32 1");
    emitln("  %needle2 = insertelement <4 x i64> %needle1, i64 %p1, i32 2");
    emitln("  %needle = insertelement <4 x i64> %needle2, i64 %p1, i32 3");
    emitln("  %sent0 = insertelement <4 x i64> zeroinitializer, i64 %len, i32 0");
    emitln("  %sent1 = insertelement <4 x i64> %sent0, i64 %len, i32 1");
    emitln("  %sent2 = insertelement <4 x i64> %sent1, i64 %len, i32 2");
    emitln("  %sentinel = insertelement <4 x i64> %sent2, i64 %len, i32 3");
    emitln("  %vec_limit = and i64 %len, -4");
    emitln("  %has_vec = icmp uge i64 %len, 4");
    emitln("  br i1 %has_vec, label %vec.body, label %tail");
    emitln("vec.body:");
    emitln("  %i = phi i64 [ 0, %prep ], [ %i.next, %vec.body ]");
    emitln("  %vbest = phi <4 x i64> [ %sentinel, %prep ], [ %vbest.next, %vec.body ]");
    emitln("  %elem = getelementptr i64, ptr %base, i64 %i");
    emitln("  %v = load <4 x i64>, ptr %elem, align 8");
    emitln("  %cmp = icmp eq <4 x i64> %v, %needle");
    emitln("  %i1 = add i64 %i, 1");
    emitln("  %i2 = add i64 %i, 2");
    emitln("  %i3 = add i64 %i, 3");
    emitln("  %idx0 = insertelement <4 x i64> zeroinitializer, i64 %i, i32 0");
    emitln("  %idx1 = insertelement <4 x i64> %idx0, i64 %i1, i32 1");
    emitln("  %idx2 = insertelement <4 x i64> %idx1, i64 %i2, i32 2");
    emitln("  %idx = insertelement <4 x i64> %idx2, i64 %i3, i32 3");
    emitln("  %cand = select <4 x i1> %cmp, <4 x i64> %idx, <4 x i64> %sentinel");
    emitln("  %better = icmp ult <4 x i64> %cand, %vbest");
    emitln("  %vbest.next = select <4 x i1> %better, <4 x i64> %cand, <4 x i64> %vbest");
    emitln("  %i.next = add i64 %i, 4");
    emitln("  %more = icmp ult i64 %i.next, %vec_limit");
    emitln("  br i1 %more, label %vec.body, label %vec.done");
    emitln("vec.done:");
    emitln("  %e0 = extractelement <4 x i64> %vbest.next, i32 0");
    emitln("  %e1 = extractelement <4 x i64> %vbest.next, i32 1");
    emitln("  %e2 = extractelement <4 x i64> %vbest.next, i32 2");
    emitln("  %e3 = extractelement <4 x i64> %vbest.next, i32 3");
    emitln("  %c01 = icmp ult i64 %e1, %e0");
    emitln("  %m01 = select i1 %c01, i64 %e1, i64 %e0");
    emitln("  %c23 = icmp ult i64 %e3, %e2");
    emitln("  %m23 = select i1 %c23, i64 %e3, i64 %e2");
    emitln("  %c03 = icmp ult i64 %m23, %m01");
    emitln("  %vred = select i1 %c03, i64 %m23, i64 %m01");
    emitln("  br label %tail");
    emitln("tail:");
    emitln("  %t = phi i64 [ 0, %prep ], [ %vec_limit, %vec.done ], [ %t.next, %tail.body ]");
    emitln("  %acc = phi i64 [ %len, %prep ], [ %vred, %vec.done ], [ %acc.next, %tail.body ]");
    emitln("  %tail_done = icmp uge i64 %t, %len");
    emitln("  br i1 %tail_done, label %done, label %tail.body");
    emitln("tail.body:");
    emitln("  %tp = getelementptr i64, ptr %base, i64 %t");
    emitln("  %tv = load i64, ptr %tp, align 8");
    emitln("  %tc = icmp eq i64 %tv, %p1");
    emitln("  %tail.cand = select i1 %tc, i64 %t, i64 %len");
    emitln("  %tail.better = icmp ult i64 %tail.cand, %acc");
    emitln("  %acc.next = select i1 %tail.better, i64 %tail.cand, i64 %acc");
    emitln("  %t.next = add i64 %t, 1");
    emitln("  br label %tail");
    emitln("done:");
    emitln("  %found = icmp ult i64 %acc, %len");
    emitln("  br i1 %found, label %done.found, label %done.notfound");
    emitln("done.found:");
    emitln("  ret i64 %acc");
    emitln("done.notfound:");
    emitln("  ret i64 -1");
    emitln("}");
    return 1;
}


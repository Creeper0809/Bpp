func llvm_contract_ll_reg_has_f64_use_impl(fn: *AstFunc, sketch: *LLVMSSAFuncSketch, reg_id: u64) -> u64 {
    if (sketch == 0 || sketch.blocks == 0 || reg_id == 0) { return 0; }
    var nb: u64 = sketch.blocks.len();
    for (var bi: u64 = 0; bi < nb; bi = bi + 1) {
        var block: *LLVMSSABlockSketch = sketch.blocks.get(bi);
        if (block == 0 || block.insts == 0) { continue; }
        var ni: u64 = block.insts.len();
        for (var ii: u64 = 0; ii < ni; ii = ii + 1) {
            var inst: *LLVMSSAInstSketch = block.insts.get(ii);
            if (inst == 0) { continue; }
            if (inst.op == SSA_OP_FADD || inst.op == SSA_OP_FSUB ||
                inst.op == SSA_OP_FMUL || inst.op == SSA_OP_FDIV || inst.op == SSA_OP_FNEG ||
                inst.op == SSA_OP_FEQ || inst.op == SSA_OP_FNE || inst.op == SSA_OP_FLT ||
                inst.op == SSA_OP_FGT || inst.op == SSA_OP_FLE || inst.op == SSA_OP_FGE ||
                inst.op == SSA_OP_F2I || inst.op == SSA_OP_F2U) {
                if (inst.has_src1 != 0 && inst.src1_is_const == 0 && inst.src1_value == reg_id) { return 1; }
                if (inst.has_src2 != 0 && inst.src2_is_const == 0 && inst.src2_value == reg_id) { return 1; }
            }
            if (fn != 0 && fn.ret_type == TYPE_F64 && fn.ret_ptr_depth == 0 && inst.op == SSA_OP_RET) {
                if (inst.has_src1 != 0 && inst.src1_is_const == 0 && inst.src1_value == reg_id) { return 1; }
            }
            if (inst.op == SSA_OP_CALL && inst.has_src1 != 0 && inst.src1_is_const != 0) {
                var call_info: *SSACallInfo = (*SSACallInfo)inst.src1_value;
                if (call_info != 0 && call_info.args_vec != 0 && call_info.args_vec.len() > 0 &&
                    call_info.args_vec.get(0) == reg_id) {
                    if (str_eq(call_info.name, slice("std_number__Number_from_f64", str_len("std_number__Number_from_f64"))) != 0) { return 1; }
                    if (str_eq(call_info.name, slice("Number_from_f64", str_len("Number_from_f64"))) != 0) { return 1; }
                    if (str_eq(call_info.name, slice("std_io__to_str_f64", str_len("std_io__to_str_f64"))) != 0) { return 1; }
                    if (str_eq(call_info.name, slice("to_str_f64", str_len("to_str_f64"))) != 0) { return 1; }
                }
            }
        }
    }
    return 0;
}

func llvm_contract_ll_reg_is_f64_depth_impl(fn: *AstFunc, sketch: *LLVMSSAFuncSketch, reg_id: u64, depth: u64) -> u64 {
    if (depth > 32) { return 0; }
    if (sketch == 0 || sketch.blocks == 0 || reg_id == 0) { return 0; }
    var inst: *LLVMSSAInstSketch = llvm_contract_ll_find_inst_by_dest_impl(sketch, reg_id, 18446744073709551615, 18446744073709551615);
    if (inst == 0) { return 0; }
    if (inst.op == SSA_OP_FCONST || inst.op == SSA_OP_FADD || inst.op == SSA_OP_FSUB ||
        inst.op == SSA_OP_FMUL || inst.op == SSA_OP_FDIV || inst.op == SSA_OP_FNEG ||
        inst.op == SSA_OP_I2F || inst.op == SSA_OP_U2F) { return 1; }
    if (inst.op == SSA_OP_LOAD64 && llvm_contract_ll_reg_has_f64_use_impl(fn, sketch, reg_id) != 0) { return 1; }
    if (inst.op == SSA_OP_COPY && inst.has_src1 != 0 && inst.src1_is_const == 0) {
        return llvm_contract_ll_reg_is_f64_depth_impl(fn, sketch, inst.src1_value, depth + 1);
    }
    if (inst.op == SSA_OP_PHI && inst.phi_args != 0 && inst.phi_args.len() != 0) {
        var saw_f64: u64 = 0;
        for (var pi: u64 = 0; pi < inst.phi_args.len(); pi = pi + 1) {
            var phi_arg: *LLVMSSAPhiArgSketch = inst.phi_args.get(pi);
            if (phi_arg == 0 || phi_arg.val == 0 || phi_arg.val == reg_id) { continue; }
            var phi_arg_ty: u64 = llvm_contract_ll_reg_value_type_depth_impl(fn, sketch, phi_arg.val, depth + 1);
            if (phi_arg_ty == TYPE_F64 || llvm_contract_ll_reg_is_f64_depth_impl(fn, sketch, phi_arg.val, depth + 1) != 0) {
                saw_f64 = 1;
                continue;
            }
            return 0;
        }
        return saw_f64;
    }
    if (inst.op == SSA_OP_PARAM && fn != 0) {
        var param_t: *Param = llvm_contract_fn_param_from_abi_index_from_program_impl(0, fn, inst.src1_value);
        if (param_t != 0 && param_t.ptr_depth == 0 && param_t.type_kind == TYPE_F64) { return 1; }
    }
    if (inst.op == SSA_OP_CALL && inst.has_src1 != 0 && inst.src1_is_const != 0) {
        var call_info: *SSACallInfo = (*SSACallInfo)inst.src1_value;
        if (call_info != 0 && call_info.ret_ptr_depth == 0 && call_info.ret_type == TYPE_F64) { return 1; }
    }
    if (inst.op == SSA_OP_CALL_PTR && inst.has_src1 != 0 && inst.src1_is_const != 0) {
        var call_ptr_info: *SSACallPtrInfo = (*SSACallPtrInfo)inst.src1_value;
        if (call_ptr_info != 0 && call_ptr_info.ret_ptr_depth == 0 && call_ptr_info.ret_type == TYPE_F64) { return 1; }
    }
    return 0;
}

func llvm_contract_ll_reg_is_f64_impl(fn: *AstFunc, sketch: *LLVMSSAFuncSketch, reg_id: u64) -> u64 {
    return llvm_contract_ll_reg_is_f64_depth_impl(fn, sketch, reg_id, 0);
}

func llvm_contract_ll_emit_boolish_value_impl(fn: *AstFunc, sketch: *LLVMSSAFuncSketch, is_const: u64, value: u64, block_id: u64, inst_idx: u64, slot_id: u64) -> u64 {
    if (is_const != 0) {
        if (value != 0) { emit("1"); }
        else { emit("0"); }
        return 1;
    }
    if (value == 0) {
        emit("0");
        return 1;
    }
    if (llvm_contract_ll_reg_value_type_impl(fn, sketch, value) == TYPE_BOOL ||
        llvm_contract_ll_reg_is_bool_impl(fn, sketch, value) != 0) {
        emit("%r");
        print_u64(value);
        return 1;
    }
    var bool_const: u64 = 0;
    if (llvm_contract_ll_try_eval_const_reg_impl(sketch, value, block_id, inst_idx, 0, &bool_const) != 0) {
        if (bool_const != 0) { emit("1"); }
        else { emit("0"); }
        return 1;
    }
    emit("  %boolcast");
    print_u64(block_id);
    emit("_");
    print_u64(inst_idx);
    emit("_");
    print_u64(slot_id);
    emit(" = icmp ne i64 %r");
    print_u64(value);
    emit(", 0\n");
    emit("%boolcast");
    print_u64(block_id);
    emit("_");
    print_u64(inst_idx);
    emit("_");
    print_u64(slot_id);
    return 1;
}

func llvm_contract_ll_var_slot_type_impl(fn: *AstFunc, sketch: *LLVMSSAFuncSketch, var_id: u64) -> u64 {
    if (sketch == 0 || sketch.blocks == 0 || var_id == 0) { return TYPE_U64; }
    var nb: u64 = sketch.blocks.len();

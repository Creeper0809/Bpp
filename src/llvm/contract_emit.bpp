// llvm_contract_emit.b - LLVM-facing text emitters

import std.io;
import std.os;
import std.str;
import ast;
import types;
import lexer;
import compiler;
import compiler.annotations;
import compiler.runtime_api;
import compiler.symbol_runtime;
import emitter.typeinfo;
import llvm.contract_types;
import llvm.lower_ssa;
import ssa.datastruct;
import ssa.core;

func llvm_contract_dump_adapter_fd_impl(adapter: *AnnLLVMContractAdapter, fd: u64) -> u64 {
    if (adapter == 0 || adapter.atoms == 0) { return 0; }
    var saved_fd: u64 = io_get_output_fd();
    io_set_output_fd(fd);
    emitln("llvm_contract_adapter_v1 {");
    emitln("  schema=\"bpp.contract.adapter.v1\"");
    emit("  atom_count=");
    print_u64(adapter.atoms.len());
    emit("\n");
    var n: u64 = adapter.atoms.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var atom: *AnnLLVMContractAtom = adapter.atoms.get(i);
        if (atom == 0) { continue; }
        emitln("  atom {");
        emit("    owner=\"");
        if (u8_slice_ptr(atom.owner) != 0 && u8_slice_len(atom.owner) != 0) { io_write_out(u8_slice_ptr(atom.owner), u8_slice_len(atom.owner)); }
        emitln("\"");
        emit("    module=\"");
        if (u8_slice_ptr(atom.module) != 0 && u8_slice_len(atom.module) != 0) { io_write_out(u8_slice_ptr(atom.module), u8_slice_len(atom.module)); }
        emitln("\"");
        emit("    metadata_key=\"");
        if (u8_slice_ptr(atom.metadata_key) != 0 && u8_slice_len(atom.metadata_key) != 0) { io_write_out(u8_slice_ptr(atom.metadata_key), u8_slice_len(atom.metadata_key)); }
        emitln("\"");
        emit("    surface=\"");
        if (u8_slice_ptr(atom.surface) != 0 && u8_slice_len(atom.surface) != 0) { io_write_out(u8_slice_ptr(atom.surface), u8_slice_len(atom.surface)); }
        emitln("\"");
        emit("    detail=\"");
        if (u8_slice_ptr(atom.detail) != 0 && u8_slice_len(atom.detail) != 0) { io_write_out(u8_slice_ptr(atom.detail), u8_slice_len(atom.detail)); }
        emitln("\"");
        emit("    family_mask=");
        print_u64(atom.family_mask);
        emit("\n");
        emit("    boundary_mask=");
        print_u64(atom.boundary_mask);
        emit("\n");
        emit("    decl_site=");
        print_u64(atom.decl_line);
        emit(":");
        print_u64(atom.decl_col);
        emit("\n");
        emit("    related_decl_site=");
        print_u64(atom.related_decl_line);
        emit(":");
        print_u64(atom.related_decl_col);
        emit("\n");
        if (u8_slice_ptr(atom.related) != 0 && u8_slice_len(atom.related) != 0) {
            emit("    related=\"");
            io_write_out(u8_slice_ptr(atom.related), u8_slice_len(atom.related));
            emitln("\"");
        }
        if (u8_slice_ptr(atom.aux) != 0 && u8_slice_len(atom.aux) != 0) {
            emit("    aux=\"");
            io_write_out(u8_slice_ptr(atom.aux), u8_slice_len(atom.aux));
            emitln("\"");
        }
        emitln("  }");
    }
    emitln("}");
    io_set_output_fd(saved_fd);
    return 0;
}

func llvm_contract_dump_proto_fd_impl(adapter: *AnnLLVMContractAdapter, fd: u64) -> u64 {
    if (adapter == 0 || adapter.atoms == 0) { return 0; }
    var saved_fd: u64 = io_get_output_fd();
    io_set_output_fd(fd);
    emitln("; bpp llvm contract metadata prototype v1");
    emitln("!bpp.contract = !{");
    var n: u64 = adapter.atoms.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        emit("  !");
        print_u64(i);
        if (i + 1 < n) { emit(","); }
        emit("\n");
    }
    emitln("}");
    for (var i2: u64 = 0; i2 < n; i2 = i2 + 1) {
        var atom2: *AnnLLVMContractAtom = adapter.atoms.get(i2);
        if (atom2 == 0) { continue; }
        emit("!");
        print_u64(i2);
        emit(" = !{!");
        emit("\"");
        if (u8_slice_ptr(atom2.metadata_key) != 0 && u8_slice_len(atom2.metadata_key) != 0) { io_write_out(u8_slice_ptr(atom2.metadata_key), u8_slice_len(atom2.metadata_key)); }
        emit("\", !");
        emit("\"");
        if (u8_slice_ptr(atom2.owner) != 0 && u8_slice_len(atom2.owner) != 0) { io_write_out(u8_slice_ptr(atom2.owner), u8_slice_len(atom2.owner)); }
        emit("\", !");
        emit("\"");
        if (u8_slice_ptr(atom2.module) != 0 && u8_slice_len(atom2.module) != 0) { io_write_out(u8_slice_ptr(atom2.module), u8_slice_len(atom2.module)); }
        emit("\", !");
        emit("\"");
        if (u8_slice_ptr(atom2.surface) != 0 && u8_slice_len(atom2.surface) != 0) { io_write_out(u8_slice_ptr(atom2.surface), u8_slice_len(atom2.surface)); }
        emit("\", !");
        emit("\"");
        if (u8_slice_ptr(atom2.detail) != 0 && u8_slice_len(atom2.detail) != 0) { io_write_out(u8_slice_ptr(atom2.detail), u8_slice_len(atom2.detail)); }
        emit("\"");
        emit(", i64 ");
        print_u64(atom2.family_mask);
        emit(", i64 ");
        print_u64(atom2.boundary_mask);
        emit(", i64 ");
        print_u64(atom2.decl_line);
        emit(", i64 ");
        print_u64(atom2.decl_col);
        emit(", i64 ");
        print_u64(atom2.related_decl_line);
        emit(", i64 ");
        print_u64(atom2.related_decl_col);
        if (u8_slice_ptr(atom2.related) != 0 && u8_slice_len(atom2.related) != 0) {
            emit(", !");
            emit("\"");
            io_write_out(u8_slice_ptr(atom2.related), u8_slice_len(atom2.related));
            emit("\"");
        }
        if (u8_slice_ptr(atom2.aux) != 0 && u8_slice_len(atom2.aux) != 0) {
            emit(", !");
            emit("\"");
            io_write_out(u8_slice_ptr(atom2.aux), u8_slice_len(atom2.aux));
            emit("\"");
        }
        emitln("}");
    }
    io_set_output_fd(saved_fd);
    return 0;
}

func llvm_contract_target_triple_impl() -> u64 {
    if (compiler_target() == COMPILER_TARGET_WINDOWS_X86_64) {
        return "x86_64-pc-windows-msvc";
    }
    return "x86_64-unknown-linux-gnu";
}

func llvm_contract_emit_quoted_symbol_impl(name: []u8) -> u64 {
    emit("@\"");
    if (name.ptr != 0 && name.len != 0) {
        io_write_out(name.ptr, name.len);
    }
    emit("\"");
    return 0;
}

func llvm_contract_emit_md_string_impl(text: []u8) -> u64 {
    emit("!\"");
    if (text.ptr != 0 && text.len != 0) {
        io_write_out(text.ptr, text.len);
    }
    emit("\"");
    return 0;
}

func llvm_contract_ll_emit_hex_nibble_impl(v: u64) -> u64 {
    match (v & 15) {
        case 0: emit("0"); return 1;
        case 1: emit("1"); return 1;
        case 2: emit("2"); return 1;
        case 3: emit("3"); return 1;
        case 4: emit("4"); return 1;
        case 5: emit("5"); return 1;
        case 6: emit("6"); return 1;
        case 7: emit("7"); return 1;
        case 8: emit("8"); return 1;
        case 9: emit("9"); return 1;
        case 10: emit("A"); return 1;
        case 11: emit("B"); return 1;
        case 12: emit("C"); return 1;
        case 13: emit("D"); return 1;
        case 14: emit("E"); return 1;
    }
    emit("F");
    return 1;
}

func llvm_contract_ll_emit_hex_byte_impl(v: u64) -> u64 {
    emit("\\");
    llvm_contract_ll_emit_hex_nibble_impl((v >> 4) & 15);
    llvm_contract_ll_emit_hex_nibble_impl(v & 15);
    return 1;
}

func llvm_contract_ll_next_string_data_byte_impl(str: []u8, idx_ref: *u64, out_byte: *u64) -> u64 {
    if (idx_ref == 0 || out_byte == 0 || str.ptr == 0 || str.len < 2) { return 0; }
    var j: u64 = *idx_ref;
    if (j == 0 || j >= str.len - 1) { return 0; }
    var c: u64 = *((*u8)(str.ptr + j));
    if (c == 92 && j + 1 < str.len - 1) {
        j = j + 1;
        var ec: u64 = *((*u8)(str.ptr + j));
        if (ec == 110) { *out_byte = 10; }       // \n
        else if (ec == 116) { *out_byte = 9; }   // \t
        else if (ec == 48) { *out_byte = 0; }    // \0
        else if (ec == 92) { *out_byte = 92; }   // \\
        else if (ec == 34) { *out_byte = 34; }   // \"
        else { *out_byte = ec; }
    } else {
        *out_byte = c;
    }
    *idx_ref = j + 1;
    return 1;
}

func llvm_contract_ll_string_data_len_impl(str: []u8) -> u64 {
    if (str.ptr == 0 || str.len < 2) { return 1; }
    var count: u64 = 0;
    var j: u64 = 1;
    var byte_val: u64 = 0;
    while (llvm_contract_ll_next_string_data_byte_impl(slice(str.ptr, str.len), &j, &byte_val) != 0) {
        count = count + 1;
    }
    return count + 1;
}

func llvm_contract_ll_emit_string_bytes_impl(str: []u8) -> u64 {
    if (str.ptr == 0 || str.len < 2) {
        llvm_contract_ll_emit_hex_byte_impl(0);
        return 1;
    }
    var j: u64 = 1;
    var byte_val: u64 = 0;
    while (llvm_contract_ll_next_string_data_byte_impl(slice(str.ptr, str.len), &j, &byte_val) != 0) {
        llvm_contract_ll_emit_hex_byte_impl(byte_val);
    }
    llvm_contract_ll_emit_hex_byte_impl(0);
    return 1;
}

func llvm_contract_ll_emit_string_global_name_impl(fn_id: u64, block_id: u64, inst_idx: u64) -> u64 {
    emit("@\".bpp.str.");
    print_u64(fn_id);
    emit(".");
    print_u64(block_id);
    emit(".");
    print_u64(inst_idx);
    emit("\"");
    return 0;
}

func llvm_contract_ll_emit_string_globals_impl(module: *LLVMSSAModuleSketch) -> u64 {
    if (module == 0 || module.funcs == 0) { return 0; }
    var nfuncs: u64 = module.funcs.len();
    for (var fi: u64 = 0; fi < nfuncs; fi = fi + 1) {
        var sketch: *LLVMSSAFuncSketch = module.funcs.get(fi);
        if (sketch == 0 || sketch.blocks == 0) { continue; }
        var nb: u64 = sketch.blocks.len();
        for (var bi: u64 = 0; bi < nb; bi = bi + 1) {
            var block: *LLVMSSABlockSketch = sketch.blocks.get(bi);
            if (block == 0 || block.insts == 0) { continue; }
            var ni: u64 = block.insts.len();
            for (var ii: u64 = 0; ii < ni; ii = ii + 1) {
                var inst: *LLVMSSAInstSketch = block.insts.get(ii);
                if (inst == 0 || inst.op != SSA_OP_LEA_STR || inst.has_src1 == 0 || inst.src1_is_const == 0) { continue; }
                var info: *PtrLen = (*PtrLen)inst.src1_value;
                if (info == 0 || info.ptr == 0 || info.len == 0) { continue; }
                llvm_contract_ll_emit_string_global_name_impl(sketch.fn_id, block.id, ii);
                emit(" = private unnamed_addr constant [");
                print_u64(llvm_contract_ll_string_data_len_impl(slice(info.ptr, info.len)));
                emit(" x i8] c\"");
                llvm_contract_ll_emit_string_bytes_impl(slice(info.ptr, info.len));
                emitln("\"");
            }
        }
    }
    return 1;
}

func llvm_contract_program_find_func_impl(program: *AstProgram, name: []u8) -> *AstFunc {
    if (name.ptr == 0 || name.len == 0) { return 0; }
    if (program != 0 && program.funcs_vec != 0) {
        var n_prog: u64 = program.funcs_vec.len();
        for (var i_prog: u64 = 0; i_prog < n_prog; i_prog = i_prog + 1) {
            var fn_prog: *AstFunc = program.funcs_vec.get(i_prog);
            if (fn_prog == 0 || u8_slice_ptr(fn_prog.name) == 0 || u8_slice_len(fn_prog.name) != name.len) { continue; }
            if (str_eq(fn_prog.name, slice(name.ptr, name.len)) != 0) { return fn_prog; }
        }
    }
    if (g_compiler_ctx.all_funcs == 0) { return 0; }
    var n: u64 = g_compiler_ctx.all_funcs.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var fn: *AstFunc = g_compiler_ctx.all_funcs.get(i);
        if (fn == 0 || u8_slice_ptr(fn.name) == 0 || u8_slice_len(fn.name) != name.len) { continue; }
        if (str_eq(fn.name, slice(name.ptr, name.len)) != 0) { return fn; }
    }
    return 0;
}

func llvm_contract_program_find_struct_impl(program: *AstProgram, name: []u8) -> *AstStructDef {
    if (program != 0 && program.structs_vec != 0 && name.ptr != 0 && name.len != 0) {
        var n_prog: u64 = program.structs_vec.len();
        for (var i_prog: u64 = 0; i_prog < n_prog; i_prog = i_prog + 1) {
            var sd_prog: *AstStructDef = program.structs_vec.get(i_prog);
            if (sd_prog == 0 || u8_slice_ptr(sd_prog.name) == 0 || u8_slice_len(sd_prog.name) != name.len) { continue; }
            if (str_eq(sd_prog.name, slice(name.ptr, name.len)) != 0) { return sd_prog; }
        }
    }
    if (g_compiler_ctx.all_structs_vec == 0 || name.ptr == 0 || name.len == 0) { return 0; }
    var n: u64 = g_compiler_ctx.all_structs_vec.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var sd: *AstStructDef = g_compiler_ctx.all_structs_vec.get(i);
        if (sd == 0 || u8_slice_ptr(sd.name) == 0 || u8_slice_len(sd.name) != name.len) { continue; }
        if (str_eq(sd.name, slice(name.ptr, name.len)) != 0) { return sd; }
    }
    return 0;
}

func llvm_contract_program_find_global_impl(program: *AstProgram, name: []u8) -> *GlobalInfo {
    if (name.ptr == 0 || name.len == 0) { return 0; }
    if (program != 0 && program.globals_vec != 0) {
        var n_prog: u64 = program.globals_vec.len();
        for (var i_prog: u64 = 0; i_prog < n_prog; i_prog = i_prog + 1) {
            var g_prog: *GlobalInfo = program.globals_vec.get(i_prog);
            if (g_prog == 0 || u8_slice_ptr(g_prog.name) == 0 || u8_slice_len(g_prog.name) != name.len) { continue; }
            if (str_eq(g_prog.name, slice(name.ptr, name.len)) != 0) { return g_prog; }
        }
    }
    if (g_compiler_ctx.all_globals == 0) { return 0; }
    var n: u64 = g_compiler_ctx.all_globals.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var g: *GlobalInfo = g_compiler_ctx.all_globals.get(i);
        if (g == 0 || u8_slice_ptr(g.name) == 0 || u8_slice_len(g.name) != name.len) { continue; }
        if (str_eq(g.name, slice(name.ptr, name.len)) != 0) { return g; }
    }
    return 0;
}

func llvm_contract_program_find_const_value_impl(program: *AstProgram, name: []u8, out_value: *u64) -> u64 {
    if (out_value != 0) { *out_value = 0; }
    if (name.ptr == 0 || name.len == 0 || out_value == 0) { return 0; }
    if (program != 0 && program.consts_vec != 0) {
        var n_prog: u64 = program.consts_vec.len();
        for (var i_prog: u64 = 0; i_prog < n_prog; i_prog = i_prog + 1) {
            var c_prog: *AstConstDecl = program.consts_vec.get(i_prog);
            if (c_prog == 0 || u8_slice_ptr(c_prog.name) == 0 || u8_slice_len(c_prog.name) != name.len) { continue; }
            if (str_eq(c_prog.name, slice(name.ptr, name.len)) == 0) { continue; }
            *out_value = c_prog.value;
            return 1;
        }
    }
    if (g_compiler_ctx.all_consts != 0) {
        var n: u64 = g_compiler_ctx.all_consts.len();
        for (var i: u64 = 0; i < n; i = i + 1) {
            var c: *AstConstDecl = g_compiler_ctx.all_consts.get(i);
            if (c == 0 || u8_slice_ptr(c.name) == 0 || u8_slice_len(c.name) != name.len) { continue; }
            if (str_eq(c.name, slice(name.ptr, name.len)) == 0) { continue; }
            *out_value = c.value;
            return 1;
        }
    }
    return 0;
}

func llvm_contract_emit_global_symbol_name_impl(name: []u8) -> u64 {
    emit("@\"_gvar_");
    if (name.ptr != 0 && name.len != 0) { io_write_out(name.ptr, name.len); }
    emit("\"");
    return 0;
}

func llvm_contract_name_has_prefix_impl(name: []u8, prefix: []u8) -> u64 {
    if (name.ptr == 0 || prefix.ptr == 0 || name.len < prefix.len) { return 0; }
    return str_eq(slice(name.ptr, prefix.len), slice(prefix.ptr, prefix.len));
}

func llvm_contract_global_is_vtable_impl(ginfo: *GlobalInfo) -> u64 {
    if (ginfo == 0) { return 0; }
    if (llvm_contract_name_has_prefix_impl(ginfo.name, slice("__vtable_", 9)) != 0) { return 1; }
    if (ginfo.typeinfo_ptr != 0 &&
        llvm_contract_name_has_prefix_impl(ginfo.typeinfo_ptr.struct_name, slice("__VTable_", 9)) != 0) {
        return 1;
    }
    return 0;
}

func llvm_contract_global_storage_size_from_typeinfo_impl(ti: *TypeInfo) -> u64 {
    if (ti == 0) { return 8; }
    if (ti.ptr_depth != 0) { return 8; }
    if (ti.type_kind == TYPE_BOOL || ti.type_kind == TYPE_U8 || ti.type_kind == TYPE_I8) { return 1; }
    if (ti.type_kind == TYPE_U16 || ti.type_kind == TYPE_I16) { return 2; }
    if (ti.type_kind == TYPE_U32 || ti.type_kind == TYPE_I32) { return 4; }
    if (ti.type_kind == TYPE_U64 || ti.type_kind == TYPE_I64 || ti.type_kind == TYPE_F64) { return 8; }
    if (ti.type_kind == TYPE_SLICE) { return 16; }
    if (ti.type_kind == TYPE_STRUCT) { return llvm_contract_struct_size_impl(0, ti.struct_name); }
    if (ti.type_kind == TYPE_ARRAY) {
        var elem_sz: u64 = 0;
        if (ti.elem_typeinfo != 0) { elem_sz = llvm_contract_global_storage_size_from_typeinfo_impl(ti.elem_typeinfo); }
        else if (ti.elem_type_kind == TYPE_STRUCT) { elem_sz = llvm_contract_struct_size_impl(0, ti.struct_name); }
        else if (ti.elem_ptr_depth != 0) { elem_sz = 8; }
        else if (ti.elem_type_kind == TYPE_BOOL || ti.elem_type_kind == TYPE_U8 || ti.elem_type_kind == TYPE_I8) { elem_sz = 1; }
        else if (ti.elem_type_kind == TYPE_U16 || ti.elem_type_kind == TYPE_I16) { elem_sz = 2; }
        else if (ti.elem_type_kind == TYPE_U32 || ti.elem_type_kind == TYPE_I32) { elem_sz = 4; }
        else { elem_sz = 8; }
        return elem_sz * ti.array_len;
    }
    return 8;
}

func llvm_contract_global_storage_size_impl(ginfo: *GlobalInfo) -> u64 {
    if (ginfo == 0 || ginfo.typeinfo_ptr == 0) { return 8; }
    return llvm_contract_global_storage_size_from_typeinfo_impl(ginfo.typeinfo_ptr);
}

func llvm_contract_global_vtable_slot_count_impl(ginfo: *GlobalInfo) -> u64 {
    if (ginfo == 0) { return 0; }
    if (ginfo.init_expr != 0 && ast_kind((*AstNode)ginfo.init_expr) == AST_STRUCT_LITERAL) {
        var lit: *AstStructLiteral = (*AstStructLiteral)((*AstNode)ginfo.init_expr);
        if (lit.values_vec != 0) { return lit.values_vec.len(); }
    }
    var storage_size: u64 = llvm_contract_global_storage_size_impl(ginfo);
    if (storage_size == 0) { return 0; }
    return storage_size / 8;
}

func llvm_contract_global_symbol_from_expr_impl(expr: *AstNode, out_ptr: *u64, out_len: *u64) -> u64 {
    if (expr == 0 || out_ptr == 0 || out_len == 0) { return 0; }
    var kind: u64 = ast_kind(expr);
    if (kind == AST_CAST) {
        var cast_node: *AstCast = (*AstCast)expr;
        return llvm_contract_global_symbol_from_expr_impl(cast_node.expr, out_ptr, out_len);
    }
    if (kind == AST_ADDR_OF) {
        var addrof: *AstAddrOf = (*AstAddrOf)expr;
        return llvm_contract_global_symbol_from_expr_impl(addrof.operand, out_ptr, out_len);
    }
    if (kind != AST_IDENT) { return 0; }
    var id: *AstIdent = (*AstIdent)expr;
    var resolved_ptr: u64 = u8_slice_ptr(id.name);
    var resolved_len: u64 = u8_slice_len(id.name);
    var resolved: *NameInfo = resolve_name(id.name);
    if (resolved != 0 && resolved.ptr != 0 && resolved.len != 0) {
        resolved_ptr = resolved.ptr;
        resolved_len = resolved.len;
    }
    if (sym_func_exists(slice(resolved_ptr, resolved_len)) != 0 || sym_func_exists(id.name) != 0) {
        *out_ptr = resolved_ptr;
        *out_len = resolved_len;
        return 1;
    }
    var ginfo_resolved: *GlobalInfo = llvm_contract_program_find_global_impl(0, slice(resolved_ptr, resolved_len));
    if (ginfo_resolved != 0) {
        *out_ptr = u8_slice_ptr(ginfo_resolved.name);
        *out_len = u8_slice_len(ginfo_resolved.name);
        return 2;
    }
    var ginfo_raw: *GlobalInfo = llvm_contract_program_find_global_impl(0, id.name);
    if (ginfo_raw != 0) {
        *out_ptr = u8_slice_ptr(ginfo_raw.name);
        *out_len = u8_slice_len(ginfo_raw.name);
        return 2;
    }
    return 0;
}

func llvm_contract_emit_i8_list_sep_impl(first: *u64) -> u64 {
    if (first == 0) { return 0; }
    if (*first == 0) { emit(", "); }
    else { *first = 0; }
    return 0;
}

func llvm_contract_emit_i8_scalar_bytes_impl(value: u64, width: u64, first: *u64) -> u64 {
    for (var bi: u64 = 0; bi < width; bi = bi + 1) {
        llvm_contract_emit_i8_list_sep_impl(first);
        emit("i8 ");
        print_u64((value >> (bi * 8)) & 255);
    }
    return 0;
}

func llvm_contract_emit_i8_zero_bytes_impl(count: u64, first: *u64) -> u64 {
    for (var zi: u64 = 0; zi < count; zi = zi + 1) {
        llvm_contract_emit_i8_list_sep_impl(first);
        emit("i8 0");
    }
    return 0;
}

func llvm_contract_global_const_u64_expr_impl(program: *AstProgram, expr: *AstNode, out_value: *u64) -> u64 {
    if (expr == 0 || out_value == 0) { return 0; }
    var kind: u64 = ast_kind(expr);
    if (kind == AST_LITERAL) {
        *out_value = ((*AstLiteral)expr).value;
        return 1;
    }
    if (kind == AST_IDENT) {
        var id: *AstIdent = (*AstIdent)expr;
        var cres: *ConstResult = (*ConstResult)sym_find_const(id.name);
        if (cres != 0 && cres.found != 0) {
            *out_value = cres.value;
            return 1;
        }
        var resolved: *NameInfo = resolve_name(id.name);
        if (resolved != 0 && resolved.ptr != 0 && resolved.len != 0) {
            var cres2: *ConstResult = (*ConstResult)sym_find_const(slice(resolved.ptr, resolved.len));
            if (cres2 != 0 && cres2.found != 0) {
                *out_value = cres2.value;
                return 1;
            }
            if (llvm_contract_program_find_const_value_impl(program, slice(resolved.ptr, resolved.len), out_value) != 0) {
                return 1;
            }
        }
        if (llvm_contract_program_find_const_value_impl(program, id.name, out_value) != 0) {
            return 1;
        }
    }
    if (kind == AST_CAST) {
        var cast_node: *AstCast = (*AstCast)expr;
        return llvm_contract_global_const_u64_expr_impl(program, cast_node.expr, out_value);
    }
    if (kind == AST_UNARY) {
        var un: *AstUnary = (*AstUnary)expr;
        var sub_value: u64 = 0;
        if (llvm_contract_global_const_u64_expr_impl(program, un.operand, &sub_value) == 0) { return 0; }
        match (un.op) {
            case TOKEN_MINUS:
                *out_value = 0 - sub_value;
                return 1;
            case TOKEN_BANG:
                if (sub_value == 0) { *out_value = 1; }
                else { *out_value = 0; }
                return 1;
            case TOKEN_TILDE:
                *out_value = ~sub_value;
                return 1;
        }
        return 0;
    }
    if (kind == AST_BINARY) {
        var bin: *AstBinary = (*AstBinary)expr;
        var lhs: u64 = 0;
        var rhs: u64 = 0;
        if (llvm_contract_global_const_u64_expr_impl(program, bin.left, &lhs) == 0) { return 0; }
        if (llvm_contract_global_const_u64_expr_impl(program, bin.right, &rhs) == 0) { return 0; }
        match (bin.op) {
            case TOKEN_PLUS: *out_value = lhs + rhs; return 1;
            case TOKEN_MINUS: *out_value = lhs - rhs; return 1;
            case TOKEN_STAR: *out_value = lhs * rhs; return 1;
            case TOKEN_SLASH:
                if (rhs == 0) { return 0; }
                *out_value = lhs / rhs;
                return 1;
            case TOKEN_PERCENT:
                if (rhs == 0) { return 0; }
                *out_value = lhs % rhs;
                return 1;
            case TOKEN_AMPERSAND: *out_value = lhs & rhs; return 1;
            case TOKEN_PIPE: *out_value = lhs | rhs; return 1;
            case TOKEN_CARET: *out_value = lhs ^ rhs; return 1;
            case TOKEN_LSHIFT: *out_value = lhs << rhs; return 1;
            case TOKEN_RSHIFT: *out_value = lhs >> rhs; return 1;
            case TOKEN_EQEQ:
                if (lhs == rhs) { *out_value = 1; }
                else { *out_value = 0; }
                return 1;
            case TOKEN_BANGEQ:
                if (lhs != rhs) { *out_value = 1; }
                else { *out_value = 0; }
                return 1;
            case TOKEN_LT:
                if (lhs < rhs) { *out_value = 1; }
                else { *out_value = 0; }
                return 1;
            case TOKEN_LTEQ:
                if (lhs <= rhs) { *out_value = 1; }
                else { *out_value = 0; }
                return 1;
            case TOKEN_GT:
                if (lhs > rhs) { *out_value = 1; }
                else { *out_value = 0; }
                return 1;
            case TOKEN_GTEQ:
                if (lhs >= rhs) { *out_value = 1; }
                else { *out_value = 0; }
                return 1;
        }
    }
    return 0;
}

func llvm_contract_emit_struct_literal_bytes_for_def_impl(program: *AstProgram, lit: *AstStructLiteral, target_def: *AstStructDef, total_sz: u64, first: *u64) -> u64 {
    if (lit == 0 || target_def == 0 || target_def.fields_vec == 0 || first == 0) { return 0; }
    var cursor: u64 = 0;
    var nf: u64 = target_def.fields_vec.len();
    var nv: u64 = 0;
    if (lit.values_vec != 0) { nv = lit.values_vec.len(); }
    for (var fi: u64 = 0; fi < nf; fi = fi + 1) {
        var field: *FieldDesc = target_def.fields_vec.get(fi);
        if (field == 0) { continue; }
        var field_sz: u64 = layout_field_sizeof(field);
        var val_expr: *AstNode = 0;
        if (fi < nv) { val_expr = lit.values_vec.get(fi); }
        if (field.type_kind == TYPE_STRUCT && field.ptr_depth == 0 && val_expr != 0 && ast_kind(val_expr) == AST_STRUCT_LITERAL) {
            var nested_total_sz: u64 = llvm_contract_struct_size_impl(0, field.struct_name);
            var nested_def: *AstStructDef = llvm_contract_program_find_struct_impl(0, field.struct_name);
            llvm_contract_emit_struct_literal_bytes_for_def_impl(program, (*AstStructLiteral)val_expr, nested_def, nested_total_sz, first);
        } else {
            var v: u64 = 0;
            if (val_expr != 0 && llvm_contract_global_const_u64_expr_impl(program, val_expr, &v) != 0) {
                llvm_contract_emit_i8_scalar_bytes_impl(v, field_sz, first);
            } else {
                llvm_contract_emit_i8_zero_bytes_impl(field_sz, first);
            }
        }
        cursor = cursor + field_sz;
    }
    while (cursor < total_sz) {
        llvm_contract_emit_i8_zero_bytes_impl(1, first);
        cursor = cursor + 1;
    }
    return total_sz;
}

func llvm_contract_global_type_supported_impl(ginfo: *GlobalInfo) -> u64 {
    if (ginfo == 0 || ginfo.typeinfo_ptr == 0) { return 0; }
    var ti: *TypeInfo = ginfo.typeinfo_ptr;
    if (ti.ptr_depth != 0) { return 1; }
    match (ti.type_kind) {
        case TYPE_ARRAY: return 1;
        case TYPE_SLICE: return 1;
        case TYPE_STRUCT: return 1;
        case TYPE_BOOL: return 1;
        case TYPE_U8: return 1;
        case TYPE_I8: return 1;
        case TYPE_U16: return 1;
        case TYPE_I16: return 1;
        case TYPE_U32: return 1;
        case TYPE_I32: return 1;
        case TYPE_U64: return 1;
        case TYPE_I64: return 1;
        case TYPE_F64: return 1;
    }
    return 0;
}

func llvm_contract_emit_global_type_impl(ginfo: *GlobalInfo) -> u64 {
    if (ginfo == 0 || ginfo.typeinfo_ptr == 0) { emit("i64"); return 1; }
    if (llvm_contract_global_is_vtable_impl(ginfo) != 0) {
        emit("[");
        print_u64(llvm_contract_global_vtable_slot_count_impl(ginfo));
        emit(" x ptr]");
        return 1;
    }
    var ti: *TypeInfo = ginfo.typeinfo_ptr;
    if (ti.ptr_depth != 0) { emit("ptr"); return 1; }
    if (ti.type_kind == TYPE_ARRAY || ti.type_kind == TYPE_SLICE || ti.type_kind == TYPE_STRUCT) {
        emit("[");
        print_u64(llvm_contract_global_storage_size_impl(ginfo));
        emit(" x i8]");
        return 1;
    }
    if (ti.type_kind == TYPE_BOOL) { emit("i1"); return 1; }
    if (ti.type_kind == TYPE_U8 || ti.type_kind == TYPE_I8) { emit("i8"); return 1; }
    if (ti.type_kind == TYPE_U16 || ti.type_kind == TYPE_I16) { emit("i16"); return 1; }
    if (ti.type_kind == TYPE_U32 || ti.type_kind == TYPE_I32) { emit("i32"); return 1; }
    if (ti.type_kind == TYPE_F64) { emit("double"); return 1; }
    emit("i64");
    return 1;
}

func llvm_contract_emit_global_ptr_init_expr_impl(program: *AstProgram, expr: *AstNode) -> u64 {
    var sym_ptr: u64 = 0;
    var sym_len: u64 = 0;
    var sym_kind: u64 = llvm_contract_global_symbol_from_expr_impl(expr, &sym_ptr, &sym_len);
    if (sym_kind == 1) {
        llvm_contract_emit_quoted_symbol_impl(slice(sym_ptr, sym_len));
        return 1;
    }
    if (sym_kind == 2) {
        llvm_contract_emit_global_symbol_name_impl(slice(sym_ptr, sym_len));
        return 1;
    }
    var const_v: u64 = 0;
    if (llvm_contract_global_const_u64_expr_impl(program, expr, &const_v) != 0 && const_v == 0) {
        emit("null");
        return 1;
    }
    emit("null");
    return 1;
}

func llvm_contract_emit_global_vtable_init_impl(program: *AstProgram, ginfo: *GlobalInfo) -> u64 {
    if (ginfo == 0 || ginfo.init_expr == 0 || ast_kind((*AstNode)ginfo.init_expr) != AST_STRUCT_LITERAL) {
        emit("zeroinitializer");
        return 1;
    }
    var lit: *AstStructLiteral = (*AstStructLiteral)((*AstNode)ginfo.init_expr);
    var n: u64 = 0;
    if (lit.values_vec != 0) { n = lit.values_vec.len(); }
    emit("[");
    for (var i: u64 = 0; i < n; i = i + 1) {
        if (i != 0) { emit(", "); }
        emit("ptr ");
        llvm_contract_emit_global_ptr_init_expr_impl(program, lit.values_vec.get(i));
    }
    emit("]");
    return 1;
}

func llvm_contract_emit_global_init_impl(program: *AstProgram, ginfo: *GlobalInfo) -> u64 {
    if (ginfo == 0 || ginfo.typeinfo_ptr == 0) { emit("0"); return 1; }
    if (llvm_contract_global_is_vtable_impl(ginfo) != 0) {
        return llvm_contract_emit_global_vtable_init_impl(program, ginfo);
    }
    var ti: *TypeInfo = ginfo.typeinfo_ptr;
    if (ti.ptr_depth != 0) {
        emit("null");
        return 1;
    }
    if (ti.type_kind == TYPE_ARRAY || ti.type_kind == TYPE_SLICE) {
        emit("zeroinitializer");
        return 1;
    }
    if (ti.type_kind == TYPE_STRUCT) {
        if (ginfo.init_kind == GLOBAL_INIT_EXPR && ginfo.init_expr != 0 && ast_kind((*AstNode)ginfo.init_expr) == AST_STRUCT_LITERAL) {
            emit("[");
            var first: u64 = 1;
            var total_sz: u64 = llvm_contract_global_storage_size_impl(ginfo);
            var target_def: *AstStructDef = ginfo.typeinfo_ptr.struct_def;
            if (target_def == 0 && u8_slice_ptr(ginfo.typeinfo_ptr.struct_name) != 0 && u8_slice_len(ginfo.typeinfo_ptr.struct_name) != 0) {
                target_def = llvm_contract_program_find_struct_impl(program, ginfo.typeinfo_ptr.struct_name);
            }
            llvm_contract_emit_struct_literal_bytes_for_def_impl(program, (*AstStructLiteral)((*AstNode)ginfo.init_expr), target_def, total_sz, &first);
            emit("]");
        } else {
            emit("zeroinitializer");
        }
        return 1;
    }
    if (ti.type_kind == TYPE_F64) {
        if (ginfo.init_kind == GLOBAL_INIT_VALUE && ginfo.init_value == 0) { emit("0.0"); }
        else { emit("0.0"); }
        return 1;
    }
    if (ginfo.init_kind == GLOBAL_INIT_VALUE) {
        if (ti.type_kind == TYPE_BOOL) {
            if (ginfo.init_value != 0) { emit("1"); } else { emit("0"); }
            return 1;
        }
        print_u64(ginfo.init_value);
        return 1;
    }
    if (ginfo.init_expr != 0 &&
        ti.type_kind != TYPE_ARRAY &&
        ti.type_kind != TYPE_SLICE &&
        ti.type_kind != TYPE_STRUCT) {
        var const_v: u64 = 0;
        if (llvm_contract_global_const_u64_expr_impl(program, (*AstNode)ginfo.init_expr, &const_v) != 0) {
            if (ti.type_kind == TYPE_BOOL) {
                if (const_v != 0) { emit("1"); } else { emit("0"); }
                return 1;
            }
            if (ti.type_kind == TYPE_F64) {
                if (const_v == 0) { emit("0.0"); }
                else {
                    print_u64(const_v);
                    emit(".0");
                }
                return 1;
            }
            print_u64(const_v);
            return 1;
        }
    }
    if (ti.type_kind == TYPE_BOOL) { emit("0"); }
    else { emit("0"); }
    return 1;
}

func llvm_contract_ll_emit_global_defs_impl(program: *AstProgram) -> u64 {
    if (program == 0 || program.globals_vec == 0) { return 0; }
    var n: u64 = program.globals_vec.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var ginfo: *GlobalInfo = program.globals_vec.get(i);
        if (ginfo == 0 || u8_slice_ptr(ginfo.name) == 0 || u8_slice_len(ginfo.name) == 0) { continue; }
        if (llvm_contract_global_type_supported_impl(ginfo) == 0) { continue; }
        set_current_module_for_global(ginfo.name);
        llvm_contract_emit_global_symbol_name_impl(ginfo.name);
        emit(" = global ");
        llvm_contract_emit_global_type_impl(ginfo);
        emit(" ");
        llvm_contract_emit_global_init_impl(program, ginfo);
        emit("\n");
    }
    return 1;
}

func llvm_contract_struct_size_impl(program: *AstProgram, name: []u8) -> u64 {
    if (name.ptr == 0 || name.len == 0) { return 8; }
    var sd: *AstStructDef = llvm_contract_program_find_struct_impl(program, slice(name.ptr, name.len));
    if (sd == 0 || sd.fields_vec == 0) {
        return layout_type_sizeof(TYPE_STRUCT, 0, slice(name.ptr, name.len));
    }
    var max_end: u64 = 0;
    var sum_size: u64 = 0;
    var nf: u64 = sd.fields_vec.len();
    for (var fi: u64 = 0; fi < nf; fi = fi + 1) {
        var field: *FieldDesc = sd.fields_vec.get(fi);
        if (field == 0) { continue; }
        var fsz: u64 = layout_field_sizeof(field);
        sum_size = sum_size + fsz;
        var fend: u64 = field.offset + fsz;
        if (fend > max_end) { max_end = fend; }
    }
    if (max_end == 0 && sum_size == 0) { return 8; }
    if (sum_size > max_end) { return sum_size; }
    return max_end;
}

func llvm_contract_adapter_find_entry_atom_impl(adapter: *AnnLLVMContractAdapter) -> *AnnLLVMContractAtom {
    if (adapter == 0 || adapter.atoms == 0) { return 0; }
    var n: u64 = adapter.atoms.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var atom: *AnnLLVMContractAtom = adapter.atoms.get(i);
        if (atom == 0 || u8_slice_ptr(atom.metadata_key) == 0) { continue; }
        if (u8_slice_len(atom.metadata_key) == 18 &&
            str_eq(atom.metadata_key, slice("bpp.contract.entry", str_len("bpp.contract.entry"))) != 0) {
            return atom;
        }
    }
    return 0;
}

func llvm_contract_program_has_main_entry_fallback_impl(program: *AstProgram) -> u64 {
    return ((u64)llvm_contract_program_find_func_impl(program, slice("main", 4)) != 0);
}

func llvm_contract_find_main_sketch_impl(module: *LLVMSSAModuleSketch) -> *LLVMSSAFuncSketch {
    if (module == 0 || module.funcs == 0) { return 0; }
    var exact: *LLVMSSAFuncSketch = llvm_ssa_find_func_sketch(module, slice("main", 4));
    if (exact != 0) { return exact; }
    var suffix_ptr: u64 = "__main";
    var suffix_len: u64 = 6;
    var n: u64 = module.funcs.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var sketch: *LLVMSSAFuncSketch = module.funcs.get(i);
        if (sketch == 0 || u8_slice_ptr(sketch.name) == 0 || u8_slice_len(sketch.name) < suffix_len) { continue; }
        var off: u64 = u8_slice_len(sketch.name) - suffix_len;
        if (str_eq(slice(u8_slice_ptr(sketch.name) + off, suffix_len), slice(suffix_ptr, suffix_len)) != 0) { return sketch; }
    }
    return 0;
}

func llvm_contract_name_module_prefix_len_impl(name: []u8) -> u64 {
    if (name.ptr == 0 || name.len < 2) { return 0; }
    var i: u64 = name.len;
    while (i > 1) {
        i = i - 1;
        if (*((*u8)(name.ptr + i - 1)) == '_' && *((*u8)(name.ptr + i)) == '_') {
            return i - 1;
        }
    }
    return 0;
}

func llvm_contract_same_module_prefix_impl(lhs: []u8, rhs: []u8) -> u64 {
    var lhs_prefix: u64 = llvm_contract_name_module_prefix_len_impl(slice(lhs.ptr, lhs.len));
    var rhs_prefix: u64 = llvm_contract_name_module_prefix_len_impl(slice(rhs.ptr, rhs.len));
    if (lhs_prefix == 0 || rhs_prefix == 0 || lhs_prefix != rhs_prefix) { return 0; }
    return str_eq(slice(lhs.ptr, lhs_prefix), slice(rhs.ptr, rhs_prefix));
}

func llvm_contract_sketch_has_direct_call_to_name_impl(sketch: *LLVMSSAFuncSketch, target: []u8) -> u64 {
    if (sketch == 0 || sketch.blocks == 0 || target.ptr == 0 || target.len == 0) { return 0; }
    var nb: u64 = sketch.blocks.len();
    for (var bi: u64 = 0; bi < nb; bi = bi + 1) {
        var block: *LLVMSSABlockSketch = sketch.blocks.get(bi);
        if (block == 0 || block.insts == 0) { continue; }
        var ni: u64 = block.insts.len();
        for (var ii: u64 = 0; ii < ni; ii = ii + 1) {
            var inst: *LLVMSSAInstSketch = block.insts.get(ii);
            if (inst == 0 || inst.op != SSA_OP_CALL || inst.has_src1 == 0 || inst.src1_is_const == 0) { continue; }
            var info: *SSACallInfo = (*SSACallInfo)inst.src1_value;
            if (info == 0 || u8_slice_ptr(info.name) == 0 || u8_slice_len(info.name) != target.len) { continue; }
            if (str_eq(info.name, slice(target.ptr, target.len)) != 0) { return 1; }
        }
    }
    return 0;
}

func llvm_contract_sketch_has_slice_call_to_name_impl(sketch: *LLVMSSAFuncSketch, target: []u8) -> u64 {
    if (sketch == 0 || sketch.blocks == 0 || target.ptr == 0 || target.len == 0) { return 0; }
    var nb: u64 = sketch.blocks.len();
    for (var bi: u64 = 0; bi < nb; bi = bi + 1) {
        var block: *LLVMSSABlockSketch = sketch.blocks.get(bi);
        if (block == 0 || block.insts == 0) { continue; }
        var ni: u64 = block.insts.len();
        for (var ii: u64 = 0; ii < ni; ii = ii + 1) {
            var inst: *LLVMSSAInstSketch = block.insts.get(ii);
            if (inst == 0 || inst.op != SSA_OP_CALL_SLICE_STORE || inst.has_src1 == 0 || inst.src1_is_const == 0) { continue; }
            var info: *SSACallSliceStoreInfo = (*SSACallSliceStoreInfo)inst.src1_value;
            if (info == 0 || u8_slice_ptr(info.name) == 0 || u8_slice_len(info.name) != target.len) { continue; }
            if (str_eq(info.name, slice(target.ptr, target.len)) != 0) { return 1; }
        }
    }
    return 0;
}

func llvm_contract_sketch_has_lea_func_to_name_impl(sketch: *LLVMSSAFuncSketch, target: []u8) -> u64 {
    if (sketch == 0 || sketch.blocks == 0 || target.ptr == 0 || target.len == 0) { return 0; }
    var nb: u64 = sketch.blocks.len();
    for (var bi: u64 = 0; bi < nb; bi = bi + 1) {
        var block: *LLVMSSABlockSketch = sketch.blocks.get(bi);
        if (block == 0 || block.insts == 0) { continue; }
        var ni: u64 = block.insts.len();
        for (var ii: u64 = 0; ii < ni; ii = ii + 1) {
            var inst: *LLVMSSAInstSketch = block.insts.get(ii);
            if (inst == 0 || inst.op != SSA_OP_LEA_FUNC || inst.has_src1 == 0 || inst.src1_is_const == 0) { continue; }
            var info: *PtrLen = (*PtrLen)inst.src1_value;
            if (info == 0 || info.ptr == 0 || info.len != target.len) { continue; }
            if (str_eq(slice(info.ptr, info.len), slice(target.ptr, target.len)) != 0) { return 1; }
        }
    }
    return 0;
}

func llvm_contract_seen_name_impl(seen: *Vec<*PtrLen>, name: []u8) -> u64 {
    if (seen == 0 || name.ptr == 0 || name.len == 0) { return 0; }
    var n: u64 = seen.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var item: *PtrLen = seen.get(i);
        if (item == 0 || item.ptr == 0 || item.len != name.len) { continue; }
        if (str_eq(slice(item.ptr, item.len), slice(name.ptr, name.len)) != 0) { return 1; }
    }
    return 0;
}

func llvm_contract_mark_seen_name_impl(seen: *Vec<*PtrLen>, name: []u8) -> u64 {
    if (seen == 0 || name.ptr == 0 || name.len == 0) { return 0; }
    if (llvm_contract_seen_name_impl(seen, slice(name.ptr, name.len)) != 0) { return 0; }
    seen.push(new PtrLen{name.ptr, name.len});
    return 1;
}

func llvm_contract_func_reachable_from_seen_impl(module: *LLVMSSAModuleSketch, root: []u8, target: []u8, depth: u64, seen: *Vec<*PtrLen>) -> u64 {
    if (module == 0 || module.funcs == 0 || root.ptr == 0 || root.len == 0 || target.ptr == 0 || target.len == 0) { return 0; }
    if (root.len == target.len && str_eq(slice(root.ptr, root.len), slice(target.ptr, target.len)) != 0) { return 1; }
    if (depth > module.funcs.len() + 4) { return 0; }
    if (llvm_contract_seen_name_impl(seen, slice(root.ptr, root.len)) != 0) { return 0; }
    llvm_contract_mark_seen_name_impl(seen, slice(root.ptr, root.len));
    var root_sketch: *LLVMSSAFuncSketch = llvm_ssa_find_func_sketch(module, slice(root.ptr, root.len));
    if (root_sketch == 0 || root_sketch.blocks == 0) { return 0; }
    if (llvm_contract_sketch_has_direct_call_to_name_impl(root_sketch, slice(target.ptr, target.len)) != 0) { return 1; }
    if (llvm_contract_sketch_has_slice_call_to_name_impl(root_sketch, slice(target.ptr, target.len)) != 0) { return 1; }
    if (llvm_contract_sketch_has_lea_func_to_name_impl(root_sketch, slice(target.ptr, target.len)) != 0) { return 1; }
    var n: u64 = module.funcs.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var callee: *LLVMSSAFuncSketch = module.funcs.get(i);
        if (callee == 0 || u8_slice_ptr(callee.name) == 0 || u8_slice_len(callee.name) == 0) { continue; }
        if (llvm_contract_sketch_has_direct_call_to_name_impl(root_sketch, callee.name) == 0 &&
            llvm_contract_sketch_has_slice_call_to_name_impl(root_sketch, callee.name) == 0 &&
            llvm_contract_sketch_has_lea_func_to_name_impl(root_sketch, callee.name) == 0) { continue; }
        if (llvm_contract_func_reachable_from_seen_impl(module, callee.name, slice(target.ptr, target.len), depth + 1, seen) != 0) {
            return 1;
        }
    }
    return 0;
}

func llvm_contract_func_reachable_from_impl(module: *LLVMSSAModuleSketch, root: []u8, target: []u8, depth: u64) -> u64 {
    var cap: u64 = 16;
    if (module != 0 && module.funcs != 0) { cap = module.funcs.len() + 8; }
    var seen: *Vec<*PtrLen> = new Vec<*PtrLen>{heap_alloc((cap) * sizeof(*PtrLen)), 0, cap};
    return llvm_contract_func_reachable_from_seen_impl(module, slice(root.ptr, root.len), slice(target.ptr, target.len), depth, seen);
}

func llvm_contract_mark_reachable_from_impl(module: *LLVMSSAModuleSketch, root: []u8, seen: *Vec<*PtrLen>) -> u64 {
    if (module == 0 || module.funcs == 0 || root.ptr == 0 || root.len == 0 || seen == 0) { return 0; }
    if (llvm_contract_seen_name_impl(seen, slice(root.ptr, root.len)) != 0) { return 0; }

    var root_sketch: *LLVMSSAFuncSketch = llvm_ssa_find_func_sketch(module, slice(root.ptr, root.len));
    if (root_sketch == 0) { return 0; }
    llvm_contract_mark_seen_name_impl(seen, slice(root.ptr, root.len));
    if (root_sketch.blocks == 0) { return 1; }

    var nb: u64 = root_sketch.blocks.len();
    for (var bi: u64 = 0; bi < nb; bi = bi + 1) {
        var block: *LLVMSSABlockSketch = root_sketch.blocks.get(bi);
        if (block == 0 || block.insts == 0) { continue; }
        var ni: u64 = block.insts.len();
        for (var ii: u64 = 0; ii < ni; ii = ii + 1) {
            var inst: *LLVMSSAInstSketch = block.insts.get(ii);
            if (inst == 0 || inst.has_src1 == 0 || inst.src1_is_const == 0) { continue; }

            if (inst.op == SSA_OP_CALL) {
                var call_info: *SSACallInfo = (*SSACallInfo)inst.src1_value;
                if (call_info != 0 && u8_slice_ptr(call_info.name) != 0 && u8_slice_len(call_info.name) != 0) {
                    llvm_contract_mark_reachable_from_impl(module, call_info.name, seen);
                }
            } else if (inst.op == SSA_OP_CALL_SLICE_STORE) {
                var slice_info: *SSACallSliceStoreInfo = (*SSACallSliceStoreInfo)inst.src1_value;
                if (slice_info != 0 && slice_info.is_ptr == 0 && u8_slice_ptr(slice_info.name) != 0 && u8_slice_len(slice_info.name) != 0) {
                    llvm_contract_mark_reachable_from_impl(module, slice_info.name, seen);
                }
            } else if (inst.op == SSA_OP_LEA_FUNC) {
                var fn_info: *PtrLen = (*PtrLen)inst.src1_value;
                if (fn_info != 0 && fn_info.ptr != 0 && fn_info.len != 0) {
                    llvm_contract_mark_reachable_from_impl(module, slice(fn_info.ptr, fn_info.len), seen);
                }
            }
        }
    }
    return 1;
}

func llvm_contract_mark_all_func_names_impl(module: *LLVMSSAModuleSketch, seen: *Vec<*PtrLen>) -> u64 {
    if (module == 0 || module.funcs == 0 || seen == 0) { return 0; }
    var n: u64 = module.funcs.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var sketch: *LLVMSSAFuncSketch = module.funcs.get(i);
        if (sketch == 0 || u8_slice_ptr(sketch.name) == 0 || u8_slice_len(sketch.name) == 0) { continue; }
        llvm_contract_mark_seen_name_impl(seen, sketch.name);
    }
    return 1;
}

func llvm_contract_name_matches_entry_module_prefix_impl(entry_atom: *AnnLLVMContractAtom, name: []u8) -> u64 {
    if (entry_atom == 0 || name.ptr == 0 || name.len == 0) { return 0; }
    if (u8_slice_ptr(entry_atom.module) == 0 || u8_slice_len(entry_atom.module) == 0) { return 0; }
    var prefix_len: u64 = u8_slice_len(entry_atom.module) + 3;
    var tmp: [512]u8;
    if (prefix_len > 512) { return 0; }
    tmp[0] = '_';
    for (var pi: u64 = 0; pi < u8_slice_len(entry_atom.module); pi = pi + 1) {
        tmp[1 + pi] = *((*u8)(u8_slice_ptr(entry_atom.module) + pi));
    }
    tmp[1 + u8_slice_len(entry_atom.module)] = '_';
    tmp[2 + u8_slice_len(entry_atom.module)] = '_';
    if (name.len >= prefix_len && str_eq(slice(name.ptr, prefix_len), slice(&tmp[0], prefix_len)) != 0) {
        return 1;
    }
    return 0;
}

func llvm_contract_mark_entry_module_prefix_impl(module: *LLVMSSAModuleSketch, entry_atom: *AnnLLVMContractAtom, seen: *Vec<*PtrLen>) -> u64 {
    if (module == 0 || module.funcs == 0 || entry_atom == 0 || seen == 0) { return 0; }
    var n: u64 = module.funcs.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var sketch: *LLVMSSAFuncSketch = module.funcs.get(i);
        if (sketch == 0 || u8_slice_ptr(sketch.name) == 0 || u8_slice_len(sketch.name) == 0) { continue; }
        if (llvm_contract_name_matches_entry_module_prefix_impl(entry_atom, sketch.name) != 0) {
            llvm_contract_mark_seen_name_impl(seen, sketch.name);
        }
    }
    return 1;
}

func llvm_contract_mark_vtable_reachable_impl(module: *LLVMSSAModuleSketch, seen: *Vec<*PtrLen>) -> u64 {
    if (module == 0 || module.source_program == 0 || module.source_program.globals_vec == 0 || seen == 0) { return 0; }
    var gn: u64 = module.source_program.globals_vec.len();
    for (var gi: u64 = 0; gi < gn; gi = gi + 1) {
        var ginfo: *GlobalInfo = module.source_program.globals_vec.get(gi);
        if (llvm_contract_global_is_vtable_impl(ginfo) == 0) { continue; }
        if (ginfo.init_expr == 0 || ast_kind((*AstNode)ginfo.init_expr) != AST_STRUCT_LITERAL) { continue; }
        var lit: *AstStructLiteral = (*AstStructLiteral)((*AstNode)ginfo.init_expr);
        if (lit.values_vec == 0) { continue; }
        var vn: u64 = lit.values_vec.len();
        for (var vi: u64 = 0; vi < vn; vi = vi + 1) {
            var root_ptr: u64 = 0;
            var root_len: u64 = 0;
            if (llvm_contract_global_symbol_from_expr_impl(lit.values_vec.get(vi), &root_ptr, &root_len) != 1) { continue; }
            llvm_contract_mark_reachable_from_impl(module, slice(root_ptr, root_len), seen);
        }
    }
    return 1;
}

func llvm_contract_mark_annotation_generated_reachable_impl(module: *LLVMSSAModuleSketch, seen: *Vec<*PtrLen>) -> u64 {
    if (module == 0 || module.funcs == 0 || seen == 0) { return 0; }
    var n: u64 = module.funcs.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var sketch: *LLVMSSAFuncSketch = module.funcs.get(i);
        if (sketch == 0 || u8_slice_ptr(sketch.name) == 0 || u8_slice_len(sketch.name) == 0) { continue; }
        if (llvm_contract_name_has_prefix_impl(sketch.name, slice("__ann_", 6)) == 0) { continue; }
        llvm_contract_mark_reachable_from_impl(module, sketch.name, seen);
    }
    return 1;
}

func llvm_contract_collect_emit_names_impl(module: *LLVMSSAModuleSketch, adapter: *AnnLLVMContractAdapter) -> *Vec<*PtrLen> {
    var cap: u64 = 16;
    if (module != 0 && module.funcs != 0) { cap = module.funcs.len() + 8; }
    var seen: *Vec<*PtrLen> = new Vec<*PtrLen>{heap_alloc((cap) * sizeof(*PtrLen)), 0, cap};
    if (module == 0 || module.funcs == 0) { return seen; }

    if (llvm_contract_program_find_func_impl(module.source_program, slice("__global_init", 13)) != 0) {
        llvm_contract_mark_reachable_from_impl(module, slice("__global_init", 13), seen);
    }
    llvm_contract_mark_vtable_reachable_impl(module, seen);
    llvm_contract_mark_annotation_generated_reachable_impl(module, seen);

    var entry_atom: *AnnLLVMContractAtom = llvm_contract_adapter_find_entry_atom_impl(adapter);
    if (entry_atom != 0 && u8_slice_ptr(entry_atom.owner) != 0 && u8_slice_len(entry_atom.owner) != 0) {
        llvm_contract_mark_entry_module_prefix_impl(module, entry_atom, seen);
        llvm_contract_mark_reachable_from_impl(module, entry_atom.owner, seen);
        return seen;
    }

    var main_sketch: *LLVMSSAFuncSketch = llvm_contract_find_main_sketch_impl(module);
    if (main_sketch == 0) {
        if (llvm_contract_program_has_main_entry_fallback_impl(module.source_program) == 0) {
            llvm_contract_mark_all_func_names_impl(module, seen);
        }
        return seen;
    }
    llvm_contract_mark_reachable_from_impl(module, main_sketch.name, seen);
    return seen;
}

func llvm_contract_func_reachable_from_vtable_globals_impl(module: *LLVMSSAModuleSketch, target: []u8) -> u64 {
    if (module == 0 || module.source_program == 0 || module.source_program.globals_vec == 0 ||
        target.ptr == 0 || target.len == 0) {
        return 0;
    }
    var gn: u64 = module.source_program.globals_vec.len();
    for (var gi: u64 = 0; gi < gn; gi = gi + 1) {
        var ginfo: *GlobalInfo = module.source_program.globals_vec.get(gi);
        if (llvm_contract_global_is_vtable_impl(ginfo) == 0) { continue; }
        if (ginfo.init_expr == 0 || ast_kind((*AstNode)ginfo.init_expr) != AST_STRUCT_LITERAL) { continue; }
        var lit: *AstStructLiteral = (*AstStructLiteral)((*AstNode)ginfo.init_expr);
        if (lit.values_vec == 0) { continue; }
        var vn: u64 = lit.values_vec.len();
        for (var vi: u64 = 0; vi < vn; vi = vi + 1) {
            var root_ptr: u64 = 0;
            var root_len: u64 = 0;
            if (llvm_contract_global_symbol_from_expr_impl(lit.values_vec.get(vi), &root_ptr, &root_len) != 1) { continue; }
            if (llvm_contract_func_reachable_from_impl(module, slice(root_ptr, root_len), slice(target.ptr, target.len), 0) != 0) {
                return 1;
            }
        }
    }
    return 0;
}

func llvm_contract_should_emit_func_cached_impl(module: *LLVMSSAModuleSketch, adapter: *AnnLLVMContractAdapter, sketch: *LLVMSSAFuncSketch, emit_names: *Vec<*PtrLen>) -> u64 {
    if (emit_names == 0) { return llvm_contract_should_emit_func_impl(module, adapter, sketch); }
    if (sketch == 0 || u8_slice_ptr(sketch.name) == 0 || u8_slice_len(sketch.name) == 0) { return 0; }
    return llvm_contract_seen_name_impl(emit_names, sketch.name);
}

func llvm_contract_should_emit_func_impl(module: *LLVMSSAModuleSketch, adapter: *AnnLLVMContractAdapter, sketch: *LLVMSSAFuncSketch) -> u64 {
    if (module == 0 || sketch == 0 || u8_slice_ptr(sketch.name) == 0 || u8_slice_len(sketch.name) == 0) { return 0; }
    if (u8_slice_len(sketch.name) == 13 &&
        str_eq(sketch.name, slice("__global_init", str_len("__global_init"))) != 0) {
        var maybe_global_init: *AstFunc = llvm_contract_program_find_func_impl(module.source_program, slice("__global_init", 13));
        if (maybe_global_init != 0) {
            return 1;
        }
    }
    if (llvm_contract_func_reachable_from_vtable_globals_impl(module, sketch.name) != 0) {
        return 1;
    }
    var entry_atom: *AnnLLVMContractAtom = llvm_contract_adapter_find_entry_atom_impl(adapter);
    if (entry_atom == 0 || u8_slice_ptr(entry_atom.owner) == 0 || u8_slice_len(entry_atom.owner) == 0) {
        var main_sketch: *LLVMSSAFuncSketch = llvm_contract_find_main_sketch_impl(module);
        if (main_sketch == 0) {
            if (llvm_contract_program_has_main_entry_fallback_impl(module.source_program) == 0) { return 1; }
            return 0;
        }
        if (u8_slice_len(sketch.name) == u8_slice_len(main_sketch.name) &&
            str_eq(sketch.name, main_sketch.name) != 0) {
            return 1;
        }
        return llvm_contract_func_reachable_from_impl(module, main_sketch.name, sketch.name, 0);
    }
    if (u8_slice_ptr(entry_atom.module) != 0 && u8_slice_len(entry_atom.module) != 0) {
        var prefix_len: u64 = u8_slice_len(entry_atom.module) + 3;
        var tmp: [512]u8;
        if (prefix_len <= 512) {
            tmp[0] = '_';
            for (var pi: u64 = 0; pi < u8_slice_len(entry_atom.module); pi = pi + 1) {
                tmp[1 + pi] = *((*u8)(u8_slice_ptr(entry_atom.module) + pi));
            }
            tmp[1 + u8_slice_len(entry_atom.module)] = '_';
            tmp[2 + u8_slice_len(entry_atom.module)] = '_';
            if (u8_slice_len(sketch.name) >= prefix_len && str_eq(slice(u8_slice_ptr(sketch.name), prefix_len), slice(&tmp[0], prefix_len)) != 0) {
                return 1;
            }
        }
    }
    return llvm_contract_func_reachable_from_impl(module, entry_atom.owner, sketch.name, 0);
}

func llvm_contract_emit_type_impl(type_kind: u64, ptr_depth: u64) -> u64 {
    if (ptr_depth > 0) {
        emit("ptr");
        return 1;
    }
    match (type_kind) {
        case TYPE_VOID:
            emit("void");
            return 1;
        case TYPE_BOOL:
            emit("i1");
            return 1;
        case TYPE_U8:
        case TYPE_I8:
            emit("i8");
            return 1;
        case TYPE_U16:
        case TYPE_I16:
            emit("i16");
            return 1;
        case TYPE_U32:
        case TYPE_I32:
            emit("i32");
            return 1;
        case TYPE_U64:
        case TYPE_I64:
        case TYPE_FUNC:
            emit("i64");
            return 1;
        case TYPE_F64:
            emit("double");
            return 1;
    }
    return 0;
}

const LLVM_ABI_ROLE_SRET = 1;
const LLVM_ABI_ROLE_SCALAR = 2;
const LLVM_ABI_ROLE_SLICE_PTR = 3;
const LLVM_ABI_ROLE_SLICE_LEN = 4;
const LLVM_ABI_ROLE_SMALL_STRUCT_LO = 5;
const LLVM_ABI_ROLE_SMALL_STRUCT_HI = 6;
const LLVM_ABI_ROLE_LARGE_STRUCT_PTR = 7;
const LLVM_ABI_ROLE_ARRAY_PTR = 8;

struct LLVMABIParamPartInfo {
    public found: u64;
    public abi_index: u64;
    public param_index: u64;
    public role: u64;
    public type_kind: u64;
    public ptr_depth: u64;
    public struct_size: u64;
}

impl LLVMABIParamPartInfo {
    public constructor() {
        self.found = 0;
        self.abi_index = 0;
        self.param_index = 0;
        self.role = 0;
        self.type_kind = 0;
        self.ptr_depth = 0;
        self.struct_size = 0;
    }
}

func llvm_contract_param_storage_size_impl(param: *Param) -> u64 {
    return llvm_contract_param_storage_size_from_program_impl(0, param);
}

func llvm_contract_param_storage_size_from_program_impl(program: *AstProgram, param: *Param) -> u64 {
    if (param == 0) { return 0; }
    if (param.type_kind == TYPE_STRUCT && param.ptr_depth == 0) {
        var sz: u64 = llvm_contract_struct_size_impl(program, param.struct_name);
        return sz;
    }
    if (param.type_kind == TYPE_ARRAY && param.ptr_depth == 0) {
        var elem_sz: u64 = layout_type_sizeof(param.elem_type_kind, param.elem_ptr_depth, param.struct_name);
        if (elem_sz == 0 && param.elem_type_kind == TYPE_STRUCT) {
            elem_sz = llvm_contract_struct_size_impl(program, param.struct_name);
        }
        if (elem_sz == 0) { elem_sz = 8; }
        if (param.array_len == 0) { return elem_sz; }
        return elem_sz * param.array_len;
    }
    if (param.type_kind == TYPE_SLICE && param.ptr_depth == 0) { return 16; }
    var scalar_size: u64 = layout_type_sizeof(param.type_kind, param.ptr_depth, param.struct_name);
    if (scalar_size == 0) { scalar_size = 8; }
    return scalar_size;
}

func llvm_contract_fn_struct_ret_size_impl(fn: *AstFunc) -> u64 {
    return llvm_contract_fn_struct_ret_size_from_program_impl(0, fn);
}

func llvm_contract_fn_struct_ret_size_from_program_impl(program: *AstProgram, fn: *AstFunc) -> u64 {
    if (fn == 0 || fn.ret_type != TYPE_STRUCT || fn.ret_ptr_depth != 0) { return 0; }
    return llvm_contract_struct_size_impl(program, fn.ret_struct_name);
}

func llvm_contract_fn_has_sret_param_impl(fn: *AstFunc) -> u64 {
    return llvm_contract_fn_has_sret_param_from_program_impl(0, fn);
}

func llvm_contract_fn_has_sret_param_from_program_impl(program: *AstProgram, fn: *AstFunc) -> u64 {
    return (llvm_contract_fn_struct_ret_size_from_program_impl(program, fn) > 16);
}

func llvm_contract_fn_abi_param_count_impl(fn: *AstFunc) -> u64 {
    return llvm_contract_fn_abi_param_count_from_program_impl(0, fn);
}

func llvm_contract_fn_abi_param_count_from_program_impl(program: *AstProgram, fn: *AstFunc) -> u64 {
    if (fn == 0) { return 0; }
    var count: u64 = 0;
    if (llvm_contract_fn_has_sret_param_from_program_impl(program, fn) != 0) { count = 1; }
    if (fn.params_vec == 0) { return count; }
    var n: u64 = fn.params_vec.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var param: *Param = fn.params_vec.get(i);
        if (param == 0) { continue; }
        if (param.type_kind == TYPE_STRUCT && param.ptr_depth == 0) {
            var sz: u64 = llvm_contract_param_storage_size_from_program_impl(program, param);
            if (sz <= 8) { count = count + 1; }
            else if (sz <= 16) { count = count + 2; }
            else { count = count + 1; }
            continue;
        }
        if (param.type_kind == TYPE_SLICE && param.ptr_depth == 0) {
            count = count + 2;
            continue;
        }
        count = count + 1;
    }
    return count;
}

func llvm_contract_fn_abi_part_info_impl(fn: *AstFunc, target_idx: u64) -> LLVMABIParamPartInfo {
    return llvm_contract_fn_abi_part_info_from_program_impl(0, fn, target_idx);
}

func llvm_contract_fn_abi_part_info_from_program_impl(program: *AstProgram, fn: *AstFunc, target_idx: u64) -> LLVMABIParamPartInfo {
    var out: LLVMABIParamPartInfo;
    if (fn == 0) { return out; }
    var abi_idx: u64 = 0;
    if (llvm_contract_fn_has_sret_param_from_program_impl(program, fn) != 0) {
        if (target_idx == 0) {
            out.found = 1;
            out.abi_index = 0;
            out.param_index = 18446744073709551615;
            out.role = LLVM_ABI_ROLE_SRET;
            out.type_kind = TYPE_U64;
            out.ptr_depth = 1;
            out.struct_size = llvm_contract_fn_struct_ret_size_from_program_impl(program, fn);
            return out;
        }
        abi_idx = 1;
    }
    if (fn.params_vec == 0) { return out; }
    var n: u64 = fn.params_vec.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var param: *Param = fn.params_vec.get(i);
        if (param == 0) { continue; }
        if (param.type_kind == TYPE_STRUCT && param.ptr_depth == 0) {
            var sz: u64 = llvm_contract_param_storage_size_from_program_impl(program, param);
            if (sz <= 8) {
                if (abi_idx == target_idx) {
                    out.found = 1; out.abi_index = abi_idx; out.param_index = i;
                    out.role = LLVM_ABI_ROLE_SMALL_STRUCT_LO; out.type_kind = TYPE_U64; out.ptr_depth = 0; out.struct_size = sz;
                    return out;
                }
                abi_idx = abi_idx + 1;
            } else if (sz <= 16) {
                if (abi_idx == target_idx) {
                    out.found = 1; out.abi_index = abi_idx; out.param_index = i;
                    out.role = LLVM_ABI_ROLE_SMALL_STRUCT_LO; out.type_kind = TYPE_U64; out.ptr_depth = 0; out.struct_size = sz;
                    return out;
                }
                abi_idx = abi_idx + 1;
                if (abi_idx == target_idx) {
                    out.found = 1; out.abi_index = abi_idx; out.param_index = i;
                    out.role = LLVM_ABI_ROLE_SMALL_STRUCT_HI; out.type_kind = TYPE_U64; out.ptr_depth = 0; out.struct_size = sz;
                    return out;
                }
                abi_idx = abi_idx + 1;
            } else {
                if (abi_idx == target_idx) {
                    out.found = 1; out.abi_index = abi_idx; out.param_index = i;
                    out.role = LLVM_ABI_ROLE_LARGE_STRUCT_PTR; out.type_kind = TYPE_U64; out.ptr_depth = 1; out.struct_size = sz;
                    return out;
                }
                abi_idx = abi_idx + 1;
            }
            continue;
        }
        if (param.type_kind == TYPE_ARRAY && param.ptr_depth == 0) {
            if (abi_idx == target_idx) {
                out.found = 1; out.abi_index = abi_idx; out.param_index = i;
                out.role = LLVM_ABI_ROLE_ARRAY_PTR; out.type_kind = TYPE_U64; out.ptr_depth = 1; out.struct_size = llvm_contract_param_storage_size_from_program_impl(program, param);
                return out;
            }
            abi_idx = abi_idx + 1;
            continue;
        }
        if (param.type_kind == TYPE_SLICE && param.ptr_depth == 0) {
            if (abi_idx == target_idx) {
                out.found = 1; out.abi_index = abi_idx; out.param_index = i;
                out.role = LLVM_ABI_ROLE_SLICE_PTR; out.type_kind = TYPE_U64; out.ptr_depth = 1; out.struct_size = 16;
                return out;
            }
            abi_idx = abi_idx + 1;
            if (abi_idx == target_idx) {
                out.found = 1; out.abi_index = abi_idx; out.param_index = i;
                out.role = LLVM_ABI_ROLE_SLICE_LEN; out.type_kind = TYPE_U64; out.ptr_depth = 0; out.struct_size = 16;
                return out;
            }
            abi_idx = abi_idx + 1;
            continue;
        }
        if (abi_idx == target_idx) {
            out.found = 1; out.abi_index = abi_idx; out.param_index = i;
            out.role = LLVM_ABI_ROLE_SCALAR; out.type_kind = param.type_kind; out.ptr_depth = param.ptr_depth; out.struct_size = llvm_contract_param_storage_size_from_program_impl(program, param);
            return out;
        }
        abi_idx = abi_idx + 1;
    }
    return out;
}

func llvm_contract_emit_abi_part_type_impl(part: LLVMABIParamPartInfo) -> u64 {
    if (part.role == LLVM_ABI_ROLE_SRET || part.role == LLVM_ABI_ROLE_LARGE_STRUCT_PTR ||
        part.role == LLVM_ABI_ROLE_ARRAY_PTR || part.role == LLVM_ABI_ROLE_SLICE_PTR) {
        emit("ptr");
        return 1;
    }
    if (part.role == LLVM_ABI_ROLE_SMALL_STRUCT_LO || part.role == LLVM_ABI_ROLE_SMALL_STRUCT_HI ||
        part.role == LLVM_ABI_ROLE_SLICE_LEN) {
        emit("i64");
        return 1;
    }
    return llvm_contract_emit_type_impl(part.type_kind, part.ptr_depth);
}

func llvm_contract_emit_fn_ret_type_impl(fn: *AstFunc) -> u64 {
    return llvm_contract_emit_fn_ret_type_from_program_impl(0, fn);
}

func llvm_contract_emit_fn_ret_type_from_program_impl(program: *AstProgram, fn: *AstFunc) -> u64 {
    if (fn == 0) { emit("void"); return 0; }
    if (fn.ret_ptr_depth > 0) { emit("ptr"); return 1; }
    if (fn.ret_type == TYPE_SLICE) {
        emit("{ ptr, i64 }");
        return 1;
    }
    if (fn.ret_type == TYPE_STRUCT) {
        var struct_size: u64 = llvm_contract_fn_struct_ret_size_from_program_impl(program, fn);
        if (struct_size == 0) { emit("void"); return 0; }
        if (struct_size <= 8) {
            emit("i64");
            return 1;
        }
        if (struct_size <= 16) {
            emit("{ i64, i64 }");
            return 1;
        }
        emit("void");
        return 1;
    }
    return llvm_contract_emit_type_impl(fn.ret_type, fn.ret_ptr_depth);
}

func llvm_contract_emit_ret_type_from_meta_impl(ret_type: u64, ret_ptr_depth: u64, ret_struct_size: u64) -> u64 {
    if (ret_ptr_depth > 0) {
        emit("ptr");
        return 1;
    }
    if (ret_type == TYPE_SLICE) {
        emit("{ ptr, i64 }");
        return 1;
    }
    if (ret_type == TYPE_STRUCT) {
        if (ret_struct_size == 0) {
            emit("void");
            return 0;
        }
        if (ret_struct_size <= 8) {
            emit("i64");
            return 1;
        }
        if (ret_struct_size <= 16) {
            emit("{ i64, i64 }");
            return 1;
        }
        emit("void");
        return 1;
    }
    return llvm_contract_emit_type_impl(ret_type, ret_ptr_depth);
}

func llvm_contract_fn_param_from_abi_index_impl(fn: *AstFunc, abi_index: u64) -> *Param {
    return llvm_contract_fn_param_from_abi_index_from_program_impl(0, fn, abi_index);
}

func llvm_contract_fn_param_from_abi_index_from_program_impl(program: *AstProgram, fn: *AstFunc, abi_index: u64) -> *Param {
    var part: LLVMABIParamPartInfo = llvm_contract_fn_abi_part_info_from_program_impl(program, fn, abi_index);
    if (part.found == 0 || part.param_index == 18446744073709551615 || fn == 0 || fn.params_vec == 0) { return 0; }
    if (part.param_index >= fn.params_vec.len()) { return 0; }
    return fn.params_vec.get(part.param_index);
}

func llvm_contract_fn_first_abi_index_for_source_param_impl(program: *AstProgram, fn: *AstFunc, source_param_index: u64) -> u64 {
    if (fn == 0) { return source_param_index; }
    var n: u64 = llvm_contract_fn_abi_param_count_from_program_impl(program, fn);
    for (var i: u64 = 0; i < n; i = i + 1) {
        var part: LLVMABIParamPartInfo = llvm_contract_fn_abi_part_info_from_program_impl(program, fn, i);
        if (part.found != 0 && part.param_index == source_param_index) { return part.abi_index; }
    }
    return source_param_index;
}

func llvm_contract_fn_source_arg_count_without_sret_impl(program: *AstProgram, fn: *AstFunc) -> u64 {
    if (fn == 0 || fn.params_vec == 0) { return 0; }
    var count: u64 = 0;
    for (var i: u64 = 0; i < fn.params_vec.len(); i = i + 1) {
        var param: *Param = fn.params_vec.get(i);
        if (param == 0) { continue; }
        if (param.type_kind == TYPE_STRUCT && param.ptr_depth == 0) {
            var sz: u64 = llvm_contract_param_storage_size_from_program_impl(program, param);
            if (sz <= 8) { count = count + 1; }
            else if (sz <= 16) { count = count + 2; }
            else { count = count + 1; }
            continue;
        }
        if (param.type_kind == TYPE_SLICE && param.ptr_depth == 0) {
            count = count + 2;
            continue;
        }
        count = count + 1;
    }
    return count;
}

func llvm_contract_emit_i64_value_as_ptr_impl(sketch: *LLVMSSAFuncSketch, reg_id: u64, block_idx: u64, inst_idx: u64, name_prefix: []u8) -> u64 {
    var enc: u64 = llvm_contract_ll_find_reg_local_base_impl(sketch, reg_id, block_idx, inst_idx);
    if (enc != 0) {
        llvm_contract_ll_emit_local_slot_name_impl(1, enc);
        return 1;
    }
    emit("  %");
    if (name_prefix.ptr != 0 && name_prefix.len != 0) { io_write_out(name_prefix.ptr, name_prefix.len); }
    print_u64(block_idx);
    emit("_");
    print_u64(inst_idx);
    emit("_");
    print_u64(reg_id);
    emit(" = inttoptr i64 %r");
    print_u64(reg_id);
    emit(" to ptr\n");
    return 0;
}

func llvm_contract_emit_i32_main_bridge_impl(program: *AstProgram, adapter: *AnnLLVMContractAdapter) -> u64 {
    var entry_atom: *AnnLLVMContractAtom = llvm_contract_adapter_find_entry_atom_impl(adapter);
    if (entry_atom == 0 || u8_slice_ptr(entry_atom.owner) == 0 || u8_slice_len(entry_atom.owner) == 0) { return 0; }
    if (u8_slice_len(entry_atom.owner) == 4 && str_eq(entry_atom.owner, slice("main", str_len("main"))) != 0) {
        return 0;
    }
    var entry_fn: *AstFunc = llvm_contract_program_find_func_impl(program, entry_atom.owner);
    if (entry_fn == 0) { return 0; }
    emitln("define i32 @\"main\"() {");
    emitln("entry:");
    var global_init_fn: *AstFunc = llvm_contract_program_find_func_impl(program, slice("__global_init", 13));
    if (global_init_fn != 0) {
        emitln("  call void @\"__global_init\"()");
    }
    if (entry_fn.ret_type == TYPE_VOID && entry_fn.ret_ptr_depth == 0) {
        emit("  call void ");
        llvm_contract_emit_quoted_symbol_impl(entry_atom.owner);
        emitln("()");
        emitln("  ret i32 0");
        emitln("}");
        return 1;
    }
    emit("  %entry_ret = call ");
    if (llvm_contract_emit_type_impl(entry_fn.ret_type, entry_fn.ret_ptr_depth) == 0) { return 0; }
    emit(" ");
    llvm_contract_emit_quoted_symbol_impl(entry_atom.owner);
    emitln("()");
    if (entry_fn.ret_ptr_depth > 0) {
        emitln("  %entry_i32 = ptrtoint ptr %entry_ret to i32");
        emitln("  ret i32 %entry_i32");
        emitln("}");
        return 1;
    }
    if (entry_fn.ret_type == TYPE_BOOL) {
        emitln("  %entry_i32 = zext i1 %entry_ret to i32");
        emitln("  ret i32 %entry_i32");
        emitln("}");
        return 1;
    }
    if (entry_fn.ret_type == TYPE_U8) {
        emitln("  %entry_i32 = zext i8 %entry_ret to i32");
        emitln("  ret i32 %entry_i32");
        emitln("}");
        return 1;
    }
    if (entry_fn.ret_type == TYPE_U16) {
        emitln("  %entry_i32 = zext i16 %entry_ret to i32");
        emitln("  ret i32 %entry_i32");
        emitln("}");
        return 1;
    }
    if (entry_fn.ret_type == TYPE_I8) {
        emitln("  %entry_i32 = sext i8 %entry_ret to i32");
        emitln("  ret i32 %entry_i32");
        emitln("}");
        return 1;
    }
    if (entry_fn.ret_type == TYPE_I16) {
        emitln("  %entry_i32 = sext i16 %entry_ret to i32");
        emitln("  ret i32 %entry_i32");
        emitln("}");
        return 1;
    }
    if (entry_fn.ret_type == TYPE_U32 || entry_fn.ret_type == TYPE_I32) {
        emitln("  ret i32 %entry_ret");
        emitln("}");
        return 1;
    }
    if (entry_fn.ret_type == TYPE_U64 || entry_fn.ret_type == TYPE_I64) {
        emitln("  %entry_i32 = trunc i64 %entry_ret to i32");
        emitln("  ret i32 %entry_i32");
        emitln("}");
        return 1;
    }
    if (entry_fn.ret_type == TYPE_F64) {
        emitln("  %entry_i32 = fptosi double %entry_ret to i32");
        emitln("  ret i32 %entry_i32");
        emitln("}");
        return 1;
    }
    emitln("  ret i32 0");
    emitln("}");
    return 1;
}

func llvm_contract_type_supported_impl(type_kind: u64, ptr_depth: u64) -> u64 {
    if (ptr_depth > 0) { return 1; }
    match (type_kind) {
        case TYPE_VOID: return 1;
        case TYPE_BOOL: return 1;
        case TYPE_U8: return 1;
        case TYPE_I8: return 1;
        case TYPE_U16: return 1;
        case TYPE_I16: return 1;
        case TYPE_U32: return 1;
        case TYPE_I32: return 1;
        case TYPE_U64: return 1;
        case TYPE_I64: return 1;
        case TYPE_FUNC: return 1;
        case TYPE_F64: return 1;
    }
    return 0;
}

func llvm_contract_fn_is_zero_arg_nonvariadic_impl(fn: *AstFunc) -> u64 {
    if (fn == 0) { return 0; }
    if (fn.params_vec == 0 || fn.params_vec.len() == 0) { return 1; }
    return 0;
}

func llvm_contract_fn_has_variadic_param_impl(fn: *AstFunc) -> u64 {
    if (fn == 0 || fn.params_vec == 0) { return 0; }
    var n: u64 = fn.params_vec.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var param: *Param = fn.params_vec.get(i);
        if (param != 0 && param.is_variadic != 0) { return 1; }
    }
    return 0;
}

func llvm_contract_fn_has_func_param_impl(fn: *AstFunc) -> u64 {
    if (fn == 0 || fn.params_vec == 0) { return 0; }
    var n: u64 = fn.params_vec.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var param: *Param = fn.params_vec.get(i);
        if (param != 0 && param.type_kind == TYPE_FUNC && param.ptr_depth == 0) { return 1; }
    }
    return 0;
}

func llvm_contract_fn_has_supported_return_type_impl(fn: *AstFunc) -> u64 {
    return llvm_contract_fn_has_supported_return_type_from_program_impl(0, fn);
}

func llvm_contract_fn_has_supported_return_type_from_program_impl(program: *AstProgram, fn: *AstFunc) -> u64 {
    if (fn == 0) { return 0; }
    if (fn.ret_ptr_depth > 0) { return 1; }
    if (fn.ret_type == TYPE_SLICE) { return 1; }
    if (fn.ret_type == TYPE_STRUCT) {
        return (llvm_contract_fn_struct_ret_size_from_program_impl(program, fn) != 0);
    }
    return llvm_contract_type_supported_impl(fn.ret_type, fn.ret_ptr_depth);
}

func llvm_contract_fn_has_supported_param_types_impl(fn: *AstFunc) -> u64 {
    return llvm_contract_fn_has_supported_param_types_from_program_impl(0, fn);
}

func llvm_contract_fn_has_supported_param_types_from_program_impl(program: *AstProgram, fn: *AstFunc) -> u64 {
    if (fn == 0) { return 0; }
    if (fn.params_vec == 0) { return 1; }
    var n: u64 = fn.params_vec.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var param: *Param = fn.params_vec.get(i);
        if (param == 0) { return 0; }
        if (param.is_variadic != 0 && param.ptr_depth == 0) { return 0; }
        if ((param.type_kind == TYPE_STRUCT || param.type_kind == TYPE_ARRAY || param.type_kind == TYPE_SLICE) && param.ptr_depth == 0) {
            if (llvm_contract_param_storage_size_from_program_impl(program, param) == 0 && param.type_kind != TYPE_SLICE) { return 0; }
            continue;
        }
        if (llvm_contract_type_supported_impl(param.type_kind, param.ptr_depth) == 0) { return 0; }
    }
    return 1;
}

func llvm_contract_emit_fn_params_impl(fn: *AstFunc) -> u64 {
    return llvm_contract_emit_fn_params_from_program_impl(0, fn);
}

func llvm_contract_emit_fn_params_from_program_impl(program: *AstProgram, fn: *AstFunc) -> u64 {
    if (fn == 0) { return 0; }
    var n: u64 = llvm_contract_fn_abi_param_count_from_program_impl(program, fn);
    var has_variadic: u64 = llvm_contract_fn_has_variadic_param_impl(fn);
    for (var i: u64 = 0; i < n; i = i + 1) {
        var part: LLVMABIParamPartInfo = llvm_contract_fn_abi_part_info_from_program_impl(program, fn, i);
        if (part.found == 0) { continue; }
        if (i != 0) { emit(", "); }
        if (llvm_contract_emit_abi_part_type_impl(part) == 0) { emit("i64"); }
        emit(" %p");
        print_u64(i);
    }
    if (has_variadic != 0) {
        if (n != 0) { emit(", "); }
        emit("...");
        return 1;
    }
    return (n != 0);
}

func llvm_contract_stmt_is_empty_void_body_impl(stmt: *AstNode) -> u64 {
    if (stmt == 0 || ast_kind(stmt) != AST_BLOCK) { return 0; }
    var blk: *AstBlock = (*AstBlock)stmt;
    if (blk.stmts_vec == 0 || blk.stmts_vec.len() == 0) { return 1; }
    if (blk.stmts_vec.len() != 1) { return 0; }
    var only_stmt: *AstNode = blk.stmts_vec.get(0);
    if (only_stmt == 0 || ast_kind(only_stmt) != AST_RETURN) { return 0; }
    return (((*AstReturn)only_stmt).expr == 0);
}

func llvm_contract_ll_supports_single_return_expr_impl(fn: *AstFunc, expr: *AstNode) -> u64 {
    if (fn == 0) { return 0; }
    if (fn.ret_ptr_depth > 0) {
        return (expr != 0 && ast_kind(expr) == AST_LITERAL && ((*AstLiteral)expr).value == 0);
    }
    if (expr == 0) { return (fn.ret_type == TYPE_VOID); }
    var kind: u64 = ast_kind(expr);
    if (kind == AST_LITERAL) {
        if (fn.ret_type == TYPE_BOOL || fn.ret_type == TYPE_U8 || fn.ret_type == TYPE_I8 ||
            fn.ret_type == TYPE_U16 || fn.ret_type == TYPE_I16 || fn.ret_type == TYPE_U32 ||
            fn.ret_type == TYPE_I32 || fn.ret_type == TYPE_U64 || fn.ret_type == TYPE_I64) {
            return 1;
        }
        return 0;
    }
    if (kind == AST_FLOAT && fn.ret_type == TYPE_F64) { return 1; }
    return 0;
}

func llvm_contract_ll_emit_return_expr_impl(fn: *AstFunc, expr: *AstNode) -> u64 {
    if (fn == 0) { return 0; }
    emit("  ret ");
    if (llvm_contract_emit_type_impl(fn.ret_type, fn.ret_ptr_depth) == 0) { return 0; }
    emit(" ");
    if (fn.ret_ptr_depth > 0) {
        emit("null");
        emit("\n");
        return 1;
    }
    if (fn.ret_type == TYPE_VOID) {
        emit("\n");
        return 1;
    }
    if (expr == 0) { return 0; }
    var kind: u64 = ast_kind(expr);
    if (kind == AST_LITERAL) {
        var lit: *AstLiteral = (*AstLiteral)expr;
        if (fn.ret_type == TYPE_BOOL) {
            if (lit.value != 0) { emit("1"); }
            else { emit("0"); }
        } else {
            print_u64(lit.value);
        }
        emit("\n");
        return 1;
    }
    if (kind == AST_FLOAT) {
        var fl: *AstFloat = (*AstFloat)expr;
        if (u8_slice_ptr(fl.str) != 0 && u8_slice_len(fl.str) != 0) {
            io_write_out(u8_slice_ptr(fl.str), u8_slice_len(fl.str));
            emit("\n");
            return 1;
        }
    }
    return 0;
}

func llvm_contract_ll_emit_ssa_value_impl(inst: *LLVMSSAInstSketch, which: u64) -> u64 {
    if (inst == 0) { return 0; }
    if (which == 1) {
        if (inst.src1_is_const != 0) { print_u64(inst.src1_value); }
        else {
            emit("%r");
            print_u64(inst.src1_value);
        }
        return 1;
    }
    if (which == 2) {
        if (inst.src2_is_const != 0) { print_u64(inst.src2_value); }
        else {
            emit("%r");
            print_u64(inst.src2_value);
        }
        return 1;
    }
    return 0;
}

func llvm_contract_ll_try_eval_const_reg_impl(sketch: *LLVMSSAFuncSketch, reg_id: u64, block_limit: u64, inst_limit: u64, depth: u64, out_val: *u64) -> u64 {
    if (out_val != 0) { *out_val = 0; }
    if (sketch == 0 || reg_id == 0 || out_val == 0) { return 0; }
    if (depth > 12) { return 0; }
    var inst: *LLVMSSAInstSketch = llvm_contract_ll_find_inst_by_dest_impl(sketch, reg_id, block_limit, inst_limit);
    if (inst == 0) { return 0; }
    if (inst.op == SSA_OP_CONST && inst.has_src1 != 0) {
        *out_val = inst.src1_value;
        return 1;
    }
    if (inst.op == SSA_OP_COPY && inst.has_src1 != 0) {
        if (inst.src1_is_const != 0) {
            *out_val = inst.src1_value;
            return 1;
        }
        return llvm_contract_ll_try_eval_const_reg_impl(sketch, inst.src1_value, block_limit, inst_limit, depth + 1, out_val);
    }
    if (!(inst.op == SSA_OP_ADD || inst.op == SSA_OP_SUB || inst.op == SSA_OP_MUL ||
          inst.op == SSA_OP_AND || inst.op == SSA_OP_OR || inst.op == SSA_OP_XOR ||
          inst.op == SSA_OP_SHL || inst.op == SSA_OP_SHR || inst.op == SSA_OP_SAR)) {
        return 0;
    }
    var lhs: u64 = 0;
    var rhs: u64 = 0;
    if (inst.has_src1 == 0 || inst.has_src2 == 0) { return 0; }
    if (inst.src1_is_const != 0) { lhs = inst.src1_value; }
    else if (llvm_contract_ll_try_eval_const_reg_impl(sketch, inst.src1_value, block_limit, inst_limit, depth + 1, &lhs) == 0) { return 0; }
    if (inst.src2_is_const != 0) { rhs = inst.src2_value; }
    else if (llvm_contract_ll_try_eval_const_reg_impl(sketch, inst.src2_value, block_limit, inst_limit, depth + 1, &rhs) == 0) { return 0; }
    match (inst.op) {
        case SSA_OP_ADD: *out_val = lhs + rhs; return 1;
        case SSA_OP_SUB: *out_val = lhs - rhs; return 1;
        case SSA_OP_MUL: *out_val = lhs * rhs; return 1;
        case SSA_OP_AND: *out_val = lhs & rhs; return 1;
        case SSA_OP_OR: *out_val = lhs | rhs; return 1;
        case SSA_OP_XOR: *out_val = lhs ^ rhs; return 1;
        case SSA_OP_SHL: *out_val = lhs << rhs; return 1;
        case SSA_OP_SHR: *out_val = lhs >> rhs; return 1;
        case SSA_OP_SAR: *out_val = lhs >> rhs; return 1;
    }
    return 0;
}

func llvm_contract_ll_emit_int_width_type_impl(width: u64) -> u64 {
    if (width == 1) { emit("i8"); return 1; }
    if (width == 2) { emit("i16"); return 1; }
    if (width == 4) { emit("i32"); return 1; }
    if (width == 8) { emit("i64"); return 1; }
    return 0;
}

func llvm_contract_ll_emit_float_value_impl(inst: *LLVMSSAInstSketch, which: u64) -> u64 {
    if (inst == 0) { return 0; }
    var raw: u64 = 0;
    var is_const: u64 = 0;
    if (which == 1) {
        is_const = inst.src1_is_const;
        raw = inst.src1_value;
    } else if (which == 2) {
        is_const = inst.src2_is_const;
        raw = inst.src2_value;
    } else {
        return 0;
    }
    if (is_const != 0) {
        var info: *NameInfo = (*NameInfo)raw;
        if (info == 0 || info.ptr == 0 || info.len == 0) {
            emit("0.0");
            return 1;
        }
        io_write_out(info.ptr, info.len);
        return 1;
    }
    emit("%r");
    print_u64(raw);
    return 1;
}

func llvm_contract_ll_emit_local_slot_name_impl(kind: u64, id: u64) -> u64 {
    if (kind == 1) { emit("%loc"); }
    else { emit("%var"); }
    print_u64(id);
    return 0;
}

func llvm_contract_asm_ch_impl(text_vec: *Vec<u64>, idx: u64) -> u64 {
    if (text_vec == 0 || idx >= text_vec.len()) { return 0; }
    return text_vec.get(idx);
}

func llvm_contract_asm_lower_impl(ch: u64) -> u64 {
    if (ch >= 65 && ch <= 90) { return ch + 32; }
    return ch;
}

func llvm_contract_asm_is_ws_impl(ch: u64) -> u64 {
    if (ch == 32 || ch == 9 || ch == 10 || ch == 13) { return 1; }
    return 0;
}

func llvm_contract_asm_is_ident_impl(ch: u64) -> u64 {
    if (ch >= 65 && ch <= 90) { return 1; }
    if (ch >= 97 && ch <= 122) { return 1; }
    if (ch >= 48 && ch <= 57) { return 1; }
    if (ch == 95) { return 1; }
    return 0;
}

func llvm_contract_asm_match_lit_impl(text_vec: *Vec<u64>, start: u64, lit: []u8) -> u64 {
    if (text_vec == 0 || lit.ptr == 0) { return 0; }
    if (start + lit.len > text_vec.len()) { return 0; }
    var lit_u8: []u8 = slice(lit.ptr, lit.len);
    for (var i: u64 = 0; i < lit.len; i = i + 1) {
        var got: u64 = llvm_contract_asm_lower_impl(llvm_contract_asm_ch_impl(text_vec, start + i));
        var want: u64 = llvm_contract_asm_lower_impl((u64)lit_u8[i]);
        if (got != want) { return 0; }
    }
    return 1;
}

func llvm_contract_asm_token_boundary_impl(text_vec: *Vec<u64>, start: u64, len: u64) -> u64 {
    if (text_vec == 0) { return 0; }
    if (start > 0 && llvm_contract_asm_is_ident_impl(llvm_contract_asm_ch_impl(text_vec, start - 1)) != 0) { return 0; }
    if (start + len < text_vec.len() && llvm_contract_asm_is_ident_impl(llvm_contract_asm_ch_impl(text_vec, start + len)) != 0) { return 0; }
    return 1;
}

func llvm_contract_asm_skip_ws_impl(text_vec: *Vec<u64>, idx: *u64) -> u64 {
    if (text_vec == 0 || idx == 0) { return 0; }
    while (*idx < text_vec.len() && llvm_contract_asm_is_ws_impl(llvm_contract_asm_ch_impl(text_vec, *idx)) != 0) {
        *idx = *idx + 1;
    }
    return 0;
}

func llvm_contract_asm_parse_u64_impl(text_vec: *Vec<u64>, idx: *u64, out: *u64) -> u64 {
    if (text_vec == 0 || idx == 0 || out == 0) { return 0; }
    llvm_contract_asm_skip_ws_impl(text_vec, idx);
    var value: u64 = 0;
    var seen: u64 = 0;
    while (*idx < text_vec.len()) {
        var ch: u64 = llvm_contract_asm_ch_impl(text_vec, *idx);
        if (ch < 48 || ch > 57) { break; }
        value = value * 10 + (ch - 48);
        seen = 1;

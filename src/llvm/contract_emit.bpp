    emitln("  %scalar_guard = or i1 %not_vectorizable, %elem_zero");
    emitln("  br i1 %scalar_guard, label %chosen_scalar, label %lanes");
    emitln("lanes:");
    emitln("  %raw_lanes = udiv i64 32, %p2");
    emitln("  %below_one = icmp ult i64 %raw_lanes, 1");

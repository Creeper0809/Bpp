                    } else {
                        emit("  %retslicesrc");
                        print_u64(block.id);
                        emit("_");
                        print_u64(i);
                        emit(" = inttoptr i64 %r");
                        print_u64(inst.src1_value);
                        emit(" to ptr\n");
                        emit("  call void @\"llvm.memcpy.p0.p0.i64\"(ptr %retsliceheap");
                        print_u64(block.id);
                        emit("_");
                        print_u64(i);
                        emit(", ptr %retslicesrc");
                        print_u64(block.id);
                        emit("_");
                        print_u64(i);
                        emit(", i64 %retslicesize");
                        print_u64(block.id);
                        emit("_");
                        print_u64(i);
                        emit(", i1 0)\n");

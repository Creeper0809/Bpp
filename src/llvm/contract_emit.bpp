                    print_u64(block.id);
                    emit("_");
                    print_u64(i);
                    emit(", 0\n");
                    emit("  %retheapagg1");
                    print_u64(block.id);
                    emit("_");
                    print_u64(i);
                    emit(" = insertvalue { ptr, i64 } %retheapagg0");
                    print_u64(block.id);
                    emit("_");
                    print_u64(i);
                    emit(", i64 %retslicelen");
                    print_u64(block.id);
                    emit("_");
                    print_u64(i);
                    emit(", 1\n");
                    emit("  ret { ptr, i64 } %retheapagg1");

    emitln("  %lanes = phi i64 [ %lanes_calc_val, %lanes_calc ], [ 1, %lanes_scalar ]");
    emitln("  %unroll_gt_len = icmp ugt i64 %lanes, %len");
    emitln("  %unroll0 = select i1 %unroll_gt_len, i64 %len, i64 %lanes");
    emitln("  %unroll_lt_two = icmp ult i64 %unroll0, 2");
    emitln("  %len_ge_four = icmp uge i64 %len, 4");
    emitln("  %force_unroll4 = and i1 %unroll_lt_two, %len_ge_four");
    emitln("  %unroll = select i1 %force_unroll4, i64 4, i64 %unroll0");
    emitln("  %enough_lanes = icmp uge i64 %lanes, 2");
    emitln("  %len_ge_lanes = icmp uge i64 %len, %lanes");
    emitln("  %can_vector = and i1 %enough_lanes, %len_ge_lanes");
    emitln("  br i1 %can_vector, label %fp_vector, label %fp_unroll_check");
    emitln("fp_unroll_check:");
    emitln("  %len_ge_two = icmp uge i64 %len, 2");
    emitln("  %can_unroll = and i1 %len_ge_two, %enough_lanes");
    emitln("  br i1 %can_unroll, label %fp_unrolled, label %fp_scalar");
    emitln("fp_vector:");
    emitln("  br label %write_fast");
    emitln("fp_unrolled:");
    emitln("  br label %write_fast");
    emitln("fp_scalar:");
    emitln("  br label %write_fast");
    emitln("write_fast:");
    emitln("  %fast_path = phi i64 [ 3, %fp_vector ], [ 2, %fp_unrolled ], [ 1, %fp_scalar ]");
    emitln("  store i64 %fast_path, ptr %p0");
    emitln("  %lanes_ptr = getelementptr i8, ptr %p0, i64 8");
    emitln("  store i64 %lanes, ptr %lanes_ptr");
    emitln("  %unroll_ptr = getelementptr i8, ptr %p0, i64 16");
    emitln("  store i64 %unroll, ptr %unroll_ptr");
    emitln("  %shape_out_ptr = getelementptr i8, ptr %p0, i64 24");
    emitln("  store i64 %shape, ptr %shape_out_ptr");
    emitln("  %hot_out_ptr = getelementptr i8, ptr %p0, i64 32");
    emitln("  store i64 %hot, ptr %hot_out_ptr");
    emitln("  ret void");
    emitln("default_shape:");
    emitln("  store i64 1, ptr %p0");
    emitln("  %def_lanes_ptr = getelementptr i8, ptr %p0, i64 8");
    emitln("  store i64 1, ptr %def_lanes_ptr");
    emitln("  %def_unroll_ptr = getelementptr i8, ptr %p0, i64 16");
    emitln("  store i64 1, ptr %def_unroll_ptr");
    emitln("  %def_shape_ptr = getelementptr i8, ptr %p0, i64 24");
    emitln("  store i64 %shape, ptr %def_shape_ptr");
    emitln("  %def_hot_ptr = getelementptr i8, ptr %p0, i64 32");
    emitln("  store i64 %hot, ptr %def_hot_ptr");
    emitln("  ret void");
    emitln("default_unknown:");
    emitln("  store i64 1, ptr %p0");
    emitln("  %unk_lanes_ptr = getelementptr i8, ptr %p0, i64 8");
    emitln("  store i64 1, ptr %unk_lanes_ptr");
    emitln("  %unk_unroll_ptr = getelementptr i8, ptr %p0, i64 16");
    emitln("  store i64 1, ptr %unk_unroll_ptr");
    emitln("  %unk_shape_ptr = getelementptr i8, ptr %p0, i64 24");
    emitln("  store i64 0, ptr %unk_shape_ptr");
    emitln("  %unk_hot_ptr = getelementptr i8, ptr %p0, i64 32");
    emitln("  store i64 0, ptr %unk_hot_ptr");
    emitln("  ret void");
    emitln("}");
    return 1;
}


            } else
            if ((part.role == LLVM_ABI_ROLE_LARGE_STRUCT_PTR || part.role == LLVM_ABI_ROLE_ARRAY_PTR) && enc != 0) {
                llvm_contract_ll_emit_local_slot_name_impl(1, enc);
            } else
            if (enc != 0 && llvm_contract_ll_reg_is_direct_local_addr_impl(sketch, arg_reg, block_idx, inst_idx, 0) != 0) {
                llvm_contract_ll_emit_local_slot_name_impl(1, enc);
            } else {
                emit("%argptr");
                print_u64(block_idx);
                emit("_");
                print_u64(inst_idx);
                emit("_");
                print_u64(i);
            }
        } else if ((part.role == LLVM_ABI_ROLE_SMALL_STRUCT_LO || part.role == LLVM_ABI_ROLE_SMALL_STRUCT_HI) &&
                   llvm_contract_ll_find_reg_aggregate_base_impl(sketch, arg_reg, block_idx, inst_idx) != 0) {

        var block: *LLVMSSABlockSketch = sketch.blocks.get(bi);
        if (block == 0 || block.insts == 0) { continue; }
        var ni: u64 = block.insts.len();
        for (var ii: u64 = 0; ii < ni; ii = ii + 1) {
            var inst: *LLVMSSAInstSketch = block.insts.get(ii);
            if (inst == 0 || inst.op != SSA_OP_STORE || inst.has_src1 == 0 || inst.src1_is_const == 0) { continue; }
            if (inst.src1_value != var_id || inst.has_src2 == 0 || inst.src2_is_const != 0) { continue; }
            return llvm_contract_ll_reg_value_type_impl(fn, sketch, inst.src2_value);
        }
    }
    return TYPE_U64;
}

func llvm_contract_ll_sketch_has_local_slot_impl(sketch: *LLVMSSAFuncSketch, kind: u64, id: u64, block_limit: u64, inst_limit: u64) -> u64 {
    if (sketch == 0 || sketch.blocks == 0) { return 0; }

func llvm_contract_ll_find_reg_local_base_offset_impl(sketch: *LLVMSSAFuncSketch, reg_id: u64, block_limit: u64, inst_limit: u64, depth: u64, base_enc_out: *u64, offset_out: *u64) -> u64 {

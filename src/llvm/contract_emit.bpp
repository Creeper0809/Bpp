func llvm_contract_ll_find_future_store_target_for_value_reg_impl(sketch: *LLVMSSAFuncSketch, block_idx: u64, inst_idx: u64, value_reg: u64, out_base_enc: *u64, out_off: *u64) -> u64 {
    if (out_base_enc != 0) { *out_base_enc = 0; }
    if (out_off != 0) { *out_off = 0; }
    if (sketch == 0 || sketch.blocks == 0 || value_reg == 0) { return 0; }
    var nb: u64 = sketch.blocks.len();
    for (var bi: u64 = block_idx; bi < nb; bi = bi + 1) {
        var block: *LLVMSSABlockSketch = sketch.blocks.get(bi);
        if (block == 0 || block.insts == 0) { continue; }
        var ni: u64 = block.insts.len();
        var ii_start: u64 = 0;
        if (bi == block_idx) { ii_start = inst_idx + 1; }
        for (var ii: u64 = ii_start; ii < ni; ii = ii + 1) {
            var inst: *LLVMSSAInstSketch = block.insts.get(ii);
            if (inst == 0 || inst.has_src1 == 0 || inst.src1_is_const != 0 || inst.has_src2 == 0 || inst.src2_is_const != 0) { continue; }
            if (!(inst.op == SSA_OP_STORE || inst.op == SSA_OP_STORE8 || inst.op == SSA_OP_STORE16 || inst.op == SSA_OP_STORE32 || inst.op == SSA_OP_STORE64)) { continue; }
            if (inst.src2_value != value_reg) { continue; }
            var base_enc: u64 = 0;
            var off: u64 = 0;
            if (llvm_contract_ll_find_reg_local_base_offset_impl(sketch, inst.src1_value, bi, ii, 0, &base_enc, &off) == 0) { continue; }
            if (out_base_enc != 0) { *out_base_enc = base_enc; }
            if (out_off != 0) { *out_off = off; }
            return 1;
        }
    }
    return 0;
}

func llvm_contract_ll_find_param_aggregate_slot_impl(program: *AstProgram, fn: *AstFunc, sketch: *LLVMSSAFuncSketch, source_param_index: u64, out_base_enc: *u64) -> u64 {
    if (out_base_enc != 0) { *out_base_enc = 0; }
    if (program == 0 || fn == 0 || sketch == 0 || sketch.blocks == 0) { return 0; }
    var reg0: u64 = 0;
    var reg1: u64 = 0;
    var nb: u64 = sketch.blocks.len();
    for (var bi: u64 = 0; bi < nb; bi = bi + 1) {
        var block: *LLVMSSABlockSketch = sketch.blocks.get(bi);
        if (block == 0 || block.insts == 0) { continue; }
        var ni: u64 = block.insts.len();
        for (var ii: u64 = 0; ii < ni; ii = ii + 1) {
            var inst: *LLVMSSAInstSketch = block.insts.get(ii);
            if (inst == 0 || inst.op != SSA_OP_PARAM || inst.dest == 0 || inst.has_src1 == 0 || inst.src1_is_const == 0) { continue; }
            var part: LLVMABIParamPartInfo = llvm_contract_fn_abi_part_info_from_program_impl(program, fn, inst.src1_value);
            if (part.found == 0 || part.param_index != source_param_index) { continue; }
            if (reg0 == 0) { reg0 = inst.dest; }
            else if (reg1 == 0 && inst.dest != reg0) { reg1 = inst.dest; }
        }
    }
    if (reg0 == 0 && reg1 == 0) { return 0; }
    for (var bi2: u64 = 0; bi2 < nb; bi2 = bi2 + 1) {
        var block2: *LLVMSSABlockSketch = sketch.blocks.get(bi2);
        if (block2 == 0 || block2.insts == 0) { continue; }
        var ni2: u64 = block2.insts.len();
        for (var ii2: u64 = 0; ii2 < ni2; ii2 = ii2 + 1) {
            var inst2: *LLVMSSAInstSketch = block2.insts.get(ii2);
            if (inst2 == 0 || inst2.has_src1 == 0 || inst2.src1_is_const != 0 || inst2.has_src2 == 0 || inst2.src2_is_const != 0) { continue; }
            if (!(inst2.op == SSA_OP_STORE || inst2.op == SSA_OP_STORE8 || inst2.op == SSA_OP_STORE16 || inst2.op == SSA_OP_STORE32 || inst2.op == SSA_OP_STORE64)) { continue; }
            if (inst2.src2_value != reg0 && inst2.src2_value != reg1) { continue; }
            var base_enc: u64 = 0;
            var off: u64 = 0;
            if (llvm_contract_ll_find_reg_local_base_offset_impl(sketch, inst2.src1_value, bi2, ii2, 0, &base_enc, &off) == 0) { continue; }
            if (out_base_enc != 0) { *out_base_enc = base_enc; }
            return 1;
        }
    }
    return 0;
}

func llvm_contract_ll_store_param_aggregate_materialization_impl(program: *AstProgram, fn: *AstFunc, sketch: *LLVMSSAFuncSketch) -> u64 {
    if (program == 0 || fn == 0 || sketch == 0 || fn.params_vec == 0) { return 0; }
    for (var i: u64 = 0; i < fn.params_vec.len(); i = i + 1) {
        var param: *Param = fn.params_vec.get(i);
        if (param == 0 || param.ptr_depth != 0) { continue; }
        if (!(param.type_kind == TYPE_STRUCT || param.type_kind == TYPE_SLICE || param.type_kind == TYPE_ARRAY)) { continue; }
        var enc: u64 = 0;
        if (llvm_contract_ll_find_param_aggregate_slot_impl(program, fn, sketch, i, &enc) == 0 || enc == 0) { continue; }
        var abi_base: u64 = llvm_contract_fn_first_abi_index_for_source_param_impl(program, fn, i);
        if (param.type_kind == TYPE_STRUCT) {
            var sz: u64 = llvm_contract_param_storage_size_from_program_impl(program, param);
            if (sz <= 8) {
                emit("  store i64 %p");
                print_u64(abi_base);
                emit(", ptr ");
                llvm_contract_ll_emit_local_slot_name_impl(1, enc);
                emit("\n");
                continue;
            }
            if (sz <= 16) {
                emit("  store i64 %p");
                print_u64(abi_base);
                emit(", ptr ");
                llvm_contract_ll_emit_local_slot_name_impl(1, enc);
                emit("\n");
                emit("  %paramagg_hi_");
                print_u64(i);
                emit(" = getelementptr i8, ptr ");
                llvm_contract_ll_emit_local_slot_name_impl(1, enc);
                emit(", i64 8\n");
                emit("  store i64 %p");
                print_u64(abi_base + 1);
                emit(", ptr %paramagg_hi_");
                print_u64(i);
                emit("\n");
                continue;
            }
            emit("  call void @\"llvm.memcpy.p0.p0.i64\"(ptr ");
            llvm_contract_ll_emit_local_slot_name_impl(1, enc);
            emit(", ptr %p");
            print_u64(abi_base);
            emit(", i64 ");
            print_u64(sz);
            emit(", i1 false)\n");
            continue;
        }
        if (param.type_kind == TYPE_SLICE) {
            emit("  store ptr %p");
            print_u64(abi_base);
            emit(", ptr ");
            llvm_contract_ll_emit_local_slot_name_impl(1, enc);
            emit("\n");
            emit("  %paramslice_len_");
            print_u64(i);
            emit(" = getelementptr i8, ptr ");
            llvm_contract_ll_emit_local_slot_name_impl(1, enc);
            emit(", i64 8\n");
            emit("  store i64 %p");
            print_u64(abi_base + 1);
            emit(", ptr %paramslice_len_");
            print_u64(i);
            emit("\n");
            continue;
        }
        if (param.type_kind == TYPE_ARRAY) {
            var arr_sz: u64 = llvm_contract_param_storage_size_from_program_impl(program, param);
            emit("  call void @\"llvm.memcpy.p0.p0.i64\"(ptr ");
            llvm_contract_ll_emit_local_slot_name_impl(1, enc);
            emit(", ptr %p");
            print_u64(abi_base);
            emit(", i64 ");
            print_u64(arr_sz);
            emit(", i1 false)\n");
        }
    }
    return 0;
}

func llvm_contract_ll_is_materialized_param_store_impl(program: *AstProgram, fn: *AstFunc, sketch: *LLVMSSAFuncSketch, block_idx: u64, inst_idx: u64, inst: *LLVMSSAInstSketch) -> u64 {
    if (program == 0 || fn == 0 || sketch == 0 || inst == 0) { return 0; }
    if (!(inst.op == SSA_OP_STORE || inst.op == SSA_OP_STORE8 || inst.op == SSA_OP_STORE16 || inst.op == SSA_OP_STORE32 || inst.op == SSA_OP_STORE64)) { return 0; }
    if (inst.has_src1 == 0 || inst.src1_is_const != 0 || inst.has_src2 == 0 || inst.src2_is_const != 0) { return 0; }
    var src_reg: u64 = inst.src2_value;
    var base_enc: u64 = 0;
    var off: u64 = 0;
    if (llvm_contract_ll_find_reg_local_base_offset_impl(sketch, inst.src1_value, block_idx, inst_idx, 0, &base_enc, &off) == 0 || base_enc == 0) { return 0; }
    if (fn.params_vec == 0) { return 0; }
    for (var i: u64 = 0; i < fn.params_vec.len(); i = i + 1) {
        var param: *Param = fn.params_vec.get(i);
        if (param == 0 || param.ptr_depth != 0) { continue; }
        if (!(param.type_kind == TYPE_STRUCT || param.type_kind == TYPE_SLICE || param.type_kind == TYPE_ARRAY)) { continue; }
        var enc: u64 = 0;
        if (llvm_contract_ll_find_param_aggregate_slot_impl(program, fn, sketch, i, &enc) == 0 || enc != base_enc) { continue; }
        var reg0: u64 = 0;
        var reg1: u64 = 0;
        var nb: u64 = sketch.blocks.len();
        for (var bi: u64 = 0; bi < nb; bi = bi + 1) {
            var block: *LLVMSSABlockSketch = sketch.blocks.get(bi);
            if (block == 0 || block.insts == 0) { continue; }
            var ni: u64 = block.insts.len();
            for (var ii: u64 = 0; ii < ni; ii = ii + 1) {
                var pi_inst: *LLVMSSAInstSketch = block.insts.get(ii);
                if (pi_inst == 0 || pi_inst.op != SSA_OP_PARAM || pi_inst.dest == 0 || pi_inst.has_src1 == 0 || pi_inst.src1_is_const == 0) { continue; }
                var part: LLVMABIParamPartInfo = llvm_contract_fn_abi_part_info_from_program_impl(program, fn, pi_inst.src1_value);
                if (part.found == 0 || part.param_index != i) { continue; }
                if (reg0 == 0) { reg0 = pi_inst.dest; }
                else if (reg1 == 0 && pi_inst.dest != reg0) { reg1 = pi_inst.dest; }
            }
        }
        if (src_reg == reg0 || src_reg == reg1) { return 1; }
    }
    return 0;
}

func llvm_contract_fn_source_arg_index_for_abi_part_impl(program: *AstProgram, fn: *AstFunc, abi_index: u64, src_nargs: u64) -> u64 {
    if (fn == 0) { return abi_index; }
    var sret_needed: u64 = llvm_contract_fn_has_sret_param_from_program_impl(program, fn);
    var sret_explicit: u64 = 0;
    if (sret_needed != 0) {
        var source_args_without_sret: u64 = llvm_contract_fn_source_arg_count_without_sret_impl(program, fn);
        if (src_nargs == source_args_without_sret + 1) { sret_explicit = 1; }
    }
    var abi_cur: u64 = 0;
    var src_cur: u64 = 0;
    if (sret_needed != 0) {
        if (abi_index == 0) {
            if (sret_explicit != 0) { return 0; }
            return 18446744073709551615;
        }
        abi_cur = 1;
        if (sret_explicit != 0) { src_cur = 1; }
    }
    if (fn.params_vec == 0) { return src_cur; }
    for (var i: u64 = 0; i < fn.params_vec.len(); i = i + 1) {
        var param: *Param = fn.params_vec.get(i);
        if (param == 0) { continue; }
        if (param.type_kind == TYPE_STRUCT && param.ptr_depth == 0) {
            var sz: u64 = llvm_contract_param_storage_size_from_program_impl(program, param);
            if (sz <= 8) {
                if (abi_index == abi_cur) { return src_cur; }
                abi_cur = abi_cur + 1;
                src_cur = src_cur + 1;
                continue;
            }
            if (sz <= 16) {
                if (abi_index == abi_cur) { return src_cur; }
                if (abi_index == abi_cur + 1) { return src_cur + 1; }
                abi_cur = abi_cur + 2;
                src_cur = src_cur + 2;
                continue;
            }
            if (abi_index == abi_cur) { return src_cur; }
            abi_cur = abi_cur + 1;
            src_cur = src_cur + 1;
            continue;
        }
        if (param.type_kind == TYPE_SLICE && param.ptr_depth == 0) {
            if (abi_index == abi_cur) { return src_cur; }
            if (abi_index == abi_cur + 1) { return src_cur + 1; }
            abi_cur = abi_cur + 2;
            src_cur = src_cur + 2;
            continue;
        }
        if (abi_index == abi_cur) { return src_cur; }
        abi_cur = abi_cur + 1;
        src_cur = src_cur + 1;
    }
    return src_cur;
}

func llvm_contract_ll_infer_local_slot_size_impl(program: *AstProgram, sketch: *LLVMSSAFuncSketch, enc: u64) -> u64 {
    if (sketch == 0 || sketch.blocks == 0 || enc == 0) { return 8; }
    var max_size: u64 = 0;
    var owner_fn: *AstFunc = llvm_contract_program_find_func_impl(program, sketch.name);
    if (owner_fn != 0 && owner_fn.params_vec != 0) {
        for (var pi: u64 = 0; pi < owner_fn.params_vec.len(); pi = pi + 1) {
            var param: *Param = owner_fn.params_vec.get(pi);
            if (param == 0 || param.ptr_depth != 0) { continue; }
            if (!(param.type_kind == TYPE_STRUCT || param.type_kind == TYPE_SLICE || param.type_kind == TYPE_ARRAY)) { continue; }
            var param_enc: u64 = 0;
            if (llvm_contract_ll_find_param_aggregate_slot_impl(program, owner_fn, sketch, pi, &param_enc) == 0 || param_enc != enc) { continue; }
            var abi_sz: u64 = 16;
            if (param.type_kind == TYPE_STRUCT || param.type_kind == TYPE_ARRAY) {
                abi_sz = llvm_contract_param_storage_size_from_program_impl(program, param);
                if (abi_sz > 8 && abi_sz < 16) { abi_sz = 16; }
            }
            if (abi_sz > max_size) { max_size = abi_sz; }
        }
    }
    var nb: u64 = sketch.blocks.len();
    for (var bi: u64 = 0; bi < nb; bi = bi + 1) {
        var block: *LLVMSSABlockSketch = sketch.blocks.get(bi);
        if (block == 0 || block.insts == 0) { continue; }
        var ni: u64 = block.insts.len();
        for (var ii: u64 = 0; ii < ni; ii = ii + 1) {
            var inst: *LLVMSSAInstSketch = block.insts.get(ii);
            if (inst == 0) { continue; }
            var width: u64 = llvm_contract_ll_mem_access_width_from_op_impl(inst.op);
            if (width != 0 && inst.has_src1 != 0 && inst.src1_is_const == 0) {
                var base_enc: u64 = 0;
                var off: u64 = 0;
                if (llvm_contract_ll_find_reg_local_base_offset_impl(sketch, inst.src1_value, bi, ii, 0, &base_enc, &off) != 0 && base_enc == enc) {
                    if (off + width > max_size) { max_size = off + width; }
                } else {
                    var dyn_base: u64 = 0;
                    if (llvm_contract_ll_find_reg_local_base_dynamic_impl(sketch, inst.src1_value, bi, ii, 0, &dyn_base) != 0 && dyn_base == enc) {
                        if (max_size < 262144) { max_size = 262144; }
                    }
                }
            }
            if (inst.op == SSA_OP_CALL || inst.op == SSA_OP_CALL_PTR) {
                var ret_type_eff: u64 = TYPE_VOID;
                var ret_ptr_depth_eff: u64 = 0;
                var ret_struct_size_eff: u64 = 0;
                var nargs: u64 = 0;
                if (inst.op == SSA_OP_CALL) {
                    var info: *SSACallInfo = (*SSACallInfo)inst.src1_value;
                    var callee: *AstFunc = llvm_contract_program_find_func_impl(program, info.name);
                    ret_type_eff = info.ret_type;
                    ret_ptr_depth_eff = info.ret_ptr_depth;
                    ret_struct_size_eff = info.ret_struct_size;
                    if (callee != 0) {
                        ret_type_eff = callee.ret_type;
                        ret_ptr_depth_eff = callee.ret_ptr_depth;
                        ret_struct_size_eff = llvm_contract_fn_struct_ret_size_from_program_impl(program, callee);
                    }
                    nargs = llvm_contract_call_args_len_impl(info.args_vec, info.nargs);
                    for (var ai: u64 = 0; ai < nargs; ai = ai + 1) {
                        var arg_reg: u64 = info.args_vec.get(ai);
                        var base_enc2: u64 = 0;
                        var off2: u64 = 0;
                        if (llvm_contract_ll_find_reg_local_base_offset_impl(sketch, arg_reg, bi, ii, 0, &base_enc2, &off2) == 0 || base_enc2 != enc) { continue; }
                        var part2: LLVMABIParamPartInfo = llvm_contract_fn_abi_part_info_from_program_impl(program, callee, ai);
                        if (part2.found == 0) { if (off2 + 8 > max_size) { max_size = off2 + 8; } continue; }
                        if (part2.type_kind == TYPE_STRUCT && part2.ptr_depth != 0 && callee != 0 && callee.params_vec != 0 && part2.param_index < callee.params_vec.len()) {
                            var ptr_param: *Param = callee.params_vec.get(part2.param_index);
                            if (ptr_param != 0) {
                                var pointee_sz: u64 = llvm_contract_struct_size_impl(program, ptr_param.struct_name);
                                if (pointee_sz > 0 && off2 + pointee_sz > max_size) { max_size = off2 + pointee_sz; }
                            }
                        }
                        if ((part2.role == LLVM_ABI_ROLE_SMALL_STRUCT_LO || part2.role == LLVM_ABI_ROLE_SMALL_STRUCT_HI) &&
                            part2.struct_size > 8 && part2.struct_size < 16 && off2 + 16 > max_size) {
                            max_size = off2 + 16;
                        }
                        if (part2.struct_size != 0 && off2 + part2.struct_size > max_size) { max_size = off2 + part2.struct_size; }
                        else if (off2 + 8 > max_size) { max_size = off2 + 8; }
                    }
                } else {
                    var info_ptr: *SSACallPtrInfo = (*SSACallPtrInfo)inst.src1_value;
                    var callee_name: *PtrLen = llvm_contract_ll_find_reg_lea_func_info_impl(sketch, info_ptr.callee_reg, bi, ii);
                    var callee2: *AstFunc = 0;
                    if (callee_name != 0 && callee_name.ptr != 0 && callee_name.len != 0) {

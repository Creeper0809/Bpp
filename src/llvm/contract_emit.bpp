    emitln("  %vector0 = and i1 %hot_profiled, %enough_lanes");
    emitln("  %can_vector = and i1 %vector0, %len_ge_lanes");
    emitln("  br i1 %can_vector, label %chosen_vector, label %unroll_check");
    emitln("unroll_check:");

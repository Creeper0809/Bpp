        emitln("; bpp.ssa.loop.detected=counted-backedge");
    }
    if (has_tagged_access != 0) {
        emitln("; bpp.ssa.tagged_access.detected=guarded-container");
    }
    if (has_counted_loop != 0 && has_tagged_access != 0) {
        emitln("; bpp.ssa.auto_tagged_loop=candidate");
    }
    if (sketch.tag_summary_bits != 0) {
        emitln("; bpp.ssa.tag.summary=stored");
    }
    if (sketch.tag_interproc_summary_bits != 0) {
        emitln("; bpp.ssa.tag.summary=interprocedural");
    }
    if (sketch.tag_fold_count != 0) {
        emitln("; bpp.ssa.tag.folded=direct-callsite");
    }
    if (sketch.tag_hot_path_fold_count != 0) {
        emitln("; bpp.ssa.profile.fastpath=folded");
    }
    if (sketch.tag_profile_fold_count != 0) {
        emitln("; bpp.ssa.profile.threshold=folded");
    }
    if (sketch.tag_inline_cache_fold_count != 0) {
        emitln("; bpp.ssa.inline_cache.fastpath=folded");
    }
    if (sketch.stack_new_lower_count != 0) {
        emitln("; bpp.ssa.new_stack_lowering=escape-stack-slot");
    }
    if (sketch.stack_new_noescape_callsite_count != 0) {
        emitln("; bpp.ssa.stack_new.noescape_summary=interprocedural");
    }
    if (sketch.stack_new_tag_policy_count != 0) {
        emitln("; bpp.ssa.stack_new.tag_policy=escape-lifecycle");
    }
    if (sketch.stack_new_sroa_field_count != 0) {
        emitln("; bpp.ssa.stack_new.sroa=field-address");
    }
    if (sketch.stack_new_sroa_scalar_count != 0) {
        emitln("; bpp.ssa.stack_new.sroa=scalar-load");
    }
    return 0;
}


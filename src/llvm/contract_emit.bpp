        print_u64(block_idx);
        emit("_");
        print_u64(inst_idx);
        emit(" = ");
    } else if (inst.dest != 0 && is_large_sret == 0) {
        emit("  %r");
        print_u64(inst.dest);
        emit(" = ");
    } else {
        emit("  ");
    }
    emit("call ");
    if (callee != 0) {
        if (llvm_contract_emit_fn_ret_type_from_program_impl(program, callee) == 0) { emit("i64"); }
    } else if (llvm_contract_emit_ret_type_from_meta_impl(ret_type_eff, ret_ptr_depth_eff, ret_struct_size_eff) == 0) {
        emit("i64");
    }
    emit(" %callptr");
    print_u64(block_idx);
    emit("_");
    print_u64(inst_idx);
    emit("(");
    llvm_contract_ll_emit_call_ptr_args_impl(program, sketch, block_idx, inst_idx, info);
    emit(")\n");
    if (needs_raw_ret != 0) {
        if (ret_ptr_depth_eff != 0) {
            emit("  %r");
            print_u64(inst.dest);
            emit(" = ptrtoint ptr %callraw");
            print_u64(block_idx);
            emit("_");
            print_u64(inst_idx);
            emit(" to i64\n");
        } else if (ret_type_eff == TYPE_SLICE) {
            emit("  %callptrret");
            print_u64(block_idx);
            emit("_");
            print_u64(inst_idx);
            emit(" = extractvalue { ptr, i64 } %callraw");
            print_u64(block_idx);
            emit("_");
            print_u64(inst_idx);
            emit(", 0\n");
            emit("  %r");
            print_u64(inst.dest);
            emit(" = ptrtoint ptr %callptrret");
            print_u64(block_idx);
            emit("_");
            print_u64(inst_idx);
            emit(" to i64\n");
            if (inst.has_src2 != 0 && inst.src2_is_const == 0) {
                emit("  %r");
                print_u64(inst.src2_value);
                emit(" = extractvalue { ptr, i64 } %callraw");
                print_u64(block_idx);
                emit("_");
                print_u64(inst_idx);
                emit(", 1\n");
            }
        } else if (ret_type_eff == TYPE_STRUCT && ret_struct_size_eff > 8 && ret_struct_size_eff <= 16) {
            emit("  %r");
            print_u64(inst.dest);
            emit(" = extractvalue { i64, i64 } %callraw");
            print_u64(block_idx);
            emit("_");
            print_u64(inst_idx);
            emit(", 0\n");
            if (inst.has_src2 != 0 && inst.src2_is_const == 0) {
                emit("  %r");
                print_u64(inst.src2_value);
                emit(" = extractvalue { i64, i64 } %callraw");
                print_u64(block_idx);
                emit("_");
                print_u64(inst_idx);
                emit(", 1\n");
            } else {
                var spill_enc: u64 = 0;
                var spill_off: u64 = 0;
                if (llvm_contract_ll_find_future_store_target_for_value_reg_impl(sketch, block_idx, inst_idx, inst.dest, &spill_enc, &spill_off) != 0 && spill_enc != 0) {
                    emit("  %callrawhi");
                    print_u64(block_idx);
                    emit("_");
                    print_u64(inst_idx);
                    emit(" = extractvalue { i64, i64 } %callraw");
                    print_u64(block_idx);
                    emit("_");
                    print_u64(inst_idx);
                    emit(", 1\n");
                    emit("  %callrawslot");
                    print_u64(block_idx);
                    emit("_");
                    print_u64(inst_idx);
                    emit(" = getelementptr i8, ptr ");
                    llvm_contract_ll_emit_local_slot_name_impl(1, spill_enc);
                    emit(", i64 ");
                    print_u64(spill_off + 8);
                    emit("\n");
                    emit("  store i64 %callrawhi");
                    print_u64(block_idx);
                    emit("_");
                    print_u64(inst_idx);
                    emit(", ptr %callrawslot");
                    print_u64(block_idx);
                    emit("_");
                    print_u64(inst_idx);
                    emit("\n");
                }
            }
        } else {
            emit("  %r");
            print_u64(inst.dest);
            emit(" = ");
            if (ret_type_eff == TYPE_U8 || ret_type_eff == TYPE_U16 || ret_type_eff == TYPE_U32) { emit("zext "); }
            else { emit("sext "); }
            if (ret_type_eff == TYPE_U8 || ret_type_eff == TYPE_I8) { emit("i8 "); }
            else if (ret_type_eff == TYPE_U16 || ret_type_eff == TYPE_I16) { emit("i16 "); }
            else { emit("i32 "); }
            emit("%callraw");
            print_u64(block_idx);
            emit("_");
            print_u64(inst_idx);
            emit(" to i64\n");
        }
    } else if (is_large_sret != 0 && inst.dest != 0) {
        var sret_enc: u64 = llvm_contract_ll_find_nearest_call_sret_local_impl(sketch, block_idx, inst_idx);
        if (sret_enc != 0) {
            emit("  %r");
            print_u64(inst.dest);
            emit(" = load i64, ptr ");
            llvm_contract_ll_emit_local_slot_name_impl(1, sret_enc);
            emit("\n");
            if (inst.has_src2 != 0 && inst.src2_is_const == 0) {
                emit("  %r");
                print_u64(inst.src2_value);
                emit(" = load i64, ptr ");
                llvm_contract_ll_emit_local_slot_ref_with_offset_impl(sret_enc, 8, slice("sret_hi", 7), block_idx, inst_idx);
                emit("\n");
            }
        }
    }
    return 1;
}

func llvm_contract_ll_emit_block_label_impl(sketch: *LLVMSSAFuncSketch, block_id: u64) -> u64 {
    if (sketch != 0 && block_id == sketch.entry_block_id) { emit("entry"); }
    else {
        emit("bb");
        print_u64(block_id);
    }
    return 0;
}

func llvm_contract_ll_emit_block_ref_impl(sketch: *LLVMSSAFuncSketch, block_id: u64) -> u64 {
    emit("label %");
    return llvm_contract_ll_emit_block_label_impl(sketch, block_id);
}

func llvm_contract_ll_block_has_meaningful_inst_impl(block: *LLVMSSABlockSketch) -> u64 {
    if (block == 0 || block.insts == 0) { return 0; }
    var n: u64 = block.insts.len();
    for (var i: u64 = 0; i < n; i = i + 1) {
        var inst: *LLVMSSAInstSketch = block.insts.get(i);
        if (inst == 0) { continue; }
        if (inst.op != SSA_OP_NOP) { return 1; }
    }
    return 0;
}

func llvm_contract_ll_block_has_edge_to_impl(sketch: *LLVMSSAFuncSketch, from_id: u64, to_id: u64) -> u64 {
    if (sketch == 0 || sketch.blocks == 0) { return 0; }
    var nb: u64 = sketch.blocks.len();
    for (var bi: u64 = 0; bi < nb; bi = bi + 1) {
        var block: *LLVMSSABlockSketch = sketch.blocks.get(bi);
        if (block == 0 || block.id != from_id || block.insts == 0) { continue; }
        var ni: u64 = block.insts.len();
        for (var ii: u64 = 0; ii < ni; ii = ii + 1) {
            var inst: *LLVMSSAInstSketch = block.insts.get(ii);
            if (inst == 0) { continue; }
            if (inst.op == SSA_OP_BR) {
                if (inst.src2_value == to_id || operand_value(inst.dest) == to_id) { return 1; }
                return 0;
            }
            if (inst.op == SSA_OP_JMP) {
                if (inst.src1_value == to_id) { return 1; }
                return 0;
            }
            if (inst.op == SSA_OP_RET || inst.op == SSA_OP_RET_SLICE_HEAP) { return 0; }
        }
        return 0;
    }
    return 0;
}

func llvm_contract_ll_phi_arg_seen_before_impl(sketch: *LLVMSSAFuncSketch, inst: *LLVMSSAInstSketch, target_block_id: u64, arg_block_id: u64, limit_idx: u64) -> u64 {
    if (inst == 0 || inst.phi_args == 0) { return 0; }
    var n: u64 = inst.phi_args.len();
    if (limit_idx < n) { n = limit_idx; }
    for (var i: u64 = 0; i < n; i = i + 1) {
        var prev: *LLVMSSAPhiArgSketch = inst.phi_args.get(i);
        if (prev == 0 || prev.block_id != arg_block_id) { continue; }
        if (llvm_contract_ll_block_has_edge_to_impl(sketch, prev.block_id, target_block_id) == 0) { continue; }
        return 1;
    }
    return 0;
}

func llvm_contract_ll_reg_is_bool_depth_impl(fn: *AstFunc, sketch: *LLVMSSAFuncSketch, reg_id: u64, depth: u64) -> u64 {
    if (depth > 32) { return 0; }
    if (sketch == 0 || sketch.blocks == 0 || reg_id == 0) { return 0; }
    var nb: u64 = sketch.blocks.len();
    for (var bi: u64 = 0; bi < nb; bi = bi + 1) {
        var block: *LLVMSSABlockSketch = sketch.blocks.get(bi);
        if (block == 0 || block.insts == 0) { continue; }
        var ni: u64 = block.insts.len();
        for (var ii: u64 = 0; ii < ni; ii = ii + 1) {
            var inst: *LLVMSSAInstSketch = block.insts.get(ii);
            if (inst == 0 || inst.dest != reg_id) { continue; }
            if (inst.op == SSA_OP_EQ || inst.op == SSA_OP_NE ||
                inst.op == SSA_OP_LT || inst.op == SSA_OP_GT ||
                inst.op == SSA_OP_LE || inst.op == SSA_OP_GE ||
                inst.op == SSA_OP_ULT || inst.op == SSA_OP_UGT ||
                inst.op == SSA_OP_ULE || inst.op == SSA_OP_UGE ||
                inst.op == SSA_OP_FEQ || inst.op == SSA_OP_FNE ||
                inst.op == SSA_OP_FLT || inst.op == SSA_OP_FGT ||
                inst.op == SSA_OP_FLE || inst.op == SSA_OP_FGE) {
                return 1;
            }
            if (inst.op == SSA_OP_COPY && inst.has_src1 != 0 && inst.src1_is_const == 0) {
                return llvm_contract_ll_reg_is_bool_depth_impl(fn, sketch, inst.src1_value, depth + 1);
            }
            if (inst.op == SSA_OP_PHI && inst.phi_args != 0 && inst.phi_args.len() != 0) {
                var all_boolish: u64 = 1;
                var saw_bool: u64 = 0;
                for (var pi: u64 = 0; pi < inst.phi_args.len(); pi = pi + 1) {
                    var phi_arg: *LLVMSSAPhiArgSketch = inst.phi_args.get(pi);
                    if (phi_arg == 0 || phi_arg.val == 0 || phi_arg.val == reg_id) { continue; }
                    var phi_bool_const: u64 = 0;
                    if (llvm_contract_ll_try_eval_const_reg_impl(sketch, phi_arg.val, 18446744073709551615, 18446744073709551615, 0, &phi_bool_const) != 0 &&
                        (phi_bool_const == 0 || phi_bool_const == 1)) {
                        continue;
                    }
                    var phi_arg_ty: u64 = llvm_contract_ll_reg_value_type_depth_impl(fn, sketch, phi_arg.val, depth + 1);
                    if (phi_arg_ty == TYPE_BOOL || llvm_contract_ll_reg_is_bool_depth_impl(fn, sketch, phi_arg.val, depth + 1) != 0) {
                        saw_bool = 1;
                        continue;
                    }
                    all_boolish = 0;
                    break;
                }
                if (saw_bool != 0 && all_boolish != 0) { return 1; }
                return 0;
            }
            if (inst.op == SSA_OP_CALL && inst.has_src1 != 0 && inst.src1_is_const != 0) {
                var call_info: *SSACallInfo = (*SSACallInfo)inst.src1_value;
                if (call_info != 0 && call_info.ret_ptr_depth == 0 && call_info.ret_type == TYPE_BOOL) { return 1; }
            }
            if (inst.op == SSA_OP_CALL_PTR && inst.has_src1 != 0 && inst.src1_is_const != 0) {
                var call_ptr_info: *SSACallPtrInfo = (*SSACallPtrInfo)inst.src1_value;
                if (call_ptr_info != 0 && call_ptr_info.ret_ptr_depth == 0 && call_ptr_info.ret_type == TYPE_BOOL) { return 1; }
            }
            return 0;
        }
    }
    return 0;
}

func llvm_contract_ll_reg_is_bool_impl(fn: *AstFunc, sketch: *LLVMSSAFuncSketch, reg_id: u64) -> u64 {
    return llvm_contract_ll_reg_is_bool_depth_impl(fn, sketch, reg_id, 0);
}

func llvm_contract_ll_emit_ssa_body_impl(program: *AstProgram, fn: *AstFunc, sketch: *LLVMSSAFuncSketch) -> u64 {
    if (program == 0 || fn == 0 || sketch == 0 || sketch.blocks == 0 || sketch.blocks.len() == 0) { return 0; }
    emitln(" {");
    emitln("entry:");
    if (u8_slice_ptr(fn.name) != 0 &&
        u8_slice_len(fn.name) == 4 &&
        str_eq(fn.name, slice("main", str_len("main"))) != 0) {
        var global_init_fn: *AstFunc = llvm_contract_program_find_func_impl(program, slice("__global_init", 13));
        if (global_init_fn != 0) {
            emitln("  call void @\"__global_init\"()");
        }
    }
    llvm_contract_ll_emit_local_allocas_impl(program, fn, sketch);
    llvm_contract_ll_store_param_aggregate_materialization_impl(program, fn, sketch);
    var nb: u64 = sketch.blocks.len();
    for (var bi: u64 = 0; bi < nb; bi = bi + 1) {
        var block: *LLVMSSABlockSketch = sketch.blocks.get(bi);
        if (llvm_contract_ll_block_has_meaningful_inst_impl(block) == 0) { continue; }
        if (!(bi == 0 && block.id == sketch.entry_block_id)) {
            llvm_contract_ll_emit_block_label_impl(sketch, block.id);
            emitln(":");
        }
        var n: u64 = block.insts.len();
        var saw_terminator: u64 = 0;
        for (var i: u64 = 0; i < n; i = i + 1) {
            var inst: *LLVMSSAInstSketch = block.insts.get(i);
            if (inst == 0) { continue; }
            if (saw_terminator != 0) { continue; }
            match (inst.op) {
                case SSA_OP_NOP:
                    break;
                case SSA_OP_PHI:
                    var phi_ty: u64 = llvm_contract_ll_reg_value_type_impl(fn, sketch, inst.dest);
                    var has_phi_arg: u64 = 0;
                    if (inst.phi_args != 0) {
                        var pre_pn: u64 = inst.phi_args.len();
                        for (var pre_pi: u64 = 0; pre_pi < pre_pn; pre_pi = pre_pi + 1) {
                            var pre_phi_arg: *LLVMSSAPhiArgSketch = inst.phi_args.get(pre_pi);
                            if (pre_phi_arg == 0) { continue; }
                            if (llvm_contract_ll_block_has_edge_to_impl(sketch, pre_phi_arg.block_id, block.id) == 0) { continue; }
                            has_phi_arg = 1;
                            break;
                        }
                    }
                    emit("  %r");
                    print_u64(inst.dest);
                    if (has_phi_arg == 0) {
                        if (phi_ty == TYPE_F64) { emitln(" = fadd double 0.0, 0.0"); }
                        else if (phi_ty == TYPE_BOOL) { emitln(" = icmp ne i64 0, 0"); }
                        else { emitln(" = add i64 0, 0"); }
                        break;
                    }
                    emit(" = phi ");
                    if (phi_ty == TYPE_F64) { emit("double "); }
                    else if (phi_ty == TYPE_BOOL) { emit("i1 "); }
                    else { emit("i64 "); }
                    if (inst.phi_args != 0) {
                        var pn: u64 = inst.phi_args.len();
                        var emitted_phi_arg: u64 = 0;
                        for (var pi: u64 = 0; pi < pn; pi = pi + 1) {
                            var phi_arg: *LLVMSSAPhiArgSketch = inst.phi_args.get(pi);
                            if (phi_arg == 0) { continue; }
                            if (llvm_contract_ll_block_has_edge_to_impl(sketch, phi_arg.block_id, block.id) == 0) { continue; }
                            if (llvm_contract_ll_phi_arg_seen_before_impl(sketch, inst, block.id, phi_arg.block_id, pi) != 0) { continue; }
                            if (emitted_phi_arg != 0) { emit(", "); }
                            emitted_phi_arg = 1;
                            emit("[ ");
                            if (phi_arg.val == 0) {
                                if (phi_ty == TYPE_F64) { emit("0.0"); }
                                else if (phi_ty == TYPE_BOOL) { emit("0"); }
                                else { emit("0"); }
                            } else if (phi_ty == TYPE_F64) {
                                emit("%r");
                                print_u64(phi_arg.val);
                            } else if (phi_ty == TYPE_BOOL) {
                                if (llvm_contract_ll_reg_value_type_impl(fn, sketch, phi_arg.val) == TYPE_BOOL ||
                                    llvm_contract_ll_reg_is_bool_impl(fn, sketch, phi_arg.val) != 0) {
                                    emit("%r");
                                    print_u64(phi_arg.val);
                                } else {
                                    var phi_bool_const: u64 = 0;
                                    if (llvm_contract_ll_try_eval_const_reg_impl(sketch, phi_arg.val, bi, i, 0, &phi_bool_const) != 0) {
                                        if (phi_bool_const != 0) { emit("1"); }
                                        else { emit("0"); }
                                    } else {
                                        emit("%r");
                                        print_u64(phi_arg.val);
                                    }
                                }
                            } else {
                                emit("%r");
                                print_u64(phi_arg.val);
                            }
                            emit(", %");
                            llvm_contract_ll_emit_block_label_impl(sketch, phi_arg.block_id);
                            emit(" ]");
                        }
                    }
                    emit("\n");
                    break;
                case SSA_OP_LEA_STR:
                    var str_info: *PtrLen = (*PtrLen)inst.src1_value;
                    emit("  %r");
                    print_u64(inst.dest);
                    emit(" = ptrtoint ptr getelementptr inbounds ([");
                    if (str_info == 0 || str_info.ptr == 0 || str_info.len == 0) { emit("1"); }
                    else { print_u64(llvm_contract_ll_string_data_len_impl(slice(str_info.ptr, str_info.len))); }
                    emit(" x i8], ptr ");
                    llvm_contract_ll_emit_string_global_name_impl(sketch.fn_id, block.id, i);
                    emit(", i64 0, i64 0) to i64\n");
                    break;
                case SSA_OP_LEA_LOCAL:
                    emit("  %r");
                    print_u64(inst.dest);
                    emit(" = ptrtoint ptr ");
                    llvm_contract_ll_emit_local_slot_name_impl(1, inst.src1_value);
                    emit(" to i64\n");
                    break;
                case SSA_OP_LEA_GLOBAL:
                    var ginfo_name: *PtrLen = (*PtrLen)inst.src1_value;
                    emit("  %r");
                    print_u64(inst.dest);
                    emit(" = ptrtoint ptr ");
                    if (ginfo_name != 0 && ginfo_name.ptr != 0 && ginfo_name.len != 0) {
                        llvm_contract_emit_global_symbol_name_impl(slice(ginfo_name.ptr, ginfo_name.len));
                    } else {
                        emit("null");
                    }
                    emit(" to i64\n");
                    break;
                case SSA_OP_LEA_FUNC:
                    emit("  %r");
                    print_u64(inst.dest);
                    emit(" = ptrtoint ptr ");
                    var fn_info: *PtrLen = (*PtrLen)inst.src1_value;
                    if (fn_info == 0 || fn_info.ptr == 0 || fn_info.len == 0) {
                        emit("null");
                    } else {
                        llvm_contract_emit_quoted_symbol_impl(slice(fn_info.ptr, fn_info.len));
                    }
                    emit(" to i64\n");
                    break;
                case SSA_OP_LOAD:
                    var load_ty: u64 = llvm_contract_ll_var_slot_type_impl(fn, sketch, inst.src1_value);
                    if (load_ty == TYPE_F64) {
                        emit("  %r");
                        print_u64(inst.dest);
                        emit(" = load double, ptr ");
                        llvm_contract_ll_emit_local_slot_name_impl(2, inst.src1_value);
                        emit("\n");
                    } else if (load_ty == TYPE_BOOL) {
                        emit("  %load");
                        print_u64(block.id);
                        emit("_");
                        print_u64(i);
                        emit(" = load i1, ptr ");
                        llvm_contract_ll_emit_local_slot_name_impl(2, inst.src1_value);
                        emit("\n");
                        emit("  %r");
                        print_u64(inst.dest);
                        emit(" = zext i1 %load");
                        print_u64(block.id);
                        emit("_");
                        print_u64(i);
                        emit(" to i64\n");
                    } else if (load_ty == TYPE_U8 || load_ty == TYPE_I8 ||
                               load_ty == TYPE_U16 || load_ty == TYPE_I16 ||
                               load_ty == TYPE_U32 || load_ty == TYPE_I32) {
                        emit("  %load");
                        print_u64(block.id);
                        emit("_");
                        print_u64(i);
                        emit(" = load ");
                        if (load_ty == TYPE_U8 || load_ty == TYPE_I8) { emit("i8"); }
                        else if (load_ty == TYPE_U16 || load_ty == TYPE_I16) { emit("i16"); }
                        else { emit("i32"); }
                        emit(", ptr ");
                        llvm_contract_ll_emit_local_slot_name_impl(2, inst.src1_value);
                        emit("\n");
                        emit("  %r");
                        print_u64(inst.dest);
                        emit(" = ");
                        if (load_ty == TYPE_U8 || load_ty == TYPE_U16 || load_ty == TYPE_U32) { emit("zext "); }
                        else { emit("sext "); }
                        if (load_ty == TYPE_U8 || load_ty == TYPE_I8) { emit("i8 "); }
                        else if (load_ty == TYPE_U16 || load_ty == TYPE_I16) { emit("i16 "); }
                        else { emit("i32 "); }
                        emit("%load");
                        print_u64(block.id);
                        emit("_");
                        print_u64(i);
                        emit(" to i64\n");
                    } else {
                        emit("  %r");
                        print_u64(inst.dest);
                        emit(" = load i64, ptr ");
                        llvm_contract_ll_emit_local_slot_name_impl(2, inst.src1_value);
                        emit("\n");
                    }
                    break;
                case SSA_OP_STORE:
                    if (llvm_contract_ll_is_materialized_param_store_impl(program, fn, sketch, bi, i, inst) != 0) { break; }
                    var store_ty: u64 = llvm_contract_ll_var_slot_type_impl(fn, sketch, inst.src1_value);
                    if (store_ty == TYPE_F64) {
                        emit("  store double ");
                        llvm_contract_ll_emit_float_value_impl(inst, 2);
                        emit(", ptr ");
                        llvm_contract_ll_emit_local_slot_name_impl(2, inst.src1_value);
                        emit("\n");
                    } else if (store_ty == TYPE_BOOL) {
                        if (inst.src2_is_const != 0) {
                            emit("  store i1 ");
                            if (inst.src2_value != 0) { emit("1"); } else { emit("0"); }
                            emit(", ptr ");
                            llvm_contract_ll_emit_local_slot_name_impl(2, inst.src1_value);
                            emit("\n");
                        } else if (llvm_contract_ll_reg_is_bool_impl(fn, sketch, inst.src2_value) != 0) {
                            emit("  store i1 %r");
                            print_u64(inst.src2_value);
                            emit(", ptr ");
                            llvm_contract_ll_emit_local_slot_name_impl(2, inst.src1_value);
                            emit("\n");
                        } else {
                            emit("  %store");
                            print_u64(block.id);
                            emit("_");
                            print_u64(i);
                            emit(" = trunc i64 %r");
                            print_u64(inst.src2_value);
                            emit(" to i1\n");
                            emit("  store i1 %store");
                            print_u64(block.id);
                            emit("_");
                            print_u64(i);
                            emit(", ptr ");
                            llvm_contract_ll_emit_local_slot_name_impl(2, inst.src1_value);
                            emit("\n");
                        }
                    } else if (store_ty == TYPE_U8 || store_ty == TYPE_I8 ||
                               store_ty == TYPE_U16 || store_ty == TYPE_I16 ||
                               store_ty == TYPE_U32 || store_ty == TYPE_I32) {
                        emit("  %store");
                        print_u64(block.id);
                        emit("_");
                        print_u64(i);
                        emit(" = trunc i64 ");
                        llvm_contract_ll_emit_ssa_value_impl(inst, 2);
                        emit(" to ");

func llvm_contract_ll_infer_local_slot_span_impl(sketch: *LLVMSSAFuncSketch, enc: u64) -> u64 {
    if (sketch == 0 || sketch.blocks == 0 || enc == 0) { return 0; }
    var cur_off: i64 = llvm_contract_ll_decode_local_enc_offset_impl(enc);
    var found_prev: u64 = 0;
    var prev_off: i64 = 0;
    var nb: u64 = sketch.blocks.len();
    for (var bi: u64 = 0; bi < nb; bi = bi + 1) {
        var block: *LLVMSSABlockSketch = sketch.blocks.get(bi);
        if (block == 0 || block.insts == 0) { continue; }
        var ni: u64 = block.insts.len();
        for (var ii: u64 = 0; ii < ni; ii = ii + 1) {
            var inst: *LLVMSSAInstSketch = block.insts.get(ii);
            if (inst == 0 || inst.op != SSA_OP_LEA_LOCAL || inst.has_src1 == 0 || inst.src1_is_const == 0) { continue; }
            var other_enc: u64 = inst.src1_value;
            if (other_enc == enc) { continue; }
            var other_off: i64 = llvm_contract_ll_decode_local_enc_offset_impl(other_enc);
            if (other_off <= cur_off) { continue; }
            if (found_prev == 0 || other_off < prev_off) {
                found_prev = 1;
                prev_off = other_off;
            }
        }
    }
    if (found_prev == 0) {
        if (cur_off < 0) { return (u64)(0 - cur_off); }
        return 0;
    }
    var span: i64 = prev_off - cur_off;
    if (span <= 0) { return 0; }
    return (u64)span;
}

func llvm_contract_ll_reg_is_direct_local_addr_impl(sketch: *LLVMSSAFuncSketch, reg_id: u64, block_limit: u64, inst_limit: u64, depth: u64) -> u64 {

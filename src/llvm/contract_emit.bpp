func llvm_contract_ll_emit_simple_asm_store_impl(sketch: *LLVMSSAFuncSketch, inst: *LLVMSSAInstSketch) -> u64 {
    if (sketch == 0 || inst == 0 || inst.has_src1 == 0 || inst.src1_is_const == 0 || inst.src1_value == 0) { return 0; }
    var text_vec: *Vec<u64> = (*Vec<u64>)inst.src1_value;
    var bias: u64 = 4611686018427387904;
    var emitted: u64 = 0;
    var search_idx: u64 = 0;
    while (search_idx < text_vec.len()) {
        var rbp_off: u64 = 0;
        var store_reg: u64 = 0;
        var store_idx: u64 = 0;
        var next_idx: u64 = 0;
        if (llvm_contract_asm_find_rbp_store_from_impl(text_vec, search_idx, &rbp_off, &store_reg, &store_idx, &next_idx) == 0) { break; }
        var value: u64 = 0;
        if (llvm_contract_asm_find_mov_const_before_impl(text_vec, store_reg, store_idx, &value) == 0) { return 0; }
        if (rbp_off > bias) { return 0; }
        var enc: u64 = bias - rbp_off;
        if (llvm_contract_ll_sketch_has_local_slot_impl(sketch, 1, enc, 18446744073709551615, 18446744073709551615) == 0) { return 0; }
        emit("  store i64 ");
        print_u64(value);
        emit(", ptr ");
        llvm_contract_ll_emit_local_slot_name_impl(1, enc);
        emit("\n");
        emitted = 1;
        if (next_idx <= search_idx) { search_idx = search_idx + 1; }
        else { search_idx = next_idx; }
    }
    return emitted;
}

func llvm_contract_ll_reg_value_type_origin_depth_impl(fn: *AstFunc, sketch: *LLVMSSAFuncSketch, reg_id: u64, origin_id: u64, depth: u64) -> u64 {
    if (depth > 32) { return TYPE_U64; }
    if (sketch == 0 || sketch.blocks == 0 || reg_id == 0) { return TYPE_U64; }
    var inst: *LLVMSSAInstSketch = llvm_contract_ll_find_inst_by_dest_impl(sketch, reg_id, 18446744073709551615, 18446744073709551615);
    if (inst == 0) { return TYPE_U64; }
            if (inst.op == SSA_OP_FCONST || inst.op == SSA_OP_FADD || inst.op == SSA_OP_FSUB ||
                inst.op == SSA_OP_FMUL || inst.op == SSA_OP_FDIV || inst.op == SSA_OP_FNEG ||
                inst.op == SSA_OP_I2F || inst.op == SSA_OP_U2F) { return TYPE_F64; }
            if (inst.op == SSA_OP_LOAD64 && llvm_contract_ll_reg_has_f64_use_impl(fn, sketch, reg_id) != 0) { return TYPE_F64; }
            if (inst.op == SSA_OP_FEQ || inst.op == SSA_OP_FNE || inst.op == SSA_OP_FLT ||
                inst.op == SSA_OP_FGT || inst.op == SSA_OP_FLE || inst.op == SSA_OP_FGE ||
                inst.op == SSA_OP_EQ || inst.op == SSA_OP_NE || inst.op == SSA_OP_LT ||
                inst.op == SSA_OP_GT || inst.op == SSA_OP_LE || inst.op == SSA_OP_GE ||
                inst.op == SSA_OP_ULT || inst.op == SSA_OP_UGT || inst.op == SSA_OP_ULE ||
                inst.op == SSA_OP_UGE) { return TYPE_BOOL; }
            if (inst.op == SSA_OP_COPY && inst.has_src1 != 0) {
                if (inst.src1_is_const != 0) { return TYPE_U64; }
                if (inst.src1_value == origin_id) { return TYPE_U64; }
                return llvm_contract_ll_reg_value_type_origin_depth_impl(fn, sketch, inst.src1_value, origin_id, depth + 1);
            }
            if (inst.op == SSA_OP_PHI && inst.phi_args != 0 && inst.phi_args.len() != 0) {
                var all_boolish: u64 = 1;
                var saw_bool: u64 = 0;
                var all_f64: u64 = 1;
                var saw_any: u64 = 0;
                for (var pi: u64 = 0; pi < inst.phi_args.len(); pi = pi + 1) {
                    var phi_arg: *LLVMSSAPhiArgSketch = inst.phi_args.get(pi);
                    if (phi_arg == 0 || phi_arg.val == 0 || phi_arg.val == reg_id || phi_arg.val == origin_id) { continue; }
                    saw_any = 1;
                    var phi_bool_const: u64 = 0;
                    if (llvm_contract_ll_try_eval_const_reg_impl(sketch, phi_arg.val, 18446744073709551615, 18446744073709551615, 0, &phi_bool_const) != 0 &&
                        (phi_bool_const == 0 || phi_bool_const == 1)) {
                        all_f64 = 0;
                        continue;
                    }
                    var phi_arg_ty: u64 = llvm_contract_ll_reg_value_type_origin_depth_impl(fn, sketch, phi_arg.val, origin_id, depth + 1);
                    if (phi_arg_ty == TYPE_BOOL) {
                        saw_bool = 1;
                        all_f64 = 0;
                        continue;
                    }
                    if (phi_arg_ty == TYPE_F64) {
                        all_boolish = 0;
                        continue;
                    }
                    all_boolish = 0;
                    all_f64 = 0;
                }
                if (saw_bool != 0 && all_boolish != 0) { return TYPE_BOOL; }
                if (saw_any != 0 && all_f64 != 0) { return TYPE_F64; }
                return TYPE_U64;
            }
            if (inst.op == SSA_OP_PARAM && fn != 0) {
                var param_ti: *Param = llvm_contract_fn_param_from_abi_index_from_program_impl(0, fn, inst.src1_value);
                if (param_ti != 0) {
                    if (param_ti.ptr_depth != 0) { return TYPE_U64; }
                    if (param_ti.type_kind == TYPE_ARRAY || param_ti.type_kind == TYPE_STRUCT || param_ti.type_kind == TYPE_SLICE) { return TYPE_U64; }
                    return param_ti.type_kind;
                }
            }
            if (inst.op == SSA_OP_CALL && inst.has_src1 != 0 && inst.src1_is_const != 0) {
                var info: *SSACallInfo = (*SSACallInfo)inst.src1_value;
                if (info != 0 && info.ret_ptr_depth == 0 && info.ret_type != 0) { return info.ret_type; }
            }
            if (inst.op == SSA_OP_CALL_PTR && inst.has_src1 != 0 && inst.src1_is_const != 0) {
                var info2: *SSACallPtrInfo = (*SSACallPtrInfo)inst.src1_value;
                if (info2 != 0 && info2.ret_ptr_depth == 0 && info2.ret_type != 0) { return info2.ret_type; }
            }
            return TYPE_U64;
}


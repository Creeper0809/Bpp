                    }
                    ret_type_eff = info_ptr.ret_type;
                    ret_ptr_depth_eff = info_ptr.ret_ptr_depth;
                    ret_struct_size_eff = info_ptr.ret_struct_size;
                    if (callee2 != 0) {
                        ret_type_eff = callee2.ret_type;
                        ret_ptr_depth_eff = callee2.ret_ptr_depth;
                        ret_struct_size_eff = llvm_contract_fn_struct_ret_size_from_program_impl(program, callee2);
                    }
                    nargs = llvm_contract_call_args_len_impl(info_ptr.args_vec, info_ptr.nargs);
                    for (var ai2: u64 = 0; ai2 < nargs; ai2 = ai2 + 1) {
                        var arg_reg2: u64 = info_ptr.args_vec.get(ai2);
                        var base_enc3: u64 = 0;
                        var off3: u64 = 0;
                        if (llvm_contract_ll_find_reg_local_base_offset_impl(sketch, arg_reg2, bi, ii, 0, &base_enc3, &off3) == 0 || base_enc3 != enc) { continue; }
                        var part3: LLVMABIParamPartInfo = llvm_contract_fn_abi_part_info_from_program_impl(program, callee2, ai2);
                        if (part3.found == 0) { if (off3 + 8 > max_size) { max_size = off3 + 8; } continue; }
                        if (part3.type_kind == TYPE_STRUCT && part3.ptr_depth != 0 && callee2 != 0 && callee2.params_vec != 0 && part3.param_index < callee2.params_vec.len()) {
                            var ptr_param2: *Param = callee2.params_vec.get(part3.param_index);
                            if (ptr_param2 != 0) {
                                var pointee_sz2: u64 = llvm_contract_struct_size_impl(program, ptr_param2.struct_name);
                                if (pointee_sz2 > 0 && off3 + pointee_sz2 > max_size) { max_size = off3 + pointee_sz2; }
                            }
                        }
                        if ((part3.role == LLVM_ABI_ROLE_SMALL_STRUCT_LO || part3.role == LLVM_ABI_ROLE_SMALL_STRUCT_HI) &&
                            part3.struct_size > 8 && part3.struct_size < 16 && off3 + 16 > max_size) {
                            max_size = off3 + 16;
                        }
                        if (part3.struct_size != 0 && off3 + part3.struct_size > max_size) { max_size = off3 + part3.struct_size; }
                        else if (off3 + 8 > max_size) { max_size = off3 + 8; }
                    }
                }
                if (ret_type_eff == TYPE_STRUCT && ret_ptr_depth_eff == 0) {
                    if (ret_struct_size_eff > 8 && ret_struct_size_eff <= 16 && inst.dest != 0) {
                        var spill_enc: u64 = 0;
                        var spill_off: u64 = 0;
                        if (llvm_contract_ll_find_future_store_target_for_value_reg_impl(sketch, bi, ii, inst.dest, &spill_enc, &spill_off) != 0 && spill_enc == enc) {
                            if (spill_off + ret_struct_size_eff > max_size) { max_size = spill_off + ret_struct_size_eff; }
                        }
                    } else if (ret_struct_size_eff > 16) {
                        var sret_enc: u64 = llvm_contract_ll_find_nearest_call_sret_local_impl(sketch, bi, ii);
                        if (sret_enc == enc && ret_struct_size_eff > max_size) { max_size = ret_struct_size_eff; }
                    }
                }
            }
            if (inst.op == SSA_OP_CALL_SLICE_STORE && inst.has_src2 != 0 && inst.src2_is_const == 0) {
                var base_enc4: u64 = 0;
                var off4: u64 = 0;
                if (llvm_contract_ll_find_reg_local_base_offset_impl(sketch, inst.src2_value, bi, ii, 0, &base_enc4, &off4) != 0 && base_enc4 == enc) {
                    if (off4 + 16 > max_size) { max_size = off4 + 16; }
                }
            }
        }
    }
    var span_fallback: u64 = llvm_contract_ll_infer_local_slot_span_impl(sketch, enc);
    if (span_fallback > max_size) { max_size = span_fallback; }
    if (max_size == 0) { return 256; }
    if (max_size < 16) { return 16; }
    return max_size;
}

func llvm_contract_ll_emit_local_allocas_impl(program: *AstProgram, fn: *AstFunc, sketch: *LLVMSSAFuncSketch) -> u64 {
    if (sketch == 0 || sketch.blocks == 0) { return 0; }
    var nb: u64 = sketch.blocks.len();
    for (var bi: u64 = 0; bi < nb; bi = bi + 1) {
        var block: *LLVMSSABlockSketch = sketch.blocks.get(bi);
        if (block == 0 || block.insts == 0) { continue; }
        var ni: u64 = block.insts.len();
        for (var ii: u64 = 0; ii < ni; ii = ii + 1) {
            var inst: *LLVMSSAInstSketch = block.insts.get(ii);
            if (inst == 0) { continue; }
            if (inst.op == SSA_OP_LEA_LOCAL && inst.has_src1 != 0 && inst.src1_is_const != 0) {
                var enc: u64 = inst.src1_value;
                if (llvm_contract_ll_sketch_has_local_slot_impl(sketch, 1, enc, bi, ii) == 0) {
                    var local_size: u64 = llvm_contract_ll_infer_local_slot_size_impl(program, sketch, enc);
                    emit("  ");
                    llvm_contract_ll_emit_local_slot_name_impl(1, enc);
                    emit(" = alloca i8, i64 ");
                    print_u64(local_size);
                    emit("\n");
                    emit("  call void @\"llvm.memset.p0.i64\"(ptr ");
                    llvm_contract_ll_emit_local_slot_name_impl(1, enc);
                    emit(", i8 0, i64 ");
                    print_u64(local_size);
                    emit(", i1 false)\n");
                }
                continue;
            }
            if ((inst.op == SSA_OP_LOAD || inst.op == SSA_OP_STORE) && inst.has_src1 != 0 && inst.src1_is_const != 0) {
                var var_id: u64 = inst.src1_value;
                if (llvm_contract_ll_sketch_has_local_slot_impl(sketch, 2, var_id, bi, ii) == 0) {
                    emit("  ");
                    llvm_contract_ll_emit_local_slot_name_impl(2, var_id);
                    emit(" = alloca ");
                    var var_type: u64 = llvm_contract_ll_var_slot_type_impl(fn, sketch, var_id);
                    if (var_type == TYPE_F64) { emitln("double"); }
                    else if (var_type == TYPE_BOOL) { emitln("i1"); }
                    else if (var_type == TYPE_U8 || var_type == TYPE_I8) { emitln("i8"); }
                    else if (var_type == TYPE_U16 || var_type == TYPE_I16) { emitln("i16"); }
                    else if (var_type == TYPE_U32 || var_type == TYPE_I32) { emitln("i32"); }
                    else { emitln("i64"); }
                }
            }
        }
    }
    return 0;
}

func llvm_contract_ll_emit_call_arg_ptr_casts_impl(program: *AstProgram, sketch: *LLVMSSAFuncSketch, block_idx: u64, inst_idx: u64, info: *SSACallInfo) -> u64 {
    if (info == 0 || info.args_vec == 0) { return 0; }
    var callee: *AstFunc = llvm_contract_program_find_func_impl(program, info.name);
    var abi_nargs: u64 = llvm_contract_call_args_len_impl(info.args_vec, info.nargs);
    var src_nargs: u64 = llvm_contract_call_args_len_impl(info.args_vec, info.nargs);
    if (callee != 0) {
        var abi_count: u64 = llvm_contract_fn_abi_param_count_from_program_impl(program, callee);
        if (abi_count > abi_nargs) { abi_nargs = abi_count; }
    }
    for (var i: u64 = 0; i < abi_nargs; i = i + 1) {
        var arg_reg: u64 = 0;
        var src_arg_idx: u64 = i;
        if (callee != 0) { src_arg_idx = llvm_contract_fn_source_arg_index_for_abi_part_impl(program, callee, i, src_nargs); }
        if (src_arg_idx != 18446744073709551615 && src_arg_idx < src_nargs) { arg_reg = info.args_vec.get(src_arg_idx); }
        var part: LLVMABIParamPartInfo = llvm_contract_fn_abi_part_info_from_program_impl(program, callee, i);
        if (part.found == 0 && info.ret_type == TYPE_STRUCT && info.ret_ptr_depth == 0 && info.ret_struct_size > 16 && i == 0) {
            part.found = 1;
            part.role = LLVM_ABI_ROLE_SRET;
            part.ptr_depth = 1;
            part.type_kind = TYPE_U64;
            part.struct_size = info.ret_struct_size;
        }
        if (part.found == 0) { continue; }
        if (part.role == LLVM_ABI_ROLE_SRET && arg_reg == 0 && src_arg_idx == 18446744073709551615) { continue; }
        var enc: u64 = llvm_contract_ll_find_reg_aggregate_base_impl(sketch, arg_reg, block_idx, inst_idx);
        if ((part.role == LLVM_ABI_ROLE_SMALL_STRUCT_LO || part.role == LLVM_ABI_ROLE_SMALL_STRUCT_HI) && enc != 0) {
            emit("  %argagg");
            print_u64(block_idx);
            emit("_");
            print_u64(inst_idx);
            emit("_");
            print_u64(i);
            if (part.role == LLVM_ABI_ROLE_SMALL_STRUCT_HI) {
                emit(" = getelementptr i8, ptr ");
                llvm_contract_ll_emit_local_slot_name_impl(1, enc);
                emit(", i64 8\n");
                emit("  %argagg");
                print_u64(block_idx);
                emit("_");
                print_u64(inst_idx);
                emit("_");
                print_u64(i);
                emit("_v = load i64, ptr %argagg");
                print_u64(block_idx);
                emit("_");
                print_u64(inst_idx);
                emit("_");
                print_u64(i);
                emit("\n");
            } else {
                emit(" = load i64, ptr ");
                llvm_contract_ll_emit_local_slot_name_impl(1, enc);
                emit("\n");
            }
            continue;
        }
        if (part.ptr_depth != 0) {
            if ((part.role == LLVM_ABI_ROLE_LARGE_STRUCT_PTR || part.role == LLVM_ABI_ROLE_ARRAY_PTR) && enc != 0) { continue; }
            if (enc != 0 && llvm_contract_ll_reg_is_direct_local_addr_impl(sketch, arg_reg, block_idx, inst_idx, 0) != 0) { continue; }
            if (src_arg_idx == 18446744073709551615) { continue; }
            emit("  %argptr");
            print_u64(block_idx);
            emit("_");
            print_u64(inst_idx);
            emit("_");
            print_u64(i);
            emit(" = inttoptr i64 %r");
            print_u64(arg_reg);
            emit(" to ptr\n");
            continue;
        }
        if (part.type_kind == TYPE_BOOL) {
            if (llvm_contract_ll_reg_is_bool_impl(callee, sketch, arg_reg) != 0) { continue; }
            emit("  %argcast");
            print_u64(block_idx);
            emit("_");
            print_u64(inst_idx);
            emit("_");
            print_u64(i);
            emit(" = trunc i64 %r");
            print_u64(arg_reg);
            emit(" to i1\n");
            continue;
        }
        if (part.type_kind == TYPE_U8 || part.type_kind == TYPE_I8 ||
            part.type_kind == TYPE_U16 || part.type_kind == TYPE_I16 ||
            part.type_kind == TYPE_U32 || part.type_kind == TYPE_I32) {
            emit("  %argcast");
            print_u64(block_idx);
            emit("_");
            print_u64(inst_idx);
            emit("_");
            print_u64(i);
            emit(" = trunc i64 %r");
            print_u64(arg_reg);
            emit(" to ");
            if (part.type_kind == TYPE_U8 || part.type_kind == TYPE_I8) { emit("i8"); }
            else if (part.type_kind == TYPE_U16 || part.type_kind == TYPE_I16) { emit("i16"); }
            else { emit("i32"); }

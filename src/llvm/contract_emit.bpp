                    emit(" = add i64 0, ");
                    llvm_contract_ll_emit_ssa_value_impl(inst, 2);
                    emit("\n");
                    emit("  %retslicesize");
                    print_u64(block.id);
                    emit("_");
                    print_u64(i);
                    emit(" = mul i64 %retslicelen");
                    print_u64(block.id);
                    emit("_");
                    print_u64(i);
                    emit(", ");
                    print_u64(inst.dest);
                    emit("\n");
                    emit("  %retsliceheap");
                    print_u64(block.id);
                    emit("_");
                    print_u64(i);
                    emit(" = call ptr @\"malloc\"(i64 %retslicesize");
                    print_u64(block.id);
                    emit("_");
                    print_u64(i);
                    emit(")\n");
                    var ret_heap_enc: u64 = llvm_contract_ll_find_reg_local_base_impl(sketch, inst.src1_value, bi, i);
                    if (ret_heap_enc != 0) {
                        emit("  call void @\"llvm.memcpy.p0.p0.i64\"(ptr %retsliceheap");

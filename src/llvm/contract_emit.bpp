const LLVM_TAG_SLICE_VEC_NONE = 0;
const LLVM_TAG_SLICE_VEC_TYPE_U64 = 1;
const LLVM_TAG_SLICE_VEC_TYPE_I64 = 2;
const LLVM_TAG_SLICE_VEC_TYPE_F64 = 3;
const LLVM_TAG_SLICE_VEC_OP_SUM = 1;
const LLVM_TAG_SLICE_VEC_OP_MIN = 2;
const LLVM_TAG_SLICE_VEC_OP_MAX = 3;
const LLVM_TAG_SLICE_VEC_OP_COUNT_EQ = 4;
const LLVM_TAG_SLICE_VEC_OP_FIND_EQ = 5;

struct LLVMTagSliceVectorIntrinsic {
    public op: u64;
    public ty: u64;
}

impl LLVMTagSliceVectorIntrinsic {
    public constructor() {
        self.op = LLVM_TAG_SLICE_VEC_NONE;
        self.ty = LLVM_TAG_SLICE_VEC_NONE;
    }
}

func llvm_contract_classify_std_mem_tag_slice_vector_impl(owner: []u8) -> LLVMTagSliceVectorIntrinsic {
    var out: LLVMTagSliceVectorIntrinsic;
    out.op = LLVM_TAG_SLICE_VEC_NONE;
    out.ty = LLVM_TAG_SLICE_VEC_NONE;
    if (owner.ptr == 0 || owner.len == 0) { return out; }
    var prefix: []u8 = slice("std_mem__bpp_tag_slice_", str_len("std_mem__bpp_tag_slice_"));
    var suffix_len: u64 = 4;
    if (llvm_contract_name_has_prefix_impl(owner, prefix) == 0) { return out; }
    if (owner.len <= prefix.len + suffix_len) { return out; }

    var suffix: []u8 = slice(owner.ptr + owner.len - suffix_len, suffix_len);
    if (str_eq(suffix, slice("_u64", str_len("_u64"))) != 0) {
        out.ty = LLVM_TAG_SLICE_VEC_TYPE_U64;
    } else if (str_eq(suffix, slice("_i64", str_len("_i64"))) != 0) {
        out.ty = LLVM_TAG_SLICE_VEC_TYPE_I64;
    } else if (str_eq(suffix, slice("_f64", str_len("_f64"))) != 0) {
        out.ty = LLVM_TAG_SLICE_VEC_TYPE_F64;
    } else {
        return out;
    }

    var op_len: u64 = owner.len - prefix.len - suffix_len;
    if (op_len == 0) {
        out.ty = LLVM_TAG_SLICE_VEC_NONE;
        return out;
    }
    var op_name: []u8 = slice(owner.ptr + prefix.len, op_len);
    if (str_eq(op_name, slice("sum", str_len("sum"))) != 0) {
        out.op = LLVM_TAG_SLICE_VEC_OP_SUM;
    } else if (str_eq(op_name, slice("min", str_len("min"))) != 0) {
        out.op = LLVM_TAG_SLICE_VEC_OP_MIN;
    } else if (str_eq(op_name, slice("max", str_len("max"))) != 0) {
        out.op = LLVM_TAG_SLICE_VEC_OP_MAX;
    } else if (str_eq(op_name, slice("count_eq", str_len("count_eq"))) != 0) {
        out.op = LLVM_TAG_SLICE_VEC_OP_COUNT_EQ;
    } else if (str_eq(op_name, slice("find_eq", str_len("find_eq"))) != 0 ||
               str_eq(op_name, slice("index_of", str_len("index_of"))) != 0) {
        out.op = LLVM_TAG_SLICE_VEC_OP_FIND_EQ;
    } else {
        out.ty = LLVM_TAG_SLICE_VEC_NONE;
    }
    return out;
}

func llvm_contract_owner_is_std_mem_tag_slice_vector_reduction_impl(owner: []u8) -> u64 {
    var intrinsic: LLVMTagSliceVectorIntrinsic = llvm_contract_classify_std_mem_tag_slice_vector_impl(owner);
    if (intrinsic.op != LLVM_TAG_SLICE_VEC_NONE && intrinsic.ty != LLVM_TAG_SLICE_VEC_NONE) { return 1; }
    return 0;
}

func llvm_contract_ll_emit_std_mem_tag_slice_vector_body_impl(owner: []u8) -> u64 {
    var intrinsic: LLVMTagSliceVectorIntrinsic = llvm_contract_classify_std_mem_tag_slice_vector_impl(owner);
    if (intrinsic.op == LLVM_TAG_SLICE_VEC_OP_SUM) {
        if (intrinsic.ty == LLVM_TAG_SLICE_VEC_TYPE_U64 || intrinsic.ty == LLVM_TAG_SLICE_VEC_TYPE_I64) {
            return llvm_contract_ll_emit_tag_slice_sum_i64_vector_body_impl();
        }
        if (intrinsic.ty == LLVM_TAG_SLICE_VEC_TYPE_F64) {
            return llvm_contract_ll_emit_tag_slice_sum_f64_vector_body_impl();
        }
    }
    if (intrinsic.op == LLVM_TAG_SLICE_VEC_OP_MIN || intrinsic.op == LLVM_TAG_SLICE_VEC_OP_MAX) {
        var is_max: u64 = 0;
        if (intrinsic.op == LLVM_TAG_SLICE_VEC_OP_MAX) { is_max = 1; }
        if (intrinsic.ty == LLVM_TAG_SLICE_VEC_TYPE_U64) {
            return llvm_contract_ll_emit_tag_slice_minmax_i64_vector_body_impl(0, is_max);
        }
        if (intrinsic.ty == LLVM_TAG_SLICE_VEC_TYPE_I64) {
            return llvm_contract_ll_emit_tag_slice_minmax_i64_vector_body_impl(1, is_max);
        }
        if (intrinsic.ty == LLVM_TAG_SLICE_VEC_TYPE_F64) {
            return llvm_contract_ll_emit_tag_slice_minmax_f64_vector_body_impl(is_max);
        }
    }
    if (intrinsic.op == LLVM_TAG_SLICE_VEC_OP_COUNT_EQ) {
        if (intrinsic.ty == LLVM_TAG_SLICE_VEC_TYPE_U64) {
            return llvm_contract_ll_emit_tag_slice_count_eq_i64_vector_body_impl(0);
        }
        if (intrinsic.ty == LLVM_TAG_SLICE_VEC_TYPE_I64) {
            return llvm_contract_ll_emit_tag_slice_count_eq_i64_vector_body_impl(1);
        }
        if (intrinsic.ty == LLVM_TAG_SLICE_VEC_TYPE_F64) {
            return llvm_contract_ll_emit_tag_slice_count_eq_f64_vector_body_impl();
        }

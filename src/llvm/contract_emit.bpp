func llvm_contract_dump_ll_skeleton_from_module_fd_impl(module: *LLVMSSAModuleSketch, adapter: *AnnLLVMContractAdapter, fd: u64) -> u64 {
    if (module == 0 || module.source_program == 0 || adapter == 0 || adapter.atoms == 0) { return 0; }
    var saved_fd: u64 = io_get_output_fd();
    io_set_output_fd(fd);
    emitln("; bpp llvm ll skeleton v1");
    emitln("source_filename = \"bpp-llvm-skeleton\"");
    emit("target triple = \"");
    emit(llvm_contract_target_triple_impl());
    emitln("\"");
    emit("\n");
    llvm_contract_ll_emit_global_defs_impl(module.source_program);
    llvm_contract_ll_emit_string_globals_impl(module);
    emit("\n");
    emitln("declare ptr @\"malloc\"(i64)");
    emitln("declare i64 @\"read\"(i32, ptr, i64)");
    emitln("declare i64 @\"write\"(i32, ptr, i64)");
    emitln("declare void @\"exit\"(i32)");
    emitln("declare void @\"llvm.memcpy.p0.p0.i64\"(ptr, ptr, i64, i1)");
    emitln("declare void @\"llvm.memset.p0.i64\"(ptr, i8, i64, i1)");
    emit("\n");
    var emit_names: *Vec<*PtrLen> = llvm_contract_collect_emit_names_impl(module, adapter);
    var nfuncs: u64 = 0;
    if (module.funcs != 0) { nfuncs = module.funcs.len(); }
    for (var fi: u64 = 0; fi < nfuncs; fi = fi + 1) {
        var sketch: *LLVMSSAFuncSketch = module.funcs.get(fi);
        if (sketch == 0 || u8_slice_ptr(sketch.name) == 0 || u8_slice_len(sketch.name) == 0) { continue; }
        if (llvm_contract_should_emit_func_cached_impl(module, adapter, sketch, emit_names) == 0) { continue; }
        llvm_contract_emit_func_sketch_comment_impl(sketch);
        llvm_contract_ll_emit_decl_or_def_impl(module.source_program, sketch.name, sketch);
    }
    llvm_contract_emit_i32_main_bridge_impl(module.source_program, adapter);
    emit("\n");
    var n: u64 = adapter.atoms.len();
    emitln("!bpp.contract = !{");
    for (var mi: u64 = 0; mi < n; mi = mi + 1) {
        emit("  !");
        print_u64(mi);
        if (mi + 1 < n) { emit(","); }
        emit("\n");
    }
    emitln("}");
    for (var i2: u64 = 0; i2 < n; i2 = i2 + 1) {
        var atom2: *AnnLLVMContractAtom = adapter.atoms.get(i2);
        if (atom2 == 0) { continue; }
        emit("!");
        print_u64(i2);
        emit(" = !{");
        llvm_contract_emit_md_string_impl(atom2.owner);
        emit(", ");
        llvm_contract_emit_md_string_impl(atom2.metadata_key);
        emit(", ");
        llvm_contract_emit_md_string_impl(atom2.module);
        emit(", ");
        llvm_contract_emit_md_string_impl(atom2.surface);
        emit(", ");
        llvm_contract_emit_md_string_impl(atom2.detail);
        emit(", i64 ");
        print_u64(atom2.family_mask);
        emit(", i64 ");
        print_u64(atom2.boundary_mask);
        emit(", i64 ");
        print_u64(atom2.decl_line);
        emit(", i64 ");
        print_u64(atom2.decl_col);
        emit(", i64 ");
        print_u64(atom2.related_decl_line);
        emit(", i64 ");
        print_u64(atom2.related_decl_col);
        if (u8_slice_ptr(atom2.related) != 0 && u8_slice_len(atom2.related) != 0) {
            emit(", ");
            llvm_contract_emit_md_string_impl(atom2.related);
        }
        if (u8_slice_ptr(atom2.aux) != 0 && u8_slice_len(atom2.aux) != 0) {
            emit(", ");
            llvm_contract_emit_md_string_impl(atom2.aux);
        }
        emitln("}");
    }
    io_set_output_fd(saved_fd);
    return 0;
}

func llvm_contract_dump_ll_skeleton_fd_impl(program: *AstProgram, adapter: *AnnLLVMContractAdapter, fd: u64) -> u64 {
    if (program == 0 || adapter == 0 || adapter.atoms == 0) { return 0; }
    var opts: *LLVMSSALoweringOptions = new LLVMSSALoweringOptions{};
    var module: *LLVMSSAModuleSketch = llvm_ssa_collect_module_sketch_from_program(program, adapter, opts);
    if (module == 0) { return 0; }
    if (llvm_ssa_validate_module_sketch(module) == 0) { return 0; }
    return llvm_contract_dump_ll_skeleton_from_module_fd_impl(module, adapter, fd);
}

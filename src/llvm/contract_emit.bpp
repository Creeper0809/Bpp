func llvm_contract_tag_generic_elem_size_from_owner_impl(owner: []u8, prefix: []u8) -> u64 {
    if (owner.ptr == 0 || owner.len == 0) { return 0; }
    if (llvm_contract_name_has_prefix_impl(owner, prefix) == 0) { return 0; }
    var suffix_len: u64 = owner.len - prefix.len;
    if (suffix_len == 3 && str_eq(slice(owner.ptr + prefix.len, suffix_len), slice("u64", str_len("u64"))) != 0) { return 8; }
    if (suffix_len == 3 && str_eq(slice(owner.ptr + prefix.len, suffix_len), slice("i64", str_len("i64"))) != 0) { return 8; }
    if (suffix_len == 3 && str_eq(slice(owner.ptr + prefix.len, suffix_len), slice("f64", str_len("f64"))) != 0) { return 8; }
    if (suffix_len == 3 && str_eq(slice(owner.ptr + prefix.len, suffix_len), slice("u32", str_len("u32"))) != 0) { return 4; }
    if (suffix_len == 3 && str_eq(slice(owner.ptr + prefix.len, suffix_len), slice("i32", str_len("i32"))) != 0) { return 4; }
    if (suffix_len == 3 && str_eq(slice(owner.ptr + prefix.len, suffix_len), slice("f32", str_len("f32"))) != 0) { return 4; }
    if (suffix_len == 3 && str_eq(slice(owner.ptr + prefix.len, suffix_len), slice("u16", str_len("u16"))) != 0) { return 2; }
    if (suffix_len == 3 && str_eq(slice(owner.ptr + prefix.len, suffix_len), slice("i16", str_len("i16"))) != 0) { return 2; }
    if (suffix_len == 2 && str_eq(slice(owner.ptr + prefix.len, suffix_len), slice("u8", str_len("u8"))) != 0) { return 1; }
    if (suffix_len == 2 && str_eq(slice(owner.ptr + prefix.len, suffix_len), slice("i8", str_len("i8"))) != 0) { return 1; }
    return 0;
}

func llvm_contract_tag_generic_elem_size_ext_from_owner_impl(owner: []u8, prefix: []u8) -> u64 {
    var out: u64 = llvm_contract_tag_generic_elem_size_from_owner_impl(owner, prefix);
    if (out != 0) { return out; }
    if (owner.ptr == 0 || owner.len == 0) { return 0; }
    if (llvm_contract_name_has_prefix_impl(owner, prefix) == 0) { return 0; }
    var suffix_len: u64 = owner.len - prefix.len;
    if (suffix_len == 7 && str_eq(slice(owner.ptr + prefix.len, suffix_len), slice("SNumber", str_len("SNumber"))) != 0) { return 8; }
    if (suffix_len == 1 && str_eq(slice(owner.ptr + prefix.len, suffix_len), slice("t", str_len("t"))) != 0) { return 8; }
    return 0;
}

func llvm_contract_tag_generic_type_size_ext_from_owner_impl(owner: []u8, prefix: []u8) -> u64 {
    var out: u64 = llvm_contract_tag_generic_elem_size_ext_from_owner_impl(owner, prefix);
    if (out != 0) { return out; }
    if (owner.ptr == 0 || owner.len <= prefix.len + 1) { return 0; }
    if (llvm_contract_name_has_prefix_impl(owner, prefix) == 0) { return 0; }
    var suffix_len: u64 = owner.len - prefix.len;
    if (str_eq(slice(owner.ptr + prefix.len, 1), slice("S", 1)) == 0) { return 0; }
    var struct_name: []u8 = slice(owner.ptr + prefix.len + 1, suffix_len - 1);
    var struct_size: u64 = llvm_contract_struct_size_impl(0, struct_name);
    if (struct_size == 0) { return 0; }
    return struct_size;
}

func llvm_contract_tag_generic_owner_has_prefix_impl(owner: []u8, prefix: []u8) -> u64 {
    if (owner.ptr == 0 || owner.len <= prefix.len) { return 0; }
    return llvm_contract_name_has_prefix_impl(owner, prefix);
}


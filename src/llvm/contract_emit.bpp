func llvm_contract_ssa_target_is_backedge_impl(from_id: u64, to_id: u64) -> u64 {
    if (to_id <= from_id) { return 1; }
    return 0;
}

func llvm_contract_ssa_op_is_loop_compare_impl(op: u64) -> u64 {
    if (op == SSA_OP_LT || op == SSA_OP_LE || op == SSA_OP_GT || op == SSA_OP_GE) { return 1; }
    if (op == SSA_OP_ULT || op == SSA_OP_ULE || op == SSA_OP_UGT || op == SSA_OP_UGE) { return 1; }
    return 0;
}

func llvm_contract_call_name_is_tagged_access_candidate_impl(name: []u8) -> u64 {
    if (name.ptr == 0 || name.len == 0) { return 0; }
    if (str_eq(name, slice("std_mem__bpp_tag_access_plan_can_index", str_len("std_mem__bpp_tag_access_plan_can_index"))) != 0) { return 1; }
    if (str_eq(name, slice("std_mem__bpp_tag_access_plan_can_range", str_len("std_mem__bpp_tag_access_plan_can_range"))) != 0) { return 1; }
    if (str_eq(name, slice("std_mem__bpp_tag_access_plan_hot_path", str_len("std_mem__bpp_tag_access_plan_hot_path"))) != 0) { return 1; }
    if (llvm_contract_name_has_prefix_impl(name, slice("std_mem__bpp_tag_access_plan_cold_path__G__T_", str_len("std_mem__bpp_tag_access_plan_cold_path__G__T_"))) != 0) { return 1; }
    if (llvm_contract_name_has_prefix_impl(name, slice("std_mem__bpp_tag_fast_guard_matches_slice__G__T_", str_len("std_mem__bpp_tag_fast_guard_matches_slice__G__T_"))) != 0) { return 1; }
    if (llvm_contract_name_has_prefix_impl(name, slice("std_vec__Vec_tagged_access_plan__G__T_", str_len("std_vec__Vec_tagged_access_plan__G__T_"))) != 0) { return 1; }
    if (llvm_contract_name_has_prefix_impl(name, slice("std_vec__Vec_tagged_hot_path_plan__G__T_", str_len("std_vec__Vec_tagged_hot_path_plan__G__T_"))) != 0) { return 1; }
    if (llvm_contract_name_has_prefix_impl(name, slice("std_vec__Vec_tagged_can_skip_bounds__G__T_", str_len("std_vec__Vec_tagged_can_skip_bounds__G__T_"))) != 0) { return 1; }
    if (llvm_contract_name_has_prefix_impl(name, slice("std_vec__Vec_tagged_element_ptr__G__T_", str_len("std_vec__Vec_tagged_element_ptr__G__T_"))) != 0) { return 1; }
    if (llvm_contract_name_has_prefix_impl(name, slice("std_vec__Vec_tagged_get_proven__G__T_", str_len("std_vec__Vec_tagged_get_proven__G__T_"))) != 0) { return 1; }
    if (llvm_contract_name_has_prefix_impl(name, slice("std_vec__Vec_tagged_set_proven__G__T_", str_len("std_vec__Vec_tagged_set_proven__G__T_"))) != 0) { return 1; }
    if (str_eq(name, slice("std_number__NumberSlice_access_plan", str_len("std_number__NumberSlice_access_plan"))) != 0) { return 1; }
    if (str_eq(name, slice("std_number__NumberSlice_hot_path_plan", str_len("std_number__NumberSlice_hot_path_plan"))) != 0) { return 1; }
    if (str_eq(name, slice("std_number__NumberSlice_can_skip_bounds", str_len("std_number__NumberSlice_can_skip_bounds"))) != 0) { return 1; }
    if (str_eq(name, slice("std_number__NumberSlice_element_ptr", str_len("std_number__NumberSlice_element_ptr"))) != 0) { return 1; }
    if (str_eq(name, slice("std_number__NumberSlice_at_proven", str_len("std_number__NumberSlice_at_proven"))) != 0) { return 1; }
    if (str_eq(name, slice("std_number__NumberSlice_set_proven", str_len("std_number__NumberSlice_set_proven"))) != 0) { return 1; }
    return 0;
}

func llvm_contract_inst_is_tagged_access_candidate_impl(inst: *LLVMSSAInstSketch) -> u64 {
    if (inst == 0 || inst.has_src1 == 0 || inst.src1_is_const == 0) { return 0; }
    if (inst.op == SSA_OP_CALL) {
        var call_info: *SSACallInfo = (*SSACallInfo)inst.src1_value;
        if (call_info == 0) { return 0; }
        return llvm_contract_call_name_is_tagged_access_candidate_impl(call_info.name);
    }
    if (inst.op == SSA_OP_CALL_SLICE_STORE) {
        var slice_info: *SSACallSliceStoreInfo = (*SSACallSliceStoreInfo)inst.src1_value;
        if (slice_info == 0) { return 0; }
        return llvm_contract_call_name_is_tagged_access_candidate_impl(slice_info.name);
    }
    return 0;
}

func llvm_contract_sketch_has_counted_loop_candidate_impl(sketch: *LLVMSSAFuncSketch) -> u64 {
    if (sketch == 0 || sketch.blocks == 0) { return 0; }
    var saw_backedge: u64 = 0;
    var saw_compare: u64 = 0;
    var nb: u64 = sketch.blocks.len();
    for (var bi: u64 = 0; bi < nb; bi = bi + 1) {
        var block: *LLVMSSABlockSketch = sketch.blocks.get(bi);
        if (block == 0 || block.insts == 0) { continue; }
        var ni: u64 = block.insts.len();
        for (var ii: u64 = 0; ii < ni; ii = ii + 1) {
            var inst: *LLVMSSAInstSketch = block.insts.get(ii);
            if (inst == 0) { continue; }
            if (llvm_contract_ssa_op_is_loop_compare_impl(inst.op) != 0) { saw_compare = 1; }
            if (inst.op == SSA_OP_JMP && inst.has_src1 != 0 && inst.src1_is_const != 0) {
                if (llvm_contract_ssa_target_is_backedge_impl(block.id, inst.src1_value) != 0) { saw_backedge = 1; }
            } else if (inst.op == SSA_OP_BR) {
                if (inst.has_src2 != 0 && inst.src2_is_const != 0 &&
                    llvm_contract_ssa_target_is_backedge_impl(block.id, inst.src2_value) != 0) {
                    saw_backedge = 1;
                }
                if (llvm_contract_ssa_target_is_backedge_impl(block.id, operand_value(inst.dest)) != 0) {
                    saw_backedge = 1;
                }
            }
        }
    }
    if (saw_backedge != 0 && saw_compare != 0) { return 1; }
    return 0;
}

func llvm_contract_sketch_has_tagged_access_candidate_impl(sketch: *LLVMSSAFuncSketch) -> u64 {
    if (sketch == 0 || sketch.blocks == 0) { return 0; }
    var nb: u64 = sketch.blocks.len();
    for (var bi: u64 = 0; bi < nb; bi = bi + 1) {
        var block: *LLVMSSABlockSketch = sketch.blocks.get(bi);
        if (block == 0 || block.insts == 0) { continue; }
        var ni: u64 = block.insts.len();
        for (var ii: u64 = 0; ii < ni; ii = ii + 1) {
            var inst: *LLVMSSAInstSketch = block.insts.get(ii);
            if (llvm_contract_inst_is_tagged_access_candidate_impl(inst) != 0) { return 1; }
        }
    }
    return 0;
}

func llvm_contract_emit_func_sketch_comment_impl(sketch: *LLVMSSAFuncSketch) -> u64 {
    if (sketch == 0) { return 0; }
    emit("; bpp.ssa.blocks=");
    print_u64(sketch.block_count);
    emit(" insts=");
    print_u64(sketch.inst_count);
    emit(" phis=");
    print_u64(sketch.phi_count);
    emit(" entry=");
    print_u64(sketch.entry_block_id);
    emit(" term_op=");
    print_u64(sketch.terminator_op);
    emit(" params=");
    print_u64(sketch.param_count);
    emit(" sig=");

    var inst: *LLVMSSAInstSketch = llvm_contract_ll_find_inst_by_dest_impl(sketch, reg_id, block_limit, inst_limit);
    if (inst == 0) { return 0; }
    if (inst.op == SSA_OP_LEA_LOCAL && inst.has_src1 != 0 && inst.src1_is_const != 0) { return 1; }
    if (inst.op == SSA_OP_COPY && inst.has_src1 != 0 && inst.src1_is_const == 0) {
        return llvm_contract_ll_reg_is_direct_local_addr_impl(sketch, inst.src1_value, block_limit, inst_limit, depth + 1);
    }
    if (inst.op == SSA_OP_ADD) {
        if (inst.has_src1 != 0 && inst.src1_is_const == 0 && inst.has_src2 != 0 && inst.src2_is_const != 0) {
            return llvm_contract_ll_reg_is_direct_local_addr_impl(sketch, inst.src1_value, block_limit, inst_limit, depth + 1);
        }
        if (inst.has_src2 != 0 && inst.src2_is_const == 0 && inst.has_src1 != 0 && inst.src1_is_const != 0) {
            return llvm_contract_ll_reg_is_direct_local_addr_impl(sketch, inst.src2_value, block_limit, inst_limit, depth + 1);
        }
    }
    return 0;
}

func llvm_contract_ll_mem_access_width_from_op_impl(op: u64) -> u64 {
    if (op == SSA_OP_LOAD8 || op == SSA_OP_STORE8) { return 1; }
    if (op == SSA_OP_LOAD16 || op == SSA_OP_STORE16) { return 2; }
    if (op == SSA_OP_LOAD32 || op == SSA_OP_STORE32) { return 4; }
    if (op == SSA_OP_LOAD64 || op == SSA_OP_STORE64) { return 8; }
    if (op == SSA_OP_LOAD || op == SSA_OP_STORE) { return 8; }
    return 0;
}

func llvm_contract_ll_find_nearest_call_sret_local_impl(sketch: *LLVMSSAFuncSketch, block_idx: u64, inst_idx: u64) -> u64 {
    if (sketch == 0 || sketch.blocks == 0) { return 0; }
    var bi_rev: u64 = block_idx + 1;
    while (bi_rev > 0) {
        bi_rev = bi_rev - 1;
        var block: *LLVMSSABlockSketch = sketch.blocks.get(bi_rev);
        if (block == 0 || block.insts == 0) { continue; }
        var ni: u64 = block.insts.len();
        var ii_rev: u64 = ni;
        if (bi_rev == block_idx && inst_idx < ii_rev) { ii_rev = inst_idx; }
        while (ii_rev > 0) {
            ii_rev = ii_rev - 1;
            var inst: *LLVMSSAInstSketch = block.insts.get(ii_rev);
            if (inst == 0 || inst.op != SSA_OP_LEA_LOCAL || inst.has_src1 == 0 || inst.src1_is_const == 0) { continue; }
            return inst.src1_value;
        }
    }
    return 0;
}

func llvm_contract_ll_emit_local_slot_ref_with_offset_impl(enc: u64, off: u64, temp_prefix: []u8, block_idx: u64, inst_idx: u64) -> u64 {
    if (enc == 0) { emit("null"); return 0; }
    if (off == 0) {
        llvm_contract_ll_emit_local_slot_name_impl(1, enc);
        return 1;
    }
    emit("  %");
    if (temp_prefix.ptr != 0 && temp_prefix.len != 0) { io_write_out(temp_prefix.ptr, temp_prefix.len); }
    print_u64(block_idx);
    emit("_");
    print_u64(inst_idx);
    emit(" = getelementptr i8, ptr ");
    llvm_contract_ll_emit_local_slot_name_impl(1, enc);
    emit(", i64 ");
    print_u64(off);
    emit("\n");
    emit("%");
    if (temp_prefix.ptr != 0 && temp_prefix.len != 0) { io_write_out(temp_prefix.ptr, temp_prefix.len); }
    print_u64(block_idx);
    emit("_");
    print_u64(inst_idx);
    return 1;
}


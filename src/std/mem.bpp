// mem.b - Memory utilities for v3.16

import std.io;
import std.str;

func memset(dst: u64, value: u64, len: u64) -> u64 {
    var v: u64 = value & 255;
    var dst_u8: *u8 = (*u8)dst;
    for (var i: u64 = 0; i < len; i++) {
        dst_u8[i] = v;
    }
    return dst;
}

func malloc(size: u64) -> u64 {
    return heap_alloc(size);
}

func free(ptr: u64) -> u64 {
    return heap_free(ptr);
}

func __bpp_delete_begin(ptr: u64) -> u64 {
    return heap_delete_begin(ptr);
}

func __bpp_delete_end(ptr: u64) -> u64 {
    return heap_delete_end(ptr);
}

const BPP_TAG_PTR_MASK = 281474976710655;
const BPP_TAG_HEAP_HEADER_SIZE = 40;
const BPP_TAG_HEAP_STATE_LIVE = 1;
const BPP_TAG_HEAP_STATE_DROPPING = 2;
const BPP_TAG_HEAP_STATE_FREED = 3;
const BPP_TAG_ARENA_CHUNK_BYTES = 262144;
const BPP_TAG_ARENA_CHUNK_HEADER_SIZE = 16;

const BPP_TAG_LIFE_UNKNOWN = 0;
const BPP_TAG_LIFE_YOUNG = 1;
const BPP_TAG_LIFE_OLD = 2;
const BPP_TAG_LIFE_ARENA = 3;
const BPP_TAG_LIFE_BORROWED = 4;
const BPP_TAG_LIFE_PINNED = 5;
const BPP_TAG_LIFE_IMMORTAL = 6;
const BPP_TAG_LIFE_DEAD = 7;

const BPP_TAG_OWN_UNKNOWN = 0;
const BPP_TAG_OWN_OWNED = 1;
const BPP_TAG_OWN_BORROWED = 2;
const BPP_TAG_OWN_SHARED = 3;
const BPP_TAG_OWN_WEAK = 4;
const BPP_TAG_OWN_UNIQUE = 5;
const BPP_TAG_OWN_ESCAPED = 6;
const BPP_TAG_OWN_STACK = 7;

const BPP_TAG_STORAGE_UNKNOWN = 0;
const BPP_TAG_STORAGE_HEAP = 1;
const BPP_TAG_STORAGE_STACK = 2;
const BPP_TAG_STORAGE_ARENA = 3;
const BPP_TAG_STORAGE_STATIC = 4;
const BPP_TAG_STORAGE_FOREIGN = 5;
const BPP_TAG_STORAGE_INLINE = 6;
const BPP_TAG_STORAGE_VECTOR = 7;

const BPP_TAG_BARRIER_UNKNOWN = 0;
const BPP_TAG_BARRIER_CLEAN = 1;
const BPP_TAG_BARRIER_DIRTY = 2;
const BPP_TAG_BARRIER_SKIP = 3;

const BPP_TAG_SHAPE_UNKNOWN = 0;
const BPP_TAG_SHAPE_EMPTY = 1;
const BPP_TAG_SHAPE_I64 = 2;
const BPP_TAG_SHAPE_U64 = 3;
const BPP_TAG_SHAPE_F64 = 4;
const BPP_TAG_SHAPE_NUMBER = 5;
const BPP_TAG_SHAPE_OBJECT = 6;
const BPP_TAG_SHAPE_POD = 7;
const BPP_TAG_SHAPE_PTR = 8;
const BPP_TAG_SHAPE_MIXED = 15;

const BPP_LOOP_PROFILE_DEFAULT_HOT_THRESHOLD = 1024;

const BPP_ESCAPE_STACK_MAX_BYTES = 4096;
const BPP_ESCAPE_ARENA_MAX_BYTES = 262144;

const BPP_FAST_PATH_NONE = 0;
const BPP_FAST_PATH_SCALAR = 1;
const BPP_FAST_PATH_UNROLLED = 2;
const BPP_FAST_PATH_VECTOR = 3;

const BPP_COLD_PATH_NONE = 0;
const BPP_COLD_PATH_GUARD_MISS = 1;
const BPP_COLD_PATH_BOUNDS = 2;
const BPP_COLD_PATH_SCALAR = 3;

const BPP_SHAPE_CACHE_HOT_HITS = 3;
const BPP_TAG_TUNE_DEFAULT_VECTOR_MIN_LEN = 4;
const BPP_TAG_TUNE_DEFAULT_UNROLL_MIN_LEN = 2;
const BPP_TAG_TUNE_DEFAULT_MAX_LANES = 8;

const BPP_TAG_LEN_EMPTY = 0;
const BPP_TAG_LEN_TINY = 1;
const BPP_TAG_LEN_SMALL = 2;
const BPP_TAG_LEN_MEDIUM = 3;
const BPP_TAG_LEN_LARGE = 4;

const BPP_TAG_LIFECYCLE_SHIFT = 48;
const BPP_TAG_OWNERSHIP_SHIFT = 51;
const BPP_TAG_STORAGE_SHIFT = 54;
const BPP_TAG_BARRIER_SHIFT = 57;
const BPP_TAG_SHAPE_SHIFT = 59;
const BPP_TAG_PROFILED_SHIFT = 63;

const BPP_TAG_BARRIER_CLEAR_MASK = 18014398509481983999;
const BPP_TAG_BARRIER_DIRTY_BITS = 288230376151711744;

packed struct BppObjectTag {
    public lifecycle: u3;
    public ownership: u3;
    public storage: u3;
    public barrier: u2;
    public shape: u4;
    public profiled: u1;
}

struct BppTaggedObject<T> {
    public ptr: *tagged(BppObjectTag) T;
}

struct BppTaggedSlice<T> {
    public ptr: *tagged(BppObjectTag) T;
    public len: u64;
}

struct BppLoopProfile {
    public iterations: u64;
    public trips: u64;
    public hot_threshold: u64;
    public selected_shape: u64;
}

struct BppEscapePolicy {
    public lifecycle: u64;
    public ownership: u64;
    public storage: u64;
    public barrier: u64;
    public skip_refcount: u64;
    public skip_barrier: u64;
    public delete_allowed: u64;
}

struct BppSliceProof {
    public base: u64;
    public len: u64;
    public start: u64;
    public end_index: u64;
    public shape: u64;
    public stable_bounds: u64;
    public nonnull: u64;
    public effect_safe: u64;
    public epoch: u64;
}

struct BppShapeCache {
    public shape: u64;
    public elem_size: u64;
    public len_class: u64;
    public profiled: u64;
    public hot: u64;
    public fast_path: u64;
    public hits: u64;
    public misses: u64;
    public last_epoch: u64;
}

struct BppVectorPlan {
    public fast_path: u64;
    public lanes: u64;
    public unroll: u64;
    public shape: u64;
    public hot: u64;
}

struct BppTagFastGuard {
    public shape: u64;
    public elem_size: u64;
    public len_class: u64;
    public profiled: u64;
    public hot: u64;
    public epoch: u64;
    public fast_path: u64;
    public lanes: u64;
}

struct BppTaggedAccessPlan {
    public shape: u64;
    public elem_size: u64;
    public len: u64;
    public len_class: u64;
    public profiled: u64;
    public hot: u64;
    public epoch: u64;
    public fast_path: u64;
    public lanes: u64;
    public stable_bounds: u64;
    public nonnull: u64;
    public effect_safe: u64;
    public vectorizable: u64;
}

struct BppHotPathPlan {
    public fast_path: u64;
    public cold_path: u64;
    public epoch: u64;
    public lanes: u64;
    public deopt_reason: u64;
}

struct BppTagTuning {
    public hot_threshold: u64;
    public vector_min_len: u64;
    public unroll_min_len: u64;
    public cache_hot_hits: u64;
    public max_lanes: u64;
}

struct BppTaggedAllocatorStats {
    public allocs: u64;
    public heap_allocs: u64;
    public arena_tagged_allocs: u64;
    public stack_tagged_allocs: u64;
    public immortal_tagged_allocs: u64;
    public young_tagged_allocs: u64;
    public old_tagged_allocs: u64;
    public pinned_tagged_allocs: u64;
    public frees: u64;
    public delete_begins: u64;
    public denied_allocs: u64;
    public denied_frees: u64;
}

var g_bpp_tag_allocs: u64;
var g_bpp_tag_heap_allocs: u64;
var g_bpp_tag_arena_allocs: u64;
var g_bpp_tag_stack_allocs: u64;
var g_bpp_tag_immortal_allocs: u64;
var g_bpp_tag_young_allocs: u64;
var g_bpp_tag_old_allocs: u64;
var g_bpp_tag_pinned_allocs: u64;
var g_bpp_tag_frees: u64;
var g_bpp_tag_delete_begins: u64;
var g_bpp_tag_denied_allocs: u64;
var g_bpp_tag_denied_frees: u64;
var g_bpp_tag_arena_head: u64;
var g_bpp_tag_arena_cur: u64;
var g_bpp_tag_arena_end: u64;
var g_bpp_tag_arena_chunks: u64;
var g_bpp_tag_arena_bytes_reserved: u64;
var g_bpp_tag_arena_bytes_used: u64;
var g_bpp_tag_arena_resets: u64;
var g_bpp_tag_stack_materialized_allocs: u64;
var g_bpp_tag_refcount_retain_needed: u64;
var g_bpp_tag_refcount_retain_skipped: u64;
var g_bpp_tag_refcount_release_needed: u64;
var g_bpp_tag_refcount_release_skipped: u64;
var g_bpp_tag_gc_barrier_needed: u64;
var g_bpp_tag_gc_barrier_skipped: u64;
var g_bpp_tag_gc_barrier_dirty: u64;

func bpp_tag_strip(ptr: u64) -> u64 {
    return ptr & BPP_TAG_PTR_MASK;
}

func bpp_tag_layout_has_memory_state(layout: []u8) -> u64 {
    if (layout.ptr == 0 || layout.len == 0) { return 0; }
    if (str_eq(layout, slice("BppObjectTag", str_len("BppObjectTag"))) != 0) { return 1; }
    if (str_eq(layout, slice("std_mem__BppObjectTag", str_len("std_mem__BppObjectTag"))) != 0) { return 1; }
    return 0;
}

func bpp_tag_pack(ptr: u64, lifecycle: u64, ownership: u64, storage: u64, barrier: u64, shape: u64, profiled: u64) -> u64 {
    var out: u64 = bpp_tag_strip(ptr);
    out = out | ((lifecycle & 7) << BPP_TAG_LIFECYCLE_SHIFT);
    out = out | ((ownership & 7) << BPP_TAG_OWNERSHIP_SHIFT);
    out = out | ((storage & 7) << BPP_TAG_STORAGE_SHIFT);
    out = out | ((barrier & 3) << BPP_TAG_BARRIER_SHIFT);
    out = out | ((shape & 15) << BPP_TAG_SHAPE_SHIFT);
    out = out | ((profiled & 1) << BPP_TAG_PROFILED_SHIFT);
    return out;
}

func bpp_tag_allocator_reset() -> u64 {
    g_bpp_tag_allocs = 0;
    g_bpp_tag_heap_allocs = 0;
    g_bpp_tag_arena_allocs = 0;
    g_bpp_tag_stack_allocs = 0;
    g_bpp_tag_immortal_allocs = 0;
    g_bpp_tag_young_allocs = 0;
    g_bpp_tag_old_allocs = 0;
    g_bpp_tag_pinned_allocs = 0;
    g_bpp_tag_frees = 0;
    g_bpp_tag_delete_begins = 0;
    g_bpp_tag_denied_allocs = 0;
    g_bpp_tag_denied_frees = 0;
    g_bpp_tag_stack_materialized_allocs = 0;
    g_bpp_tag_refcount_retain_needed = 0;
    g_bpp_tag_refcount_retain_skipped = 0;
    g_bpp_tag_refcount_release_needed = 0;
    g_bpp_tag_refcount_release_skipped = 0;
    g_bpp_tag_gc_barrier_needed = 0;
    g_bpp_tag_gc_barrier_skipped = 0;
    g_bpp_tag_gc_barrier_dirty = 0;
    return 0;
}

func bpp_tag_allocator_record_alloc(lifecycle: u64, ownership: u64, storage: u64) -> u64 {
    g_bpp_tag_allocs = g_bpp_tag_allocs + 1;
    if (storage == BPP_TAG_STORAGE_HEAP) { g_bpp_tag_heap_allocs = g_bpp_tag_heap_allocs + 1; }
    if (storage == BPP_TAG_STORAGE_ARENA) { g_bpp_tag_arena_allocs = g_bpp_tag_arena_allocs + 1; }
    if (storage == BPP_TAG_STORAGE_STACK) { g_bpp_tag_stack_allocs = g_bpp_tag_stack_allocs + 1; }
    if (lifecycle == BPP_TAG_LIFE_IMMORTAL) { g_bpp_tag_immortal_allocs = g_bpp_tag_immortal_allocs + 1; }
    if (lifecycle == BPP_TAG_LIFE_YOUNG) { g_bpp_tag_young_allocs = g_bpp_tag_young_allocs + 1; }
    if (lifecycle == BPP_TAG_LIFE_OLD) { g_bpp_tag_old_allocs = g_bpp_tag_old_allocs + 1; }
    if (lifecycle == BPP_TAG_LIFE_PINNED) { g_bpp_tag_pinned_allocs = g_bpp_tag_pinned_allocs + 1; }
    return 0;
}

func bpp_tag_allocator_record_denied_alloc(lifecycle: u64, ownership: u64, storage: u64) -> u64 {
    g_bpp_tag_denied_allocs = g_bpp_tag_denied_allocs + 1;
    return 0;
}

func bpp_tag_allocator_record_free(ptr: u64, allowed: u64) -> u64 {
    if (ptr == 0) { return 0; }
    if (allowed == 0) {
        g_bpp_tag_denied_frees = g_bpp_tag_denied_frees + 1;
        return 0;
    }
    g_bpp_tag_frees = g_bpp_tag_frees + 1;
    return 0;
}

func bpp_tag_allocator_record_delete_begin(ptr: u64, allowed: u64) -> u64 {
    if (ptr == 0) { return 0; }
    if (allowed == 0) {
        g_bpp_tag_denied_frees = g_bpp_tag_denied_frees + 1;
        return 0;
    }
    g_bpp_tag_delete_begins = g_bpp_tag_delete_begins + 1;
    return 0;
}

func bpp_tag_allocator_stats() -> BppTaggedAllocatorStats {
    var out: BppTaggedAllocatorStats;
    out.allocs = g_bpp_tag_allocs;
    out.heap_allocs = g_bpp_tag_heap_allocs;
    out.arena_tagged_allocs = g_bpp_tag_arena_allocs;
    out.stack_tagged_allocs = g_bpp_tag_stack_allocs;
    out.immortal_tagged_allocs = g_bpp_tag_immortal_allocs;
    out.young_tagged_allocs = g_bpp_tag_young_allocs;
    out.old_tagged_allocs = g_bpp_tag_old_allocs;
    out.pinned_tagged_allocs = g_bpp_tag_pinned_allocs;
    out.frees = g_bpp_tag_frees;
    out.delete_begins = g_bpp_tag_delete_begins;
    out.denied_allocs = g_bpp_tag_denied_allocs;
    out.denied_frees = g_bpp_tag_denied_frees;
    return out;
}

func bpp_tag_allocator_alloc_count() -> u64 { return g_bpp_tag_allocs; }
func bpp_tag_allocator_heap_alloc_count() -> u64 { return g_bpp_tag_heap_allocs; }
func bpp_tag_allocator_arena_alloc_count() -> u64 { return g_bpp_tag_arena_allocs; }
func bpp_tag_allocator_stack_alloc_count() -> u64 { return g_bpp_tag_stack_allocs; }
func bpp_tag_allocator_free_count() -> u64 { return g_bpp_tag_frees; }
func bpp_tag_allocator_delete_begin_count() -> u64 { return g_bpp_tag_delete_begins; }
func bpp_tag_allocator_denied_alloc_count() -> u64 { return g_bpp_tag_denied_allocs; }
func bpp_tag_allocator_denied_free_count() -> u64 { return g_bpp_tag_denied_frees; }
func bpp_tag_arena_chunk_count() -> u64 { return g_bpp_tag_arena_chunks; }
func bpp_tag_arena_bytes_reserved() -> u64 { return g_bpp_tag_arena_bytes_reserved; }
func bpp_tag_arena_bytes_used() -> u64 { return g_bpp_tag_arena_bytes_used; }
func bpp_tag_arena_reset_count() -> u64 { return g_bpp_tag_arena_resets; }
func bpp_tag_stack_materialized_count() -> u64 { return g_bpp_tag_stack_materialized_allocs; }
func bpp_tag_refcount_retain_needed_count() -> u64 { return g_bpp_tag_refcount_retain_needed; }
func bpp_tag_refcount_retain_skipped_count() -> u64 { return g_bpp_tag_refcount_retain_skipped; }
func bpp_tag_refcount_release_needed_count() -> u64 { return g_bpp_tag_refcount_release_needed; }
func bpp_tag_refcount_release_skipped_count() -> u64 { return g_bpp_tag_refcount_release_skipped; }
func bpp_tag_gc_barrier_needed_count() -> u64 { return g_bpp_tag_gc_barrier_needed; }
func bpp_tag_gc_barrier_skipped_count() -> u64 { return g_bpp_tag_gc_barrier_skipped; }
func bpp_tag_gc_barrier_dirty_count() -> u64 { return g_bpp_tag_gc_barrier_dirty; }

func bpp_tag_arena_alloc_raw(size: u64) -> u64 {
    if (size == 0 || size > BPP_ESCAPE_ARENA_MAX_BYTES) { return 0; }
    var aligned: u64 = heap_align8(size);
    if (aligned == 0) { return 0; }
    if (g_bpp_tag_arena_cur == 0 || g_bpp_tag_arena_cur + aligned > g_bpp_tag_arena_end) {
        var payload_size: u64 = BPP_TAG_ARENA_CHUNK_BYTES;
        if (aligned > payload_size) { payload_size = aligned; }
        var chunk: u64 = heap_alloc(payload_size + BPP_TAG_ARENA_CHUNK_HEADER_SIZE);
        if (chunk == 0) { return 0; }
        var meta: *u64 = (*u64)chunk;
        meta[0] = g_bpp_tag_arena_head;
        meta[1] = payload_size;
        g_bpp_tag_arena_head = chunk;
        g_bpp_tag_arena_cur = chunk + BPP_TAG_ARENA_CHUNK_HEADER_SIZE;
        g_bpp_tag_arena_end = g_bpp_tag_arena_cur + payload_size;
        g_bpp_tag_arena_chunks = g_bpp_tag_arena_chunks + 1;
        g_bpp_tag_arena_bytes_reserved = g_bpp_tag_arena_bytes_reserved + payload_size;
    }
    var out: u64 = g_bpp_tag_arena_cur;
    g_bpp_tag_arena_cur = g_bpp_tag_arena_cur + aligned;
    g_bpp_tag_arena_bytes_used = g_bpp_tag_arena_bytes_used + aligned;
    return out;
}

func bpp_tag_arena_reset() -> u64 {
    var cur: u64 = g_bpp_tag_arena_head;
    while (cur != 0) {
        var meta: *u64 = (*u64)cur;
        var next: u64 = meta[0];
        heap_free(cur);
        cur = next;
    }
    g_bpp_tag_arena_head = 0;
    g_bpp_tag_arena_cur = 0;
    g_bpp_tag_arena_end = 0;
    g_bpp_tag_arena_chunks = 0;
    g_bpp_tag_arena_bytes_reserved = 0;
    g_bpp_tag_arena_bytes_used = 0;
    g_bpp_tag_arena_resets = g_bpp_tag_arena_resets + 1;
    return 0;
}

func bpp_tag_arena_contains_raw(ptr: u64) -> u64 {
    var raw: u64 = bpp_tag_strip(ptr);
    if (raw == 0) { return 0; }
    var cur: u64 = g_bpp_tag_arena_head;
    while (cur != 0) {
        var meta: *u64 = (*u64)cur;
        var start: u64 = cur + BPP_TAG_ARENA_CHUNK_HEADER_SIZE;
        var end: u64 = start + meta[1];
        if (raw >= start && raw < end) { return 1; }
        cur = meta[0];
    }
    return 0;
}

func bpp_heap_alloc_tagged(size: u64, lifecycle: u64, ownership: u64, storage: u64, barrier: u64, shape: u64, profiled: u64) -> u64 {
    if (storage != BPP_TAG_STORAGE_HEAP) {
        bpp_tag_allocator_record_denied_alloc(lifecycle, ownership, storage);
        return 0;
    }
    var ptr: u64 = heap_alloc(size);
    if (ptr == 0) { return 0; }
    bpp_tag_allocator_record_alloc(lifecycle, ownership, storage);
    return bpp_tag_pack(ptr, lifecycle, ownership, storage, barrier, shape, profiled);
}

func bpp_arena_alloc_tagged(size: u64, lifecycle: u64, ownership: u64, barrier: u64, shape: u64, profiled: u64) -> u64 {
    var ptr: u64 = bpp_tag_arena_alloc_raw(size);
    if (ptr == 0) {
        bpp_tag_allocator_record_denied_alloc(lifecycle, ownership, BPP_TAG_STORAGE_ARENA);
        return 0;
    }
    bpp_tag_allocator_record_alloc(lifecycle, ownership, BPP_TAG_STORAGE_ARENA);
    return bpp_tag_pack(ptr, lifecycle, ownership, BPP_TAG_STORAGE_ARENA, barrier, shape, profiled);
}

func bpp_stack_materialize_tagged_raw(ptr: u64, lifecycle: u64, ownership: u64, barrier: u64, shape: u64, profiled: u64) -> u64 {
    var raw: u64 = bpp_tag_strip(ptr);
    if (raw == 0) {
        bpp_tag_allocator_record_denied_alloc(lifecycle, ownership, BPP_TAG_STORAGE_STACK);
        return 0;
    }
    bpp_tag_allocator_record_alloc(lifecycle, ownership, BPP_TAG_STORAGE_STACK);
    g_bpp_tag_stack_materialized_allocs = g_bpp_tag_stack_materialized_allocs + 1;
    return bpp_tag_pack(raw, lifecycle, ownership, BPP_TAG_STORAGE_STACK, barrier, shape, profiled);
}

func bpp_heap_alloc_with_policy(size: u64, policy: *BppEscapePolicy, shape: u64) -> u64 {
    if (policy == 0) {
        return bpp_heap_alloc_tagged(size, BPP_TAG_LIFE_YOUNG, BPP_TAG_OWN_OWNED, BPP_TAG_STORAGE_HEAP, BPP_TAG_BARRIER_CLEAN, shape, 0);
    }
    if (policy.storage == BPP_TAG_STORAGE_ARENA) {
        return bpp_arena_alloc_tagged(size, policy.lifecycle, policy.ownership, policy.barrier, shape, 0);
    }
    return bpp_heap_alloc_tagged(size, policy.lifecycle, policy.ownership, policy.storage, policy.barrier, shape, 0);
}

func bpp_heap_alloc_auto_tagged(size: u64, escapes: u64, address_taken: u64, shared: u64, pinned: u64, immortal: u64, arena_hint: u64, shape: u64) -> u64 {
    var policy: BppEscapePolicy = bpp_escape_policy_for(size, escapes, address_taken, shared, pinned, immortal, arena_hint);
    return bpp_heap_alloc_with_policy(size, &policy, shape);
}

func bpp_stack_alloc_auto_tagged_from_raw(ptr: u64, size: u64, escapes: u64, address_taken: u64, shared: u64, pinned: u64, immortal: u64, arena_hint: u64, shape: u64) -> u64 {
    var policy: BppEscapePolicy = bpp_escape_policy_for(size, escapes, address_taken, shared, pinned, immortal, arena_hint);
    if (policy.storage == BPP_TAG_STORAGE_STACK) {
        return bpp_stack_materialize_tagged_raw(ptr, policy.lifecycle, policy.ownership, policy.barrier, shape, 0);
    }
    return bpp_heap_alloc_with_policy(size, &policy, shape);
}

func bpp_heap_tagged_free(ptr: u64) -> u64 {
    if (ptr == 0) { return 0; }
    var allowed: u64 = bpp_tag_allocator_can_free_raw(ptr);
    bpp_tag_allocator_record_free(ptr, allowed);
    if (allowed == 0) { return 0; }
    return heap_free(ptr);
}

func bpp_tag_lifecycle_raw(ptr: u64) -> u64 {
    return (ptr >> BPP_TAG_LIFECYCLE_SHIFT) & 7;
}

func bpp_tag_ownership_raw(ptr: u64) -> u64 {
    return (ptr >> BPP_TAG_OWNERSHIP_SHIFT) & 7;
}

func bpp_tag_storage_raw(ptr: u64) -> u64 {
    return (ptr >> BPP_TAG_STORAGE_SHIFT) & 7;
}

func bpp_tag_heap_block_raw(ptr: u64) -> u64 {
    var raw: u64 = bpp_tag_strip(ptr);
    if (raw == 0 || raw < BPP_TAG_HEAP_HEADER_SIZE) { return 0; }
    var block: u64 = raw - BPP_TAG_HEAP_HEADER_SIZE;
    if (heap_block_is_valid(block) == 0) { return 0; }
    return block;
}


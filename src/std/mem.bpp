func bpp_tag_slice_index_of_u64(s: *BppTaggedSlice<u64>, needle: u64) -> i64 {
    return bpp_tag_slice_find_eq_u64(s, needle);
}

func bpp_tag_slice_index_of_i64(s: *BppTaggedSlice<i64>, needle: i64) -> i64 {
    return bpp_tag_slice_find_eq_i64(s, needle);

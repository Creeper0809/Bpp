func bpp_tag_slice_find_eq_u64(s: *BppTaggedSlice<u64>, needle: u64) -> i64 {
    if (s == 0 || s.len == 0) { return -1; }
    var raw: *u64 = bpp_tag_slice_raw<u64>(s);
    if (raw == 0) { return -1; }
    var plan: BppVectorPlan = bpp_vector_plan_for(bpp_tag_slice_shape<u64>(s), sizeof(u64), s.len, bpp_tag_profiled_raw((u64)s.ptr), 1);
    var i: u64 = 0;
    if (plan.fast_path == BPP_FAST_PATH_VECTOR || plan.fast_path == BPP_FAST_PATH_UNROLLED) {
        while (i + 4 <= s.len) {
            if (raw[i] == needle) { return (i64)i; }
            if (raw[i + 1] == needle) { return (i64)(i + 1); }
            if (raw[i + 2] == needle) { return (i64)(i + 2); }
            if (raw[i + 3] == needle) { return (i64)(i + 3); }
            i = i + 4;
        }
    }
    while (i < s.len) {
        if (raw[i] == needle) { return (i64)i; }
        i = i + 1;
    }
    return -1;
}


func bpp_escape_policy_new(lifecycle: u64, ownership: u64, storage: u64, barrier: u64) -> BppEscapePolicy {
    var out: BppEscapePolicy;
    out.lifecycle = lifecycle;
    out.ownership = ownership;
    out.storage = storage;
    out.barrier = barrier;
    out.skip_refcount = 0;
    out.skip_barrier = 0;
    out.delete_allowed = 1;

    if (lifecycle == BPP_TAG_LIFE_BORROWED || lifecycle == BPP_TAG_LIFE_ARENA || lifecycle == BPP_TAG_LIFE_IMMORTAL) {
        out.delete_allowed = 0;
    }
    if (ownership == BPP_TAG_OWN_BORROWED || ownership == BPP_TAG_OWN_WEAK || ownership == BPP_TAG_OWN_STACK) {
        out.delete_allowed = 0;
    }
    if (storage == BPP_TAG_STORAGE_STACK || storage == BPP_TAG_STORAGE_ARENA || storage == BPP_TAG_STORAGE_STATIC ||
        storage == BPP_TAG_STORAGE_FOREIGN || storage == BPP_TAG_STORAGE_INLINE || storage == BPP_TAG_STORAGE_VECTOR) {
        out.delete_allowed = 0;
    }

    if (lifecycle == BPP_TAG_LIFE_IMMORTAL || ownership == BPP_TAG_OWN_UNIQUE || ownership == BPP_TAG_OWN_BORROWED || ownership == BPP_TAG_OWN_WEAK || ownership == BPP_TAG_OWN_STACK) {
        out.skip_refcount = 1;
    }
    if (barrier == BPP_TAG_BARRIER_SKIP || lifecycle == BPP_TAG_LIFE_IMMORTAL || storage == BPP_TAG_STORAGE_STACK || storage == BPP_TAG_STORAGE_STATIC) {
        out.skip_barrier = 1;
    }
    return out;
}

func bpp_escape_policy_for(size: u64, escapes: u64, address_taken: u64, shared: u64, pinned: u64, immortal: u64, arena_hint: u64) -> BppEscapePolicy {
    if (immortal != 0) {
        return bpp_escape_policy_new(BPP_TAG_LIFE_IMMORTAL, BPP_TAG_OWN_SHARED, BPP_TAG_STORAGE_STATIC, BPP_TAG_BARRIER_SKIP);
    }
    if (pinned != 0) {
        return bpp_escape_policy_new(BPP_TAG_LIFE_PINNED, BPP_TAG_OWN_SHARED, BPP_TAG_STORAGE_HEAP, BPP_TAG_BARRIER_DIRTY);
    }
    if (escapes != 0) {
        if (shared != 0) {
            return bpp_escape_policy_new(BPP_TAG_LIFE_YOUNG, BPP_TAG_OWN_SHARED, BPP_TAG_STORAGE_HEAP, BPP_TAG_BARRIER_CLEAN);
        }
        return bpp_escape_policy_new(BPP_TAG_LIFE_YOUNG, BPP_TAG_OWN_ESCAPED, BPP_TAG_STORAGE_HEAP, BPP_TAG_BARRIER_CLEAN);
    }
    if (shared != 0) {
        return bpp_escape_policy_new(BPP_TAG_LIFE_YOUNG, BPP_TAG_OWN_SHARED, BPP_TAG_STORAGE_HEAP, BPP_TAG_BARRIER_CLEAN);
    }
    if (arena_hint != 0 || size > BPP_ESCAPE_STACK_MAX_BYTES) {
        if (size <= BPP_ESCAPE_ARENA_MAX_BYTES) {
            return bpp_escape_policy_new(BPP_TAG_LIFE_ARENA, BPP_TAG_OWN_BORROWED, BPP_TAG_STORAGE_ARENA, BPP_TAG_BARRIER_CLEAN);
        }
        return bpp_escape_policy_new(BPP_TAG_LIFE_YOUNG, BPP_TAG_OWN_OWNED, BPP_TAG_STORAGE_HEAP, BPP_TAG_BARRIER_CLEAN);
    }
    if (address_taken == 0 && size <= BPP_ESCAPE_STACK_MAX_BYTES) {
        return bpp_escape_policy_new(BPP_TAG_LIFE_BORROWED, BPP_TAG_OWN_STACK, BPP_TAG_STORAGE_STACK, BPP_TAG_BARRIER_SKIP);
    }
    return bpp_escape_policy_new(BPP_TAG_LIFE_YOUNG, BPP_TAG_OWN_UNIQUE, BPP_TAG_STORAGE_HEAP, BPP_TAG_BARRIER_CLEAN);
}

func bpp_tag_object_from_policy<T>(ptr: *T, policy: *BppEscapePolicy, shape: u64) -> BppTaggedObject<T> {
    var out: BppTaggedObject<T>;
    if (policy == 0) {
        out.ptr = (*tagged(BppObjectTag) T)bpp_tag_pack((u64)ptr, BPP_TAG_LIFE_UNKNOWN, BPP_TAG_OWN_UNKNOWN, BPP_TAG_STORAGE_UNKNOWN, BPP_TAG_BARRIER_UNKNOWN, shape, 0);
        return out;
    }
    out.ptr = (*tagged(BppObjectTag) T)bpp_tag_pack((u64)ptr, policy.lifecycle, policy.ownership, policy.storage, policy.barrier, shape, 0);
    return out;
}

func bpp_tag_object_auto<T>(ptr: *T, escapes: u64, address_taken: u64, shared: u64, pinned: u64, immortal: u64, arena_hint: u64) -> BppTaggedObject<T> {
    var policy: BppEscapePolicy = bpp_escape_policy_for(sizeof(T), escapes, address_taken, shared, pinned, immortal, arena_hint);
    return bpp_tag_object_from_policy<T>(ptr, &policy, BPP_TAG_SHAPE_OBJECT);
}

func bpp_tag_delete_allowed_raw(ptr: u64) -> u64 {
    if (ptr == 0) { return 0; }
    var lifecycle: u64 = bpp_tag_lifecycle_raw(ptr);
    var ownership: u64 = bpp_tag_ownership_raw(ptr);
    var storage: u64 = bpp_tag_storage_raw(ptr);
    if (lifecycle == BPP_TAG_LIFE_BORROWED) { return 0; }
    if (lifecycle == BPP_TAG_LIFE_ARENA) { return 0; }
    if (lifecycle == BPP_TAG_LIFE_IMMORTAL) { return 0; }
    if (lifecycle == BPP_TAG_LIFE_DEAD) { return 0; }
    if (ownership == BPP_TAG_OWN_BORROWED) { return 0; }
    if (ownership == BPP_TAG_OWN_WEAK) { return 0; }
    if (ownership == BPP_TAG_OWN_STACK) { return 0; }
    if (storage == BPP_TAG_STORAGE_STACK) { return 0; }
    if (storage == BPP_TAG_STORAGE_ARENA) { return 0; }
    if (storage == BPP_TAG_STORAGE_STATIC) { return 0; }
    if (storage == BPP_TAG_STORAGE_FOREIGN) { return 0; }
    if (storage == BPP_TAG_STORAGE_INLINE) { return 0; }
    if (storage == BPP_TAG_STORAGE_VECTOR) { return 0; }
    return 1;
}


func bpp_tag_slice_count_eq_u64(s: *BppTaggedSlice<u64>, needle: u64) -> u64 {
    if (s == 0 || s.len == 0) { return 0; }
    var raw: *u64 = bpp_tag_slice_raw<u64>(s);
    if (raw == 0) { return 0; }
    var plan: BppVectorPlan = bpp_vector_plan_for(bpp_tag_slice_shape<u64>(s), sizeof(u64), s.len, bpp_tag_profiled_raw((u64)s.ptr), 1);
    var acc: u64 = 0;
    var i: u64 = 0;
    if (plan.fast_path == BPP_FAST_PATH_VECTOR || plan.fast_path == BPP_FAST_PATH_UNROLLED) {
        while (i + 4 <= s.len) {
            if (raw[i] == needle) { acc = acc + 1; }
            if (raw[i + 1] == needle) { acc = acc + 1; }
            if (raw[i + 2] == needle) { acc = acc + 1; }
            if (raw[i + 3] == needle) { acc = acc + 1; }
            i = i + 4;
        }
    }
    while (i < s.len) {
        if (raw[i] == needle) { acc = acc + 1; }
        i = i + 1;
    }
    return acc;
}


    return 0;
}

func __bpp_tagged_delete_begin(ptr: u64) -> u64 {
    var allowed: u64 = bpp_tag_allocator_can_delete_begin_raw(ptr);
    bpp_tag_allocator_record_delete_begin(ptr, allowed);
    if (allowed == 0) { return 0; }
    return heap_delete_begin(ptr);
}

func bpp_heap_tagged_delete_end(ptr: u64) -> u64 {
    if (ptr == 0) { return 0; }
    var allowed: u64 = bpp_tag_allocator_can_delete_end_raw(ptr);
    bpp_tag_allocator_record_free(ptr, allowed);
    if (allowed == 0) { return 0; }
    return heap_delete_end(ptr);
}

func bpp_tag_can_skip_refcount_raw(ptr: u64) -> u64 {
    if (ptr == 0) { return 1; }
    var lifecycle: u64 = bpp_tag_lifecycle_raw(ptr);
    var ownership: u64 = bpp_tag_ownership_raw(ptr);
    if (lifecycle == BPP_TAG_LIFE_IMMORTAL) { return 1; }
    if (ownership == BPP_TAG_OWN_UNIQUE) { return 1; }
    if (ownership == BPP_TAG_OWN_BORROWED) { return 1; }
    if (ownership == BPP_TAG_OWN_WEAK) { return 1; }
    if (ownership == BPP_TAG_OWN_STACK) { return 1; }
    return 0;
}

func bpp_tag_refcount_retain_needed_raw(ptr: u64) -> u64 {
    if (bpp_tag_can_skip_refcount_raw(ptr) != 0) { return 0; }
    return 1;
}

func bpp_tag_refcount_retain_runtime_raw(ptr: u64) -> u64 {
    if (bpp_tag_refcount_retain_needed_raw(ptr) == 0) {
        g_bpp_tag_refcount_retain_skipped = g_bpp_tag_refcount_retain_skipped + 1;
        return ptr;
    }
    g_bpp_tag_refcount_retain_needed = g_bpp_tag_refcount_retain_needed + 1;

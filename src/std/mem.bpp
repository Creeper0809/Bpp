        while (i + 4 <= s.len) {
            if (raw[i] == needle) { acc = acc + 1; }
            if (raw[i + 1] == needle) { acc = acc + 1; }
            if (raw[i + 2] == needle) { acc = acc + 1; }
            if (raw[i + 3] == needle) { acc = acc + 1; }

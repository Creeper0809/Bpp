func bpp_loop_profile_new(threshold: u64) -> BppLoopProfile {
    var out: BppLoopProfile;
    out.iterations = 0;
    out.trips = 0;
    if (threshold == 0) { out.hot_threshold = BPP_LOOP_PROFILE_DEFAULT_HOT_THRESHOLD; }
    else { out.hot_threshold = threshold; }
    out.selected_shape = BPP_TAG_SHAPE_UNKNOWN;
    return out;
}

func bpp_loop_profile_new_tuned(tuning: *BppTagTuning) -> BppLoopProfile {
    if (tuning == 0 || tuning.hot_threshold == 0) {
        return bpp_loop_profile_new(0);
    }
    return bpp_loop_profile_new(tuning.hot_threshold);
}

func bpp_loop_profile_apply_tuning(profile: *BppLoopProfile, tuning: *BppTagTuning) -> u64 {
    if (profile == 0 || tuning == 0) { return 0; }
    if (tuning.hot_threshold != 0) {
        profile.hot_threshold = tuning.hot_threshold;
    }
    return 0;
}

func bpp_loop_profile_record(profile: *BppLoopProfile, iterations: u64, shape: u64) -> u64 {
    if (profile == 0) { return 0; }
    profile.iterations = profile.iterations + iterations;
    profile.trips = profile.trips + 1;
    if (profile.selected_shape == BPP_TAG_SHAPE_UNKNOWN || profile.selected_shape == BPP_TAG_SHAPE_EMPTY) {
        profile.selected_shape = shape;
    } else if (profile.selected_shape != shape) {
        profile.selected_shape = BPP_TAG_SHAPE_MIXED;
    }
    return 0;
}

func bpp_loop_profile_record_tuned(profile: *BppLoopProfile, iterations: u64, shape: u64, tuning: *BppTagTuning) -> u64 {
    bpp_loop_profile_apply_tuning(profile, tuning);
    return bpp_loop_profile_record(profile, iterations, shape);
}

func bpp_loop_profile_is_hot(profile: *BppLoopProfile) -> u64 {
    if (profile == 0) { return 0; }
    if (profile.iterations >= profile.hot_threshold) { return 1; }
    return 0;
}

func bpp_loop_profile_vector_candidate<T>(profile: *BppLoopProfile, s: *BppTaggedSlice<T>) -> u64 {
    if (bpp_loop_profile_is_hot(profile) == 0) { return 0; }
    return bpp_tag_slice_is_vector_candidate<T>(s);
}

func bpp_shape_cache_new(shape: u64) -> BppShapeCache {
    var out: BppShapeCache;
    out.shape = shape;
    out.elem_size = 0;
    out.len_class = BPP_TAG_LEN_EMPTY;
    out.profiled = 0;
    out.hot = 0;
    out.fast_path = BPP_FAST_PATH_NONE;
    out.hits = 0;
    out.misses = 0;
    out.last_epoch = 0;
    return out;
}

func bpp_shape_cache_probe(cache: *BppShapeCache, shape: u64, epoch: u64) -> u64 {
    if (cache == 0) { return 0; }
    if (cache.shape == shape && cache.last_epoch == epoch) {
        cache.hits = cache.hits + 1;
        return 1;
    }
    cache.shape = shape;
    cache.last_epoch = epoch;
    cache.misses = cache.misses + 1;
    cache.hits = 1;
    cache.fast_path = BPP_FAST_PATH_NONE;
    return 0;
}

func bpp_shape_cache_probe_guard(cache: *BppShapeCache, shape: u64, elem_size: u64, len_class: u64, hot: u64, profiled: u64, epoch: u64) -> u64 {
    if (cache == 0) { return 0; }
    if (cache.shape == shape && cache.elem_size == elem_size && cache.len_class == len_class && cache.hot == hot && cache.profiled == profiled && cache.last_epoch == epoch) {
        cache.hits = cache.hits + 1;
        return 1;
    }
    cache.shape = shape;
    cache.elem_size = elem_size;
    cache.len_class = len_class;
    cache.hot = hot;
    cache.profiled = profiled;
    cache.last_epoch = epoch;
    cache.misses = cache.misses + 1;
    cache.hits = 1;
    cache.fast_path = BPP_FAST_PATH_NONE;
    return 0;
}

func bpp_shape_cache_select_fast_path_len(cache: *BppShapeCache, shape: u64, elem_size: u64, len: u64, hot: u64, profiled: u64, epoch: u64) -> u64 {
    var chosen: u64 = bpp_fast_path_for_shape_len(shape, hot, profiled, elem_size, len);
    if (cache == 0) { return chosen; }
    var hit: u64 = bpp_shape_cache_probe_guard(cache, shape, elem_size, bpp_tag_len_class(len), hot, profiled, epoch);
    if (chosen == BPP_FAST_PATH_NONE) {
        cache.fast_path = BPP_FAST_PATH_NONE;
    } else if (hit != 0 && cache.hits >= BPP_SHAPE_CACHE_HOT_HITS) {
        cache.fast_path = chosen;
    } else {
        cache.fast_path = BPP_FAST_PATH_SCALAR;
    }
    return cache.fast_path;
}

func bpp_shape_cache_select_fast_path_len_tuned(cache: *BppShapeCache, shape: u64, elem_size: u64, len: u64, hot: u64, profiled: u64, epoch: u64, tuning: *BppTagTuning) -> u64 {
    var chosen: u64 = bpp_fast_path_for_shape_len_tuned(shape, hot, profiled, elem_size, len, tuning);
    if (cache == 0) { return chosen; }
    var hit: u64 = bpp_shape_cache_probe_guard(cache, shape, elem_size, bpp_tag_len_class(len), hot, profiled, epoch);
    var needed_hits: u64 = BPP_SHAPE_CACHE_HOT_HITS;
    if (tuning != 0 && tuning.cache_hot_hits != 0) { needed_hits = tuning.cache_hot_hits; }
    if (chosen == BPP_FAST_PATH_NONE) {
        cache.fast_path = BPP_FAST_PATH_NONE;
    } else if (hit != 0 && cache.hits >= needed_hits) {
        cache.fast_path = chosen;
    } else {
        cache.fast_path = BPP_FAST_PATH_SCALAR;
    }
    return cache.fast_path;
}

func bpp_shape_cache_select_fast_path(cache: *BppShapeCache, shape: u64, elem_size: u64, hot: u64, profiled: u64, epoch: u64) -> u64 {
    return bpp_shape_cache_select_fast_path_len(cache, shape, elem_size, bpp_vector_lanes_for_shape(shape, elem_size), hot, profiled, epoch);
}

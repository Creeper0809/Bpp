func bpp_tag_slice_is_vector_candidate<T>(s: *BppTaggedSlice<T>) -> u64 {
    if (s == 0 || s.len == 0) { return 0; }
    var shape: u64 = bpp_tag_slice_shape<T>(s);
    if (shape == BPP_TAG_SHAPE_I64) { return 1; }
    if (shape == BPP_TAG_SHAPE_U64) { return 1; }
    if (shape == BPP_TAG_SHAPE_F64) { return 1; }
    if (shape == BPP_TAG_SHAPE_NUMBER) { return 1; }
    if (shape == BPP_TAG_SHAPE_POD) { return 1; }
    return 0;
}

func bpp_slice_proof_empty() -> BppSliceProof {
    var out: BppSliceProof;
    out.base = 0;
    out.len = 0;
    out.start = 0;
    out.end_index = 0;
    out.shape = BPP_TAG_SHAPE_UNKNOWN;
    out.stable_bounds = 0;
    out.nonnull = 0;
    out.effect_safe = 0;
    out.epoch = 0;
    return out;
}

func bpp_slice_proof_from_tagged<T>(s: *BppTaggedSlice<T>) -> BppSliceProof {
    var out: BppSliceProof = bpp_slice_proof_empty();
    if (s == 0) { return out; }
    out.base = bpp_tag_strip((u64)s.ptr);
    out.len = s.len;
    out.end_index = s.len;
    out.shape = bpp_tag_slice_shape<T>(s);
    out.stable_bounds = 1;
    if (out.base != 0) { out.nonnull = 1; }
    if (bpp_tag_profiled_raw((u64)s.ptr) != 0 || bpp_tag_ownership_raw((u64)s.ptr) == BPP_TAG_OWN_BORROWED) {
        out.effect_safe = 1;
    }
    return out;
}

func bpp_slice_proof_subslice(proof: *BppSliceProof, start: u64, len: u64) -> BppSliceProof {
    if (proof == 0) { return bpp_slice_proof_empty(); }
    var out: BppSliceProof = *proof;
    if (start >= proof.len) {
        out.start = proof.start + proof.len;
        out.len = 0;
        out.end_index = out.start;
        out.shape = BPP_TAG_SHAPE_EMPTY;
        out.nonnull = 0;
        return out;
    }
    var avail: u64 = proof.len - start;
    var len2: u64 = len;
    if (len2 > avail) { len2 = avail; }
    out.start = proof.start + start;
    out.len = len2;
    out.end_index = out.start + len2;
    if (len2 == 0) {
        out.shape = BPP_TAG_SHAPE_EMPTY;
        out.nonnull = 0;
    }
    return out;
}

func bpp_slice_proof_can_skip_bounds(proof: *BppSliceProof, index: u64) -> u64 {
    if (proof == 0) { return 0; }
    if (proof.stable_bounds == 0 || proof.nonnull == 0) { return 0; }
    if (index < proof.len) { return 1; }
    return 0;
}

func bpp_slice_proof_can_skip_range_bounds(proof: *BppSliceProof, start: u64, len: u64) -> u64 {
    if (proof == 0) { return 0; }
    if (proof.stable_bounds == 0 || proof.nonnull == 0) { return 0; }
    if (start > proof.len) { return 0; }
    if (len > proof.len - start) { return 0; }
    return 1;
}

func bpp_slice_proof_contains_absolute_range(proof: *BppSliceProof, start: u64, end_index: u64) -> u64 {
    if (proof == 0) { return 0; }
    if (proof.stable_bounds == 0 || proof.nonnull == 0) { return 0; }
    if (end_index < start) { return 0; }
    if (start < proof.start) { return 0; }
    if (end_index > proof.end_index) { return 0; }
    return 1;
}

func bpp_slice_proof_element_ptr<T>(proof: *BppSliceProof, index: u64) -> *T {
    if (bpp_slice_proof_can_skip_bounds(proof, index) == 0) { return (*T)0; }
    return (*T)(proof.base + ((proof.start + index) * sizeof(T)));
}

func bpp_shape_is_vectorizable(shape: u64) -> u64 {
    if (shape == BPP_TAG_SHAPE_I64) { return 1; }
    if (shape == BPP_TAG_SHAPE_U64) { return 1; }
    if (shape == BPP_TAG_SHAPE_F64) { return 1; }
    if (shape == BPP_TAG_SHAPE_POD) { return 1; }
    return 0;
}

func bpp_slice_proof_can_vectorize(proof: *BppSliceProof) -> u64 {
    if (proof == 0 || proof.len == 0 || proof.stable_bounds == 0 || proof.effect_safe == 0) { return 0; }
    return bpp_shape_is_vectorizable(proof.shape);
}

func bpp_slice_proof_vector_plan(proof: *BppSliceProof, profile: *BppLoopProfile, elem_size: u64) -> BppVectorPlan {
    var out: BppVectorPlan;
    out.fast_path = BPP_FAST_PATH_SCALAR;
    out.lanes = 1;
    out.unroll = 1;
    out.shape = BPP_TAG_SHAPE_UNKNOWN;
    out.hot = 0;
    if (proof == 0) { return out; }
    out.shape = proof.shape;
    if (profile != 0 && bpp_loop_profile_is_hot(profile) != 0) { out.hot = 1; }
    if (bpp_slice_proof_can_vectorize(proof) == 0 || out.hot == 0) { return out; }
    return bpp_vector_plan_for(proof.shape, elem_size, proof.len, 1, out.hot);
}

func bpp_tag_slice_subslice<T>(s: *BppTaggedSlice<T>, start: u64, len: u64) -> BppTaggedSlice<T> {
    if (s == 0) {
        return bpp_tag_slice_from_ptr<T>((*T)0, 0, BPP_TAG_SHAPE_EMPTY);
    }
    var raw: *T = bpp_tag_slice_raw<T>(s);
    if (raw == 0 || start >= s.len) {
        return bpp_tag_slice_from_raw_tag<T>((*T)0, 0, bpp_tag_lifecycle_raw((u64)s.ptr), bpp_tag_ownership_raw((u64)s.ptr), bpp_tag_storage_raw((u64)s.ptr), bpp_tag_barrier_raw((u64)s.ptr), BPP_TAG_SHAPE_EMPTY, bpp_tag_profiled_raw((u64)s.ptr));
    }
    var avail: u64 = s.len - start;
    var len2: u64 = len;
    if (len2 > avail) { len2 = avail; }
    var ptr2: *T = (*T)((u64)raw + start * sizeof(T));
    return bpp_tag_slice_from_raw_tag<T>(ptr2, len2, bpp_tag_lifecycle_raw((u64)s.ptr), bpp_tag_ownership_raw((u64)s.ptr), bpp_tag_storage_raw((u64)s.ptr), bpp_tag_barrier_raw((u64)s.ptr), bpp_tag_shape_raw((u64)s.ptr), bpp_tag_profiled_raw((u64)s.ptr));
}

func bpp_vector_lanes_for_shape(shape: u64, elem_size: u64) -> u64 {
    if (bpp_shape_is_vectorizable(shape) == 0) { return 1; }
    if (elem_size == 0) { return 1; }
    var lanes: u64 = 32 / elem_size;
    if (lanes < 1) { lanes = 1; }
    if (lanes > 8) { lanes = 8; }
    return lanes;
}

func bpp_tag_len_class(len: u64) -> u64 {
    if (len == 0) { return BPP_TAG_LEN_EMPTY; }
    if (len < 4) { return BPP_TAG_LEN_TINY; }
    if (len < 16) { return BPP_TAG_LEN_SMALL; }
    if (len < 1024) { return BPP_TAG_LEN_MEDIUM; }
    return BPP_TAG_LEN_LARGE;
}

func bpp_fast_path_for_shape_len(shape: u64, hot: u64, profiled: u64, elem_size: u64, len: u64) -> u64 {
    if (len == 0) { return BPP_FAST_PATH_NONE; }
    if (bpp_shape_is_vectorizable(shape) == 0) { return BPP_FAST_PATH_SCALAR; }
    var lanes: u64 = bpp_vector_lanes_for_shape(shape, elem_size);
    if (hot != 0 && profiled != 0 && lanes >= 2 && len >= lanes) { return BPP_FAST_PATH_VECTOR; }
    if (len >= 2 && lanes >= 2) { return BPP_FAST_PATH_UNROLLED; }
    return BPP_FAST_PATH_SCALAR;
}

func bpp_fast_path_for_shape(shape: u64, hot: u64, profiled: u64, elem_size: u64) -> u64 {
    return bpp_fast_path_for_shape_len(shape, hot, profiled, elem_size, bpp_vector_lanes_for_shape(shape, elem_size));
}

func bpp_profile_hot_from_threshold(iterations: u64, threshold: u64) -> u64 {
    var limit: u64 = threshold;
    if (limit == 0) { limit = BPP_LOOP_PROFILE_DEFAULT_HOT_THRESHOLD; }
    if (iterations >= limit) { return 1; }
    return 0;
}

func bpp_tag_tuning_default() -> BppTagTuning {
    var out: BppTagTuning;
    out.hot_threshold = BPP_LOOP_PROFILE_DEFAULT_HOT_THRESHOLD;
    out.vector_min_len = BPP_TAG_TUNE_DEFAULT_VECTOR_MIN_LEN;
    out.unroll_min_len = BPP_TAG_TUNE_DEFAULT_UNROLL_MIN_LEN;
    out.cache_hot_hits = BPP_SHAPE_CACHE_HOT_HITS;
    out.max_lanes = BPP_TAG_TUNE_DEFAULT_MAX_LANES;
    return out;
}

func bpp_tag_tuning_from_benchmark(scalar_ticks: u64, vector_ticks: u64, samples: u64) -> BppTagTuning {
    var out: BppTagTuning = bpp_tag_tuning_default();
    if (samples == 0 || scalar_ticks == 0 || vector_ticks == 0) { return out; }
    if (vector_ticks < scalar_ticks) {
        out.hot_threshold = 64;
        out.vector_min_len = 2;
        out.unroll_min_len = 2;
        out.cache_hot_hits = 2;
    } else {
        out.hot_threshold = 2048;
        out.vector_min_len = 8;
        out.unroll_min_len = 4;
        out.cache_hot_hits = 5;
    }
    if (samples >= 1024 && vector_ticks * 2 < scalar_ticks) {
        out.hot_threshold = 16;
        out.vector_min_len = 2;
        out.cache_hot_hits = 1;
    }
    return out;
}

func bpp_profile_fast_path_for_shape_len(shape: u64, profiled: u64, elem_size: u64, len: u64, iterations: u64, hot_threshold: u64, vector_min_len: u64, unroll_min_len: u64, max_lanes: u64) -> u64 {
    if (len == 0) { return BPP_FAST_PATH_NONE; }
    if (bpp_shape_is_vectorizable(shape) == 0) { return BPP_FAST_PATH_SCALAR; }
    var lanes: u64 = bpp_vector_lanes_for_shape(shape, elem_size);
    if (max_lanes != 0 && lanes > max_lanes) { lanes = max_lanes; }
    var vector_min: u64 = vector_min_len;
    var unroll_min: u64 = unroll_min_len;
    if (vector_min == 0) { vector_min = BPP_TAG_TUNE_DEFAULT_VECTOR_MIN_LEN; }
    if (unroll_min == 0) { unroll_min = BPP_TAG_TUNE_DEFAULT_UNROLL_MIN_LEN; }
    var hot: u64 = bpp_profile_hot_from_threshold(iterations, hot_threshold);
    if (hot != 0 && profiled != 0 && lanes >= 2 && len >= vector_min && len >= lanes) { return BPP_FAST_PATH_VECTOR; }
    if (len >= unroll_min && lanes >= 2) { return BPP_FAST_PATH_UNROLLED; }
    return BPP_FAST_PATH_SCALAR;
}

func bpp_shape_inline_cache_fast_path(shape: u64, profiled: u64, elem_size: u64, len: u64, iterations: u64, hot_threshold: u64, cache_hits: u64, cache_hot_hits: u64, vector_min_len: u64, unroll_min_len: u64, max_lanes: u64) -> u64 {
    var chosen: u64 = bpp_profile_fast_path_for_shape_len(shape, profiled, elem_size, len, iterations, hot_threshold, vector_min_len, unroll_min_len, max_lanes);
    if (chosen == BPP_FAST_PATH_NONE) { return BPP_FAST_PATH_NONE; }
    var needed_hits: u64 = cache_hot_hits;
    if (needed_hits == 0) { needed_hits = BPP_SHAPE_CACHE_HOT_HITS; }
    if (cache_hits >= needed_hits) { return chosen; }
    return BPP_FAST_PATH_SCALAR;
}

func bpp_fast_path_for_shape_len_tuned(shape: u64, hot: u64, profiled: u64, elem_size: u64, len: u64, tuning: *BppTagTuning) -> u64 {
    if (len == 0) { return BPP_FAST_PATH_NONE; }
    if (bpp_shape_is_vectorizable(shape) == 0) { return BPP_FAST_PATH_SCALAR; }
    var lanes: u64 = bpp_vector_lanes_for_shape(shape, elem_size);
    var vector_min: u64 = BPP_TAG_TUNE_DEFAULT_VECTOR_MIN_LEN;
    var unroll_min: u64 = BPP_TAG_TUNE_DEFAULT_UNROLL_MIN_LEN;
    if (tuning != 0) {
        if (tuning.max_lanes != 0 && lanes > tuning.max_lanes) { lanes = tuning.max_lanes; }
        if (tuning.vector_min_len != 0) { vector_min = tuning.vector_min_len; }
        if (tuning.unroll_min_len != 0) { unroll_min = tuning.unroll_min_len; }
    }
    if (hot != 0 && profiled != 0 && lanes >= 2 && len >= vector_min && len >= lanes) { return BPP_FAST_PATH_VECTOR; }
    if (len >= unroll_min && lanes >= 2) { return BPP_FAST_PATH_UNROLLED; }
    return BPP_FAST_PATH_SCALAR;
}

func bpp_vector_plan_for(shape: u64, elem_size: u64, len: u64, profiled: u64, hot: u64) -> BppVectorPlan {
    var out: BppVectorPlan;
    out.fast_path = BPP_FAST_PATH_NONE;
    out.lanes = 1;
    out.unroll = 1;
    out.shape = shape;
    out.hot = hot;
    if (len == 0) { return out; }
    out.lanes = bpp_vector_lanes_for_shape(shape, elem_size);
    out.unroll = out.lanes;
    if (out.unroll > len) { out.unroll = len; }
    if (out.unroll < 2 && len >= 4) { out.unroll = 4; }
    out.fast_path = bpp_fast_path_for_shape_len(shape, hot, profiled, elem_size, len);
    return out;
}

func bpp_vector_plan_for_tuned(shape: u64, elem_size: u64, len: u64, profiled: u64, hot: u64, tuning: *BppTagTuning) -> BppVectorPlan {
    var out: BppVectorPlan = bpp_vector_plan_for(shape, elem_size, len, profiled, hot);
    if (len == 0) { return out; }
    if (tuning != 0 && tuning.max_lanes != 0 && out.lanes > tuning.max_lanes) {
        out.lanes = tuning.max_lanes;
    }
    out.unroll = out.lanes;
    if (out.unroll > len) { out.unroll = len; }
    out.fast_path = bpp_fast_path_for_shape_len_tuned(shape, hot, profiled, elem_size, len, tuning);
    return out;
}

func bpp_tag_fast_guard_empty() -> BppTagFastGuard {
    var out: BppTagFastGuard;
    out.shape = BPP_TAG_SHAPE_UNKNOWN;
    out.elem_size = 0;
    out.len_class = BPP_TAG_LEN_EMPTY;
    out.profiled = 0;
    out.hot = 0;
    out.epoch = 0;
    out.fast_path = BPP_FAST_PATH_NONE;
    out.lanes = 1;
    return out;
}

func bpp_tag_fast_guard_from_slice<T>(s: *BppTaggedSlice<T>, profile: *BppLoopProfile, epoch: u64) -> BppTagFastGuard {
    var out: BppTagFastGuard = bpp_tag_fast_guard_empty();
    if (s == 0) { return out; }
    out.shape = bpp_tag_slice_shape<T>(s);
    out.elem_size = sizeof(T);
    out.len_class = bpp_tag_len_class(s.len);
    out.profiled = bpp_tag_profiled_raw((u64)s.ptr);
    out.hot = bpp_loop_profile_is_hot(profile);
    out.epoch = epoch;
    out.lanes = bpp_vector_lanes_for_shape(out.shape, out.elem_size);
    out.fast_path = bpp_fast_path_for_shape_len(out.shape, out.hot, out.profiled, out.elem_size, s.len);
    return out;
}

func bpp_tag_fast_guard_matches_slice<T>(guard: *BppTagFastGuard, s: *BppTaggedSlice<T>, profile: *BppLoopProfile, epoch: u64) -> u64 {
    if (guard == 0 || s == 0) { return 0; }
    if (guard.shape != bpp_tag_slice_shape<T>(s)) { return 0; }
    if (guard.elem_size != sizeof(T)) { return 0; }
    if (guard.len_class != bpp_tag_len_class(s.len)) { return 0; }
    if (guard.profiled != bpp_tag_profiled_raw((u64)s.ptr)) { return 0; }
    if (guard.hot != bpp_loop_profile_is_hot(profile)) { return 0; }
    if (guard.epoch != epoch) { return 0; }
    return 1;
}

func bpp_tag_access_plan_empty() -> BppTaggedAccessPlan {
    var out: BppTaggedAccessPlan;
    out.shape = BPP_TAG_SHAPE_UNKNOWN;
    out.elem_size = 0;
    out.len = 0;
    out.len_class = BPP_TAG_LEN_EMPTY;
    out.profiled = 0;
    out.hot = 0;
    out.epoch = 0;
    out.fast_path = BPP_FAST_PATH_NONE;
    out.lanes = 1;
    out.stable_bounds = 0;
    out.nonnull = 0;
    out.effect_safe = 0;
    out.vectorizable = 0;
    return out;
}

func bpp_tag_access_plan_from_slice<T>(s: *BppTaggedSlice<T>, profile: *BppLoopProfile, epoch: u64) -> BppTaggedAccessPlan {
    var out: BppTaggedAccessPlan = bpp_tag_access_plan_empty();
    if (s == 0) { return out; }
    out.shape = bpp_tag_slice_shape<T>(s);
    out.elem_size = sizeof(T);
    out.len = s.len;
    out.len_class = bpp_tag_len_class(s.len);
    out.profiled = bpp_tag_profiled_raw((u64)s.ptr);
    out.hot = bpp_loop_profile_is_hot(profile);
    out.epoch = epoch;
    out.lanes = bpp_vector_lanes_for_shape(out.shape, out.elem_size);
    out.stable_bounds = 1;
    if (bpp_tag_strip((u64)s.ptr) != 0) { out.nonnull = 1; }
    if (out.profiled != 0 || bpp_tag_ownership_raw((u64)s.ptr) == BPP_TAG_OWN_BORROWED) {
        out.effect_safe = 1;
    }
    if (out.len != 0 && out.stable_bounds != 0 && out.nonnull != 0 && out.effect_safe != 0 && bpp_shape_is_vectorizable(out.shape) != 0) {
        out.vectorizable = 1;
    }
    out.fast_path = bpp_fast_path_for_shape_len(out.shape, out.hot, out.profiled, out.elem_size, out.len);
    if (out.vectorizable == 0 && out.fast_path == BPP_FAST_PATH_VECTOR) {
        out.fast_path = BPP_FAST_PATH_SCALAR;
    }
    return out;
}

func bpp_tag_access_plan_matches_slice<T>(plan: *BppTaggedAccessPlan, s: *BppTaggedSlice<T>, profile: *BppLoopProfile, epoch: u64) -> u64 {
    if (plan == 0 || s == 0) { return 0; }
    if (plan.shape != bpp_tag_slice_shape<T>(s)) { return 0; }
    if (plan.elem_size != sizeof(T)) { return 0; }
    if (plan.len != s.len) { return 0; }
    if (plan.len_class != bpp_tag_len_class(s.len)) { return 0; }
    if (plan.profiled != bpp_tag_profiled_raw((u64)s.ptr)) { return 0; }
    if (plan.hot != bpp_loop_profile_is_hot(profile)) { return 0; }
    if (plan.epoch != epoch) { return 0; }
    return 1;
}

func bpp_tag_access_plan_can_index(plan: *BppTaggedAccessPlan, index: u64) -> u64 {
    if (plan == 0) { return 0; }
    if (plan.stable_bounds == 0 || plan.nonnull == 0) { return 0; }
    if (index < plan.len) { return 1; }
    return 0;
}

func bpp_tag_access_plan_can_range(plan: *BppTaggedAccessPlan, start: u64, len: u64) -> u64 {
    if (plan == 0) { return 0; }
    if (plan.stable_bounds == 0 || plan.nonnull == 0) { return 0; }
    if (start > plan.len) { return 0; }
    if (len > plan.len - start) { return 0; }
    return 1;
}

func bpp_tag_access_plan_hot_path(plan: *BppTaggedAccessPlan) -> u64 {
    if (plan == 0) { return BPP_FAST_PATH_NONE; }
    if (plan.fast_path == BPP_FAST_PATH_NONE) { return BPP_FAST_PATH_NONE; }
    return plan.fast_path;
}

func bpp_tag_access_plan_cold_path<T>(plan: *BppTaggedAccessPlan, s: *BppTaggedSlice<T>, profile: *BppLoopProfile, epoch: u64, require_index: u64, index: u64) -> u64 {
    if (plan == 0 || s == 0) { return BPP_COLD_PATH_GUARD_MISS; }
    if (bpp_tag_access_plan_matches_slice<T>(plan, s, profile, epoch) == 0) { return BPP_COLD_PATH_GUARD_MISS; }
    if (require_index != 0 && bpp_tag_access_plan_can_index(plan, index) == 0) { return BPP_COLD_PATH_BOUNDS; }
    if (plan.fast_path == BPP_FAST_PATH_NONE) { return BPP_COLD_PATH_SCALAR; }
    return BPP_COLD_PATH_NONE;
}

func bpp_hot_path_plan_from_access(plan: *BppTaggedAccessPlan, require_index: u64, index: u64) -> BppHotPathPlan {
    var out: BppHotPathPlan;
    out.fast_path = BPP_FAST_PATH_NONE;
    out.cold_path = BPP_COLD_PATH_GUARD_MISS;
    out.epoch = 0;
    out.lanes = 1;
    out.deopt_reason = BPP_COLD_PATH_GUARD_MISS;
    if (plan == 0) { return out; }
    out.fast_path = bpp_tag_access_plan_hot_path(plan);
    out.epoch = plan.epoch;
    out.lanes = plan.lanes;
    out.cold_path = BPP_COLD_PATH_NONE;
    out.deopt_reason = BPP_COLD_PATH_NONE;
    if (require_index != 0 && bpp_tag_access_plan_can_index(plan, index) == 0) {
        out.fast_path = BPP_FAST_PATH_NONE;
        out.cold_path = BPP_COLD_PATH_BOUNDS;
        out.deopt_reason = BPP_COLD_PATH_BOUNDS;
    } else if (out.fast_path == BPP_FAST_PATH_NONE) {
        out.cold_path = BPP_COLD_PATH_SCALAR;
        out.deopt_reason = BPP_COLD_PATH_SCALAR;
    }
    return out;
}

func bpp_tag_slice_vector_plan<T>(profile: *BppLoopProfile, s: *BppTaggedSlice<T>) -> BppVectorPlan {
    var hot: u64 = bpp_loop_profile_is_hot(profile);
    if (s == 0) {
        return bpp_vector_plan_for(BPP_TAG_SHAPE_UNKNOWN, sizeof(T), 0, 0, hot);
    }
    return bpp_vector_plan_for(bpp_tag_slice_shape<T>(s), sizeof(T), s.len, bpp_tag_profiled_raw((u64)s.ptr), hot);
}

func bpp_tag_slice_sum_u64(s: *BppTaggedSlice<u64>) -> u64 {
    if (s == 0 || s.len == 0) { return 0; }
    var raw: *u64 = bpp_tag_slice_raw<u64>(s);
    if (raw == 0) { return 0; }
    var plan: BppVectorPlan = bpp_vector_plan_for(bpp_tag_slice_shape<u64>(s), sizeof(u64), s.len, bpp_tag_profiled_raw((u64)s.ptr), 1);
    var acc: u64 = 0;
    var i: u64 = 0;
    if (plan.fast_path == BPP_FAST_PATH_VECTOR || plan.fast_path == BPP_FAST_PATH_UNROLLED) {
        while (i + 4 <= s.len) {
            acc = acc + raw[i] + raw[i + 1] + raw[i + 2] + raw[i + 3];
            i = i + 4;
        }
    }
    while (i < s.len) {
        acc = acc + raw[i];
        i = i + 1;
    }
    return acc;
}

func bpp_tag_slice_sum_i64(s: *BppTaggedSlice<i64>) -> i64 {
    if (s == 0 || s.len == 0) { return 0; }
    var raw: *i64 = bpp_tag_slice_raw<i64>(s);
    if (raw == 0) { return 0; }
    var plan: BppVectorPlan = bpp_vector_plan_for(bpp_tag_slice_shape<i64>(s), sizeof(i64), s.len, bpp_tag_profiled_raw((u64)s.ptr), 1);
    var acc: i64 = 0;
    var i: u64 = 0;
    if (plan.fast_path == BPP_FAST_PATH_VECTOR || plan.fast_path == BPP_FAST_PATH_UNROLLED) {
        while (i + 4 <= s.len) {
            acc = acc + raw[i] + raw[i + 1] + raw[i + 2] + raw[i + 3];
            i = i + 4;
        }
    }
    while (i < s.len) {
        acc = acc + raw[i];
        i = i + 1;
    }
    return acc;
}

func bpp_tag_slice_sum_f64(s: *BppTaggedSlice<f64>) -> f64 {
    if (s == 0 || s.len == 0) { return 0.0; }
    var raw: *f64 = bpp_tag_slice_raw<f64>(s);
    if (raw == 0) { return 0.0; }
    var plan: BppVectorPlan = bpp_vector_plan_for(bpp_tag_slice_shape<f64>(s), sizeof(f64), s.len, bpp_tag_profiled_raw((u64)s.ptr), 1);
    var acc: f64 = 0.0;
    var i: u64 = 0;
    if (plan.fast_path == BPP_FAST_PATH_VECTOR || plan.fast_path == BPP_FAST_PATH_UNROLLED) {
        while (i + 4 <= s.len) {
            acc = acc + raw[i] + raw[i + 1] + raw[i + 2] + raw[i + 3];
            i = i + 4;
        }
    }
    while (i < s.len) {
        acc = acc + raw[i];
        i = i + 1;
    }
    return acc;
}

func bpp_tag_slice_min_u64(s: *BppTaggedSlice<u64>) -> u64 {
    if (s == 0 || s.len == 0) { return 0; }
    var raw: *u64 = bpp_tag_slice_raw<u64>(s);
    if (raw == 0) { return 0; }
    var plan: BppVectorPlan = bpp_vector_plan_for(bpp_tag_slice_shape<u64>(s), sizeof(u64), s.len, bpp_tag_profiled_raw((u64)s.ptr), 1);
    var acc: u64 = raw[0];
    var i: u64 = 1;
    if ((plan.fast_path == BPP_FAST_PATH_VECTOR || plan.fast_path == BPP_FAST_PATH_UNROLLED) && s.len >= 4) {
        acc = raw[0];
        if (raw[1] < acc) { acc = raw[1]; }
        if (raw[2] < acc) { acc = raw[2]; }
        if (raw[3] < acc) { acc = raw[3]; }
        i = 4;
        while (i + 4 <= s.len) {
            if (raw[i] < acc) { acc = raw[i]; }
            if (raw[i + 1] < acc) { acc = raw[i + 1]; }
            if (raw[i + 2] < acc) { acc = raw[i + 2]; }
            if (raw[i + 3] < acc) { acc = raw[i + 3]; }
            i = i + 4;
        }
    }
    while (i < s.len) {
        if (raw[i] < acc) { acc = raw[i]; }
        i = i + 1;
    }
    return acc;
}


// Builtin dynamic numeric value (Number).
// Tagged storage: small signed 63-bit immediate or pointer to a heap payload.
// Lifetime is arena-style monotonic allocation.

import std.io;
import std.vec;

// Limbs are base 2^31. 31 bits keeps a single limb multiply plus carry
// inside u64 while still making shifts and bitwise operations limb-native.
const NUMBER_BASE_BITS = 31;
const NUMBER_BASE = 2147483648;
const NUMBER_BASE_MASK = 2147483647;
const NUMBER_MAX_U64 = 18446744073709551615;
const NUMBER_MAX_I64_U64 = 9223372036854775807;
const NUMBER_MIN_I64_MAG = 9223372036854775808;

const NUMBER_TAG_SMALL = 1;
const NUMBER_TAG_MASK = 1;
const NUMBER_HEAP_TAG_MASK = 7;
const NUMBER_TAG_BIG = 0;
const NUMBER_TAG_REAL = 2;
const NUMBER_TAG_COMPLEX = 4;
const NUMBER_PTR_MASK = 18446744073709551608;

const NUMBER_SMALL_MAX_U64 = 4611686018427387903;
const NUMBER_SMALL_MIN_I64 = -4611686018427387904;
const NUMBER_SMALL_MAX_I64 = 4611686018427387903;

const NUMBER_BITWISE_AND = 0;
const NUMBER_BITWISE_OR = 1;
const NUMBER_BITWISE_XOR = 2;
const NUMBER_KARATSUBA_THRESHOLD = 24;
const NUMBER_KARATSUBA_UNBALANCED_FACTOR = 2;
const NUMBER_TOOM3_THRESHOLD = 72;
const NUMBER_TOOM3_UNBALANCED_FACTOR = 3;
const NUMBER_NTT_THRESHOLD = 80;
const NUMBER_DIV_DC_THRESHOLD = 64;
const NUMBER_NTT_CHUNK_BITS = 15;
const NUMBER_NTT_CHUNK_BASE = 32768;
const NUMBER_NTT_CHUNK_MASK = 32767;
const NUMBER_NTT_MOD1 = 998244353;
const NUMBER_NTT_MOD2 = 1004535809;
const NUMBER_NTT_ROOT = 3;
const NUMBER_NTT_MAX_LEN = 2097152;

struct Number {
    public bits: u64;
}

struct NumberBig {
    public sign: i64;
    public digits: *Vec<u32>;
}

struct NumberReal {
    public value: f64;
}

struct NumberComplex {
    public real: Number;
    public imag: Number;
}

struct NumberBigDivMod {
    public q: *NumberBig;
    public r: *NumberBig;
}

struct NumberDivMod {
    public q: Number;
    public r: Number;
}

func number_make_real(v: f64) -> Number {
    var real: *NumberReal = new NumberReal{v};
    return Number { (((u64)real) & NUMBER_PTR_MASK) | NUMBER_TAG_REAL };
}

func number_make_complex(real: Number, imag: Number) -> Number {
    if (imag.signum() == 0) {
        return Number { real.bits };
    }
    var c: *NumberComplex = new NumberComplex{real, imag};
    return Number { (((u64)c) & NUMBER_PTR_MASK) | NUMBER_TAG_COMPLEX };
}

impl NumberBig {
    public constructor() {
        self.sign = 0;
        self.digits = 0;
    }

    public static func alloc(sign: i64, cap: u64) -> *NumberBig {
        var c: u64 = cap;
        if (c < 1) { c = 1; }
        var big: *NumberBig = new NumberBig{};
        big.sign = sign;
        var digits_buf: u64 = heap_alloc(c * sizeof(u32));
        big.digits = new Vec<u32>{digits_buf, 0, c};
        return big;
    }

    public static func zero() -> *NumberBig {
        return NumberBig.alloc(0, 1);
    }

    public static func alloc_zeroed(sign: i64, len: u64) -> *NumberBig {
        var out: *NumberBig = NumberBig.alloc(sign, len + 1);
        for (var i: u64 = 0; i < len; i = i + 1) {
            out.digits.push(0);
        }
        return out;
    }

    public static func limb_low(v: u64) -> u32 {
        return (u32)(v & NUMBER_BASE_MASK);
    }

    public static func limb_carry(v: u64) -> u64 {
        return v >> NUMBER_BASE_BITS;
    }

    public static func digit_or_zero(big: *NumberBig, len: u64, i: u64) -> u64 {
        if (big == 0 || big.digits == 0 || i >= len) { return 0; }
        return (u64)big.digits.get(i);
    }

    public static func limb_and_value(a: u64, b: u64) -> u64 {
        return a & b;
    }

    public static func limb_or_value(a: u64, b: u64) -> u64 {
        var both: u64 = a & b;
        return a + b - both;
    }

    public static func limb_xor_value(a: u64, b: u64) -> u64 {
        var both: u64 = a & b;
        return a + b - both - both;
    }

    public static func mod_pow(base: u64, exp: u64, mod: u64) -> u64 {
        var result: u64 = 1;
        var b: u64 = base % mod;
        var e: u64 = exp;
        while (e != 0) {
            if ((e & 1) != 0) {
                result = (result * b) % mod;
            }
            b = (b * b) % mod;
            e = e >> 1;
        }
        return result;
    }

    public static func mod_inv(v: u64, mod: u64) -> u64 {
        return NumberBig.mod_pow(v, mod - 2, mod);
    }

    public static func next_pow2(v: u64) -> u64 {
        var n: u64 = 1;
        while (n < v) {
            n = n << 1;
        }
        return n;
    }

    public static func vec_u64_zeroed(len: u64) -> *Vec<u64> {
        var buf: u64 = heap_alloc(len * sizeof(u64));
        var out: *Vec<u64> = new Vec<u64>{buf, 0, len};
        for (var i: u64 = 0; i < len; i = i + 1) {
            out.push(0);
        }
        return out;
    }

    public static func from_u64_raw(v: u64) -> *NumberBig {
        if (v == 0) {
            return NumberBig.zero();
        }
        var out: *NumberBig = NumberBig.alloc(1, 4);
        var mag: u64 = v;
        while (mag != 0) {
            out.digits.push(NumberBig.limb_low(mag));
            mag = mag >> NUMBER_BASE_BITS;
        }
        out.trim_inplace();
        return out;
    }

    public static func pow2_abs(bits: u64) -> *NumberBig {
        var limb_shift: u64 = bits / NUMBER_BASE_BITS;
        var bit_shift: u64 = bits % NUMBER_BASE_BITS;
        var out: *NumberBig = NumberBig.alloc_zeroed(1, limb_shift + 1);
        var digit: u64 = 1;
        digit = digit << bit_shift;
        out.digits.set(limb_shift, (u32)digit);
        out.trim_inplace();
        return out;
    }

    public static func from_i64_raw(v: i64) -> *NumberBig {
        if (v == 0) {
            return NumberBig.zero();
        }
        var mag: u64 = 0;
        Number.i64_abs_mag(v, &mag);
        var out: *NumberBig = NumberBig.from_u64_raw(mag);
        if (v < 0 && out.sign != 0) { out.sign = -1; }
        return out;
    }

    public func trim_inplace(self: *NumberBig) -> u64 {
        if (self == 0 || self.digits == 0) { return 0; }
        var n: u64 = self.digits.len();
        while (n > 0) {
            var last: u32 = self.digits.get(n - 1);
            if ((u64)last != 0) { break; }
            self.digits.pop();
            n = n - 1;
        }
        if (n == 0) {
            self.sign = 0;
            return 0;
        }
        if (self.sign > 0) { self.sign = 1; }
        else if (self.sign < 0) { self.sign = -1; }
        return 0;
    }

    public func copy(self: *NumberBig) -> *NumberBig {
        if (self == 0) {
            return NumberBig.zero();
        }
        var n: u64 = 0;
        if (self.digits != 0) { n = self.digits.len(); }
        var out: *NumberBig = NumberBig.alloc(self.sign, n + 1);
        for (var i: u64 = 0; i < n; i = i + 1) {
            out.digits.push(self.digits.get(i));
        }
        out.trim_inplace();
        return out;
    }

    public func abs_copy(self: *NumberBig) -> *NumberBig {
        var out: *NumberBig = self.copy();
        if (out.sign < 0) { out.sign = 1; }
        return out;
    }

    public func abs_to_u64_checked(self: *NumberBig, out: *u64) -> u64 {
        if (out == 0) { return 0; }
        out[0] = 0;
        if (self == 0 || self.sign == 0 || self.digits == 0) { return 1; }
        var n: u64 = self.digits.len();
        var acc: u64 = 0;
        var i: u64 = n;
        while (i > 0) {
            i = i - 1;
            var limb: u64 = (u64)self.digits.get(i);
            if (acc > (NUMBER_MAX_U64 - limb) / NUMBER_BASE) { return 0; }
            acc = acc * NUMBER_BASE + limb;
        }
        out[0] = acc;
        return 1;
    }

    public func try_to_i64(self: *NumberBig, out: *i64) -> u64 {
        if (out == 0) { return 0; }
        out[0] = 0;
        if (self == 0 || self.sign == 0) { return 1; }
        var mag: u64 = 0;
        if (self.abs_to_u64_checked(&mag) == 0) { return 0; }
        if (self.sign > 0) {
            if (mag > NUMBER_MAX_I64_U64) { return 0; }
            out[0] = (i64)mag;
            return 1;
        }
        if (mag > NUMBER_MIN_I64_MAG) { return 0; }
        if (mag == NUMBER_MIN_I64_MAG) {
            out[0] = i64.MIN;
            return 1;
        }
        out[0] = 0 - (i64)mag;
        return 1;
    }

    public func abs_cmp(self: *NumberBig, rhs: *NumberBig) -> i64 {
        var an: u64 = 0;
        var bn: u64 = 0;
        if (self != 0 && self.digits != 0) { an = self.digits.len(); }
        if (rhs != 0 && rhs.digits != 0) { bn = rhs.digits.len(); }
        if (an > bn) { return 1; }
        if (an < bn) { return -1; }
        var i: u64 = an;
        while (i > 0) {
            i = i - 1;
            var av: u64 = (u64)self.digits.get(i);
            var bv: u64 = (u64)rhs.digits.get(i);
            if (av > bv) { return 1; }
            if (av < bv) { return -1; }
        }
        return 0;
    }

    public func add_abs(self: *NumberBig, rhs: *NumberBig) -> *NumberBig {
        var an: u64 = 0;
        var bn: u64 = 0;
        if (self != 0 && self.digits != 0) { an = self.digits.len(); }
        if (rhs != 0 && rhs.digits != 0) { bn = rhs.digits.len(); }
        var n: u64 = an;
        if (bn > n) { n = bn; }

        var out: *NumberBig = NumberBig.alloc(1, n + 2);
        var carry: u64 = 0;
        for (var i: u64 = 0; i < n; i = i + 1) {
            var av: u64 = 0;
            var bv: u64 = 0;
            if (i < an) { av = (u64)self.digits.get(i); }
            if (i < bn) { bv = (u64)rhs.digits.get(i); }
            var cur: u64 = av + bv + carry;
            out.digits.push(NumberBig.limb_low(cur));
            carry = NumberBig.limb_carry(cur);
        }
        if (carry != 0) {
            out.digits.push((u32)carry);
        }
        out.trim_inplace();
        return out;
    }

    public func sub_abs(self: *NumberBig, rhs: *NumberBig) -> *NumberBig {
        // Preconditions: |self| >= |rhs|
        var an: u64 = 0;
        var bn: u64 = 0;
        if (self != 0 && self.digits != 0) { an = self.digits.len(); }
        if (rhs != 0 && rhs.digits != 0) { bn = rhs.digits.len(); }

        var out: *NumberBig = NumberBig.alloc(1, an + 1);
        var borrow: i64 = 0;
        for (var i: u64 = 0; i < an; i = i + 1) {
            var av: i64 = (i64)(u64)self.digits.get(i);
            var bv: i64 = 0;
            if (i < bn) { bv = (i64)(u64)rhs.digits.get(i); }
            var cur: i64 = av - bv - borrow;
            if (cur < 0) {
                cur = cur + (i64)NUMBER_BASE;
                borrow = 1;
            } else {
                borrow = 0;
            }
            out.digits.push((u32)(u64)cur);
        }
        out.trim_inplace();
        return out;
    }

    public func add_mul_digit_shift_abs(
        self: *NumberBig,
        out: *NumberBig,
        digit: u64,
        shift: u64
    ) -> u64 {
        if (self == 0 || out == 0 || self.sign == 0 || digit == 0) {
            return 0;
        }
        var n: u64 = self.digits.len();
        var carry: u64 = 0;
        for (var i: u64 = 0; i < n; i = i + 1) {
            var idx: u64 = i + shift;
            var cur: u64 =
                (u64)out.digits.get(idx) +
                (u64)self.digits.get(i) * digit +
                carry;
            out.digits.set(idx, NumberBig.limb_low(cur));
            carry = NumberBig.limb_carry(cur);
        }
        var k: u64 = n + shift;
        while (carry != 0) {
            var cur2: u64 = (u64)out.digits.get(k) + carry;
            out.digits.set(k, NumberBig.limb_low(cur2));
            carry = NumberBig.limb_carry(cur2);
            k = k + 1;
        }
        return 0;
    }

    public static func add_shifted_abs_to(
        out: *NumberBig,
        src: *NumberBig,
        shift: u64
    ) -> u64 {
        if (out == 0 || src == 0 || src.sign == 0) { return 0; }
        var n: u64 = src.digits.len();
        var carry: u64 = 0;
        for (var i: u64 = 0; i < n; i = i + 1) {
            var idx: u64 = i + shift;
            var cur: u64 =
                (u64)out.digits.get(idx) +
                (u64)src.digits.get(i) +
                carry;
            out.digits.set(idx, NumberBig.limb_low(cur));
            carry = NumberBig.limb_carry(cur);
        }
        var k: u64 = n + shift;
        while (carry != 0) {
            var cur2: u64 = (u64)out.digits.get(k) + carry;
            out.digits.set(k, NumberBig.limb_low(cur2));
            carry = NumberBig.limb_carry(cur2);
            k = k + 1;
        }
        return 0;
    }

    public func slice_abs(
        self: *NumberBig,
        start: u64,
        count: u64
    ) -> *NumberBig {
        if (self == 0 || self.sign == 0 || self.digits == 0) {
            return NumberBig.zero();
        }
        var n: u64 = self.digits.len();
        if (start >= n || count == 0) { return NumberBig.zero(); }
        var end: u64 = start + count;
        if (end > n) { end = n; }
        var out: *NumberBig = NumberBig.alloc(1, end - start + 1);
        for (var i: u64 = start; i < end; i = i + 1) {
            out.digits.push(self.digits.get(i));
        }
        out.trim_inplace();
        return out;
    }

    public func to_ntt_chunks_abs(self: *NumberBig) -> *Vec<u64> {
        var n: u64 = 0;
        if (self != 0 && self.sign != 0 && self.digits != 0) {
            n = self.digits.len();
        }
        var buf: u64 = heap_alloc((n * 3 + 1) * sizeof(u64));
        var out: *Vec<u64> = new Vec<u64>{buf, 0, n * 3 + 1};
        var pending: u64 = 0;
        var pending_bits: u64 = 0;
        for (var i: u64 = 0; i < n; i = i + 1) {
            var d: u64 = (u64)self.digits.get(i);
            pending = pending + (d << pending_bits);
            pending_bits = pending_bits + NUMBER_BASE_BITS;
            while (pending_bits >= NUMBER_NTT_CHUNK_BITS) {
                out.push(pending & NUMBER_NTT_CHUNK_MASK);
                pending = pending >> NUMBER_NTT_CHUNK_BITS;
                pending_bits = pending_bits - NUMBER_NTT_CHUNK_BITS;
            }
        }
        if (pending_bits != 0 || pending != 0) {
            out.push(pending & NUMBER_NTT_CHUNK_MASK);
        }
        var len: u64 = out.len();
        while (len > 0) {
            if (out.get(len - 1) != 0) { break; }
            out.pop();
            len = len - 1;
        }
        return out;
    }

    public static func ntt_transform(a: *Vec<u64>, n: u64, invert: u64, mod: u64) -> u64 {
        var j: u64 = 0;
        for (var i: u64 = 1; i < n; i = i + 1) {
            var bit: u64 = n >> 1;
            while ((j & bit) != 0) {
                j = j ^ bit;
                bit = bit >> 1;
            }
            j = j ^ bit;
            if (i < j) {
                var ai: u64 = a.get(i);
                var aj: u64 = a.get(j);
                a.set(i, aj);
                a.set(j, ai);
            }
        }

        var len: u64 = 2;
        while (len <= n) {
            var wlen: u64 = NumberBig.mod_pow(NUMBER_NTT_ROOT, (mod - 1) / len, mod);
            if (invert != 0) {
                wlen = NumberBig.mod_inv(wlen, mod);
            }
            var i0: u64 = 0;
            while (i0 < n) {
                var w: u64 = 1;
                var half: u64 = len / 2;
                for (var k: u64 = 0; k < half; k = k + 1) {
                    var u: u64 = a.get(i0 + k);
                    var v: u64 = (a.get(i0 + k + half) * w) % mod;
                    var x: u64 = u + v;
                    if (x >= mod) { x = x - mod; }
                    var y: u64 = 0;
                    if (u >= v) { y = u - v; }
                    else { y = u + mod - v; }
                    a.set(i0 + k, x);
                    a.set(i0 + k + half, y);
                    w = (w * wlen) % mod;
                }
                i0 = i0 + len;
            }
            len = len << 1;
        }

        if (invert != 0) {
            var n_inv: u64 = NumberBig.mod_inv(n % mod, mod);
            for (var ii: u64 = 0; ii < n; ii = ii + 1) {
                a.set(ii, (a.get(ii) * n_inv) % mod);
            }
        }
        return 0;
    }

    public func mul_schoolbook_abs(
        self: *NumberBig,
        rhs: *NumberBig
    ) -> *NumberBig {
        if (self == 0 || rhs == 0 || self.sign == 0 || rhs.sign == 0) {
            return NumberBig.zero();
        }
        var an: u64 = self.digits.len();
        var bn: u64 = rhs.digits.len();
        var out: *NumberBig = NumberBig.alloc(1, an + bn + 2);

        for (var i0: u64 = 0; i0 < an + bn + 1; i0 = i0 + 1) {
            out.digits.push(0);
        }

        for (var i: u64 = 0; i < an; i = i + 1) {
            var carry: u64 = 0;
            var av: u64 = (u64)self.digits.get(i);
            for (var j: u64 = 0; j < bn; j = j + 1) {
                var idx: u64 = i + j;
                var cur: u64 = (u64)out.digits.get(idx);
                var bv: u64 = (u64)rhs.digits.get(j);
                var prod: u64 = cur + av * bv + carry;
                out.digits.set(idx, NumberBig.limb_low(prod));
                carry = NumberBig.limb_carry(prod);
            }
            var k: u64 = i + bn;
            while (carry != 0) {
                var cur2: u64 = (u64)out.digits.get(k);
                var sum2: u64 = cur2 + carry;
                out.digits.set(k, NumberBig.limb_low(sum2));
                carry = NumberBig.limb_carry(sum2);
                k = k + 1;
            }
        }

        out.trim_inplace();
        return out;
    }

    public func mul_u64_abs(self: *NumberBig, m: u64) -> *NumberBig {
        if (self == 0 || self.sign == 0 || m == 0) {
            return NumberBig.zero();
        }
        var an: u64 = self.digits.len();
        var tmp: u64 = m;
        var mn: u64 = 0;
        while (tmp != 0) {
            mn = mn + 1;
            tmp = tmp >> NUMBER_BASE_BITS;
        }

        var out: *NumberBig = NumberBig.alloc(1, an + mn + 1);
        for (var i: u64 = 0; i < an + mn + 1; i = i + 1) {
            out.digits.push(0);
        }

        var rem: u64 = m;
        var shift: u64 = 0;
        while (rem != 0) {
            var digit: u64 = rem & NUMBER_BASE_MASK;
            self.add_mul_digit_shift_abs(out, digit, shift);
            rem = rem >> NUMBER_BASE_BITS;
            shift = shift + 1;
        }

        out.trim_inplace();
        return out;
    }

    public func mul_karatsuba_abs(
        self: *NumberBig,
        rhs: *NumberBig
    ) -> *NumberBig {
        var an: u64 = self.digits.len();
        var bn: u64 = rhs.digits.len();
        var n: u64 = an;
        if (bn > n) { n = bn; }
        var m: u64 = n / 2;
        if (m == 0) { return self.mul_schoolbook_abs(rhs); }

        var a0: *NumberBig = self.slice_abs(0, m);
        var a1: *NumberBig = self.slice_abs(m, an - m);
        var b0: *NumberBig = rhs.slice_abs(0, m);
        var b1: *NumberBig = rhs.slice_abs(m, bn - m);

        var z0: *NumberBig = a0.mul_abs(b0);
        var z2: *NumberBig = a1.mul_abs(b1);
        var asum: *NumberBig = a0.add_abs(a1);
        var bsum: *NumberBig = b0.add_abs(b1);
        var cross: *NumberBig = asum.mul_abs(bsum);
        cross = cross.sub_abs(z2);
        cross = cross.sub_abs(z0);

        var out: *NumberBig = NumberBig.alloc(1, an + bn + 2);
        for (var i: u64 = 0; i < an + bn + 2; i = i + 1) {
            out.digits.push(0);
        }
        NumberBig.add_shifted_abs_to(out, z0, 0);
        NumberBig.add_shifted_abs_to(out, cross, m);
        NumberBig.add_shifted_abs_to(out, z2, m * 2);
        out.trim_inplace();
        return out;
    }

    public func mul_toom3_abs(
        self: *NumberBig,
        rhs: *NumberBig
    ) -> *NumberBig {
        var an: u64 = self.digits.len();
        var bn: u64 = rhs.digits.len();
        var n: u64 = an;
        if (bn > n) { n = bn; }
        var m: u64 = (n + 2) / 3;
        if (m == 0) { return self.mul_schoolbook_abs(rhs); }

        var a1_count: u64 = 0;
        if (an > m) {
            a1_count = an - m;
            if (a1_count > m) { a1_count = m; }
        }
        var a2_count: u64 = 0;
        if (an > m * 2) { a2_count = an - m * 2; }
        var b1_count: u64 = 0;
        if (bn > m) {
            b1_count = bn - m;
            if (b1_count > m) { b1_count = m; }
        }
        var b2_count: u64 = 0;
        if (bn > m * 2) { b2_count = bn - m * 2; }

        var a0b: *NumberBig = self.slice_abs(0, m);
        var a1b: *NumberBig = self.slice_abs(m, a1_count);
        var a2b: *NumberBig = self.slice_abs(m * 2, a2_count);
        var b0b: *NumberBig = rhs.slice_abs(0, m);
        var b1b: *NumberBig = rhs.slice_abs(m, b1_count);
        var b2b: *NumberBig = rhs.slice_abs(m * 2, b2_count);

        var a0: Number = Number.from_big_normalized(a0b);
        var a1: Number = Number.from_big_normalized(a1b);
        var a2: Number = Number.from_big_normalized(a2b);
        var b0: Number = Number.from_big_normalized(b0b);
        var b1: Number = Number.from_big_normalized(b1b);
        var b2: Number = Number.from_big_normalized(b2b);

        var v0b: *NumberBig = a0b.mul_abs(b0b);
        var v4b: *NumberBig = a2b.mul_abs(b2b);
        var v0: Number = Number.from_big_normalized(v0b);
        var v4: Number = Number.from_big_normalized(v4b);

        var a01: Number = a0.add_values(&a1);
        var eval1a: Number = a01.add_values(&a2);
        var b01: Number = b0.add_values(&b1);
        var eval1b: Number = b01.add_values(&b2);
        var v1: Number = eval1a.mul_values(&eval1b);

        var am1a0: Number = a0.sub_values(&a1);
        var evalm1a: Number = am1a0.add_values(&a2);
        var bm1a0: Number = b0.sub_values(&b1);
        var evalm1b: Number = bm1a0.add_values(&b2);
        var vm1: Number = evalm1a.mul_values(&evalm1b);

        var a1x2: Number = a1.mul_small(2);
        var a2x4: Number = a2.mul_small(4);
        var eval2a0: Number = a0.add_values(&a1x2);
        var eval2a: Number = eval2a0.add_values(&a2x4);
        var b1x2: Number = b1.mul_small(2);
        var b2x4: Number = b2.mul_small(4);
        var eval2b0: Number = b0.add_values(&b1x2);
        var eval2b: Number = eval2b0.add_values(&b2x4);
        var v2: Number = eval2a.mul_values(&eval2b);

        var two: Number = Number { NUMBER_TAG_SMALL };
        two.set_i64(2);
        var three: Number = Number { NUMBER_TAG_SMALL };
        three.set_i64(3);

        var s1_tmp: Number = v1.sub_values(&v0);
        var s1: Number = s1_tmp.sub_values(&v4);
        var sm1_tmp: Number = vm1.sub_values(&v0);
        var sm1: Number = sm1_tmp.sub_values(&v4);
        var v4x16: Number = v4.mul_small(16);
        var s2_tmp: Number = v2.sub_values(&v0);
        var s2: Number = s2_tmp.sub_values(&v4x16);

        var c2_num: Number = s1.add_values(&sm1);
        var r2: Number = c2_num.div_values(&two);
        var s_num: Number = s1.sub_values(&sm1);
        var s: Number = s_num.div_values(&two);
        var r2x4: Number = r2.mul_small(4);
        var t_num: Number = s2.sub_values(&r2x4);
        var t: Number = t_num.div_values(&two);
        var r3_num: Number = t.sub_values(&s);
        var r3: Number = r3_num.div_values(&three);
        var r1: Number = s.sub_values(&r3);

        var outn: Number = v0.clone();
        var shift1: u64 = m * NUMBER_BASE_BITS;
        var part1: Number = r1.shl_values(shift1);
        outn = outn.add_values(&part1);
        var part2: Number = r2.shl_values(shift1 * 2);
        outn = outn.add_values(&part2);
        var part3: Number = r3.shl_values(shift1 * 3);
        outn = outn.add_values(&part3);
        var part4: Number = v4.shl_values(shift1 * 4);
        outn = outn.add_values(&part4);

        var out: *NumberBig = outn.to_abs_big();
        out.trim_inplace();
        return out;
    }

    public func mul_ntt_abs(
        self: *NumberBig,
        rhs: *NumberBig
    ) -> *NumberBig {
        var ach: *Vec<u64> = self.to_ntt_chunks_abs();
        var bch: *Vec<u64> = rhs.to_ntt_chunks_abs();
        var alen: u64 = ach.len();
        var blen: u64 = bch.len();
        if (alen == 0 || blen == 0) { return NumberBig.zero(); }

        var need: u64 = alen + blen - 1;
        var ntt_len: u64 = NumberBig.next_pow2(need);
        if (ntt_len > NUMBER_NTT_MAX_LEN) {
            return self.mul_toom3_abs(rhs);
        }

        var a1: *Vec<u64> = NumberBig.vec_u64_zeroed(ntt_len);
        var b1: *Vec<u64> = NumberBig.vec_u64_zeroed(ntt_len);
        var a2: *Vec<u64> = NumberBig.vec_u64_zeroed(ntt_len);
        var b2: *Vec<u64> = NumberBig.vec_u64_zeroed(ntt_len);

        for (var i: u64 = 0; i < alen; i = i + 1) {
            var v: u64 = ach.get(i);
            a1.set(i, v % NUMBER_NTT_MOD1);
            a2.set(i, v % NUMBER_NTT_MOD2);
        }
        for (var j: u64 = 0; j < blen; j = j + 1) {
            var v2: u64 = bch.get(j);
            b1.set(j, v2 % NUMBER_NTT_MOD1);
            b2.set(j, v2 % NUMBER_NTT_MOD2);
        }

        NumberBig.ntt_transform(a1, ntt_len, 0, NUMBER_NTT_MOD1);
        NumberBig.ntt_transform(b1, ntt_len, 0, NUMBER_NTT_MOD1);
        NumberBig.ntt_transform(a2, ntt_len, 0, NUMBER_NTT_MOD2);
        NumberBig.ntt_transform(b2, ntt_len, 0, NUMBER_NTT_MOD2);

        for (var k: u64 = 0; k < ntt_len; k = k + 1) {
            a1.set(k, (a1.get(k) * b1.get(k)) % NUMBER_NTT_MOD1);
            a2.set(k, (a2.get(k) * b2.get(k)) % NUMBER_NTT_MOD2);
        }

        NumberBig.ntt_transform(a1, ntt_len, 1, NUMBER_NTT_MOD1);
        NumberBig.ntt_transform(a2, ntt_len, 1, NUMBER_NTT_MOD2);

        var out: *NumberBig = NumberBig.alloc(1, (need * NUMBER_NTT_CHUNK_BITS) / NUMBER_BASE_BITS + 4);
        var pending: u64 = 0;
        var pending_bits: u64 = 0;
        var carry: u64 = 0;
        var inv_mod1_mod2: u64 = NumberBig.mod_inv(NUMBER_NTT_MOD1 % NUMBER_NTT_MOD2, NUMBER_NTT_MOD2);

        for (var ci: u64 = 0; ci < need; ci = ci + 1) {
            var r1: u64 = a1.get(ci);
            var r2: u64 = a2.get(ci);
            var diff: u64 = 0;
            if (r2 >= r1) { diff = r2 - r1; }
            else { diff = r2 + NUMBER_NTT_MOD2 - r1; }
            var t: u64 = (diff * inv_mod1_mod2) % NUMBER_NTT_MOD2;
            var coeff: u64 = r1 + NUMBER_NTT_MOD1 * t;
            var cur: u64 = coeff + carry;
            var chunk: u64 = cur & NUMBER_NTT_CHUNK_MASK;
            carry = cur >> NUMBER_NTT_CHUNK_BITS;

            pending = pending + (chunk << pending_bits);
            pending_bits = pending_bits + NUMBER_NTT_CHUNK_BITS;
            while (pending_bits >= NUMBER_BASE_BITS) {
                out.digits.push((u32)(pending & NUMBER_BASE_MASK));
                pending = pending >> NUMBER_BASE_BITS;
                pending_bits = pending_bits - NUMBER_BASE_BITS;
            }
        }

        while (carry != 0) {
            var chunk2: u64 = carry & NUMBER_NTT_CHUNK_MASK;
            carry = carry >> NUMBER_NTT_CHUNK_BITS;
            pending = pending + (chunk2 << pending_bits);
            pending_bits = pending_bits + NUMBER_NTT_CHUNK_BITS;
            while (pending_bits >= NUMBER_BASE_BITS) {
                out.digits.push((u32)(pending & NUMBER_BASE_MASK));
                pending = pending >> NUMBER_BASE_BITS;
                pending_bits = pending_bits - NUMBER_BASE_BITS;
            }
        }
        if (pending_bits != 0 || pending != 0) {
            out.digits.push((u32)(pending & NUMBER_BASE_MASK));
        }
        out.trim_inplace();
        return out;
    }

    public func mul_abs(self: *NumberBig, rhs: *NumberBig) -> *NumberBig {
        if (self == 0 || rhs == 0 || self.sign == 0 || rhs.sign == 0) {
            return NumberBig.zero();
        }
        var an: u64 = self.digits.len();
        var bn: u64 = rhs.digits.len();
        if (an < bn) { return rhs.mul_abs(self); }
        if (bn <= NUMBER_KARATSUBA_THRESHOLD) {
            return self.mul_schoolbook_abs(rhs);
        }
        if (an > bn * NUMBER_KARATSUBA_UNBALANCED_FACTOR) {
            return self.mul_schoolbook_abs(rhs);
        }
        if (bn >= NUMBER_NTT_THRESHOLD) {
            return self.mul_ntt_abs(rhs);
        }
        if (bn >= NUMBER_TOOM3_THRESHOLD && an <= bn * NUMBER_TOOM3_UNBALANCED_FACTOR) {
            return self.mul_toom3_abs(rhs);
        }
        return self.mul_karatsuba_abs(rhs);
    }

    public func mul_small_abs(self: *NumberBig, m: u64) -> *NumberBig {
        if (self == 0 || self.sign == 0 || m == 0) {
            return NumberBig.zero();
        }
        var an: u64 = self.digits.len();
        var out: *NumberBig = NumberBig.alloc(1, an + 2);
        var carry: u64 = 0;
        for (var i: u64 = 0; i < an; i = i + 1) {
            var av: u64 = (u64)self.digits.get(i);
            var cur: u64 = av * m + carry;
            out.digits.push(NumberBig.limb_low(cur));
            carry = NumberBig.limb_carry(cur);
        }
        while (carry != 0) {
            out.digits.push(NumberBig.limb_low(carry));
            carry = NumberBig.limb_carry(carry);
        }
        out.trim_inplace();
        return out;
    }

    public func div_small_abs(self: *NumberBig, m: u64) -> *NumberBig {
        if (m == 0) {
            panic("Number divide by zero");
            return NumberBig.zero();
        }
        if (self == 0 || self.sign == 0) {
            return NumberBig.zero();
        }
        var an: u64 = self.digits.len();
        var q: *NumberBig = NumberBig.alloc(1, an + 1);
        for (var i0: u64 = 0; i0 < an; i0 = i0 + 1) {
            q.digits.push(0);
        }

        var rem: u64 = 0;
        var i: u64 = an;
        while (i > 0) {
            i = i - 1;
            var cur: u64 = (rem << NUMBER_BASE_BITS) + (u64)self.digits.get(i);
            var qd: u64 = cur / m;
            rem = cur % m;
            q.digits.set(i, (u32)qd);
        }
        q.trim_inplace();
        return q;
    }

    public func mod_small_abs(self: *NumberBig, m: u64) -> u64 {
        if (m == 0) {
            panic("Number modulo by zero");
            return 0;
        }
        if (self == 0 || self.sign == 0) { return 0; }
        var an: u64 = self.digits.len();
        var rem: u64 = 0;
        var i: u64 = an;
        while (i > 0) {
            i = i - 1;
            var cur: u64 = (rem << NUMBER_BASE_BITS) + (u64)self.digits.get(i);
            rem = cur % m;
        }
        return rem;
    }

    public func shift_limbs_abs(self: *NumberBig, limb_shift: u64) -> *NumberBig {
        if (self == 0 || self.sign == 0 || self.digits == 0) {
            return NumberBig.zero();
        }
        var n: u64 = self.digits.len();
        var out: *NumberBig = NumberBig.alloc(1, n + limb_shift + 1);
        for (var i: u64 = 0; i < limb_shift; i = i + 1) {
            out.digits.push(0);
        }
        for (var j: u64 = 0; j < n; j = j + 1) {
            out.digits.push(self.digits.get(j));
        }
        out.trim_inplace();
        return out;
    }

    public func shl_bits_abs(self: *NumberBig, bits: u64) -> *NumberBig {
        if (self == 0 || self.sign == 0 || self.digits == 0) {
            return NumberBig.zero();
        }
        if (bits == 0) { return self.abs_copy(); }
        var n: u64 = self.digits.len();
        var limb_shift: u64 = bits / NUMBER_BASE_BITS;
        var bit_shift: u64 = bits % NUMBER_BASE_BITS;
        var out: *NumberBig = NumberBig.alloc(1, n + limb_shift + 2);
        for (var z: u64 = 0; z < limb_shift; z = z + 1) {
            out.digits.push(0);
        }
        var carry: u64 = 0;
        for (var i: u64 = 0; i < n; i = i + 1) {
            var cur: u64 = ((u64)self.digits.get(i) << bit_shift) + carry;
            out.digits.push(NumberBig.limb_low(cur));
            carry = NumberBig.limb_carry(cur);
        }
        if (carry != 0) { out.digits.push((u32)carry); }
        out.trim_inplace();
        return out;
    }

    public func shr_bits_abs(self: *NumberBig, bits: u64) -> *NumberBig {
        if (self == 0 || self.sign == 0 || self.digits == 0) {
            return NumberBig.zero();
        }
        if (bits == 0) { return self.abs_copy(); }
        var n: u64 = self.digits.len();
        var limb_shift: u64 = bits / NUMBER_BASE_BITS;
        if (limb_shift >= n) { return NumberBig.zero(); }
        var bit_shift: u64 = bits % NUMBER_BASE_BITS;
        var out_len: u64 = n - limb_shift;
        var out: *NumberBig = NumberBig.alloc_zeroed(1, out_len);

        if (bit_shift == 0) {
            for (var i0: u64 = 0; i0 < out_len; i0 = i0 + 1) {
                out.digits.set(i0, self.digits.get(i0 + limb_shift));
            }
            out.trim_inplace();
            return out;
        }

        var low_mask: u64 = (1 << bit_shift) - 1;
        var carry: u64 = 0;
        var i: u64 = n;
        while (i > limb_shift) {
            i = i - 1;
            var digit: u64 = (u64)self.digits.get(i);
            var val: u64 = (digit >> bit_shift) | (carry << (NUMBER_BASE_BITS - bit_shift));
            out.digits.set(i - limb_shift, (u32)(val & NUMBER_BASE_MASK));
            carry = digit & low_mask;
        }
        out.trim_inplace();
        return out;
    }

    public func bit_length_abs(self: *NumberBig) -> u64 {
        if (self == 0 || self.sign == 0 || self.digits == 0) { return 0; }
        var n: u64 = self.digits.len();
        if (n == 0) { return 0; }
        var top: u64 = (u64)self.digits.get(n - 1);
        var top_bits: u64 = 0;
        while (top != 0) {
            top = top >> 1;
            top_bits = top_bits + 1;
        }
        return (n - 1) * NUMBER_BASE_BITS + top_bits;
    }

    public func abs_divmod_knuth(self: *NumberBig, rhs: *NumberBig) -> NumberBigDivMod {
        var out: NumberBigDivMod = NumberBigDivMod { 0, 0 };

        if (self == 0 || rhs == 0 || rhs.sign == 0 || self.sign == 0) {
            out.q = NumberBig.zero();
            out.r = NumberBig.zero();
            return out;
        }

        var cmp0: i64 = self.abs_cmp(rhs);
        if (cmp0 < 0) {
            out.q = NumberBig.zero();
            out.r = self.abs_copy();
            return out;
        }
        if (cmp0 == 0) {
            out.q = NumberBig.from_u64_raw(1);
            out.r = NumberBig.zero();
            return out;
        }

        var rhs_len0: u64 = rhs.digits.len();
        if (rhs_len0 == 1) {
            var d0: u64 = (u64)rhs.digits.get(0);
            out.q = self.div_small_abs(d0);
            var r0: u64 = self.mod_small_abs(d0);
            out.r = NumberBig.from_u64_raw(r0);
            return out;
        }

        var top0: u64 = (u64)rhs.digits.get(rhs_len0 - 1);
        var norm: u64 = NUMBER_BASE / (top0 + 1);
        if (norm < 1) { norm = 1; }

        var u: *NumberBig = 0;
        var v: *NumberBig = 0;
        if (norm == 1) {
            u = self.abs_copy();
            v = rhs.abs_copy();
        } else {
            u = self.mul_small_abs(norm);
            v = rhs.mul_small_abs(norm);
        }

        var n: u64 = v.digits.len();
        var u_len: u64 = u.digits.len();
        if (u_len < n) {
            out.q = NumberBig.zero();
            if (norm == 1) { out.r = u; }
            else { out.r = u.div_small_abs(norm); }
            return out;
        }

        var m: u64 = u_len - n;
        u.digits.push(0);

        var q: *NumberBig = NumberBig.alloc_zeroed(1, m + 1);
        var vtop: u64 = (u64)v.digits.get(n - 1);
        var vnext: u64 = 0;
        if (n > 1) { vnext = (u64)v.digits.get(n - 2); }

        var jj: u64 = m + 1;
        while (jj > 0) {
            jj = jj - 1;

            var u_hi: u64 = (u64)u.digits.get(jj + n);
            var u_mid: u64 = (u64)u.digits.get(jj + n - 1);
            var numerator: u64 = (u_hi << NUMBER_BASE_BITS) + u_mid;
            var qhat: u64 = numerator / vtop;
            var rhat: u64 = numerator % vtop;
            if (qhat >= NUMBER_BASE) {
                qhat = NUMBER_BASE - 1;
                rhat = rhat + vtop;
            }

            if (n > 1) {
                var adjusting: u64 = 1;
                while (adjusting != 0) {
                    adjusting = 0;
                    var u_low: u64 = (u64)u.digits.get(jj + n - 2);
                    var lhs: u64 = qhat * vnext;
                    var rhs_cmp: u64 = (rhat << NUMBER_BASE_BITS) + u_low;
                    if (lhs > rhs_cmp) {
                        qhat = qhat - 1;
                        rhat = rhat + vtop;
                        if (rhat < NUMBER_BASE) {
                            adjusting = 1;
                        }
                    }
                }
            }

            var borrow: u64 = 0;
            var carry: u64 = 0;
            for (var i: u64 = 0; i < n; i = i + 1) {
                var prod: u64 = qhat * (u64)v.digits.get(i) + carry;
                carry = NumberBig.limb_carry(prod);
                var sub_digit: u64 = prod & NUMBER_BASE_MASK;
                var ui: u64 = (u64)u.digits.get(jj + i);
                var need: u64 = sub_digit + borrow;
                if (ui < need) {
                    u.digits.set(jj + i, (u32)(ui + NUMBER_BASE - need));
                    borrow = 1;
                } else {
                    u.digits.set(jj + i, (u32)(ui - need));
                    borrow = 0;
                }
            }

            var top: u64 = (u64)u.digits.get(jj + n);
            var need_top: u64 = carry + borrow;
            var negative: u64 = 0;
            if (top < need_top) {
                u.digits.set(jj + n, (u32)(top + NUMBER_BASE - need_top));
                negative = 1;
            } else {
                u.digits.set(jj + n, (u32)(top - need_top));
            }

            if (negative != 0) {
                qhat = qhat - 1;
                var carry_add: u64 = 0;
                for (var ai: u64 = 0; ai < n; ai = ai + 1) {
                    var sum: u64 =
                        (u64)u.digits.get(jj + ai) +
                        (u64)v.digits.get(ai) +
                        carry_add;
                    if (sum >= NUMBER_BASE) {
                        u.digits.set(jj + ai, (u32)(sum - NUMBER_BASE));
                        carry_add = 1;
                    } else {
                        u.digits.set(jj + ai, (u32)sum);
                        carry_add = 0;
                    }
                }
                var top2: u64 = (u64)u.digits.get(jj + n) + carry_add;
                if (top2 >= NUMBER_BASE) { top2 = top2 - NUMBER_BASE; }
                u.digits.set(jj + n, (u32)top2);
            }

            q.digits.set(jj, (u32)qhat);
        }

        q.trim_inplace();
        u.trim_inplace();
        out.q = q;
        if (norm == 1) {
            out.r = u;
        } else {
            out.r = u.div_small_abs(norm);
        }
        out.r.trim_inplace();
        return out;
    }

    public func abs_divmod_divide_conquer(self: *NumberBig, rhs: *NumberBig) -> NumberBigDivMod {
        var out: NumberBigDivMod = NumberBigDivMod { 0, 0 };

        if (self == 0 || rhs == 0 || rhs.sign == 0 || self.sign == 0) {
            out.q = NumberBig.zero();
            out.r = NumberBig.zero();
            return out;
        }

        var cmp0: i64 = self.abs_cmp(rhs);
        if (cmp0 < 0) {
            out.q = NumberBig.zero();
            out.r = self.abs_copy();
            return out;
        }
        if (cmp0 == 0) {
            out.q = NumberBig.from_u64_raw(1);
            out.r = NumberBig.zero();
            return out;
        }

        var an: u64 = self.digits.len();
        var bn: u64 = rhs.digits.len();
        if (bn < NUMBER_DIV_DC_THRESHOLD || an <= bn * 2) {
            return self.abs_divmod_knuth(rhs);
        }

        var split: u64 = an / 2;
        if (split == 0 || split >= an) {
            return self.abs_divmod_knuth(rhs);
        }

        var low: *NumberBig = self.slice_abs(0, split);
        var high: *NumberBig = self.slice_abs(split, an - split);
        var high_dm: NumberBigDivMod = high.abs_divmod_divide_conquer(rhs);

        var shifted_r: *NumberBig = high_dm.r.shift_limbs_abs(split);
        var combined: *NumberBig = shifted_r.add_abs(low);
        var low_dm: NumberBigDivMod = combined.abs_divmod_divide_conquer(rhs);

        var shifted_q: *NumberBig = high_dm.q.shift_limbs_abs(split);
        var q: *NumberBig = shifted_q.add_abs(low_dm.q);
        q.trim_inplace();
        low_dm.r.trim_inplace();
        out.q = q;
        out.r = low_dm.r;
        return out;
    }

    public func abs_divmod_long(self: *NumberBig, rhs: *NumberBig) -> NumberBigDivMod {
        var out: NumberBigDivMod = NumberBigDivMod { 0, 0 };

        if (self == 0 || rhs == 0 || rhs.sign == 0 || self.sign == 0) {
            out.q = NumberBig.zero();
            out.r = NumberBig.zero();
            return out;
        }

        var cmp0: i64 = self.abs_cmp(rhs);
        if (cmp0 < 0) {
            out.q = NumberBig.zero();
            out.r = self.abs_copy();
            return out;
        }
        if (cmp0 == 0) {
            out.q = NumberBig.from_u64_raw(1);
            out.r = NumberBig.zero();
            return out;
        }

        var an: u64 = self.digits.len();
        var bn: u64 = rhs.digits.len();
        var q_len: u64 = an - bn + 1;

        var q: *NumberBig = NumberBig.alloc(1, q_len + 1);
        for (var qi: u64 = 0; qi < q_len; qi = qi + 1) {
            q.digits.push(0);
        }

        var r: *NumberBig = self.abs_copy();

        var shift: u64 = q_len;
        while (shift > 0) {
            shift = shift - 1;
            var shifted_b: *NumberBig = rhs.shift_limbs_abs(shift);
            if (r.abs_cmp(shifted_b) < 0) { continue; }

            var lo: u64 = 1;
            var hi: u64 = NUMBER_BASE - 1;
            var best: u64 = 0;
            while (lo <= hi) {
                var mid: u64 = lo + ((hi - lo) / 2);
                var prod_mid: *NumberBig = shifted_b.mul_small_abs(mid);
                var cmp_mid: i64 = prod_mid.abs_cmp(r);
                if (cmp_mid <= 0) {
                    best = mid;
                    lo = mid + 1;
                } else {
                    hi = mid - 1;
                }
            }

            if (best != 0) {
                var best_prod: *NumberBig = shifted_b.mul_small_abs(best);
                r = r.sub_abs(best_prod);
                q.digits.set(shift, (u32)best);
            }
        }

        q.trim_inplace();
        r.trim_inplace();
        out.q = q;
        out.r = r;
        return out;
    }
}

impl Number {
    public static func i64_abs_mag(v: i64, out: *u64) -> u64 {
        if (out == 0) { return 0; }
        if (v >= 0) {
            out[0] = (u64)v;
            return 1;
        }
        if (v == i64.MIN) {
            out[0] = NUMBER_MIN_I64_MAG;
            return 1;
        }
        out[0] = (u64)(0 - v);
        return 1;
    }

    public static func fits_small_i64(v: i64) -> u64 {
        if (v < NUMBER_SMALL_MIN_I64) { return 0; }
        if (v > NUMBER_SMALL_MAX_I64) { return 0; }
        return 1;
    }

    public static func zero() -> Number {
        return Number { NUMBER_TAG_SMALL };
    }

    public func is_small(self: *Number) -> u64 {
        if (self == 0) {
            panic("Number.is_small: null Number*");
            return 0;
        }
        return (self.bits & NUMBER_TAG_MASK) != 0;
    }

    public func is_real(self: *Number) -> u64 {
        if (self == 0) { return 0; }
        if (self.is_small() != 0) { return 0; }
        return (self.bits & NUMBER_HEAP_TAG_MASK) == NUMBER_TAG_REAL;
    }

    public func is_complex(self: *Number) -> u64 {
        if (self == 0) { return 0; }
        if (self.is_small() != 0) { return 0; }
        return (self.bits & NUMBER_HEAP_TAG_MASK) == NUMBER_TAG_COMPLEX;
    }

    public func small_value(self: *Number) -> i64 {
        if (self == 0) {
            panic("Number.small_value: null Number*");
            return 0;
        }
        return ((i64)self.bits) >> 1;
    }

    public func big_ptr(self: *Number) -> *NumberBig {
        if (self == 0) { return 0; }
        if (self.is_small() != 0) { return 0; }
        if ((self.bits & NUMBER_HEAP_TAG_MASK) != NUMBER_TAG_BIG) { return 0; }
        return (*NumberBig)(self.bits & NUMBER_PTR_MASK);
    }

    public func real_ptr(self: *Number) -> *NumberReal {
        if (self == 0) { return 0; }
        if (self.is_real() == 0) { return 0; }
        return (*NumberReal)(self.bits & NUMBER_PTR_MASK);
    }

    public func complex_ptr(self: *Number) -> *NumberComplex {
        if (self == 0) { return 0; }
        if (self.is_complex() == 0) { return 0; }
        return (*NumberComplex)(self.bits & NUMBER_PTR_MASK);
    }

    public static func from_i64(v: i64) -> Number {
        if (Number.fits_small_i64(v) != 0) {
            return Number { (((u64)v) << 1) | NUMBER_TAG_SMALL };
        }
        var big: *NumberBig = NumberBig.from_i64_raw(v);
        return Number { ((u64)big) & NUMBER_PTR_MASK };
    }

    public static func from_i8(v: i8) -> Number {
        return Number { (((u64)((i64)v)) << 1) | NUMBER_TAG_SMALL };
    }

    public static func from_i16(v: i16) -> Number {
        return Number { (((u64)((i64)v)) << 1) | NUMBER_TAG_SMALL };
    }

    public static func from_i32(v: i32) -> Number {
        return Number { (((u64)((i64)v)) << 1) | NUMBER_TAG_SMALL };
    }

    public static func from_u64(v: u64) -> Number {
        if (v <= NUMBER_SMALL_MAX_U64) {
            return Number { (((u64)((i64)v)) << 1) | NUMBER_TAG_SMALL };
        }
        var big: *NumberBig = NumberBig.from_u64_raw(v);
        return Number { ((u64)big) & NUMBER_PTR_MASK };
    }

    public static func from_u8(v: u8) -> Number {
        return Number { (((u64)v) << 1) | NUMBER_TAG_SMALL };
    }

    public static func from_u16(v: u16) -> Number {
        return Number { (((u64)v) << 1) | NUMBER_TAG_SMALL };
    }

    public static func from_u32(v: u32) -> Number {
        return Number { (((u64)v) << 1) | NUMBER_TAG_SMALL };
    }

    public static func from_f64(v: f64) -> Number {
        return number_make_real(v);
    }

    public static func from_complex(real: Number, imag: Number) -> Number {
        return number_make_complex(real, imag);
    }

    public static func from_complex_f64(real: f64, imag: f64) -> Number {
        var r: Number = number_make_real(real);
        var i: Number = number_make_real(imag);
        return number_make_complex(r, i);
    }

    public static func from_str(src: []u8) -> Number {
        var out: Number = Number { NUMBER_TAG_SMALL };
        out.set_from_str(slice(src.ptr, src.len));
        return out;
    }

    public static func input(max_len: u64 = IO_INPUT_DEFAULT_MAX_LEN, out_len: *u64 = 0) -> Number {
        var line_len: u64 = 0;
        var line: u64 = (u64)input(max_len, &line_len);
        if (out_len != 0) { out_len[0] = line_len; }
        var out: Number = Number { NUMBER_TAG_SMALL };
        out.set_from_str(slice(line, line_len));
        return out;
    }

    public static func from_big_normalized(big: *NumberBig) -> Number {
        if (big == 0) { return Number { NUMBER_TAG_SMALL }; }
        big.trim_inplace();
        if (big.sign == 0) { return Number { NUMBER_TAG_SMALL }; }

        var iv: i64 = 0;
        if (big.try_to_i64(&iv) != 0) {
            if (Number.fits_small_i64(iv) != 0) {
                return Number { (((u64)iv) << 1) | NUMBER_TAG_SMALL };
            }
        }
        return Number { ((u64)big) & NUMBER_PTR_MASK };
    }

    public func to_abs_big(self: *Number) -> *NumberBig {
        if (self == 0) {
            return NumberBig.zero();
        }
        if (self.is_small() != 0) {
            var sv: i64 = self.small_value();
            if (sv == 0) {
                return NumberBig.zero();
            }
            var mag: u64 = 0;
            Number.i64_abs_mag(sv, &mag);
            return NumberBig.from_u64_raw(mag);
        }
        if (self.is_real() != 0) {
            var rv: f64 = self.real_ptr().value;
            if (rv < 0.0) { rv = 0.0 - rv; }
            return NumberBig.from_u64_raw((u64)rv);
        }
        if (self.is_complex() != 0) {
            return NumberBig.zero();
        }
        return self.big_ptr().abs_copy();
    }

    public func set_i64(self: *Number, v: i64) -> u64 {
        if (self == 0) { return 0; }
        if (Number.fits_small_i64(v) != 0) {
            self.bits = (((u64)v) << 1) | NUMBER_TAG_SMALL;
            return 0;
        }
        self.bits = ((u64)NumberBig.from_i64_raw(v)) & NUMBER_PTR_MASK;
        return 0;
    }

    public func set_u64(self: *Number, v: u64) -> u64 {
        if (self == 0) { return 0; }
        if (v <= NUMBER_SMALL_MAX_U64) {
            self.bits = (((u64)((i64)v)) << 1) | NUMBER_TAG_SMALL;
            return 0;
        }
        self.bits = ((u64)NumberBig.from_u64_raw(v)) & NUMBER_PTR_MASK;
        return 0;
    }

    public func set_from_str(self: *Number, src: []u8) -> u64 {
        if (self == 0) { return 0; }
        self.bits = NUMBER_TAG_SMALL;
        if (src.ptr == 0 || src.len == 0) { return 0; }

        var s: *u8 = (*u8)src.ptr;
        var idx: u64 = 0;
        var sign: i64 = 1;
        if (s[0] == 45) {
            sign = -1;
            idx = 1;
        } else if (s[0] == 43) {
            idx = 1;
        }
        if (idx >= src.len) { return 0; }

        var out: Number = Number { NUMBER_TAG_SMALL };
        for (; idx < src.len; idx = idx + 1) {
            var c: u8 = s[idx];
            if (c < 48 || c > 57) {
                self.bits = NUMBER_TAG_SMALL;
                return 0;
            }
            out = out.mul_small(10);
            var d: Number = Number { NUMBER_TAG_SMALL };
            d.set_u64((u64)(c - 48));
            out = out.add_values(&d);
        }

        if (sign < 0 && out.signum() != 0) {
            out = out.abs_with_sign(-1);
        }
        self.bits = out.bits;
        return 0;
    }

    public func clone(self: *Number) -> Number {
        if (self == 0) {
            panic("number_clone: null Number*");
            return Number { NUMBER_TAG_SMALL };
        }
        return Number { self.bits };
    }

    public func signum(self: *Number) -> i64 {
        if (self == 0) {
            panic("number_signum: null Number*");
            return 0;
        }
        if (self.is_small() != 0) {
            var sv: i64 = self.small_value();
            if (sv > 0) { return 1; }
            if (sv < 0) { return -1; }
            return 0;
        }
        if (self.is_real() != 0) {
            var rv: f64 = self.real_ptr().value;
            if (rv > 0.0) { return 1; }
            if (rv < 0.0) { return -1; }
            return 0;
        }
        if (self.is_complex() != 0) {
            var c: *NumberComplex = self.complex_ptr();
            if (c == 0) { return 0; }
            if (c.real.signum() != 0 || c.imag.signum() != 0) { return 1; }
            return 0;
        }
        var b: *NumberBig = self.big_ptr();
        if (b == 0) { return 0; }
        if (b.sign > 0) { return 1; }
        if (b.sign < 0) { return -1; }
        return 0;
    }

    public func negated(self: *Number) -> Number {
        if (self == 0) {
            panic("number_negated: null Number*");
            return Number { NUMBER_TAG_SMALL };
        }
        if (self.is_small() != 0) {
            var out_small: Number = Number { NUMBER_TAG_SMALL };
            out_small.set_i64(0 - self.small_value());
            return out_small;
        }
        if (self.is_real() != 0) {
            return number_make_real(0.0 - self.real_ptr().value);
        }
        if (self.is_complex() != 0) {
            var c: *NumberComplex = self.complex_ptr();
            if (c == 0) { return Number { NUMBER_TAG_SMALL }; }
            var nr: Number = c.real.negated();
            var ni: Number = c.imag.negated();
            return number_make_complex(nr, ni);
        }
        var src: *NumberBig = self.big_ptr();
        if (src == 0 || src.sign == 0) { return Number { NUMBER_TAG_SMALL }; }
        var copy: *NumberBig = src.copy();
        copy.sign = 0 - copy.sign;
        var out: Number = Number.from_big_normalized(copy);
        return out;
    }

    public func abs_with_sign(self: *Number, sign: i64) -> Number {
        if (self == 0) {
            panic("number_abs_with_sign: null Number*");
            return Number { NUMBER_TAG_SMALL };
        }
        if (sign == 0 || self.signum() == 0) {
            return Number { NUMBER_TAG_SMALL };
        }
        if (self.is_small() != 0) {
            var sv: i64 = self.small_value();
            var mag: u64 = 0;
            Number.i64_abs_mag(sv, &mag);
            if (sign < 0) {
                if (mag <= NUMBER_MAX_I64_U64) {
                    var out_small_neg: Number = Number { NUMBER_TAG_SMALL };
                    out_small_neg.set_i64(0 - (i64)mag);
                    return out_small_neg;
                }
                var bneg: *NumberBig = NumberBig.from_u64_raw(mag);
                bneg.sign = -1;
                var out_neg: Number = Number.from_big_normalized(bneg);
                return out_neg;
            }
            var out_small_abs: Number = Number { NUMBER_TAG_SMALL };
            out_small_abs.set_u64(mag);
            return out_small_abs;
        }
        var srcb: *NumberBig = self.big_ptr();
        if (srcb == 0) { return Number { NUMBER_TAG_SMALL }; }
        var copyb: *NumberBig = srcb.abs_copy();
        if (sign < 0) { copyb.sign = -1; }
        else { copyb.sign = 1; }
        var out: Number = Number.from_big_normalized(copyb);
        return out;
    }

    public func abs_cmp(self: *Number, rhs: *Number) -> i64 {
        if (self == 0) {
            panic("number_abs_cmp: null lhs");
            return 0;
        }
        if (rhs == 0) {
            panic("number_abs_cmp: null rhs");
            return 0;
        }
        if (self.is_real() != 0 || rhs.is_real() != 0 || self.is_complex() != 0 || rhs.is_complex() != 0) {
            var avf: f64 = self.to_f64_lossy();
            var bvf: f64 = rhs.to_f64_lossy();
            if (avf < 0.0) { avf = 0.0 - avf; }
            if (bvf < 0.0) { bvf = 0.0 - bvf; }
            if (avf < bvf) { return -1; }
            if (avf > bvf) { return 1; }
            return 0;
        }
        var a_small: u64 = self.is_small();
        var b_small: u64 = rhs.is_small();
        if (a_small != 0 && b_small != 0) {
            var amag: u64 = 0;
            var bmag: u64 = 0;
            Number.i64_abs_mag(self.small_value(), &amag);
            Number.i64_abs_mag(rhs.small_value(), &bmag);
            if (amag < bmag) { return -1; }
            if (amag > bmag) { return 1; }
            return 0;
        }
        if (a_small != 0) {
            var bptr0: *NumberBig = rhs.big_ptr();
            if (bptr0 == 0 || bptr0.sign == 0) {
                var amag0: u64 = 0;
                Number.i64_abs_mag(self.small_value(), &amag0);
                if (amag0 == 0) { return 0; }
            }
            return -1;
        }
        if (b_small != 0) {
            var aptr0: *NumberBig = self.big_ptr();
            if (aptr0 == 0 || aptr0.sign == 0) {
                var bmag0: u64 = 0;
                Number.i64_abs_mag(rhs.small_value(), &bmag0);
                if (bmag0 == 0) { return 0; }
            }
            return 1;
        }
        return self.big_ptr().abs_cmp(rhs.big_ptr());
    }

    public func real_part(self: *Number) -> Number {
        if (self == 0) { return Number { NUMBER_TAG_SMALL }; }
        if (self.is_complex() != 0) {
            var c: *NumberComplex = self.complex_ptr();
            if (c == 0) { return Number { NUMBER_TAG_SMALL }; }
            return Number { c.real.bits };
        }
        return Number { self.bits };
    }

    public func imag_part(self: *Number) -> Number {
        if (self == 0) { return Number { NUMBER_TAG_SMALL }; }
        if (self.is_complex() != 0) {
            var c: *NumberComplex = self.complex_ptr();
            if (c == 0) { return Number { NUMBER_TAG_SMALL }; }
            return Number { c.imag.bits };
        }
        return Number { NUMBER_TAG_SMALL };
    }

    public func cmp_ptr(self: *Number, rhs: *Number) -> i64 {
        if (self == 0) {
            panic("number_cmp_ptr: null lhs");
            return 0;
        }
        if (rhs == 0) {
            panic("number_cmp_ptr: null rhs");
            return 0;
        }

        if (self.is_complex() != 0 || rhs.is_complex() != 0) {
            var ar: Number = self.real_part();
            var ai: Number = self.imag_part();
            var br: Number = rhs.real_part();
            var bi: Number = rhs.imag_part();
            var rc: i64 = ar.cmp_ptr(&br);
            if (rc != 0) { return rc; }
            return ai.cmp_ptr(&bi);
        }

        if (self.is_real() != 0 || rhs.is_real() != 0) {
            var avf: f64 = self.to_f64_lossy();
            var bvf: f64 = rhs.to_f64_lossy();
            if (avf < bvf) { return -1; }
            if (avf > bvf) { return 1; }
            return 0;
        }

        var a_small: u64 = self.is_small();
        var b_small: u64 = rhs.is_small();
        if (a_small != 0 && b_small != 0) {
            var av: i64 = self.small_value();
            var bv: i64 = rhs.small_value();
            if (av < bv) { return -1; }
            if (av > bv) { return 1; }
            return 0;
        }

        var a_sign: i64 = self.signum();
        var bs: i64 = rhs.signum();
        if (a_sign != bs) {
            if (a_sign < bs) { return -1; }
            return 1;
        }
        if (a_sign == 0) { return 0; }

        var cmp: i64 = 0;
        if (a_small == 0 && b_small == 0) {
            cmp = self.big_ptr().abs_cmp(rhs.big_ptr());
        } else if (a_small == 0) {
            cmp = 1;
        } else {
            cmp = -1;
        }
        if (a_sign > 0) { return cmp; }
        return 0 - cmp;
    }

    public func add_values(self: *Number, rhs: *Number) -> Number {
        if (self.is_complex() != 0 || rhs.is_complex() != 0) {
            var ar: Number = self.real_part();
            var ai: Number = self.imag_part();
            var br: Number = rhs.real_part();
            var bi: Number = rhs.imag_part();
            var rr: Number = ar.add_values(&br);
            var ii: Number = ai.add_values(&bi);
            return number_make_complex(rr, ii);
        }
        if (self.is_real() != 0 || rhs.is_real() != 0) {
            return number_make_real(self.to_f64_lossy() + rhs.to_f64_lossy());
        }

        var a_sign: i64 = self.signum();
        var bs: i64 = rhs.signum();
        if (a_sign == 0) { return Number { rhs.bits }; }
        if (bs == 0) { return Number { self.bits }; }

        if (self.is_small() != 0 && rhs.is_small() != 0) {
            var av: i64 = self.small_value();
            var bv: i64 = rhs.small_value();
            var sv: i64 = av + bv;
            if (
                a_sign != bs ||
                (a_sign > 0 && sv <= NUMBER_SMALL_MAX_I64) ||
                (a_sign < 0 && sv >= NUMBER_SMALL_MIN_I64)
            ) {
                var out_small_sum: Number = Number.from_i64(sv);
                return out_small_sum;
            }
        }

        var aa: *NumberBig = self.to_abs_big();
        var bb: *NumberBig = rhs.to_abs_big();

        if (a_sign == bs) {
            var sum: *NumberBig = aa.add_abs(bb);
            sum.sign = a_sign;
            var out_sum: Number = Number.from_big_normalized(sum);
            return out_sum;
        }

        var cmp: i64 = aa.abs_cmp(bb);
        if (cmp == 0) { return Number { NUMBER_TAG_SMALL }; }
        if (cmp > 0) {
            var diff1: *NumberBig = aa.sub_abs(bb);
            diff1.sign = a_sign;
            var out_diff1: Number = Number.from_big_normalized(diff1);
            return out_diff1;
        }
        var diff2: *NumberBig = bb.sub_abs(aa);
        diff2.sign = bs;
        var out_diff2: Number = Number.from_big_normalized(diff2);
        return out_diff2;
    }

    public func sub_values(self: *Number, rhs: *Number) -> Number {
        var neg: Number = rhs.negated();
        var out: Number = self.add_values(&neg);
        return out;
    }

    public func mul_values(self: *Number, rhs: *Number) -> Number {
        if (self.is_complex() != 0 || rhs.is_complex() != 0) {
            var ar: Number = self.real_part();
            var ai: Number = self.imag_part();
            var br: Number = rhs.real_part();
            var bi: Number = rhs.imag_part();
            var ac: Number = ar.mul_values(&br);
            var bd: Number = ai.mul_values(&bi);
            var ad: Number = ar.mul_values(&bi);
            var bc: Number = ai.mul_values(&br);
            var rr: Number = ac.sub_values(&bd);
            var ii: Number = ad.add_values(&bc);
            return number_make_complex(rr, ii);
        }
        if (self.is_real() != 0 || rhs.is_real() != 0) {
            return number_make_real(self.to_f64_lossy() * rhs.to_f64_lossy());
        }

        var a_sign: i64 = self.signum();
        var bs: i64 = rhs.signum();
        if (a_sign == 0 || bs == 0) { return Number { NUMBER_TAG_SMALL }; }

        if (self.is_small() != 0 && rhs.is_small() != 0) {
            var amag: u64 = 0;
            var bmag: u64 = 0;
            Number.i64_abs_mag(self.small_value(), &amag);
            Number.i64_abs_mag(rhs.small_value(), &bmag);
            if (amag != 0 && bmag <= NUMBER_SMALL_MAX_U64 / amag) {
                var prod: u64 = amag * bmag;
                if (a_sign == bs) {
                    var out_prod_pos: Number = Number.from_u64(prod);
                    return out_prod_pos;
                }
                var out_prod_neg: Number = Number.from_i64(0 - (i64)prod);
                return out_prod_neg;
            }
        }

        if (self.is_small() != 0 && rhs.is_small() == 0) {
            var amag2: u64 = 0;
            Number.i64_abs_mag(self.small_value(), &amag2);
            var rb: *NumberBig = rhs.big_ptr();
            var out_rhs: *NumberBig = rb.mul_u64_abs(amag2);
            out_rhs.sign = a_sign * bs;
            var out_small_lhs: Number = Number.from_big_normalized(out_rhs);
            return out_small_lhs;
        }
        if (rhs.is_small() != 0 && self.is_small() == 0) {
            var bmag2: u64 = 0;
            Number.i64_abs_mag(rhs.small_value(), &bmag2);
            var lb: *NumberBig = self.big_ptr();
            var out_lhs: *NumberBig = lb.mul_u64_abs(bmag2);
            out_lhs.sign = a_sign * bs;
            var out_small_rhs: Number = Number.from_big_normalized(out_lhs);
            return out_small_rhs;
        }

        var aa: *NumberBig = self.to_abs_big();
        var bb: *NumberBig = rhs.to_abs_big();
        var out_big: *NumberBig = aa.mul_abs(bb);
        out_big.sign = a_sign * bs;
        var out: Number = Number.from_big_normalized(out_big);
        return out;
    }

    public func divmod_values_nonzero(
        self: *Number,
        rhs: *Number
    ) -> NumberDivMod {
        var out: NumberDivMod = NumberDivMod {
            Number { NUMBER_TAG_SMALL },
            Number { NUMBER_TAG_SMALL }
        };
        if (self == 0 || rhs == 0) { return out; }

        var a_sign: i64 = self.signum();
        if (a_sign == 0) { return out; }
        var bs: i64 = rhs.signum();
        if (bs == 0) { return out; }

        if (self.is_small() != 0 && rhs.is_small() != 0) {
            var av: i64 = self.small_value();
            var bv: i64 = rhs.small_value();
            out.q.set_i64(av / bv);
            out.r.set_i64(av % bv);
            return out;
        }

        var aa: *NumberBig = self.to_abs_big();
        var bb: *NumberBig = rhs.to_abs_big();

        var q_abs: *NumberBig = NumberBig.zero();
        var r_abs: Number = Number { NUMBER_TAG_SMALL };
        var bb_u64: u64 = 0;
        if (bb.abs_to_u64_checked(&bb_u64) != 0 && bb_u64 < NUMBER_BASE) {
            q_abs = aa.div_small_abs(bb_u64);
            var rem: u64 = aa.mod_small_abs(bb_u64);
            if (rem != 0) {
                r_abs.set_u64(rem);
            }
        } else {
            var dm: NumberBigDivMod = aa.abs_divmod_divide_conquer(bb);
            q_abs = dm.q;
            r_abs = Number.from_big_normalized(dm.r);
        }

        if (q_abs.sign != 0) { q_abs.sign = a_sign * bs; }
        out.q = Number.from_big_normalized(q_abs);
        out.r = r_abs;
        if (a_sign < 0 && out.r.signum() != 0) {
            out.r = out.r.abs_with_sign(-1);
        }
        return out;
    }

    public func div_values(self: *Number, rhs: *Number) -> Number {
        if (self == 0) {
            panic("number_div_values: null lhs");
            return Number { NUMBER_TAG_SMALL };
        }
        if (rhs == 0) {
            panic("number_div_values: null rhs");
            return Number { NUMBER_TAG_SMALL };
        }
        if (self.is_complex() != 0 || rhs.is_complex() != 0) {
            var ar_num: Number = self.real_part();
            var ai_num: Number = self.imag_part();
            var br_num: Number = rhs.real_part();
            var bi_num: Number = rhs.imag_part();
            var ar: f64 = ar_num.to_f64_lossy();
            var ai: f64 = ai_num.to_f64_lossy();
            var br: f64 = br_num.to_f64_lossy();
            var bi: f64 = bi_num.to_f64_lossy();
            var denom: f64 = (br * br) + (bi * bi);
            if (denom == 0.0) {
                panic("Number complex divide by zero");
                return Number { NUMBER_TAG_SMALL };
            }
            var rr: Number = number_make_real(((ar * br) + (ai * bi)) / denom);
            var ii: Number = number_make_real(((ai * br) - (ar * bi)) / denom);
            return number_make_complex(rr, ii);
        }
        if (self.is_real() != 0 || rhs.is_real() != 0) {
            var rv: f64 = rhs.to_f64_lossy();
            if (rv == 0.0) {
                panic("Number divide by zero");
                return Number { NUMBER_TAG_SMALL };
            }
            return number_make_real(self.to_f64_lossy() / rv);
        }
        if (rhs.signum() == 0) {
            panic("Number divide by zero");
            return Number { NUMBER_TAG_SMALL };
        }
        var dm: NumberDivMod = self.divmod_values_nonzero(rhs);
        return dm.q;
    }

    public func mod_values(self: *Number, rhs: *Number) -> Number {
        if (self == 0) {
            panic("number_mod_values: null lhs");
            return Number { NUMBER_TAG_SMALL };
        }
        if (rhs == 0) {
            panic("number_mod_values: null rhs");
            return Number { NUMBER_TAG_SMALL };
        }
        if (self.is_real() != 0 || rhs.is_real() != 0 || self.is_complex() != 0 || rhs.is_complex() != 0) {
            panic("Number modulo requires integer operands");
            return Number { NUMBER_TAG_SMALL };
        }
        if (rhs.signum() == 0) {
            panic("Number modulo by zero");
            return Number { NUMBER_TAG_SMALL };
        }
        var dm: NumberDivMod = self.divmod_values_nonzero(rhs);
        return dm.r;
    }

    public func mul_small(self: *Number, m: u64) -> Number {
        if (self == 0 || m == 0) { return Number { NUMBER_TAG_SMALL }; }
        var a_sign: i64 = self.signum();
        if (a_sign == 0) { return Number { NUMBER_TAG_SMALL }; }
        if (self.is_small() != 0) {
            var mag: u64 = 0;
            Number.i64_abs_mag(self.small_value(), &mag);
            if (mag <= NUMBER_SMALL_MAX_U64 / m) {
                var prod: u64 = mag * m;
                if (a_sign > 0) {
                    var out_mul_small_pos: Number = Number.from_u64(prod);
                    return out_mul_small_pos;
                }
                var out_mul_small_neg: Number = Number.from_i64(0 - (i64)prod);
                return out_mul_small_neg;
            }
        }
        var aa: *NumberBig = self.to_abs_big();
        var out_big: *NumberBig = aa.mul_u64_abs(m);
        out_big.sign = a_sign;
        var out: Number = Number.from_big_normalized(out_big);
        return out;
    }

    public func abs_clone(self: *Number) -> Number {
        if (self == 0) {
            panic("number_abs_clone: null Number*");
            return Number { NUMBER_TAG_SMALL };
        }
        if (self.is_small() != 0) {
            var sv: i64 = self.small_value();
            if (sv >= 0) {
                return Number { (((u64)sv) << 1) | NUMBER_TAG_SMALL };
            }
            var mag: u64 = 0;
            Number.i64_abs_mag(sv, &mag);
            var out_small: Number = Number { NUMBER_TAG_SMALL };
            out_small.set_u64(mag);
            return out_small;
        }
        if (self.is_real() != 0) {
            var rv: f64 = self.real_ptr().value;
            if (rv < 0.0) { rv = 0.0 - rv; }
            return number_make_real(rv);
        }
        if (self.is_complex() != 0) {
            var rp: Number = self.real_part();
            return rp.abs_clone();
        }
        var out_big: *NumberBig = self.big_ptr().abs_copy();
        var out: Number = Number.from_big_normalized(out_big);
        return out;
    }

    public func div_small_abs(self: *Number, m: u64) -> Number {
        if (self == 0) {
            panic("number_div_small_abs: null Number*");
            return Number { NUMBER_TAG_SMALL };
        }
        if (m == 0) {
            panic("Number divide by zero");
            return Number { NUMBER_TAG_SMALL };
        }
        if (self.signum() == 0) { return Number { NUMBER_TAG_SMALL }; }
        if (m >= NUMBER_BASE) {
            var absn: Number = self.abs_clone();
            var divisor: Number = Number.from_u64(m);
            var out_large_small_div: Number = absn.div_values(&divisor);
            return out_large_small_div;
        }

        if (self.is_small() != 0) {
            var mag: u64 = 0;
            Number.i64_abs_mag(self.small_value(), &mag);
            var out_small: Number = Number { NUMBER_TAG_SMALL };
            out_small.set_u64(mag / m);
            return out_small;
        }

        var aa: *NumberBig = self.to_abs_big();
        var q: *NumberBig = aa.div_small_abs(m);
        var out: Number = Number.from_big_normalized(q);
        return out;
    }

    public func mod_small_abs(self: *Number, m: u64) -> u64 {
        if (self == 0) {
            panic("number_mod_small_abs: null Number*");
            return 0;
        }
        if (m == 0) {
            panic("Number modulo by zero");
            return 0;
        }
        if (self.signum() == 0) { return 0; }
        if (m >= NUMBER_BASE) {
            var absn: Number = self.abs_clone();
            var divisor: Number = Number.from_u64(m);
            var remn: Number = absn.mod_values(&divisor);
            var rem_out: u64 = 0;
            remn.to_u64_checked(&rem_out);
            return rem_out;
        }

        if (self.is_small() != 0) {
            var mag: u64 = 0;
            Number.i64_abs_mag(self.small_value(), &mag);
            return mag % m;
        }

        var aa: *NumberBig = self.to_abs_big();
        return aa.mod_small_abs(m);
    }

    public func scale_pow2_abs(self: *Number, bits: u64, divide: u64) -> Number {
        if (self == 0 || self.signum() == 0) { return Number { NUMBER_TAG_SMALL }; }
        var aa: *NumberBig = self.to_abs_big();
        var out_big: *NumberBig = 0;
        if (divide != 0) {
            out_big = aa.shr_bits_abs(bits);
        } else {
            out_big = aa.shl_bits_abs(bits);
        }
        var out: Number = Number.from_big_normalized(out_big);
        return out;
    }

    public static func pow2(bits: u64) -> Number {
        var out_big: *NumberBig = NumberBig.pow2_abs(bits);
        var out: Number = Number.from_big_normalized(out_big);
        return out;
    }

    public func bit_length_abs(self: *Number) -> u64 {
        if (self == 0) { return 0; }
        if (self.is_small() != 0) {
            var mag: u64 = 0;
            Number.i64_abs_mag(self.small_value(), &mag);
            var small_bits: u64 = 0;
            while (mag != 0) {
                mag = mag >> 1;
                small_bits = small_bits + 1;
            }
            return small_bits;
        }
        var b: *NumberBig = self.big_ptr();
        if (b == 0) { return 0; }
        return b.bit_length_abs();
    }

    public func shl_values(self: *Number, sh: u64) -> Number {
        if (self == 0 || self.signum() == 0) { return Number { NUMBER_TAG_SMALL }; }
        if (sh == 0) {
            var cloned: Number = self.clone();
            return cloned;
        }

        var out: Number = self.scale_pow2_abs(sh, 0);

        var a_sign: i64 = self.signum();
        if (a_sign < 0 && out.signum() != 0) {
            out = out.abs_with_sign(-1);
        }
        return out;
    }

    public func bitwise_nonneg_abs(
        self: *Number,
        rhs: *Number,
        mode: u64
    ) -> Number {
        var aa: *NumberBig = self.to_abs_big();
        var bb: *NumberBig = rhs.to_abs_big();
        var an: u64 = 0;
        var bn: u64 = 0;
        if (aa != 0 && aa.digits != 0) { an = aa.digits.len(); }
        if (bb != 0 && bb.digits != 0) { bn = bb.digits.len(); }
        var n: u64 = an;
        if (bn > n) { n = bn; }
        var out_big: *NumberBig = NumberBig.alloc(1, n + 1);

        if (mode == NUMBER_BITWISE_AND) {
            for (var i_and: u64 = 0; i_and < n; i_and = i_and + 1) {
                var av_and: u64 = NumberBig.digit_or_zero(aa, an, i_and);
                var bv_and: u64 = NumberBig.digit_or_zero(bb, bn, i_and);
                out_big.digits.push((u32)NumberBig.limb_and_value(av_and, bv_and));
            }
        } else if (mode == NUMBER_BITWISE_OR) {
            for (var i_or: u64 = 0; i_or < n; i_or = i_or + 1) {
                var av_or: u64 = NumberBig.digit_or_zero(aa, an, i_or);
                var bv_or: u64 = NumberBig.digit_or_zero(bb, bn, i_or);
                out_big.digits.push((u32)NumberBig.limb_or_value(av_or, bv_or));
            }
        } else {
            for (var i_xor: u64 = 0; i_xor < n; i_xor = i_xor + 1) {
                var av_xor: u64 = NumberBig.digit_or_zero(aa, an, i_xor);
                var bv_xor: u64 = NumberBig.digit_or_zero(bb, bn, i_xor);
                out_big.digits.push((u32)NumberBig.limb_xor_value(av_xor, bv_xor));
            }
        }
        out_big.trim_inplace();
        var out: Number = Number.from_big_normalized(out_big);
        return out;
    }

    public func bitwise_values(
        self: *Number,
        rhs: *Number,
        mode: u64
    ) -> Number {
        if (self.is_real() != 0 || rhs.is_real() != 0 || self.is_complex() != 0 || rhs.is_complex() != 0) {
            panic("Number bitwise operation requires integer operands");
            return Number { NUMBER_TAG_SMALL };
        }
        var self_sign0: i64 = self.signum();
        var rhs_sign0: i64 = rhs.signum();
        if (self_sign0 >= 0 && rhs_sign0 >= 0) {
            if (mode == NUMBER_BITWISE_AND) {
                var out_and: Number = self.bitwise_nonneg_abs(rhs, NUMBER_BITWISE_AND);
                return out_and;
            }
            if (mode == NUMBER_BITWISE_OR) {
                var out_or: Number = self.bitwise_nonneg_abs(rhs, NUMBER_BITWISE_OR);
                return out_or;
            }
            var out_xor: Number = self.bitwise_nonneg_abs(rhs, NUMBER_BITWISE_XOR);
            return out_xor;
        }

        var abit: u64 = self.bit_length_abs();
        var bbit: u64 = rhs.bit_length_abs();
        var width: u64 = abit;
        if (bbit > width) { width = bbit; }
        width = width + 2;

        var atc: Number = self.abs_clone();
        if (self.signum() < 0) {
            var abase: Number = Number.pow2(width);
            atc = abase.add_values(self);
        }
        var btc: Number = rhs.abs_clone();
        if (rhs.signum() < 0) {
            var bbase: Number = Number.pow2(width);
            btc = bbase.add_values(rhs);
        }
        var otc: Number = Number { NUMBER_TAG_SMALL };
        if (mode == NUMBER_BITWISE_AND) {
            otc = atc.bitwise_nonneg_abs(&btc, NUMBER_BITWISE_AND);
        } else if (mode == NUMBER_BITWISE_OR) {
            otc = atc.bitwise_nonneg_abs(&btc, NUMBER_BITWISE_OR);
        } else {
            otc = atc.bitwise_nonneg_abs(&btc, NUMBER_BITWISE_XOR);
        }
        if (otc.signum() == 0 || width == 0) {
            return Number { NUMBER_TAG_SMALL };
        }
        var sign_bit: Number = Number.pow2(width - 1);
        if (otc.abs_cmp(&sign_bit) < 0) {
            var out_abs: Number = otc.abs_clone();
            return out_abs;
        }
        var base: Number = Number.pow2(width);
        var out_sub: Number = otc.sub_values(&base);
        return out_sub;
    }

    public func bitnot_values(self: *Number) -> Number {
        var neg: Number = self.negated();
        var one: Number = Number { NUMBER_TAG_SMALL };
        one.set_i64(1);
        var out: Number = neg.sub_values(&one);
        return out;
    }

    public func shift_amount(self: *Number) -> u64 {
        if (self == 0) {
            panic("number_shift_amount_from_number: null rhs");
            return 0;
        }
        if (self.is_real() != 0 || self.is_complex() != 0) {
            panic("Number shift amount requires integer operand");
            return 0;
        }
        if (self.signum() <= 0) { return 0; }
        if (self.is_small() != 0) {
            var mag: u64 = 0;
            Number.i64_abs_mag(self.small_value(), &mag);
            return mag;
        }
        var out: u64 = 0;
        if (self.big_ptr().abs_to_u64_checked(&out) == 0) {
            return NUMBER_MAX_U64;
        }
        return out;
    }

    public func shr_values(self: *Number, sh: u64) -> Number {
        if (self == 0 || self.signum() == 0) { return Number { NUMBER_TAG_SMALL }; }
        if (sh == 0) {
            var cloned: Number = self.clone();
            return cloned;
        }

        var a_sign: i64 = self.signum();
        var q: Number = self.scale_pow2_abs(sh, 1);
        if (a_sign > 0) { return q; }

        var restored: Number = q.scale_pow2_abs(sh, 0);
        if (restored.abs_cmp(self) != 0) {
            var one: Number = Number { NUMBER_TAG_SMALL };
            one.set_i64(1);
            q = q.add_values(&one);
        }
        var out_neg: Number = q.abs_with_sign(-1);
        return out_neg;
    }


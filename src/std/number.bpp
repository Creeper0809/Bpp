    public func __op_ge(self: *Number, rhs: Number) -> u64 { return self.cmp_ptr(&rhs) >= 0; }
    public func __op_ge(self: *Number, rhs: i64) -> u64 { var rv: Number = Number { NUMBER_TAG_SMALL }; rv.set_i64(rhs); return self.cmp_ptr(&rv) >= 0; }
    public func __op_ge(self: *Number, rhs: u64) -> u64 { var rv: Number = Number { NUMBER_TAG_SMALL }; rv.set_u64(rhs); return self.cmp_ptr(&rv) >= 0; }
    public func __op_ge(self: *Number, rhs: f64) -> u64 { var rv: Number = number_make_real(rhs); return self.cmp_ptr(&rv) >= 0; }

    public func cmp(self: *Number, rhs: Number) -> i64 { return self.cmp_ptr(&rhs); }

    public func to_i64_checked(self: *Number, out: *i64) -> u64 {
        if (out == 0) { return 0; }
        out[0] = 0;
        if (self == 0) { return 1; }

        if (self.is_small() != 0) {
            out[0] = self.small_value();
            return 1;
        }
        if (self.is_real() != 0) {
            var rv: f64 = self.real_ptr().value;
            var iv: i64 = (i64)rv;
            if ((f64)iv == rv) {
                out[0] = iv;
                return 1;
            }
            return 0;
        }
        if (self.is_complex() != 0) {
            return 0;
        }

        return self.big_ptr().try_to_i64(out);
    }

    public func to_u64_checked(self: *Number, out: *u64) -> u64 {
        if (out == 0) { return 0; }
        out[0] = 0;
        if (self == 0) { return 1; }

        if (self.is_small() != 0) {
            var sv: i64 = self.small_value();
            if (sv < 0) { return 0; }
            out[0] = (u64)sv;
            return 1;
        }
        if (self.is_real() != 0) {
            var rv: f64 = self.real_ptr().value;
            if (rv < 0.0) { return 0; }
            var uv: u64 = (u64)rv;
            if ((f64)uv == rv) {
                out[0] = uv;
                return 1;
            }
            return 0;
        }
        if (self.is_complex() != 0) {
            return 0;
        }

        var b: *NumberBig = self.big_ptr();
        if (b == 0 || b.sign == 0) { return 1; }
        if (b.sign < 0) { return 0; }
        return b.abs_to_u64_checked(out);
    }

    public func to_i64_checked_value(self: *Number) -> i64 {
        var out: i64 = 0;
        if (self.to_i64_checked(&out) == 0) {
            panic("number does not fit in i64");
        }
        return out;
    }

    public func to_u64_checked_value(self: *Number) -> u64 {
        var out: u64 = 0;
        if (self.to_u64_checked(&out) == 0) {
            panic("number does not fit in u64");
        }
        return out;
    }

    public func to_i8_checked_value(self: *Number) -> i8 {
        var out: i64 = self.to_i64_checked_value();
        if (out < -128 || out > 127) { panic("number does not fit in i8"); }
        return (i8)out;
    }

    public func to_i16_checked_value(self: *Number) -> i16 {
        var out: i64 = self.to_i64_checked_value();
        if (out < -32768 || out > 32767) { panic("number does not fit in i16"); }
        return (i16)out;
    }

    public func to_i32_checked_value(self: *Number) -> i32 {
        var out: i64 = self.to_i64_checked_value();
        if (out < -2147483648 || out > 2147483647) { panic("number does not fit in i32"); }
        return (i32)out;
    }

    public func to_u8_checked_value(self: *Number) -> u8 {
        var out: u64 = self.to_u64_checked_value();
        if (out > 255) { panic("number does not fit in u8"); }
        return (u8)out;
    }

    public func to_u16_checked_value(self: *Number) -> u16 {
        var out: u64 = self.to_u64_checked_value();
        if (out > 65535) { panic("number does not fit in u16"); }
        return (u16)out;
    }

    public func to_u32_checked_value(self: *Number) -> u32 {
        var out: u64 = self.to_u64_checked_value();
        if (out > 4294967295) { panic("number does not fit in u32"); }
        return (u32)out;
    }

    public func to_str(self: *Number) -> u64 {
        if (self != 0 && self.is_real() != 0) {
            return to_str_f64(self.real_ptr().value);
        }
        if (self != 0 && self.is_complex() != 0) {
            var c: *NumberComplex = self.complex_ptr();
            if (c == 0) { return "0"; }
            var rs: u64 = c.real.to_str();
            var is: u64 = c.imag.to_str();
            var joined: u64 = str_concat3(rs, str_len(rs), "+", 1, is, str_len(is));
            return str_concat(joined, str_len(joined), "i", 1);
        }

        var sign: i64 = 0;
        if (self != 0) {
            sign = self.signum();
        }
        if (sign == 0) {
            var z: u64 = heap_alloc(2 * sizeof(u8));
            var zu8: *u8 = (*u8)z;
            zu8[0] = 48;
            zu8[1] = 0;
            return z;
        }

        var t: Number = self.abs_clone();
        var rev_buf: u64 = heap_alloc(32 * sizeof(u8));
        var rev: *Vec<u8> = new Vec<u8>{rev_buf, 0, 32};
        while (t.signum() != 0) {
            var d: u64 = t.mod_small_abs(10);
            rev.push((u8)(48 + d));
            t = t.div_small_abs(10);
        }

        var sign_len: u64 = 0;
        if (sign < 0) { sign_len = 1; }
        var n: u64 = rev.len();
        var out: u64 = heap_alloc((sign_len + n + 1) * sizeof(u8));
        var out_u8: *u8 = (*u8)out;
        var pos: u64 = 0;
        if (sign < 0) {
            out_u8[0] = 45;
            pos = 1;
        }
        var i: u64 = n;
        while (i > 0) {
            i = i - 1;
            out_u8[pos] = rev.get(i);
            pos = pos + 1;
        }
        out_u8[pos] = 0;
        return out;
    }

    public func to_f64_lossy(self: *Number) -> f64 {
        if (self == 0) { return 0.0; }
        if (self.is_real() != 0) { return self.real_ptr().value; }
        if (self.is_complex() != 0) {
            var rp: Number = self.real_part();
            return rp.to_f64_lossy();
        }
        if (self.is_small() != 0) { return (f64)self.small_value(); }

        var b: *NumberBig = self.big_ptr();
        if (b == 0 || b.sign == 0) { return 0.0; }

        var n: u64 = b.digits.len();
        var acc: f64 = 0.0;
        var i: u64 = n;
        while (i > 0) {
            i = i - 1;
            acc = (acc * (f64)NUMBER_BASE) + (f64)b.digits.get(i);
        }
        if (b.sign < 0) { return 0.0 - acc; }
        return acc;
    }

    public func to_i64_lossy(self: *Number) -> i64 {
        var out: i64 = 0;
        if (self.to_i64_checked(&out) != 0) { return out; }

        if (self == 0) { return 0; }
        if (self.is_real() != 0) { return (i64)self.real_ptr().value; }
        if (self.is_complex() != 0) {
            var rp: Number = self.real_part();
            return rp.to_i64_lossy();
        }
        if (self.is_small() != 0) { return self.small_value(); }
        var b: *NumberBig = self.big_ptr();
        if (b == 0 || b.sign == 0) { return 0; }

        var n: u64 = b.digits.len();
        var acc: u64 = 0;
        var i: u64 = n;
        while (i > 0) {
            i = i - 1;
            acc = acc * NUMBER_BASE + (u64)b.digits.get(i);
        }
        if (b.sign < 0) { return 0 - (i64)acc; }
        return (i64)acc;
    }
}

func number_from_i8(v: i8) -> Number { var out: Number = Number { NUMBER_TAG_SMALL }; out.set_i64((i64)v); return out; }
func number_from_i16(v: i16) -> Number { var out: Number = Number { NUMBER_TAG_SMALL }; out.set_i64((i64)v); return out; }
func number_from_i32(v: i32) -> Number { var out: Number = Number { NUMBER_TAG_SMALL }; out.set_i64((i64)v); return out; }
func number_from_i64(v: i64) -> Number { var out: Number = Number { NUMBER_TAG_SMALL }; out.set_i64(v); return out; }
func number_from_u8(v: u8) -> Number { var out: Number = Number { NUMBER_TAG_SMALL }; out.set_u64((u64)v); return out; }
func number_from_u16(v: u16) -> Number { var out: Number = Number { NUMBER_TAG_SMALL }; out.set_u64((u64)v); return out; }
func number_from_u32(v: u32) -> Number { var out: Number = Number { NUMBER_TAG_SMALL }; out.set_u64((u64)v); return out; }
func number_from_u64(v: u64) -> Number { var out: Number = Number { NUMBER_TAG_SMALL }; out.set_u64(v); return out; }
func number_from_f64(v: f64) -> Number { return number_make_real(v); }
func number_cmp_ptr(lhs: *Number, rhs: *Number) -> i64 { return lhs.cmp_ptr(rhs); }

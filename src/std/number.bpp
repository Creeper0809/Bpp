    public func operator *(self: *Number, rhs: u64) -> Number { var rv: Number = Number { NUMBER_TAG_SMALL }; rv.set_u64(rhs); var out: Number = self.mul_values(&rv); return out; }
    public func operator /(self: *Number, rhs: Number) -> Number { var out: Number = self.div_values(&rhs); return out; }
    public func operator /(self: *Number, rhs: i64) -> Number { var rv: Number = Number { NUMBER_TAG_SMALL }; rv.set_i64(rhs); var out: Number = self.div_values(&rv); return out; }
    public func operator /(self: *Number, rhs: u64) -> Number { var rv: Number = Number { NUMBER_TAG_SMALL }; rv.set_u64(rhs); var out: Number = self.div_values(&rv); return out; }
    public func operator %(self: *Number, rhs: Number) -> Number { var out: Number = self.mod_values(&rhs); return out; }
    public func operator %(self: *Number, rhs: i64) -> Number { var rv: Number = Number { NUMBER_TAG_SMALL }; rv.set_i64(rhs); var out: Number = self.mod_values(&rv); return out; }
    public func operator %(self: *Number, rhs: u64) -> Number { var rv: Number = Number { NUMBER_TAG_SMALL }; rv.set_u64(rhs); var out: Number = self.mod_values(&rv); return out; }
    public func operator &(self: *Number, rhs: Number) -> Number { var out: Number = self.bitwise_values(&rhs, NUMBER_BITWISE_AND); return out; }
    public func operator &(self: *Number, rhs: i64) -> Number { var rv: Number = Number { NUMBER_TAG_SMALL }; rv.set_i64(rhs); var out: Number = self.bitwise_values(&rv, NUMBER_BITWISE_AND); return out; }
    public func operator &(self: *Number, rhs: u64) -> Number { var rv: Number = Number { NUMBER_TAG_SMALL }; rv.set_u64(rhs); var out: Number = self.bitwise_values(&rv, NUMBER_BITWISE_AND); return out; }
    public func operator |(self: *Number, rhs: Number) -> Number { var out: Number = self.bitwise_values(&rhs, NUMBER_BITWISE_OR); return out; }
    public func operator |(self: *Number, rhs: i64) -> Number { var rv: Number = Number { NUMBER_TAG_SMALL }; rv.set_i64(rhs); var out: Number = self.bitwise_values(&rv, NUMBER_BITWISE_OR); return out; }
    public func operator |(self: *Number, rhs: u64) -> Number { var rv: Number = Number { NUMBER_TAG_SMALL }; rv.set_u64(rhs); var out: Number = self.bitwise_values(&rv, NUMBER_BITWISE_OR); return out; }
    public func operator ^(self: *Number, rhs: Number) -> Number { var out: Number = self.bitwise_values(&rhs, NUMBER_BITWISE_XOR); return out; }
    public func operator ^(self: *Number, rhs: i64) -> Number { var rv: Number = Number { NUMBER_TAG_SMALL }; rv.set_i64(rhs); var out: Number = self.bitwise_values(&rv, NUMBER_BITWISE_XOR); return out; }
    public func operator ^(self: *Number, rhs: u64) -> Number { var rv: Number = Number { NUMBER_TAG_SMALL }; rv.set_u64(rhs); var out: Number = self.bitwise_values(&rv, NUMBER_BITWISE_XOR); return out; }
    public func operator <<(self: *Number, rhs: Number) -> Number { var out: Number = self.shl_values(rhs.shift_amount()); return out; }
    public func operator <<(self: *Number, rhs: i64) -> Number { var rv: Number = Number { NUMBER_TAG_SMALL }; rv.set_i64(rhs); var out: Number = self.shl_values(rv.shift_amount()); return out; }
    public func operator <<(self: *Number, rhs: u64) -> Number { var rv: Number = Number { NUMBER_TAG_SMALL }; rv.set_u64(rhs); var out: Number = self.shl_values(rv.shift_amount()); return out; }
    public func operator >>(self: *Number, rhs: Number) -> Number { var out: Number = self.shr_values(rhs.shift_amount()); return out; }
    public func operator >>(self: *Number, rhs: i64) -> Number { var rv: Number = Number { NUMBER_TAG_SMALL }; rv.set_i64(rhs); var out: Number = self.shr_values(rv.shift_amount()); return out; }
    public func operator >>(self: *Number, rhs: u64) -> Number { var rv: Number = Number { NUMBER_TAG_SMALL }; rv.set_u64(rhs); var out: Number = self.shr_values(rv.shift_amount()); return out; }
    public func operator ~(self: *Number) -> Number { var out: Number = self.bitnot_values(); return out; }

    public func __op_eq(self: *Number, rhs: Number) -> u64 { return self.cmp_ptr(&rhs) == 0; }
    public func __op_ne(self: *Number, rhs: Number) -> u64 { return self.cmp_ptr(&rhs) != 0; }
    public func __op_ne(self: *Number, rhs: i64) -> u64 { var rv: Number = Number { NUMBER_TAG_SMALL }; rv.set_i64(rhs); return self.cmp_ptr(&rv) != 0; }

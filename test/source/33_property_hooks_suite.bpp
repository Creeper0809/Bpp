// Covers: property hooks success suite

//=== CASE 201_property_hook_auto_getter_setter_and_raw_success
struct HookAuto201 {
    @[setter]
    public hp: i32;
    @[getter]
    public mp: i32;
}

func main() -> u64 {
    var v: HookAuto201 = HookAuto201 { (i32)0, (i32)3 };
    v.hp = (i32)150;
    if ((u64)v.hp != 150) { return 1; }

    v.$mp = (i32)9;
    if ((u64)v.mp != 9) { return 2; }
    return 0;
}
//=== END

//=== CASE 202_property_hook_manual_setter_success
struct HookManualSetter202 {
    @[setter(set_hp_202)]
    public hp: u64;
}

func set_hp_202(self: *HookManualSetter202, val: u64) {
    self.$hp = val;
}

func main() -> u64 {
    var v: HookManualSetter202 = HookManualSetter202 { 0 };
    v.hp = 7;
    if (v.hp != 7) { return 1; }
    v.hp = 41;
    if (v.hp != 41) { return 2; }
    return 0;
}
//=== END

//=== CASE 203_property_hook_manual_getter_success
struct HookManualGetter203 {
    @[getter(get_mp_203)]
    public mp: i32;
}

func get_mp_203(self: *HookManualGetter203) -> i32 {
    return self.$mp;
}

func main() -> u64 {
    var v: HookManualGetter203 = HookManualGetter203 { (i32)41 };
    if ((u64)v.mp != 41) { return 1; }

    v.$mp = (i32)9;
    if ((u64)v.mp != 9) { return 2; }
    return 0;
}
//=== END

//=== CASE 204_property_hook_manual_setter_and_getter_same_field_success
struct HookManualBoth204 {
    @[setter(set_x_204)]
    @[getter(get_x_204)]
    public x: u64;
}

func set_x_204(self: *HookManualBoth204, val: u64) {
    self.$x = val;
}

func get_x_204(self: *HookManualBoth204) -> u64 {
    return self.$x;
}

func main() -> u64 {
    var v: HookManualBoth204 = HookManualBoth204 { 0 };
    v.x = 20;
    if (v.$x != 20) { return 1; }
    if (v.x != 20) { return 2; }
    return 0;
}
//=== END

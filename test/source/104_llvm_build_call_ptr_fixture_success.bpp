// LLVM Build: true

@[feature]
func add_104(a: u64, b: u64) -> u64 {
    return a + b;
}

@[feature]
func sub_104(a: u64, b: u64) -> u64 {
    return a - b;
}

@[entry]
func runtime_entry() -> u64 {
    var fp: u64 = &add_104;
    var out: u64 = fp(9, 1);
    if (out != 10) { return 1; }
    fp = &sub_104;
    out = out + fp(9, 1);
    return out - 18;

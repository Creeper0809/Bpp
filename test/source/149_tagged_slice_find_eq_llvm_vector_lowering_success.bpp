// LLVM Build: true
// Expect llvm metadata contains: bpp.vector.lowering = tagged-slice-find-eq-u64x4
// Expect llvm metadata contains: bpp.vector.lowering = tagged-slice-find-eq-i64x4
// Expect llvm metadata contains: icmp eq <4 x i64>
// Expect llvm metadata contains: bpp.vector.lowering = tagged-slice-find-eq-f64x4
// Expect llvm metadata contains: fcmp oeq <4 x double>
// Expect llvm metadata contains: select <4 x i1>
// Expect llvm metadata contains: extractelement <4 x i64>
// Expect llvm metadata contains: ret i64 -1
// Covers: LLVM vector lowering for tagged slice first-match search reductions
// Expect exit code: 0

func main() -> u64 {
    var us: [10]u64;
    us[0] = 9;
    us[1] = 3;
    us[2] = 5;
    us[3] = 7;
    us[4] = 11;
    us[5] = 7;
    us[6] = 13;
    us[7] = 17;
    us[8] = 19;
    us[9] = 7;
    var su: BppTaggedSlice<u64> = bpp_tag_slice_from_ptr<u64>(&us[0], 10, BPP_TAG_SHAPE_U64);
    bpp_tag_slice_mark_profiled<u64>(&su);
    if (bpp_tag_slice_find_eq_u64(&su, 7) != 3) { return 1; }
    if (bpp_tag_slice_index_of_u64(&su, 19) != 8) { return 2; }
    if (bpp_tag_slice_find_eq_u64(&su, 100) != -1) { return 3; }

    var ss: [9]i64;
    ss[0] = 4;
    ss[1] = -8;
    ss[2] = 10;
    ss[3] = 12;
    ss[4] = -8;
    ss[5] = 14;
    ss[6] = 16;
    ss[7] = -8;
    ss[8] = 20;
    var si: BppTaggedSlice<i64> = bpp_tag_slice_from_ptr<i64>(&ss[0], 9, BPP_TAG_SHAPE_I64);
    bpp_tag_slice_mark_profiled<i64>(&si);
    if (bpp_tag_slice_find_eq_i64(&si, -8) != 1) { return 4; }
    if (bpp_tag_slice_index_of_i64(&si, 20) != 8) { return 5; }
    if (bpp_tag_slice_find_eq_i64(&si, -99) != -1) { return 6; }

    var fs: [8]f64;
    fs[0] = 0.5;
    fs[1] = 1.5;
    fs[2] = 2.5;
    fs[3] = 3.5;
    fs[4] = 4.5;
    fs[5] = 3.5;
    fs[6] = 6.5;
    fs[7] = 7.5;
    var sf: BppTaggedSlice<f64> = bpp_tag_slice_from_ptr<f64>(&fs[0], 8, BPP_TAG_SHAPE_F64);
    bpp_tag_slice_mark_profiled<f64>(&sf);
    if (bpp_tag_slice_find_eq_f64(&sf, 3.5) != 3) { return 7; }
    if (bpp_tag_slice_index_of_f64(&sf, 7.5) != 7) { return 8; }
    if (bpp_tag_slice_find_eq_f64(&sf, 9.5) != -1) { return 9; }

    return 0;
}

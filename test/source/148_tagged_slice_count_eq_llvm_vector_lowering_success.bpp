// LLVM Build: true
// Expect llvm metadata contains: bpp.vector.lowering = tagged-slice-count-eq-u64x4
// Expect llvm metadata contains: bpp.vector.lowering = tagged-slice-count-eq-i64x4
// Expect llvm metadata contains: icmp eq <4 x i64>
// Expect llvm metadata contains: bpp.vector.lowering = tagged-slice-count-eq-f64x4
// Expect llvm metadata contains: fcmp oeq <4 x double>
// Expect llvm metadata contains: select <4 x i1>
// Covers: LLVM vector lowering for tagged slice equality counting reductions
// Expect exit code: 0

func main() -> u64 {
    var us: [10]u64;
    us[0] = 7;
    us[1] = 1;
    us[2] = 7;
    us[3] = 3;
    us[4] = 7;
    us[5] = 5;
    us[6] = 7;
    us[7] = 7;
    us[8] = 8;
    us[9] = 7;
    var su: BppTaggedSlice<u64> = bpp_tag_slice_from_ptr<u64>(&us[0], 10, BPP_TAG_SHAPE_U64);
    bpp_tag_slice_mark_profiled<u64>(&su);
    if (bpp_tag_slice_count_eq_u64(&su, 7) != 6) { return 1; }
    if (bpp_tag_slice_any_eq_u64(&su, 8) == 0) { return 2; }
    if (bpp_tag_slice_any_eq_u64(&su, 99) != 0) { return 3; }

    var is: [9]i64;
    is[0] = -2;
    is[1] = 4;
    is[2] = -2;
    is[3] = 9;
    is[4] = -2;
    is[5] = 10;
    is[6] = 11;
    is[7] = -2;
    is[8] = 12;
    var si: BppTaggedSlice<i64> = bpp_tag_slice_from_ptr<i64>(&is[0], 9, BPP_TAG_SHAPE_I64);
    bpp_tag_slice_mark_profiled<i64>(&si);
    if (bpp_tag_slice_count_eq_i64(&si, -2) != 4) { return 4; }
    if (bpp_tag_slice_any_eq_i64(&si, 12) == 0) { return 5; }
    if (bpp_tag_slice_any_eq_i64(&si, -100) != 0) { return 6; }

    var fs: [8]f64;
    fs[0] = 1.5;
    fs[1] = 2.0;
    fs[2] = 1.5;
    fs[3] = 3.5;
    fs[4] = 1.5;
    fs[5] = 4.0;
    fs[6] = 5.0;
    fs[7] = 1.5;
    var sf: BppTaggedSlice<f64> = bpp_tag_slice_from_ptr<f64>(&fs[0], 8, BPP_TAG_SHAPE_F64);
    bpp_tag_slice_mark_profiled<f64>(&sf);
    if (bpp_tag_slice_count_eq_f64(&sf, 1.5) != 4) { return 7; }
    if (bpp_tag_slice_any_eq_f64(&sf, 5.0) == 0) { return 8; }
    if (bpp_tag_slice_any_eq_f64(&sf, 9.0) != 0) { return 9; }

    return 0;
}

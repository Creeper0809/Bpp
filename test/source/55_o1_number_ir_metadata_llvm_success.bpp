// Covers: O1 number_ir small integer constant folding and number fast-path metadata
// Mode: ssa
// Opt: O1
// Compiler args: -O1
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.number.range=small-int-selected
// Expect llvm metadata contains: bpp.ssa.number.fastpath=int-float-complex-specialized
// Expect llvm metadata contains: bpp.ssa.number.overflow=bigint-guarded-slow-path
// Expect llvm metadata contains: bpp.ssa.number.bigint_outline=cold-block-candidate
// Expect llvm metadata contains: bpp.ssa.number.complex_scalar=real-imag-ssa
// Expect llvm metadata contains: bpp.ssa.number.const_fold=o1-small-int
// Expect llvm metadata contains: bpp.ssa.number.vector=number-slice-loop-candidate
// Expect llvm metadata contains: bpp.ssa.number.stack_slot=range-tag-policy
// Expect exit code: 0

func o1_number_ir_probe() -> u64 {
    var a: number = Number.from_i8(-5);
    var b: number = Number.from_u16(7);
    var c: number = Number.from_i64(140737488355327);
    var d: number = Number.from_u64(140737488355327);
    var z: number = Number.from_complex(1, 2);
    if (a.to_i64_checked_value() != -5) { return 1; }
    if (b.to_u64_checked_value() != 7) { return 2; }
    if (c.to_i64_checked_value() != 140737488355327) { return 3; }
    if (d.to_u64_checked_value() != 140737488355327) { return 4; }
    var zr: number = z.real_part();
    var zi: number = z.imag_part();
    if (zr.to_i64_checked_value() != 1) { return 5; }
    if (zi.to_i64_checked_value() != 2) { return 6; }
    return 0;
}

func main() -> u64 {
    return o1_number_ir_probe();
}

// LLVM Build: true
// Covers: heap lifecycle metadata + tagged delete + double delete guard
// Expect exit code: 0

var g_sum: i64 = 0;

packed struct LifeTag141 {
    public owner: u8;
    public generation: u8;
}

struct DropBox141 {
    public id: i64;
}

impl DropBox141 {
    public destructor {
        g_sum = g_sum + self.id;
    }
}

func main(argc: i64, argv: *u64) -> i64 {
    var p: *DropBox141 = new DropBox141{7};
    delete p;
    delete p;
    if (g_sum != 7) { return 1; }

    var q: *DropBox141 = new DropBox141{11};
    var tagged_q: *tagged(LifeTag141) DropBox141 = (*tagged(LifeTag141) DropBox141)q;
    tagged_q.owner = 3;
    tagged_q.generation = 5;
    if (tagged_q.owner != 3) { return 2; }
    if (tagged_q.generation != 5) { return 3; }

    delete tagged_q;
    delete tagged_q;
    if (g_sum != 18) { return 4; }

    var r: *DropBox141 = new DropBox141{13};
    var raw_addr: u64 = (u64)r;
    var tagged_r: *tagged(LifeTag141) DropBox141 = (*tagged(LifeTag141) DropBox141)raw_addr;
    tagged_r.owner = 1;
    delete tagged_r;
    if (g_sum != 31) { return 5; }

    return 0;
}

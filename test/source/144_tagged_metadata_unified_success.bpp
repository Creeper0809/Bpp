// LLVM Build: true
// Covers: unified BppObjectTag lifecycle/ownership/barrier/shape metadata
// Expect llvm metadata contains: bpp.tag.fast_delete_allowed = lifecycle-ownership-storage
// Expect llvm metadata contains: bpp.tag.fast_tagged_delete_begin = lifecycle-ownership-storage
// Expect exit code: 0

var g_drops_144: u64 = 0;

struct MetaBox144 {
    public value: u64;
}

impl MetaBox144 {
    public destructor {
        g_drops_144 = g_drops_144 + self.value;
    }
}

func main() -> u64 {
    var p: *MetaBox144 = new MetaBox144{7};
    var owned: BppTaggedObject<MetaBox144> = bpp_tag_object_heap_owned<MetaBox144>(p);
    if (bpp_tag_object_lifecycle<MetaBox144>(&owned) != BPP_TAG_LIFE_YOUNG) { return 1; }
    if (bpp_tag_object_ownership<MetaBox144>(&owned) != BPP_TAG_OWN_OWNED) { return 2; }
    var raw: *MetaBox144 = bpp_tag_object_raw<MetaBox144>(&owned);
    raw.value = 9;
    bpp_tag_object_mark_old<MetaBox144>(&owned);
    if (bpp_tag_object_lifecycle<MetaBox144>(&owned) != BPP_TAG_LIFE_OLD) { return 3; }
    delete owned.ptr;
    if (g_drops_144 != 9) { return 4; }

    var q: *MetaBox144 = new MetaBox144{11};
    var borrowed: BppTaggedObject<MetaBox144> = bpp_tag_object_borrowed<MetaBox144>(q);
    if (bpp_tag_delete_allowed_raw((u64)borrowed.ptr) != 0) { return 5; }
    if (bpp_tag_can_skip_refcount_raw((u64)borrowed.ptr) == 0) { return 6; }
    delete borrowed.ptr;
    if (g_drops_144 != 9) { return 7; }
    delete q;
    if (g_drops_144 != 20) { return 8; }

    var r: *MetaBox144 = new MetaBox144{13};
    var immortal: BppTaggedObject<MetaBox144> = bpp_tag_object_immortal<MetaBox144>(r);
    if (bpp_tag_delete_allowed_raw((u64)immortal.ptr) != 0) { return 9; }
    if (bpp_tag_can_skip_gc_barrier_raw((u64)immortal.ptr) == 0) { return 10; }
    delete immortal.ptr;
    if (g_drops_144 != 20) { return 11; }
    delete r;
    if (g_drops_144 != 33) { return 12; }

    var nums: Vec<u64> = Vec<u64>{2};
    nums.push(3);
    nums.push(5);
    nums.push(8);
    var sv: BppTaggedSlice<u64> = nums.profiled_tagged_slice(BPP_TAG_SHAPE_U64);
    if (sv.len != 3) { return 13; }
    if (bpp_tag_slice_shape<u64>(&sv) != BPP_TAG_SHAPE_U64) { return 14; }
    if (bpp_tag_profiled_raw((u64)sv.ptr) != 1) { return 15; }
    if (bpp_tag_slice_is_vector_candidate<u64>(&sv) == 0) { return 16; }
    var raw_nums: *u64 = bpp_tag_slice_raw<u64>(&sv);
    if (raw_nums[0] + raw_nums[1] + raw_nums[2] != 16) { return 17; }

    var profile: BppLoopProfile = bpp_loop_profile_new(10);
    bpp_loop_profile_record(&profile, 4, bpp_tag_slice_shape<u64>(&sv));
    if (bpp_loop_profile_is_hot(&profile) != 0) { return 18; }
    bpp_loop_profile_record(&profile, 6, bpp_tag_slice_shape<u64>(&sv));
    if (bpp_loop_profile_is_hot(&profile) == 0) { return 19; }
    if (bpp_loop_profile_vector_candidate<u64>(&profile, &sv) == 0) { return 20; }

    bpp_tag_slice_retag_shape<u64>(&sv, BPP_TAG_SHAPE_MIXED);
    if (bpp_loop_profile_vector_candidate<u64>(&profile, &sv) != 0) { return 21; }

    return 0;
}

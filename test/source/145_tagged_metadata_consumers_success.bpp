// LLVM Build: true
// Covers: escape policy, slice proof propagation, shape cache, and vector fast-path consumers
// Expect exit code: 0

var g_drops_145: u64 = 0;

struct MetaBox145 {
    public value: u64;
}

impl MetaBox145 {
    public destructor {
        g_drops_145 = g_drops_145 + self.value;
    }
}

func expect_number_i64_145(v: number, expected: i64, code: u64) -> u64 {
    if (v.to_i64_checked_value() != expected) { return code; }
    return 0;
}

func main() -> u64 {
    var stack_policy: BppEscapePolicy = bpp_escape_policy_for(64, 0, 0, 0, 0, 0, 0);
    if (stack_policy.storage != BPP_TAG_STORAGE_STACK) { return 1; }
    if (stack_policy.skip_refcount == 0) { return 2; }
    if (stack_policy.skip_barrier == 0) { return 3; }
    if (stack_policy.delete_allowed != 0) { return 4; }

    var arena_policy: BppEscapePolicy = bpp_escape_policy_for(8192, 0, 1, 0, 0, 0, 1);
    if (arena_policy.storage != BPP_TAG_STORAGE_ARENA) { return 5; }
    if (arena_policy.delete_allowed != 0) { return 6; }

    var local_box: MetaBox145;
    local_box.value = 3;
    var stack_tag: BppTaggedObject<MetaBox145> = bpp_tag_object_auto<MetaBox145>(&local_box, 0, 0, 0, 0, 0, 0);
    if (bpp_tag_object_storage<MetaBox145>(&stack_tag) != BPP_TAG_STORAGE_STACK) { return 7; }
    if (bpp_tag_delete_allowed_raw((u64)stack_tag.ptr) != 0) { return 8; }
    delete stack_tag.ptr;
    if (g_drops_145 != 0) { return 9; }

    var heap_box: *MetaBox145 = new MetaBox145{17};
    var escaped_tag: BppTaggedObject<MetaBox145> = bpp_tag_object_auto<MetaBox145>(heap_box, 1, 1, 0, 0, 0, 0);
    if (bpp_tag_object_ownership<MetaBox145>(&escaped_tag) != BPP_TAG_OWN_ESCAPED) { return 10; }
    if (bpp_tag_refcount_retain_needed_raw((u64)escaped_tag.ptr) == 0) { return 11; }
    if (bpp_tag_refcount_release_needed_raw((u64)escaped_tag.ptr) == 0) { return 12; }
    delete escaped_tag.ptr;
    if (g_drops_145 != 17) { return 13; }

    var child_static: MetaBox145;
    child_static.value = 19;
    var parent_dirty: BppTaggedObject<MetaBox145> = bpp_tag_object_from_raw<MetaBox145>(&local_box, BPP_TAG_LIFE_OLD, BPP_TAG_OWN_SHARED, BPP_TAG_STORAGE_HEAP);
    bpp_tag_object_pin<MetaBox145>(&parent_dirty);
    var child_immortal: BppTaggedObject<MetaBox145> = bpp_tag_object_immortal<MetaBox145>(&child_static);
    if (bpp_tag_gc_barrier_needed_raw((u64)parent_dirty.ptr, (u64)child_immortal.ptr) != 0) { return 14; }

    var values: Vec<u64> = Vec<u64>{4};
    values.push(2);
    values.push(5);
    values.push(8);
    values.push(13);
    var tagged_values: BppTaggedSlice<u64> = values.profiled_tagged_slice(BPP_TAG_SHAPE_U64);
    var proof: BppSliceProof = values.tagged_proof(BPP_TAG_SHAPE_U64);
    if (proof.len != 4) { return 15; }
    if (proof.shape != BPP_TAG_SHAPE_U64) { return 16; }
    if (bpp_slice_proof_can_skip_bounds(&proof, 3) == 0) { return 17; }
    if (bpp_slice_proof_can_skip_bounds(&proof, 4) != 0) { return 18; }
    if (bpp_slice_proof_can_vectorize(&proof) == 0) { return 19; }

    var sub: BppTaggedSlice<u64> = bpp_tag_slice_subslice<u64>(&tagged_values, 1, 2);
    if (sub.len != 2) { return 20; }
    if (bpp_tag_slice_sum_u64(&sub) != 13) { return 21; }
    var sub_proof: BppSliceProof = bpp_slice_proof_subslice(&proof, 1, 2);
    if (sub_proof.start != 1 || sub_proof.end_index != 3) { return 22; }

    var profile: BppLoopProfile = bpp_loop_profile_new(4);
    bpp_loop_profile_record(&profile, values.len(), BPP_TAG_SHAPE_U64);
    var plan: BppVectorPlan = values.tagged_vector_plan(BPP_TAG_SHAPE_U64, &profile);
    if (plan.fast_path != BPP_FAST_PATH_VECTOR) { return 23; }
    if (plan.lanes < 2) { return 24; }

    var cache: BppShapeCache = bpp_shape_cache_new(BPP_TAG_SHAPE_UNKNOWN);
    var fp1: u64 = values.tagged_shape_cache_fast_path(BPP_TAG_SHAPE_U64, &cache, &profile, 0);
    var fp2: u64 = values.tagged_shape_cache_fast_path(BPP_TAG_SHAPE_U64, &cache, &profile, 0);
    var fp3: u64 = values.tagged_shape_cache_fast_path(BPP_TAG_SHAPE_U64, &cache, &profile, 0);
    if (fp1 != BPP_FAST_PATH_SCALAR) { return 25; }
    if (fp2 != BPP_FAST_PATH_SCALAR) { return 26; }
    if (fp3 != BPP_FAST_PATH_VECTOR) { return 27; }
    if (cache.hits < 3) { return 28; }

    var nums: [4]number;
    nums[0] = 1;
    nums[1] = 2;
    nums[2] = 3;
    nums[3] = 4;
    var ns: NumberSlice = NumberSlice.from_initialized_ptr(&nums[0], 4);
    var number_proof: BppSliceProof = ns.common_proof();
    if (number_proof.shape != BPP_TAG_SHAPE_I64) { return 29; }
    if (bpp_slice_proof_can_vectorize(&number_proof) == 0) { return 30; }
    var number_profile: BppLoopProfile = bpp_loop_profile_new(4);
    bpp_loop_profile_record(&number_profile, 4, number_proof.shape);
    var number_plan: BppVectorPlan = ns.vector_plan(&number_profile);
    if (number_plan.fast_path != BPP_FAST_PATH_VECTOR) { return 31; }
    var sum_n: number = ns.sum();
    return expect_number_i64_145(sum_n, 10, 32);
}

func driver_variance(cb: func (i64) -> i64) -> u64 {
    return (u64)cb((i64)41);
}

func main() -> u64 {
    var c: func (u64) -> u64 = func (x: u64) -> u64 { x + 1 };
    var direct: u64 = driver_variance(c);
    if (direct != 42) { return 1; }

    var d: func (func (i64) -> i64) -> u64 = driver_variance;
    var out: u64 = d(c);
    if (out != 42) { return 2; }
    return 0;
}

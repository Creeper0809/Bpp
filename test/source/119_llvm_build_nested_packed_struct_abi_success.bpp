// LLVM Build: true
// LLVM Only: true
// Covers: LLVM ABI nested packed struct param/return and unaligned field access
// Expect exit code: 0

packed struct TinyPacked119 {
    public a: u8;
    public b: u16;
}

struct InnerPacked119 {
    public tiny: TinyPacked119;
    public z: u8;
}

struct OuterPacked119 {
    public prefix: u8;
    public inner: InnerPacked119;
    public tail: u64;
    public suffix: u8;
}

func make_outer_packed_119(seed: u64) -> OuterPacked119 {
    var out: OuterPacked119;
    out.prefix = (u8)seed;
    out.inner.tiny.a = (u8)(seed + 1);
    out.inner.tiny.b = (u16)(seed + 20);
    out.inner.z = (u8)(seed + 3);
    out.tail = seed * 100;
    out.suffix = (u8)(seed + 9);
    return out;
}

func sum_outer_packed_119(v: OuterPacked119) -> u64 {
    return (u64)v.prefix + (u64)v.inner.tiny.a + (u64)v.inner.tiny.b + (u64)v.inner.z + v.tail + (u64)v.suffix;
}

func bump_outer_packed_119(v: OuterPacked119, delta: u64) -> OuterPacked119 {
    v.inner.tiny.b = (u16)((u64)v.inner.tiny.b + delta);
    v.tail = v.tail + delta * 10;
    v.suffix = (u8)((u64)v.suffix + 1);
    return v;
}

func main() -> u64 {
    if (sizeof(TinyPacked119) != 3) { return 1; }
    var base: OuterPacked119 = make_outer_packed_119(5);
    if (sum_outer_packed_119(base) != 558) { return 4; }

    var bumped: OuterPacked119 = bump_outer_packed_119(base, 7);
    if (sum_outer_packed_119(bumped) != 636) { return 5; }
    if (sum_outer_packed_119(base) != 558) { return 6; }

    var acc: u64 = 0;
    for (var i: u64 = 0; i < 6; i = i + 1) {
        var item: OuterPacked119 = bump_outer_packed_119(make_outer_packed_119(i), i + 1);
        acc = acc + sum_outer_packed_119(item);
    }
    if (acc != 2010) { return 7; }
    return 0;
}

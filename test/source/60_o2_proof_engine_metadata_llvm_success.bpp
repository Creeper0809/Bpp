// Covers: O2 unified proof engine queries and invalidation reporting
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.proof.engine=unified-query-api
// Expect llvm metadata contains: bpp.ssa.proof.kinds=range-alias-lifecycle-ownership-tag-tripcount
// Expect llvm metadata contains: bpp.ssa.proof.flow=edge-refine-phi-widen
// Expect llvm metadata contains: bpp.ssa.proof.invalidate=call-store-foreign-asm
// Expect llvm metadata contains: bpp.ssa.proof.reason=stable-reason-bits
// Expect llvm metadata contains: bpp.ssa.proof.consumers=number-slice-vec-object-field
// Expect llvm metadata contains: proof_engine=1
// Expect llvm metadata contains: proof_invalidations=
// Expect exit code: 0

func o2_proof_unknown_call(x: u64) -> u64 {
    return x + 1;
}

func o2_proof_engine_probe(flag: u64) -> u64 {
    var a: u64 = bpp_tag_pack(4096, BPP_TAG_LIFE_YOUNG, BPP_TAG_OWN_UNIQUE, BPP_TAG_STORAGE_HEAP, BPP_TAG_BARRIER_CLEAN, BPP_TAG_SHAPE_U64, 1);
    var b: u64 = bpp_tag_repack_lifecycle_barrier(a, BPP_TAG_LIFE_OLD, BPP_TAG_BARRIER_CLEAN);
    var total: u64 = 0;
    for (var i: u64 = 0; i < 4; i = i + 1) {
        if (i < flag) {
            total = total + bpp_tag_strip(b);
        } else {
            total = total + o2_proof_unknown_call(i);
        }
    }
    if (bpp_tag_lifecycle_raw(b) != BPP_TAG_LIFE_OLD) { return 1; }
    if (total == 0) { return 2; }
    return 0;
}

func main() -> u64 {
    return o2_proof_engine_probe(2);
}

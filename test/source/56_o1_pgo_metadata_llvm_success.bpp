// Covers: O1 PGO metadata and benchmark threshold fast-path hooks
// Mode: ssa
// Opt: O1
// Compiler args: -O1
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.pgo.benchmark=micro-runner-candidate
// Expect llvm metadata contains: bpp.ssa.pgo.report=optimization-report
// Expect llvm metadata contains: bpp.ssa.pgo.inline_threshold=tunable
// Expect llvm metadata contains: bpp.ssa.pgo.bigint_threshold=tunable
// Expect llvm metadata contains: bpp.ssa.pgo.allocator_threshold=tunable
// Expect llvm metadata contains: bpp.ssa.pgo.vector_unroll_threshold=tunable
// Expect llvm metadata contains: bpp.ssa.pgo.ci_perf=separate-job
// Expect llvm metadata contains: bpp.ssa.pgo.full_benchmark_ci=separate-from-fast
// Expect exit code: 0

func o1_pgo_probe() -> u64 {
    var hot: u64 = bpp_profile_hot_from_threshold(64, 32);
    if (hot == 0) { return 1; }
    var path: u64 = bpp_profile_fast_path_for_shape_len(BPP_TAG_SHAPE_U64, 1, sizeof(u64), 8, 64, 32, 4, 2, 8);
    if (path != BPP_FAST_PATH_VECTOR) { return 2; }
    var cached: u64 = bpp_shape_inline_cache_fast_path(BPP_TAG_SHAPE_U64, 1, sizeof(u64), 8, 64, 32, 3, 3, 4, 2, 8);
    if (cached != BPP_FAST_PATH_VECTOR) { return 3; }
    var tuned: BppTagTuning = bpp_tag_tuning_from_benchmark(100, 40, 1024);
    if (tuned.hot_threshold != 16) { return 4; }
    return 0;
}

func main() -> u64 {
    return o1_pgo_probe();
}

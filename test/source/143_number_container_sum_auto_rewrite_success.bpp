// Covers: [N]number and []number .sum() auto-lower to tagged NumberSlice fast paths
// Mode: ssa|nossa
// Opt: O0|O1
// LLVM Build: true
// Expect exit code: 0

func expect_i64_143(v: number, expected: i64, code: u64) -> u64 {
    if (v.to_i64_checked_value() != expected) { return code; }
    return 0;
}

func expect_scaled_f64_143(v: number, scale: f64, expected: i64, code: u64) -> u64 {
    var scaled: f64 = v.to_f64_lossy() * scale;
    var got: i64 = (i64)scaled;
    if (got != expected) { return code; }
    return 0;
}

func main() -> u64 {
    var ints: [5]number;
    ints[0] = 10;
    ints[1] = -2;
    ints[2] = 30;
    ints[3] = 4;
    ints[4] = 8;
    var array_sum: number = ints.sum();
    var rc: u64 = expect_i64_143(array_sum, 50, 1);
    if (rc != 0) { return rc; }

    var int_slice: []number = slice(&ints[1], 3);
    var slice_sum: number = int_slice.sum();
    rc = expect_i64_143(slice_sum, 32, 2);
    if (rc != 0) { return rc; }

    var reals: [3]number;
    reals[0] = 1.25;
    reals[1] = 2.5;
    reals[2] = 0.75;
    var real_sum: number = reals.sum();
    rc = expect_scaled_f64_143(real_sum, 100.0, 450, 3);
    if (rc != 0) { return rc; }

    var complex_values: [2]number;
    complex_values[0] = 1 + 2i;
    complex_values[1] = 3 + 4i;
    var complex_sum: number = complex_values.sum();
    rc = expect_i64_143(complex_sum.real_part(), 4, 4);
    if (rc != 0) { return rc; }
    rc = expect_i64_143(complex_sum.imag_part(), 6, 5);
    if (rc != 0) { return rc; }

    ints[2] = 1.5;
    var mixed_sum: number = ints.sum();
    rc = expect_scaled_f64_143(mixed_sum, 10.0, 215, 6);
    if (rc != 0) { return rc; }

    return 0;
}

// Covers: O2 MemorySSA2 interprocedural readonly summary enables local memory rewrite
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.o2.transaction=verified-pass-local-rewrite
// Expect llvm metadata contains: bpp.ssa.proof.consumer=memoryssa2-rewrite-legality
// Expect llvm metadata contains: bpp.ssa.memoryssa2.call=ipa-readonly-forwarding
// Expect llvm metadata contains: bpp.ssa.memoryssa2.rewrite=ipa-readonly-local-memory
// Expect llvm metadata contains: memssa2_ipa_readonly=
// Expect llvm metadata contains: memssa2_verify_errors=0
// Expect exit code: 0

struct O2MemorySSA2IPABox {
    public value: u64;
    public guard: u64;
}

func o2_memoryssa2_ipa_readonly_helper() -> u64 {
    return 66;
}

func o2_memoryssa2_ipa_readonly_probe(x: u64) -> u64 {
    var box: O2MemorySSA2IPABox = O2MemorySSA2IPABox{0, 91};
    box.value = x + 1;
    var h: u64 = o2_memoryssa2_ipa_readonly_helper();
    box.value = x + 5;
    var y: u64 = box.value;
    if (h != 66) { return 1; }
    if (y != x + 5) { return 2; }
    if (box.guard != 91) { return 3; }
    return 0;
}

func main() -> u64 {
    return o2_memoryssa2_ipa_readonly_probe(30);
}

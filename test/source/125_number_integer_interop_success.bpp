// LLVM Build: true
// Covers: implicit Number-to-integer conversions in assignments, returns, calls, casts, and indexing
// Mode: ssa|nossa
// Opt: O0|O1
// Stdin: 100\n
// Expect exit code: 0

import std.io;

func expect_i64_125(value: i64) -> u64 {
    if (value != 100) { return 1; }
    return 0;
}

func expect_u8_125(value: u8) -> u64 {
    if (value != 100) { return 1; }
    return 0;
}

func return_i32_from_number_125(value: number) -> i32 {
    return value;
}

func main() -> u64 {
    var target: number = input<number>();

    var current: i64 = target;
    if (current != 100) { return 1; }

    var as_u64: u64 = target;
    if (as_u64 != 100) { return 2; }

    var as_i32: i32 = target;
    if (as_i32 != 100) { return 3; }

    var as_u8: u8 = target;
    if (as_u8 != 100) { return 4; }

    var negative: number = -12;
    var as_i16: i16 = negative;
    if (as_i16 != -12) { return 5; }

    var assigned: i64 = 0;
    assigned = target;
    if (assigned != 100) { return 6; }

    if (expect_i64_125(target) != 0) { return 7; }
    if (expect_u8_125(target) != 0) { return 8; }

    if (return_i32_from_number_125(target) != 100) { return 9; }

    var explicit_cast: i64 = (i64)target;
    if (explicit_cast != 100) { return 10; }

    var from_call: i32 = number_from_i64(42);
    if (from_call != 42) { return 11; }

    var from_number_expr: i64 = target + 23;
    if (from_number_expr != 123) { return 12; }

    var from_number_shift: u64 = target >> 2;
    if (from_number_shift != 25) { return 13; }

    var spf: [101]i64;
    spf[current] = 7;
    if (spf[100] != 7) { return 14; }

    return 0;
}

// LLVM Build: true
// Mode: ssa
// Opt: O0,O1
// Expect exit code: 0

func pow2_number_case100(exp: u64) -> number {
    var x: number = 1;
    for (var i: u64 = 0; i < exp; i = i + 1) {
        x = x + x;
    }
    return x;
}

func main() -> u64 {
    var big: number = pow2_number_case100(90);
    var s_big: u64 = big.to_str();
    var parsed_big: number = Number.from_str(slice(s_big, 28));
    if (parsed_big != big) { return 1; }
    var checked_i64: i64 = 0;
    if (big.to_i64_checked(&checked_i64) != 0) { return 2; }
    return 0;
}

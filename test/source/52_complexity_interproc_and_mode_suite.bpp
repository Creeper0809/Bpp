// Expect exit code: 0

func rand() -> u64 {
    // Deterministic stub for compile-time mode inference tests.
    return 4;
}

@[complexity(time="O(n)", space="O(1)")]
@[constraints(n=2048)]
func helper_linear(n: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        acc += (i & 1);
        i += 1;
    }
    return acc;
}

@[complexity_budget(time="O(n^2)", space="O(1)")]
@[constraints(n=512)]
@[complexity_debug]
func caller_interproc(n: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        acc += helper_linear(n);
        i += 1;
    }
    return acc;
}

@[complexity_budget(time="O(4*n)", space="O(1)", mode="expected")]
@[constraints(n=4096)]
@[complexity_debug]
func random_walk_like(n: u64) -> u64 {
    var i: u64 = 0;
    var x: u64 = 0;
    while (i < n) {
        x = x + (rand() & 1);
        i += 1;
    }
    return x;
}

func main() -> u64 {
    var a: u64 = caller_interproc(20);
    var b: u64 = random_walk_like(100);
    if (a == 0 && b == 0) {
        return 1;
    }
    return 0;
}

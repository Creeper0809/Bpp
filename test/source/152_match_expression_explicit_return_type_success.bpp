struct MatchPair {
    public a: u64;
    public b: u64;
}

func main() -> u64 {
    var pair: MatchPair = match (2) -> MatchPair {
        case 1:
            MatchPair { 1, 2 };
        case _:
            MatchPair { 20, 22 };
    };
    if (pair.a != 20) { return 1; }
    if (pair.b != 22) { return 2; }
    return 0;
}

// -- bundled from 121_llvm_build_vtable_generic_new_delete_abi_success.bpp

trait Eval121 {
    func value(self: *Self) -> u64;
}

struct HeapCalc121 {
    public n: u64;
}

impl Eval121 for HeapCalc121 {
    public func value(self: *HeapCalc121) -> u64 {
        return self.n + 1;
    }
}

struct PairBox121<T> {
    public item: T;
    public scale: u64;
}

func make_pair_box_121<T>(item: T, scale: u64) -> *PairBox121<T> {
    return new PairBox121<T>{item, scale};
}

func score_pair_box_121<T>(box: *PairBox121<T>, extra: u64) -> u64 {
    return box.scale + extra;
}

func bundle_case__121_llvm_build_vtable_generic_new_delete_abi_success() -> u64 {
    var calc: *HeapCalc121 = new HeapCalc121{41};
    var boxed: *PairBox121<*HeapCalc121> = make_pair_box_121<*HeapCalc121>(calc, 5);
    var dyn: *Eval121 = (*Eval121)boxed.item;

    if (dyn.value() != 42) { return 1; }
    if (score_pair_box_121<*HeapCalc121>(boxed, dyn.value()) != 47) { return 2; }

    boxed.item.n = boxed.item.n + 8;
    if (dyn.value() != 50) { return 3; }

    delete boxed;
    delete calc;
    return 0;
}

func main() -> u64 {
    if (bundle_case__12_std_vec_hashmap() != 0) { return 1; }
    if (bundle_case__16_module_import_generics_suite() != 0) { return 2; }
    if (bundle_case__17_vec_generic_suite() != 0) { return 3; }
    if (bundle_case__18_hashmap_suite() != 0) { return 4; }
    if (bundle_case__121_llvm_build_vtable_generic_new_delete_abi_success() != 0) { return 5; }
    return 0;
}

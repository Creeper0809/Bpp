// LLVM Build: true

@[feature]
func make_tail_110() -> []u8 {
    var buf: [4]u8;
    buf[0] = 10;
    buf[1] = 20;
    buf[2] = 30;
    buf[3] = 40;
    return slice(&buf[1], 2);
}

@[entry]
func runtime_entry() -> u64 {
    var s: []u8 = make_tail_110();
    return (u64)s[0] + (u64)s[1] + s.len - 52;
}

// Covers: ternary operator and do-while loops

//=== CASE 001_ternary_basic_and_nested
func max_u64(a: u64, b: u64) -> u64 {
    return (a > b) ? a : b;
}

func main() -> u64 {
    var a: u64 = (1 < 2) ? 40 : 1;
    var b: u64 = (1 > 2) ? 1 : 2;
    var c: u64 = max_u64(a, b);
    var d: u64 = (a == 40) ? ((b == 2) ? 42 : 0) : 0;

    if (a != 40) { return 1; }
    if (b != 2) { return 2; }
    if (c != 40) { return 3; }
    if (d != 42) { return 4; }
    return 0;
}
//=== END

//=== CASE 002_do_while_continue_break
func main() -> u64 {
    var i: u64 = 0;
    var sum: u64 = 0;

    do {
        i = i + 1;
        if ((i & 1) == 0) { continue; }
        if (i == 9) { break; }
        sum = sum + i;
    } while (i < 20);

    // odd numbers below 9: 1 + 3 + 5 + 7 = 16
    if (sum != 16) { return 1; }
    if (i != 9) { return 2; }
    return 0;
}
//=== END

//=== CASE 003_do_while_single_statement_body
func main() -> u64 {
    var n: u64 = 0;
    do n = n + 1; while (n < 5);
    if (n != 5) { return 1; }
    return 0;
}
//=== END

// Covers: O1 regalloc2 pressure metadata and native regalloc degree/copy preference guards
// Mode: ssa
// Opt: O1
// Compiler args: -O1
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.regalloc2.order=degree-pressure
// Expect llvm metadata contains: bpp.ssa.regalloc2.copy_preference=noninterfering
// Expect llvm metadata contains: bpp.ssa.regalloc2.spill_guard=deterministic-bailout
// Expect llvm metadata contains: bpp.ssa.regalloc2.spill=stable-candidate
// Expect llvm metadata contains: bpp.ssa.regalloc2.live_split=candidate
// Expect llvm metadata contains: bpp.ssa.regalloc2.coalesce=candidate
// Expect llvm metadata contains: bpp.ssa.regalloc2.phi_coalesce=candidate
// Expect llvm metadata contains: bpp.ssa.regalloc2.remat=const-lea-tag
// Expect llvm metadata contains: bpp.ssa.regalloc2.cost_model=caller-callee
// Expect llvm metadata contains: bpp.ssa.regalloc2.constraints=instruction-aware
// Expect llvm metadata contains: bpp.ssa.regalloc2.xmm=separate-class
// Expect llvm metadata contains: bpp.ssa.regalloc2.stack_color=spill-slot
// Expect exit code: 0

func o1_regalloc2_pressure(seed: u64) -> u64 {
    var a0: u64 = seed + 1;
    var a1: u64 = a0 + 2;
    var a2: u64 = a1 + 3;
    var a3: u64 = a2 + 4;
    var a4: u64 = a3 + 5;
    var a5: u64 = a4 + 6;
    var a6: u64 = a5 + 7;
    var a7: u64 = a6 + 8;
    var c0: u64 = a7;
    var c1: u64 = c0;
    var c2: u64 = c1 + a3;
    var c3: u64 = c2 + a5;
    var c4: u64 = c3 ^ a1;
    var c5: u64 = c4 + a6;
    var c6: u64 = c5 - a2;
    var c7: u64 = c6 + a4;
    return c7;
}

func main() -> u64 {
    if (o1_regalloc2_pressure(10) != 155) {
        return 1;
    }
    return 0;
}

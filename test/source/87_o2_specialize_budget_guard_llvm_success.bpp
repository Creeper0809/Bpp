// Covers: O2 specialization reports duplicate/code-size guard when call budget is exceeded
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.specialize.guard=duplicate-code-size
// Expect llvm metadata contains: bpp.ssa.specialize.report=debug-dump-opt-report-benchmark
// Expect llvm metadata contains: spec_budget=
// Expect exit code: 0

func o2_specialize_budget_large(x: u64) -> u64 {
    var y: u64 = x;
    y = y + 1;
    y = y + 2;
    y = y + 3;
    y = y + 4;
    y = y + 5;
    y = y + 6;
    y = y + 7;
    y = y + 8;
    y = y + 9;
    y = y + 10;
    y = y + 11;
    y = y + 12;
    y = y + 13;
    y = y + 14;
    y = y + 15;
    y = y + 16;
    y = y + 17;
    y = y + 18;
    y = y + 19;
    y = y + 20;
    return y;
}

func o2_specialize_budget_probe() -> u64 {
    var total: u64 = 0;
    total = total + o2_specialize_budget_large(1);
    total = total + o2_specialize_budget_large(2);
    total = total + o2_specialize_budget_large(3);
    total = total + o2_specialize_budget_large(4);
    total = total + o2_specialize_budget_large(5);
    total = total + o2_specialize_budget_large(6);
    total = total + o2_specialize_budget_large(7);
    total = total + o2_specialize_budget_large(8);
    total = total + o2_specialize_budget_large(9);
    total = total + o2_specialize_budget_large(10);
    total = total + o2_specialize_budget_large(11);
    total = total + o2_specialize_budget_large(12);
    total = total + o2_specialize_budget_large(13);
    total = total + o2_specialize_budget_large(14);
    total = total + o2_specialize_budget_large(15);
    total = total + o2_specialize_budget_large(16);
    total = total + o2_specialize_budget_large(17);
    total = total + o2_specialize_budget_large(18);
    total = total + o2_specialize_budget_large(19);
    total = total + o2_specialize_budget_large(20);
    total = total + o2_specialize_budget_large(21);
    total = total + o2_specialize_budget_large(22);
    total = total + o2_specialize_budget_large(23);
    total = total + o2_specialize_budget_large(24);
    total = total + o2_specialize_budget_large(25);
    total = total + o2_specialize_budget_large(26);
    total = total + o2_specialize_budget_large(27);
    total = total + o2_specialize_budget_large(28);
    total = total + o2_specialize_budget_large(29);
    total = total + o2_specialize_budget_large(30);
    total = total + o2_specialize_budget_large(31);
    total = total + o2_specialize_budget_large(32);
    total = total + o2_specialize_budget_large(33);
    total = total + o2_specialize_budget_large(34);
    if (total == 0) { return 1; }
    return 0;
}

func main() -> u64 {
    return o2_specialize_budget_probe();
}

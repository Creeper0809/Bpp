// Mode: ssa
// Opt: O0,O1
// Expect exit code: 0

func pow2_number_case97(exp: u64) -> number {
    var x: number = 1;
    for (var i: u64 = 0; i < exp; i = i + 1) {
        x = x + x;
    }
    return x;
}

func main() -> u64 {
    var big: number = pow2_number_case97(90);
    var qbig: number = big / 8;
    var rbig: number = big % 8;
    if (qbig == 0 && rbig == 123456789) { return 1; }
    var mneg: number = -10;
    var neg_mod: number = mneg % 6;
    if (neg_mod != -4) { return 2; }

    var one: number = 1;
    var big_or: number = big | one;
    if (big_or == big) { return 10; }
    if (big_or < big) { return 11; }
    var delta: number = big_or - big;
    if (delta != one) { return 12; }
    return 0;
}

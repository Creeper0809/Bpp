// Expect exit code: 0

// 5-variable expression acceptance.
@[complexity_budget(time="O(6*(n*m + k*log(p) + q))", space="O(1)", mode="worst")]
@[constraints(n=32, m=48, k=64, p=65536, q=128)]
@[time_limit(ms=80, machine="ref_v1")]
@[complexity_debug]
func five_var_mixed(n: u64, m: u64, k: u64, p: u64, q: u64) -> u64 {
    var acc: u64 = 0;

    var i: u64 = 0;
    while (i < n) {
        var j: u64 = 0;
        while (j < m) {
            acc += ((i + j) & 1);
            j += 1;
        }
        i += 1;
    }

    var t: u64 = 0;
    while (t < k) {
        var u: u64 = 1;
        while (u < p) {
            acc += (u & 1);
            u = u << 1;
        }
        t += 1;
    }

    var r: u64 = 0;
    while (r < q) {
        acc += (r & 1);
        r += 1;
    }
    return acc;
}

// Transitive relation propagation:
// rel1 requires m first, rel2 provides m, rel3 depends on k.
@[complexity_budget(time="O(4*t)", space="O(1)")]
@[constraints(n=256, p=64, q=32, rel1="k<=n*m", rel2="m<=p+q", rel3="t<=k+q")]
@[time_limit(ms=200, machine="ref_v1")]
@[complexity_debug]
func transitive_relation_bound(t: u64) -> u64 {
    var i: u64 = 0;
    var s: u64 = 0;
    while (i < t) {
        s += (i & 1);
        i += 1;
    }
    return s;
}

func main() -> u64 {
    var a: u64 = five_var_mixed(8, 12, 16, 1024, 20);
    if (a == 0) { return 1; }

    var b: u64 = transitive_relation_bound(1000);
    if (b != 500) { return 2; }

    return 0;
}

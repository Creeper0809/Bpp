// Covers: O2 runtime allocator/GC and number tower contract metadata
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.runtime_gc.engine=allocator-lifecycle-barrier-stackmap
// Expect llvm metadata contains: bpp.ssa.runtime_gc.alloc=sizeclass-huge-tcache-debug
// Expect llvm metadata contains: bpp.ssa.runtime_gc.escape=stack-arena-nursery-old
// Expect llvm metadata contains: bpp.ssa.runtime_gc.stackmap=moving-gc-ready
// Expect llvm metadata contains: bpp.ssa.number_tower.engine=numeric-tower-fast-slow-path
// Expect llvm metadata contains: bpp.ssa.number_tower.repr=int-float-complex-bigint
// Expect llvm metadata contains: bpp.ssa.number_tower.overflow=machine-fast-bigint-slow
// Expect llvm metadata contains: bpp.ssa.number_tower.threshold=benchmark-tuned
// Expect llvm metadata contains: runtime_gc=
// Expect llvm metadata contains: number_tower=
// Expect exit code: 0

func o2_runtime_number_probe() -> u64 {
    bpp_gc_init();
    var parent: u64 = bpp_gc_alloc_tagged(32, BPP_TAG_SHAPE_OBJECT);
    var child: u64 = bpp_heap_alloc_auto_tagged(16, 1, 1, 1, 0, 0, 0, BPP_TAG_SHAPE_OBJECT);
    bpp_tag_write_barrier_raw(parent, child);

    var a: number = 7;
    var b: number = 3;
    var c: number = (a * b) + a;
    if (c != 28) { return 1; }
    return 0;
}

func main() -> u64 {
    return o2_runtime_number_probe();
}

// LLVM Build: true

struct BigLLVM108 {
    public a: u64;
    public b: u64;
    public c: u64;
}

@[feature]
func make_big_108(base: u64) -> BigLLVM108 {
    return BigLLVM108{base, base + 1, base + 2};
}

@[feature]
func sum_big_108(v: BigLLVM108) -> u64 {
    return v.a + v.b + v.c;
}

@[entry]
func runtime_entry() -> u64 {
    var v: BigLLVM108 = make_big_108(10);
    return sum_big_108(v) - 33;
}

// Covers: O2 MemorySSA2 local dead store elimination
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.memoryssa2.rewrite=local-dead-store-kill
// Expect llvm metadata contains: memssa2_store_kill=
// Expect exit code: 0

struct O2DeadStoreBox {
    public value: u64;
    public guard: u64;
}

func o2_memoryssa2_dead_store_probe(x: u64) -> u64 {
    var box: O2DeadStoreBox = O2DeadStoreBox{0, 77};
    box.value = x + 1;
    var n: number = Number.from_str(slice("7", 1));
    box.value = x + 2;
    var y: u64 = box.value;
    if (n != 7) { return 3; }
    if (y != x + 2) { return 1; }
    if (box.guard != 77) { return 2; }
    return 0;
}

func main() -> u64 {
    return o2_memoryssa2_dead_store_probe(40);
}

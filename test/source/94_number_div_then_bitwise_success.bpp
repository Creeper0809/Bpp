// LLVM Build: true
// Mode: ssa
// Opt: O0,O1
// Expect exit code: 0

func pow2_number_case94(exp: u64) -> number {
    var x: number = 1;
    for (var i: u64 = 0; i < exp; i = i + 1) {
        x = x + x;
    }
    return x;
}

func main() -> u64 {
    var big: number = pow2_number_case94(90);
    var qbig: number = big / 8;
    var p87: number = pow2_number_case94(87);
    if (qbig != p87) { return 1; }
    var rbig: number = big % 8;
    if (rbig != 0) { return 2; }
    var mneg: number = -10;
    var neg_mod: number = mneg % 6;
    if (neg_mod != -4) { return 3; }

    var big_or: number = big | 1;
    if ((big_or - big) != 1) { return 4; }
    var big_and: number = big_or & big;
    if (big_and != big) { return 5; }
    return 0;
}

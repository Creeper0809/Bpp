// Covers: number.to_str() can be passed to raw emitln after input<number>()
// Stdin: 42\n
// Expect exit code: 0
// Expect stdout: program says: 42\n

import std.io;

func main() -> u64 {
    var line: number = input<number>();
    emit("program says: ");
    emitln(line.to_str());
    return 0;
}

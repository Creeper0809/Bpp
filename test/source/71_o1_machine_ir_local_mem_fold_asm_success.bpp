// Covers: O1 machine-IR local address folding in SSA native codegen
// Mode: ssa
// Opt: O1
// Compile only: true
// Expect asm contains: _71_o1_machine_ir_local_mem_fold_asm_success__machine_ir_fold_pair:
// Expect asm contains: mov [rbp-8], rax
// Expect asm contains: mov [rbp-16], rbx

struct MachineIrFoldPair {
    public a: u64;
    public b: u64;
}

func machine_ir_fold_pair(a: u64, b: u64) -> u64 {
    var p: MachineIrFoldPair = MachineIrFoldPair{a, b};
    return p.a + p.b;
}

func main() -> u64 {
    return machine_ir_fold_pair(19, 23) - 42;
}

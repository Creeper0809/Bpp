// Covers: O2 MemorySSA2 real rewrite across readonly number call
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.memoryssa2.rewrite=readonly-local-load-forward
// Expect llvm metadata contains: memssa2_forwards=
// Expect exit code: 0

struct O2MemoryForwardBox {
    public value: u64;
    public guard: u64;
}

func o2_memoryssa2_readonly_forward_probe(x: u64) -> u64 {
    var box: O2MemoryForwardBox = O2MemoryForwardBox{x, 99};
    box.value = x + 5;
    var n: number = Number.from_str(slice("12345", 5));
    var y: u64 = box.value;
    if (y != x + 5) { return 1; }
    if (box.guard != 99) { return 2; }
    if (n != 12345) { return 3; }
    return 0;
}

func main() -> u64 {
    return o2_memoryssa2_readonly_forward_probe(37);
}

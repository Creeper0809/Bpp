// Covers: O1 SROA2 field scalarization, field load forwarding, dead field store removal, and slice-header proof metadata
// Mode: ssa
// Opt: O1
// Compiler args: -O1
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.sroa2.field=scalar
// Expect llvm metadata contains: bpp.ssa.sroa2.field_load=forwarded
// Expect llvm metadata contains: bpp.ssa.sroa2.field_store=tracked
// Expect llvm metadata contains: bpp.ssa.sroa2.struct_copy=scalar-field-copy
// Expect llvm metadata contains: bpp.ssa.sroa2.dead_field_store=removed
// Expect llvm metadata contains: bpp.ssa.sroa2.escape_field=heap-guarded-only
// Expect llvm metadata contains: bpp.ssa.sroa2.aggregate_return=scalarization-reviewed
// Expect llvm metadata contains: bpp.ssa.sroa2.slice_header=split-ptr-len
// Expect llvm metadata contains: bpp.ssa.sroa2.stack_new=shared-local-proof
// Expect exit code: 0

struct O1Sroa2Pair {
    public a: u64;
    public b: u64;
}

struct O1Sroa2SliceBox {
    public bytes: []u8;
    public marker: u64;
}

func o1_sroa2_pair_probe() -> u64 {
    var p: O1Sroa2Pair;
    p.a = 1;
    p.b = 2;
    p.a = 40;
    var q: O1Sroa2Pair = p;
    q.b = q.b + 1;
    return q.a + q.b;
}

func o1_sroa2_slice_probe() -> u64 {
    var buf: [4]u8;
    buf[0] = 11;
    buf[1] = 22;
    buf[2] = 33;
    buf[3] = 44;
    var box: O1Sroa2SliceBox = O1Sroa2SliceBox{slice(&buf[0], 4), 9};
    box.bytes.len = 3;
    return (u64)box.bytes[1] + box.bytes.len + box.marker;
}

func main() -> u64 {
    if (o1_sroa2_pair_probe() != 43) { return 1; }
    if (o1_sroa2_slice_probe() != 34) { return 2; }
    return 0;
}

// Expect exit code: 0

@[complexity_budget(time="O(8*(log(n)^2))", space="O(1)")]
@[constraints(n=1048576)]
@[complexity_debug]
func polylog_nested(n: u64) -> u64 {
    var acc: u64 = 0;
    for (var i: u64 = 1; i < n; i = i << 1) {
        for (var j: u64 = 1; j < n; j = j << 1) {
            acc += 1;
        }
    }
    return acc;
}

@[complexity_budget(time="O(1)", space="O(1)")]
@[complexity_debug]
func zero_iter_for_known() -> u64 {
    var acc: u64 = 0;
    for (var i: u64 = 10; i < 5; i = i + 1) {
        acc += 1;
    }
    return acc;
}

func main() -> u64 {
    var a: u64 = polylog_nested(1024);
    if (a != 100) { return 1; }

    var z: u64 = zero_iter_for_known();
    if (z != 0) { return 2; }
    return 0;
}

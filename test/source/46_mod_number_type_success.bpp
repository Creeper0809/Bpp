// LLVM Build: true
// Expect exit code: 0

import std.mod_number;

func check_modnumber_type_sugar() -> u64 {
    var a: modnumber<11> = -3;
    if (a.value != 8) { return 100; }
    if (a.modulus != 11) { return 101; }

    var b: modnumber<11> = 5;
    if (b.value != 5) { return 102; }
    if (b.modulus != 11) { return 103; }

    var c: modnumber<10> = 23;
    if (c.value != 3) { return 104; }
    if (c.modulus != 10) { return 105; }

    return 0;
}

func check_basic_new() -> u64 {
    var a: ModNumber = mod_number_new(-3, 11);
    if (a.value != 8) { return 1; }
    if (a.modulus != 11) { return 2; }
    return 0;
}

func check_add_sub_mul() -> u64 {
    var a: ModNumber = mod_number_new(-3, 11);
    var b: ModNumber = mod_number_new(20, 11);
    var c: ModNumber = a + b; // 8 + 9 = 17 -> 6
    if (c.value != 6) { return 3; }
    if (c.modulus != 11) { return 4; }

    var d: ModNumber = c - 19; // 6 - 8 = -2 -> 9
    if (d.value != 9) { return 5; }
    var e: ModNumber = d * 7; // 9 * 7 = 63 -> 8
    if (e.value != 8) { return 6; }
    return 0;
}

func check_setmod() -> u64 {
    var e: ModNumber = mod_number_new(8, 11);
    if (mod_number_setmod_ptr(&e, 7) == 0) { return 7; } // 8 mod 7 -> 1
    if (e.modulus != 7) { return 8; }
    if (e.value != 1) { return 9; }
    return 0;
}

func check_div_inv_pow() -> u64 {
    var x: ModNumber = mod_number_new(7, 13);
    var y: ModNumber = mod_number_new(5, 13);
    var z: ModNumber = x / y; // 5^-1 mod 13 = 8, 7*8 = 56 -> 4
    if (z.value != 4) { return 10; }
    if (z.modulus != 13) { return 11; }

    var inv: ModNumber = mod_number_zero(13);
    if (y.inverse_checked(&inv) == 0) { return 12; }
    if (inv.value != 8) { return 13; }
    if (inv.modulus != 13) { return 14; }

    var p: ModNumber = x.pow((u64)5); // 7^5 mod 13 = 11
    if (p.value != 11) { return 15; }
    return 0;
}

func check_non_invertible() -> u64 {
    var x: ModNumber = mod_number_new(7, 13);
    var noinv: ModNumber = mod_number_new(2, 10);
    var bad: ModNumber = x / noinv; // inverse(2 mod 13) exists if coerced -> using lhs modulus
    if (bad.value != 10) { return 16; } // 2^-1 mod 13 = 7, 7*7 = 49 -> 10

    var lhs10: ModNumber = mod_number_new(4, 10);
    var rhs10: ModNumber = mod_number_new(2, 10);
    var no_div: ModNumber = lhs10 / rhs10; // inverse does not exist in mod 10
    if (no_div.value != 0) { return 17; }
    if (no_div.modulus != 10) { return 18; }
    return 0;
}

func check_eq_and_mix() -> u64 {
    var eq1: ModNumber = mod_number_new(20, 13);
    if (eq1.eq(mod_number_new(7, 13)) == 0) { return 19; }
    if (eq1.eq(mod_number_new(7, 11)) != 0) { return 20; }

    var x: ModNumber = mod_number_new(7, 13);
    var mix: ModNumber = x + 100; // 7 + 9 = 16 -> 3
    if (mix.value != 3) { return 21; }
    return 0;
}

func main() -> u64 {
    var rc: u64 = check_modnumber_type_sugar();
    if (rc != 0) { return rc; }

    rc = check_basic_new();
    if (rc != 0) { return rc; }
    rc = check_add_sub_mul();
    if (rc != 0) { return rc; }
    rc = check_setmod();
    if (rc != 0) { return rc; }
    rc = check_div_inv_pow();
    if (rc != 0) { return rc; }
    rc = check_non_invertible();
    if (rc != 0) { return rc; }
    rc = check_eq_and_mix();
    if (rc != 0) { return rc; }
    return 0;
}

// LLVM Build: true
// Covers: tagged pointer capability guards + refcount/barrier fast lowering + proof range checks
// Expect llvm metadata contains: bpp.tag.fast_refcount_skip = lifecycle-ownership
// Expect llvm metadata contains: bpp.tag.fast_refcount_retain = lifecycle-ownership
// Expect llvm metadata contains: bpp.tag.fast_refcount_release = lifecycle-ownership
// Expect llvm metadata contains: bpp.tag.fast_gc_barrier_skip = lifecycle-storage-barrier
// Expect llvm metadata contains: bpp.tag.fast_gc_barrier_needed = parent-child-tags
// Expect llvm metadata contains: bpp.tag.fast_write_barrier = parent-child-tags
// Expect exit code: 0

packed struct CustomTag150 {
    public state: u8;
}

struct TagFastBox150 {
    public value: u64;
}

func main() -> u64 {
    if (bpp_tag_layout_has_memory_state(slice("BppObjectTag", str_len("BppObjectTag"))) == 0) { return 1; }
    if (bpp_tag_layout_has_memory_state(slice("std_mem__BppObjectTag", str_len("std_mem__BppObjectTag"))) == 0) { return 2; }
    if (bpp_tag_layout_has_memory_state(slice("CustomTag150", str_len("CustomTag150"))) != 0) { return 3; }

    var a: TagFastBox150;
    a.value = 10;
    var unique_policy: BppEscapePolicy = bpp_escape_policy_new(BPP_TAG_LIFE_YOUNG, BPP_TAG_OWN_UNIQUE, BPP_TAG_STORAGE_HEAP, BPP_TAG_BARRIER_CLEAN);
    var unique_tag: BppTaggedObject<TagFastBox150> = bpp_tag_object_from_policy<TagFastBox150>(&a, &unique_policy, BPP_TAG_SHAPE_OBJECT);
    if (bpp_tag_can_skip_refcount_raw((u64)unique_tag.ptr) == 0) { return 4; }
    if (bpp_tag_refcount_retain_needed_raw((u64)unique_tag.ptr) != 0) { return 5; }
    if (bpp_tag_refcount_release_needed_raw((u64)unique_tag.ptr) != 0) { return 6; }

    var shared_policy: BppEscapePolicy = bpp_escape_policy_new(BPP_TAG_LIFE_YOUNG, BPP_TAG_OWN_SHARED, BPP_TAG_STORAGE_HEAP, BPP_TAG_BARRIER_CLEAN);
    var shared_tag: BppTaggedObject<TagFastBox150> = bpp_tag_object_from_policy<TagFastBox150>(&a, &shared_policy, BPP_TAG_SHAPE_OBJECT);
    if (bpp_tag_can_skip_refcount_raw((u64)shared_tag.ptr) != 0) { return 7; }
    if (bpp_tag_refcount_retain_needed_raw((u64)shared_tag.ptr) == 0) { return 8; }
    if (bpp_tag_refcount_release_needed_raw((u64)shared_tag.ptr) == 0) { return 9; }

    var stack_policy: BppEscapePolicy = bpp_escape_policy_new(BPP_TAG_LIFE_BORROWED, BPP_TAG_OWN_STACK, BPP_TAG_STORAGE_STACK, BPP_TAG_BARRIER_SKIP);
    var stack_tag: BppTaggedObject<TagFastBox150> = bpp_tag_object_from_policy<TagFastBox150>(&a, &stack_policy, BPP_TAG_SHAPE_OBJECT);
    if (bpp_tag_delete_allowed_raw((u64)stack_tag.ptr) != 0) { return 10; }
    if (bpp_tag_can_skip_gc_barrier_raw((u64)stack_tag.ptr) == 0) { return 11; }

    var parent: TagFastBox150;
    var child: TagFastBox150;
    parent.value = 20;
    child.value = 30;
    var parent_policy: BppEscapePolicy = bpp_escape_policy_new(BPP_TAG_LIFE_OLD, BPP_TAG_OWN_SHARED, BPP_TAG_STORAGE_HEAP, BPP_TAG_BARRIER_DIRTY);
    var parent_tag: BppTaggedObject<TagFastBox150> = bpp_tag_object_from_policy<TagFastBox150>(&parent, &parent_policy, BPP_TAG_SHAPE_OBJECT);
    var child_tag: BppTaggedObject<TagFastBox150> = bpp_tag_object_heap_owned<TagFastBox150>(&child);
    if (bpp_tag_can_skip_gc_barrier_raw((u64)parent_tag.ptr) != 0) { return 12; }
    if (bpp_tag_gc_barrier_needed_raw((u64)parent_tag.ptr, (u64)child_tag.ptr) == 0) { return 13; }
    var dirty_parent: u64 = bpp_tag_write_barrier_raw((u64)parent_tag.ptr, (u64)child_tag.ptr);
    if (bpp_tag_barrier_raw(dirty_parent) != BPP_TAG_BARRIER_DIRTY) { return 14; }
    if ((dirty_parent & BPP_TAG_PTR_MASK) != (((u64)parent_tag.ptr) & BPP_TAG_PTR_MASK)) { return 15; }

    var immortal_child: BppTaggedObject<TagFastBox150> = bpp_tag_object_immortal<TagFastBox150>(&child);
    if (bpp_tag_gc_barrier_needed_raw((u64)parent_tag.ptr, (u64)immortal_child.ptr) != 0) { return 16; }
    if (bpp_tag_write_barrier_raw((u64)parent_tag.ptr, (u64)immortal_child.ptr) != (u64)parent_tag.ptr) { return 17; }

    var values: [4]u64;
    values[0] = 2;
    values[1] = 4;
    values[2] = 8;
    values[3] = 16;
    var tagged_values: BppTaggedSlice<u64> = bpp_tag_slice_from_ptr<u64>(&values[0], 4, BPP_TAG_SHAPE_U64);
    bpp_tag_slice_mark_profiled<u64>(&tagged_values);
    var proof: BppSliceProof = bpp_slice_proof_from_tagged<u64>(&tagged_values);
    if (bpp_slice_proof_can_skip_range_bounds(&proof, 1, 2) == 0) { return 18; }
    if (bpp_slice_proof_can_skip_range_bounds(&proof, 3, 2) != 0) { return 19; }
    var p: *u64 = bpp_slice_proof_element_ptr<u64>(&proof, 2);
    if (p == 0 || *p != 8) { return 20; }
    var profile: BppLoopProfile = bpp_loop_profile_new(4);
    bpp_loop_profile_record(&profile, 4, BPP_TAG_SHAPE_U64);
    var plan: BppVectorPlan = bpp_slice_proof_vector_plan(&proof, &profile, sizeof(u64));
    if (plan.fast_path != BPP_FAST_PATH_VECTOR || plan.lanes != 4) { return 21; }

    return 0;
}

// LLVM Build: true
// Covers: context-driven implicit numeric conversions for literals, calls, assignments, and returns
// Mode: ssa|nossa
// Opt: O0|O1
// Expect exit code: 0

func expect_u8(value: u8) -> u64 {
    if (value != 42) { return 1; }
    return 0;
}

func expect_u64(value: u64) -> u64 {
    if (value != 42) { return 1; }
    return 0;
}

func expect_i64(value: i64) -> u64 {
    if (value != -12) { return 1; }
    return 0;
}

func expect_f64(value: f64) -> u64 {
    if (value < 41.9) { return 1; }
    if (value > 42.1) { return 2; }
    return 0;
}

func expect_number_neg12(value: number) -> u64 {
    if (value != -12) { return 1; }
    return 0;
}

func return_u64_from_u8(value: u8) -> u64 {
    return value;
}

func return_f64_from_u8(value: u8) -> f64 {
    return value;
}

func return_number_from_i16(value: i16) -> number {
    return value;
}

func main() -> u64 {
    var small_u8: u8 = 42;
    var small_i16: i16 = -12;

    var widened_u64: u64 = small_u8;
    if (widened_u64 != 42) { return 1; }

    var widened_i64: i64 = small_i16;
    if (widened_i64 != -12) { return 2; }

    var float_from_u8: f64 = small_u8;
    if (float_from_u8 < 41.9) { return 3; }
    if (float_from_u8 > 42.1) { return 4; }

    var number_from_i16: number = small_i16;
    if (number_from_i16 != -12) { return 5; }

    if (expect_u8(42) != 0) { return 6; }
    if (expect_u64(small_u8) != 0) { return 7; }
    if (expect_i64(small_i16) != 0) { return 8; }
    if (expect_f64(small_u8) != 0) { return 9; }
    if (expect_f64(42) != 0) { return 10; }
    if (expect_number_neg12(small_i16) != 0) { return 11; }

    if (return_u64_from_u8(small_u8) != 42) { return 12; }
    if (return_f64_from_u8(small_u8) < 41.9) { return 13; }
    if (return_f64_from_u8(small_u8) > 42.1) { return 14; }

    var returned_number: number = return_number_from_i16(small_i16);
    if (returned_number != -12) { return 15; }

    return 0;
}

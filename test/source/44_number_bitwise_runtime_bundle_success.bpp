// Bundled runtime test.
// Covers: large number bitwise, division preservation, and bit-not identity runtime tests
// Mode: ssa|nossa
// Opt: O0|O1
// LLVM Build: true
// Expect exit code: 0

// -- bundled from 93_number_bitwise_big_ssa_success.bpp

func pow2_number_case93(exp: u64) -> number {
    var x: number = 1;
    for (var i: u64 = 0; i < exp; i = i + 1) {
        x = x + x;
    }
    return x;
}

func bundle_case__93_number_bitwise_big_ssa_success() -> u64 {
    var big: number = pow2_number_case93(90);
    var one: number = 1;
    var big_or: number = big | 1;

    if (big_or == big) { return 101; }

    var diff: number = big_or - big;
    if (diff == 0) { return 102; }
    if (diff != one) { return 103; }

    var big_and: number = big_or & big;
    if (big_and != big) { return 104; }

    return 0;
}

// -- bundled from 94_number_div_then_bitwise_success.bpp

func pow2_number_case94(exp: u64) -> number {
    var x: number = 1;
    for (var i: u64 = 0; i < exp; i = i + 1) {
        x = x + x;
    }
    return x;
}

func bundle_case__94_number_div_then_bitwise_success() -> u64 {
    var big: number = pow2_number_case94(90);
    var qbig: number = big / 8;
    var p87: number = pow2_number_case94(87);
    if (qbig != p87) { return 1; }
    var rbig: number = big % 8;
    if (rbig != 0) { return 2; }
    var mneg: number = -10;
    var neg_mod: number = mneg % 6;
    if (neg_mod != -4) { return 3; }

    var big_or: number = big | 1;
    if ((big_or - big) != 1) { return 4; }
    var big_and: number = big_or & big;
    if (big_and != big) { return 5; }
    return 0;
}

// -- bundled from 96_number_div_preserves_input_success.bpp

func pow2_number_case96(exp: u64) -> number {
    var x: number = 1;
    for (var i: u64 = 0; i < exp; i = i + 1) {
        x = x + x;
    }
    return x;
}

func bundle_case__96_number_div_preserves_input_success() -> u64 {
    var big: number = pow2_number_case96(90);
    var expected: number = pow2_number_case96(90);
    var qbig: number = big / 8;
    var rbig: number = big % 8;
    if (qbig == 0 && rbig == 123456789) { return 1; }
    if (big != expected) { return 2; }
    return 0;
}

// -- bundled from 97_number_div_then_bitwise_diagnose_success.bpp

func pow2_number_case97(exp: u64) -> number {
    var x: number = 1;
    for (var i: u64 = 0; i < exp; i = i + 1) {
        x = x + x;
    }
    return x;
}

func bundle_case__97_number_div_then_bitwise_diagnose_success() -> u64 {
    var big: number = pow2_number_case97(90);
    var qbig: number = big / 8;
    var rbig: number = big % 8;
    if (qbig == 0 && rbig == 123456789) { return 1; }
    var mneg: number = -10;
    var neg_mod: number = mneg % 6;
    if (neg_mod != -4) { return 2; }

    var one: number = 1;
    var big_or: number = big | one;
    if (big_or == big) { return 10; }
    if (big_or < big) { return 11; }
    var delta: number = big_or - big;
    if (delta != one) { return 12; }
    return 0;
}

// -- bundled from 98_number_post_bitwise_success.bpp

func pow2_number_case98(exp: u64) -> number {
    var x: number = 1;
    for (var i: u64 = 0; i < exp; i = i + 1) {
        x = x + x;
    }
    return x;
}

func bundle_case__98_number_post_bitwise_success() -> u64 {
    var big: number = pow2_number_case98(90);
    var qbig: number = big / 8;
    var p87: number = pow2_number_case98(87);
    if (qbig != p87) { return 1; }
    var rbig: number = big % 8;
    if (rbig != 0) { return 2; }
    var big_or: number = big | 1;
    if ((big_or - big) != 1) { return 3; }
    var big_and: number = big_or & big;
    if (big_and != big) { return 4; }

    var big_shr: number = big >> 70;
    var p20: number = pow2_number_case98(20);
    if (big_shr != p20) { return 5; }
    var big_shl: number = p20 << 70;
    if (big_shl != big) { return 6; }
    var bitnot_identity: number = (~big) + big;
    if (bitnot_identity != -1) { return 7; }

    var s_big: u64 = big.to_str();
    var parsed_big: number = Number.from_str(slice(s_big, 28));
    if (parsed_big != big) { return 8; }

    var checked_i64: i64 = 0;
    if (big.to_i64_checked(&checked_i64) != 0) { return 9; }
    return 0;
}

// -- bundled from 99_number_bitnot_identity_success.bpp

func pow2_number_case99(exp: u64) -> number {
    var x: number = 1;
    for (var i: u64 = 0; i < exp; i = i + 1) {
        x = x + x;
    }
    return x;
}

func bundle_case__99_number_bitnot_identity_success() -> u64 {
    var big: number = pow2_number_case99(90);
    var qbig: number = big / 8;
    var p87: number = pow2_number_case99(87);
    if (qbig != p87) { return 1; }
    var rbig: number = big % 8;
    if (rbig != 0) { return 2; }
    var big_or: number = big | 1;
    if ((big_or - big) != 1) { return 3; }
    var big_and: number = big_or & big;
    if (big_and != big) { return 4; }
    var big_shr: number = big >> 70;
    var p20: number = pow2_number_case99(20);
    if (big_shr != p20) { return 5; }
    var big_shl: number = p20 << 70;
    if (big_shl != big) { return 6; }
    var bitnot_identity: number = (~big) + big;
    if (bitnot_identity != -1) { return 7; }
    return 0;
}

func main() -> u64 {
    if (bundle_case__93_number_bitwise_big_ssa_success() != 0) { return 1; }
    if (bundle_case__94_number_div_then_bitwise_success() != 0) { return 2; }
    if (bundle_case__96_number_div_preserves_input_success() != 0) { return 3; }
    if (bundle_case__97_number_div_then_bitwise_diagnose_success() != 0) { return 4; }
    if (bundle_case__98_number_post_bitwise_success() != 0) { return 5; }
    if (bundle_case__99_number_bitnot_identity_success() != 0) { return 6; }
    return 0;
}

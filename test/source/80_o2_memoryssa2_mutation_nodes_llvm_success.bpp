// Covers: O2 MemorySSA2 mutation node journal for rewritten uses and killed defs
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.memoryssa2.nodes=mutation-journal-updated
// Expect llvm metadata contains: memssa2_nodes=
// Expect llvm metadata contains: memssa2_node_updates=
// Expect llvm metadata contains: memssa2_verify_errors=0
// Expect exit code: 0

struct O2MemorySSA2NodeBox {
    public value: u64;
    public guard: u64;
}

func o2_memoryssa2_mutation_nodes_probe(x: u64) -> u64 {
    var box: O2MemorySSA2NodeBox = O2MemorySSA2NodeBox{0, 71};
    box.value = x + 1;
    var n: number = Number.from_str(slice("4", 1));
    box.value = x + 5;
    var y: u64 = box.value;
    if (n != 4) { return 1; }
    if (y != x + 5) { return 2; }
    if (box.guard != 71) { return 3; }
    return 0;
}

func main() -> u64 {
    return o2_memoryssa2_mutation_nodes_probe(30);
}

// LLVM Build: true
// Mode: ssa
// Opt: O0,O1
// Expect exit code: 0

import std.vec;

func main() -> u64 {
    var v: *Vec<u32> = (*Vec<u32>)new Vec<u32>(4);
    v.push(10);
    v.push(20);
    v.push(30);
    v.push(40);
    v.set(2, 77);
    if (v.len() != 4) { return 1; }
    if (v.get(0) != 10) { return 2; }
    if (v.get(1) != 20) { return 3; }
    if (v.get(2) != 77) { return 4; }
    if (v.get(3) != 40) { return 5; }
    return 0;
}

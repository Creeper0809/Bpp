// Covers: O2 MemorySSA2 effect, alias, field, readonly, and GC guard metadata
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.memoryssa2.engine=effect-field-sensitive-gc-aware
// Expect llvm metadata contains: bpp.ssa.memoryssa2.nodes=def-use-phi
// Expect llvm metadata contains: bpp.ssa.memoryssa2.alias=stack-heap-arena-global-slice-vec-foreign
// Expect llvm metadata contains: bpp.ssa.memoryssa2.field=layout-offset-size
// Expect llvm metadata contains: bpp.ssa.memoryssa2.call=readonly-forwarding
// Expect llvm metadata contains: bpp.ssa.memoryssa2.gc=barrier-finalizer-pinning
// Expect llvm metadata contains: memssa2_defs=
// Expect llvm metadata contains: memssa2_uses=
// Expect exit code: 0

struct O2MemoryBox {
    public value: u64;
}

func o2_memoryssa2_probe() -> u64 {
    var box: O2MemoryBox = O2MemoryBox{7};
    box.value = box.value + 5;
    var parent_value: u64 = bpp_tag_pack(4096, BPP_TAG_LIFE_OLD, BPP_TAG_OWN_SHARED, BPP_TAG_STORAGE_HEAP, BPP_TAG_BARRIER_CLEAN, BPP_TAG_SHAPE_OBJECT, 0);
    var child_value: u64 = bpp_tag_pack(8192, BPP_TAG_LIFE_YOUNG, BPP_TAG_OWN_SHARED, BPP_TAG_STORAGE_HEAP, BPP_TAG_BARRIER_CLEAN, BPP_TAG_SHAPE_OBJECT, 0);
    bpp_tag_write_barrier_raw(parent_value, child_value);
    if (box.value != 12) { return 1; }
    return 0;
}

func main() -> u64 {
    return o2_memoryssa2_probe();
}

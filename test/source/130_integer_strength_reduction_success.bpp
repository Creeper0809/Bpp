// Covers: SSA integer multiply/divide/mod strength-reduction semantics
// Mode: ssa|nossa
// Opt: O0|O1
// Expect exit code: 0
// LLVM Build: true

func signed_strength_130(x: i64, y: i64) -> u64 {
    if (x * 8 != -264) { return 1; }
    if (8 * x != -264) { return 2; }
    if (x / 8 != -4) { return 3; }
    if (x % 8 != -1) { return 4; }
    if (y / 8 != 4) { return 5; }
    if (y % 8 != 1) { return 6; }
    if (x / 1 != x) { return 7; }
    if (x % 1 != 0) { return 8; }
    return 0;
}

func unsigned_strength_130(x: u64) -> u64 {
    if (x * 16 != 18446744073709551600) { return 11; }
    if (16 * x != 18446744073709551600) { return 12; }
    if (x / 16 != 1152921504606846975) { return 13; }
    if (x % 16 != 15) { return 14; }
    if (x / 1 != x) { return 15; }
    if (x % 1 != 0) { return 16; }
    return 0;
}

func main() -> u64 {
    var signed_rc: u64 = signed_strength_130(-33, 33);
    if (signed_rc != 0) { return signed_rc; }

    var unsigned_rc: u64 = unsigned_strength_130(18446744073709551615);
    if (unsigned_rc != 0) { return unsigned_rc; }

    var z: u64 = 12345;
    if (z * 0 != 0) { return 21; }
    if (0 * z != 0) { return 22; }

    return 0;
}

// Covers: magic-method style override without explicit trait + direct-call sugar lowering
// Expect exit code: 0
// LLVM Build: true

struct PairMagic {
    public a: u64;
    public b: u64;
}

impl PairMagic {
    @[override]
    public func to_str(self: *PairMagic) -> u64 {
        return (u64)1;
    }

    @[override]
    public func hash(self: *PairMagic) -> u64 {
        return self.a + self.b;
    }

    @[override]
    public func eq(self: *PairMagic, rhs: PairMagic) -> u64 {
        if (self.a != rhs.a) { return 0; }
        if (self.b != rhs.b) { return 0; }
        return 1;
    }

    @[override]
    public func cmp(self: *PairMagic, rhs: PairMagic) -> i64 {
        if (self.a < rhs.a) { return -1; }
        if (self.a > rhs.a) { return 1; }
        if (self.b < rhs.b) { return -1; }
        if (self.b > rhs.b) { return 1; }
        return 0;
    }
}

func main() -> u64 {
    var p: PairMagic;
    p.a = 7;
    p.b = 3;

    if (p.to_str() != 1) { return 1; }
    if (to_str(p) != 1) { return 2; }
    if (hash(p) != 10) { return 3; }

    var q: PairMagic;
    q.a = 7;
    q.b = 3;
    if (eq(p, q) == 0) { return 4; }

    q.b = 9;
    if (cmp(p, q) >= 0) { return 5; }
    if (cmp(q, p) <= 0) { return 6; }
    if (p.eq(q) != 0) { return 7; }

    return 0;
}

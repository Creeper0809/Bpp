// Covers: O2 specializer rewrites a monomorphic function-pointer call to a direct call
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.specialize.rewrite=call-ptr-direct-call
// Expect llvm metadata contains: spec_devirt_rewrites=
// Expect exit code: 0

func o2_specialize_call_ptr_target(a: u64, b: u64) -> u64 {
    return a + b;
}

func o2_specialize_call_ptr_probe() -> u64 {
    var got: u64 = (&o2_specialize_call_ptr_target)(40, 2);
    if (got != 42) { return 1; }
    return 0;
}

func main() -> u64 {
    return o2_specialize_call_ptr_probe();
}

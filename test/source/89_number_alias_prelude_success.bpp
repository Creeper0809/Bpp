// Covers: compiler-known prelude number aliases (`number` and `Number`) share the same type family
// Mode: ssa|nossa
// Opt: O0|O1
// Expect exit code: 0

func main() -> u64 {
    var a: number = 41;
    var b: Number = a;
    if (b != 41) { return 1; }

    var c: number = Number.from_i64(5);
    if (c != 5) { return 2; }

    var d: Number = c;
    if (d != 5) { return 3; }

    var e: number = d;
    if (e != 5) { return 4; }

    return 0;
}

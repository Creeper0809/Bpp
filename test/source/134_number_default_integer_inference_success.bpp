// Covers: unannotated integer locals default to number while fixed-width contexts still coerce explicitly
// Mode: ssa|nossa
// Opt: O0|O1
// LLVM Build: true
// Expect exit code: 0

import std.vec;

func takes_u64_134(v: u64) -> u64 {
    return v + 1;
}

func main() -> u64 {
    var a = 41;
    if (a.to_i64_checked_value() != 41) { return 1; }

    var b = a + 1;
    if (b.to_i64_checked_value() != 42) { return 2; }

    var fixed: u64 = 5;
    fixed = fixed + 1;
    if (fixed != 6) { return 3; }
    if (takes_u64_134(7) != 8) { return 4; }

    var vec_ptr = new Vec<u64>(4);
    vec_ptr.push(10);
    vec_ptr.push(20);
    var idx = 1;
    if (vec_ptr.get(idx) != 20) { return 5; }

    var total = 0;
    for (var i = 0; i < 3; i = i + 1) {
        total = total + i;
    }
    if (total.to_i64_checked_value() != 3) { return 6; }

    return 0;
}

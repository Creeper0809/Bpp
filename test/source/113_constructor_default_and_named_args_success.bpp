struct PointEx {
    public x: u64;
    public y: u64;
}

impl PointEx {
    public constructor(x: u64, y: u64 = 5) {
        self.x = x;
        self.y = y;
    }
}

func main() -> u64 {
    var p0: PointEx = PointEx(2);
    var p1: PointEx = PointEx(y: 9, x: 3);

    if (p0.x != 2 || p0.y != 5) { return 1; }
    if (p1.x != 3 || p1.y != 9) { return 2; }
    return 0;
}

    while (i < x) {
        acc += 1;
        i += 1;
    }
    return acc;
}

@[complexity(time="O(n^3)", space="O(1)")]
func heavy_external_cost(n: u64) -> u64 {
    var acc: u64 = 0;
    for (var i: u64 = 0; i < n; i = i + 1) {
        for (var j: u64 = 0; j < n; j = j + 1) {
            for (var k: u64 = 0; k < n; k = k + 1) {
                acc += ((i + j + k) & 1);
            }
        }
    }
    return acc;
}

@[complexity_budget(time="O(1)", space="O(1)")]
@[constraints(n=64)]
@[complexity_debug]
func line_skip_external_cost(n: u64) -> u64 {
    var out: u64 = 0;
    @[complexity_ignore(reason="external helper cost intentionally excluded for this site")]
    out = heavy_external_cost(n);
    return out;
}


const A = 'A';
const NL = '\n';
const TAB = '\t';
const CR = '\r';
const BS = '\\';
const SQ = '\'';

func bundle_case__30_literals_cast_import_suite() -> u64 {
    if (A != 65) { return 1; }
    if (NL != 10) { return 2; }
    if (TAB != 9) { return 3; }
    if (CR != 13) { return 4; }
    if (BS != 92) { return 5; }
    if (SQ != 39) { return 6; }

    var x: u64 = 7;
    var y: f64 = (f64)x;
    if (y != 7.0) { return 7; }
    var y2: f64 = y + 1.25;
    if (y2 != 8.25) { return 8; }
    var z: u64 = (u64)y;
    if (z != x) { return 9; }
    var n: u32 = (u32)y2;
    if (n != 8) { return 10; }

    return 0;
}
// -- end embedded case


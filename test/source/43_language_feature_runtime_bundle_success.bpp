func gcd_u64(a: u64, b: u64) -> u64 {
    var x: u64 = a;
    var y: u64 = b;
    while (y != 0) {
        var t: u64 = x % y;
        x = y;
        y = t;
    }
    return x;
}

func rho_next(x: u64, c: u64, n: u64) -> u64 {
    return ((x * x) + c) % n;
}

@[complexity_budget(time="O(2*n^(1/4))", space="O(1)")]
@[constraints(n=100000000)]
@[time_limit(ms=200, machine="ref_v1")]
@[complexity_debug]
func pollard_rho_once(n: u64, seed: u64, c: u64) -> u64 {
    if ((n & 1) == 0) { return 2; }

    var x: u64 = seed % n;
    if (x == 0) { x = 2; }
    var y: u64 = x;
    var d: u64 = 1;
    var iter: u64 = 0;

    while (d == 1) {
        if (iter >= 200000) { return 0; }
        x = rho_next(x, c, n);
        y = rho_next(y, c, n);
        y = rho_next(y, c, n);

        var diff: u64 = 0;
        if (x >= y) { diff = x - y; }
        else { diff = y - x; }

        d = gcd_u64(diff, n);
        iter += 1;
    }

    if (d == n) { return 0; }
    return d;
}

func pollard_rho_factor(n: u64) -> u64 {
    var c: u64 = 1;
    while (c <= 8) {
        var seed: u64 = c + 1;
        var f: u64 = pollard_rho_once(n, seed, c);
        if (f > 1 && f < n) { return f; }
        c += 1;
    }
    return 0;
}


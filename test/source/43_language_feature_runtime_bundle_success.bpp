}

@[complexity_budget(time="O(16*(max(n,m)+min(n,m)+n)/2)", space="O(1)")]
@[constraints(n=4096, m=2048)]
@[complexity_debug]
func complexity_div_minmax_budget(n: u64, m: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        acc += 1;
        i += 1;
    }
    if (m > 0) {
        acc += m;
    }
    return acc;
}

@[complexity_input(x="k")]
@[complexity_budget(time="O(8*x)", space="O(1)")]
@[constraints(n=256, rel1="0<=k<a<n")]
@[complexity_debug(strict_input=true)]
func relation_chain_input_alias(x: u64) -> u64 {
    var i: u64 = 0;

}

@[complexity_budget(time="O(2*n log log n)", space="O(n)")]
@[complexity_debug]
@[constraints(n=200000)]
@[time_limit(ms=2000, machine="ref_v1")]
func sieve_style_count(n: u64) -> u64 {
    if (n < 2) { return 0; }
    var mark: [200001]u8;
    var i: u64 = 2;
    var cnt: u64 = 0;
    while (i * i <= n) {
        if (mark[i] == 0) {
            var j: u64 = i * i;
            while (j <= n) {
                mark[j] = 1;
                j += i;
            }
        }
        i += 1;
    }
    var k: u64 = 2;
    while (k <= n) {
        if (mark[k] == 0) { cnt += 1; }
        k += 1;
    }
    return cnt;
}


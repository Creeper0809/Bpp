@[complexity_budget(time="O(4*log n)", space="O(1)", mode="high_prob")]
@[constraints(n=1048576)]
@[complexity_debug]
func random_geometric_high_prob(n: u64) -> u64 {
    var x: u64 = 0;
    for (var i: u64 = 1; i < n; i = i << 1) {
        x = x + (rand() & 1);
    }
    return x;
}

@[complexity_budget(time="O(8*(log(n)^2))", space="O(1)")]
@[constraints(n=1048576)]
@[complexity_debug]
func polylog_nested(n: u64) -> u64 {
    var acc: u64 = 0;
    for (var i: u64 = 1; i < n; i = i << 1) {
        for (var j: u64 = 1; j < n; j = j << 1) {
            acc += 1;
        }
    }
    return acc;
}

@[complexity_budget(time="O(1)", space="O(1)")]
@[complexity_debug]
func zero_iter_for_known() -> u64 {

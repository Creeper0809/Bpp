    if (tagged_stack_storage == BPP_TAG_STORAGE_STACK && bpp_tag_ownership_raw((u64)tagged_stack) != BPP_TAG_OWN_STACK) { return 7; }
    if (tagged_stack_storage == BPP_TAG_STORAGE_STACK && bpp_tag_allocator_stack_alloc_count() != 1) { return 8; }

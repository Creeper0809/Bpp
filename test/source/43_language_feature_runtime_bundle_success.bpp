    if (f == 0 || f == 1 || f == n) { return 12; }
    if ((n % f) != 0) { return 13; }
    var q: u64 = n / f;
    if (q <= 1) { return 14; }
    if (q * f != n) { return 15; }

    var cl: u64 = constrained_linear(16, 64);
    if (cl == 0) { return 16; }
    var rh: u64 = rec_halve(1024);
    if (rh != 11) { return 17; }

    var mv4: u64 = multivar_four_symbols(8, 12, 32, 1024);
    if (mv4 == 0) { return 18; }
    var rd: u64 = relation_derived_bound(20);
    if (rd != 10) { return 19; }

    var mv5: u64 = five_var_mixed(8, 12, 16, 1024, 20);
    if (mv5 == 0) { return 20; }
    var tr: u64 = transitive_relation_bound(1000);
    if (tr != 500) { return 21; }
    var eqb: u64 = relation_eq_bound(200);
    if (eqb == 0) { return 33; }

    for (var i: u64 = 0; i < 128; i = i + 1) {
        fib_cache[i] = DP_SENT;
        fib_seen[i] = 0;
        fib_value[i] = 0;
    }
    for (var r: u64 = 0; r < 32; r = r + 1) {
        for (var c: u64 = 0; c < 32; c = c + 1) {
            grid_cache[r][c] = DP_SENT;
        }
    }

    var fm: u64 = fib_memo(20);
    if (fm != 6765) { return 22; }
    var gp: u64 = grid_paths_memo(8, 7);
    if (gp != 6435) { return 23; }

    for (var t: u64 = 0; t < 128; t = t + 1) {
        fib_cache[t] = DP_SENT;
    }
    var ff: u64 = fib_memo_flexible(20);
    if (ff != 6765) { return 24; }

    for (var t2: u64 = 0; t2 < 128; t2 = t2 + 1) {
        fib_seen[t2] = 0;
        fib_value[t2] = 0;
    }
    var fh: u64 = fib_memo_hint(20);
    if (fh != 6765) { return 25; }

    if (fib_memo(20) != 6765) { return 26; }
    if (grid_paths_memo(8, 7) != 6435) { return 27; }
    if (fib_memo_flexible(20) != 6765) { return 28; }
    if (fib_memo_hint(20) != 6765) { return 29; }

    var ci: u64 = caller_interproc(20);
    var cns: u64 = caller_named_shape_probe(20);
    var cmt: u64 = caller__tick(20);
    var rw: u64 = random_walk_like(100);
    var rw_wrap: u64 = random_walk_wrapper_like(100);
    var rw_hp: u64 = random_geometric_high_prob(1024);
    var ov: u64 = caller_overload_probe(20);
    if (ci == 0 && cns == 0 && cmt == 0 && rw == 0 && rw_wrap == 0 && rw_hp == 0 && ov == 0) { return 30; }

    var pl: u64 = polylog_nested(1024);
    if (pl != 100) { return 31; }
    var zi: u64 = zero_iter_for_known();
    if (zi != 0) { return 32; }
    var dm: u64 = complexity_div_minmax_budget(100, 50);
    if (dm != 150) { return 34; }
    var rc: u64 = relation_chain_input_alias(20);
    if (rc != 20) { return 35; }
    var ls: u64 = line_skip_external_cost(4);
    if (ls == 0) { return 36; }

    return 0;
}

// -- bundled from 42_symbolic_annotation_alias_suite.bpp

func symbolic_alias_helper(x: u64) -> u64 {
    return x & 1;
}

@[symbolic_assume(n=64, m=64, rel1="0<=m<=n")]
@[symbolic_expect(expr="O(n*m)", space="O(1)", mode="worst")]
@[symbolic_budget(time="O(n*m)", space="O(1)", mode="worst")]
func symbolic_alias_work(n: u64, m: u64) -> u64 {
    var acc: u64 = 0;
    for (var i: u64 = 0; i < n; i = i + 1) {
        for (var j: u64 = 0; j < m; j = j + 1) {
            acc = acc + 1;
            @[symbolic_ignore(reason="constant helper noise excluded")]
            acc = acc + symbolic_alias_helper(i + j);
        }
    }
    return acc;
}

@[symbolic_ignore(reason="manual model only")]
func symbolic_alias_ignored() -> u64 {
    return 7;
}

func bundle_case__42_symbolic_annotation_alias_suite() -> u64 {
    var v: u64 = symbolic_alias_work(3, 4);
    if (v < 12) { return 1; }
    if (symbolic_alias_ignored() != 7) { return 2; }
    return 0;
}

// -- bundled from 44_number_builtin_type_success.bpp

func pow2_number(exp: u64) -> number {
    var x: number = 1;
    for (var i: u64 = 0; i < exp; i = i + 1) {
        x = x + x;
    }
    return x;
}

func bundle_case__44_number_builtin_type_success() -> u64 {
    var x: number = 40;
    var y: number = -2;
    var z: number = x + y;
    if (z != 38) { return 1; }

    var a: number = x + 5;
    if (a != 45) { return 6; }
    var b: number = 5 + x;
    if (b != 45) { return 7; }
    var c: number = x - 12;
    if (c != 28) { return 8; }
    var e: number = x * 3;
    if (e != 120) { return 9; }
    var e2: number = 3 * x;
    if (e2 != 120) { return 10; }
    var f: number = -3 + x;
    if (f != 37) { return 11; }
    if (f < 37) { return 12; }
    if (f > 37) { return 13; }
    if (f <= 36) { return 14; }
    if (f >= 38) { return 15; }
    if (37 != f) { return 16; }
    if (36 >= f) { return 17; }
    if (38 <= f) { return 18; }

    var q1: number = x / 6;
    if (q1 != 6) { return 19; }
    var r1: number = x % 6;
    if (r1 != 4) { return 20; }
    var q2: number = 120 / x;
    if (q2 != 3) { return 21; }
    var r2: number = 121 % x;
    if (r2 != 1) { return 22; }
    var bw_and: number = 13 & 6;
    if (bw_and != 4) { return 26; }
    var bw_or: number = 13 | 6;
    if (bw_or != 15) { return 27; }
    var bw_xor: number = 13 ^ 6;
    if (bw_xor != 11) { return 28; }
    var shl1: number = 5 << 3;
    if (shl1 != 40) { return 29; }
    var shr1: number = 40 >> 3;
    if (shr1 != 5) { return 30; }
    var shr_neg: number = -5 >> 1;
    if (shr_neg != -3) { return 31; }
    var not5: number = ~5;
    if (not5 != -6) { return 32; }

    var si: i64 = -77;
    var ui: u64 = 123;
    var from_si: number = si;
    var from_ui: number = ui;
    if (from_si != -77) { return 33; }
    if (from_ui != 123) { return 34; }
    var mix1: number = from_si + si;
    if (mix1 != -154) { return 35; }
    var mix2: number = from_ui + ui;
    if (mix2 != 246) { return 36; }
    var assigned: number = 0;
    assigned = si;
    if (assigned != -77) { return 46; }
    assigned = ui;
    if (assigned != 123) { return 47; }

    // 2^90 exceeds 64-bit range.
    var big: number = pow2_number(90);
    var expected: number = pow2_number(90);
    if (big != expected) { return 2; }

    var p89a: number = pow2_number(89);
    var reduced: number = big - p89a;
    var p89b: number = pow2_number(89);
    if (reduced != p89b) { return 3; }

    var qbig: number = big / 8;
    var p87: number = pow2_number(87);
    if (qbig != p87) { return 23; }
    var rbig: number = big % 8;
    if (rbig != 0) { return 24; }
    var mneg: number = -10;
    var neg_mod: number = mneg % 6;
    if (neg_mod != -4) { return 25; }

    var big_or: number = big | 1;
    if ((big_or - big) != 1) { return 37; }
    var big_and: number = big_or & big;
    if (big_and != big) { return 38; }
    var big_shr: number = big >> 70;
    var p20: number = pow2_number(20);
    if (big_shr != p20) { return 39; }
    var big_shl: number = p20 << 70;
    if (big_shl != big) { return 40; }
    var zero_for_shift: number = 0;
    var neg_big: number = zero_for_shift - big;
    var neg_big_shr: number = neg_big >> 70;
    var neg_p20: number = zero_for_shift - p20;
    if (neg_big_shr != neg_p20) { return 48; }
    var neg_big_rem: number = neg_big - 1;
    var neg_big_rem_shr: number = neg_big_rem >> 70;
    if (neg_big_rem_shr != (neg_p20 - 1)) { return 49; }
    var bitnot_identity: number = (~big) + big;
    if (bitnot_identity != -1) { return 41; }

    var s_big: u64 = big.to_str();
    var parsed_big: number = Number.from_str(slice(s_big, 28));
    if (parsed_big != big) { return 42; }

    var checked_i64: i64 = 0;
    if (x.to_i64_checked(&checked_i64) == 0) { return 43; }
    if (checked_i64 != 40) { return 44; }
    if (big.to_i64_checked(&checked_i64) != 0) { return 45; }

    var zero: number = 0;
    var neg: number = zero - big;
    if (neg >= 0) { return 4; }

    var five: number = 5;
    var plus5: number = big + five;
    var minus5: number = plus5 - five;
    if (minus5 != big) { return 5; }
    return 0;
}

// -- bundled from 46_mod_number_type_success.bpp


func check_modnumber_type_sugar() -> u64 {
    var a: modnumber<11> = -3;
    if (a.value != 8) { return 100; }
    if (a.modulus != 11) { return 101; }

    var b: modnumber<11> = 5;
    if (b.value != 5) { return 102; }
    if (b.modulus != 11) { return 103; }

    var c: modnumber<10> = 23;
    if (c.value != 3) { return 104; }
    if (c.modulus != 10) { return 105; }

    return 0;
}

func check_basic_new() -> u64 {
    var a: ModNumber = mod_number_new(-3, 11);
    if (a.value != 8) { return 1; }
    if (a.modulus != 11) { return 2; }
    return 0;
}

func check_add_sub_mul() -> u64 {
    var a: ModNumber = mod_number_new(-3, 11);
    var b: ModNumber = mod_number_new(20, 11);
    var c: ModNumber = a + b; // 8 + 9 = 17 -> 6
    if (c.value != 6) { return 3; }
    if (c.modulus != 11) { return 4; }

    var d: ModNumber = c - 19; // 6 - 8 = -2 -> 9
    if (d.value != 9) { return 5; }
    var e: ModNumber = d * 7; // 9 * 7 = 63 -> 8
    if (e.value != 8) { return 6; }
    return 0;
}

func check_setmod() -> u64 {
    var e: ModNumber = mod_number_new(8, 11);
    if (mod_number_setmod_ptr(&e, 7) == 0) { return 7; } // 8 mod 7 -> 1
    if (e.modulus != 7) { return 8; }
    if (e.value != 1) { return 9; }
    return 0;
}

func check_div_inv_pow() -> u64 {
    var x: ModNumber = mod_number_new(7, 13);
    var y: ModNumber = mod_number_new(5, 13);
    var z: ModNumber = x / y; // 5^-1 mod 13 = 8, 7*8 = 56 -> 4
    if (z.value != 4) { return 10; }
    if (z.modulus != 13) { return 11; }

    var inv: ModNumber = mod_number_zero(13);
    if (y.inverse_checked(&inv) == 0) { return 12; }
    if (inv.value != 8) { return 13; }
    if (inv.modulus != 13) { return 14; }

    var p: ModNumber = x.pow((u64)5); // 7^5 mod 13 = 11
    if (p.value != 11) { return 15; }
    return 0;
}

func check_non_invertible() -> u64 {
    var x: ModNumber = mod_number_new(7, 13);
    var noinv: ModNumber = mod_number_new(2, 10);
    var bad: ModNumber = x / noinv; // inverse(2 mod 13) exists if coerced -> using lhs modulus
    if (bad.value != 10) { return 16; } // 2^-1 mod 13 = 7, 7*7 = 49 -> 10

    var lhs10: ModNumber = mod_number_new(4, 10);
    var rhs10: ModNumber = mod_number_new(2, 10);
    var no_div: ModNumber = lhs10 / rhs10; // inverse does not exist in mod 10
    if (no_div.value != 0) { return 17; }
    if (no_div.modulus != 10) { return 18; }
    return 0;
}

func check_eq_and_mix() -> u64 {
    var eq1: ModNumber = mod_number_new(20, 13);
    if (eq1.eq(mod_number_new(7, 13)) == 0) { return 19; }
    if (eq1.eq(mod_number_new(7, 11)) != 0) { return 20; }

    var x: ModNumber = mod_number_new(7, 13);
    var mix: ModNumber = x + 100; // 7 + 9 = 16 -> 3
    if (mix.value != 3) { return 21; }
    return 0;
}

func bundle_case__46_mod_number_type_success() -> u64 {
    var rc: u64 = check_modnumber_type_sugar();
    if (rc != 0) { return rc; }

    rc = check_basic_new();
    if (rc != 0) { return rc; }
    rc = check_add_sub_mul();
    if (rc != 0) { return rc; }
    rc = check_setmod();
    if (rc != 0) { return rc; }
    rc = check_div_inv_pow();
    if (rc != 0) { return rc; }
    rc = check_non_invertible();
    if (rc != 0) { return rc; }
    rc = check_eq_and_mix();
    if (rc != 0) { return rc; }
    return 0;
}


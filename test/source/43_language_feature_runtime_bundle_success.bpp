    if (a1 == 0) { return 3; }
    var b1: u64 = fib_style(10);
    if (b1 != 89) { return 4; }
    var c1: u64 = sieve_style_count(1000);
    if (c1 != 168) { return 5; }
    var d1: u64 = graph_linear_scan(1000, 2000);
    if (d1 == 0) { return 6; }

    var g: u64 = geometric_count(1024);
    if (g != 10) { return 7; }

@[complexity(time="O(n log n)", space="O(n)")]
@[complexity_input(n="len(arr)", m="len(edges)")]
@[complexity_budget(time="O(n^2)", space="O(n)")]
@[complexity_debug]
@[constraints(n=200000, m=300000, t=10)]
@[time_limit(ms=2000, machine="ref_v1")]
func score_complexity_annotations(arr_n: u64, edges_m: u64) -> u64 {
    var i: u64 = 1;
    var acc: u64 = 0;
    while (i < arr_n) {
        acc = acc + i;
        i = i << 1;
    }
    if (edges_m > 0) {
        acc = acc + edges_m;
    }
    return acc;
}


@[complexity(time="O(n^3)", space="O(1)")]
@[constraints(n=64)]
func other__named_shape_target(k: u64, n: u64 = 1) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < k) {
        var j: u64 = 0;
        while (j < n) {
            var t: u64 = 0;
            while (t < n) {
                acc += ((i + j + t) & 1);
                t += 1;
            }
            j += 1;
        }
        i += 1;
    }
    return acc;
}

@[complexity_budget(time="O(3*n^2)", space="O(1)")]
@[constraints(n=512)]
@[complexity_debug]
func caller_named_shape_probe(n: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        acc += named_shape_target(n: n);
        i += 1;
    }
    return acc;
}

struct ComplexityProbeWorker {
    public seed: u64;
}

impl ComplexityProbeWorker {
    @[complexity(time="O(n)", space="O(1)")]
    public func tick(self: *ComplexityProbeWorker, n: u64) -> u64 {
        var i: u64 = 0;
        var acc: u64 = self.seed;
        while (i < n) {
            acc += (i & 1);
            i += 1;
        }
        return acc;
    }
}

@[constraints(n=256)]
@[complexity_debug]
func caller__tick(n: u64) -> u64 {
    var worker: ComplexityProbeWorker = ComplexityProbeWorker { 1 };
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        // Ensure method call remains an external summary candidate.
        acc += worker.tick(n);
        i += 1;
    }
    return acc;
}

@[complexity_budget(time="O(n^2)", space="O(1)")]
@[constraints(n=512)]
@[complexity_debug]
func caller_interproc(n: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        acc += helper_linear(n);
        i += 1;

// -- bundled from 87_match_keyword.bpp

func classify(v: i64) -> i64 {
    match (v) {
        case 1: return 10;
        case 2: return 20;
        case 3: return 30;
        default: return 0;
    }
}

func bundle_case__87_match_keyword() -> i64 {
    if (classify(1) != 10) { return 1; }
    if (classify(2) != 20) { return 2; }
    if (classify(3) != 30) { return 3; }
    if (classify(99) != 0) { return 4; }

    // match with break
    var result: i64 = 0;
    var x: i64 = 2;
    match (x) {
        case 1:
            result = 100;
            break;
        case 2:
            result = 200;
            break;
        default:
            result = 999;
            break;
    }
    if (result != 200) { return 10; }

    return 0;
}


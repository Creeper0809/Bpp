@[complexity(time="O(n^3)", space="O(1)")]
@[complexity_budget(time="O(2*n^3)", space="O(1)")]
@[constraints(n=40)]
@[time_limit(ms=2000, machine="ref_v1")]
func floyd_style_relax(n: u64) -> u64 {
    var acc: u64 = 0;
    var k: u64 = 0;
    while (k < n) {
        var i: u64 = 0;
        while (i < n) {
            var j: u64 = 0;
            while (j < n) {
                acc = acc + ((i + j + k) & 3);
                j = j + 1;
            }
            i = i + 1;
        }
        k = k + 1;
    }
    return acc;
}

@[complexity(time="O(2^n)", space="O(n)")]
@[complexity_budget(time="O(2^n)", space="O(n)")]

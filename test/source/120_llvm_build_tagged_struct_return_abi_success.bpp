// LLVM Build: true
// LLVM Only: true
// Covers: LLVM ABI tagged pointer metadata carried through struct return
// Expect exit code: 0

packed struct TagBits120 {
    public kind: u16;
    public flags: u8;
}

struct TaggedBox120 {
    public ptr: *tagged(TagBits120) u8;
    public code: u64;
    public total: u64;
}

func make_tagged_box_120(base: *u8, seed: u64) -> TaggedBox120 {
    var p: *tagged(TagBits120) u8 = (*tagged(TagBits120) u8)base;
    p.kind = (u16)(seed + 5);
    p.flags = (u8)(seed & 7);

    var out: TaggedBox120;
    out.ptr = p;
    out.code = seed * 10;
    out.total = (u64)p.kind + (u64)p.flags + out.code;
    return out;
}

func retag_box_120(box: TaggedBox120, add: u64) -> TaggedBox120 {
    var p: *tagged(TagBits120) u8 = box.ptr;
    p.kind = (u16)((u64)p.kind + add);
    p.flags = (u8)((u64)p.flags ^ (add & 7));
    box.ptr = p;
    box.code = box.code + add * 3;
    box.total = (u64)p.kind + (u64)p.flags + box.code;
    return box;
}

func main() -> u64 {
    var storage: [16]u8;
    var box: TaggedBox120 = make_tagged_box_120(&storage[0], 9);
    if (box.ptr.kind != 14) { return 1; }
    if (box.ptr.flags != 1) { return 2; }
    if (box.total != 105) { return 3; }

    var next: TaggedBox120 = retag_box_120(box, 6);
    if (next.ptr.kind != 20) { return 4; }
    if (next.ptr.flags != 7) { return 5; }
    if (next.total != 135) { return 6; }
    if (box.ptr.kind != 14) { return 7; }
    if (box.ptr.flags != 1) { return 8; }

    var acc: u64 = 0;
    for (var i: u64 = 0; i < 5; i = i + 1) {
        var item: TaggedBox120 = make_tagged_box_120(&storage[i], i + 1);
        item = retag_box_120(item, i);
        acc = acc + item.total;
    }
    if (acc != 243) { return 9; }
    return 0;
}

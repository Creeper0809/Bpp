// Covers: buffered numeric printers preserve ordering, and raw emit/emitln flush pending text
// Mode: ssa|nossa
// Opt: O0|O1
// Expect exit code: 0
// Expect stdout: A42B\nmin=-9223372036854775808 done\n

func main() -> u64 {
    print("A", 1);
    print_u64(42);
    emit("B");
    emit("\n");

    var min_i64: i64 = (i64)0 - (i64)9223372036854775807 - (i64)1;
    print("min=", 4);
    print_i64(min_i64);
    emitln(" done");
    return 0;
}

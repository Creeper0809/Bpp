// LLVM Build: true

struct PairLLVM107 {
    public a: u64;
    public b: u64;
}

@[feature]
func make_pair_107(base: u64) -> PairLLVM107 {
    return PairLLVM107{base, base + 1};
}

@[feature]
func sum_pair_107(p: PairLLVM107) -> u64 {
    return p.a + p.b;
}

@[entry]
func runtime_entry() -> u64 {
    var p: PairLLVM107 = make_pair_107(10);
    return sum_pair_107(p) - 21;
}

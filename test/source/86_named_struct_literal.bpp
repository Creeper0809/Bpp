// Covers: named struct literal fields
// Expect exit code: 0
// LLVM Build: true

struct Point {
    public x: i64;
    public y: i64;
}

struct Rect {
    public x: i64;
    public y: i64;
    public w: i64;
    public h: i64;
}

func main(argc: i64, argv: *u64) -> i64 {
    // Named struct literal (different order than declaration)
    var p1: Point = Point{y: 20, x: 10};
    if (p1.x != 10) { return 1; }
    if (p1.y != 20) { return 2; }

    // Named struct literal (same order as declaration)
    var p2: Point = Point{x: 30, y: 40};
    if (p2.x != 30) { return 3; }
    if (p2.y != 40) { return 4; }

    // Positional struct literal still works
    var p3: Point = Point{50, 60};
    if (p3.x != 50) { return 5; }
    if (p3.y != 60) { return 6; }

    // Named struct literal with more fields
    var r1: Rect = Rect{h: 400, w: 300, y: 200, x: 100};
    if (r1.x != 100) { return 10; }
    if (r1.y != 200) { return 11; }
    if (r1.w != 300) { return 12; }
    if (r1.h != 400) { return 13; }

    // new with named fields
    var p4: *Point = new Point{y: 80, x: 70};
    if (p4.x != 70) { return 20; }
    if (p4.y != 80) { return 21; }
    delete p4;

    return 0;
}

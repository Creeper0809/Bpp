@[complexity(time="O(n)", space="O(n)")]
func deco_space_linear_surface_ok_94(next: u64, n: u64) -> u64 {
    var i: u64 = 0;
    while (i < n) {
        var p: u64 = heap_alloc(8);
        if (p == 0) { return next(n); }
        i = i + 1;
    }
    return next(n);
}

@[deco_space_linear_surface_ok_94]

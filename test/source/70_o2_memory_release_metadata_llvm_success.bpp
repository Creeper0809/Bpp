// Covers: O2 compile-time memory limit and release-grade optimization contract metadata
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.memory_limit.engine=rss-arena-budget
// Expect llvm metadata contains: bpp.ssa.memory_limit.profile=selfhost-rss-arena-highwater
// Expect llvm metadata contains: bpp.ssa.memory_limit.fallback=oom-budget-conservative
// Expect llvm metadata contains: bpp.ssa.memory_limit.report=pass-attribution
// Expect llvm metadata contains: bpp.ssa.release_contract.engine=spec-ci-benchmark-checklist
// Expect llvm metadata contains: bpp.ssa.release_contract.levels=o1-o2-o3-os
// Expect llvm metadata contains: bpp.ssa.release_contract.done=metadata-conservative-production
// Expect llvm metadata contains: bpp.ssa.release_contract.baseline=number-vec-call-alloc-loop-compiletime
// Expect llvm metadata contains: memory_limit=
// Expect llvm metadata contains: release_contract=
// Expect exit code: 0

func o2_memory_release_probe() -> u64 {
    var acc: u64 = 0;
    for (var i: u64 = 0; i < 12; i = i + 1) {
        acc = acc + (i * 2);
    }
    if (acc != 132) { return 1; }
    return 0;
}

func main() -> u64 {
    return o2_memory_release_probe();
}

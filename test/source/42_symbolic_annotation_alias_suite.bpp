// Expect exit code: 0

func symbolic_alias_helper(x: u64) -> u64 {
    return x & 1;
}

@[symbolic_assume(n=64, m=64, rel1="0<=m<=n")]
@[symbolic_expect(expr="O(n*m)", space="O(1)", mode="worst")]
@[symbolic_budget(time="O(n*m)", space="O(1)", mode="worst")]
func symbolic_alias_work(n: u64, m: u64) -> u64 {
    var acc: u64 = 0;
    for (var i: u64 = 0; i < n; i = i + 1) {
        for (var j: u64 = 0; j < m; j = j + 1) {
            acc = acc + 1;
            @[symbolic_ignore(reason="constant helper noise excluded")]
            acc = acc + symbolic_alias_helper(i + j);
        }
    }
    return acc;
}

@[symbolic_ignore(reason="manual model only")]
func symbolic_alias_ignored() -> u64 {
    return 7;
}

func main() -> u64 {
    var v: u64 = symbolic_alias_work(3, 4);
    if (v < 12) { return 1; }
    if (symbolic_alias_ignored() != 7) { return 2; }
    return 0;
}

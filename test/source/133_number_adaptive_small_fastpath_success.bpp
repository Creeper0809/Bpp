// Covers: adaptive Number small-path arithmetic, fallback at small range edges, and small comparisons
// Mode: ssa|nossa
// Opt: O0|O1
// LLVM Build: true
// Expect exit code: 0

func expect_number_i64_133(v: number, expected: i64, code: u64) -> u64 {
    if (v.to_i64_checked_value() != expected) { return code; }
    return 0;
}

func main() -> u64 {
    var zero: number = 0;
    var one: number = 1;
    var neg_one: number = zero - one;

    var max_small: number = 4611686018427387903;
    var min_small: number = zero - 4611686018427387904;
    var spill_pos: number = max_small + one;
    var spill_neg: number = min_small - one;

    if (spill_pos <= max_small) { return 1; }
    if (spill_neg >= min_small) { return 2; }
    if (spill_pos - one != max_small) { return 3; }
    if (spill_neg + one != min_small) { return 4; }
    if (min_small / neg_one != spill_pos) { return 5; }
    if (min_small % neg_one != zero) { return 6; }

    var a: number = 123456789;
    var b: number = zero - 97;
    var c: number = ((a + b) * 33) / 11;
    var rc: u64 = expect_number_i64_133(c, 370370076, 7);
    if (rc != 0) { return rc; }

    if ((a & 255) != 21) { return 8; }
    if ((b | 7) != -97) { return 9; }
    if ((b ^ neg_one) != 96) { return 10; }
    if (a <= b) { return 11; }
    if (b >= a) { return 12; }
    if (a != 123456789) {
        return 13;
    }

    return 0;
}

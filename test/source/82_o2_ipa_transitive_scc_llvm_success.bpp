// Covers: O2 IPA detects a transitive recursive component, not only self/2-node recursion
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.ipa.scc=transitive-recursive-component
// Expect llvm metadata contains: ipa_recursive=
// Expect exit code: 0

func o2_ipa_scc_a(n: u64) -> u64 {
    if (n == 0) { return 0; }
    return o2_ipa_scc_b(n - 1);
}

func o2_ipa_scc_b(n: u64) -> u64 {
    if (n == 0) { return 0; }
    return o2_ipa_scc_c(n - 1);
}

func o2_ipa_scc_c(n: u64) -> u64 {
    if (n == 0) { return 0; }
    return o2_ipa_scc_a(n - 1);
}

func main() -> u64 {
    return o2_ipa_scc_a(3);
}

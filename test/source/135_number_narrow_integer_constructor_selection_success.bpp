// Covers: number boxing selects narrow integer constructors when a value range or fixed-width type proves it
// Mode: ssa|nossa
// Opt: O0|O1
// LLVM Build: true
// Expect exit code: 0

func expect_u8_135(v: number, expected: u8, code: u64) -> u64 {
    if (v.to_u8_checked_value() != expected) { return code; }
    return 0;
}

func expect_u16_135(v: number, expected: u16, code: u64) -> u64 {
    if (v.to_u16_checked_value() != expected) { return code; }
    return 0;
}

func expect_u32_135(v: number, expected: u32, code: u64) -> u64 {
    if (v.to_u32_checked_value() != expected) { return code; }
    return 0;
}

func expect_i8_135(v: number, expected: i8, code: u64) -> u64 {
    if (v.to_i8_checked_value() != expected) { return code; }
    return 0;
}

func expect_i16_135(v: number, expected: i16, code: u64) -> u64 {
    if (v.to_i16_checked_value() != expected) { return code; }
    return 0;
}

func expect_i32_135(v: number, expected: i32, code: u64) -> u64 {
    if (v.to_i32_checked_value() != expected) { return code; }
    return 0;
}

func main() -> u64 {
    var lit_u8 = 255;
    var rc: u64 = expect_u8_135(lit_u8, 255, 1);
    if (rc != 0) { return rc; }

    var lit_u16 = 65535;
    rc = expect_u16_135(lit_u16, 65535, 2);
    if (rc != 0) { return rc; }

    var lit_u32 = 4294967295;
    rc = expect_u32_135(lit_u32, 4294967295, 3);
    if (rc != 0) { return rc; }

    var lit_i8 = -128;
    rc = expect_i8_135(lit_i8, -128, 4);
    if (rc != 0) { return rc; }

    var lit_i16 = -32768;
    rc = expect_i16_135(lit_i16, -32768, 5);
    if (rc != 0) { return rc; }

    var lit_i32 = -2147483648;
    rc = expect_i32_135(lit_i32, -2147483648, 6);
    if (rc != 0) { return rc; }

    var fixed_u8: u8 = 42;
    var n_u8: number = fixed_u8;
    rc = expect_u8_135(n_u8, 42, 7);
    if (rc != 0) { return rc; }

    var fixed_u16: u16 = 513;
    var n_u16: number = fixed_u16;
    rc = expect_u16_135(n_u16, 513, 8);
    if (rc != 0) { return rc; }

    var fixed_i16: i16 = -1234;
    var n_i16: number = fixed_i16;
    rc = expect_i16_135(n_i16, -1234, 9);
    if (rc != 0) { return rc; }

    var fixed_i32: i32 = -123456789;
    var n_i32: number = fixed_i32;
    rc = expect_i32_135(n_i32, -123456789, 10);
    if (rc != 0) { return rc; }

    var direct: number = Number.from_u16(1024);
    rc = expect_u16_135(direct, 1024, 11);
    if (rc != 0) { return rc; }

    var sum = lit_u8 + 1;
    rc = expect_u16_135(sum, 256, 12);
    if (rc != 0) { return rc; }

    return 0;
}

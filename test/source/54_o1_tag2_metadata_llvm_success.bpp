// Covers: O1 tag2 block/phi propagation, metadata verification, MemorySSA alias bridge, and shape/profile fast-path metadata
// Mode: ssa
// Opt: O1
// Compiler args: -O1
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.tag2.state=block-phi-propagated
// Expect llvm metadata contains: bpp.ssa.tag2.alias=memoryssa-noalias
// Expect llvm metadata contains: bpp.ssa.tag2.lifecycle=barrier-refcount-elided
// Expect llvm metadata contains: bpp.ssa.tag2.shape=container-fastpath-selected
// Expect llvm metadata contains: bpp.ssa.tag2.profile=hot-path-specialized
// Expect llvm metadata contains: bpp.ssa.tag2.verifier=call-metadata-checked
// Expect llvm metadata contains: bpp.ssa.tag2.invalidate=call-memory-effect-guard
// Expect llvm metadata contains: bpp.ssa.tag2.loop=slice-vector-loop-specialization
// Expect exit code: 0

func o1_tag2_phi_probe(flag: u64) -> u64 {
    var hot: u64 = bpp_profile_hot_from_threshold(64, 32);
    var a: u64 = bpp_tag_pack(4096, BPP_TAG_LIFE_YOUNG, BPP_TAG_OWN_UNIQUE, BPP_TAG_STORAGE_HEAP, BPP_TAG_BARRIER_CLEAN, BPP_TAG_SHAPE_U64, 1);
    var b: u64 = bpp_tag_repack_shape_profiled(a, BPP_TAG_SHAPE_U64, 1);
    var chosen: u64 = 0;
    if (flag != 0) {
        chosen = a;
    } else {
        chosen = b;
    }
    if (bpp_tag_shape_raw(chosen) != BPP_TAG_SHAPE_U64) { return 1; }
    if (bpp_tag_profiled_raw(chosen) != 1) { return 2; }
    if (bpp_fast_path_for_shape_len(BPP_TAG_SHAPE_U64, hot, bpp_tag_profiled_raw(chosen), sizeof(u64), 8) != BPP_FAST_PATH_VECTOR) { return 3; }
    return 0;
}

func main() -> u64 {
    if (o1_tag2_phi_probe(1) != 0) { return 1; }
    if (o1_tag2_phi_probe(0) != 0) { return 2; }
    return 0;
}

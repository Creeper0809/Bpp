// Covers: SSA property getter/setter contract preservation
// Mode: ssa
// Expect exit code: 0

struct PropertySSA92 {
    property(setter=set_value_92, getter=get_value_92)
    public value: u64;
}

func set_value_92(self: *PropertySSA92, val: u64) {
    self.$value = val + 1;
}

func get_value_92(self: *PropertySSA92) -> u64 {
    return self.$value + 2;
}

func main() -> u64 {
    var obj: PropertySSA92 = PropertySSA92 { 0 };
    obj.value = 7;
    if (obj.$value != 8) { return 1; }
    if (obj.value != 10) { return 2; }
    return 0;
}

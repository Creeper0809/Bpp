// Covers: single-arg print/println parse sugar + builtin/global to_str lowering across primitives/std types
// Mode: ssa|nossa
// Opt: O0|O1
// Expect exit code: 0
// Expect stdout: XY\ntrue\nfalse\n7\n-12\n9000000000000\n1.25\n-2\nhello\n0x0000000000000000\nnull\nslice\n<array len=3>\n<struct>\nSome(<struct>)\nErr(bad)\nVec[1, 2]\n1234567890123\n8 (mod 11)\n<func>\n

import std.option;
import std.result;
import std.vec;
import std.mod_number;

struct Plain {
    public x: u64;
}

func sample_value() -> u64 {
    return 42;
}

func main() -> u64 {
    print("XY", 2);
    print_nl();

    println(true);
    println(false);

    var small_u8: u8 = 7;
    println(small_u8);

    var neg_i32: i32 = -12;
    println(neg_i32);

    var big_u64: u64 = 9000000000000;
    println(big_u64);

    println(1.25);
    var neg_f64: f64 = -2.0;
    println(neg_f64);
    println("hello");

    var null_ptr: *u64 = null;
    println(null_ptr);
    println(null);

    var raw_bytes: []u8 = slice("slice", 5);
    println(raw_bytes);

    var arr: [3]u64;
    arr[0] = 1;
    arr[1] = 2;
    arr[2] = 3;
    println(arr);

    var plain: Plain;
    plain.x = 99;
    println(plain);

    var opt_plain: Option<Plain> = Option_some<Plain>(plain);
    println(opt_plain);

    var err_res: Result<u64, *u8> = Result_err<u64, *u8>("bad");
    println(err_res);

    var vec_ptr: *Vec<u64> = (*Vec<u64>)new Vec<u64>(2);
    vec_ptr.push(1);
    vec_ptr.push(2);
    println(vec_ptr);

    var big_number: number = 1234567890123;
    println(big_number);

    var mod: ModNumber = mod_number_new(-3, 11);
    println(mod);

    println(sample_value);
    return 0;
}

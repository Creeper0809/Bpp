// Covers: hex, binary, octal integer literals and underscore separators
// Expect exit code: 0

func main(argc: i64, argv: *u64) -> i64 {
    // Hex literals
    var h1: u64 = 0xFF;
    if (h1 != 255) { return 1; }

    var h2: u64 = 0x0A;
    if (h2 != 10) { return 2; }

    var h3: u64 = 0xDEAD;
    if (h3 != 57005) { return 3; }

    // Binary literals
    var b1: u64 = 0b1010;
    if (b1 != 10) { return 10; }

    var b2: u64 = 0b11111111;
    if (b2 != 255) { return 11; }

    var b3: u64 = 0b0;
    if (b3 != 0) { return 12; }

    // Octal literals
    var o1: u64 = 0o77;
    if (o1 != 63) { return 20; }

    var o2: u64 = 0o10;
    if (o2 != 8) { return 21; }

    var o3: u64 = 0o777;
    if (o3 != 511) { return 22; }

    // Underscore separators in decimal
    var d1: u64 = 1_000_000;
    if (d1 != 1000000) { return 30; }

    // Underscore separators in hex
    var h4: u64 = 0xFF_FF;
    if (h4 != 65535) { return 31; }

    // Underscore separators in binary
    var b4: u64 = 0b1111_0000;
    if (b4 != 240) { return 32; }

    // Zero literal
    var z: u64 = 0;
    if (z != 0) { return 40; }

    return 0;
}

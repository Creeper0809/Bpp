// Expect exit code: 0
// LLVM Build: true

struct NumOp38 {
    public v: i64;
}

impl NumOp38 {
    public func operator +(self: *NumOp38, rhs: NumOp38) -> i64 {
        return self.v + rhs.v;
    }

    public func operator -(self: *NumOp38, rhs: NumOp38) -> i64 {
        return self.v - rhs.v;
    }

    public func operator -(self: *NumOp38) -> i64 {
        return 0 - self.v;
    }

    public func operator <<(self: *NumOp38, bits: u64) -> i64 {
        return self.v << bits;
    }
}

struct FlagOp38 {
    public value: u64;
}

impl FlagOp38 {
    public func operator !(self: *FlagOp38) -> u64 {
        if (self.value == 0) { return 1; }
        return 0;
    }

    public func operator ~(self: *FlagOp38) -> u64 {
        return ~self.value;
    }
}

struct BufferOp38 {
    public data: [4]u64;
}

impl BufferOp38 {
    public func operator [](self: *BufferOp38, idx: u64) -> u64 {
        return self.data[idx];
    }
}

func main() -> u64 {
    var a: NumOp38 = NumOp38 { 7 };
    var b: NumOp38 = NumOp38 { 4 };

    if (a + b != 11) { return 1; }
    if (a - b != 3) { return 2; }
    if (-b != -4) { return 3; }
    if ((b << 3) != 32) { return 4; }

    var fl0: FlagOp38 = FlagOp38 { 0 };
    var fl1: FlagOp38 = FlagOp38 { 7 };
    if (!fl0 != 1) { return 5; }
    if (!fl1 != 0) { return 6; }
    if (~fl1 != ~7) { return 7; }

    var buf: BufferOp38;
    buf.data[0] = 10;
    buf.data[1] = 20;
    buf.data[2] = 30;
    buf.data[3] = 40;
    if (buf[2] != 30) { return 8; }
    if (buf[0] + buf[3] != 50) { return 9; }

    return 0;
}

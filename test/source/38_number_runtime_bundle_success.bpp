// -- bundled from test/source/137_number_real_complex_success.bpp

func expect_scaled_f64_137(v: number, scale: f64, expected: i64, code: u64) -> u64 {
    var scaled: f64 = v.to_f64_lossy() * scale;
    var got: i64 = (i64)scaled;
    if (got != expected) { return code; }
    return 0;
}

func expect_i64_137(v: number, expected: i64, code: u64) -> u64 {
    if (v.to_i64_checked_value() != expected) { return code; }
    return 0;
}

func bundle_case__137_number_real_complex_success() -> u64 {
    var a: number = 1.5;
    var b: number = 2.25;
    var c: number = a + b;
    var rc: u64 = expect_scaled_f64_137(c, 100.0, 375, 1);
    if (rc != 0) { return rc; }

    var d: number = c * 2.0;
    rc = expect_scaled_f64_137(d, 100.0, 750, 2);
    if (rc != 0) { return rc; }

    var e: number = d / 2.5;
    rc = expect_scaled_f64_137(e, 100.0, 300, 3);
    if (rc != 0) { return rc; }

    var z: number = Number.from_complex(3, 4);
    var w: number = Number.from_complex(Number.from_i64(1), Number.from_i64(2));

    var s: number = z + w;
    var sr: number = s.real_part();
    var si: number = s.imag_part();
    rc = expect_i64_137(sr, 4, 4);
    if (rc != 0) { return rc; }
    rc = expect_i64_137(si, 6, 5);
    if (rc != 0) { return rc; }

    var p: number = z * w;
    var pr: number = p.real_part();
    var pi: number = p.imag_part();
    rc = expect_i64_137(pr, -5, 6);
    if (rc != 0) { return rc; }
    rc = expect_i64_137(pi, 10, 7);
    if (rc != 0) { return rc; }

    var q: number = p / w;
    var qr: number = q.real_part();
    var qi: number = q.imag_part();
    rc = expect_scaled_f64_137(qr, 100.0, 300, 8);
    if (rc != 0) { return rc; }
    rc = expect_scaled_f64_137(qi, 100.0, 400, 9);
    if (rc != 0) { return rc; }

    return 0;
}


// Bundled runtime test.
// Covers: number integer, bigint, real, complex, proof-slice, and container-sum runtime tests
// Mode: ssa|nossa
// Opt: O0|O1
// LLVM Build: true
// Expect exit code: 0

import std.vec;

// -- bundled from test/source/129_number_karatsuba_multiply_success.bpp

func bundle_case__129_number_karatsuba_multiply_success() -> u64 {
    var one: number = 1;
    var zero: number = 0;
    var p900: number = one << 900;
    var p870: number = one << 870;
    var p1770: number = one << 1770;

    var a: number = p900 + 1;
    var b: number = p870 + 3;
    var prod: number = a * b;
    var expected: number = p1770 + p900 + p900 + p900 + p870 + 3;
    if (prod != expected) { return 1; }

    var neg_a: number = zero - a;
    var neg_prod: number = neg_a * b;
    if ((neg_prod + prod) != 0) { return 2; }

    var times8_expected: number = (one << 903) + 8;
    if ((a * 8) != times8_expected) { return 3; }
    var eight: number = 8;
    if ((eight * a) != times8_expected) { return 4; }
    if ((8 * a) != times8_expected) { return 5; }

    return 0;
}

// -- bundled from test/source/130_integer_strength_reduction_success.bpp

func signed_strength_130(x: i64, y: i64) -> u64 {
    if (x * 8 != -264) { return 1; }
    if (8 * x != -264) { return 2; }
    if (x / 8 != -4) { return 3; }
    if (x % 8 != -1) { return 4; }
    if (y / 8 != 4) { return 5; }
    if (y % 8 != 1) { return 6; }
    if (x / 1 != x) { return 7; }
    if (x % 1 != 0) { return 8; }
    return 0;
}

func unsigned_strength_130(x: u64) -> u64 {
    if (x * 16 != 18446744073709551600) { return 11; }
    if (16 * x != 18446744073709551600) { return 12; }
    if (x / 16 != 1152921504606846975) { return 13; }
    if (x % 16 != 15) { return 14; }
    if (x / 1 != x) { return 15; }
    if (x % 1 != 0) { return 16; }
    return 0;
}

func bundle_case__130_integer_strength_reduction_success() -> u64 {
    var signed_rc: u64 = signed_strength_130(-33, 33);
    if (signed_rc != 0) { return signed_rc; }

    var unsigned_rc: u64 = unsigned_strength_130(18446744073709551615);
    if (unsigned_rc != 0) { return unsigned_rc; }

    var z: u64 = 12345;
    if (z * 0 != 0) { return 21; }
    if (0 * z != 0) { return 22; }

    return 0;
}

// -- bundled from test/source/131_number_bigint_algorithms_success.bpp

func pow2_number_case131(exp: u64) -> number {
    var x: number = 1;
    for (var i: u64 = 0; i < exp; i = i + 1) {
        x = x + x;
    }
    return x;
}

func bundle_case__131_number_bigint_algorithms_success() -> u64 {
    var one: number = 1;
    var zero: number = 0;

    var p2300: number = pow2_number_case131(2300);
    var p2250: number = pow2_number_case131(2250);
    var p1400: number = pow2_number_case131(1400);
    var p900: number = pow2_number_case131(900);

    var a: number = p2300 + p1400 + 17;
    var b: number = p2250 + p900 + 19;
    var prod: number = a * b;
    var expected_prod: number =
        pow2_number_case131(4550) +
        pow2_number_case131(3200) +
        (p2300 * 19) +
        pow2_number_case131(3650) +
        pow2_number_case131(2300) +
        (p1400 * 19) +
        (p2250 * 17) +
        (p900 * 17) +
        323;
    if (prod != expected_prod) { return 1; }

    var divisor: number = pow2_number_case131(1200) + 33;
    var dividend: number = prod + pow2_number_case131(1700) + 12345;
    var q: number = dividend / divisor;
    var r: number = dividend % divisor;
    if ((q * divisor + r) != dividend) { return 2; }
    if (r < zero) { return 3; }
    if (r >= divisor) { return 4; }

    var high_bits: number = p2300 | p1400 | one;
    if ((high_bits & p2300) != p2300) { return 5; }
    if ((high_bits & p2250) != 0) { return 6; }
    if ((high_bits ^ p1400) != (p2300 | one)) { return 7; }

    var shifted_down: number = p2300 >> 777;
    if (shifted_down != pow2_number_case131(1523)) { return 8; }
    var shifted_up: number = shifted_down << 777;
    if (shifted_up != p2300) { return 9; }

    var neg_p2300: number = zero - p2300;
    var neg_shifted: number = neg_p2300 >> 777;
    var expected_neg_shifted: number = zero - pow2_number_case131(1523);
    if (neg_shifted != expected_neg_shifted) { return 10; }

    return 0;
}

// -- bundled from test/source/133_number_adaptive_small_fastpath_success.bpp

func expect_number_i64_133(v: number, expected: i64, code: u64) -> u64 {
    if (v.to_i64_checked_value() != expected) { return code; }
    return 0;
}

func bundle_case__133_number_adaptive_small_fastpath_success() -> u64 {
    var zero: number = 0;
    var one: number = 1;
    var neg_one: number = zero - one;

    var max_small: number = 4611686018427387903;
    var min_small: number = zero - 4611686018427387904;
    var spill_pos: number = max_small + one;
    var spill_neg: number = min_small - one;

    if (spill_pos <= max_small) { return 1; }
    if (spill_neg >= min_small) { return 2; }
    if (spill_pos - one != max_small) { return 3; }
    if (spill_neg + one != min_small) { return 4; }
    if (min_small / neg_one != spill_pos) { return 5; }
    if (min_small % neg_one != zero) { return 6; }

    var a: number = 123456789;
    var b: number = zero - 97;
    var c: number = ((a + b) * 33) / 11;
    var rc: u64 = expect_number_i64_133(c, 370370076, 7);
    if (rc != 0) { return rc; }

    if ((a & 255) != 21) { return 8; }
    if ((b | 7) != -97) { return 9; }
    if ((b ^ neg_one) != 96) { return 10; }
    if (a <= b) { return 11; }
    if (b >= a) { return 12; }
    if (a != 123456789) {
        return 13;
    }

    return 0;
}

// -- bundled from test/source/134_number_default_integer_inference_success.bpp


func takes_u64_134(v: u64) -> u64 {
    return v + 1;
}

func bundle_case__134_number_default_integer_inference_success() -> u64 {
    var a = 41;
    if (a.to_i64_checked_value() != 41) { return 1; }

    var b = a + 1;
    if (b.to_i64_checked_value() != 42) { return 2; }

    var fixed: u64 = 5;
    fixed = fixed + 1;
    if (fixed != 6) { return 3; }
    if (takes_u64_134(7) != 8) { return 4; }

    var vec_ptr = new Vec<u64>(4);
    vec_ptr.push(10);
    vec_ptr.push(20);
    var idx = 1;
    if (vec_ptr.get(idx) != 20) { return 5; }

    var total = 0;
    for (var i = 0; i < 3; i = i + 1) {
        total = total + i;
    }
    if (total.to_i64_checked_value() != 3) { return 6; }

    return 0;
}


    var neg: number = -7i;
    var neg_i: number = neg.imag_part();
    rc = expect_i64_138(neg_i, -7, 5);
    if (rc != 0) { return rc; }

    var product: number = 2 * 3i;
    var product_r: number = product.real_part();
    var product_i: number = product.imag_part();
    rc = expect_i64_138(product_r, 0, 6);
    if (rc != 0) { return rc; }
    rc = expect_i64_138(product_i, 6, 7);
    if (rc != 0) { return rc; }

    return 0;
}

// -- bundled from test/source/139_number_exact_numeric_tower_success.bpp

func expect_i64_139(v: number, expected: i64, code: u64) -> u64 {
    if (v.to_i64_checked_value() != expected) { return code; }
    return 0;
}

func expect_scaled_f64_139(v: number, scale: f64, expected: i64, code: u64) -> u64 {
    var scaled: f64 = v.to_f64_lossy() * scale;
    var got: i64 = (i64)scaled;
    if (got != expected) { return code; }
    return 0;
}

func expect_frac_139(v: number, num: i64, den: i64, code: u64) -> u64 {
    var rc: u64 = expect_i64_139(v.numerator(), num, code);
    if (rc != 0) { return rc; }
    return expect_i64_139(v.denominator(), den, code + 1);
}

func bundle_case__139_number_exact_numeric_tower_success() -> u64 {
    var half: number = Number.from_rational(1, 2);
    var third: number = Number.from_rational(1, 3);
    var sum: number = half + third;
    var rc: u64 = expect_frac_139(sum, 5, 6, 1);
    if (rc != 0) { return rc; }

    var quotient: number = half / third;
    rc = expect_frac_139(quotient, 3, 2, 3);
    if (rc != 0) { return rc; }

    var dec: number = Number.from_decimal(125, 2);
    var mix: number = dec + half;
    rc = expect_frac_139(mix, 7, 4, 5);
    if (rc != 0) { return rc; }

    var dec_mul: number = Number.from_decimal(25, 1) * half;
    rc = expect_frac_139(dec_mul, 5, 4, 7);
    if (rc != 0) { return rc; }

    var bf_int: number = Number.from_bigfloat(3, 10, 128);
    rc = expect_i64_139(bf_int, 3072, 9);
    if (rc != 0) { return rc; }

    var bf_frac: number = Number.from_bigfloat(1, -3, 128);
    rc = expect_frac_139(bf_frac, 1, 8, 10);
    if (rc != 0) { return rc; }

    var bf_sum: number = bf_frac + Number.from_rational(1, 8);
    rc = expect_frac_139(bf_sum, 1, 4, 12);
    if (rc != 0) { return rc; }
    rc = expect_scaled_f64_139(bf_sum, 1000.0, 250, 14);
    if (rc != 0) { return rc; }

    var z: number = 76 + 7i;
    if (z != Number.from_complex(76, 7)) { return 15; }
    if (z == Number.from_complex(76, 8)) { return 16; }

    return 0;
}

// -- bundled from test/source/142_number_proof_slice_tag_optimization_success.bpp

func expect_i64_142(v: number, expected: i64, code: u64) -> u64 {
    if (v.to_i64_checked_value() != expected) { return code; }
    return 0;
}

func expect_scaled_f64_142(v: number, scale: f64, expected: i64, code: u64) -> u64 {
    var scaled: f64 = v.to_f64_lossy() * scale;
    var got: i64 = (i64)scaled;
    if (got != expected) { return code; }
    return 0;
}

func bundle_case__142_number_proof_slice_tag_optimization_success() -> u64 {
    var ints: [5]number;
    var xs: NumberSlice = NumberSlice.from_ptr(&ints[0], 5);
    if (xs.domain() != NUMBER_PROOF_DOMAIN_SLICE) { return 1; }
    if (xs.capability() != NUMBER_PROOF_CAP_BORROWED) { return 2; }
    if (xs.is_nonnull() != 1) { return 3; }
    if (xs.has_stable_bounds() != 1) { return 4; }

    xs.set_i64(0, 10);
    xs.set_i64(1, -2);
    xs.set_i64(2, 30);
    xs.set_i64(3, 4);
    xs.set_i64(4, 8);
    if (xs.shape() != NUMBER_PROOF_SHAPE_I64) { return 5; }
    var sum_i: number = xs.sum();
    var rc: u64 = expect_i64_142(sum_i, 50, 6);
    if (rc != 0) { return rc; }

    var reals: [3]number;
    var rs: NumberSlice = NumberSlice.from_ptr(&reals[0], 3);
    rs.set_f64(0, 1.25);
    rs.set_f64(1, 2.5);
    rs.set_f64(2, 0.75);
    if (rs.shape() != NUMBER_PROOF_SHAPE_F64) { return 7; }
    var sum_r: number = rs.sum();
    rc = expect_scaled_f64_142(sum_r, 100.0, 450, 8);
    if (rc != 0) { return rc; }

    var complex_values: [2]number;
    var zs: NumberSlice = NumberSlice.from_ptr(&complex_values[0], 2);
    zs.set_number(0, Number.from_complex(1, 2));
    zs.set_number(1, Number.from_complex(3, 4));
    if (zs.shape() != NUMBER_PROOF_SHAPE_COMPLEX) { return 9; }
    var sum_z: number = zs.sum();
    rc = expect_i64_142(sum_z.real_part(), 4, 10);
    if (rc != 0) { return rc; }
    rc = expect_i64_142(sum_z.imag_part(), 6, 11);
    if (rc != 0) { return rc; }

    xs.set_f64(2, 1.5);
    if (xs.shape() != NUMBER_PROOF_SHAPE_MIXED) { return 12; }
    var mixed_sum: number = xs.sum();
    rc = expect_scaled_f64_142(mixed_sum, 10.0, 215, 13);
    if (rc != 0) { return rc; }

    return 0;
}

// -- bundled from test/source/143_number_container_sum_auto_rewrite_success.bpp

func expect_i64_143(v: number, expected: i64, code: u64) -> u64 {
    if (v.to_i64_checked_value() != expected) { return code; }
    return 0;
}

func expect_scaled_f64_143(v: number, scale: f64, expected: i64, code: u64) -> u64 {
    var scaled: f64 = v.to_f64_lossy() * scale;
    var got: i64 = (i64)scaled;
    if (got != expected) { return code; }
    return 0;
}

var g_slice_make_calls_143: u64 = 0;

func counted_slice_143(ptr: *number, len: u64) -> []number {
    g_slice_make_calls_143 = g_slice_make_calls_143 + 1;
    return slice(ptr, len);
}

func bundle_case__143_number_container_sum_auto_rewrite_success() -> u64 {
    var ints: [5]number;
    ints[0] = 10;
    ints[1] = -2;
    ints[2] = 30;
    ints[3] = 4;
    ints[4] = 8;
    var array_sum: number = ints.sum();
    var rc: u64 = expect_i64_143(array_sum, 50, 1);
    if (rc != 0) { return rc; }

    var int_slice: []number = slice(&ints[1], 3);
    var slice_sum: number = int_slice.sum();
    rc = expect_i64_143(slice_sum, 32, 2);
    if (rc != 0) { return rc; }

    var reals: [3]number;
    reals[0] = 1.25;
    reals[1] = 2.5;
    reals[2] = 0.75;
    var real_sum: number = reals.sum();
    rc = expect_scaled_f64_143(real_sum, 100.0, 450, 3);
    if (rc != 0) { return rc; }

    var complex_values: [2]number;
    complex_values[0] = 1 + 2i;
    complex_values[1] = 3 + 4i;
    var complex_sum: number = complex_values.sum();
    rc = expect_i64_143(complex_sum.real_part(), 4, 4);
    if (rc != 0) { return rc; }
    rc = expect_i64_143(complex_sum.imag_part(), 6, 5);
    if (rc != 0) { return rc; }

    ints[2] = 1.5;
    var mixed_sum: number = ints.sum();
    rc = expect_scaled_f64_143(mixed_sum, 10.0, 215, 6);
    if (rc != 0) { return rc; }

    g_slice_make_calls_143 = 0;
    var side_effect_sum: number = counted_slice_143(&ints[0], 5).sum();
    rc = expect_scaled_f64_143(side_effect_sum, 10.0, 215, 7);
    if (rc != 0) { return rc; }
    if (g_slice_make_calls_143 != 1) { return 8; }

    return 0;
}


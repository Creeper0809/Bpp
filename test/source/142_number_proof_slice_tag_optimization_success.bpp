// Covers: proof-carrying tagged pointer metadata for NumberSlice shape/bounds fast paths
// Mode: ssa|nossa
// Opt: O0|O1
// LLVM Build: true
// Expect exit code: 0

func expect_i64_142(v: number, expected: i64, code: u64) -> u64 {
    if (v.to_i64_checked_value() != expected) { return code; }
    return 0;
}

func expect_scaled_f64_142(v: number, scale: f64, expected: i64, code: u64) -> u64 {
    var scaled: f64 = v.to_f64_lossy() * scale;
    var got: i64 = (i64)scaled;
    if (got != expected) { return code; }
    return 0;
}

func main() -> u64 {
    var ints: [5]number;
    var xs: NumberSlice = NumberSlice.from_ptr(&ints[0], 5);
    if (xs.domain() != NUMBER_PROOF_DOMAIN_SLICE) { return 1; }
    if (xs.capability() != NUMBER_PROOF_CAP_BORROWED) { return 2; }
    if (xs.is_nonnull() != 1) { return 3; }
    if (xs.has_stable_bounds() != 1) { return 4; }

    xs.set_i64(0, 10);
    xs.set_i64(1, -2);
    xs.set_i64(2, 30);
    xs.set_i64(3, 4);
    xs.set_i64(4, 8);
    if (xs.shape() != NUMBER_PROOF_SHAPE_I64) { return 5; }
    var sum_i: number = xs.sum();
    var rc: u64 = expect_i64_142(sum_i, 50, 6);
    if (rc != 0) { return rc; }

    var reals: [3]number;
    var rs: NumberSlice = NumberSlice.from_ptr(&reals[0], 3);
    rs.set_f64(0, 1.25);
    rs.set_f64(1, 2.5);
    rs.set_f64(2, 0.75);
    if (rs.shape() != NUMBER_PROOF_SHAPE_F64) { return 7; }
    var sum_r: number = rs.sum();
    rc = expect_scaled_f64_142(sum_r, 100.0, 450, 8);
    if (rc != 0) { return rc; }

    var complex_values: [2]number;
    var zs: NumberSlice = NumberSlice.from_ptr(&complex_values[0], 2);
    zs.set_number(0, Number.from_complex(1, 2));
    zs.set_number(1, Number.from_complex(3, 4));
    if (zs.shape() != NUMBER_PROOF_SHAPE_COMPLEX) { return 9; }
    var sum_z: number = zs.sum();
    rc = expect_i64_142(sum_z.real_part(), 4, 10);
    if (rc != 0) { return rc; }
    rc = expect_i64_142(sum_z.imag_part(), 6, 11);
    if (rc != 0) { return rc; }

    xs.set_f64(2, 1.5);
    if (xs.shape() != NUMBER_PROOF_SHAPE_MIXED) { return 12; }
    var mixed_sum: number = xs.sum();
    rc = expect_scaled_f64_142(mixed_sum, 10.0, 215, 13);
    if (rc != 0) { return rc; }

    return 0;
}

// Covers: free functions ending in _eq are not lowered as magic method calls
// Expect exit code: 0
// LLVM Build: true

struct EqProbe {
    public value: u64;
}

func helper_key_eq(arg: *EqProbe, key: []u8) -> u64 {
    if (arg == 0) { return 1; }
    if (key.len != 1) { return 2; }
    if (key[0] != 120) { return 3; }
    return 0;
}

func main() -> u64 {
    var probe: EqProbe;
    probe.value = 7;
    return helper_key_eq(&probe, slice("x", 1));
}

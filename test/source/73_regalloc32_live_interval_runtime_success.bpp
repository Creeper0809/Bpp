// Covers: production regalloc live interval path, call constraints, remat/coalesce candidates
// Mode: ssa
// Opt: O1
// LLVM Build: true
// Expect asm contains: _73_regalloc32_live_interval_runtime_success__regalloc32_pressure:
// Expect asm contains: mov [rbp-72], r12
// Expect asm count <=: scope=_73_regalloc32_live_interval_runtime_success__regalloc32_pressure:;mov [rbp-72], r12|1
// Expect exit code: 0

func regalloc32_leaf(a: u64, b: u64, c: u64, d: u64, e: u64, f: u64) -> u64 {
    return a + (b * 2) + (c * 3) + (d * 4) + (e * 5) + (f * 6);
}

func regalloc32_pressure(seed: u64) -> u64 {
    var a: u64 = seed + 1;
    var b: u64 = seed + 2;
    var c: u64 = seed + 3;
    var d: u64 = seed + 4;
    var e: u64 = seed + 5;
    var f: u64 = seed + 6;
    var g: u64 = a + b;
    var h: u64 = c + d;
    var i: u64 = e + f;
    var j: u64 = regalloc32_leaf(g, h, i, a, c, e);
    var k: u64 = regalloc32_leaf(j, g, h, i, b, d);
    var copy0: u64 = k;
    var copy1: u64 = copy0;
    var copy2: u64 = copy1 + j;
    return copy2 ^ (a + b + c + d + e + f);
}

func main() -> u64 {
    if (regalloc32_pressure(7) != 843) {
        return 1;
    }
    return 0;
}

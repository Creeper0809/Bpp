// LLVM Build: true

@[feature]
func sum_slice_114(s: []u8) -> u64 {
    return (u64)s[0] + (u64)s[1] + (u64)s[2];
}

@[entry]
func runtime_entry() -> u64 {
    var buf: [4]u8;
    buf[0] = 3;
    buf[1] = 4;
    buf[2] = 5;
    buf[3] = 6;
    var s: []u8 = slice(&buf[0], 3);
    return sum_slice_114(s) - 12;
}

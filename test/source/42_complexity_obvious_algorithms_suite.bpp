// Expect exit code: 0

// Floyd-Warshall style triple loop: obvious O(n^3)
@[complexity(time="O(n^3)", space="O(1)")]
@[complexity_budget(time="O(n^3)", space="O(1)")]
@[constraints(n=40)]
@[time_limit(ms=2000, machine="ref_v1")]
func floyd_style_relax(n: u64) -> u64 {
    var acc: u64 = 0;
    var k: u64 = 0;
    while (k < n) {
        var i: u64 = 0;
        while (i < n) {
            var j: u64 = 0;
            while (j < n) {
                acc = acc + ((i + j + k) & 3);
                j = j + 1;
            }
            i = i + 1;
        }
        k = k + 1;
    }
    return acc;
}

// Binary recursion with two self-calls: obvious exponential.
@[complexity(time="O(2^n)", space="O(n)")]
@[complexity_budget(time="O(2^n)", space="O(n)")]
@[constraints(n=12)]
@[time_limit(ms=2000, machine="ref_v1")]
func fib_style(n: u64) -> u64 {
    if (n <= 1) { return 1; }
    return fib_style(n - 1) + fib_style(n - 2);
}

// Sieve-style nested loop with j += i: expected O(n log log n)
@[complexity_budget(time="O(n log log n)", space="O(n)")]
@[complexity_debug]
@[constraints(n=200000)]
@[time_limit(ms=2000, machine="ref_v1")]
func sieve_style_count(n: u64) -> u64 {
    if (n < 2) { return 0; }
    var mark: [200001]u8;
    var i: u64 = 2;
    var cnt: u64 = 0;
    while (i * i <= n) {
        if (mark[i] == 0) {
            var j: u64 = i * i;
            while (j <= n) {
                mark[j] = 1;
                j += i;
            }
        }
        i += 1;
    }
    var k: u64 = 2;
    while (k <= n) {
        if (mark[k] == 0) { cnt += 1; }
        k += 1;
    }
    return cnt;
}

// Multi-variable linear form: O(v + e)
@[complexity_budget(time="O(v+e)", space="O(1)")]
@[constraints(v=100000, e=200000)]
@[time_limit(ms=2000, machine="ref_v1")]
func graph_linear_scan(v: u64, e: u64) -> u64 {
    var acc: u64 = 0;
    var i: u64 = 0;
    while (i < v) {
        acc += (i & 1);
        i += 1;
    }
    var j: u64 = 0;
    while (j < e) {
        acc += (j & 1);
        j += 1;
    }
    return acc;
}

func main() -> u64 {
    var a: u64 = floyd_style_relax(8);
    if (a == 0) { return 1; }

    var b: u64 = fib_style(10);
    if (b != 89) { return 2; }

    var c: u64 = sieve_style_count(1000);
    if (c != 168) { return 3; }

    var d: u64 = graph_linear_scan(1000, 2000);
    if (d == 0) { return 4; }

    return 0;
}

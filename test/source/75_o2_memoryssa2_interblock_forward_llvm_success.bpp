// Covers: O2 MemorySSA2 single-predecessor inter-block load forwarding
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.memoryssa2.rewrite=single-pred-interblock-load-forward
// Expect llvm metadata contains: memssa2_interblock=
// Expect exit code: 0

struct O2MemoryInterBlockBox {
    public value: u64;
    public guard: u64;
}

func o2_memoryssa2_interblock_forward_probe(x: u64, gate: u64) -> u64 {
    var box: O2MemoryInterBlockBox = O2MemoryInterBlockBox{x, 17};
    box.value = x + 11;
    var n: number = Number.from_str(slice("23456", 5));
    if (gate == 0) {
        return 9;
    }
    var y: u64 = box.value;
    if (y != x + 11) { return 1; }
    if (box.guard != 17) { return 2; }
    if (n != 23456) { return 3; }
    return 0;
}

func main() -> u64 {
    return o2_memoryssa2_interblock_forward_probe(31, 1);
}

// LLVM Build: true
// Covers: println(number arithmetic expression) uses Number.to_str instead of raw tagged bits
// Stdin: 12\n
// Expect exit code: 0
// Expect stdout: 14\n17\n-12\n

func main() -> u64 {
    var i: number = input<number>();
    println(i + 2);
    println((i + 2) + 3);
    println(-i);
    return 0;
}

// LLVM Build: true
// Mode: ssa
// Opt: O0,O1
// Expect exit code: 0

func pow2_number_case96(exp: u64) -> number {
    var x: number = 1;
    for (var i: u64 = 0; i < exp; i = i + 1) {
        x = x + x;
    }
    return x;
}

func main() -> u64 {
    var big: number = pow2_number_case96(90);
    var expected: number = pow2_number_case96(90);
    var qbig: number = big / 8;
    var rbig: number = big % 8;
    if (qbig == 0 && rbig == 123456789) { return 1; }
    if (big != expected) { return 2; }
    return 0;
}

@[config]
var G_ANNOTATED: u64 = 40;

struct AnnBox {
}

impl AnnBox {
    @[trace]
    public static func add(a: u64, b: u64) -> u64 {
        return a + b;
    }
}

@[feature]
func sum_with_annotation(a: u64, b: u64) -> u64 {
    @[hot]
    var local_sum: u64 = a + b;
    return local_sum;
}

func main() -> u64 {
    var out: u64 = sum_with_annotation(G_ANNOTATED, 2);
    if (out != 42) { return 1; }
    if (AnnBox.add(1, 1) != 2) { return 2; }
    return 0;
}

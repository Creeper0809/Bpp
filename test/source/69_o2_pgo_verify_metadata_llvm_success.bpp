// Covers: O2 PGO/autotune and verification/fuzz/differential contract metadata
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.pgo2.engine=autotune-benchmark-governance
// Expect llvm metadata contains: bpp.ssa.pgo2.axis=compile-runtime-memory-codesize
// Expect llvm metadata contains: bpp.ssa.pgo2.threshold=inline-unroll-vector-bigint-alloc-gc
// Expect llvm metadata contains: bpp.ssa.pgo2.noise=median-variance-machine-info
// Expect llvm metadata contains: bpp.ssa.verify2.engine=fuzz-diff-sanitizer
// Expect llvm metadata contains: bpp.ssa.verify2.matrix=o0-o1-o2-o3-llvm-native-cache-debug
// Expect llvm metadata contains: bpp.ssa.verify2.generator=type-ownership-number-aware
// Expect llvm metadata contains: bpp.ssa.verify2.minimize=source-bundle-promotion
// Expect llvm metadata contains: pgo2=
// Expect llvm metadata contains: verify2=
// Expect exit code: 0

func o2_pgo_verify_probe(n: u64) -> u64 {
    var hot: u64 = bpp_profile_hot_from_threshold(n + 64, 32);
    if (hot == 0) { return 1; }
    if (n > 1000) { return 2; }
    return 0;
}

func main() -> u64 {
    return o2_pgo_verify_probe(9);
}

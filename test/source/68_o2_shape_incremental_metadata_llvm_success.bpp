// Covers: O2 shape/container inline cache and incremental cache contract metadata
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.shape_ic.engine=container-inline-cache
// Expect llvm metadata contains: bpp.ssa.shape_ic.meta=object-vec-map-string
// Expect llvm metadata contains: bpp.ssa.shape_ic.invalidate=mutation-proof-guard
// Expect llvm metadata contains: bpp.ssa.shape_ic.fastpath=hot-container-cold-generic
// Expect llvm metadata contains: bpp.ssa.incremental.engine=persistent-cache-deterministic
// Expect llvm metadata contains: bpp.ssa.incremental.key=content-version-opt-target-stdhash
// Expect llvm metadata contains: bpp.ssa.incremental.graph=import-generic-min-invalidation
// Expect llvm metadata contains: bpp.ssa.incremental.fallback=corrupt-cache-cold-rebuild
// Expect llvm metadata contains: shape_ic=
// Expect llvm metadata contains: incremental_cache=
// Expect exit code: 0

func o2_shape_incremental_probe() -> u64 {
    var hot: u64 = bpp_profile_hot_from_threshold(16, 8);
    var path: u64 = bpp_fast_path_for_shape_len(BPP_TAG_SHAPE_U64, hot, 1, sizeof(u64), 4);
    if (path != BPP_FAST_PATH_VECTOR) { return 1; }
    return 0;
}

func main() -> u64 {
    return o2_shape_incremental_probe();
}

enum MaybeU64 {
    None,
    Some(value: u64),
}

func unwrap_or_zero(v: MaybeU64) -> u64 {
    match (v) {
        case MaybeU64.None:
            return 0;
        case MaybeU64.Some(x):
            return x;
    }
}

func main() -> u64 {
    var a: MaybeU64 = MaybeU64.None();
    var b: MaybeU64 = MaybeU64.Some(42);
    if (unwrap_or_zero(a) != 0) { return 1; }
    if (unwrap_or_zero(b) != 42) { return 2; }
    return 0;
}

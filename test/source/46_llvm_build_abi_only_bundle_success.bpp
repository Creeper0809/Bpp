// Bundled LLVM-only ABI fixture test.
// LLVM Build: true
// LLVM Only: true
// Covers: LLVM ABI nested packed struct param/return and tagged pointer metadata carried through struct return
// Expect exit code: 0

// -- bundled from 119_llvm_build_nested_packed_struct_abi_success.bpp

packed struct TinyPacked119 {
    public a: u8;
    public b: u16;
}

struct InnerPacked119 {
    public tiny: TinyPacked119;
    public z: u8;
}

struct OuterPacked119 {
    public prefix: u8;
    public inner: InnerPacked119;
    public tail: u64;
    public suffix: u8;
}

func make_outer_packed_119(seed: u64) -> OuterPacked119 {
    var out: OuterPacked119;
    out.prefix = (u8)seed;
    out.inner.tiny.a = (u8)(seed + 1);
    out.inner.tiny.b = (u16)(seed + 20);
    out.inner.z = (u8)(seed + 3);
    out.tail = seed * 100;
    out.suffix = (u8)(seed + 9);
    return out;
}

func sum_outer_packed_119(v: OuterPacked119) -> u64 {
    return (u64)v.prefix + (u64)v.inner.tiny.a + (u64)v.inner.tiny.b + (u64)v.inner.z + v.tail + (u64)v.suffix;
}

func bump_outer_packed_119(v: OuterPacked119, delta: u64) -> OuterPacked119 {
    v.inner.tiny.b = (u16)((u64)v.inner.tiny.b + delta);
    v.tail = v.tail + delta * 10;
    v.suffix = (u8)((u64)v.suffix + 1);
    return v;
}

func llvm_abi_bundle_case_119() -> u64 {
    if (sizeof(TinyPacked119) != 3) { return 1; }
    var base: OuterPacked119 = make_outer_packed_119(5);
    if (sum_outer_packed_119(base) != 558) { return 4; }

    var bumped: OuterPacked119 = bump_outer_packed_119(base, 7);
    if (sum_outer_packed_119(bumped) != 636) { return 5; }
    if (sum_outer_packed_119(base) != 558) { return 6; }

    var acc: u64 = 0;
    for (var i: u64 = 0; i < 6; i = i + 1) {
        var item: OuterPacked119 = bump_outer_packed_119(make_outer_packed_119(i), i + 1);
        acc = acc + sum_outer_packed_119(item);
    }
    if (acc != 2010) { return 7; }
    return 0;
}

// -- bundled from 120_llvm_build_tagged_struct_return_abi_success.bpp

packed struct TagBits120 {
    public kind: u16;
    public flags: u8;
}

struct TaggedBox120 {
    public ptr: *tagged(TagBits120) u8;
    public code: u64;
    public total: u64;
}

func make_tagged_box_120(base: *u8, seed: u64) -> TaggedBox120 {
    var p: *tagged(TagBits120) u8 = (*tagged(TagBits120) u8)base;
    p.kind = (u16)(seed + 5);
    p.flags = (u8)(seed & 7);

    var out: TaggedBox120;
    out.ptr = p;
    out.code = seed * 10;
    out.total = (u64)p.kind + (u64)p.flags + out.code;
    return out;
}

func retag_box_120(box: TaggedBox120, add: u64) -> TaggedBox120 {
    var p: *tagged(TagBits120) u8 = box.ptr;
    p.kind = (u16)((u64)p.kind + add);
    p.flags = (u8)((u64)p.flags ^ (add & 7));
    box.ptr = p;
    box.code = box.code + add * 3;
    box.total = (u64)p.kind + (u64)p.flags + box.code;
    return box;
}

func llvm_abi_bundle_case_120() -> u64 {
    var storage: [16]u8;
    var box: TaggedBox120 = make_tagged_box_120(&storage[0], 9);
    if (box.ptr.kind != 14) { return 1; }
    if (box.ptr.flags != 1) { return 2; }
    if (box.total != 105) { return 3; }

    var next: TaggedBox120 = retag_box_120(box, 6);
    if (next.ptr.kind != 20) { return 4; }
    if (next.ptr.flags != 7) { return 5; }
    if (next.total != 135) { return 6; }
    if (box.ptr.kind != 14) { return 7; }
    if (box.ptr.flags != 1) { return 8; }

    var acc: u64 = 0;
    for (var i: u64 = 0; i < 5; i = i + 1) {
        var item: TaggedBox120 = make_tagged_box_120(&storage[i], i + 1);
        item = retag_box_120(item, i);
        acc = acc + item.total;
    }
    if (acc != 243) { return 9; }
    return 0;
}

func main() -> u64 {
    if (llvm_abi_bundle_case_119() != 0) { return 119; }
    if (llvm_abi_bundle_case_120() != 0) { return 120; }
    return 0;
}

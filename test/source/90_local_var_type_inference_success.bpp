// Covers: local `var name = expr` type inference from clear initializer types
// Mode: ssa|nossa
// Opt: O0|O1
// Stdin: 42\nline\n
// Expect exit code: 0
// LLVM Build: true

import std.str;
import std.vec;

func main() -> u64 {
    var i = 41;
    if (i + 1 != 42) { return 1; }

    var f = 1.5;
    if (f < 1.49) { return 2; }
    if (f > 1.51) { return 3; }

    var s = "ok";
    if (str_eq(slice((u64)s, 2), "ok") == 0) { return 4; }

    var n = input<number>();
    var n_expected: number = 42;
    if (n != n_expected) { return 5; }

    var line = input<[]u8>();
    if (line.len != 4) { return 6; }
    if (str_eq(slice((u64)line.ptr, line.len), "line") == 0) { return 7; }

    var vec_ptr = new Vec<u64>(2);
    if (vec_ptr == 0) { return 8; }
    vec_ptr.push(7);
    vec_ptr.push(11);
    if (vec_ptr.len() != 2) { return 9; }
    if (vec_ptr.get(0) != 7) { return 10; }
    if (vec_ptr.get(1) != 11) { return 11; }

    for (var loop_i = 0; loop_i < 3; loop_i = loop_i + 1) {
        if (loop_i > 2) { return 12; }
    }

    return 0;
}

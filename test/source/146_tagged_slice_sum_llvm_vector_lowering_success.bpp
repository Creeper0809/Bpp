// LLVM Build: true
// Expect llvm metadata contains: bpp.vector.lowering = tagged-slice-sum-i64x4
// Expect llvm metadata contains: load <4 x i64>
// Expect llvm metadata contains: bpp.vector.lowering = tagged-slice-sum-f64x4
// Expect llvm metadata contains: load <4 x double>
// Covers: LLVM vector lowering for tagged slice sum helpers
// Expect exit code: 0

func main() -> u64 {
    var us: [9]u64;
    us[0] = 1;
    us[1] = 2;
    us[2] = 3;
    us[3] = 4;
    us[4] = 5;
    us[5] = 6;
    us[6] = 7;
    us[7] = 8;
    us[8] = 9;
    var su: BppTaggedSlice<u64> = bpp_tag_slice_from_ptr<u64>(&us[0], 9, BPP_TAG_SHAPE_U64);
    bpp_tag_slice_mark_profiled<u64>(&su);
    if (bpp_tag_slice_sum_u64(&su) != 45) { return 1; }

    var si_raw: [6]i64;
    si_raw[0] = -10;
    si_raw[1] = 3;
    si_raw[2] = 4;
    si_raw[3] = 5;
    si_raw[4] = 6;
    si_raw[5] = 7;
    var si: BppTaggedSlice<i64> = bpp_tag_slice_from_ptr<i64>(&si_raw[0], 6, BPP_TAG_SHAPE_I64);
    bpp_tag_slice_mark_profiled<i64>(&si);
    if (bpp_tag_slice_sum_i64(&si) != 15) { return 2; }

    var fs: [5]f64;
    fs[0] = 1.5;
    fs[1] = 2.25;
    fs[2] = 3.25;
    fs[3] = 4.0;
    fs[4] = 5.0;
    var sf: BppTaggedSlice<f64> = bpp_tag_slice_from_ptr<f64>(&fs[0], 5, BPP_TAG_SHAPE_F64);
    bpp_tag_slice_mark_profiled<f64>(&sf);
    var scaled: i64 = (i64)(bpp_tag_slice_sum_f64(&sf) * 10.0);
    if (scaled != 160) { return 3; }

    return 0;
}

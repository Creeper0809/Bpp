func lambda_ref_from_param(x: u64) -> u64 {
    var by_ref: u64 = func [&x] () -> u64 { x + 1 };
    x = x + 40;
    return by_ref();
}

func main() -> u64 {
    var v_ref: u64 = lambda_ref_from_param(1);
    if (v_ref != 42) { return 1; }

    var y: u64 = 7;
    var by_val: u64 = func [y] () -> u64 { y + 1 };
    y = 100;
    if (by_val() != 8) { return 2; }
    if (y != 100) { return 3; }
    return 0;
}

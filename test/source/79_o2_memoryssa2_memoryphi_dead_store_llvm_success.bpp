// Covers: O2 MemorySSA2 MemoryPhi dead store elimination across matching predecessors
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.memoryssa2.rewrite=memoryphi-dead-store-kill
// Expect llvm metadata contains: memssa2_phi_store_kill=
// Expect llvm metadata contains: memssa2_verify_errors=0
// Expect exit code: 0

struct O2MemoryPhiDseBox {
    public value: u64;
    public guard: u64;
}

func o2_memoryssa2_memoryphi_dead_store_probe(x: u64, gate: u64) -> u64 {
    var box: O2MemoryPhiDseBox = O2MemoryPhiDseBox{0, 37};
    var v: u64 = x + 5;
    if (gate == 0) {
        box.value = v;
    } else {
        box.value = v;
    }
    box.value = x + 9;
    var y: u64 = box.value;
    if (y != x + 9) { return 1; }
    if (box.guard != 37) { return 2; }
    return 0;
}

func o2_memoryssa2_memoryphi_dead_store_gate(seed: u64) -> u64 {
    var n: number = Number.from_str(slice("1", 1));
    if (n != 1) { return 0; }
    return seed;
}

func main() -> u64 {
    return o2_memoryssa2_memoryphi_dead_store_probe(20, o2_memoryssa2_memoryphi_dead_store_gate(1));
}

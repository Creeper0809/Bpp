// LLVM Build: true
func classify(v: u64) -> u64 {
    match (v) {
        case 1:
            return 10;
        case 2:
            return 20;
        case _:
            return 99;
    }
}

func classify_many(v: u64) -> u64 {
    match (v) {
        case 1, 2, 3:
            return 10;
        case 4, 5:
            return 20;
        case _:
            return 99;
    }
}

enum MaybeU64Case111 {
    None,
    Some(value: u64),
}

func unwrap_or_zero_case111(v: MaybeU64Case111) -> u64 {
    match (v) {
        case MaybeU64Case111.None:
            return 0;
        case MaybeU64Case111.Some(x):
            return x;
    }
}

enum ExprMatchEnumCase111 {
    None,
    Some(value: u64),
}

struct MatchPairCase111 {
    public a: u64;
    public b: u64;
}

struct PayloadPairCase111 {
    public a: u64;
    public b: u64;
}

enum PayloadCompositeCase111 {
    Pair(PayloadPairCase111),
    Arr([2]u64),
    Slice([]u64),
}

func payload_score_case111(v: PayloadCompositeCase111) -> u64 {
    match (v) {
        case PayloadCompositeCase111.Pair(p):
            return p.a + p.b;
        case PayloadCompositeCase111.Arr(a):
            return a[0] + a[1];
        case PayloadCompositeCase111.Slice(s):
            if (s.len == 0) { return 0; }
            return s[0];
    }
}

func main() -> u64 {
    if (classify(1) != 10) { return 1; }
    if (classify(2) != 20) { return 2; }
    if (classify(777) != 99) { return 3; }

    if (classify_many(1) != 10) { return 10; }
    if (classify_many(3) != 10) { return 11; }
    if (classify_many(5) != 20) { return 12; }
    if (classify_many(9) != 99) { return 13; }

    var base: u64 = 40;
    var x: u64 = 2;
    var y: u64 = match (x) {
        case 1:
            base + 1;
        case 2, 3:
            base + x;
        case _:
            0;
    };
    if (y != 42) { return 20; }

    var a: MaybeU64Case111 = MaybeU64Case111.None();
    var b: MaybeU64Case111 = MaybeU64Case111.Some(42);
    if (unwrap_or_zero_case111(a) != 0) { return 30; }
    if (unwrap_or_zero_case111(b) != 42) { return 31; }

    var out: u64 = match (ExprMatchEnumCase111.Some(42)) {
        case ExprMatchEnumCase111.None:
            0;
        case ExprMatchEnumCase111.Some(v):
            v;
    };
    if (out != 42) { return 40; }

    var pair: MatchPairCase111 = match (2) -> MatchPairCase111 {
        case 1:
            MatchPairCase111 { 1, 2 };
        case _:
            MatchPairCase111 { 20, 22 };
    };
    if (pair.a != 20) { return 50; }
    if (pair.b != 22) { return 51; }

    var p: PayloadPairCase111 = PayloadPairCase111 { 10, 32 };
    if (payload_score_case111(PayloadCompositeCase111.Pair(p)) != 42) { return 60; }

    var arr: [2]u64;
    arr[0] = 20;
    arr[1] = 22;
    if (payload_score_case111(PayloadCompositeCase111.Arr(arr)) != 42) { return 61; }

    var s: []u64 = slice(&arr[0], 2);
    if (payload_score_case111(PayloadCompositeCase111.Slice(s)) != 20) { return 62; }

    return 0;
}

// Covers: O2 MemorySSA2 post-rewrite verifier
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.memoryssa2.verify=post-rewrite
// Expect llvm metadata contains: memssa2_verify_errors=0
// Expect exit code: 0

struct O2MemoryVerifyBox {
    public value: u64;
    public guard: u64;
}

func o2_memoryssa2_verify_probe(x: u64, gate: u64) -> u64 {
    var box: O2MemoryVerifyBox = O2MemoryVerifyBox{0, 91};
    if (gate == 0) {
        box.value = x + 3;
    } else {
        box.value = x + 3;
    }
    var y: u64 = box.value;
    if (y != x + 3) { return 1; }
    if (box.guard != 91) { return 2; }
    return 0;
}

func main() -> u64 {
    return o2_memoryssa2_verify_probe(8, 1);
}

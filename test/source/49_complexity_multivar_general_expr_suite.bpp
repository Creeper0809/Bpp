// Expect exit code: 0

// 4-variable mixed expression:
// O(n*m + n*log(p) + k)
@[complexity_budget(time="O(8*(n*m + n*log(p) + k))", space="O(1)", mode="worst")]
@[constraints(n=64, m=64, k=1024, p=1048576)]
@[time_limit(ms=50, machine="ref_v1")]
@[complexity_debug]
func multivar_four_symbols(n: u64, m: u64, k: u64, p: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        var j: u64 = 0;
        while (j < m) {
            acc += ((i + j) & 1);
            j += 1;
        }

        var t: u64 = 1;
        while (t < p) {
            acc += (t & 1);
            t = t << 1;
        }
        i += 1;
    }

    var u: u64 = 0;
    while (u < k) {
        acc += (u & 1);
        u += 1;
    }
    return acc;
}

// No direct `k=` bound in constraints: derive from relation key.
@[complexity_budget(time="O(4*k)", space="O(1)")]
@[constraints(n=256, m=128, rel1="k<=n*m")]
@[time_limit(ms=100, machine="ref_v1")]
@[complexity_debug]
func relation_derived_bound(k: u64) -> u64 {
    var i: u64 = 0;
    var s: u64 = 0;
    while (i < k) {
        s += (i & 1);
        i += 1;
    }
    return s;
}

func main() -> u64 {
    var a: u64 = multivar_four_symbols(8, 12, 32, 1024);
    if (a == 0) { return 1; }

    var b: u64 = relation_derived_bound(20);
    if (b != 10) { return 2; }

    return 0;
}

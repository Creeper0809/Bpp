// Covers: contract composition for decorator/property/override/entry
// Expect exit code: 42

func deco_add_one_91(next: u64, x: u64) -> u64 {
    return next(x) + 1;
}

func deco_mul_two_91(next: u64, x: u64) -> u64 {
    return next(x) * 2;
}

@[deco_add_one_91]
@[deco_mul_two_91]
func decorated_order_91(x: u64) -> u64 {
    return x + 3;
}

struct HookDecorated91 {
    property(setter=set_hp_91, getter=get_hp_91)
    public hp: u64;
}

func setter_bonus_91(next: u64, self: *HookDecorated91, val: u64) {
    next(self, val);
    self.$hp = self.$hp + 1;
}

@[setter_bonus_91]
func set_hp_91(self: *HookDecorated91, val: u64) {
    self.$hp = val;
}

func get_hp_91(self: *HookDecorated91) -> u64 {
    return self.$hp;
}

struct PairMagicDecorated91 {
    public a: u64;
    public b: u64;
}

func hash_bonus_91(next: u64, self: *PairMagicDecorated91) -> u64 {
    return next(self) + 5;
}

impl PairMagicDecorated91 {
    @[override]
    @[hash_bonus_91]
    public func hash(self: *PairMagicDecorated91) -> u64 {
        return self.a + self.b;
    }
}

func entry_bonus_91(next: u64) -> u64 {
    return next() + 2;
}

func main() -> u64 {
    return 1;
}

@[entry]
@[entry_bonus_91]
func runtime_entry_91() -> u64 {
    if (decorated_order_91(5) != 17) { return 10; }

    var hook: HookDecorated91 = HookDecorated91 { 0 };
    hook.hp = 9;
    if (hook.hp != 10) { return 20; }

    var pair: PairMagicDecorated91;
    pair.a = 7;
    pair.b = 3;
    if (hash(pair) != 15) { return 30; }
    if (pair.hash() != 15) { return 31; }

    return 40;
}

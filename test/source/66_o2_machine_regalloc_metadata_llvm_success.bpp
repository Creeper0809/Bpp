// Covers: O2 native machine IR and production regalloc contract metadata
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.machine_ir.engine=isel-schedule-regalloc-input
// Expect llvm metadata contains: bpp.ssa.machine_ir.addr=x86_64-addressing-mode
// Expect llvm metadata contains: bpp.ssa.machine_ir.branch=compare-test-setcc
// Expect llvm metadata contains: bpp.ssa.machine_ir.abi=stack-redzone-save-policy
// Expect llvm metadata contains: bpp.ssa.machine_ir.diff=llvm-native-semantic-summary
// Expect llvm metadata contains: bpp.ssa.regalloc3.engine=live-interval-spill-remat-coalesce
// Expect llvm metadata contains: bpp.ssa.regalloc3.classes=gpr-xmm-fixed-callclobber
// Expect llvm metadata contains: bpp.ssa.regalloc3.stack=spill-slot-coloring
// Expect llvm metadata contains: bpp.ssa.regalloc3.fallback=diagnostic-safe-path
// Expect llvm metadata contains: machine_ir=
// Expect llvm metadata contains: regalloc3=
// Expect exit code: 0

func o2_machine_regalloc_leaf(x: u64, y: u64) -> u64 {
    return (x * 3) + y;
}

func o2_machine_regalloc_probe(seed: u64) -> u64 {
    var acc: u64 = 1;
    for (var i: u64 = 0; i < 8; i = i + 1) {
        acc = o2_machine_regalloc_leaf(acc + i, seed);
    }
    if (acc == 0) { return 1; }
    return 0;
}

func main() -> u64 {
    return o2_machine_regalloc_probe(5);
}

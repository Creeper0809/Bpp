func add3(a: u64, b: u64 = 7, c: u64 = 11) -> u64 {
    return a + b + c;
}

func variadic_head_sum(head: u64, ...rest: u64) -> u64 {
    return head + rest;
}

struct PointEx109 {
    public x: u64;
    public y: u64;
}

impl PointEx109 {
    public constructor(x: u64, y: u64 = 5) {
        self.x = x;
        self.y = y;
    }
}

struct CalcEx109 {
}

impl CalcEx109 {
    public static func add(a: u64, b: u64 = 40) -> u64 {
        return a + b;
    }
}

struct NamedArgsBox109 {
    public v: u64;
}

impl NamedArgsBox109 {
    public func set(self: *NamedArgsBox109, a: u64, b: u64 = 10, c: u64 = 1) -> u64 {
        self.v = a + b + c;
        return self.v;
    }
}

func main() -> u64 {
    var a: u64 = add3(1);
    var b: u64 = add3(1, c: 100, b: 10);
    var c: u64 = add3(a: 5, c: 1);

    if (a != 19) { return 10; }
    if (b != 111) { return 11; }
    if (c != 13) { return 12; }

    var v0: u64 = variadic_head_sum(9);
    var v1: u64 = variadic_head_sum(9, 4);
    var v2: u64 = variadic_head_sum(9, 4, 88, 99);

    if (v0 != 9) { return 20; }
    if (v1 != 13) { return 21; }
    if (v2 != 13) { return 22; }

    var p0: PointEx109 = PointEx109(2);
    var p1: PointEx109 = PointEx109(y: 9, x: 3);
    if (p0.x != 2 || p0.y != 5) { return 30; }
    if (p1.x != 3 || p1.y != 9) { return 31; }

    var sv0: u64 = CalcEx109.add(2);
    var sv1: u64 = CalcEx109.add(b: 39, a: 3);
    if (sv0 != 42) { return 40; }
    if (sv1 != 42) { return 41; }

    var box: NamedArgsBox109 = NamedArgsBox109 { 0 };
    var r0: u64 = box.set(1, 10, 1);
    var r1: u64 = box.set(c: 2, a: 3, b: 4);
    var r2: u64 = box.set(a: 5, c: 6);
    if (r0 != 12) { return 50; }
    if (r1 != 9) { return 51; }
    if (r2 != 21) { return 52; }

    return 0;
}

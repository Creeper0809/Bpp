struct MaybeU64Case156 {
    public is_some: bool;
    public value: u64;
}

func maybe_inc_case156(x: MaybeU64Case156) -> MaybeU64Case156 {
    var v: u64 = x?;
    return MaybeU64Case156 { true, v + 1 };
}

func main() -> u64 {
    var ok_in: MaybeU64Case156 = MaybeU64Case156 { true, 41 };
    var ok_out: MaybeU64Case156 = maybe_inc_case156(ok_in);
    if (ok_out.is_some == 0) { return 1; }
    if (ok_out.value != 42) { return 2; }

    var none_in: MaybeU64Case156 = MaybeU64Case156 { false, 9 };
    var none_out: MaybeU64Case156 = maybe_inc_case156(none_in);
    if (none_out.is_some != 0) { return 3; }
    if (none_out.value != 9) { return 4; }
    return 0;
}

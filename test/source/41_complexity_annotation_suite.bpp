// Expect exit code: 0

@[complexity(time="O(n log n)", space="O(n)")]
@[complexity_input(n="len(arr)", m="len(edges)")]
@[complexity_budget(time="O(n^2)", space="O(n)")]
@[complexity_debug]
@[constraints(n=200000, m=300000, t=10)]
@[time_limit(ms=2000, machine="ref_v1")]
func score_complexity_annotations(arr_n: u64, edges_m: u64) -> u64 {
    var i: u64 = 1;
    var acc: u64 = 0;
    while (i < arr_n) {
        acc = acc + i;
        i = i << 1;
    }
    if (edges_m > 0) {
        acc = acc + edges_m;
    }
    return acc;
}

@[complexity_ignore(reason="legacy tuned by benchmark only")]
@[constraints(n=100000)]
@[time_limit(ms=500)]
func ignored_contract_fn(n: u64) -> u64 {
    var i: u64 = 0;
    var sum: u64 = 0;
    while (i < n) {
        sum = sum + i;
        i = i + 1;
    }
    return sum;
}

@[complexity(time="O(n^3)", space="O(1)")]
@[complexity_budget(time="O(2*n^3)", space="O(1)")]
@[constraints(n=40)]
@[time_limit(ms=2000, machine="ref_v1")]
func floyd_style_relax(n: u64) -> u64 {
    var acc: u64 = 0;
    var k: u64 = 0;
    while (k < n) {
        var i: u64 = 0;
        while (i < n) {
            var j: u64 = 0;
            while (j < n) {
                acc = acc + ((i + j + k) & 3);
                j = j + 1;
            }
            i = i + 1;
        }
        k = k + 1;
    }
    return acc;
}

@[complexity(time="O(2^n)", space="O(n)")]
@[complexity_budget(time="O(2^n)", space="O(n)")]
@[constraints(n=12)]
@[time_limit(ms=2000, machine="ref_v1")]
func fib_style(n: u64) -> u64 {
    if (n <= 1) { return 1; }
    return fib_style(n - 1) + fib_style(n - 2);
}

@[complexity_budget(time="O(2*n log log n)", space="O(n)")]
@[complexity_debug]
@[constraints(n=200000)]
@[time_limit(ms=2000, machine="ref_v1")]
func sieve_style_count(n: u64) -> u64 {
    if (n < 2) { return 0; }
    var mark: [200001]u8;
    var i: u64 = 2;
    var cnt: u64 = 0;
    while (i * i <= n) {
        if (mark[i] == 0) {
            var j: u64 = i * i;
            while (j <= n) {
                mark[j] = 1;
                j += i;
            }
        }
        i += 1;
    }
    var k: u64 = 2;
    while (k <= n) {
        if (mark[k] == 0) { cnt += 1; }
        k += 1;
    }
    return cnt;
}

@[complexity_budget(time="O(2*(v+e))", space="O(1)")]
@[constraints(v=100000, e=200000)]
@[time_limit(ms=2000, machine="ref_v1")]
func graph_linear_scan(v: u64, e: u64) -> u64 {
    var acc: u64 = 0;
    var i: u64 = 0;
    while (i < v) {
        acc += (i & 1);
        i += 1;
    }
    var j: u64 = 0;
    while (j < e) {
        acc += (j & 1);
        j += 1;
    }
    return acc;
}

@[complexity_budget(time="O(log n)", space="O(1)")]
@[constraints(n=1048576)]
@[time_limit(ms=100, machine="ref_v1")]
@[complexity_debug]
func geometric_count(n: u64) -> u64 {
    var cnt: u64 = 0;
    for (var i: u64 = 1; i < n; i = i << 1) {
        cnt += 1;
    }
    return cnt;
}

@[complexity_budget(time="O(2*n*log(n))", space="O(1)")]
@[constraints(n=200000)]
@[time_limit(ms=400, machine="ref_v1")]
@[complexity_debug]
func nested_linear_geometric(n: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        for (var j: u64 = 1; j < n; j = j << 1) {
            acc += (j & 1);
        }
        i += 1;
    }
    return acc;
}

@[complexity_budget(time="O(3*v*e)", space="O(1)")]
@[constraints(v=30000, e=30000)]
@[time_limit(ms=13000, machine="ref_v1")]
@[complexity_debug]
func ve_nested(v: u64, e: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < v) {
        var j: u64 = 0;
        while (j < e) {
            acc += ((i + j) & 1);
            j += 1;
        }
        i += 1;
    }
    return acc;
}

@[complexity_budget(time="O(3*v*log(e))", space="O(1)")]
@[constraints(v=120000, e=1048576)]
@[time_limit(ms=30, machine="ref_v1")]
@[complexity_debug]
func ve_log_nested(v: u64, e: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < v) {
        for (var j: u64 = 1; j < e; j = j << 1) {
            acc += (j & 1);
        }
        i += 1;
    }
    return acc;
}

@[complexity_budget(time="O(2*sqrt(p))", space="O(1)")]
@[constraints(p=100000000)]
@[time_limit(ms=50, machine="ref_v1")]
@[complexity_debug]
func pollard_rho_expected_like(p: u64) -> u64 {
    var i: u64 = 1;
    var steps: u64 = 0;
    while (i * i < p) {
        steps += 1;
        i += 1;
    }
    return steps;
}

func gcd_u64(a: u64, b: u64) -> u64 {
    var x: u64 = a;
    var y: u64 = b;
    while (y != 0) {
        var t: u64 = x % y;
        x = y;
        y = t;
    }
    return x;
}

func rho_next(x: u64, c: u64, n: u64) -> u64 {
    return ((x * x) + c) % n;
}

@[complexity_budget(time="O(2*n^(1/4))", space="O(1)")]
@[constraints(n=100000000)]
@[time_limit(ms=200, machine="ref_v1")]
@[complexity_debug]
func pollard_rho_once(n: u64, seed: u64, c: u64) -> u64 {
    if ((n & 1) == 0) { return 2; }

    var x: u64 = seed % n;
    if (x == 0) { x = 2; }
    var y: u64 = x;
    var d: u64 = 1;
    var iter: u64 = 0;

    while (d == 1) {
        if (iter >= 200000) { return 0; }
        x = rho_next(x, c, n);
        y = rho_next(y, c, n);
        y = rho_next(y, c, n);

        var diff: u64 = 0;
        if (x >= y) { diff = x - y; }
        else { diff = y - x; }

        d = gcd_u64(diff, n);
        iter += 1;
    }

    if (d == n) { return 0; }
    return d;
}

func pollard_rho_factor(n: u64) -> u64 {
    var c: u64 = 1;
    while (c <= 8) {
        var seed: u64 = c + 1;
        var f: u64 = pollard_rho_once(n, seed, c);
        if (f > 1 && f < n) { return f; }
        c += 1;
    }
    return 0;
}

@[complexity(time="O(m)", space="O(1)", mode="worst")]
@[complexity_budget(time="O(4*m)", space="O(1)", mode="worst")]
@[constraints(n=100, m=100000, rel1="m<=n^2")]
@[time_limit(ms=1, machine="ref_v1", ops_per_ms=100000)]
@[complexity_debug]
func constrained_linear(n: u64, m: u64) -> u64 {
    var i: u64 = 0;
    var s: u64 = 0;
    while (i < m) {
        s += (i & 1);
        i += 1;
    }
    return s + n;
}

@[complexity_budget(time="O(log n)", space="O(1)", mode="worst")]
@[constraints(n=1048576)]
@[complexity_debug]
func rec_halve(n: u64) -> u64 {
    if (n <= 1) { return 1; }
    return rec_halve(n >> 1) + 1;
}

@[complexity_budget(time="O(8*(n*m + n*log(p) + k))", space="O(1)", mode="worst")]
@[constraints(n=64, m=64, k=1024, p=1048576)]
@[time_limit(ms=50, machine="ref_v1")]
@[complexity_debug]
func multivar_four_symbols(n: u64, m: u64, k: u64, p: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        var j: u64 = 0;
        while (j < m) {
            acc += ((i + j) & 1);
            j += 1;
        }

        var t: u64 = 1;
        while (t < p) {
            acc += (t & 1);
            t = t << 1;
        }
        i += 1;
    }

    var u: u64 = 0;
    while (u < k) {
        acc += (u & 1);
        u += 1;
    }
    return acc;
}

@[complexity_budget(time="O(4*k)", space="O(1)")]
@[constraints(n=256, m=128, rel1="k<=n*m")]
@[time_limit(ms=100, machine="ref_v1")]
@[complexity_debug]
func relation_derived_bound(k: u64) -> u64 {
    var i: u64 = 0;
    var s: u64 = 0;
    while (i < k) {
        s += (i & 1);
        i += 1;
    }
    return s;
}

@[complexity_budget(time="O(6*(n*m + k*log(p) + q))", space="O(1)", mode="worst")]
@[constraints(n=32, m=48, k=64, p=65536, q=128)]
@[time_limit(ms=80, machine="ref_v1")]
@[complexity_debug]
func five_var_mixed(n: u64, m: u64, k: u64, p: u64, q: u64) -> u64 {
    var acc: u64 = 0;

    var i: u64 = 0;
    while (i < n) {
        var j: u64 = 0;
        while (j < m) {
            acc += ((i + j) & 1);
            j += 1;
        }
        i += 1;
    }

    var t: u64 = 0;
    while (t < k) {
        var u: u64 = 1;
        while (u < p) {
            acc += (u & 1);
            u = u << 1;
        }
        t += 1;
    }

    var r: u64 = 0;
    while (r < q) {
        acc += (r & 1);
        r += 1;
    }
    return acc;
}

@[complexity_budget(time="O(4*t)", space="O(1)")]
@[constraints(n=256, p=64, q=32, rel1="k<=n*m", rel2="m<=p+q", rel3="t<=k+q")]
@[time_limit(ms=200, machine="ref_v1")]
@[complexity_debug]
func transitive_relation_bound(t: u64) -> u64 {
    var i: u64 = 0;
    var s: u64 = 0;
    while (i < t) {
        s += (i & 1);
        i += 1;
    }
    return s;
}

const DP_SENT = 18446744073709551615;

var fib_cache: [128]u64;
var fib_seen: [128]u64;
var fib_value: [128]u64;
var grid_cache: [32][32]u64;

@[complexity_budget(time="O(8*n)", space="O(n)")]
@[constraints(n=120)]
@[time_limit(ms=100, machine="ref_v1")]
@[complexity_debug]
func fib_memo(n: u64) -> u64 {
    if (fib_cache[n] != DP_SENT) {
        return fib_cache[n];
    }
    if (n <= 1) {
        fib_cache[n] = n;
        return n;
    }
    var v: u64 = fib_memo(n - 1) + fib_memo(n - 2);
    fib_cache[n] = v;
    return v;
}

@[complexity_budget(time="O(8*n)", space="O(n)")]
@[constraints(n=120)]
@[time_limit(ms=100, machine="ref_v1")]
@[complexity_debug]
func fib_memo_flexible(n: u64) -> u64 {
    if (fib_cache[n] == DP_SENT) {
        if (n <= 1) {
            fib_cache[n] = n;
        } else {
            var a: u64 = fib_memo_flexible(n - 1);
            var b: u64 = fib_memo_flexible(n - 2);
            fib_cache[n] = a + b;
        }
    } else {
        var cached: u64 = fib_cache[n];
        if (cached >= 0) {
            return fib_cache[n];
        }
    }
    return fib_cache[n];
}

@[complexity_budget(time="O(4*n*m)", space="O(n*m)")]
@[constraints(n=32, m=32)]
@[time_limit(ms=150, machine="ref_v1")]
@[complexity_debug]
func grid_paths_memo(i: u64, j: u64) -> u64 {
    if (grid_cache[i][j] != DP_SENT) {
        return grid_cache[i][j];
    }
    if (i == 0 || j == 0) {
        grid_cache[i][j] = 1;
        return 1;
    }
    var v: u64 = grid_paths_memo(i - 1, j) + grid_paths_memo(i, j - 1);
    grid_cache[i][j] = v;
    return v;
}

func fib_seen_query(n: u64) -> u64 {
    return fib_seen[n];
}

@[complexity_budget(time="O(8*n)", space="O(n)", memo_state="n", memo_transition="O(1)")]
@[constraints(n=120)]
@[time_limit(ms=100, machine="ref_v1")]
@[complexity_debug]
func fib_memo_hint(n: u64) -> u64 {
    if (fib_seen_query(n) == 0) {
        fib_seen[n] = 1;
        if (n <= 1) {
            fib_value[n] = n;
        } else {
            fib_value[n] = fib_memo_hint(n - 1) + fib_memo_hint(n - 2);
        }
    }
    return fib_value[n];
}

func rand() -> u64 {
    return 4;
}

func fast_rand32() -> u64 {
    return rand();
}

@[complexity(time="O(n)", space="O(1)")]
@[constraints(n=2048)]
func helper_linear(n: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        acc += (i & 1);
        i += 1;
    }
    return acc;
}

@[complexity(time="O(n)", space="O(1)")]
@[constraints(n=2048)]
func probe_target(n: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        acc += (i & 1);
        i += 1;
    }
    return acc;
}

@[complexity(time="O(n^3)", space="O(1)")]
@[constraints(n=128)]
func other__probe_target(a: u64, b: u64, c: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < a) {
        var j: u64 = 0;
        while (j < b) {
            var k: u64 = 0;
            while (k < c) {
                acc += ((i + j + k) & 1);
                k += 1;
            }
            j += 1;
        }
        i += 1;
    }
    return acc;
}

@[complexity_budget(time="O(2*n^2)", space="O(1)")]
@[constraints(n=128)]
@[complexity_debug]
func caller_overload_probe(n: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        acc += probe_target(n);
        i += 1;
    }
    return acc;
}

@[complexity(time="O(n)", space="O(1)")]
@[constraints(n=4096)]
func named_shape_target(n: u64, step: u64 = 1) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        acc += (i & step);
        i += 1;
    }
    return acc;
}

@[complexity(time="O(n^3)", space="O(1)")]
@[constraints(n=64)]
func other__named_shape_target(k: u64, n: u64 = 1) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < k) {
        var j: u64 = 0;
        while (j < n) {
            var t: u64 = 0;
            while (t < n) {
                acc += ((i + j + t) & 1);
                t += 1;
            }
            j += 1;
        }
        i += 1;
    }
    return acc;
}

@[complexity_budget(time="O(3*n^2)", space="O(1)")]
@[constraints(n=512)]
@[complexity_debug]
func caller_named_shape_probe(n: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        acc += named_shape_target(n: n);
        i += 1;
    }
    return acc;
}

struct ComplexityProbeWorker {
    public seed: u64;
}

impl ComplexityProbeWorker {
    @[complexity(time="O(n)", space="O(1)")]
    public func tick(self: *ComplexityProbeWorker, n: u64) -> u64 {
        var i: u64 = 0;
        var acc: u64 = self.seed;
        while (i < n) {
            acc += (i & 1);
            i += 1;
        }
        return acc;
    }
}

@[constraints(n=256)]
@[complexity_debug]
func caller__tick(n: u64) -> u64 {
    var worker: ComplexityProbeWorker = ComplexityProbeWorker { 1 };
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        // Ensure method call remains an external summary candidate.
        acc += worker.tick(n);
        i += 1;
    }
    return acc;
}

@[complexity_budget(time="O(n^2)", space="O(1)")]
@[constraints(n=512)]
@[complexity_debug]
func caller_interproc(n: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        acc += helper_linear(n);
        i += 1;
    }
    return acc;
}

@[complexity_budget(time="O(4*n)", space="O(1)", mode="expected")]
@[constraints(n=4096)]
@[complexity_debug]
func random_walk_like(n: u64) -> u64 {
    var i: u64 = 0;
    var x: u64 = 0;
    while (i < n) {
        x = x + (rand() & 1);
        i += 1;
    }
    return x;
}

@[complexity_budget(time="O(4*n)", space="O(1)", mode="expected")]
@[constraints(n=4096)]
@[complexity_debug]
func random_walk_wrapper_like(n: u64) -> u64 {
    var i: u64 = 0;
    var x: u64 = 0;
    while (i < n) {
        x = x + (fast_rand32() & 1);
        i += 1;
    }
    return x;
}

@[complexity_budget(time="O(8*(log(n)^2))", space="O(1)")]
@[constraints(n=1048576)]
@[complexity_debug]
func polylog_nested(n: u64) -> u64 {
    var acc: u64 = 0;
    for (var i: u64 = 1; i < n; i = i << 1) {
        for (var j: u64 = 1; j < n; j = j << 1) {
            acc += 1;
        }
    }
    return acc;
}

@[complexity_budget(time="O(1)", space="O(1)")]
@[complexity_debug]
func zero_iter_for_known() -> u64 {
    var acc: u64 = 0;
    for (var i: u64 = 10; i < 5; i = i + 1) {
        acc += 1;
    }
    return acc;
}

func main() -> u64 {
    var v: u64 = score_complexity_annotations(64, 10);
    if (v == 0) { return 1; }
    var w: u64 = ignored_contract_fn(16);
    if (w != 120) { return 2; }

    var a1: u64 = floyd_style_relax(8);
    if (a1 == 0) { return 3; }
    var b1: u64 = fib_style(10);
    if (b1 != 89) { return 4; }
    var c1: u64 = sieve_style_count(1000);
    if (c1 != 168) { return 5; }
    var d1: u64 = graph_linear_scan(1000, 2000);
    if (d1 == 0) { return 6; }

    var g: u64 = geometric_count(1024);
    if (g != 10) { return 7; }
    var nlg: u64 = nested_linear_geometric(64);
    if (nlg == 0) { return 8; }
    var ve: u64 = ve_nested(32, 48);
    if (ve == 0) { return 9; }
    var vel: u64 = ve_log_nested(64, 1024);
    if (vel == 0) { return 10; }
    var pr: u64 = pollard_rho_expected_like(1024);
    if (pr != 31) { return 11; }

    var n: u64 = 8051;
    var f: u64 = pollard_rho_factor(n);
    if (f == 0 || f == 1 || f == n) { return 12; }
    if ((n % f) != 0) { return 13; }
    var q: u64 = n / f;
    if (q <= 1) { return 14; }
    if (q * f != n) { return 15; }

    var cl: u64 = constrained_linear(16, 64);
    if (cl == 0) { return 16; }
    var rh: u64 = rec_halve(1024);
    if (rh != 11) { return 17; }

    var mv4: u64 = multivar_four_symbols(8, 12, 32, 1024);
    if (mv4 == 0) { return 18; }
    var rd: u64 = relation_derived_bound(20);
    if (rd != 10) { return 19; }

    var mv5: u64 = five_var_mixed(8, 12, 16, 1024, 20);
    if (mv5 == 0) { return 20; }
    var tr: u64 = transitive_relation_bound(1000);
    if (tr != 500) { return 21; }

    for (var i: u64 = 0; i < 128; i = i + 1) {
        fib_cache[i] = DP_SENT;
        fib_seen[i] = 0;
        fib_value[i] = 0;
    }
    for (var r: u64 = 0; r < 32; r = r + 1) {
        for (var c: u64 = 0; c < 32; c = c + 1) {
            grid_cache[r][c] = DP_SENT;
        }
    }

    var fm: u64 = fib_memo(20);
    if (fm != 6765) { return 22; }
    var gp: u64 = grid_paths_memo(8, 7);
    if (gp != 6435) { return 23; }

    for (var t: u64 = 0; t < 128; t = t + 1) {
        fib_cache[t] = DP_SENT;
    }
    var ff: u64 = fib_memo_flexible(20);
    if (ff != 6765) { return 24; }

    for (var t2: u64 = 0; t2 < 128; t2 = t2 + 1) {
        fib_seen[t2] = 0;
        fib_value[t2] = 0;
    }
    var fh: u64 = fib_memo_hint(20);
    if (fh != 6765) { return 25; }

    if (fib_memo(20) != 6765) { return 26; }
    if (grid_paths_memo(8, 7) != 6435) { return 27; }
    if (fib_memo_flexible(20) != 6765) { return 28; }
    if (fib_memo_hint(20) != 6765) { return 29; }

    var ci: u64 = caller_interproc(20);
    var cns: u64 = caller_named_shape_probe(20);
    var cmt: u64 = caller__tick(20);
    var rw: u64 = random_walk_like(100);
    var rw_wrap: u64 = random_walk_wrapper_like(100);
    var ov: u64 = caller_overload_probe(20);
    if (ci == 0 && cns == 0 && cmt == 0 && rw == 0 && rw_wrap == 0 && ov == 0) { return 30; }


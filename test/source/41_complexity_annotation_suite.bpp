// Expect exit code: 0

@[complexity(time="O(n log n)", space="O(n)")]
@[complexity_input(n="len(arr)", m="len(edges)")]
@[complexity_budget(time="O(n^2)", space="O(n)")]
@[complexity_debug]
@[constraints(n=200000, m=300000, t=10)]
@[time_limit(ms=2000, machine="ref_v1")]
func score_complexity_annotations(arr_n: u64, edges_m: u64) -> u64 {
    var i: u64 = 1;
    var acc: u64 = 0;
    while (i < arr_n) {
        acc = acc + i;
        i = i << 1;
    }
    if (edges_m > 0) {
        acc = acc + edges_m;
    }
    return acc;
}

@[complexity_ignore(reason="legacy tuned by benchmark only")]
@[constraints(n=100000)]
@[time_limit(ms=500)]
func ignored_contract_fn(n: u64) -> u64 {
    var i: u64 = 0;
    var sum: u64 = 0;
    while (i < n) {
        sum = sum + i;
        i = i + 1;
    }
    return sum;
}

func main() -> u64 {
    var v: u64 = score_complexity_annotations(64, 10);
    if (v == 0) { return 1; }
    var w: u64 = ignored_contract_fn(16);
    if (w != 120) { return 2; }
    return 0;
}

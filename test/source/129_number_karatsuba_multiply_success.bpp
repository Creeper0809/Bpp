// Mode: ssa|nossa
// Opt: O0|O1
// Expect exit code: 0

func main() -> u64 {
    var one: number = 1;
    var zero: number = 0;
    var p900: number = one << 900;
    var p870: number = one << 870;
    var p1770: number = one << 1770;

    var a: number = p900 + 1;
    var b: number = p870 + 3;
    var prod: number = a * b;
    var expected: number = p1770 + p900 + p900 + p900 + p870 + 3;
    if (prod != expected) { return 1; }

    var neg_a: number = zero - a;
    var neg_prod: number = neg_a * b;
    if ((neg_prod + prod) != 0) { return 2; }

    var times8_expected: number = (one << 903) + 8;
    if ((a * 8) != times8_expected) { return 3; }
    var eight: number = 8;
    if ((eight * a) != times8_expected) { return 4; }
    if ((8 * a) != times8_expected) { return 5; }

    return 0;
}

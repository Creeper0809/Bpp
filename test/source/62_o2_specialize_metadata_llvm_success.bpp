// Covers: O2 integrated inliner/specializer/devirtualizer cost model
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.specialize.engine=inline-generic-constarg-devirt
// Expect llvm metadata contains: bpp.ssa.specialize.cost=hotness-size-allocation-call
// Expect llvm metadata contains: bpp.ssa.specialize.shape=monomorphic-direct-call
// Expect llvm metadata contains: bpp.ssa.specialize.budget=function-module-generic
// Expect llvm metadata contains: bpp.ssa.specialize.report=debug-opt-benchmark
// Expect llvm metadata contains: spec_inline=
// Expect llvm metadata contains: spec_devirt=
// Expect exit code: 0

func o2_spec_leaf(x: u64) -> u64 {
    return x + 11;
}

func o2_spec_probe(seed: u64) -> u64 {
    var hot: u64 = bpp_profile_hot_from_threshold(64, 32);
    var fast: u64 = bpp_fast_path_for_shape_len(BPP_TAG_SHAPE_U64, hot, 1, sizeof(u64), 8);
    var a: u64 = o2_spec_leaf(seed);
    if (fast != BPP_FAST_PATH_VECTOR) { return 1; }
    if (a != seed + 11) { return 2; }
    return 0;
}

func main() -> u64 {
    return o2_spec_probe(4);
}

// Expect error contains: generic bound not satisfied

trait NeedRun {
    func run(self: *Self, x: u64) -> u64;
}

struct NoRun {
    public v: u64;
}

func call_run<T>(obj: *T, x: u64) -> u64 where T: NeedRun {
    return obj.run(x);
}

func main() -> u64 {
    return call_run<NoRun>(new NoRun { 0 }, 1);
}

// Covers: complexity contract preserved on decorated public SSA surface
// Mode: ssa
// Opt: O1
// Expect exit code: 0

@[complexity(time="O(n)", space="O(1)")]
func deco_linear_surface_ok_93(next: u64, n: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        acc = acc + 1;
        i = i + 1;
    }
    return next(n) + acc;
}

@[deco_linear_surface_ok_93]
@[complexity(time="O(n)", space="O(1)")]
@[complexity_budget(time="O(2*n)", space="O(1)")]
@[constraints(n=64)]
@[complexity_debug]
func decorated_linear_surface_ok_93(n: u64) -> u64 {
    return 1;
}

func main() -> u64 {
    if (decorated_linear_surface_ok_93(5) != 6) { return 1; }
    return 0;
}

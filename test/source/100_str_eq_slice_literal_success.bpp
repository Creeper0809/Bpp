// Covers: str_eq over []u8 slices, including full literals and partial ranges
// Mode: ssa|nossa
// Opt: O0|O1
// Expect exit code: 0

import std.str;

func main() -> u64 {
    var name: u64 = (u64)"time_limit(extra)";
    var other: u64 = (u64)"time_limit(extra)";
    var base_len: u64 = 10;

    if (str_eq(slice(name, base_len), "time_limit") == 0) { return 1; }
    if (str_eq(slice(name, 4), "time_limit") != 0) { return 2; }
    if (str_eq(slice(name + 5, 5), "limit") == 0) { return 3; }
    if (str_eq(slice(name, 16), slice(other, 16)) == 0) { return 4; }
    return 0;
}

// Covers: O1 loop2 optimizer metadata and LLVM build handoff on a small counted loop
// Mode: ssa
// Opt: O1
// Compiler args: -O1
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.loop2.info=recognized
// Expect llvm metadata contains: bpp.ssa.loop2.verify=cfg-phi-checked
// Expect llvm metadata contains: bpp.ssa.loop2.preheader.inserted=planned-safe
// Expect llvm metadata contains: bpp.ssa.loop2.lcssa=lite-candidate
// Expect llvm metadata contains: bpp.ssa.loop2.licm.hoist=candidate
// Expect llvm metadata contains: bpp.ssa.loop2.licm.load=memoryssa-guarded
// Expect llvm metadata contains: bpp.ssa.loop2.iv.canonical=scev-lite
// Expect llvm metadata contains: bpp.ssa.loop2.trip_count=bounded
// Expect llvm metadata contains: bpp.ssa.loop2.strength_reduce=affine-iv
// Expect llvm metadata contains: bpp.ssa.loop2.bounds_elim=range-proof
// Expect llvm metadata contains: bpp.ssa.loop2.unswitch=budgeted
// Expect llvm metadata contains: bpp.ssa.loop2.peel=first-iteration
// Expect llvm metadata contains: bpp.ssa.loop2.unroll=threshold
// Expect llvm metadata contains: bpp.ssa.loop2.reduction=recognized
// Expect llvm metadata contains: bpp.ssa.loop2.vector_candidate=contiguous
// Expect exit code: 0

func loop2_counted_sum(n: u64, flag: u64) -> u64 {
    var i: u64 = 0;
    var sum: u64 = 0;
    var invariant: u64 = flag + 3;
    while (i < n) {
        var scaled: u64 = i * 8;
        var carried: u64 = invariant + 5;
        if (flag != 0) {
            sum = sum + scaled + carried;
        } else {
            sum = sum + scaled;
        }
        i = i + 1;
    }
    return sum;
}

func main() -> u64 {
    if (loop2_counted_sum(4, 1) != 84) { return 1; }
    if (loop2_counted_sum(4, 0) != 48) { return 2; }
    return 0;
}

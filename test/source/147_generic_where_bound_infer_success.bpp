trait Incrementable {
    func inc(self: *Self, x: u64) -> u64;
}

struct IncBox {
    public bias: u64;
}

impl Incrementable for IncBox {
    public func inc(self: *IncBox, x: u64) -> u64 {
        return x + self.bias;
    }
}

func apply_inc<T>(obj: *T, x: u64) -> u64 where T: Incrementable {
    return obj.inc(x);
}

func main() -> u64 {
    if (apply_inc<IncBox>(new IncBox { 2 }, 40) != 42) { return 1; }
    return 0;
}

// Covers: imaginary suffix literals lower to number complex values
// Mode: ssa|nossa
// Opt: O0|O1
// LLVM Build: true
// Expect exit code: 0

func expect_i64_138(v: number, expected: i64, code: u64) -> u64 {
    if (v.to_i64_checked_value() != expected) { return code; }
    return 0;
}

func expect_scaled_f64_138(v: number, scale: f64, expected: i64, code: u64) -> u64 {
    var scaled: f64 = v.to_f64_lossy() * scale;
    var got: i64 = (i64)scaled;
    if (got != expected) { return code; }
    return 0;
}

func main() -> u64 {
    var z: number = 76 + 7i;
    var zr: number = z.real_part();
    var zi: number = z.imag_part();
    var rc: u64 = expect_i64_138(zr, 76, 1);
    if (rc != 0) { return rc; }
    rc = expect_i64_138(zi, 7, 2);
    if (rc != 0) { return rc; }

    var w: number = 1.5 + 2.25i;
    var wr: number = w.real_part();
    var wi: number = w.imag_part();
    rc = expect_scaled_f64_138(wr, 100.0, 150, 3);
    if (rc != 0) { return rc; }
    rc = expect_scaled_f64_138(wi, 100.0, 225, 4);
    if (rc != 0) { return rc; }

    var neg: number = -7i;
    var neg_i: number = neg.imag_part();
    rc = expect_i64_138(neg_i, -7, 5);
    if (rc != 0) { return rc; }

    var product: number = 2 * 3i;
    var product_r: number = product.real_part();
    var product_i: number = product.imag_part();
    rc = expect_i64_138(product_r, 0, 6);
    if (rc != 0) { return rc; }
    rc = expect_i64_138(product_i, 6, 7);
    if (rc != 0) { return rc; }

    return 0;
}

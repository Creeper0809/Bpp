// Expect exit code: 0

func pow2_number(exp: u64) -> number {
    var x: number = 1;
    for (var i: u64 = 0; i < exp; i = i + 1) {
        number_add_assign(&x, &x);
    }
    return x;
}

func main() -> u64 {
    var x: number = 40;
    var y: number = -2;
    var z: number = number_add_values(&x, &y);
    if (z != 38) { return 1; }

    var a: number = x + 5;
    if (a != 45) { return 6; }
    var b: number = 5 + x;
    if (b != 45) { return 7; }
    var c: number = x - 12;
    if (c != 28) { return 8; }
    var e: number = x * 3;
    if (e != 120) { return 9; }
    var e2: number = 3 * x;
    if (e2 != 120) { return 10; }
    var f: number = -3 + x;
    if (f != 37) { return 11; }
    if (f < 37) { return 12; }
    if (f > 37) { return 13; }
    if (f <= 36) { return 14; }
    if (f >= 38) { return 15; }
    if (37 != f) { return 16; }
    if (36 >= f) { return 17; }
    if (38 <= f) { return 18; }

    var q1: number = x / 6;
    if (q1 != 6) { return 19; }
    var r1: number = x % 6;
    if (r1 != 4) { return 20; }
    var q2: number = 120 / x;
    if (q2 != 3) { return 21; }
    var r2: number = 121 % x;
    if (r2 != 1) { return 22; }

    // 2^90 exceeds 64-bit range.
    var big: number = pow2_number(90);
    var expected: number = pow2_number(90);
    if (big != expected) { return 2; }

    var p89a: number = pow2_number(89);
    var reduced: number = number_sub_values(&big, &p89a);
    var p89b: number = pow2_number(89);
    if (reduced != p89b) { return 3; }

    var qbig: number = big / 8;
    var p87: number = pow2_number(87);
    if (qbig != p87) { return 23; }
    var rbig: number = big % 8;
    if (rbig != 0) { return 24; }
    var mneg: number = -10;
    var neg_mod: number = mneg % 6;
    if (neg_mod != -4) { return 25; }

    var zero: number = 0;
    var neg: number = number_sub_values(&zero, &big);
    if (neg >= 0) { return 4; }

    var five: number = 5;
    var plus5: number = number_add_values(&big, &five);
    var minus5: number = number_sub_values(&plus5, &five);
    if (minus5 != big) { return 5; }
    return 0;
}

// LLVM Build: true
// Expect exit code: 0

func pow2_number(exp: u64) -> number {
    var x: number = 1;
    for (var i: u64 = 0; i < exp; i = i + 1) {
        x = x + x;
    }
    return x;
}

func main() -> u64 {
    var x: number = 40;
    var y: number = -2;
    var z: number = x + y;
    if (z != 38) { return 1; }

    var a: number = x + 5;
    if (a != 45) { return 6; }
    var b: number = 5 + x;
    if (b != 45) { return 7; }
    var c: number = x - 12;
    if (c != 28) { return 8; }
    var e: number = x * 3;
    if (e != 120) { return 9; }
    var e2: number = 3 * x;
    if (e2 != 120) { return 10; }
    var f: number = -3 + x;
    if (f != 37) { return 11; }
    if (f < 37) { return 12; }
    if (f > 37) { return 13; }
    if (f <= 36) { return 14; }
    if (f >= 38) { return 15; }
    if (37 != f) { return 16; }
    if (36 >= f) { return 17; }
    if (38 <= f) { return 18; }

    var q1: number = x / 6;
    if (q1 != 6) { return 19; }
    var r1: number = x % 6;
    if (r1 != 4) { return 20; }
    var q2: number = 120 / x;
    if (q2 != 3) { return 21; }
    var r2: number = 121 % x;
    if (r2 != 1) { return 22; }
    var bw_and: number = 13 & 6;
    if (bw_and != 4) { return 26; }
    var bw_or: number = 13 | 6;
    if (bw_or != 15) { return 27; }
    var bw_xor: number = 13 ^ 6;
    if (bw_xor != 11) { return 28; }
    var shl1: number = 5 << 3;
    if (shl1 != 40) { return 29; }
    var shr1: number = 40 >> 3;
    if (shr1 != 5) { return 30; }
    var shr_neg: number = -5 >> 1;
    if (shr_neg != -3) { return 31; }
    var not5: number = ~5;
    if (not5 != -6) { return 32; }

    var si: i64 = -77;
    var ui: u64 = 123;
    var from_si: number = si;
    var from_ui: number = ui;
    if (from_si != -77) { return 33; }
    if (from_ui != 123) { return 34; }
    var mix1: number = from_si + si;
    if (mix1 != -154) { return 35; }
    var mix2: number = from_ui + ui;
    if (mix2 != 246) { return 36; }
    var assigned: number = 0;
    assigned = si;
    if (assigned != -77) { return 46; }
    assigned = ui;
    if (assigned != 123) { return 47; }

    // 2^90 exceeds 64-bit range.
    var big: number = pow2_number(90);
    var expected: number = pow2_number(90);
    if (big != expected) { return 2; }

    var p89a: number = pow2_number(89);
    var reduced: number = big - p89a;
    var p89b: number = pow2_number(89);
    if (reduced != p89b) { return 3; }

    var qbig: number = big / 8;
    var p87: number = pow2_number(87);
    if (qbig != p87) { return 23; }
    var rbig: number = big % 8;
    if (rbig != 0) { return 24; }
    var mneg: number = -10;
    var neg_mod: number = mneg % 6;
    if (neg_mod != -4) { return 25; }

    var big_or: number = big | 1;
    if ((big_or - big) != 1) { return 37; }
    var big_and: number = big_or & big;
    if (big_and != big) { return 38; }
    var big_shr: number = big >> 70;
    var p20: number = pow2_number(20);
    if (big_shr != p20) { return 39; }
    var big_shl: number = p20 << 70;
    if (big_shl != big) { return 40; }
    var bitnot_identity: number = (~big) + big;
    if (bitnot_identity != -1) { return 41; }

    var s_big: u64 = big.to_str();
    var parsed_big: number = number_from_str(s_big, 28);
    if (parsed_big != big) { return 42; }

    var checked_i64: i64 = 0;
    if (x.to_i64_checked(&checked_i64) == 0) { return 43; }
    if (checked_i64 != 40) { return 44; }
    if (big.to_i64_checked(&checked_i64) != 0) { return 45; }

    var zero: number = 0;
    var neg: number = zero - big;
    if (neg >= 0) { return 4; }

    var five: number = 5;
    var plus5: number = big + five;
    var minus5: number = plus5 - five;
    if (minus5 != big) { return 5; }
    return 0;
}

// Expect exit code: 0

func pow2_number(exp: u64) -> number {
    var x: number = 1;
    for (var i: u64 = 0; i < exp; i = i + 1) {
        number_add_assign(&x, &x);
    }
    return x;
}

func main() -> u64 {
    var x: number = 40;
    var y: number = -2;
    var z: number = number_add_values(&x, &y);
    if (number_cmp_i64_ptr(&z, 38) != 0) { return 1; }

    // 2^90 exceeds 64-bit range.
    var big: number = pow2_number(90);
    var expected: number = pow2_number(90);
    if (number_eq_ptr(&big, &expected) == 0) { return 2; }

    var p89a: number = pow2_number(89);
    var reduced: number = number_sub_values(&big, &p89a);
    var p89b: number = pow2_number(89);
    if (number_eq_ptr(&reduced, &p89b) == 0) { return 3; }

    var zero: number = 0;
    var neg: number = number_sub_values(&zero, &big);
    if (number_cmp_i64_ptr(&neg, 0) >= 0) { return 4; }

    var five: number = 5;
    var plus5: number = number_add_values(&big, &five);
    var minus5: number = number_sub_values(&plus5, &five);
    if (number_eq_ptr(&minus5, &big) == 0) { return 5; }
    return 0;
}

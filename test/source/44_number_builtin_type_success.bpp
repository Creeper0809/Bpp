// Expect exit code: 0

func add_number(a: number, b: number) -> number {
    return a + b;
}

func main() -> u64 {
    var x: number = 40;
    var y: number = 2;
    var z: number = add_number(x, y);
    if (z != 42) { return 1; }

    var s: u64 = sizeof(number);
    if (s != 8) { return 2; }

    var n: number = (number)7;
    if (n != 7) { return 3; }
    return 0;
}

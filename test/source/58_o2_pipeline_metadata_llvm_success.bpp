// Expect exit code: 0

func o2_small_helper(x: u64) -> u64 {
    return (x * 3) + 1;
}

func o2_pipeline_probe(n: u64) -> u64 {
    var acc: u64 = 0;
    for (var i: u64 = 0; i < n; i = i + 1) {
        acc = acc + o2_small_helper(i);
    }
    if (acc != 22) { return 1; }
    return 0;
}

func main() -> u64 {
    return o2_pipeline_probe(4);
}

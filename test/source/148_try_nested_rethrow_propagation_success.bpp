func main() -> u64 {
    var x: u64 = 0;
    try {
        x = x + 1;
        try {
            x = x + 10;
            throw 23;
            x = x + 1000;
        } finally {
            x = x + 100;
        }
        x = x + 10000;
    } catch (e: u64) {
        x = x + e;
    }

    if (x != 134) { return 1; }
    return 0;
}

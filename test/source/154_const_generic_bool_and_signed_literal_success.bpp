func const_flag<const B: bool>() -> u64 {
    return 1;
}

func const_i32_tag<const N: i32>() -> i32 {
    return (i32)sizeof(i32);
}

func main() -> u64 {
    var t: u64 = const_flag<true>();
    var f: u64 = const_flag<false>();
    if (t != 1 || f != 1) { return 1; }

    var a: i32 = const_i32_tag<-7>();
    var b: i32 = const_i32_tag<12>();
    if (a != 4) { return 2; }
    if (b != 4) { return 3; }
    return 0;
}

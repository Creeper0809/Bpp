// Covers: O2 IPA emits deterministic summary-cache boundaries for non-recursive propagation
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.ipa.propagation=nonrecursive-aggressive-summary
// Expect llvm metadata contains: bpp.ssa.ipa.cache=deterministic-summary-key
// Expect llvm metadata contains: bpp.ssa.ipa.cache=std-prelude-user-split
// Expect llvm metadata contains: ipa_cache=
// Expect exit code: 0

func o2_ipa_cache_leaf(x: u64) -> u64 {
    return x + 1;
}

func o2_ipa_cache_probe(seed: u64) -> u64 {
    var a: u64 = o2_ipa_cache_leaf(seed);
    var b: u64 = o2_ipa_cache_leaf(a);
    if (b != seed + 2) { return 1; }
    return 0;
}

func main() -> u64 {
    return o2_ipa_cache_probe(40);
}

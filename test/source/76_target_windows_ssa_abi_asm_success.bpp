// Compiler args: --target windows-x86_64
// Compile only: true
// LLVM Build: true
// Mode: ssa
// Expect asm contains: abi_probe_ssa:
// Expect asm contains: mov [rbp-1032], rcx
// Expect asm contains: mov [rbp-1040], rdx
// Expect asm contains: mov [rbp-1048], r8
// Expect asm contains: mov [rbp-1056], r9

func abi_probe_ssa(a: u64, b: u64, c: u64, d: u64) -> u64 {
    var x: u64 = a + b;
    var y: u64 = c + d;
    return x + y;
}

func main() -> u64 {
    return abi_probe_ssa(1, 2, 3, 4);
}

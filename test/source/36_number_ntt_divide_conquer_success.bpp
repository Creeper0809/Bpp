// Covers: Number NTT multiplication and divide-and-conquer large division
// Mode: nossa,ssa
// Opt: O1
// LLVM Build: true
// Expect exit code: 0

func pow2_number_case132(exp: u64) -> number {
    var x: number = 1;
    for (var i: u64 = 0; i < exp; i = i + 1) {
        x = x + x;
    }
    return x;
}

func main() -> u64 {
    var zero: number = 0;
    var p3400: number = pow2_number_case132(3400);
    var p2800: number = pow2_number_case132(2800);
    var p2200: number = pow2_number_case132(2200);
    var p1600: number = pow2_number_case132(1600);
    var p900: number = pow2_number_case132(900);

    var a: number = p3400 + p1600 + 123;
    var b: number = p2800 + p900 + 77;
    var prod: number = a * b;
    var expected_prod: number =
        pow2_number_case132(6200) +
        pow2_number_case132(4300) +
        (p3400 * 77) +
        pow2_number_case132(4400) +
        pow2_number_case132(2500) +
        (p1600 * 77) +
        (p2800 * 123) +
        (p900 * 123) +
        9471;
    if (prod != expected_prod) { return 1; }

    var divisor: number = p2200 + pow2_number_case132(1300) + 33;
    var dividend: number = prod + pow2_number_case132(5000) + 98765;
    var q: number = dividend / divisor;
    var r: number = dividend % divisor;
    if ((q * divisor + r) != dividend) { return 2; }
    if (r < zero) { return 3; }
    if (r >= divisor) { return 4; }

    return 0;
}

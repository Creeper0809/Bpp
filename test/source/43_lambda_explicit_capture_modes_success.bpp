func lambda_non_capture_checks() -> u64 {
    var f: u64 = func (x: u64) -> u64 { x + 2 };
    var g: u64 = func (x: u64, y: u64) -> u64 { x * y };

    var a: u64 = f(40);
    var b: u64 = g(6, 7);
    if (a != 42) { return 1; }
    if (b != 42) { return 2; }
    return 0;
}

func lambda_capture_check() -> u64 {
    var base: u64 = 5;
    var add: u64 = func (x: u64) -> u64 { x + base };
    if (add(37) != 42) { return 3; }
    return 0;
}

func lambda_ref_from_param(x: u64) -> u64 {
    var by_ref: u64 = func [&x] () -> u64 { x + 1 };
    x = x + 40;
    return by_ref();
}

func lambda_explicit_capture_modes_check() -> u64 {
    var v_ref: u64 = lambda_ref_from_param(1);
    if (v_ref != 42) { return 4; }

    var y: u64 = 7;
    var by_val: u64 = func [y] () -> u64 { y + 1 };
    y = 100;
    if (by_val() != 8) { return 5; }
    if (y != 100) { return 6; }
    return 0;
}

func lambda_block_body_multi_stmt_check() -> u64 {
    var f: u64 = func (x: u64) -> u64 {
        x = x + 2;
        x = x + 3;
        return x;
    };

    var g: u64 = func (x: u64) -> u64 {
        x = x + 5;
        x + 7
    };

    if (f(37) != 42) { return 7; }
    if (g(30) != 42) { return 8; }
    return 0;
}

func lambda_closure_handle_copy_check() -> u64 {
    var x: u64 = 1;
    var a: u64 = func () -> u64 { x };
    var b: u64 = a;
    if (b() != 1) { return 9; }
    return 0;
}

func main() -> u64 {
    var c1: u64 = lambda_non_capture_checks();
    if (c1 != 0) { return c1; }

    var c2: u64 = lambda_capture_check();
    if (c2 != 0) { return c2; }

    var c3: u64 = lambda_explicit_capture_modes_check();
    if (c3 != 0) { return c3; }

    var c4: u64 = lambda_block_body_multi_stmt_check();
    if (c4 != 0) { return c4; }

    return lambda_closure_handle_copy_check();
}

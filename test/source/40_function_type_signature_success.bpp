struct FuncBox {
    public cb: func (u64) -> u64;
}

trait Incrementable139 {
    func inc(self: *Self, x: u64) -> u64;
}

trait AssocRun139 {
    alias Item;
    func run(self: *Self, x: u64) -> u64;
}

trait RunTrait40 {
    func run(self: *Self, x: u64) -> u64;
}

struct IncBox139 {
    public bias: u64;
}

struct AssocRunBox139 {
    public bias: u64;
}

struct DecoratedCounter139 {
    public value: u64;
}

struct Runner40 {
    public v: u64;
}

func plus_one_value_139(v: u64) -> u64 {
    return v + 1;
}

func apply_once(cb: func (u64) -> u64, x: u64) -> u64 {
    return cb(x);
}

func apply_many(cb: func (u64, ...u64) -> u64) -> u64 {
    return cb(10, 20, 30);
}

func sum_head(head: u64, ...rest: u64) -> u64 {
    return head + rest;
}

func driver_variance_139(cb: func (i64) -> i64) -> u64 {
    return (u64)cb((i64)41);
}

impl Incrementable139 for IncBox139 {
    public func inc(self: *IncBox139, x: u64) -> u64 {
        return x + self.bias;
    }
}

func apply_inc_139<T>(obj: *T, x: u64) -> u64 where T: Incrementable139 {
    return obj.inc(x);
}

impl AssocRun139<Item=u64> for AssocRunBox139 {
    public func run(self: *AssocRunBox139, x: u64) -> u64 {
        return x + self.bias;
    }
}

func apply_assoc_run_139<T>(obj: *T, x: u64) -> u64 where T: AssocRun139<Item=u64> {
    return obj.run(x);
}

func deco_add_one_139(next: u64, x: u64) -> u64 {
    return next(x) + 1;
}

@[deco_add_one_139]
func decorated_double_139(x: u64) -> u64 {
    return x * 2;
}

func deco_plus_one_139(next: u64, x: u64) -> u64 {
    return next(x) + 1;
}

@[deco_plus_one_139]
func decorated_twice_139<T>(x: T) -> T {
    return x + x;
}

func add_one_method_139(next: u64, self: *DecoratedCounter139, x: u64) -> u64 {
    return next(self, x) + 1;
}

impl DecoratedCounter139 {
    @[add_one_method_139]
    public func push(self: *DecoratedCounter139, x: u64) -> u64 {
        self.value = self.value + x;
        return self.value;
    }
}

func plus_one_trait_40(next: u64, self: *Runner40, x: u64) -> u64 {
    return next(self, x) + 1;
}

impl RunTrait40 for Runner40 {
    @[plus_one_trait_40]
    public func run(self: *Runner40, x: u64) -> u64 {
        self.v = x;
        return self.v;
    }
}

func main() -> u64 {
    var f: func (u64) -> u64 = plus_one_value_139;
    if (f(41) != 42) { return 1; }

    var box: FuncBox = FuncBox { f };
    if (box.cb(41) != 42) { return 2; }

    if (apply_once(f, 41) != 42) { return 3; }

    var vf: func (u64, ...u64) -> u64 = sum_head;
    if (apply_many(vf) != 30) { return 4; }

    var c: func (u64) -> u64 = func (x: u64) -> u64 { x + 1 };
    var direct: u64 = driver_variance_139(c);
    if (direct != 42) { return 10; }

    var d: func (func (i64) -> i64) -> u64 = driver_variance_139;
    var out: u64 = d(c);
    if (out != 42) { return 11; }

    if (apply_inc_139<IncBox139>(new IncBox139 { 2 }, 40) != 42) { return 20; }

    var ar: AssocRunBox139 = AssocRunBox139 { 2 };
    if (apply_assoc_run_139(&ar, 40) != 42) { return 30; }

    if (decorated_double_139(20) != 41) { return 40; }
    if (decorated_double_139(0) != 1) { return 41; }

    var gv: u64 = decorated_twice_139<u64>(20);
    if (gv != 41) { return 42; }

    var dc: DecoratedCounter139 = DecoratedCounter139 { 0 };
    if (dc.push(41) != 42) { return 43; }
    if (dc.value != 41) { return 44; }

    var r: Runner40 = Runner40 { 0 };
    var rv: u64 = r.run(1);
    if (rv != 2) { return 45; }
    if (r.v != 1) { return 46; }

    return 0;
}

// Covers: O2 proof tracks edge refinement, join widening, and exposes rewrite consumer metadata
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.proof.flow=block-edge-refine-widen-state
// Expect llvm metadata contains: bpp.ssa.o2.passdeps=dom-loop-memoryssa-alias-range
// Expect llvm metadata contains: proof_refine=
// Expect llvm metadata contains: proof_join=
// Expect llvm metadata contains: proof_success=
// Expect exit code: 0

struct O2ProofFlowBox {
    public value: u64;
    public guard: u64;
}

func o2_proof_flow_readonly_helper(flag: u64) -> u64 {
    if (flag == 0) { return 11; }
    return 17;
}

func o2_proof_flow_consumer_probe(flag: u64) -> u64 {
    var box: O2ProofFlowBox = O2ProofFlowBox{0, 7};
    box.value = 30;
    if (flag == 0) {
        box.value = box.value + 1;
    } else {
        box.value = box.value + 5;
    }
    var h: u64 = o2_proof_flow_readonly_helper(flag);
    var got: u64 = box.value;
    if (box.guard != 7) { return 1; }
    if (h == 0) { return 2; }
    if (flag == 0 && got != 31) { return 3; }
    if (flag != 0 && got != 35) { return 4; }
    return 0;
}

func main() -> u64 {
    return o2_proof_flow_consumer_probe(1);
}

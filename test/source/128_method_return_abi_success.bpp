// Expect exit code: 0
// LLVM Build: true

struct MethodSmall128 {
    public a: u64;
    public b: u64;
}

struct MethodBig128 {
    public a: u64;
    public b: u64;
    public c: u64;
}

struct MethodMaker128 {
    public base: u64;
    public data: [4]u8;
}

impl MethodMaker128 {
    public func small(self: *MethodMaker128, add: u64) -> MethodSmall128 {
        return MethodSmall128{self.base + add, self.base + add + 1};
    }

    public func small_again(self: *MethodMaker128) -> MethodSmall128 {
        return self.small(10);
    }

    public func big(self: *MethodMaker128, add: u64) -> MethodBig128 {
        return MethodBig128{
            self.base + add,
            self.base + add + 1,
            self.base + add + 2
        };
    }

    public func big_again(self: *MethodMaker128) -> MethodBig128 {
        return self.big(20);
    }

    public func bytes(self: *MethodMaker128) -> []u8 {
        return slice(&self.data[1], 2);
    }
}

func take_small128(v: MethodSmall128) -> u64 {
    return v.a + v.b;
}

func take_big128(v: MethodBig128) -> u64 {
    return v.a + v.b + v.c;
}

func main() -> u64 {
    var m: MethodMaker128;
    m.base = 100;
    m.data[0] = 1;
    m.data[1] = 7;
    m.data[2] = 9;
    m.data[3] = 11;

    var s: MethodSmall128 = m.small_again();
    if (s.a != 110 || s.b != 111) { return 1; }

    var b: MethodBig128 = m.big_again();
    if (b.a != 120 || b.b != 121 || b.c != 122) { return 2; }

    var direct: MethodSmall128 = m.small(3);
    if (direct.a != 103 || direct.b != 104) { return 3; }

    if (m.small(4).b != 105) { return 4; }

    var bs: []u8 = m.bytes();
    if ((u64)bs[0] + (u64)bs[1] + bs.len != 18) { return 5; }

    if (take_small128(m.small(6)) != 213) { return 6; }
    if (take_big128(m.big(7)) != 324) { return 7; }

    return 0;
}

// Covers: O2 target-independent vector IR planning and reduction metadata
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.vector_ir.engine=target-independent-simd-plan
// Expect llvm metadata contains: bpp.ssa.vector_ir.legal=alignment-alias-contiguous-tripcount
// Expect llvm metadata contains: bpp.ssa.vector_ir.tail=scalar-cleanup-masked-tail
// Expect llvm metadata contains: bpp.ssa.vector_ir.reduction=horizontal
// Expect llvm metadata contains: bpp.ssa.vector_ir.target=sse2-avx2-gated
// Expect llvm metadata contains: vector_plans=
// Expect llvm metadata contains: vector_fallbacks=
// Expect exit code: 0

func o2_vector_ir_probe() -> u64 {
    var values: [4]u64;
    values[0] = 1;
    values[1] = 2;
    values[2] = 3;
    values[3] = 4;
    var tagged_values: BppTaggedSlice<u64> = bpp_tag_slice_from_ptr<u64>(&values[0], 4, BPP_TAG_SHAPE_U64);
    if (bpp_tag_slice_sum_u64(&tagged_values) != 10) { return 1; }
    return 0;
}

func main() -> u64 {
    return o2_vector_ir_probe();
}

struct NullPtrBox {
    public value: u64;
}

func null_guard_ptr(p: *NullPtrBox) -> u64 {
    if (p == null) { return 42; }
    return p.value;
}

func main() -> u64 {
    var p: *NullPtrBox = null;
    if (p != null) { return 1; }
    if (null_guard_ptr(p) != 42) { return 2; }

    var q: *NullPtrBox = new NullPtrBox { 42 };
    if (q == null) { return 3; }
    if (null_guard_ptr(q) != 42) { return 4; }
    return 0;
}

// Covers: std.io input() + stdin raw read + line read
// Stdin: alpha\nbeta\n123
// Expect exit code: 0
// LLVM Build: true

import std.io;
import std.str;

func main(argc: i64, argv: *u64) -> i64 {
    var line1: u64 = (u64)input();
    if (line1 == 0) { return 1; }
    if (str_eq(slice(line1, 5), "alpha") == 0) { return 2; }

    var line2_len: u64 = 0;
    var line2: u64 = (u64)input(16, &line2_len);
    if (line2 == 0) { return 3; }
    if (line2_len != 4) { return 4; }
    if (str_eq(slice(line2, line2_len), "beta") == 0) { return 5; }

    var buf: [4]u8;
    var raw_n: i64 = input_read(&buf[0], 3);
    if (raw_n != 3) { return 6; }
    if (str_eq(slice((u64)&buf[0], 3), "123") == 0) { return 7; }

    var eof_line: u64 = (u64)input();
    if (eof_line == 0) { return 8; }
    if (str_len(eof_line) != 0) { return 9; }

    return 0;
}

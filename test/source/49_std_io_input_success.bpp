// Covers: std.io stdin raw read + line read
// Stdin: alpha\nbeta\n123
// Expect exit code: 0

import std.io;
import std.str;

func main(argc: i64, argv: *u64) -> i64 {
    var line1_len: u64 = 99;
    var line1: u64 = io_read_line_stdin(16, &line1_len);
    if (line1 == 0) { return 1; }
    if (line1_len != 5) { return 2; }
    if (str_eq(line1, line1_len, "alpha", 5) == 0) { return 3; }

    var line2_len: u64 = 0;
    var line2: u64 = io_read_line_stdin(16, &line2_len);
    if (line2 == 0) { return 4; }
    if (line2_len != 4) { return 5; }
    if (str_eq(line2, line2_len, "beta", 4) == 0) { return 6; }

    var buf: [4]u8;
    var raw_n: i64 = io_read_stdin((u64)&buf[0], 3);
    if (raw_n != 3) { return 7; }
    if (str_eq((u64)&buf[0], 3, "123", 3) == 0) { return 8; }

    var eof_len: u64 = 77;
    var eof_line: u64 = io_read_line_stdin(8, &eof_len);
    if (eof_line == 0) { return 9; }
    if (eof_len != 0) { return 10; }

    return 0;
}

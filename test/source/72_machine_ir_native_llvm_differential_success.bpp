// Covers: machine IR local memory lowering agrees between native SSA and LLVM build
// Mode: ssa
// Opt: O1
// LLVM Build: true
// Expect exit code: 0

struct MachineIrDiffPair {
    public a: u64;
    public b: u64;
}

func machine_ir_diff_pair(a: u64, b: u64) -> u64 {
    var p: MachineIrDiffPair = MachineIrDiffPair{a, b};
    var acc: u64 = p.a;
    acc = acc + p.b;
    return acc;
}

func main() -> u64 {
    return machine_ir_diff_pair(19, 23) - 42;
}

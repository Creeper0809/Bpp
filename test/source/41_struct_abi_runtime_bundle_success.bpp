// -- bundled from 126_slice_field_member_success.bpp

struct SliceFieldBox {
    public bytes: []u8;
    public marker: u64;
}

var g_box: SliceFieldBox;

func check_box(box: SliceFieldBox, expected_ptr: u64, expected_len: u64) -> u64 {
    if (box.bytes.ptr != expected_ptr) { return 1; }
    if (box.bytes.len != expected_len) { return 2; }
    if (box.bytes[1] != 22) { return 3; }
    return 0;
}

func bundle_case__126_slice_field_member_success() -> u64 {
    var buf: [4]u8;
    buf[0] = 11;
    buf[1] = 22;
    buf[2] = 33;
    buf[3] = 44;

    var box: SliceFieldBox = SliceFieldBox{slice(&buf[0], 4), 99};
    if (box.bytes.ptr != (u64)&buf[0]) { return 10; }
    if (box.bytes.len != 4) { return 11; }
    if (box.bytes[2] != 33) { return 12; }

    box.bytes.len = 3;
    if (box.bytes.len != 3) { return 13; }

    g_box = SliceFieldBox{box.bytes, 77};
    if (g_box.bytes.ptr != box.bytes.ptr) { return 14; }
    if (g_box.bytes.len != 3) { return 15; }
    if (g_box.bytes[0] != 11) { return 16; }

    if (check_box(g_box, (u64)&buf[0], 3) != 0) { return 17; }
    return 0;
}

// -- bundled from 127_slice_field_arg_abi_success.bpp

struct SliceArgBox {
    public name: []u8;
    public alt: []u8;
    public marker: u64;
}

func expect_slice(value: []u8, ptr: u64, len: u64, first: u8, last: u8) -> u64 {
    if (value.ptr != ptr) { return 1; }
    if (value.len != len) { return 2; }
    if (value[0] != first) { return 3; }
    if (value[len - 1] != last) { return 4; }
    return 0;
}

func forward_slice(value: []u8) -> []u8 {
    return value;
}

func pick_name(box: *SliceArgBox) -> []u8 {
    return box.name;
}

func check_box_127(box: *SliceArgBox, ptr: u64, len: u64) -> u64 {
    if (expect_slice(box.name, ptr, len, 65, 68) != 0) { return 10; }

    var local: []u8 = box.name;
    if (expect_slice(local, ptr, len, 65, 68) != 0) { return 11; }

    box.alt = box.name;
    if (expect_slice(box.alt, ptr, len, 65, 68) != 0) { return 12; }

    var returned: []u8 = forward_slice(box.name);
    if (expect_slice(returned, ptr, len, 65, 68) != 0) { return 13; }

    var picked: []u8 = pick_name(box);
    if (expect_slice(picked, ptr, len, 65, 68) != 0) { return 14; }

    return 0;
}

func bundle_case__127_slice_field_arg_abi_success() -> u64 {
    var buf: [4]u8;
    buf[0] = 65;
    buf[1] = 66;
    buf[2] = 67;
    buf[3] = 68;

    var box: SliceArgBox;
    box.name = slice(&buf[0], 4);
    box.alt = slice(0, 0);
    box.marker = 99;


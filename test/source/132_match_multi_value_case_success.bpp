func classify_many(v: u64) -> u64 {
    match (v) {
        case 1, 2, 3:
            return 10;
        case 4, 5:
            return 20;
        case _:
            return 99;
    }
}

func main() -> u64 {
    if (classify_many(1) != 10) { return 1; }
    if (classify_many(3) != 10) { return 2; }
    if (classify_many(5) != 20) { return 3; }
    if (classify_many(9) != 99) { return 4; }
    return 0;
}

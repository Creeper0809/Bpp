// Expect error contains: setter hook function not found

struct HookFail210 {
    @[setter(missing_setter_210)]
    public hp: i32;
}

func main() -> u64 {
    var v: HookFail210 = HookFail210 { (i32)0 };
    v.hp = (i32)1;
    return (u64)v.hp;
}
//=== END


// Covers: O1/native peephole lowering for lea, test, zero idiom, and metadata bridge
// Mode: ssa
// Opt: O1
// Compiler args: -O1
// LLVM Build: true
// Expect asm contains:     lea 
// Expect asm contains:     test 
// Expect asm contains:     xor 
// Expect llvm metadata contains: bpp.ssa.peephole.mov=redundant-elided
// Expect llvm metadata contains: bpp.ssa.peephole.lea=add-immediate-lowered
// Expect llvm metadata contains: bpp.ssa.peephole.test=branch-zero-lowered
// Expect llvm metadata contains: bpp.ssa.peephole.zero_idiom=xor-emitted
// Expect llvm metadata contains: bpp.ssa.peephole.immediate=preferred-form
// Expect llvm metadata contains: bpp.ssa.peephole.mem_fold=guarded-load
// Expect llvm metadata contains: bpp.ssa.peephole.branch_layout=fallthrough-candidate
// Expect llvm metadata contains: bpp.ssa.peephole.call_save=live-register-candidate
// Expect llvm metadata contains: bpp.ssa.peephole.memcpy_inline=small-copy-candidate
// Expect exit code: 0

func o1_peephole_probe(a: u64) -> u64 {
    var zero: u64 = 0;
    var b: u64 = a + 5;
    if (b != 0) {
        return b + zero;
    }
    return zero;
}

func main() -> u64 {
    if (o1_peephole_probe(37) != 42) {
        return 1;
    }
    return 0;
}

// Compiler args: --target windows-x86_64
// Compile only: true
// LLVM Build: true
// Expect asm contains: _15_target_windows_call_shadow_asm_success__use_five:
// Expect asm contains: call _15_target_windows_call_shadow_asm_success__use_five
// Expect asm contains: sub rsp, 40
// Expect asm contains: add rsp, 48

func use_five(a: u64, b: u64, c: u64, d: u64, e: u64) -> u64 {
    return a + b + c + d + e;
}

func main() -> u64 {
    return use_five(1, 2, 3, 4, 5);
}

@[config]
var G_ANNOTATED_39: u64 = 40;

struct AnnBox39 {
}

impl AnnBox39 {
    @[trace]
    public static func add(a: u64, b: u64) -> u64 {
        return a + b;
    }
}

@[feature]
func sum_with_annotation_39(a: u64, b: u64) -> u64 {
    @[hot]
    var local_sum: u64 = a + b;
    return local_sum;
}

@[config(mode="fast", retries=2, enabled=true)]
func with_ann_args_39() -> u64 {
    @[local(meta(1, 2, 3))]
    var v: u64 = 42;
    return v;
}

func main() -> u64 {
    return 77;
}

@[entry]
func runtime_entry() -> u64 {
    var out: u64 = sum_with_annotation_39(G_ANNOTATED_39, 2);
    if (out != 42) { return 1; }
    if (AnnBox39.add(1, 1) != 2) { return 2; }
    if (with_ann_args_39() != 42) { return 3; }
    return 0;
}

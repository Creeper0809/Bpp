// Covers: successful time complexity annotation for the Sieve of Eratosthenes
// Expect exit code: 0
// LLVM Build: true

@[complexity(time="O(n log log n)", space="O(n)", mode="worst")]
@[complexity_budget(time="O(4*n log log n)", space="O(n)", mode="worst")]
@[constraints(n=1024)]
@[time_limit(ms=20, machine="ref_v1")]
@[complexity_debug]
func annotated_sieve_count(n: u64) -> u64 {
    if (n < 2) { return 0; }

    var composite: [1025]u8;
    var p: u64 = 2;
    while (p * p <= n) {
        if (composite[p] == 0) {
            var multiple: u64 = p * p;
            while (multiple <= n) {
                composite[multiple] = 1;
                multiple += p;
            }
        }
        p += 1;
    }

    var count: u64 = 0;
    var i: u64 = 2;
    while (i <= n) {
        if (composite[i] == 0) { count += 1; }
        i += 1;
    }
    return count;
}

func main() -> u64 {
    if (annotated_sieve_count(30) != 10) { return 1; }
    if (annotated_sieve_count(100) != 25) { return 2; }
    return 0;
}

// Bundled LLVM build conventional main and contract metadata fixture test.
// LLVM Build: true
// Covers: conventional main lowering and contract annotation families survive backend lowering and LLVM metadata handoff
// Expect llvm metadata contains: bpp.contract.condition
// Expect llvm metadata contains: bpp.contract.effects
// Expect llvm metadata contains: bpp.contract.ownership
// Expect llvm metadata contains: bpp.contract.memory
// Expect llvm metadata contains: bpp.contract.concurrency
// Expect llvm metadata contains: bpp.contract.abi
// Expect llvm metadata contains: bpp.contract.execution
// Expect exit code: 0

// -- bundled from 117_llvm_build_conventional_main_success.bpp

func helper_117(x: u64) -> u64 {
    if (x == 3) { return 7; }
    return 1;
}

func llvm_contract_main_bundle_case_117() -> u64 {
    var v: u64 = helper_117(3);
    if (v != 7) { return 1; }
    return 0;
}

// -- bundled from 122_llvm_build_contract_families_success.bpp

@[requires("n >= 0")]
@[ensures(expr="result >= n")]
@[invariant("buf != other")]
@[effects(io=false, alloc=false, throws=false, panic=false)]
@[pure]
@[no_alloc]
@[no_io]
@[no_throw]
@[no_panic]
@[takes_ownership("buf")]
@[returns_ownership]
@[borrows(param="other")]
@[moves("tmp")]
@[consumes("tmp")]
@[no_escape("buf")]
@[lifetime(value="buf", owner="caller")]
@[nonnull("buf")]
@[bounds(ptr="buf", len="n")]
@[aligned(ptr="buf", align=8)]
@[initialized("buf")]
@[no_alias("buf", "other")]
@[thread_safe]
@[requires_lock("mu")]
@[acquires_lock(lock="mu")]
@[releases_lock("mu")]
@[no_blocking]
@[atomic]
@[abi("sysv")]
@[calling_convention("sysv")]
@[repr("C")]
@[layout(size=24, align=8, packed=false)]
@[test]
@[bench]
@[timeout(ms=10)]
@[retry(count=1)]
@[memoize]
@[cache(key="n", ttl_ms=1000)]
@[transactional]
@[panic_policy("abort")]
func contract_surface_all_122(buf: u64, other: u64, n: u64) -> u64 {
    var tmp: u64 = buf + other;
    return tmp + n + 1;
}

func llvm_contract_main_bundle_case_122() -> u64 {
    if (contract_surface_all_122(10, 20, 11) != 42) { return 1; }
    return 0;
}

func main() -> u64 {
    if (llvm_contract_main_bundle_case_117() != 0) { return 117; }
    if (llvm_contract_main_bundle_case_122() != 0) { return 122; }
    return 0;
}

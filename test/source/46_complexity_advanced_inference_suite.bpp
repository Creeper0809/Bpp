// Expect exit code: 0

// Geometric loop without declared complexity: should infer O(log n).
@[complexity_budget(time="O(log n)", space="O(1)")]
@[constraints(n=1048576)]
@[time_limit(ms=100, machine="ref_v1")]
@[complexity_debug]
func geometric_count(n: u64) -> u64 {
    var cnt: u64 = 0;
    for (var i: u64 = 1; i < n; i = i << 1) {
        cnt += 1;
    }
    return cnt;
}

// Nested linear * geometric without declared complexity: should infer O(n log n).
@[complexity_budget(time="O(2*n*log(n))", space="O(1)")]
@[constraints(n=200000)]
@[time_limit(ms=400, machine="ref_v1")]
@[complexity_debug]
func nested_linear_geometric(n: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        for (var j: u64 = 1; j < n; j = j << 1) {
            acc += (j & 1);
        }
        i += 1;
    }
    return acc;
}

// Multi-variable nested loops: should be accepted as O(v*e).
@[complexity_budget(time="O(3*v*e)", space="O(1)")]
@[constraints(v=30000, e=30000)]
@[time_limit(ms=13000, machine="ref_v1")]
@[complexity_debug]
func ve_nested(v: u64, e: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < v) {
        var j: u64 = 0;
        while (j < e) {
            acc += ((i + j) & 1);
            j += 1;
        }
        i += 1;
    }
    return acc;
}

// Multi-variable mixed form: O(v * log(e)).
@[complexity_budget(time="O(3*v*log(e))", space="O(1)")]
@[constraints(v=120000, e=1048576)]
@[time_limit(ms=30, machine="ref_v1")]
@[complexity_debug]
func ve_log_nested(v: u64, e: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < v) {
        for (var j: u64 = 1; j < e; j = j << 1) {
            acc += (j & 1);
        }
        i += 1;
    }
    return acc;
}

// Pollard-rho style expected bound declaration: O(sqrt(p)).
// (Randomized algorithm 자체 자동 추론이 아니라, budget 식을 정량 평가한다.)
@[complexity_budget(time="O(2*sqrt(p))", space="O(1)")]
@[constraints(p=100000000)]
@[time_limit(ms=50, machine="ref_v1")]
@[complexity_debug]
func pollard_rho_expected_like(p: u64) -> u64 {
    var i: u64 = 1;
    var steps: u64 = 0;
    while (i * i < p) {
        steps += 1;
        i += 1;
    }
    return steps;
}

func main() -> u64 {
    var a: u64 = geometric_count(1024);
    if (a != 10) { return 1; }

    var b: u64 = nested_linear_geometric(64);
    if (b == 0) { return 2; }

    var c: u64 = ve_nested(32, 48);
    if (c == 0) { return 3; }

    var d: u64 = ve_log_nested(64, 1024);
    if (d == 0) { return 4; }

    var r: u64 = pollard_rho_expected_like(1024);
    if (r != 31) { return 5; }

    return 0;
}

// Expect exit code: 0

trait RunTrait {
    func run(self: *Self, x: u64) -> u64;
}

struct Runner {
    public v: u64;
}

func plus_one_trait(next: u64, self: *Runner, x: u64) -> u64 {
    return next(self, x) + 1;
}

impl RunTrait for Runner {
    @[plus_one_trait]
    public func run(self: *Runner, x: u64) -> u64 {
        self.v = x;
        return self.v;
    }
}

func main() -> u64 {
    var r: Runner = Runner { 0 };
    var v: u64 = r.run(1);
    if (v != 2) { return 1; }
    if (r.v != 1) { return 2; }
    return 0;
}

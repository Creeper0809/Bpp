// Mode: ssa
// Opt: O0,O1
// Expect exit code: 0

func gcd_parallel_101(a: u64, b: u64) -> u64 {
    var x: u64 = a;
    var y: u64 = b;
    while (y != 0) {
        var t: u64 = x % y;
        x = y;
        y = t;
    }
    return x;
}

func main() -> u64 {
    if (gcd_parallel_101(1071, 462) != 21) { return 1; }
    if (gcd_parallel_101(8051, 97) != 97) { return 2; }
    if (gcd_parallel_101(8051, 83) != 83) { return 3; }
    return 0;
}

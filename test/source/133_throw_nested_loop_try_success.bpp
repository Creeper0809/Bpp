func main() -> u64 {
    var x: u64 = 0;
    try {
        var i: u64 = 0;
        while (i < 3) {
            var j: u64 = 0;
            while (j < 3) {
                x = x + 1;
                if (i == 1 && j == 1) {
                    throw 99;
                }
                j = j + 1;
            }
            x = x + 100;
            i = i + 1;
        }
        x = x + 10000;
    } catch {
        x = x + 7;
    } finally {
        x = x + 1000;
    }

    if (x != 1112) { return 1; }
    return 0;
}

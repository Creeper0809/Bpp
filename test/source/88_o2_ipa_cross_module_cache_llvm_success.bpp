// Covers: O2 IPA records deterministic summary-cache metadata across an imported helper module
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.ipa.propagation=nonrecursive-aggressive-summary
// Expect llvm metadata contains: bpp.ssa.ipa.cache=deterministic-summary-key
// Expect llvm metadata contains: bpp.ssa.ipa.cache=std-prelude-user-split
// Expect llvm metadata contains: ipa_cache=
// Expect exit code: 0

import modules.mod_b;

func o2_ipa_cross_module_cache_probe() -> u64 {
    var got: u64 = make_and_read();
    if (got != 42) { return 1; }
    return 0;
}

func main() -> u64 {
    return o2_ipa_cross_module_cache_probe();
}

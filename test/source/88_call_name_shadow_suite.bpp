// Covers: function call name resolution when local variable has same identifier

//=== CASE 001_var_initializer_same_name_as_function
func size_of(n: u64) -> u64 {
    return n + 1;
}

func main() -> u64 {
    // Must resolve RHS as function call, not local variable call-ptr.
    var size_of: u64 = size_of(41);
    if (size_of != 42) { return 1; }
    return 0;
}
//=== END

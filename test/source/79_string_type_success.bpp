// LLVM Build: true
// Covers: owned string type, string literal/input<string>() prelude lowering, println, methods, and call args
// Mode: ssa|nossa
// Opt: O0|O1
// Stdin: typed\n
// Expect stdout: hello\ntyped\nxy!z\nok\nworld\n
// Expect exit code: 0

func expect_string_arg(value: string) -> u64 {
    if (value.len() != 5) { return 1; }
    println(value);
    return 0;
}

func main() -> u64 {
    var literal_value: string = "hello";
    if (literal_value.len() != 5) { return 1; }
    var literal_slice: []u8 = literal_value.as_slice();
    if (literal_slice[0] != 104) { return 2; }
    println(literal_value);

    var input_value: string = input<string>();
    if (input_value.len() != 5) { return 3; }
    println(input_value);

    var built: string = string_from_slice(slice("xy", 2));
    built.push((u8)33);
    built.append_cstr("z");
    var expected: string = "xy!z";
    if (string_eq(&built, &expected) == 0) { return 4; }
    println(built);

    var assigned: string;
    assigned = "ok";
    if (assigned.len() != 2) { return 5; }
    println(assigned);

    if (expect_string_arg("world") != 0) { return 6; }

    return 0;
}

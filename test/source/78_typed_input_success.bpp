// Covers: context-typed input() sugar across primitive, number, pointer, []u8, assignment, and call-arg contexts
// Stdin: 123456789012345678901234567890\n-42\n987\ntrue\n1.25\nhello\nptrline\n-7\n-11\n
// Expect exit code: 0

import std.str;

func expect_i64(value: i64) -> u64 {
    if (value != -11) { return 1; }
    return 0;
}

func main() -> u64 {
    var big: number = input();
    var expected: number = number_from_str("123456789012345678901234567890", 30);
    if (big != expected) { return 1; }

    var signed_value: i64 = input();
    if (signed_value != -42) { return 2; }

    var unsigned_value: u64 = input();
    if (unsigned_value != 987) { return 3; }

    var bool_value: bool = input();
    if (!bool_value) { return 4; }

    var float_value: f64 = input();
    if (float_value < 1.24) { return 5; }
    if (float_value > 1.26) { return 6; }

    var line: []u8 = input();
    if (line.len != 5) { return 7; }
    if (str_eq((u64)line.ptr, line.len, "hello", 5) == 0) { return 8; }

    var ptr_line: *u8 = input();
    if (str_eq((u64)ptr_line, 7, "ptrline", 7) == 0) { return 9; }

    var assigned: i32 = 0;
    assigned = input();
    if (assigned != -7) { return 10; }

    if (expect_i64(input()) != 0) { return 11; }

    return 0;
}

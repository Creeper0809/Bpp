// Covers: O2 MemorySSA2 MemoryPhi load forwarding across matching predecessors
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.memoryssa2.rewrite=memoryphi-load-forward
// Expect llvm metadata contains: memssa2_phi_forward=
// Expect exit code: 0

struct O2MemoryPhiBox {
    public value: u64;
    public guard: u64;
}

func o2_memoryssa2_memoryphi_forward_probe(x: u64, gate: u64) -> u64 {
    var box: O2MemoryPhiBox = O2MemoryPhiBox{0, 23};
    var v: u64 = x + 19;
    if (gate == 0) {
        box.value = v;
    } else {
        box.value = v;
    }
    var y: u64 = box.value;
    if (y != v) { return 1; }
    if (box.guard != 23) { return 2; }
    return 0;
}

func o2_memoryssa2_memoryphi_gate(seed: u64) -> u64 {
    var n: number = Number.from_str(slice("1", 1));
    if (n != 1) { return 0; }
    return seed;
}

func main() -> u64 {
    return o2_memoryssa2_memoryphi_forward_probe(41, o2_memoryssa2_memoryphi_gate(1));
}

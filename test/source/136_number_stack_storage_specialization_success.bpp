// Covers: number locals with fixed integer ranges keep Number semantics while using specialized primitive storage
// Mode: ssa|nossa
// Opt: O0|O1
// LLVM Build: true
// Expect exit code: 0

func expect_i64_136(v: number, expected: i64, code: u64) -> u64 {
    if (v.to_i64_checked_value() != expected) { return code; }
    return 0;
}

func main() -> u64 {
    var a: number = 7;
    var b: number = 300;
    var c: number = 70000;
    var d: number = 5000000000;
    var e: number = -8;
    var f: number = -32000;
    var g: number = -2000000000;
    var h: number = -5000000000;

    var sum: number = a + b + c + d + e + f + g + h;
    var rc: u64 = expect_i64_136(sum, -1999961701, 1);
    if (rc != 0) { return rc; }

    var method_receiver: number = 123;
    if (method_receiver.to_i64_checked_value() != 123) { return 2; }

    var assigned: number = 9;
    assigned = assigned + 1;
    if (assigned.to_i64_checked_value() != 10) { return 3; }

    return 0;
}

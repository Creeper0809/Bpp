// Covers: buffered numeric printers preserve ordering, raw emit/emitln flush pending text,
// and zero-arg print/println do not reuse stale call registers
// Mode: ssa|nossa
// Opt: O0|O1
// Expect exit code: 0
// Expect stdout: A42B\nmin=-9223372036854775808 done\n\nHello, World!\ntail

// LLVM Build: true

func main() -> u64 {
    print("A", 1);
    print_u64(42);
    emit("B");
    emit("\n");

    var min_i64: i64 = (i64)0 - (i64)9223372036854775807 - (i64)1;
    print("min=", 4);
    print_i64(min_i64);
    emitln(" done");

    println();
    print("Hello, World!");
    println();
    print();
    print("tail");
    return 0;
}

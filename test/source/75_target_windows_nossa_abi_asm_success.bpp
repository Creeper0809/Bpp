// Compiler args: --target windows-x86_64
// Compile only: true
// Mode: nossa
// Expect asm contains: abi_probe_nossa:
// Expect asm contains: mov [rbp-8], rcx
// Expect asm contains: mov [rbp-16], rdx
// Expect asm contains: mov [rbp-24], r8
// Expect asm contains: mov [rbp-32], r9

func abi_probe_nossa(a: u64, b: u64, c: u64, d: u64) -> u64 {
    return a + b + c + d;
}

func main() -> u64 {
    return abi_probe_nossa(1, 2, 3, 4);
}

// Covers: O1 roadmap2 metadata for sections 12-23
// Mode: ssa
// Opt: O1
// Compiler args: -O1
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.pm.pipeline=level-separated
// Expect llvm metadata contains: bpp.ssa.range.int=minmax
// Expect llvm metadata contains: bpp.ssa.ipa2.effects=pure-read-write-summary
// Expect llvm metadata contains: bpp.ssa.devirt.shape=call-target-proof
// Expect llvm metadata contains: bpp.ssa.simd.plan=vector-ir-candidate
// Expect llvm metadata contains: bpp.ssa.machine_ir=isel-stage
// Expect llvm metadata contains: bpp.ssa.incremental.key=content-option-hash
// Expect llvm metadata contains: bpp.ssa.memprofile.arena=pass-separated
// Expect llvm metadata contains: bpp.ssa.gc.safepoint=metadata
// Expect llvm metadata contains: bpp.ssa.cold.path=panic-bounds-bigint-alloc
// Expect llvm metadata contains: bpp.ssa.verify.framework=pre-post-pass
// Expect llvm metadata contains: bpp.ssa.optlevel.policy=o1-o2-o3-separated
// Expect exit code: 0

func roadmap2_helper(x: u64) -> u64 {
    return (x + 3) * 2;
}

func roadmap2_probe(n: u64) -> u64 {
    var acc: u64 = 0;
    for (var i: u64 = 0; i < n; i = i + 1) {
        acc = acc + roadmap2_helper(i);
    }
    if (acc != 24) { return 1; }
    return 0;
}

func main() -> u64 {
    return roadmap2_probe(3);
}

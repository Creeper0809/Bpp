// Mode: ssa
// Opt: O0,O1
// Expect exit code: 0

func pow2_number_case93(exp: u64) -> number {
    var x: number = 1;
    for (var i: u64 = 0; i < exp; i = i + 1) {
        x = x + x;
    }
    return x;
}

func main() -> u64 {
    var big: number = pow2_number_case93(90);
    var one: number = 1;
    var big_or: number = big | 1;

    if (big_or == big) { return 101; }

    var diff: number = big_or - big;
    if (diff == 0) { return 102; }
    if (diff != one) { return 103; }

    var big_and: number = big_or & big;
    if (big_and != big) { return 104; }

    return 0;
}

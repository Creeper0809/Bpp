// Covers: O2 loop3 simplify, SCEV-lite, rewrite candidates, and guard metadata
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.loop3.engine=simplify-lcssa-scev-rewrite
// Expect llvm metadata contains: bpp.ssa.loop3.form=preheader-dedicated-exit-lcssa
// Expect llvm metadata contains: bpp.ssa.loop3.scev=affine-trip-overflow
// Expect llvm metadata contains: bpp.ssa.loop3.rewrite=licm-strength-bounds-unswitch-peel-unroll
// Expect llvm metadata contains: bpp.ssa.loop3.guard=sideeffect-gc-budget
// Expect llvm metadata contains: bpp.ssa.loop3.actual.scev=affine-trip-overflow-checked
// Expect llvm metadata contains: bpp.ssa.loop3.actual.form=cfg-preheader-dedicated-exit-checked
// Expect llvm metadata contains: bpp.ssa.loop3.actual.rewrite=strength-reduction
// Expect llvm metadata contains: loop3_loops=
// Expect llvm metadata contains: loop3_rewrites=
// Expect exit code: 0

func o2_loop3_probe(n: u64) -> u64 {
    var acc: u64 = 0;
    var neg_acc: u64 = 0;
    for (var i: u64 = 0; i < n; i = i + 1) {
        acc = acc + (i * 2);
        neg_acc = neg_acc + (i * 18446744073709551615);
    }
    if (acc != 20) { return 1; }
    if (neg_acc != 18446744073709551606) { return 2; }
    return 0;
}

func main() -> u64 {
    return o2_loop3_probe(5);
}

// LLVM Build: true
// Expect llvm metadata contains: bpp.vector.lowering = tagged-slice-min-u64x4
// Expect llvm metadata contains: icmp ult <4 x i64>
// Expect llvm metadata contains: bpp.vector.lowering = tagged-slice-max-u64x4
// Expect llvm metadata contains: icmp ugt <4 x i64>
// Expect llvm metadata contains: bpp.vector.lowering = tagged-slice-min-i64x4
// Expect llvm metadata contains: icmp slt <4 x i64>
// Expect llvm metadata contains: bpp.vector.lowering = tagged-slice-max-i64x4
// Expect llvm metadata contains: icmp sgt <4 x i64>
// Expect llvm metadata contains: bpp.vector.lowering = tagged-slice-min-f64x4
// Expect llvm metadata contains: fcmp olt <4 x double>
// Expect llvm metadata contains: bpp.vector.lowering = tagged-slice-max-f64x4
// Expect llvm metadata contains: fcmp ogt <4 x double>
// Covers: LLVM vector lowering for tagged slice min/max reductions
// Expect exit code: 0

func main() -> u64 {
    var us: [9]u64;
    us[0] = 91;
    us[1] = 7;
    us[2] = 33;
    us[3] = 1;
    us[4] = 19;
    us[5] = 99;
    us[6] = 42;
    us[7] = 11;
    us[8] = 23;
    var su: BppTaggedSlice<u64> = bpp_tag_slice_from_ptr<u64>(&us[0], 9, BPP_TAG_SHAPE_U64);
    bpp_tag_slice_mark_profiled<u64>(&su);
    if (bpp_tag_slice_min_u64(&su) != 1) { return 1; }
    if (bpp_tag_slice_max_u64(&su) != 99) { return 2; }

    var is: [7]i64;
    is[0] = 8;
    is[1] = -11;
    is[2] = 4;
    is[3] = 42;
    is[4] = -3;
    is[5] = 6;
    is[6] = 17;
    var si: BppTaggedSlice<i64> = bpp_tag_slice_from_ptr<i64>(&is[0], 7, BPP_TAG_SHAPE_I64);
    bpp_tag_slice_mark_profiled<i64>(&si);
    if (bpp_tag_slice_min_i64(&si) != -11) { return 3; }
    if (bpp_tag_slice_max_i64(&si) != 42) { return 4; }

    var fs: [6]f64;
    fs[0] = 9.5;
    fs[1] = 1.25;
    fs[2] = 4.75;
    fs[3] = 6.5;
    fs[4] = 12.0;
    fs[5] = 2.5;
    var sf: BppTaggedSlice<f64> = bpp_tag_slice_from_ptr<f64>(&fs[0], 6, BPP_TAG_SHAPE_F64);
    bpp_tag_slice_mark_profiled<f64>(&sf);
    var min_scaled: i64 = (i64)(bpp_tag_slice_min_f64(&sf) * 100.0);
    var max_scaled: i64 = (i64)(bpp_tag_slice_max_f64(&sf) * 10.0);
    if (min_scaled != 125) { return 5; }
    if (max_scaled != 120) { return 6; }

    return 0;
}

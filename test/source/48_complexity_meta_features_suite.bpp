// Expect exit code: 0

@[complexity(time="O(m)", space="O(1)", mode="worst")]
@[complexity_budget(time="O(4*m)", space="O(1)", mode="worst")]
@[constraints(n=100, m=100000, rel1="m<=n^2")]
@[time_limit(ms=1, machine="ref_v1", ops_per_ms=100000)]
@[complexity_debug]
func constrained_linear(n: u64, m: u64) -> u64 {
    var i: u64 = 0;
    var s: u64 = 0;
    while (i < m) {
        s += (i & 1);
        i += 1;
    }
    return s + n;
}

@[complexity_budget(time="O(log n)", space="O(1)", mode="worst")]
@[constraints(n=1048576)]
@[complexity_debug]
func rec_halve(n: u64) -> u64 {
    if (n <= 1) { return 1; }
    return rec_halve(n >> 1) + 1;
}

func main() -> u64 {
    var a: u64 = constrained_linear(16, 64);
    if (a == 0) { return 1; }

    var b: u64 = rec_halve(1024);
    if (b != 11) { return 2; }

    return 0;
}

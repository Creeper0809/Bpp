// Expect exit code: 0

const DP_SENT = 18446744073709551615;

var fib_cache: [128]u64;
var fib_seen: [128]u64;
var fib_value: [128]u64;
var grid_cache: [32][32]u64;

@[complexity_budget(time="O(8*n)", space="O(n)")]
@[constraints(n=120)]
@[time_limit(ms=100, machine="ref_v1")]
@[complexity_debug]
func fib_memo(n: u64) -> u64 {
    if (fib_cache[n] != DP_SENT) {
        return fib_cache[n];
    }
    if (n <= 1) {
        fib_cache[n] = n;
        return n;
    }
    var v: u64 = fib_memo(n - 1) + fib_memo(n - 2);
    fib_cache[n] = v;
    return v;
}

@[complexity_budget(time="O(8*n)", space="O(n)")]
@[constraints(n=120)]
@[time_limit(ms=100, machine="ref_v1")]
@[complexity_debug]
func fib_memo_flexible(n: u64) -> u64 {
    if (fib_cache[n] == DP_SENT) {
        if (n <= 1) {
            fib_cache[n] = n;
        } else {
            var a: u64 = fib_memo_flexible(n - 1);
            var b: u64 = fib_memo_flexible(n - 2);
            fib_cache[n] = a + b;
        }
    } else {
        var cached: u64 = fib_cache[n];
        if (cached >= 0) {
            return fib_cache[n];
        }
    }
    return fib_cache[n];
}

@[complexity_budget(time="O(4*n*m)", space="O(n*m)")]
@[constraints(n=32, m=32)]
@[time_limit(ms=150, machine="ref_v1")]
@[complexity_debug]
func grid_paths_memo(i: u64, j: u64) -> u64 {
    if (grid_cache[i][j] != DP_SENT) {
        return grid_cache[i][j];
    }
    if (i == 0 || j == 0) {
        grid_cache[i][j] = 1;
        return 1;
    }
    var v: u64 = grid_paths_memo(i - 1, j) + grid_paths_memo(i, j - 1);
    grid_cache[i][j] = v;
    return v;
}

func fib_seen_query(n: u64) -> u64 {
    return fib_seen[n];
}

@[complexity_budget(time="O(8*n)", space="O(n)", memo_state="n", memo_transition="O(1)")]
@[constraints(n=120)]
@[time_limit(ms=100, machine="ref_v1")]
@[complexity_debug]
func fib_memo_hint(n: u64) -> u64 {
    if (fib_seen_query(n) == 0) {
        fib_seen[n] = 1;
        if (n <= 1) {
            fib_value[n] = n;
        } else {
            fib_value[n] = fib_memo_hint(n - 1) + fib_memo_hint(n - 2);
        }
    }
    return fib_value[n];
}

func main() -> u64 {
    for (var i: u64 = 0; i < 128; i = i + 1) {
        fib_cache[i] = DP_SENT;
        fib_seen[i] = 0;
        fib_value[i] = 0;
    }
    for (var r: u64 = 0; r < 32; r = r + 1) {
        for (var c: u64 = 0; c < 32; c = c + 1) {
            grid_cache[r][c] = DP_SENT;
        }
    }

    var f: u64 = fib_memo(20);
    if (f != 6765) { return 1; }

    var p: u64 = grid_paths_memo(8, 7);
    if (p != 6435) { return 2; }

    for (var t: u64 = 0; t < 128; t = t + 1) {
        fib_cache[t] = DP_SENT;
    }
    var f2: u64 = fib_memo_flexible(20);
    if (f2 != 6765) { return 3; }

    for (var t2: u64 = 0; t2 < 128; t2 = t2 + 1) {
        fib_seen[t2] = 0;
        fib_value[t2] = 0;
    }
    var f3: u64 = fib_memo_hint(20);
    if (f3 != 6765) { return 6; }

    // cache hit path
    if (fib_memo(20) != 6765) { return 3; }
    if (grid_paths_memo(8, 7) != 6435) { return 4; }
    if (fib_memo_flexible(20) != 6765) { return 5; }
    if (fib_memo_hint(20) != 6765) { return 7; }

    return 0;
}

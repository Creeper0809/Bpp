// Covers: number exact rational/decimal/bigfloat tower and complex equality semantics
// Mode: ssa|nossa
// Opt: O0|O1
// LLVM Build: true
// Expect exit code: 0

func expect_i64_139(v: number, expected: i64, code: u64) -> u64 {
    if (v.to_i64_checked_value() != expected) { return code; }
    return 0;
}

func expect_scaled_f64_139(v: number, scale: f64, expected: i64, code: u64) -> u64 {
    var scaled: f64 = v.to_f64_lossy() * scale;
    var got: i64 = (i64)scaled;
    if (got != expected) { return code; }
    return 0;
}

func expect_frac_139(v: number, num: i64, den: i64, code: u64) -> u64 {
    var rc: u64 = expect_i64_139(v.numerator(), num, code);
    if (rc != 0) { return rc; }
    return expect_i64_139(v.denominator(), den, code + 1);
}

func main() -> u64 {
    var half: number = Number.from_rational(1, 2);
    var third: number = Number.from_rational(1, 3);
    var sum: number = half + third;
    var rc: u64 = expect_frac_139(sum, 5, 6, 1);
    if (rc != 0) { return rc; }

    var quotient: number = half / third;
    rc = expect_frac_139(quotient, 3, 2, 3);
    if (rc != 0) { return rc; }

    var dec: number = Number.from_decimal(125, 2);
    var mix: number = dec + half;
    rc = expect_frac_139(mix, 7, 4, 5);
    if (rc != 0) { return rc; }

    var dec_mul: number = Number.from_decimal(25, 1) * half;
    rc = expect_frac_139(dec_mul, 5, 4, 7);
    if (rc != 0) { return rc; }

    var bf_int: number = Number.from_bigfloat(3, 10, 128);
    rc = expect_i64_139(bf_int, 3072, 9);
    if (rc != 0) { return rc; }

    var bf_frac: number = Number.from_bigfloat(1, -3, 128);
    rc = expect_frac_139(bf_frac, 1, 8, 10);
    if (rc != 0) { return rc; }

    var bf_sum: number = bf_frac + Number.from_rational(1, 8);
    rc = expect_frac_139(bf_sum, 1, 4, 12);
    if (rc != 0) { return rc; }
    rc = expect_scaled_f64_139(bf_sum, 1000.0, 250, 14);
    if (rc != 0) { return rc; }

    var z: number = 76 + 7i;
    if (z != Number.from_complex(76, 7)) { return 15; }
    if (z == Number.from_complex(76, 8)) { return 16; }

    return 0;
}

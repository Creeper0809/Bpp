// Covers: O1 trivial wrapper inlining, inlining cost model, and recursive/large guard metadata
// Mode: ssa
// Opt: O1
// Compiler args: -O1
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.inline.cost_model=small-function-budget
// Expect llvm metadata contains: bpp.ssa.inline.rewrite=trivial-wrapper
// Expect llvm metadata contains: bpp.ssa.inline.guard=recursive-large-bailout
// Expect llvm metadata contains: bpp.ssa.inline.small=candidate
// Expect llvm metadata contains: bpp.ssa.inline.const_arg=specialization-candidate
// Expect llvm metadata contains: bpp.ssa.inline.generic=o1-specialization-candidate
// Expect llvm metadata contains: bpp.ssa.call.devirtualized=shape-candidate
// Expect llvm metadata contains: bpp.ssa.inline.escape_summary=caller-visible
// Expect llvm metadata contains: bpp.ssa.inline.memory_effect=caller-visible
// Expect exit code: 0

func o1_inline_add(a: u64, b: u64) -> u64 {
    return a + b;
}

func o1_inline_const() -> u64 {
    return 7;
}

func o1_inline_recursive_guard(n: u64) -> u64 {
    if (n == 0) {
        return 1;
    }
    return n * o1_inline_recursive_guard(n - 1);
}

func main() -> u64 {
    var x: u64 = o1_inline_add(10, 32);
    var y: u64 = o1_inline_const();
    if (x + y != 49) {
        return 1;
    }
    if (o1_inline_recursive_guard(4) != 24) {
        return 2;
    }
    return 0;
}

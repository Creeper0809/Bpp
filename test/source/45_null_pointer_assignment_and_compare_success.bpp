struct NullPtrBox {
    public value: u64;
}

func null_guard_ptr(p: *NullPtrBox) -> u64 {
    if (p == null) { return 42; }
    return p.value;
}

func main() -> u64 {
    var src: [3]u64;
    src[0] = 10;
    src[1] = 20;
    src[2] = 30;
    var dst: [3]u64 = src;
    if (dst[0] != 10 || dst[1] != 20 || dst[2] != 30) { return 1; }
    src[1] = 99;
    if (dst[1] != 20) { return 2; }

    var p: *NullPtrBox = null;
    if (p != null) { return 10; }
    if (null_guard_ptr(p) != 42) { return 11; }

    var q: *NullPtrBox = new NullPtrBox { 42 };
    if (q == null) { return 12; }
    if (null_guard_ptr(q) != 42) { return 13; }

    var arr: [3]u64;
    arr[0] = 10;
    arr[1] = 20;
    arr[2] = 30;
    var live_ptr: *u64 = &arr[0];
    var null_ptr: *u64 = null;
    if (live_ptr?[1] != 20) { return 20; }
    if (null_ptr?[2] != 0) { return 21; }
    return 0;
}

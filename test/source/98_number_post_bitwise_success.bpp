// LLVM Build: true
// Mode: ssa
// Opt: O0,O1
// Expect exit code: 0

func pow2_number_case98(exp: u64) -> number {
    var x: number = 1;
    for (var i: u64 = 0; i < exp; i = i + 1) {
        x = x + x;
    }
    return x;
}

func main() -> u64 {
    var big: number = pow2_number_case98(90);
    var qbig: number = big / 8;
    var p87: number = pow2_number_case98(87);
    if (qbig != p87) { return 1; }
    var rbig: number = big % 8;
    if (rbig != 0) { return 2; }
    var big_or: number = big | 1;
    if ((big_or - big) != 1) { return 3; }
    var big_and: number = big_or & big;
    if (big_and != big) { return 4; }

    var big_shr: number = big >> 70;
    var p20: number = pow2_number_case98(20);
    if (big_shr != p20) { return 5; }
    var big_shl: number = p20 << 70;
    if (big_shl != big) { return 6; }
    var bitnot_identity: number = (~big) + big;
    if (bitnot_identity != -1) { return 7; }

    var s_big: u64 = big.to_str();
    var parsed_big: number = number_from_str(s_big, 28);
    if (parsed_big != big) { return 8; }

    var checked_i64: i64 = 0;
    if (big.to_i64_checked(&checked_i64) != 0) { return 9; }
    return 0;
}

// LLVM Build: true
// Covers: LLVM inline asm local memory operands, register aliases, repeated clobber stores
// Expect exit code: 0

func asm_multi_local_store() -> i64 {
    var left: i64 = 0;
    var right: i64 = 0;
    alias r10: lhs;
    alias r8: rhs;
    asm {
        mov lhs, 4
        mov [rbp-8], lhs
        mov rhs, 7
        mov [rbp-16], rhs
    }
    return left * 10 + right;
}

func asm_rewrite_same_reg() -> i64 {
    var first: i64 = 0;
    var second: i64 = 0;
    alias r11: scratch;
    asm {
        mov scratch, 3
        mov [rbp-8], scratch
        mov scratch, 9
        mov [rbp-16], scratch
    }
    return first * 10 + second;
}

func main() -> u64 {
    if (asm_multi_local_store() != 47) { return 1; }
    if (asm_rewrite_same_reg() != 39) { return 2; }
    return 0;
}

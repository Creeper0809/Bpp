// Covers: O2 whole-program IPA summaries and recursive conservative handling
// Mode: ssa
// Opt: O2
// Compiler args: -O2
// LLVM Build: true
// Expect llvm metadata contains: bpp.ssa.ipa.engine=whole-program-summary
// Expect llvm metadata contains: bpp.ssa.ipa.callgraph=direct-indirect-scc
// Expect llvm metadata contains: bpp.ssa.ipa.effects=pure-readonly-alloc-escape-tag-throw
// Expect llvm metadata contains: bpp.ssa.ipa.recursive=conservative-component
// Expect llvm metadata contains: bpp.ssa.ipa.candidates=constprop-stacknew-sink
// Expect llvm metadata contains: bpp.ssa.ipa.cache=summary-serialization-boundary
// Expect llvm metadata contains: ipa_engine=1
// Expect llvm metadata contains: ipa_recursive=
// Expect exit code: 0

func o2_ipa_leaf(x: u64) -> u64 {
    return x + 3;
}

func o2_ipa_recur(n: u64) -> u64 {
    if (n == 0) { return 0; }
    return 1 + o2_ipa_recur(n - 1);
}

func o2_ipa_probe(seed: u64) -> u64 {
    var tagged_value: u64 = bpp_tag_pack(4096, BPP_TAG_LIFE_YOUNG, BPP_TAG_OWN_UNIQUE, BPP_TAG_STORAGE_HEAP, BPP_TAG_BARRIER_CLEAN, BPP_TAG_SHAPE_U64, 1);
    var a: u64 = o2_ipa_leaf(seed);
    var b: u64 = o2_ipa_recur(3);
    if (bpp_tag_shape_raw(tagged_value) != BPP_TAG_SHAPE_U64) { return 1; }
    if (a + b != seed + 6) { return 2; }
    return 0;
}

func main() -> u64 {
    return o2_ipa_probe(7);
}

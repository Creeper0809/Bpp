// Expect compile fail: 1
// Expect error contains: declared complexity underestimates inferred complexity

@[complexity(time="O(n)", space="O(1)")]
@[constraints(n=1024)]
func declared_underestimate_fail(n: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        var j: u64 = 0;
        while (j < n) {
            acc += ((i + j) & 1);
            j += 1;
        }
        i += 1;
    }
    return acc;
}

func main() -> u64 {
    return declared_underestimate_fail(8);
}

// Expect compile fail: 1
// Expect error contains: declared complexity underestimates inferred space complexity

@[complexity(time="O(log n)", space="O(1)")]
@[constraints(n=4096)]
func declared_space_underestimate_fail(n: u64) -> u64 {
    if (n <= 1) { return 1; }
    return declared_space_underestimate_fail(n >> 1) + 1;
}

func main() -> u64 {
    return declared_space_underestimate_fail(1024);
}

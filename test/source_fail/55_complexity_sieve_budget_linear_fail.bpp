// Expect compile fail: 1
// Expect error contains: complexity budget violated on function

@[complexity_budget(time="O(n)", space="O(n)")]
func sieve_budget_should_fail(n: u64) -> u64 {
    var mark: [1025]u8;
    var i: u64 = 2;
    var cnt: u64 = 0;
    while (i * i <= n) {
        if (mark[i] == 0) {
            var j: u64 = i * i;
            while (j <= n) {
                mark[j] = 1;
                j += i;
            }
        }
        i += 1;
    }
    while (i <= n) {
        if (mark[i] == 0) { cnt += 1; }
        i += 1;
    }
    return cnt;
}

func main() -> u64 {
    return sieve_budget_should_fail(1000);
}

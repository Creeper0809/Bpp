// Expect compile fail: 1
// Expect error contains: complexity space budget violated

@[complexity(time="O(log n)", space="O(log n)")]
@[complexity_budget(time="O(log n)", space="O(1)")]
@[constraints(n=4096)]
func space_budget_violation_fail(n: u64) -> u64 {
    if (n <= 1) { return 1; }
    return space_budget_violation_fail(n >> 1) + 1;
}

func main() -> u64 {
    return space_budget_violation_fail(1024);
}

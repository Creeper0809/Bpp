// Expect compile fail: 1
// Expect error contains: complexity budget violated

@[complexity(time="O(n^3)", space="O(1)")]
@[complexity_budget(time="O(n^2)", space="O(1)")]
func cubic_kernel(n: u64) -> u64 {
    var acc: u64 = 0;
    var i: u64 = 0;
    while (i < n) {
        var j: u64 = 0;
        while (j < n) {
            var k: u64 = 0;
            while (k < n) {
                acc = acc + ((i + j + k) & 1);
                k = k + 1;
            }
            j = j + 1;
        }
        i = i + 1;
    }
    return acc;
}

func main() -> u64 {
    return cubic_kernel(4);
}

// Covers: compile-fail when magic override signature is invalid without explicit trait
// Expect compile fail: 1
// Expect error contains: magic override signature mismatch

struct BrokenMagic {
    public v: u64;
}

impl BrokenMagic {
    @[override]
    public func to_str(self: *BrokenMagic, extra: u64) -> u64 {
        return extra + self.v;
    }
}

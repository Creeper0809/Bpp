@[constraints(n=1048576)]
func polylog_sublinear_budget_fail(n: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i * i < n) {
        acc += i & 1;
        i += 1;
    }
    return acc;
}

func main() -> u64 {
    return polylog_sublinear_budget_fail(1024);

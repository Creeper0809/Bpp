// Expect compile fail: 1
// Expect error contains: complexity budget violated on function

@[complexity_budget(time="O(log n)", space="O(1)")]
@[constraints(n=1048576)]
func polylog_budget_fail(n: u64) -> u64 {
    var acc: u64 = 0;
    for (var i: u64 = 1; i < n; i = i << 1) {
        for (var j: u64 = 1; j < n; j = j << 1) {
            acc += (i & j) & 1;
        }
    }
    return acc;
}

func main() -> u64 {
    return polylog_budget_fail(1024);
}

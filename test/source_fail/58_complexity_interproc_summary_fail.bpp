// Expect compile fail: 1
// Expect error contains: complexity budget violated on function

@[complexity(time="O(n)", space="O(1)")]
@[constraints(n=4096)]
func helper_linear_fail(n: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        acc += (i & 1);
        i += 1;
    }
    return acc;
}

@[complexity_budget(time="O(n)", space="O(1)")]
@[constraints(n=512)]
func caller_interproc_budget_fail(n: u64) -> u64 {
    var i: u64 = 0;
    var acc: u64 = 0;
    while (i < n) {
        acc += helper_linear_fail(n);
        i += 1;
    }
    return acc;
}


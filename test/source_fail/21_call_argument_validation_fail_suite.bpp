// Covers: call argument validation and variadic parameter declaration diagnostics

//=== CASE 116_unknown_named_argument_on_free_function_fail
// Expect compile fail: 1
// Expect error contains: unknown named argument

func addx_case116(a: u64, b: u64 = 1) -> u64 {
    return a + b;
}

func main() -> u64 {
    return addx_case116(a: 1, c: 2);
}
//=== END

//=== CASE 123_unknown_named_argument_on_instance_method_fail
// Expect compile fail: 1
// Expect error contains: unknown named argument

struct BoxFail123 {
    public v: u64;
}

impl BoxFail123 {
    public func set(self: *BoxFail123, a: u64, b: u64) -> u64 {
        self.v = a + b;
        return self.v;
    }
}

func main() -> u64 {
    var b: BoxFail123 = BoxFail123 { 0 };
    return b.set(c: 2, a: 1);
}
//=== END


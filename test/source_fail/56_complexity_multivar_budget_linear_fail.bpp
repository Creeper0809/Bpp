// Expect compile fail: 1
// Expect error contains: complexity budget violated on function

@[complexity_budget(time="O(v)", space="O(1)")]
@[constraints(v=100000, e=200000)]
func graph_linear_budget_fail(v: u64, e: u64) -> u64 {
    var acc: u64 = 0;
    var i: u64 = 0;
    while (i < v) {
        acc += (i & 1);
        i += 1;
    }
    var j: u64 = 0;
    while (j < e) {
        acc += (j & 1);
        j += 1;
    }
    return acc;
}

func main() -> u64 {
    return graph_linear_budget_fail(10, 20);
}
